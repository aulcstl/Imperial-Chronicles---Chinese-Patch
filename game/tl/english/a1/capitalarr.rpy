    # mc "Я уже чувствую себя гораздо менее вонючим."
    mc "闻起来已经好多了，不那么臭了。"

# game/a1/capitalarr.rpy:110
translate english cap_arr2_97d1ca65:

    # mom "Это хорошо. Нужно еще успеть..."
    mom "好极了。咱们还得抓紧时间……"

# game/a1/capitalarr.rpy:111
translate english cap_arr2_fd053bbe:

    # mc "Успеть что?"
    mc "抓紧什么？"

# game/a1/capitalarr.rpy:113
translate english cap_arr2_ca33f883:

    # mom "Выбрать тебе одежду."
    mom "给你挑衣裳。"

# game/a1/capitalarr.rpy:114
translate english cap_arr2_997b8c5b:

    # mc "К чему такая спешка?"
    mc "干嘛那么赶？"

# game/a1/capitalarr.rpy:115
translate english cap_arr2_13d27b2d:

    # mom "[mename]...."
    mom "[mename]...."

# game/a1/capitalarr.rpy:116
translate english cap_arr2_62bdb3ef:

    # mc "Да?"
    mc "怎么？"

# game/a1/capitalarr.rpy:118
translate english cap_arr2_1d91441d:

    # mom "Достаточно. Вы свободны."
    mom "可以了。你们下去吧。"

