    new "别分心"

    # game/a1/capitalarr.rpy:170
    old "Она очень красивая"
    new "她非常漂亮"

    # game/a1/capitalarr.rpy:280
    old "[mom]"
    new "[mom]"

    # game/a1/capitalarr.rpy:280
