translate english tavernroad2_0f1a6b5c:

    # elin "Ты сама установила правила. Проваливай."
    elin "规矩是你自己定的。快走吧。"

# game/a1/tavern_road.rpy:558
translate english tavernroad2_3951e6ef:

    # cass "Приятного всем сна."
    cass "祝所有人好梦。"

# game/a1/tavern_road.rpy:562
translate english tavernroad3_77c55f49:

    # cass "Мы меняем правила!"
    cass "我们要改规矩！"

# game/a1/tavern_road.rpy:563
translate english tavernroad3_25522e36:

    # elin "Что такое? Игра пошла не так как ты хотела?"
    elin "怎么了？游戏没照你设想的发展吗？"

# game/a1/tavern_road.rpy:564
translate english tavernroad3_4619619f:

    # cass "Вы поразительно скучные, постоянно выбираете вопросы."
    cass "你们无聊得出奇，老是选问题。"

# game/a1/tavern_road.rpy:565
translate english tavernroad3_719c4415:

    # elin "Разве игра не предоставляет выбор?"
    elin "游戏不是本来就可以选吗？"

# game/a1/tavern_road.rpy:566
translate english tavernroad3_38bcdc89:

    # cass "Вы им злоупотребляете."
    cass "你们滥用这个选择。"

# game/a1/tavern_road.rpy:567
translate english tavernroad3_e3a37ed4:

    # mc "И что?"
    mc "那又怎样？"

# game/a1/tavern_road.rpy:568
translate english tavernroad3_8ae3517d:

    # cass "Менем правила. Теперь только желания. Если человек отказывается, то тот, кто загадал желание делает его сам."
    cass "改规矩了。从现在起，只能提要求。要是有人拒绝，那提出要求的人就自己来做。"

# game/a1/tavern_road.rpy:569
translate english tavernroad3_0ec08cb6:

    # elin "Отлично, раз уж ты меняешь правило ты первая желание и выполняешь верно? Помассажируй мне ноги."
    elin "好极了，既然你改了规矩，那就由你第一个来按要求完成，对吗？给我按摩脚。"

# game/a1/tavern_road.rpy:570
translate english tavernroad3_25268591:

    # cass "...Я могу перенаправить это желание тебе..."
    cass "……我可以把这件事推回给你……"

# game/a1/tavern_road.rpy:571
translate english tavernroad3_40d2d895:

    # elin "Конечно. И проиграешь. Я готова помассажировать тебе ноги, они выглядят чистыми, в отличие от моих, я две недели в дороге..."
    elin "可以啊。那你就输了。我很乐意给你按摩脚，你的脚看着很干净，不像我，赶了两周的路……"

# game/a1/tavern_road.rpy:572
translate english tavernroad3_7eeb2a7a:

    # mc "Ну так что?"
    mc "所以呢？"

# game/a1/tavern_road.rpy:574
translate english tavernroad3_7d80677c:

    # elin "Вот так, не пропускай ни единого пальчика."
    elin "就这样，一根脚趾也别漏下。"

# game/a1/tavern_road.rpy:575
translate english tavernroad3_d61cca91:

    # cass "Ты выглядишь поразительно счастливой."
    cass "看你样子，简直开心得要命。"

# game/a1/tavern_road.rpy:576
translate english tavernroad3_bf5a6b61:

    # elin "Ты массажируешь мне ноги, с чего бы мне не быть счастливой."
    elin "你在给我按摩脚，我有什么理由不开心呢。"

# game/a1/tavern_road.rpy:577
translate english tavernroad3_b98c47ae:

    # cass "С того что следующее желание для тебя."
    cass "哦，那下一个要求就是对你提了。"

# game/a1/tavern_road.rpy:578
translate english tavernroad3_f390e21f:

    # elin "Я могу всегда могу отказаться и вернуть его тебе."
    elin "我随时可以拒绝，再转回给你。"

# game/a1/tavern_road.rpy:579
translate english tavernroad3_b10d5bcd:

    # cass "Хм..."
    cass "嗯……"

# game/a1/tavern_road.rpy:580
translate english tavernroad3_384d37af:

    # elin "Ты загнала сама себя в ловушку. Нет чего-то такого что бы я не сделала, но сделала бы ты."
    elin "你这是把自己绕进陷阱了。没有什么事是我做不了，而你却能的。"

# game/a1/tavern_road.rpy:581
translate english tavernroad3_eb465988:

    # cass "Да что ты?"
    cass "哦，是吗？"

# game/a1/tavern_road.rpy:583
translate english tavernroad3_9cceb8f9:

    # cass "[mename]."
    cass "[mename]."

# game/a1/tavern_road.rpy:584
translate english tavernroad3_d65ff2b8:

    # elin "М?"
    elin "嗯？"

# game/a1/tavern_road.rpy:585
translate english tavernroad3_7352537b:

    # cass "Поцелуй его. Глубоко и с чувством."
    cass "去亲他。深情地、投入地亲。"

# game/a1/tavern_road.rpy:587
translate english tavernroad3_6b6e7570:

    # elin "Что?"
    elin "什么？"

# game/a1/tavern_road.rpy:588
translate english tavernroad3_7e3b712d:

    # cass "Ты всегда можешь отказаться и это сделаю я."
    cass "你完全可以拒绝，那就由我来亲。"

# game/a1/tavern_road.rpy:589
translate english tavernroad3_056d248b:

    # mc "А ты хитрая..."
    mc "你可真狡猾……"

# game/a1/tavern_road.rpy:590
translate english tavernroad3_53387a0e:

    # cass "Я себя не загоняю в ловушки, [elin], я аккуратно провожу туда за руку своих врагов."
    cass "我才不会把自己绕进陷阱呢，[elin]，我是牵着敌人的手，仔仔细细地带他们进去。"

# game/a1/tavern_road.rpy:591
translate english tavernroad3_56f041e9:

    # elin "Это...это как-то..."
    elin "这……这有点……"

# game/a1/tavern_road.rpy:592
translate english tavernroad3_fde6b8a1:

    # cass "Просто откажись и я мой язычок окажется у твоего братика во рту."
    cass "拒绝就行了，然后我的小舌头就会出现在你哥哥嘴里。"

# game/a1/tavern_road.rpy:594
translate english tavernroad3_a85601ab:

    # mc "Ну так что, [elin]?"
    mc "所以呢，[elin]？"

# game/a1/tavern_road.rpy:595
translate english tavernroad3_0458eed5:

    # elin "{size=-6}Я сделаю это.{/size}"
    elin "{size=-6}我来。{/size}"

# game/a1/tavern_road.rpy:596
translate english tavernroad3_c2487b65:

    # cass "Что?"
    cass "什么？"

# game/a1/tavern_road.rpy:597
translate english tavernroad3_fcb4cb84:

    # elin "Я сделаю это."
    elin "我说我来。"

# game/a1/tavern_road.rpy:598
translate english tavernroad3_0b84041e:

    # cass "Что-то не верится."
    cass "有点不敢相信。"

# game/a1/tavern_road.rpy:599
translate english tavernroad3_7f6523fe:

    # mc "Ты уверена?"
    mc "你确定吗？"

# game/a1/tavern_road.rpy:600
translate english tavernroad3_3877aca5:

    # elin "Да."
    elin "确定。"

# game/a1/tavern_road.rpy:601
translate english tavernroad3_176a0521:

    # cass "Ну так целуйтесь, чего ждете?"
    cass "那就亲啊，还等什么？"

# game/a1/tavern_road.rpy:602
translate english tavernroad3_ea7a509e:

    # mc "[elin]?"
    mc "[elin]?"

# game/a1/tavern_road.rpy:603
translate english tavernroad3_5b16b612:

    # elin "Дай немного собраться с мыслями...."
    elin "让我定下神……"

# game/a1/tavern_road.rpy:604
translate english tavernroad3_ab3a03bb:

    # cass "Ну?"
    cass "嗯？"

# game/a1/tavern_road.rpy:606
translate english tavernroad3_558141ab:

    # cass "Ой ну надо же."
    cass "哎哟，可真行。"

# game/a1/tavern_road.rpy:607
translate english tavernroad3_2e981d47:

    # cass "Как мило..."
    cass "多甜蜜啊……"

# game/a1/tavern_road.rpy:608
translate english tavernroad3_bf991bd8:

    # cass "Братско-сестринская любовь."
    cass "真是兄妹情深。"

# game/a1/tavern_road.rpy:609
translate english tavernroad3_70ba0b08:

    # cass "Стоп!"
    cass "停！"

# game/a1/tavern_road.rpy:611
translate english tavernroad3_4f7b344e:

    # mc "Ну что?"
    mc "怎么了？"

# game/a1/tavern_road.rpy:612
translate english tavernroad3_aa70b4de:

    # cass "Я же сказала - ГЛУБОКИЙ И ЧУВСТВЕННЫЙ поцелуй, че вы целуетесь как будто вы [brother] и [sister]? Хахахха."
    cass "我说了——要'深情地、投入地'亲，你们两个亲起来怎么就跟普通的[brother]和[sister]似的？哈哈哈。"

# game/a1/tavern_road.rpy:613
translate english tavernroad3_85533cc5:

    # elin "Я не умею..."
    elin "我不太会……"

# game/a1/tavern_road.rpy:614
translate english tavernroad3_da2de898:

    # cass "Не поняла?"
    cass "什么？"

# game/a1/tavern_road.rpy:615
translate english tavernroad3_9d22a104:

    # elin "Что ты имеешь в виду под глубоким и чувственным поцелуем?"
    elin "你说的'深情地、投入地亲'到底是什么意思？"

# game/a1/tavern_road.rpy:616
translate english tavernroad3_4a0993b0:

    # cass "Как минимум то, что ваши губы не должны едва касаться друг друга. Где чувства, где близкий контакт? Где язык в конце концов."
    cass "至少，你们的嘴唇不该只是轻轻碰一下。感情在哪儿，亲密接触在哪儿？舌头又在哪儿？"

# game/a1/tavern_road.rpy:617
translate english tavernroad3_c2d11ccf:

    # elin "[mename]? Можно я попробую еще раз?"
    elin "[mename]？我可以再试一次吗？"

# game/a1/tavern_road.rpy:618
translate english tavernroad3_a31537d4:

    # mc "Конечно, [elin]."
    mc "当然了，[elin]。"

# game/a1/tavern_road.rpy:620
translate english tavernroad3_0bf1e6ce:

    # cass "Вот это уже лучше!"
    cass "这才像样嘛！"

# game/a1/tavern_road.rpy:621
translate english tavernroad3_cd88a2da:

    # cass "Гораздо лучше. Тут и чувство и язык кажется даже есть."
    cass "好太多了。有感情了，连舌头似乎都伸出来了。"

# game/a1/tavern_road.rpy:622
translate english tavernroad3_5547ba48:

    # cass "Да. Так мне определенно нравится."
    cass "对。这样子才合我心意。"

# game/a1/tavern_road.rpy:623
translate english tavernroad3_f560d5f8:

    # cass "Продолжайте. [elin] возьми его за голову руками и..."
    cass "继续啊。[elin]，用手抱住他的头……"

# game/a1/tavern_road.rpy:625
translate english tavernroad3_771f738f:

    # mc "Ты можешь хоть на секунду заткнуться? Твои комментарии мешают."
    mc "你能不能哪怕安静一秒钟？你的点评太让人分心了。"

# game/a1/tavern_road.rpy:626
translate english tavernroad3_248602be:

    # cass "Она не умеет и я просто ей помогаю, что не так?"
    cass "她不会亲，我只是帮帮她，有什么不对？"

# game/a1/tavern_road.rpy:627
translate english tavernroad3_f8852bf9:

    # mc "Может она и не умеет, но у нее отлично получается."
    mc "也许她是不会，但她亲得真好。"

# game/a1/tavern_road.rpy:628
translate english tavernroad3_9c6de5fa:

    # elin "Правда?"
    elin "真的吗？"

# game/a1/tavern_road.rpy:630
translate english tavernroad3_d2547518:

    # mc "Да. Ты отлично целуешься, [elin], мне очень понравилось. "
    mc "真的。你亲得非常好，[elin]，我很喜欢。"

# game/a1/tavern_road.rpy:631
translate english tavernroad3_18c2d5cd:

    # elin "Мне...мне тоже, [mename]..."
    elin "我……我也很喜欢，[mename]……"

# game/a1/tavern_road.rpy:632
translate english tavernroad3_3e32a3cd:

    # cass "Как мило. Мы все еще играем не забыли?"
    cass "多可爱。我们还在游戏里，没忘吧？"

# game/a1/tavern_road.rpy:633
translate english tavernroad3_2b61dbaa:

    # mc "Не забыли, просто [elin] очень неловко из-за твоего задания и я хочу ее поддержать."
    mc "没忘，只是[elin]对你的任务很不自在，我想鼓励鼓励她。"

# game/a1/tavern_road.rpy:634
translate english tavernroad3_1242153a:

    # elin "Спасибо."
    elin "谢谢。"

# game/a1/tavern_road.rpy:635
translate english tavernroad3_adb7659b:

    # cass "Она могла отказаться."
    cass "她也可以拒绝的。"

# game/a1/tavern_road.rpy:636
translate english tavernroad3_a66eae0e:

    # mc "Сейчас желания для меня?"
    mc "现在是对我提要求了吗？"

# game/a1/tavern_road.rpy:638
translate english tavernroad3_cac892f7:

    # elin "Да. Но разве мы не должны были загадывать желания по кругу?"
    elin "对。但我们难道不该轮流提要求吗？"

# game/a1/tavern_road.rpy:639
translate english tavernroad3_a7ca534e:

    # cass "Действительно."
    cass "确实。"

# game/a1/tavern_road.rpy:640
translate english tavernroad3_ba3f449c:

    # mc "О чем вы?"
    mc "你们在说什么？"

# game/a1/tavern_road.rpy:641
translate english tavernroad3_9ccbb58e:

    # cass "Мы загадали желание друг другу. Значит непонятно кто должен загадывать желание тебе."
    cass "我俩互相给对方提了要求。所以不清楚下一个该谁来向你提要求了。"

# game/a1/tavern_road.rpy:643
translate english tavernroad3_235c7667:

    # cass "Хотя знаете, есть у меня одна идейка."
    cass "不过呢，我倒是有个主意。"

# game/a1/tavern_road.rpy:644
translate english tavernroad3_0a4e0ec7:

    # mc "Какая?"
    mc "什么主意？"

# game/a1/tavern_road.rpy:645
translate english tavernroad3_ae34bfa2:

    # cass "Слышали про танец клинков?"
    cass "听说过'剑舞'吗？"

# game/a1/tavern_road.rpy:646
translate english tavernroad3_0861f199:

    # mc "Ты хочешь чтобы я дрался с вами с клинками?"
    mc "你是想让我跟你们俩比剑？"

# game/a1/tavern_road.rpy:647
translate english tavernroad3_7c873eff:

    # cass "Нет. Я собираюсь предложить танец языков."
    cass "不。我打算提议来场'舌舞'。"

# game/a1/tavern_road.rpy:649
translate english tavernroad3_f679764a:

    # mc "Звучит потрясно."
    mc "听着真棒。"

# game/a1/tavern_road.rpy:650
translate english tavernroad3_4a664c3e:

    # elin "И что надо делать?"
    elin "要怎么做？"

# game/a1/tavern_road.rpy:651
translate english tavernroad3_bbcd55bb:

    # cass "Целоваться. Кто сделает это хуже тот и проиграл."
    cass "亲吻。亲得较差的人就算输。"

# game/a1/tavern_road.rpy:652
translate english tavernroad3_b2e86bc0:

    # mc "А я проиграть не могу?"
    mc "那我就不可能输了吗？"

# game/a1/tavern_road.rpy:653
translate english tavernroad3_73ea4afb:

    # cass "Можешь. Если не выявишь победителя."
    cass "也可能输。如果你分不出谁胜谁负就算你输。"

# game/a1/tavern_road.rpy:654
translate english tavernroad3_cab25395:

    # mc "Кто начинает?"
    mc "谁先来？"

# game/a1/tavern_road.rpy:655
translate english tavernroad3_8afbc9f4:

    # cass "Ну конечно я."
    cass "那当然是我。"

# game/a1/tavern_road.rpy:657
translate english tavernroad3_21ddb096:

    # mc "{i}Такие игры мне по душе.{/i}"
    mc "{i}这种游戏才合我的胃口。{/i}"

# game/a1/tavern_road.rpy:658
translate english tavernroad3_c00edfdf:

    # mc "{i}Черт, целоваться с [elin] было приятно, но и [cass] дело знает.{/i}"
    mc "{i}该死，跟[elin]接吻是很舒服，但[cass]也很了解这一套。{/i}"

# game/a1/tavern_road.rpy:659
translate english tavernroad3_9cac5a00:

    # mc "{i}Это очень приятно.{/i}"
    mc "{i}这真是太舒服了。{/i}"

# game/a1/tavern_road.rpy:660
translate english tavernroad3_a4bc2e1d:

    # elin "Ну хватит!"
    elin "喂，够了！"

# game/a1/tavern_road.rpy:662
translate english tavernroad3_3e6fc7be:

    # elin "Моя очередь!"
    elin "轮到我了！"

# game/a1/tavern_road.rpy:663
translate english tavernroad3_67addfa2:

    # cass "Не жадничай."
    cass "别这么小气。"

# game/a1/tavern_road.rpy:664
translate english tavernroad3_31bbeccb:

    # elin "Я не жадничаю, вы делаете это слишком долго."
    elin "我才没小气，是你们亲太久了。"

# game/a1/tavern_road.rpy:665
translate english tavernroad3_4e5d89b8:

    # cass "Ладно-ладно, валяй."
    cass "好啦好啦，换你来。"

# game/a1/tavern_road.rpy:666
translate english tavernroad3_aae63dff:

    # elin "[mename]...."
    elin "[mename]...."

# game/a1/tavern_road.rpy:668
translate english tavernroad3_24efffc0:

    # mc "{i}[elin] делает это гораздо сосредоточенней.{/i}"
    mc "{i}[elin]亲得专注多了。{/i}"

# game/a1/tavern_road.rpy:669
translate english tavernroad3_7b6e88d3:

    # mc "{i}Будто старается не ошибиться.{/i}"
    mc "{i}就像生怕出什么错。{/i}"

# game/a1/tavern_road.rpy:670
translate english tavernroad3_f1dedb3c:

    # mc "{i}Из-за этого она больше напряжена.{/i}"
    mc "{i}这样她也就更紧张。{/i}"

# game/a1/tavern_road.rpy:671
translate english tavernroad3_bd1d2dee:

    # mc "{i}Но и старается больше.{/i}"
    mc "{i}但也因此更加努力。{/i}"

# game/a1/tavern_road.rpy:672
translate english tavernroad3_82733d79:

    # cass "Время кончилось, любовнички."
    cass "时间到，小情人们。"

# game/a1/tavern_road.rpy:674
translate english tavernroad3_9808ca15:

    # cass "[mename]. Твой вердикт?"
    cass "[mename]。你的结论？"

# game/a1/tavern_road.rpy:675
translate english tavernroad3_1f7340a8:

    # mc "Это будет сложно..."
    mc "这实在很难……"

# game/a1/tavern_road.rpy:676
translate english tavernroad3_5a49dc89:

    # elin "Я лучше это делаю."
    elin "我可亲得比较好。"

# game/a1/tavern_road.rpy:677
translate english tavernroad3_9a0ff339:

    # cass "Ого, да ты осмелела, [sist]."
    cass "哇哦，你胆子大起来了，[sist]。"

# game/a1/tavern_road.rpy:678
translate english tavernroad3_5b4e4fc7:

    # mc "Вы обе целуетесь потрясно."
    mc "你们两个吻得都棒极了。"

# game/a1/tavern_road.rpy:679
translate english tavernroad3_ef92ad80:

    # elin "Тебе нужно выбрать."
    elin "你必须选一个。"

# game/a1/tavern_road.rpy:680
translate english tavernroad3_faaaaed1:

