    mc "{i}这整个情况弄得我很兴奋。{/i}"

# game/a1/way_to_home1.rpy:235
translate english ala_forest3_86b1f554:

    # mc "{i}Надесюь вы и вправду спите.{/i}"
    mc "{i}希望您真的睡着了。{/i}"

# game/a1/way_to_home1.rpy:237
translate english ala_forest3_c5caf12e:

    # mc "{i}Я слышал у эльфов крепкий сон.{/i}"
    mc "{i}我听说精灵睡得沉。{/i}"

# game/a1/way_to_home1.rpy:238
translate english ala_forest3_ec7e81a8:

    # mc "{i}Надеюсь достаточно крепкий чтобы не заметить что я тут устроил.{/i}"
    mc "{i}希望沉得注意不到我在这儿搞什么。{/i}"

# game/a1/way_to_home1.rpy:239
translate english ala_forest3_34be55f7:

    # mc "Леди [alaina]?"
    mc "[alaina]小姐？"

# game/a1/way_to_home1.rpy:240
translate english ala_forest3_89a79304_3:

    # ala "..."
    ala "..."

# game/a1/way_to_home1.rpy:242
translate english ala_forest3_5815ebae:

    # mc "{i}Что я делаю?{/i}"
    mc "{i}我在干什么？{/i}"

# game/a1/way_to_home1.rpy:243
translate english ala_forest3_28b7fc73:

    # mc "{i}Кажется две недели в дороге повлияли на меня не лучшим образом.{/i}"
    mc "{i}看来路上这两周对我的影响真不怎么样。{/i}"

# game/a1/way_to_home1.rpy:244
translate english ala_forest3_9b189610:

    # mc "{i}Мой разум помутился.{/i}"
    mc "{i}我的脑子糊涂了。{/i}"

# game/a1/way_to_home1.rpy:245
translate english ala_forest3_c0fc9d79:

    # mc "{i}Иначе обьяснить какого хрена я делаю я не могу.{/i}"
    mc "{i}不然我无法解释我他妈在干嘛。{/i}"

# game/a1/way_to_home1.rpy:246
translate english ala_forest3_891ff5f4:

    # mc "{i}Как и не могу остановиться.{/i}"
    mc "{i}也停不下来。{/i}"

# game/a1/way_to_home1.rpy:247
translate english ala_forest3_5b478469:

    # mc "{i}О боги!{/i}"
    mc "{i}哦神明！{/i}"

# game/a1/way_to_home1.rpy:249
translate english ala_forest3_ce3b233d:

    # mc "Ах!"
    mc "啊！"

# game/a1/way_to_home1.rpy:250
translate english ala_forest3_6c6e6d38:

    # mc "Пиздец!"
    mc "我靠！"

# game/a1/way_to_home1.rpy:252
translate english ala_forest3_dada827f:

    # mc "{i}Это было слишком громко!{/i}"
    mc "{i}那声太响了！{/i}"

# game/a1/way_to_home1.rpy:253
translate english ala_forest3_e563aec6:

    # mc "Леди [alaina]? Вы спите?"
    mc "[alaina]小姐？您睡着了吗？"

# game/a1/way_to_home1.rpy:254
translate english ala_forest3_89a79304_4:

    # ala "..."
    ala "..."

# game/a1/way_to_home1.rpy:256
translate english ala_forest3_a98a57a6:

    # mc "{i}Хвала богам. Поверить не могу, что я это сделал.{/i}"
    mc "{i}感谢神明。真不敢相信我这么做了。{/i}"

# game/a1/way_to_home1.rpy:257
translate english ala_forest3_9758f585:

    # mc "{i}Это определенно небезопасно, дрочить ногами своей учительницы магии, пока она спит.{/i}"
    mc "{i}用魔法老师的脚自慰，趁她睡觉，这绝对不安全。{/i}"

# game/a1/way_to_home1.rpy:258
translate english ala_forest3_baabd68c:

    # mc "{i}Надеюсь она действительно спит и не превратит меня в лягушку или что-то типо того.{/i}"
    mc "{i}希望她是真的睡着了，不会把我变成青蛙之类的东西。{/i}"

# game/a1/way_to_home1.rpy:260
translate english ala_forest3_26407275:

    # ala "[mename]..."
    ala "[mename]..."

# game/a1/way_to_home1.rpy:261
translate english ala_forest3_ac2fa0bc:

    # mc "Я...эм...не то что вы подумали...я просто..."
    mc "我……嗯……不是您想的那样……我只是……"

# game/a1/way_to_home1.rpy:262
translate english ala_forest3_8dbf536d:

    # ala "М? О чем ты? Можешь закрыть палатку? Становится холодновато. У меня что-то на ногах..."
    ala "嗯？你在说什么？能把帐篷门拉上吗？有点凉了。我脚上沾了什么……"

# game/a1/way_to_home1.rpy:263
translate english ala_forest3_d415b9bf:

    # mc "Да...что капает с дерева.... Сейчас я все вытру."
    mc "嗯……是树上滴下来的东西……我现在就擦掉。"

# game/a1/way_to_home1.rpy:264
translate english ala_forest3_07cd1d33:

    # ala "Ага. Спасибо, [mename]."
    ala "嗯。谢谢，[mename]。"

# game/a1/way_to_home1.rpy:265
translate english ala_forest3_a0c443cc:

    # mc "{i}Фух! Кажется пронесло!{/i}"
    mc "{i}呼！看来蒙混过关了！{/i}"

# game/a1/way_to_home1.rpy:269
translate english ala_forest3_f3869ce0:

    # mc "{i}В такой позе голова действительно перестала болеть.{/i}"
    mc "{i}这姿势头还真不疼了。{/i}"

# game/a1/way_to_home1.rpy:270
translate english ala_forest3_b06ce3e1:

    # mc "{i}Надо было давно так решать эту проблему.{/i}"
    mc "{i}早该这么解决这个问题的。{/i}"

# game/a1/way_to_home1.rpy:271
translate english ala_forest3_a5a68a34:

    # mc "{i}Никогда не думал что так уютно лежать между ног у женщины.{/i}"
    mc "{i}从没想过躺在女人腿间会这么舒服。{/i}"

# game/a1/way_to_home1.rpy:272
translate english ala_forest3_98896aa0:

    # mc "{i}Черт, я сейчас засну. Нужно вставать.{/i}"
    mc "{i}见鬼，我快睡着了。得起来了。{/i}"

# game/a1/way_to_home1.rpy:276
translate english forest_aker_chek_831b7ef3:

    # mc "Отдыхаешь?"
    mc "在休息？"

# game/a1/way_to_home1.rpy:277
translate english forest_aker_chek_28ea992c:

    # aker "Стою на страже вашего сна."
    aker "在守护您的睡眠。"

# game/a1/way_to_home1.rpy:278
translate english forest_aker_chek_bb97a26a:

    # mc "Сидишь."
    mc "你坐着呢。"

# game/a1/way_to_home1.rpy:279
translate english forest_aker_chek_98ffca55:

    # aker "Сижу. А что, хочешь чтобы я потренировался стоять целую ночь с мечом наготове? Собрался сделать меня королевским гвардейцем, когда станешь королем?"
    aker "坐着呢。怎么了，你想让我练练整夜握剑站岗？等你当上国王想让我做皇家侍卫？"

# game/a1/way_to_home1.rpy:280
translate english forest_aker_chek_64df9476:

    # mc "Ага. Но ты не переживай, я попрошу поставить к трону стул, чтобы не утомлять твои старые кости."
    mc "嗯。不过你别担心，我会让人在宝座旁放把椅子，省得累坏你的老骨头。"

# game/a1/way_to_home1.rpy:283
translate english forest_aker_chek_0435175b:

    # aker "Лучше назначь меня королевским палачом. Люблю, знаешь, рубить головы, а не охранять всяких стариков."
    aker "还是任命我做皇家刽子手吧。你知道，我喜欢砍头，不喜欢保护各种老头子。"

# game/a1/way_to_home1.rpy:284
translate english forest_aker_chek_a17669a7:

    # mc "Я вообще-то еще не старик."
    mc "我还不是老头子呢。"

# game/a1/way_to_home1.rpy:285
translate english forest_aker_chek_7b9831c4:

    # aker "Пока что нет. Но к тому моменту как твой старик отправится отдыхать в королевскую крипту, из тебя уже будет песок сыпаться."
    aker "暂时还不是。但等你老爸去皇家地窖长眠的时候，你身上都该掉渣了。"

# game/a1/way_to_home1.rpy:286
translate english forest_aker_chek_83cdb942:

    # mc "Есть варианты сесть на трон быстрее."
    mc "有更快坐上宝座的办法。"

# game/a1/way_to_home1.rpy:287
translate english forest_aker_chek_bf988cbe:

    # aker "Я же говорю, сделать меня палачом будет хорошей идеей..."
    aker "我说嘛，让我做刽子手就是个好主意……"

# game/a1/way_to_home1.rpy:288
translate english forest_aker_chek_ce3d1c43:

    # mc "Ладно, сторожи нас, кровожадная свинья, пойду посмотрю как там остальные."
    mc "行了，守着吧，你这嗜血的猪，我去看看其他人怎么样了。"

# game/a1/way_to_home1.rpy:291
translate english forest_aker_chek_8cf0554b:

    # aker "..."
    aker "..."

# game/a1/way_to_home1.rpy:292
translate english forest_aker_chek_0ddf0eac:

    # mc "Ты в порядке?"
    mc "你还好吗？"

# game/a1/way_to_home1.rpy:293
translate english forest_aker_chek_530f2984:

    # aker "Да. Просто хотел сказать тебе, что это пиздец как несправедливо, что ты отпустил ту воровку. Наверняка она сейчас дожирает мою лошадь где-нибудь в северных лесах."
    aker "还好。只是想告诉你，你放了那个女贼，真他妈不公平。没准她现在正在北方森林里啃我的马呢。"

# game/a1/way_to_home1.rpy:294
translate english forest_aker_chek_fe9acd41:

    # mc "Это было непростое решение, я не буду говорить почему я так сделал, но уверяю тебя - как только мы вернемся в столицу я куплю тебе лошадь."
    mc "这是个艰难的决定，我不会解释原因，但我向你保证——一回首都我就给你买匹马。"

# game/a1/way_to_home1.rpy:295
translate english forest_aker_chek_648cc7ba:

    # aker "Ага. Ладно."
    aker "啊哈。行吧。"

# game/a1/way_to_home1.rpy:296
translate english forest_aker_chek_73cea505:

    # mc "Обижайся сколько хочешь, но я тут принц и я принимаю решения. Пойду проведаю остальных."
    mc "你想气多久就气多久，但我在这儿是王子，我来做决定。我去看看其他人。"

# game/a1/way_to_home1.rpy:308
translate english vall_forest_2e68b671:

    # mc "Как тебе погодка? Отличная, да?"
    mc "天气不错，是吧？"

# game/a1/way_to_home1.rpy:309
translate english vall_forest_3d88951b:

    # vall "Ты за этим пришел? Спросить у меня как нравится ли мне приятный летний ветерок, пока я привязана к дереву?"
    vall "你过来就为这个？问我喜欢不喜欢这宜人的夏风，而我被绑在树上？"

# game/a1/way_to_home1.rpy:310
translate english vall_forest_4361ede3:

    # mc "Просто думал ты тут скучаешь и все такое."
    mc "我只是觉得你在这儿可能无聊什么的。"

# game/a1/way_to_home1.rpy:311
translate english vall_forest_000c8573:

    # vall "Отпусти меня и мне сразу станет очень весело."
    vall "放开我，我立刻就会很开心。"

# game/a1/way_to_home1.rpy:312
translate english vall_forest_844b0853:

    # mc "Это было бы неразумно с моей стороны, столько везти тебя в столицу, а потом просто отпустить. Может у тебя есть желание реалистичнее? Хочешь воды или еды?"
    mc "那我就太不明智了，大老远把你带到首都，然后直接放了你。也许你有更现实点的愿望？想要水或食物？"

# game/a1/way_to_home1.rpy:313
translate english vall_forest_2ea25eda:

    # vall "Хочу писать. Развяжи меня и дай мне пописать."
    vall "想尿尿。解开我，让我尿尿。"

# game/a1/way_to_home1.rpy:317
translate english vall_forest_5de324dc:

    # mc "Ладно. Пойдем."
    mc "好吧。走。"

# game/a1/way_to_home1.rpy:318
translate english vall_forest_592d79e6:

    # vall "Оу...спасибо."
    vall "哦……谢谢。"

# game/a1/way_to_home1.rpy:319
translate english vall_forest_0abad7f7:

    # mc "За что спасибо, ты еще не пописала."
    mc "谢什么，你还没尿呢。"

# game/a1/way_to_home1.rpy:320
translate english vall_forest_c0a8e964:

    # vall "..."
    vall "..."

# game/a1/way_to_home1.rpy:321
translate english vall_forest_c8975bb3:

    # mc "Только отойдем от лагеря немного."
    mc "稍微离营地远点。"

# game/a1/way_to_home1.rpy:324
translate english vall_forest_cfa57396:

    # mc "Разве Акер не водил тебя пописать пару часов назад?"
    mc "Aker几小时前不是带你尿过了吗？"

# game/a1/way_to_home1.rpy:325
translate english vall_forest_31c0a79c:

    # vall "И что? Эта сволочь держит мои руки связанными даже когда я писаю. Разве это не жестоко?"
    vall "那又怎样？那个混蛋连我尿尿都绑着手。这难道不残忍吗？"

# game/a1/way_to_home1.rpy:326
translate english vall_forest_ca0c0191:

    # mc "Он думает ты можешь сбежать, я думаю также."
    mc "他觉得你会逃跑，我也这么认为。"

# game/a1/way_to_home1.rpy:327
translate english vall_forest_b53a477d:

    # vall "Просто отведи меня пописать."
    vall "带我去尿尿就是了。"

# game/a1/way_to_home1.rpy:328
translate english vall_forest_fb5025cc:

    # mc "Чувствую в этом какую-то уловку. Думаю лучше доверить твои походы в туалет Акеру, он не даст тебе сбежать."
    mc "感觉这里有诈。我看还是让你交给Aker带去厕所吧，他不会让你跑掉。"

# game/a1/way_to_home1.rpy:329
translate english vall_forest_a454a48a:

    # vall "Сволочи..."
    vall "混蛋……"

# game/a1/way_to_home1.rpy:333
translate english vall_forest_6cf40cf3:

    # mc "Ну. Для пленницы поход в туалет это не право, а привилегия, ты так не считаешь?"
    mc "嗯。对俘虏来说，去厕所不是权利，而是特权，你不觉得吗？"

# game/a1/way_to_home1.rpy:334
translate english vall_forest_0ea41d0e:

    # vall "Что...что ты делаешь, ублюдок?"
    vall "你在……你在干什么，混蛋？"

# game/a1/way_to_home1.rpy:335
translate english vall_forest_f399712d:

    # mc "Не волнуйся, просто я немного соскучился по женскому теплу за время нашего путешествия."
    mc "别紧张，只是旅途中我有点想念女人的温暖了。"

# game/a1/way_to_home1.rpy:336
translate english vall_forest_1d55903c:

    # vall "Ну так иди и трахни свою сестру, дегенерат, а меня не трогай."
    vall "那去干你妹妹呀，你这变态，别碰我。"

# game/a1/way_to_home1.rpy:337
translate english vall_forest_589e78ae:

    # mc "Воу, что ты такая злая, я всего лишь немного тебя пощупал. Сейчас отведу тебя пописать."
    mc "哇，干嘛这么凶，我只是稍微摸了你一下。这就带你去尿尿。"

# game/a1/way_to_home1.rpy:338
translate english vall_forest_2967b274:

    # vall "Наконец-то."
    vall "总算。"

# game/a1/way_to_home1.rpy:341
translate english vall_forest_765b9fcb:

    # mc "Ну мы достаточно далеко."
    mc "嗯，我们走得够远了。"

# game/a1/way_to_home1.rpy:342
translate english vall_forest_89ea511c:

    # vall "Уверен, что не хочешь отвести меня прямо в гномьи горы, а то отсюда моя моча может попасть в лагерь через реку."
    vall "你确定不想直接带我去矮人山脉？不然我一泡尿能顺着河淌回你们营地。"

# game/a1/way_to_home1.rpy:343
translate english vall_forest_a70e13d4:

    # mc "В гномьи горы отводить тебя не буду, но могу отвести обратно в лагерь, если ты настроена шутить, а не писать."
    mc "带你去矮人山脉就不了，但如果你打算嘴贫而不是尿尿，我倒是可以带你回营地。"

# game/a1/way_to_home1.rpy:344
translate english vall_forest_0b9c634d:

    # vall "Ну ладно-ладно, я готова."
    vall "好啦好啦，我准备好了。"

# game/a1/way_to_home1.rpy:346
translate english vall_forest_2b35b6fe:

    # mc "..."
    mc "..."

# game/a1/way_to_home1.rpy:347
translate english vall_forest_c0a8e964_1:

    # vall "..."
    vall "..."

# game/a1/way_to_home1.rpy:348
translate english vall_forest_8a511c0e:

    # mc "Писай."
    mc "尿吧。"

# game/a1/way_to_home1.rpy:349
translate english vall_forest_42a6a1bb:

    # vall "Не могу."
    vall "尿不出来。"

# game/a1/way_to_home1.rpy:350
translate english vall_forest_d0b1c0b9:

    # mc "Почему?"
    mc "为什么？"

# game/a1/way_to_home1.rpy:351
translate english vall_forest_6068eb5b:

    # vall "Развяжи меня."
    vall "解开我。"

# game/a1/way_to_home1.rpy:352
translate english vall_forest_aed362d2:

    # mc "Еще чего."
    mc "想得美。"

# game/a1/way_to_home1.rpy:353
translate english vall_forest_a06d0e8c:

    # vall "Пожалуйста! Я босая, голодная, почти голая в незнакомом лесу, зачем мне сбегать? Чтобы сдохнуть?"
    vall "求你了！我光着脚，饿着肚子，几乎半裸着在这陌生森林里，我跑什么？找死吗？"

# game/a1/way_to_home1.rpy:354
translate english vall_forest_4a833ccb:

    # mc "Эх...ладно. Но я слежу за тобой."
    mc "唉……好吧。但我会盯着你。"

# game/a1/way_to_home1.rpy:356
translate english vall_forest_905e2585:

    # vall "Ага. Ладно. Nuran. (извращенец)"
    vall "啊哈。行吧。Nuran。（变态）"

# game/a1/way_to_home1.rpy:358
translate english vall_forest_74334493:

    # vall "Ага. Ладно. Nuran."
