translate english elin_forest_eb5fb3b0:

    # mc "Нас было легко вычислить. Нужно было чаще мыть рот от сахарной пудры."
    mc "我们太容易被发现了。应该在嘴上的糖霜多洗几次。"

# game/a1/way_to_home1.rpy:625
translate english elin_forest_25589a41:

    # mc "Да уж. Мы были вздорными детьми."
    mc "说的是。我们那时候真是捣蛋鬼。"

# game/a1/way_to_home1.rpy:626
translate english elin_forest_95dc9eb6:

    # elin "Ты..."
    elin "你……"

# game/a1/way_to_home1.rpy:627
translate english elin_forest_5d150d79:

    # mc "М?"
    mc "嗯？"

# game/a1/way_to_home1.rpy:629
translate english elin_forest_e4206d62:

    # elin "Ты просто не знаешь какими бывают другие дети."
    elin "你只是不知道别的孩子有多调皮。"

# game/a1/way_to_home1.rpy:630
translate english elin_forest_df7a3e56:

    # mc "Ну у меня не было возможности их изучить. Во дворце были только мы и дети прислуги. Но они и шелохнуться боялись."
    mc "嗯，我没机会研究他们。宫殿里只有我们和仆人的孩子。但他们连动都不敢动。"

# game/a1/way_to_home1.rpy:631
translate english elin_forest_47bf9018:

    # elin "Я училась в магических башнях, там было полно детей."
    elin "我在魔法塔里学习，那里孩子多的是。"

# game/a1/way_to_home1.rpy:632
translate english elin_forest_8a341b44:

    # mc "И как они себя вели?"
    mc "他们表现怎么样？"

# game/a1/way_to_home1.rpy:633
translate english elin_forest_b19f00ef:

    # elin "По-разному. Но были и те, что были даже хуже нас."
    elin "各不相同。但有些比我们还糟糕。"

# game/a1/way_to_home1.rpy:637
translate english elin_forest_0c0ee5eb:

    # elin "Кстати о сладостях. У меня кое-что есть с собой. Открой рот."
    elin "说到甜食。我身上带了点东西。张嘴。"

# game/a1/way_to_home1.rpy:638
translate english elin_forest_cbe00235:

    # mc "М? Фшто этшто?"
    mc "嗯？介系什嘛？"

# game/a1/way_to_home1.rpy:639
translate english elin_forest_9f880364:

    # elin "Имбирная конфета. В соке черного дуба."
    elin "姜糖。泡过黑橡树汁的。"

# game/a1/way_to_home1.rpy:640
translate english elin_forest_748ad0e1:

    # mc "Какая гадость. Кажется твои вкусы в сладостях слегка изменились."
    mc "真难吃。看来你对甜食的口味有点变化。"

# game/a1/way_to_home1.rpy:641
translate english elin_forest_beb22f63:

    # elin "О чем ты?"
    elin "你说什么呢？"

# game/a1/way_to_home1.rpy:642
translate english elin_forest_170405b3:

    # mc "По вкусу как лекарство которое пьет Людвиг, чтобы у него не болели колени."
    mc "味道就像Ludwig喝的治膝盖疼的药。"

# game/a1/way_to_home1.rpy:643
translate english elin_forest_13dda597:

    # elin "Она помогает расслабиться."
    elin "它能帮人放松。"

# game/a1/way_to_home1.rpy:644
translate english elin_forest_6e6bb07b:

    # mc "Ты часто бываешь сильно напряжена?"
    mc "你经常太紧绷吗？"

# game/a1/way_to_home1.rpy:645
translate english elin_forest_c573b4ae:

    # elin "Нет, но сейчас я напряжена, потому что не принимала ванну уже месяц."
    elin "不，但此刻我很紧绷，因为我已经有一个月没洗澡了。"

# game/a1/way_to_home1.rpy:646
translate english elin_forest_1a00e72f:

    # mc "Какой ужас."
    mc "太可怕了。"

# game/a1/way_to_home1.rpy:647
translate english elin_forest_3b715b68:

    # elin "Вот именно. Здесь недалеко течет река."
    elin "就是。这附近有条河。"

# game/a1/way_to_home1.rpy:651
translate english elin_forest_180d3967:

    # mc "Ты куда?"
    mc "你去哪儿？"

# game/a1/way_to_home1.rpy:652
translate english elin_forest_0c917006:

    # elin "Ты меня не слушал? Собираюсь помыться. Потом расскажу как водичка."
    elin "你没听我说话？我打算去洗洗。回头告诉你水怎么样。"

# game/a1/way_to_home1.rpy:653
translate english elin_forest_37ffd85a:

    # mc "Оу. Ну ладно."
    mc "哦。好吧。"

# game/a1/way_to_home1.rpy:657
translate english elin_forest_496baf84:

    # elin "Не хочешь искупаться?"
    elin "不想洗个澡吗？"

# game/a1/way_to_home1.rpy:658
translate english elin_forest_cfbc037f:

    # mc "Да. Я не против."
    mc "好啊。我不介意。"

# game/a1/way_to_home1.rpy:659
translate english elin_forest_399ca469:

    # elin "Тогда пойдем прямо сейчас, пока еще не совсем стемнело."
    elin "那我们趁天还没全黑现在就走吧。"

# game/a1/way_to_home1.rpy:663
translate english elin_forest2_14cd8a21:

    # mc "Не спеши так."
    mc "别这么急。"

# game/a1/way_to_home1.rpy:664
translate english elin_forest2_82bd8756:

    # mc "Я не успеваю за тобой."
    mc "我跟不上你。"

# game/a1/way_to_home1.rpy:665
translate english elin_forest2_ad41de87:

    # mc "[elin]?"
    mc "[elin]?"

# game/a1/way_to_home1.rpy:667
translate english elin_forest2_944e92c7:

    # mc "Когда ты успела раздеться?"
    mc "你什么时候把衣服都脱了？"

# game/a1/way_to_home1.rpy:668
translate english elin_forest2_b134dccb:

    # elin "Водичка очень теплая. Залазь скорее."
    elin "这水很暖。快下来。"

# game/a1/way_to_home1.rpy:670
translate english elin_forest2_4cf41e41:

    # mc "Ты дрожишь."
    mc "你在发抖。"

# game/a1/way_to_home1.rpy:671
translate english elin_forest2_c9c8a607:

    # elin "Это с непривычки. Вода действительно теплая."
    elin "是因为不习惯。水真的很暖。"

# game/a1/way_to_home1.rpy:672
translate english elin_forest2_be905f73:

    # mc "Знаешь у меня и отсюда вид хороший, наверное я в воду залазить не буду."
    mc "知道吗，我从这里看景色也很不错，可能我不用下水了。"

# game/a1/way_to_home1.rpy:673
translate english elin_forest2_e1870881:

    # elin "[mename]! Залазь в воду и не беси меня."
    elin "[mename]！给我下水，别惹我。"

# game/a1/way_to_home1.rpy:674
translate english elin_forest2_2b35b6fe:

    # mc "..."
    mc "..."

# game/a1/way_to_home1.rpy:675
translate english elin_forest2_6769634e:

    # elin "[mename]!"
    elin "[mename]!"

# game/a1/way_to_home1.rpy:677
translate english elin_forest2_c1cfd5d5:

    # mc "ЗА ЗОЛОТУЮ ИМПЕРИЮ!"
    mc "为了黄金帝国！"

# game/a1/way_to_home1.rpy:678
translate english elin_forest2_385bf79a:

    # elin "О боги!"
    elin "哦，神明啊！"

# game/a1/way_to_home1.rpy:680
translate english elin_forest2_6d723c3c:

    # elin "Ты как ребенок."
    elin "你像个小孩一样。"

# game/a1/way_to_home1.rpy:681
translate english elin_forest2_0e0e4beb:

    # elin "Тебе даже помыться в реке нельзя без брызг и криков."
    elin "你就算在河里洗澡，也非得泼水大叫不可。"

# game/a1/way_to_home1.rpy:683
translate english elin_forest2_77397f46:

    # mc "Тебе бы тоже не помешало бы нырнуть."
    mc "你也该潜一下水才对。"

# game/a1/way_to_home1.rpy:684
translate english elin_forest2_bde7aed0:

    # elin "Нет, спасибо, я не хочу намочить волосы."
    elin "不了，谢谢，我不想弄湿头发。"

# game/a1/way_to_home1.rpy:685
translate english elin_forest2_505f6884:

    # mc "Эльфийские волосы практически не впитывают влагу."
    mc "精灵的头发几乎不沾水。"

# game/a1/way_to_home1.rpy:686
translate english elin_forest2_f6cc1eaf:

    # elin "Ага. Я эту чушь все наше детство слушала, когда ты не хотел мыться."
    elin "啊哈。我小时候不想洗澡的时候，就听你编这套瞎话。"

# game/a1/way_to_home1.rpy:687
translate english elin_forest2_0bb1f462:

    # mc "Это не чушь. Кухаркина дочь меняла сладости на мои волосы. Говорила что мама сделает из них перчатки."
    mc "这不是瞎话。厨娘的女儿拿甜食换我的头发。她说她妈妈要用它做手套。"

# game/a1/way_to_home1.rpy:688
translate english elin_forest2_3f1ee3d3:

    # elin "Чего? Что за глупость. Ты просто был красивым ребенком и нравился ей."
    elin "啊？真是瞎说。她只是觉得你是个漂亮小孩，喜欢你罢了。"

# game/a1/way_to_home1.rpy:689
translate english elin_forest2_15a7c125:

    # mc "{i}Ты тоже красивая, [elin].{/i}"
    mc "{i}你也很漂亮，[elin]。{/i}"

# game/a1/way_to_home1.rpy:690
translate english elin_forest2_14199721:

    # mc "{i}Я бы даже сказал очень красивая...{/i}"
    mc "{i}我甚至想说你非常漂亮……{/i}"

# game/a1/way_to_home1.rpy:691
translate english elin_forest2_eff62d93:

    # mc "{i}Что за черт? О чем я думаю, она же моя [sister].{/i}"
    mc "{i}搞什么鬼？我在想什么呢，她可是我[sister]。{/i}"

# game/a1/way_to_home1.rpy:697
translate english elin_forest2_439408f3:

    # mc "Ох...знаешь, по-моему стоило плыть в столицу по реке. Смастерили бы плот и окунались каждый раз, как становилось бы жарко."
    mc "哦……你知道，我觉得咱们真该顺着河漂回首都去。做个木筏，每次一热就跳下去泡着。"

# game/a1/way_to_home1.rpy:698
translate english elin_forest2_e02ba6b5:

    # elin "Какая отличная идея. Жаль только мы все превратились бы в печеные оладушки уже на второй день."
    elin "多好的主意。可惜，我们第二天就会全变成烤面饼。"

# game/a1/way_to_home1.rpy:699
translate english elin_forest2_39636101:

    # mc "А?"
    mc "啊？"

# game/a1/way_to_home1.rpy:700
translate english elin_forest2_e3c446bb:

    # elin "Ты не знаешь как работает солнечный свет?"
    elin "你不知道阳光怎么起作用的吗？"

# game/a1/way_to_home1.rpy:701
translate english elin_forest2_cbb4769a:

    # mc "Да знаю я. Просто немного помечтал. Дорога меня измотала. "
    mc "我知道啦。只是稍微幻想了一下。路上把我累垮了。"

# game/a1/way_to_home1.rpy:702
translate english elin_forest2_242396c9:

    # elin "Скоро будем дома."
    elin "很快就到家了。"

# game/a1/way_to_home1.rpy:703
translate english elin_forest2_35f38c71:

    # mc "Ты довольна этим?"
    mc "你开心吗？"

# game/a1/way_to_home1.rpy:705
translate english elin_forest2_f180344b:

    # elin "Еще бы. Я в дороге в два раза дольше чем ты. "
    elin "那还用说。我在路上的时间比你长一倍呢。"

# game/a1/way_to_home1.rpy:706
translate english elin_forest2_cd3c34f7:

    # mc "Ты все таки решила замочить волосы?"
    mc "你还是决定弄湿头发了？"

# game/a1/way_to_home1.rpy:707
translate english elin_forest2_0c2b43bc:

    # elin "Ты пялился на мою грудь. Я решила что хотя бы под водой от тебя скроюсь."
    elin "你刚才盯着我胸看。我想至少在水下能躲着你。"

# game/a1/way_to_home1.rpy:708
translate english elin_forest2_9d1282e2:

    # mc "Чего?"
    mc "什么？"

# game/a1/way_to_home1.rpy:709
translate english elin_forest2_ab770782:

    # elin "Шучу."
    elin "开玩笑的。"

# game/a1/way_to_home1.rpy:711
translate english elin_forest2_90c66e21:

    # "Некоторое время спустя."
    "过了一会."

# game/a1/way_to_home1.rpy:712
translate english elin_forest2_2b0fb667:

    # elin "Фух, отлично покупались."
    elin "呼，洗得真舒服。"

# game/a1/way_to_home1.rpy:713
translate english elin_forest2_c3bef7cf:

    # mc "Ага. Теперь я точно готов ко сну."
    mc "嗯。现在我真准备好去睡了。"

# game/a1/way_to_home1.rpy:716
translate english elin_forest3_1cbe54db:

    # mc "Что-то не так?"
    mc "有什么不对吗？"

# game/a1/way_to_home1.rpy:717
translate english elin_forest3_7362a5c5:

    # elin "Эм...[mename]..."
    elin "呃……[mename]……"

# game/a1/way_to_home1.rpy:718
translate english elin_forest3_62bdb3ef:

    # mc "Да?"
    mc "嗯？"

# game/a1/way_to_home1.rpy:719
translate english elin_forest3_1210db05:

    # elin "Твоя штука...эээ...торчит..."
    elin "你那个东西……呃……翘起来了……"

# game/a1/way_to_home1.rpy:720
translate english elin_forest3_69e26b8a:

    # mc "Ты про мой пенис?"
    mc "你说我的阴茎？"

# game/a1/way_to_home1.rpy:721
translate english elin_forest3_f4aea240:

    # elin "Ага. Я про твой....про твою штуку..."
    elin "嗯。我说你的……你那个东西……"

# game/a1/way_to_home1.rpy:723
translate english elin_forest3_0404f2c7:

    # elin "Убери ее, пожалуйста."
    elin "请你把它收起来。"

# game/a1/way_to_home1.rpy:724
translate english elin_forest3_df3b1dc2:

    # mc "И как мне это сделать?"
    mc "我该怎么办到呢？"

# game/a1/way_to_home1.rpy:725
translate english elin_forest3_5bf39b84:

    # elin "Не знаю, как-нибудь."
    elin "不知道，随便怎么。"

# game/a1/way_to_home1.rpy:726
translate english elin_forest3_6ca85c28:

    # mc "Что тебя так смущает? Это такая же часть моего тела как нос или рука."
    mc "有什么好窘的？它就像我的鼻子或手一样，是我身体的一部分。"

# game/a1/way_to_home1.rpy:727
translate english elin_forest3_b183696f:

    # elin "Ладно-ладно. Но почему он....ну знаешь...стоит?"
    elin "好吧好吧。可是为什么它……你知道的……站着？"

# game/a1/way_to_home1.rpy:728
translate english elin_forest3_3bd783c8:

    # mc "Ну возможно ты не заметила, но я тут 2 недели в дороге, а рядом купается красивая голая девушка."
    mc "嗯，也许你没注意到，我在路上待了两个星期，旁边还有个漂亮的全裸姑娘在洗澡。"

# game/a1/way_to_home1.rpy:729
translate english elin_forest3_effc78cd:

    # elin "[mename], замолчи....стой, красивая?"
    elin "[mename]，闭嘴……等等，漂亮？"

# game/a1/way_to_home1.rpy:731
translate english elin_forest3_d4d7e1c5:

    # mc "Ну конечно красивая, моя [sist] здорово подросла за эти годы."
    mc "是啊，当然漂亮，我的[sist]这些年发育得真好。"

# game/a1/way_to_home1.rpy:732
translate english elin_forest3_5f2bccce:

    # elin "Что ты делаешь, стой?"
    elin "你在干什么，住手？"

# game/a1/way_to_home1.rpy:733
translate english elin_forest3_ed0b1e96:

    # mc "Что? У тебя грудь уже размером с мамину."
    mc "怎么？你的胸都快有妈妈的那么大了。"

# game/a1/way_to_home1.rpy:734
translate english elin_forest3_03c83d8c:

    # elin "Заткнись, не говори такие вещи, ахахахах, и не щекоти меня."
    elin "闭嘴，别说这些，啊哈哈哈哈，别挠我痒。"

# game/a1/way_to_home1.rpy:735
translate english elin_forest3_8f59e1c4:

    # mc "А то что?"
    mc "挠了又怎样？"

# game/a1/way_to_home1.rpy:737
translate english elin_forest3_a023c3c7:

    # elin "А не то я буду щекотать тебя в ответ."
    elin "那我就也挠你痒。"

# game/a1/way_to_home1.rpy:738
translate english elin_forest3_6d9c29d4:

    # mc "А вот это уже против правил!"
    mc "嘿，这可是犯规！"

# game/a1/way_to_home1.rpy:739
translate english elin_forest3_6e70a12e:

    # elin "Ты вообще-то тоже здорово вырос, [bro], во всех местах."
    elin "你也真的长大了，[bro]，所有地方都。"

# game/a1/way_to_home1.rpy:740
translate english elin_forest3_59b8c431:

    # mc "Эй, если ты не прекратишь я начну использовать секретную тактику, которой меня научила мама."
    mc "嘿，你再不停止，我要用妈妈教我的秘密战术了。"

# game/a1/way_to_home1.rpy:741
translate english elin_forest3_be9e0762:

    # elin "Даже не смей только не ее, давай разойдемся миром."
    elin "可别，千万别用那个，咱们讲和吧。"

# game/a1/way_to_home1.rpy:742
translate english elin_forest3_5f9b0ffa:

    # mc "Тогда прекращаем на счет три."
    mc "那数到三我们就停手。"

# game/a1/way_to_home1.rpy:743
translate english elin_forest3_ee0d9d87:

    # elin "Раз...два..."
    elin "一……二……"

# game/a1/way_to_home1.rpy:745
translate english elin_forest3_f8357743:

    # mc "Три!"
    mc "三！"

# game/a1/way_to_home1.rpy:746
translate english elin_forest3_92d397c8:

    # elin "..."
    elin "..."

# game/a1/way_to_home1.rpy:747
translate english elin_forest3_65e52d17:

    # mc "Эй...прости что мой член встал, я не хотел тебя смущать, но я правда его не контролирую."
    mc "嘿……抱歉我那个硬起来了，我不是想让你窘，但我真的控制不了。"

# game/a1/way_to_home1.rpy:748
translate english elin_forest3_8e6f576c:

    # elin " Все нормально."
    elin "没事啦。"

# game/a1/way_to_home1.rpy:749
translate english elin_forest3_87d88ceb:

    # mc "Точно?"
    mc "真的？"

# game/a1/way_to_home1.rpy:750
translate english elin_forest3_24c55dbf:

    # elin "Да. Это даже в какой-то мере приятно..."
    elin "嗯。这在某种程度上还挺让人开心的……"

