# game/a12/9castle_stories.rpy:6
translate english castle_stories_fc7d3a18:

    # "Пару минут спустя."
    "几分钟以后。"

# game/a12/9castle_stories.rpy:7
translate english castle_stories_97f7f0e8:

    # me "{i}Вот он. Новый Император.{/i}"
    me "{i}这就是他。新皇帝。{/i}  "

# game/a12/9castle_stories.rpy:8
translate english castle_stories_96411901:

    # me "{i}Ждет меня. Хочет поговорить. Правда о чем, если я уже подписал документ?{/i}"
    me "{i}在等我，想和我谈谈。但我已经签了文件，还能谈什么呢？{/i}  "

# game/a12/9castle_stories.rpy:9
translate english castle_stories_0b5c44cc:

    # me "{i}Будет хвалить меня или наоборот, объяснять где я ошибся?{/i}"
    me "{i}他会表扬我，还是相反，告诉我哪里做错了？{/i}  "

# game/a12/9castle_stories.rpy:10
translate english castle_stories_bd12d2ad:

    # me "{i}Ладно, нет смысла загадывать, я и так сейчас все выясню.{/i}"
    me "{i}算了，猜也没用，反正我现在就会知道。{/i}  "

# game/a12/9castle_stories.rpy:11
translate english castle_stories_c3af4300:

    # me "{i}...после отравления с ним всюду стража.{/i}"
    me "{i}……自从被投毒后，他身边到处都是侍卫。{/i}  "

# game/a12/9castle_stories.rpy:12
translate english castle_stories_74bf6e1f:

    # me "{i}Ну хоть не обыскивают.{/i}"
    me "{i}不过至少没搜身。{/i}  "

# game/a12/9castle_stories.rpy:13
translate english castle_stories_2ba68507:

    # me "Отец."
    me "父亲。  "

# game/a12/9castle_stories.rpy:15
translate english castle_stories_2408fa27:

    # king "[mename]."
    king "[mename]."

# game/a12/9castle_stories.rpy:16
translate english castle_stories_2d6dd449:

    # me "Хотел меня видеть?"
    me "你想见我？  "

# game/a12/9castle_stories.rpy:17
translate english castle_stories_eabccd3d:

    # king "Да. Ты выбрал кому поручить Долину."
    king "对。你选好了把山谷交给谁。  "

# game/a12/9castle_stories.rpy:18
translate english castle_stories_b6184cfd:

    # me "Разве Леонард и мама тебе не рассказали?"
    me "难道Leonard和妈妈没告诉你吗？  "

# game/a12/9castle_stories.rpy:19
translate english castle_stories_c3594131:

    # king "Я хочу услышать от тебя."
    king "我想听你亲口说。  "

# game/a12/9castle_stories.rpy:20
translate english castle_stories_f45f6b64:

    # me "Выбрал. Документ готов. Не хватает только твоей подписи."
    me "选好了。文件已经准备好，只差你的签名。  "

# game/a12/9castle_stories.rpy:21
translate english castle_stories_7b19570d:

    # king "Я подпишу."
    king "我会签的。  "

# game/a12/9castle_stories.rpy:22
translate english castle_stories_ee897278:

    # me "...вот так просто?"
    me "……就这么简单？  "

# game/a12/9castle_stories.rpy:23
translate english castle_stories_c0cda0f0:

    # king "Да."
    king "是的。  "

# game/a12/9castle_stories.rpy:24
translate english castle_stories_54559f09:

    # me "Даже не спросишь, кого я выбрал?"
    me "你甚至不问问我选了谁？  "

# game/a12/9castle_stories.rpy:25
translate english castle_stories_51b8f079:

    # king "А это имеет значение?"
    king "这很重要吗？  "

# game/a12/9castle_stories.rpy:26
translate english castle_stories_8c7fb87e:

    # me "Если не имеет, зачем вообще ты поручал мне выбирать?"
    me "如果不重要，你又何必让我去选？  "

# game/a12/9castle_stories.rpy:27
translate english castle_stories_0b06d7df:

    # king "Присядь."
    king "坐下。  "

# game/a12/9castle_stories.rpy:30
translate english castle_stories_0a767366:

    # me "Прежде чем мы поговорим о Долине, я хотел бы спросить о матери."
    me "在我们谈山谷之前，我想先问问你母亲的事。  "

# game/a12/9castle_stories.rpy:31
translate english castle_stories_64bd5e33:

    # king "Она уже говорила со мной."
    king "她已经跟我谈过了。  "

# game/a12/9castle_stories.rpy:32
translate english castle_stories_c2fb1037:

    # me "Да. Я знаю. Просто..."
    me "对。我知道。只是……  "

# game/a12/9castle_stories.rpy:33
translate english castle_stories_68dc5265:

    # king "[mename]. Ее положение сейчас меня интересует меньше всего."
    king "[mename]。我对她现在的处境一点都不关心。  "

# game/a12/9castle_stories.rpy:34
translate english castle_stories_000913be:

    # me "Да, но..."
    me "是，但是……  "

# game/a12/9castle_stories.rpy:35
translate english castle_stories_876ea7cb:

    # king "Она уже лет как пять просто мой очередной... придворный советник. "
    king "她已经只是我的又一个……宫廷顾问，差不多五年了。  "

# game/a12/9castle_stories.rpy:36
translate english castle_stories_c83aaa1c:

    # me "Советник."
    me "顾问。  "

# game/a12/9castle_stories.rpy:37
translate english castle_stories_849dacaf:

    # king "Меня не интересует почему она сделала, то что сделала. Мое здоровье не позволяет мне быть мужчиной для нее, а мои чувства не позволяют оставаться хотя бы супругом."
    king "我不在乎她为什么做出那些事。我的健康状况让我无法再做她的男人，而我的感情让我连丈夫的身份也维持不下去。  "

# game/a12/9castle_stories.rpy:38
translate english castle_stories_74dd873b:

    # king "Но наше положение обязывает нас соблюдать определенные формальности. И она эти формальности нарушила."
    king "但我们所处的地位要求我们遵守某些形式。而她违反了这些形式。  "

# game/a12/9castle_stories.rpy:39
translate english castle_stories_f6535ff6:

    # me "Я хотел попросить..."
    me "我想请你……  "

# game/a12/9castle_stories.rpy:40
translate english castle_stories_e438cc50:

    # king "Просить не о чем. Она продолжит жить в замке. Приплод даже может быть полезен... с дипломатической точки зрения."
    king "没什么可请的。她可以继续住在城堡里。那个孩子甚至可能……从外交角度看会有点用。  "

# game/a12/9castle_stories.rpy:41
translate english castle_stories_a9438eda:

    # me "Она ведь не будет наказана?"
    me "她不会受惩罚吗？  "

# game/a12/9castle_stories.rpy:42
translate english castle_stories_78edf3f3:

    # king "За что?"
    king "为什么罚她？  "

# game/a12/9castle_stories.rpy:43
translate english castle_stories_6b47a8c2:

    # me "Тяжело представить... что ты просто рад тому, что скоро снова станешь отцом..."
    me "很难想象……你只是单纯高兴自己又要当父亲了……  "

# game/a12/9castle_stories.rpy:44
translate english castle_stories_f6664834:

    # king "Имперская система позволяет мне лишать земельных титулов непрямых наследников. Впрочем, мы всегда правили отсюда, так что это не имеет значения."
    king "帝国的体制允许我剥夺非直系继承人的封地头衔。不过我们一直是从这里统治的，所以这也没什么关系。  "

# game/a12/9castle_stories.rpy:45
translate english castle_stories_08226119:

    # me "А имел в виду..."
    me "但我指的是……  "

# game/a12/9castle_stories.rpy:46
translate english castle_stories_7a330a6c:

    # king "Я уже все сказал. Все остальное - дело меня и твоей матери. Она будет в безопасности. Тебя ведь это волновало?"
    king "我已经说完了。剩下的是我和你母亲之间的事。她会安全的。这不正是你担心的吗？  "

# game/a12/9castle_stories.rpy:47
translate english castle_stories_fc30fd2b:

    # me "Да."
    me "是的。  "

# game/a12/9castle_stories.rpy:48
translate english castle_stories_d063c1b6:

    # king "Тогда вернемся к теме Долины."
    king "那我们回到山谷的话题。  "

# game/a12/9castle_stories.rpy:50
translate english castle_stories_812c90f7:

    # me "Ну... так если разницы в том, кому ее отдавать не было, то зачем вообще..."
    me "嗯……既然交给谁都一样，那又何必……  "

# game/a12/9castle_stories.rpy:51
translate english castle_stories_ae781df0:

    # king "Главное, что ты совершил этот выбор не бездумно. Разговаривал с кандидатами, советовался с другими людьми."
    king "重要的是，你做出这个选择并非不经思考。你和候选人谈过，也和其他人商量过。  "

# game/a12/9castle_stories.rpy:52
translate english castle_stories_ea0bc058:

    # me "Так это был урок? Я должен был научиться принимать императорские решения?"
    me "所以这是个教训吗？我本该学会如何做出皇帝的决定？  "

# game/a12/9castle_stories.rpy:53
translate english castle_stories_4ec19894:

    # king "Урок призван научить тому, чего не знаешь. Ты уже достаточно давно исполняешь роль принца-регента, не так ли?"
    king "教训是为了教会你不懂的事。但你已经担任摄政王子的角色相当久了，不是吗？  "

# game/a12/9castle_stories.rpy:54
translate english castle_stories_b17cd207:

    # me "Так если это не урок, и выбор мой не имел значения, что это было? Попытка переложить на меня ответственность?"
    me "那么，如果这不是教训，我的选择也无关紧要，这算什么？想把责任推给我？  "

# game/a12/9castle_stories.rpy:55
translate english castle_stories_c0244207:

    # king "А ты не хочешь брать на себя ответственность?"
    king "难道你不想承担这个责任？  "

# game/a12/9castle_stories.rpy:56
translate english castle_stories_719d9de1:

    # me "Может и хочу. Но до этого ты избегал поручать мне такие важные решения. Что изменилось?"
    me "也许我想。但在此之前，你一直避免把这么重要的决定交给我。是什么变了？  "

# game/a12/9castle_stories.rpy:57
translate english castle_stories_f91bad57:

    # king "Ты... готов."
    king "你……准备好了。  "

# game/a12/9castle_stories.rpy:58
translate english castle_stories_1daef9c2:

    # me "Готов к чему?"
    me "准备好干什么？  "

# game/a12/9castle_stories.rpy:59
translate english castle_stories_65da6375:

    # king "К тому, чтобы собирать Империю. Ты доказал это на Западе. Но я хотел посмотреть, как ты будешь действовать не снаружи, а внутри."
    king "准备好整合帝国。你在西边证明了这一点。但我想看看你在内部，而非外部，会如何行事。  "

# game/a12/9castle_stories.rpy:60
translate english castle_stories_48013d82:

    # me "И как?"
    me "那我做得怎么样？  "

# game/a12/9castle_stories.rpy:61
translate english castle_stories_7207da68:

    # king "Ты мне скажи."
    king "你告诉我。  "

# game/a12/9castle_stories.rpy:62
translate english castle_stories_e64b0bf8:

    # me "...нормально."
    me "……还行。  "

# game/a12/9castle_stories.rpy:64
translate english castle_stories_cf61bb1a:

    # me "Я просто сделал выбор в пользу верности."
    me "我只是做出了一个基于忠诚的选择。  "

# game/a12/9castle_stories.rpy:65
translate english castle_stories_ff51407e:

    # king "Понимаю. Это может быть очень важно."
    king "我理解。这可能非常重要。  "

# game/a12/9castle_stories.rpy:67
translate english castle_stories_a84dac53:

    # me "Величие начинается с идеи. Я выбрал того, кто мыслит широко."
    me "伟大始于理念。我选了那个有广阔思维的人。  "

# game/a12/9castle_stories.rpy:68
translate english castle_stories_63d3d69d:

    # king "Интересно..."
    king "有意思……  "

# game/a12/9castle_stories.rpy:70
translate english castle_stories_bfed7a0f:

    # me "Если кусок мяса не разделить между голодными собаками, лучше не давать его никому."
    me "如果一块肉不能在饿狗之间分配，那最好谁也别给。  "

# game/a12/9castle_stories.rpy:71
translate english castle_stories_6088254d:

    # king "Это имеет смысл."
    king "这有道理。  "

# game/a12/9castle_stories.rpy:72
translate english castle_stories_2117fb2e:

    # me "Так ты доволен, тем что увидел?"
    me "那么，你对你所看到的满意吗？  "

# game/a12/9castle_stories.rpy:73
translate english castle_stories_37e5bcf1:

    # king "Думаю это слово не совсем подходит."
    king "我觉得这个词不太恰当。  "

# game/a12/9castle_stories.rpy:75
translate english castle_stories_76e875fb:

    # me "Ясно. Видимо я сделал что-то, что не сочетается с твоими пророчествами."
    me "明白了。看来我做了些不符合你预言的事。  "

# game/a12/9castle_stories.rpy:76
translate english castle_stories_cdfb3134:

    # king "..."
    king "..."

# game/a12/9castle_stories.rpy:77
translate english castle_stories_023cd7a1:

    # me "Что? Ты ждал чего-то другого? Я должен был разделить Долину пополам или отдать ее западным лордами или еще что-то?"
    me "什么？你期待别的东西？我应该把山谷一分为二，还是交给西方的领主们，或者别的什么？  "

# game/a12/9castle_stories.rpy:78
translate english castle_stories_7b95c5e3:

    # king "Разве я сказал, что расстроен твоим решением."
    king "难道我说了我对你的决定感到失望吗？  "

# game/a12/9castle_stories.rpy:79
translate english castle_stories_b45018d7:

    # me "Нет. Не сказал. Ты ничего не говоришь. Как и все остальные. С тех пор как я вернулся сюда, я ощущаю себя жуком, которого посадил в колбу алхимик."
    me "没有。你没说。你什么也没说。就像其他人一样。自从我回到这里，我感觉自己就像炼金术士放进烧瓶里的甲虫。  "

# game/a12/9castle_stories.rpy:80
translate english castle_stories_0a1ec932:

    # king "Почему?"
    king "为什么这么说？  "

# game/a12/9castle_stories.rpy:81
translate english castle_stories_66127f05:

    # me "Потому что все за мной наблюдают, говорят, чего-то просят, тщательно препарируют меня, но никто ничего мне не говорит напрямую. Одни намеки и бесконечные тайны."
    me "因为所有人都在观察我，跟我说话，向我提要求，仔细地剖析我，但没人直接告诉我任何事。只有暗示和无尽的秘密。  "

# game/a12/9castle_stories.rpy:82
translate english castle_stories_cdfb3134_1:

    # king "..."
    king "..."

# game/a12/9castle_stories.rpy:83
translate english castle_stories_3fbc5bf7:

    # me "Я только недавно узнал, что все что я знал о своем происхождении и происхождении моей семьи это ложь."
    me "我最近才知道，我所知道的关于自己和我家族出身的一切，都是谎言。  "

# game/a12/9castle_stories.rpy:84
translate english castle_stories_0d06f88a:

    # king "Но ты ведь понял, зачем эта ложь была нужна?"
    king "但你应该明白了，为什么需要这个谎言吧？  "

# game/a12/9castle_stories.rpy:85
translate english castle_stories_cc1b7c28:

    # me "Дело не в самой лжи, а в том, что ее источают все вокруг. Все что-то мне вечно недоговаривают, проверяют меня, рассказывают все новые и новые версии происходящего."
    me "问题不在于谎言本身，而在于周围所有人都在制造谎言。所有人永远都在对我欲言又止，考验我，讲给我一个又一个新版本的真相。  "

# game/a12/9castle_stories.rpy:86
translate english castle_stories_80165177:

    # king "Ты запутался?"
    king "你糊涂了吗？  "

# game/a12/9castle_stories.rpy:87
translate english castle_stories_df4b9fbd:

    # me "...не знаю. Возможно я просто понял, что никто не заслуживает моего доверия."
    me "……我不知道。也许我只是明白了，没有人值得我信任。  "

# game/a12/9castle_stories.rpy:88
translate english castle_stories_1ec1fd21:

    # king "Так говорил мой отец."
    king "我父亲就这么说过。  "

# game/a12/9castle_stories.rpy:89
translate english castle_stories_e3e5df33:

    # me "Красный Император?"
    me "红色皇帝？  "

# game/a12/9castle_stories.rpy:90
translate english castle_stories_844b4f72:

    # king "Да. В это трудно поверить, но он когда-то казался мне добродушным и милосердным человеком."
    king "对。这很难相信，但他曾在我看来是个善良仁慈的人。  "

# game/a12/9castle_stories.rpy:92
translate english castle_stories_24bdcabe:

    # me "И что же поменялось?"
    me "那是什么变了？  "

# game/a12/9castle_stories.rpy:93
translate english castle_stories_d7130dea:

    # king "Умер старый Император. Отец навещал его на смертном одре за несколько дней до кончины. Я до сих пор помню его лицо, когда он вернулся."
    king "老皇帝死了。父亲在他临终前几天去探望过他。我至今还记得他回来时的表情。  "

# game/a12/9castle_stories.rpy:94
translate english castle_stories_99c98d03:

    # me "На него так повлияла смерть отца?"
    me "是父亲的死对他影响这么大吗？  "

# game/a12/9castle_stories.rpy:95
translate english castle_stories_bfdffd1d:

    # king "Дело было не в отце. А в том, что он ему сказал."
    king "问题不在于他父亲，而在于他父亲对他说的话。  "

# game/a12/9castle_stories.rpy:96
translate english castle_stories_10943fcf:

    # me "А что он ему сказал?"
    me "那他对他说了什么？  "

# game/a12/9castle_stories.rpy:97
translate english castle_stories_4befa7af:

    # king "Этого я тогда не знал. Но он переменился. Стал более жестоким, расчетливым. Сразу же после коронации принялся централизовать Империю."
    king "这个我当时不知道。但他变了。变得更残酷，更精于算计。加冕后立刻开始中央集权。  "

# game/a12/9castle_stories.rpy:98
translate english castle_stories_3d12a661:

    # me "А тех, кто ему мешал..."
    me "而那些阻碍他的人……  "

# game/a12/9castle_stories.rpy:99
translate english castle_stories_242d082c:

    # king "Тех он казнил. Сжигал замки, вешал десятки людей на деревьях, пытал И убивал их своими руками."
    king "他处决了他们。烧毁城堡，把几十人吊在树上，亲手折磨并杀死他们。  "

# game/a12/9castle_stories.rpy:100
translate english castle_stories_19f8a09c:

    # me "А ты помогал ему."
    me "而你帮了他。  "

# game/a12/9castle_stories.rpy:101
translate english castle_stories_bba11821:

    # king "Помогал. Сначала я противился. Спорил с ним. Но что-то в его взгляде меня заставляло ему верить. Я видел в его глазах отца, того, старого, милосердного и не злого человека."
    king "帮了。起初我反对过，和他争论。但他眼神中的某种东西让我相信他。我在他眼中看到了那个父亲，那个旧的、仁慈而非恶毒的人。  "

# game/a12/9castle_stories.rpy:102
translate english castle_stories_c67a9376:

    # me "Милосердный и не злой человек сжигал замки и вешал людей?"
    me "一个仁慈而非恶毒的人，烧城堡，吊死人？  "

# game/a12/9castle_stories.rpy:103
translate english castle_stories_bc603918:

    # king "Я чувствовал, что он делает это не просто так. Понимаю, звучит это абсурдно, но я помогал ему, потому что не верил, что он просто жаждет власти."
    king "我感觉他这么做不是无缘无故的。我知道这听起来很荒谬，但我帮他，是因为我不信他只是渴望权力。  "

# game/a12/9castle_stories.rpy:104
translate english castle_stories_f4bf442d:

    # me "Просто из-за добрых глаз?"
    me "仅仅因为那双善良的眼睛？  "

# game/a12/9castle_stories.rpy:105
translate english castle_stories_e5822348:

    # king "Конечно нет. Я никогда не видел его с другой женщиной, кроме моей матери. Я никогда не видел, как он получает удовольствие от насилия, что он совершал. Он требовал подчинения, но никогда не требовал унижаться."
    king "当然不是。我从没见过他除了我母亲以外还有别的女人。我从没见过他对自己施行的暴力感到享受。他要求服从，但从不要求屈辱。  "

# game/a12/9castle_stories.rpy:106
translate english castle_stories_86cb0a61:

    # king "Половина казны в Столице до сих пор состоит из золота с тех времен. Он никогда не тратил его на себя. Никаких летних дворцов, только вооружение армии."
    king "首都国库的一半至今还是那个时代的黄金。他从不把钱花在自己身上。没有避暑宫殿，只有军队的装备。  "

# game/a12/9castle_stories.rpy:107
translate english castle_stories_9ad58263:

    # king "А уж армия... он всегда шел в бой первым. Солдаты любили его больше, чем родных матерей."
    king "而说到军队……他总是第一个冲入战场。士兵们爱他胜过爱自己的亲生母亲。  "

# game/a12/9castle_stories.rpy:108
translate english castle_stories_8648582e:

    # me "И зачем же ты тогда..."
    me "那你当时为什么要……  "

# game/a12/9castle_stories.rpy:109
translate english castle_stories_71f4f0df:

    # king "Оставьте нас."
    king "你们都退下。  "

# game/a12/9castle_stories.rpy:110
translate english castle_stories_9d536993:

    # guard "Да, мой император."
    guard "是，我的皇帝。  "

# game/a12/9castle_stories.rpy:112
translate english castle_stories_05773ba0:

    # king "Я его не убивал."
    king "我没有杀他。  "

# game/a12/9castle_stories.rpy:113
translate english castle_stories_96f2aae1:

    # me "Кто же это сделал?"
    me "那是谁干的？  "

# game/a12/9castle_stories.rpy:114
translate english castle_stories_dc6536e3:

    # king "Я задавался этим вопросом с первой секунды, как меня бросили в темницу."
    king "从我被打入地牢的第一秒起，我就在问自己这个问题。  "

# game/a12/9castle_stories.rpy:115
translate english castle_stories_2e20f919:

    # king "Конечно, я подозревал Региса. В конце концов это именно он обвинил меня. Но мне казалось, что он на такое не способен."
    king "我当然怀疑过Regis。毕竟指控我的就是他。但我觉得他做不出这种事。  "

# game/a12/9castle_stories.rpy:116
translate english castle_stories_b4b9403e:

    # king "Что если он и причастен к отцеубийству, то сделал это чужими руками."
    king "就算他与弑父有关，那也是借他人之手。  "

# game/a12/9castle_stories.rpy:117
translate english castle_stories_a5877c0d:

    # king "Но, по правде говоря, даже эта версия вызывала у меня сомнения."
    king "但说实话，即使是这个版本也让我怀疑。  "

# game/a12/9castle_stories.rpy:118
translate english castle_stories_5ac38cf1:

    # me "Почему?"
    me "为什么？  "

# game/a12/9castle_stories.rpy:119
translate english castle_stories_23f77340:

    # king "В замке был переполох. Я не чувствовал, что это было кем-то спланировано."
    king "城堡里一片混乱。我感觉这不像是有人精心策划的。  "

# game/a12/9castle_stories.rpy:120
translate english castle_stories_0b511840:

    # king "Даже самые близкие ему люди не понимали, что происходит."
    king "甚至他最亲近的人都搞不清发生了什么。  "

# game/a12/9castle_stories.rpy:121
translate english castle_stories_ac0bcd60:

    # syb "Рагвелион?"
    syb "是Ragvelion吗？  "

# game/a12/9castle_stories.rpy:123
translate english castle_stories_1b05e1d8:

    # ragval "Я уже все рассказал. Заканчивайте этот фарс. Я не признаюсь в убийстве отца, потому что я этого не делал."
    ragval "我已经全说了。结束这场闹剧吧。我不会承认杀了父亲，因为不是我干的。  "

# game/a12/9castle_stories.rpy:124
translate english castle_stories_2284f329:

    # syb "А кто, если не ты?"
    syb "如果不是你，那是谁？  "

# game/a12/9castle_stories.rpy:125
translate english castle_stories_77aa5ed7:

    # ragval "Ты пришла убедить меня поверить в то, чего я не делал? Если твоему мужу нужно мое признание - пусть хотя бы применит пытки ради приличия."
    ragval "你是来劝我承认我没做过的事吗？如果你丈夫需要我的认罪——那他至少得为了面子用用刑啊。  "

# game/a12/9castle_stories.rpy:126
translate english castle_stories_38628cea:

    # syb "Пытки? О чем ты говоришь?"
    syb "用刑？你在说什么？  "

# game/a12/9castle_stories.rpy:127
translate english castle_stories_db59787f:

    # ragval "Без пыток я не возьму на себя вину. Так что несите щипцы и отрывайте мне ногти, или уже казните меня наконец-таки."
    ragval "不受刑我是不会认罪的。所以要么拿钳子拔掉我的指甲，要么就干脆杀了我吧。  "

# game/a12/9castle_stories.rpy:128
translate english castle_stories_ddb26ca4:

    # syb "Если бы Регис хотел тебя подставить, разве ты бы уже не был мертв?"
    syb "如果Regis想陷害你，你还能活到现在吗？  "

# game/a12/9castle_stories.rpy:129
translate english castle_stories_26daa962:

    # ragval "Может он хочет привести меня в городской трибунал для иллюзии легитимности всего того, что происходит."
    ragval "也许他想把我送上城市法庭，好给他所做的一切披上合法的外衣。  "

# game/a12/9castle_stories.rpy:130
translate english castle_stories_1cfca852:

    # syb "Он единственный, кто защищает тебя. Требует сначала собрать доказательства."
    syb "他是唯一一个保护你的人。他要求先收集证据。  "

# game/a12/9castle_stories.rpy:131
translate english castle_stories_b47c681a:

    # ragval "Да. Именно поэтому он засунул меня сюда."
    ragval "是啊。正是因此他才把我关在这里。  "

# game/a12/9castle_stories.rpy:132
translate english castle_stories_4d6ab713:

    # syb "Ты был последним, кто заходил к Лотрику. Ты главный подозреваемый."
    syb "你是最后一个进去见Lotric的人。你是主要嫌疑人。  "

# game/a12/9castle_stories.rpy:133
translate english castle_stories_5a4050c6:

    # ragval "И это значит, что я его убил?"
    ragval "这就意味着是我杀了他吗？  "

# game/a12/9castle_stories.rpy:134
translate english castle_stories_bfeb207b:

    # syb "А кто? Регис вышел раньше тебя. Десятки людей видели его."
    syb "那还有谁？Regis比你早出来。几十号人都看见他了。  "

# game/a12/9castle_stories.rpy:136
translate english castle_stories_6875a401:

    # ragval "По-твоему я такой идиот, что просто убил отца и молча ушел, не попытавшись спрятать тело или хотя бы кого-то подставить?"
    ragval "你觉得我是白痴吗？会杀了父亲然后一声不吭地走掉，不试图藏尸，或者至少嫁祸给别人？  "

# game/a12/9castle_stories.rpy:137
translate english castle_stories_7aa0c584:

    # syb "...нет, но..."
    syb "……不，但是……  "

# game/a12/9castle_stories.rpy:138
translate english castle_stories_b7efb2ff:

    # ragval "Но что?"
    ragval "但是什么？  "

# game/a12/9castle_stories.rpy:139
translate english castle_stories_0f9cb6b8:

    # syb "Но кто тогда? Стражники были снаружи, их видели все просители в очереди. Между тем, как ты вышел и как обнаружили тело прошло не больше пяти минут."
    syb "但那是谁呢？侍卫当时在外面，走廊里排队的请愿者都看见了。从你出来到发现尸体，中间不超过五分钟。  "

# game/a12/9castle_stories.rpy:140
translate english castle_stories_31bb2c5b:

    # ragval "Значит убийца был внутри."
    ragval "那么凶手就在里面。  "

# game/a12/9castle_stories.rpy:141
translate english castle_stories_ce1bd68f:

    # syb "А как он вышел?"
    syb "那他是怎么离开的？  "

# game/a12/9castle_stories.rpy:142
translate english castle_stories_c51567c7:

    # ragval "Понятия не имею. Может портал? Вы проверили Магну?"
    ragval "我怎么会知道。也许用了传送门？你们查过玛格努斯吗？  "

# game/a12/9castle_stories.rpy:143
translate english castle_stories_07c4c075:

    # syb "Портал? Императора убили не магией, а мечом."
    syb "传送门？皇帝不是被魔法杀死的，而是剑。  "

# game/a12/9castle_stories.rpy:144
translate english castle_stories_78dbdec0:

    # ragval "Что? Она не способна поднять меч?"
    ragval "怎么？她举不起剑吗？  "

# game/a12/9castle_stories.rpy:145
translate english castle_stories_9bd71f9d:

    # syb "Портал ведет в случайное место. Ей нужно было бы вернуться в замок, а она была в нем сразу после убийства."
    syb "传送门通向随机地点。她需要在事后返回城堡，而她就在谋杀发生后立刻出现在城堡里。  "

# game/a12/9castle_stories.rpy:146
translate english castle_stories_575a769b:

    # ragval "Может убийца все еще там. Или был внутри после убийства. Спрятался там же, где и ждал."
    ragval "也许凶手还在那里。或者谋杀后还留在里面。就藏在他埋伏的那个地方。  "

# game/a12/9castle_stories.rpy:147
translate english castle_stories_6d845899:

    # syb "Там все обыскали. Никаких следов нет. Прятаться было негде."
    syb "那里全都搜过了。没有留下任何痕迹。根本没地方藏身。  "

# game/a12/9castle_stories.rpy:148
translate english castle_stories_09e1108a:

    # ragval "Ну что же... выходит это сделал я. Десять лет воевал с отцом бок о бок, чтобы убить его и лишиться за это головы. Вот такой я безумец."
    ragval "那好吧……看来就是我干的。和父亲并肩作战十年，就为了杀了他然后丢掉自己的脑袋。我就是这么个疯子。  "

# game/a12/9castle_stories.rpy:149
translate english castle_stories_7a56cf1f:

    # syb "Но... если Регис тебя подставил, то как... я просто не понимаю..."
    syb "但……如果是Regis陷害你，那他是怎么……我实在搞不懂……  "

# game/a12/9castle_stories.rpy:150
translate english castle_stories_ca2dd6cb:

    # ragval "О боги..."
    ragval "哦，诸神啊……  "

# game/a12/9castle_stories.rpy:152
translate english castle_stories_1578cb5f:

    # ragval "Ты и сама понятия не имеешь, причастен твой муж или нет."
    ragval "你自己也不知道，你丈夫是否参与了。  "

# game/a12/9castle_stories.rpy:153
translate english castle_stories_05163c75:

    # syb "Нет. Я этого не знаю."
    syb "是的。我不知道。  "

# game/a12/9castle_stories.rpy:154
translate english castle_stories_f3430202:

    # ragval "Но мне ты веришь?"
    ragval "但你相信我吧？  "

# game/a12/9castle_stories.rpy:155
translate english castle_stories_7f0a465c:

    # syb "...не знаю. У тебя и вправду не было причин этого делать. Какой смысл?"
    syb "……不知道。你真的没有理由这样做。有什么意义呢？  "

# game/a12/9castle_stories.rpy:156
translate english castle_stories_9249830d:

    # ragval "Спасибо. Рад, что хоть один человек в замке еще не совсем сошел с ума."
    ragval "谢谢。很高兴城堡里至少还有一个人没有完全疯掉。  "

# game/a12/9castle_stories.rpy:157
translate english castle_stories_0c3379c0:

    # syb "И все же... как? Кто?"
    syb "可还是……怎么做到的？是谁？  "

# game/a12/9castle_stories.rpy:158
translate english castle_stories_80aecc49:

    # ragval "У меня нет доступа к расследованию. Я лишь могу верить тебе на слово. Если все что ты говоришь - правда, тогда убийца явно обладает недюжинными талантами."
    ragval "我没法接触调查。只能凭你的话去相信。如果你说的一切都是真的，那凶手显然拥有非凡的本领。  "

# game/a12/9castle_stories.rpy:159
translate english castle_stories_878482d9:

    # syb "Похоже на то..."
    syb "看起来是这样……  "

# game/a12/9castle_stories.rpy:160
translate english castle_stories_3c3a1c4e:

    # ragval "Отец оказывал сопротивление?"
    ragval "父亲当时反抗了吗？  "

# game/a12/9castle_stories.rpy:161
translate english castle_stories_d12b76df:

    # syb "Не похоже на то. Его убили одним ударом в сердце. Видимо он не успел как-то среагировать."
    syb "不像。他是被一剑刺入心脏杀死的。看来他没能来得及做出任何反应。  "

# game/a12/9castle_stories.rpy:162
translate english castle_stories_40465d84:

    # ragval "Ну... если бы кто-то взял его меч, он точно попытался бы защититься."
    ragval "嗯……如果有人拿了他的剑，他肯定会试图自卫的。  "

# game/a12/9castle_stories.rpy:163
translate english castle_stories_d1cb8a14:

    # syb "Если он это вообще заметил, пока не стало слишком поздно."
    syb "除非在他注意到之前，就已经太迟了。  "

# game/a12/9castle_stories.rpy:164
translate english castle_stories_d5a8439e:

    # ragval "Ну не призрак же это сделал."
    ragval "总不会是幽灵干的吧。  "

# game/a12/9castle_stories.rpy:166
translate english castle_stories_371696b0:

    # me "Так кто это сделал?"
    me "那到底是谁干的？  "

# game/a12/9castle_stories.rpy:167
translate english castle_stories_5fe6a63b:

    # king "Я не знаю."
    king "我不知道。  "

# game/a12/9castle_stories.rpy:168
translate english castle_stories_a0ce89f9:

    # me "До сих пор?"
    me "到现在也不知道？  "

# game/a12/9castle_stories.rpy:169
translate english castle_stories_2f049b33:

    # king "До сих пор. Это загадка для меня."
    king "到现在也不知道。这对我来说是个谜。  "

# game/a12/9castle_stories.rpy:170
translate english castle_stories_fcfe7532:

    # me "Но... были же какие-то версии помимо тебя и Региса."
    me "但……除了你和Regis，总该有过一些别的猜测吧。  "

# game/a12/9castle_stories.rpy:171
translate english castle_stories_d1b8baa1:

    # king "Может и были. Но доказательств не было."
    king "也许有。但没有证据。  "

# game/a12/9castle_stories.rpy:172
translate english castle_stories_e7698b72:

    # me "Может кто-то провел внутрь замка особенно талантливого убийцу."
    me "也许有人把一个特别有本事的刺客带进了城堡。  "

# game/a12/9castle_stories.rpy:173
translate english castle_stories_9c600f23:

    # king "Отца убили ударом меча в грудь. Представить, что он хотя бы не закрылся бы рукой - невозможно."
    king "父亲是被一剑刺胸杀死的。想象他连用手挡一下都没有……这不可能。  "

# game/a12/9castle_stories.rpy:174
translate english castle_stories_777597e8:

    # me "Значит это был кто-то, кто мог взять меч в руки и не вызвать подозрений."
    me "所以这必定是个能拿起剑又不引起怀疑的人。  "

# game/a12/9castle_stories.rpy:175
translate english castle_stories_628a49f2:

    # king "Кто например?"
    king "比如谁？  "

# game/a12/9castle_stories.rpy:176
translate english castle_stories_ed656ca4:

    # me "Не знаю. Кто имел доступ к замку и дворцу?"
    me "不知道。谁有权接近城堡和宫殿？  "

# game/a12/9castle_stories.rpy:177
translate english castle_stories_d9483376:

    # king "Только ближайшее окружение. Но это не имеет значения, даже если бы это был кто-то из совета или семьи, он бы не смог выбраться незамеченным. Отец в тот день принимал прошения. В коридоре было полно людей."
    king "只有最亲近的人。但这没用，就算是议会成员或家族里的人，也不可能不被发现地逃脱。父亲那天在接见请愿者，走廊里全都是人。  "

# game/a12/9castle_stories.rpy:178
translate english castle_stories_37f50030:

    # me "Может мы чего-то не знаем о замке? Давай забудем на секунду о методе побега. Кто из ближайшего круга, кто имел доступ к замку и дворцу в любое время мог быть заинтересован?"
    me "也许我们对城堡还不够了解？我们先忘掉逃脱方法一秒钟。谁是最亲近的圈子，可以随时进入城堡和宫殿，并且可能有利害关系的人？  "

# game/a12/9castle_stories.rpy:179
translate english castle_stories_2aac503b:

    # king "Заинтересован?"
    king "利害关系？  "

# game/a12/9castle_stories.rpy:180
translate english castle_stories_cf90ec0a:

    # me "Ну... после поражение у Синих Гор наверняка было много споров."
    me "嗯……在蓝山战败之后，肯定有很多争论。  "

# game/a12/9castle_stories.rpy:181
translate english castle_stories_2307b1ff:

    # king "Разумеется."
    king "当然。  "

# game/a12/9castle_stories.rpy:183
translate english castle_stories_d3aa02d6:

    # lagg "Нужно собрать армии снова. Со всего континента. Кавалерию с Запада, фаланги с Юга, объявим рекрутинг здесь. За месяц мы соберем людей вдвое... втрое больше."
    lagg "必须再次集结军队。从整个大陆。西部的骑兵，南部的方阵，我们在这里宣布征兵。一个月内我们就能集结两倍……三倍的人手。  "

# game/a12/9castle_stories.rpy:184
translate english castle_stories_ce7bbabd:

    # leonard "Желание немедленного реванша соблазнительно, но неверно."
    leonard "渴望立刻复仇的想法的确诱人，但那是错误的。  "

# game/a12/9castle_stories.rpy:185
translate english castle_stories_05f5beb8:

    # lagg "А чего тянуть? Пока они оправятся? Там полегло не меньше северян, чем нас. У них человеческий ресурс ограничен."
    lagg "还等什么呢？等他们恢复元气？倒在那里的北方人可不比我们的人少。他们的人力资源是有限的。  "

# game/a12/9castle_stories.rpy:186
translate english castle_stories_3260a4be:

    # leonard "У нас вообще-то тоже."
    leonard "咱们的人力资源其实也有限。  "

# game/a12/9castle_stories.rpy:187
translate english castle_stories_131e7b0f:

    # lagg "Будем ждать - они подумают, что мы испугались."
    lagg "如果我们等着，他们会以为我们害怕了。  "

# game/a12/9castle_stories.rpy:188
translate english castle_stories_3173fd9d:

    # leonard "Разумнее будет наложить на них блокаду. Медленно продвигаться со стороны вольных городов будет эффективнее."
    leonard "对他们进行封锁更为合理。从自由城邦那边缓慢推进会更有效。  "

# game/a12/9castle_stories.rpy:189
translate english castle_stories_e05ea672:

    # lagg "Иногда быстро ударить - эффективнее."
    lagg "有时候迅速出击更有效。  "

# game/a12/9castle_stories.rpy:190
translate english castle_stories_6b763546:

    # leonard "Это не тот случай. Они могут отступать в горы сколько захотят. Они снова дождутся удачного момента и нападут, когда мы будем на длительном броске вглубь. Как это и было у Синих Гор."
    leonard "不是这种情况。他们可以随意退入山区。他们会再次等待一个好时机，趁我们长途深入行军时攻击我们。就像在蓝山那次一样。  "

# game/a12/9castle_stories.rpy:191
translate english castle_stories_0f353fc0:

    # lagg "Если будет ползти, как черепахи, придется изрядно потратиться на такую длительную кампанию."
    lagg "如果像乌龟一样爬，这么长的战役，花费可就大了。  "

# game/a12/9castle_stories.rpy:192
translate english castle_stories_09f4500b:

    # leonard "Если все умрут никому платить не придется. Логично, Лаггариус."
    leonard "如果所有人都死了，那就谁都不用付钱了。逻辑成立，Laggarius。  "

# game/a12/9castle_stories.rpy:193
translate english castle_stories_54d75019:

    # lagg "Да ну тебя нахрен. Принц Рагвелион меня понимает, да?"
    lagg "去你的。Ragvelion王子理解我的意思，对吧？  "

# game/a12/9castle_stories.rpy:195
translate english castle_stories_215581a8:

    # ragval "Отчасти. Я думаю вы оба правы."
    ragval "部分理解。我觉得你们俩都对。  "

# game/a12/9castle_stories.rpy:196
translate english castle_stories_30912ab8:

    # lagg "Как это?"
    lagg "怎么说？  "

# game/a12/9castle_stories.rpy:197
translate english castle_stories_9acfa28e:

    # ragval "Пожалуй не стоит больше пытаться решить эту проблему за пару недель. 'Одна хорошая битва' обернулась для нас серьезной проблемой."
    ragval "也许我们不该再试图在几周内解决这个问题了。“一次漂亮的大战”已经给我们带来了大麻烦。  "

# game/a12/9castle_stories.rpy:198
translate english castle_stories_faf567e0:

    # leonard "Об этом я и говорю."
    leonard "我就是这个意思。  "

# game/a12/9castle_stories.rpy:199
translate english castle_stories_754d4ab7:

    # ragval "Но скорость это действительно важно. Они потеряли множество хороших воинов. Пока они будут восстанавливаться мы должны пользоваться этим."
    ragval "但速度确实很重要。他们损失了许多好战士。我们应该趁他们恢复元气时利用这一点。  "

# game/a12/9castle_stories.rpy:200
translate english castle_stories_4ab543f6:

    # regis "А может лучше воспользуемся дипломатией."
    regis "也许不如用用外交手段。  "

# game/a12/9castle_stories.rpy:201
translate english castle_stories_6698a003:

    # lagg "Каким образом? Они нарушили Золотой Порядок."
    lagg "怎么用？他们破坏了黄金秩序。  "

# game/a12/9castle_stories.rpy:202
translate english castle_stories_fb17281a:

    # ragval "Ну у них же есть требования?"
    ragval "他们不是有要求吗？  "

# game/a12/9castle_stories.rpy:203
translate english castle_stories_c14a7d1f:

    # lagg "Требования сепаратистов выполнять мы не будем."
    lagg "我们不会满足分裂主义者的要求。  "

# game/a12/9castle_stories.rpy:204
translate english castle_stories_25e48371:

    # leonard "Если только они не откажутся от идеи независимости."
    leonard "除非他们放弃独立的念头。  "

# game/a12/9castle_stories.rpy:205
translate english castle_stories_a4dbb215:

    # regis "А если откажутся?"
    regis "如果他们放弃呢？  "

# game/a12/9castle_stories.rpy:206
translate english castle_stories_2c527c77:

    # ragval "Сомневаюсь, что они откажутся распустить армию после этого."
    ragval "我怀疑他们在此之后不会同意解散军队。  "

# game/a12/9castle_stories.rpy:207
translate english castle_stories_666acd48:

    # lagg "Вот именно. Нужно дожимать их."
    lagg "正是。必须乘胜追击。  "

# game/a12/9castle_stories.rpy:208
translate english castle_stories_89bb39e3:

    # leonard "Главное не спешить..."
    leonard "关键是不能急……  "

# game/a12/9castle_stories.rpy:209
translate english castle_stories_3495cbef:

    # regis "Я бы беспокоился сейчас не о Севере."
    regis "我现在担心的倒不是北方。  "

# game/a12/9castle_stories.rpy:210
translate english castle_stories_5064e656:

    # ragval "Есть какие-то вести об отступающих?"
    ragval "有败军的消息吗？  "

# game/a12/9castle_stories.rpy:211
translate english castle_stories_ef392723:

    # lagg "Пару отрядов вернулись через города на севере."
    lagg "有几支队伍通过北边的城市撤回来了。  "

# game/a12/9castle_stories.rpy:212
translate english castle_stories_13673e90:

    # leonard "Эти части небоеспособны. По крайней мере пока."
    leonard "这些部队没有战斗力。至少暂时没有。  "

# game/a12/9castle_stories.rpy:213
translate english castle_stories_1c3902cf:

    # lagg "А почему наш башенный советник молчит?"
    lagg "我们的高塔顾问怎么不说话？  "

# game/a12/9castle_stories.rpy:215
translate english castle_stories_cef97eb2:

    # magna "Я не могу вмешиваться в наступательные войны. Только помогать защищаться."
    magna "我不能干涉进攻性的战争。只能协助防御。  "

# game/a12/9castle_stories.rpy:216
translate english castle_stories_65a5d957:

    # lagg "А мы вас на поле боя не зовем. Просто интересно ваше мнение."
    lagg "我们又不是叫您上战场。只是想听听您的意见。  "

# game/a12/9castle_stories.rpy:217
translate english castle_stories_2888e85e:

    # magna "Я..."
    magna "我……  "

# game/a12/9castle_stories.rpy:218
translate english castle_stories_0a23915a:

    # lagg "Что? Правила башен и мнением запрещают делиться? Зачем тогда вы вообще нужны?"
    lagg "什么？高塔的规矩连分享意见也禁止吗？那要你们还有什么用？  "

# game/a12/9castle_stories.rpy:219
translate english castle_stories_008686cc:

    # magna "Нет. Мнение не запрещено. Просто мое мнение вам не понравится."
    magna "不，意见没有被禁止。只是我的意见你们不会喜欢。  "

# game/a12/9castle_stories.rpy:220
translate english castle_stories_c70c2bbf:

    # lagg "Почему это?"
    lagg "为什么？  "

# game/a12/9castle_stories.rpy:221
translate english castle_stories_b5700ac4:

    # magna "Я согласна с принцем Регисом. Дипломатия способна решить этот конфликт без дальнейшего кровопролития."
    magna "我同意Regis王子的看法。外交能够在不造成更多流血的情况下解决这个冲突。  "

# game/a12/9castle_stories.rpy:222
translate english castle_stories_f6a84588:

    # regis "Спасибо."
    regis "谢谢。  "

# game/a12/9castle_stories.rpy:223
translate english castle_stories_1260d6b6:

    # lagg "Какая чушь."
    lagg "真是胡说。  "

# game/a12/9castle_stories.rpy:224
translate english castle_stories_ad23d237:

    # leonard "Они подпишут только сепаратный мир или неотличимый от него мир с сохранением своей армии."
    leonard "他们只会签署单独的和平协议，或者与之无异的协议，同时保留自己的军队。  "

# game/a12/9castle_stories.rpy:225
translate english castle_stories_926ed281:

    # magna "Вы просили услышать мое мнение."
    magna "是你们要求听我的意见的。  "

# game/a12/9castle_stories.rpy:226
translate english castle_stories_73b65252:

    # lagg "Ну да. Маги. Как всегда полезны. Не удивительно, что вас так мало осталось."
    lagg "哦，是啊。法师。一如既往地“有用”。难怪你们剩不下几个人了。  "

# game/a12/9castle_stories.rpy:227
translate english castle_stories_38cd0ea4:

    # magna "Вы сами меня спросили."
    magna "是您自己问我的。  "

# game/a12/9castle_stories.rpy:229
translate english castle_stories_98d61075:

    # lagg "Да, я расчитывал на хоть сколько отличимый от капитуляции совет."
    lagg "对，我指望的是至少能听到一个和投降有所区别的建议。  "

# game/a12/9castle_stories.rpy:230
translate english castle_stories_be2cf48c:

    # leonard "Переговоры сейчас действительно бесполезны. Они думают, что побеждают, а значит будут требовать нереалистичные вещи."
    leonard "现在的确进行谈判毫无用处。他们自认为正在获胜，所以会提出不切实际的要求。  "

# game/a12/9castle_stories.rpy:231
translate english castle_stories_45cfe544:

    # regis "Да, но мы могли бы хотя бы принять их дипломата."
    regis "是的，但我们至少可以接见他们的外交官。  "

# game/a12/9castle_stories.rpy:232
translate english castle_stories_fdfb7567:

    # ragval "Дипломата?"
    ragval "外交官？  "

# game/a12/9castle_stories.rpy:233
translate english castle_stories_8427fba5:

    # magna "Это хорошая идея."
    magna "这是个好主意。  "

# game/a12/9castle_stories.rpy:234
translate english castle_stories_82d46b20:

    # lagg "Да вы охренели! Дипломата от нашей же провинции Империи? Вы что, не понимаете? Дадим им спуск и за ними последуют остальные."
    lagg "你们疯了吧！接见我们帝国一个省份派来的外交官？你们不明白吗？我们对他们退让一步，其他人就会跟风。  "

# game/a12/9castle_stories.rpy:235
translate english castle_stories_c1033ae1:

    # leonard "Здесь я вынужден согласится."
    leonard "在这一点上，我不得不赞同。  "

# game/a12/9castle_stories.rpy:236
translate english castle_stories_97d49eec:

    # regis "Может настало время для... послаблений и реорганизации?"
    regis "也许是时候进行一些……放宽政策和重组了？  "

# game/a12/9castle_stories.rpy:237
translate english castle_stories_c8390008:

    # ragval "О чем ты?"
    ragval "你什么意思？  "

# game/a12/9castle_stories.rpy:238
translate english castle_stories_793076a1:

    # magna "Полагаю принц Регис говорит о том, что предыдущая форма управления была не так плоха."
    magna "我想Regis王子的意思是，过去的治理模式并非那么糟糕。  "

# game/a12/9castle_stories.rpy:239
translate english castle_stories_a9f96bd0:

    # lagg "Вы... вы что мать твою несете? Это предательство!"
    lagg "你们……你们他妈的在说什么？这是背叛！  "

# game/a12/9castle_stories.rpy:240
translate english castle_stories_4de55557:

    # leonard "Успокойся, Лаггариус."
    leonard "冷静点，Laggarius。  "

# game/a12/9castle_stories.rpy:241
translate english castle_stories_f47711cd:

    # regis "Мы просто предлагаем. Пока только с Севером. Можно предложить им старые условия нахождения в Империи, и если они не согласятся - тогда уже воевать."
    regis "我们只是提议。目前只针对北方。可以给他们提供过去留在帝国内的旧条件，如果他们不同意——那时再开战。  "

# game/a12/9castle_stories.rpy:242
translate english castle_stories_b12a5651:

    # ragval "Они откажутся даже от такого предложения."
    ragval "就算是这样的提议他们也会拒绝。  "

# game/a12/9castle_stories.rpy:244
translate english castle_stories_caf54993:

    # bloodking "Хватит. Я устал слушать. Вы здесь не чтобы болтать друг с другом без умолку. Заткнитесь хотя бы на секунду."
    bloodking "够了。我听得烦了。你们在这里不是为了无休止地争吵。至少给我安静一秒钟。  "

# game/a12/9castle_stories.rpy:245
translate english castle_stories_a8376544:

    # ragval "..."
    ragval "..."

# game/a12/9castle_stories.rpy:246
translate english castle_stories_c325c1a8:

    # magna "..."
    magna "..."

# game/a12/9castle_stories.rpy:247
translate english castle_stories_a58b7699:

    # lagg "..."
    lagg "..."

# game/a12/9castle_stories.rpy:248
translate english castle_stories_04a735cd:

    # leonard "..."
    leonard "..."

# game/a12/9castle_stories.rpy:249
translate english castle_stories_9073b634:

    # regis "..."
    regis "..."

# game/a12/9castle_stories.rpy:250
translate english castle_stories_5a8afe47:

    # bloodking "Спасибо. А теперь предложение от каждого. По очереди. Кратко. Рагвелион."
    bloodking "谢谢。现在，每个人给出一个建议。按顺序。简要说明。Ragvelion。  "

# game/a12/9castle_stories.rpy:251
translate english castle_stories_8dc2f1dc:

    # ragval "Я бы пересобрал армию уже сейчас. Отправил бы ее к городам на гряде, пока армия у Севера не готова, мы бы заняли их и осадили пару замков поближе."
    ragval "我会现在就重组军队。趁北方的军队还没准备好，把它派到山脊旁的城镇，我们可以占领它们，并围攻几座近处的城堡。  "

# game/a12/9castle_stories.rpy:252
translate english castle_stories_6e8c884d:

    # bloodking "Лаггариус."
    bloodking "Laggarius。  "

# game/a12/9castle_stories.rpy:253
translate english castle_stories_d7e292c9:

    # lagg "Я бы вернулся к Нордштадту, организовал там масштабный сбор войск и вернулся к Синим Горам. Второй раз мы будем готовы."
    lagg "我会回到诺德施塔特，在那里组织大规模部队集结，然后返回蓝山。第二次我们会做好准备。  "

# game/a12/9castle_stories.rpy:254
translate english castle_stories_81893948:

    # bloodking "Леонард."
    bloodking "Leonard。  "

# game/a12/9castle_stories.rpy:255
translate english castle_stories_2e4ccede:

    # leonard "Лучше всего организовать блокаду их портов. Пока они будут пополнять армию - воспользуемся этим и будет сжимать вокруг них кольцо. Медленно, постепенно. Будем захватывать только приграничные города и замки."
    leonard "最好是封锁他们的港口。趁他们补充军队时加以利用，收紧对他们的包围圈。缓慢地，逐步地。只攻占边境的城镇和城堡。  "

# game/a12/9castle_stories.rpy:256
translate english castle_stories_4bb836b1:

    # leonard "Так мы вынудим их атаковать всеми силами по одному из направлений. К этому времени подготовим свою армии в резерве. Контратакуем и получим битву уже на своих условиях."
    leonard "这样我们就会迫使他们倾全力沿一个方向攻击。到那时，我们就在后方准备好预备队。进行反攻，并按我们自己的条件决战。  "

# game/a12/9castle_stories.rpy:257
translate english castle_stories_19e9fd38:

    # bloodking "Регис."
    bloodking "Regis。  "

# game/a12/9castle_stories.rpy:258
translate english castle_stories_c832bd1c:

    # regis "Я бы не стал воевать дальше. Они готовы к переговорам. Да, они хотят сейчас слишком многого. Но если мы продемонстрируем интерес к миру, мы дадим им надежду и они со временем уменьшат требования, лишь бы не возвращаться к войне.."
    regis "我不会继续开战了。他们已经准备好谈判。是的，他们现在想要得太多了。但如果我们对和平表现出兴趣，我们就能给他们希望，随着时间推移，他们会降低要求，只为避免重返战争。  "

# game/a12/9castle_stories.rpy:259
translate english castle_stories_5162380b:

    # bloodking "Магна."
    bloodking "Magna。  "

# game/a12/9castle_stories.rpy:260
translate english castle_stories_4e58d5ff:

    # magna "Я согласна с Регисом."
    magna "我同意Regis的看法。  "

# game/a12/9castle_stories.rpy:261
translate english castle_stories_93c3c609:

    # bloodking "Понятно."
    bloodking "明白了。  "

# game/a12/9castle_stories.rpy:263
translate english castle_stories_dce202aa:

    # bloodking "..."
    bloodking "..."

# game/a12/9castle_stories.rpy:264
translate english castle_stories_3f2ff1a7:

    # ragval "Отец?"
    ragval "父亲？  "

# game/a12/9castle_stories.rpy:265
translate english castle_stories_4c31c875:

    # regis "Я могу объяснить."
    regis "我可以解释。  "

# game/a12/9castle_stories.rpy:266
translate english castle_stories_724eeaea:

    # bloodking "Рагвелион. Возьмешь Леонарда и вместе придумаете план действий к утру."
    bloodking "Ragvelion，你带上Leonard，一起在天亮前制定一个行动计划。  "

# game/a12/9castle_stories.rpy:267
translate english castle_stories_ca8a851b:

    # ragval "Да. Отец."
    ragval "是，父亲。  "

# game/a12/9castle_stories.rpy:268
translate english castle_stories_1dc9a34c:

    # regis "Мне кажется это ошибка, отец. Слишком много воинов погибло."
    regis "我觉得这是个错误，父亲。太多战士牺牲了。  "

# game/a12/9castle_stories.rpy:269
translate english castle_stories_c1c8295c:

    # bloodking "Разве я спрашивал твоего мнения?"
    bloodking "我什么时候问过你的意见？  "

# game/a12/9castle_stories.rpy:270
translate english castle_stories_cb2f8624:

    # regis "Нет, но ты же спросил..."
    regis "没有，但你刚才问了……  "

# game/a12/9castle_stories.rpy:271
translate english castle_stories_84e8d080:

    # bloodking "Я спросил какое у тебя предложение. Ты его озвучил."
    bloodking "我问的是你有什么提议。你已经说了。  "

# game/a12/9castle_stories.rpy:272
translate english castle_stories_46e80d9d:

    # regis "Да. Озвучил. Но прежде чем ты сделаешь выбор..."
    regis "是的。我说了。但在你做决定之前……  "

# game/a12/9castle_stories.rpy:273
translate english castle_stories_64a59427:

    # bloodking "Я его уже сделал."
    bloodking "我已经做出决定了。  "

# game/a12/9castle_stories.rpy:274
translate english castle_stories_575bd4cf:

    # regis "Верно. Да. Но..."
    regis "没错。是的。但是……  "

# game/a12/9castle_stories.rpy:275
translate english castle_stories_4159e404:

    # bloodking "Заткнись."
    bloodking "闭嘴。  "

# game/a12/9castle_stories.rpy:276
translate english castle_stories_ad80c196:

    # regis "Отец?"
    regis "父亲？  "

# game/a12/9castle_stories.rpy:278
translate english castle_stories_8d5e9332:

    # bloodking "Твое предложение омерзительно. Оскорбительно и трусливо. Если бы ты не был моим сыном, я бы заподозрил тебя в предательстве."
    bloodking "你的提议令人作呕。既可耻又懦弱。如果你不是我儿子，我真会怀疑你背叛了。  "

# game/a12/9castle_stories.rpy:279
translate english castle_stories_93b23180:

    # regis "Я..."
    regis "我……  "

# game/a12/9castle_stories.rpy:280
translate english castle_stories_dec5e38f:

    # bloodking "Впрочем, может мне и стоит подозревать тебя?"
    bloodking "不过，也许我真该怀疑你？  "

# game/a12/9castle_stories.rpy:281
translate english castle_stories_929069bc:

    # regis "Я не предавал тебя, отец."
    regis "我没有背叛你，父亲。  "

# game/a12/9castle_stories.rpy:282
translate english castle_stories_fa29a4ec:

    # bloodking "Император. Я не только твоей отец. Я еще твой Император."
    bloodking "是皇帝。我不只是你的父亲！我还是你的皇帝。  "

# game/a12/9castle_stories.rpy:283
translate english castle_stories_308a76bf:

    # regis "Да, мой Император. Я всего лишь..."
    regis "是的，我的皇帝。我只是……  "

# game/a12/9castle_stories.rpy:284
translate english castle_stories_7dadca5e:

    # bloodking "Всего лишь что? Хотел принудить меня к миру с предателями?"
    bloodking "只是想怎样？想逼我同叛徒讲和？  "

# game/a12/9castle_stories.rpy:285
translate english castle_stories_f21743c0:

    # regis "Я бы не посмел... я...."
    regis "我不敢……我……  "

# game/a12/9castle_stories.rpy:286
translate english castle_stories_b87e936f:

    # bloodking "Нет, в этом и беда. Ты посмел. Ты слишком долго сидел в Столице и безделие отравило тебе мозги. Ты размяк, общество знати тебя испортило."
    bloodking "不，问题就在这儿。你敢了。你在首都坐得太久，无所事事让你的脑子都生锈了。你变软弱了，贵族社会腐蚀了你。  "

# game/a12/9castle_stories.rpy:287
translate english castle_stories_9073b634_1:

    # regis "..."
    regis "..."

# game/a12/9castle_stories.rpy:288
translate english castle_stories_8d0b20e4:

    # bloodking "Что? Хочешь сказать это не так?"
    bloodking "怎么？你想说这不是事实吗？  "

# game/a12/9castle_stories.rpy:289
translate english castle_stories_05d57bc3:

    # regis "Мой Император, я..."
    regis "我的皇帝，我……  "

# game/a12/9castle_stories.rpy:290
translate english castle_stories_2a95ff13:

    # bloodking "Я не для того столько лет объединял Империю, чтобы мой собственный сын предложил мне подписывать сепаратный мир."
    bloodking "我花了这么多年统一帝国，不是为了让我自己的儿子提议我去签署单独和平协议的。  "

# game/a12/9castle_stories.rpy:291
translate english castle_stories_9073b634_2:

    # regis "..."
    regis "..."

# game/a12/9castle_stories.rpy:292
translate english castle_stories_82812ea4:

    # bloodking "С сегодняшняго дня ты и Магна больше не часть совета."
    bloodking "从今天起，你和Magna不再是议会的成员。  "

# game/a12/9castle_stories.rpy:293
translate english castle_stories_ca36b3b1:

    # regis "Отец..."
    regis "父亲……  "

# game/a12/9castle_stories.rpy:294
translate english castle_stories_c560694b:

    # bloodking "Стоит наказать вас, но маги дают клятвы, я уважаю это, хоть и не принимаю. А ты... ты возглавишь одну из армий, что двинется на Север."
    bloodking "本该惩罚你们，但法师有誓言约束，对此我虽不认同，但也表示尊重。而你……你将率领一支向北方进发的军队。  "

# game/a12/9castle_stories.rpy:295
translate english castle_stories_e778cede:

    # regis "Мой Император!"
    regis "我的皇帝！  "

# game/a12/9castle_stories.rpy:296
translate english castle_stories_573632bd:

    # bloodking "Это твой долг."
    bloodking "这是你的责任。  "

# game/a12/9castle_stories.rpy:298
translate english castle_stories_2cb2a681:

    # me "Ну... понятно. Вот и два главных подозреваемых."
    me "嗯……明白了。这下有了两个主要嫌疑人。  "

# game/a12/9castle_stories.rpy:299
translate english castle_stories_7dcfeb77:

    # king "Два?"
    king "两个？  "

# game/a12/9castle_stories.rpy:300
translate english castle_stories_8e4a3772:

    # me "Магна была уволена из совета? Где-то я уже слышал это имя кстати."
    me "Magna被赶出了议会吗？说起来，我好像在哪里听说过这个名字。  "

# game/a12/9castle_stories.rpy:301
translate english castle_stories_ef4645a9:

    # king "Она была уволена из военного совета. Она продолжила быть каменным советником."
    king "她是被赶出了军事议会，但她仍是御石顾问。  "

# game/a12/9castle_stories.rpy:302
translate english castle_stories_3db5cf84:

    # me "Ну... а Регис?"
    me "那……Regis呢？  "

# game/a12/9castle_stories.rpy:303
translate english castle_stories_af6c8b14:

    # king "Более вероятно.... но..."
    king "更有可能……但是……  "

# game/a12/9castle_stories.rpy:304
translate english castle_stories_acd9b46f:

    # me "Но что?"
    me "但是什么？  "

# game/a12/9castle_stories.rpy:305
translate english castle_stories_9632852f:

    # king "Я до сих пор думаю, что он бы на такое не пошел."
    king "我到现在还是觉得，他不至于做出这种事。  "

# game/a12/9castle_stories.rpy:306
translate english castle_stories_264f4dae:

    # me "Он явно не хотел быть частью нового похода. Может это побудило его действовать?"
    me "他显然不想参与新的战役。也许这促使了他行动？  "

# game/a12/9castle_stories.rpy:307
translate english castle_stories_ed8919e4:

    # king "Отец отменил это решение."
    king "父亲后来又取消了那个决定。  "

# game/a12/9castle_stories.rpy:308
translate english castle_stories_a607796d:

    # me "Отменил? Когда?"
    me "取消了？什么时候？  "

# game/a12/9castle_stories.rpy:309
translate english castle_stories_2640ad96:

    # king "В тот же самый день, когда его убили."
    king "就在他被害的同一天。  "

# game/a12/9castle_stories.rpy:310
translate english castle_stories_db03f443:

    # me "Это тебе Регис сказал?"
    me "这是Regis告诉你的？  "

# game/a12/9castle_stories.rpy:311
translate english castle_stories_3e7482a9:

    # king "Нет, это я слышал своими собственными ушами."
    king "不，这是我亲耳听到的。  "

# game/a12/9castle_stories.rpy:313
translate english castle_stories_f2b4a7b2:

    # bloodking "...благодарю за помощь с делами в Столице."
    bloodking "……谢谢你帮我在首都处理政务。  "

# game/a12/9castle_stories.rpy:314
translate english castle_stories_634443c2:

    # regis "Парочку просителей все равно нужно бы принять."
    regis "还是有一批请愿者需要接见。  "

# game/a12/9castle_stories.rpy:315
translate english castle_stories_dce202aa_1:

    # bloodking "..."
    bloodking "..."

# game/a12/9castle_stories.rpy:316
translate english castle_stories_f71ad121:

    # regis "Они тратят колоссальные деньги на нашу армию, платят даже сверх установленного налога. Они твои самые верные подданные."
    regis "他们在我们的军队上花费了巨额金钱，甚至缴纳了超出规定税额的钱。他们是你最忠诚的臣民。  "

# game/a12/9castle_stories.rpy:317
translate english castle_stories_7c87caa4:

    # bloodking "Ладно. Сколько их там?"
    bloodking "好吧。有多少人？  "

# game/a12/9castle_stories.rpy:318
translate english castle_stories_aa05dc1a:

    # regis "Я отобрал самых важных. Семь или восемь человек. Все ждут в коридоре."
    regis "我挑出了最重要的。七到八个。都在走廊里等着。  "

# game/a12/9castle_stories.rpy:319
translate english castle_stories_c86140a9:

    # bloodking "И чего они хотят."
    bloodking "他们想要什么？  "

# game/a12/9castle_stories.rpy:320
translate english castle_stories_5f108760:

    # regis "Ну как минимум увидеть и услышать тебя, отец. Ты не возвращался в столицу уже сколько... два... три года?"
    regis "嗯，至少是见到你，听到你的声音，父亲。你有多久没回首都了……两年还是三年？  "

# game/a12/9castle_stories.rpy:321
translate english castle_stories_23bc78c2:

    # bloodking "Я что? Какая-то заморская зверушка, чтобы на меня глазеть? Или не уверены, что я жив?"
    bloodking "怎么？我是什么海外来的珍禽异兽吗，要让人观赏？还是他们不确定我是不是还活着？  "

# game/a12/9castle_stories.rpy:322
translate english castle_stories_0d170bb7:

    # regis "Дайталус заведует почти двумя десятками кораблей, может быть полезно для будущей блокады. Сивира организует сбор для нужд имперской армии среди жен знати. Каллахан организовал новый торговый маршрут с Востоком. Гаэль..."
    regis "戴塔路斯掌管着近二十艘船，对未来的封锁可能有帮助。西薇拉在贵族夫人中为帝国军队组织募捐。Callahan开辟了和东方的新贸易路线。盖尔……  "

# game/a12/9castle_stories.rpy:323
translate english castle_stories_8b9eb5b9:

    # bloodking "Ладно. Хватит. Я понял. Я поговорю с ними."
    bloodking "行了。够了。我明白了。我会和他们谈谈。  "

# game/a12/9castle_stories.rpy:324
translate english castle_stories_2b8c9cbf:

    # regis "Разумное решение, отец. Ну... пожалуй на этом моя работа здесь окончена, пойду готовится к походу."
    regis "这是个明智的决定，父亲。那么，看来我在这里的工作结束了，我这就去准备出征了。  "

# game/a12/9castle_stories.rpy:325
translate english castle_stories_9f549049:

    # bloodking "Не нужно."
    bloodking "不必了。  "

# game/a12/9castle_stories.rpy:326
translate english castle_stories_bb51cb52:

    # regis "Мой Император?"
    regis "我的皇帝？  "

# game/a12/9castle_stories.rpy:327
translate english castle_stories_4f746680:

    # bloodking "Похоже от тебя действительно есть польза здесь. Мы с твоим братом организуем новый поход. А ты будешь продолжать следить здесь за порядком."
    bloodking "看来你在这里确实有用。我和你哥哥去组织新的战役。你继续留在这里维持秩序。  "

# game/a12/9castle_stories.rpy:328
translate english castle_stories_29d9d179:

    # regis "Спасибо, отец."
    regis "谢谢您，父亲。  "

# game/a12/9castle_stories.rpy:329
translate english castle_stories_90d6d31e:

    # bloodking "И обрюхать наконец свою жену. Империи нужно больше наследников."
    bloodking "还有，赶紧让你妻子怀上孩子。帝国需要更多的继承人。  "

# game/a12/9castle_stories.rpy:330
translate english castle_stories_23cad718:

    # regis "Но Рагвелион..."
    regis "但是，Ragvelion他……  "

# game/a12/9castle_stories.rpy:331
translate english castle_stories_b9bf5d7b:

    # bloodking "Он все еще наследник. Но если мы не вернемся из похода... хорошо бы иметь больше Стархэдов в запасе, верно?"
    bloodking "他仍然是继承人。但如果我们没能从战场回来……多有几个Starhead家族的血脉备用总是好的，对吧？  "

# game/a12/9castle_stories.rpy:332
translate english castle_stories_0b1a8ec3:

    # regis "Конечно."
    regis "那当然。  "

# game/a12/9castle_stories.rpy:333
translate english castle_stories_e5d97a6a:

    # bloodking "Все. Иди."
    bloodking "好了。去吧。  "

# game/a12/9castle_stories.rpy:335
translate english castle_stories_e919371a:

    # regis "Удачи в походе, брат."
    regis "祝你出征顺利，兄弟。  "

# game/a12/9castle_stories.rpy:336
translate english castle_stories_dda178e6:

    # ragval "Спасибо."
    ragval "谢谢。  "

# game/a12/9castle_stories.rpy:337
translate english castle_stories_b5b6d1ee:

    # regis "Надеюсь мы еще увидимся."
    regis "希望我们还能再见面。  "

# game/a12/9castle_stories.rpy:338
translate english castle_stories_b4c15b23:

    # ragval "И я."
    ragval "我也是。  "

# game/a12/9castle_stories.rpy:339
translate english castle_stories_57d80c49:

    # regis "Поговори с ним о дипломате с Севера."
    regis "和他谈谈关于接见北方外交官的事。  "

# game/a12/9castle_stories.rpy:340
translate english castle_stories_8ecb6cdb:

    # ragval "Ты же знаешь..."
    ragval "你明知道……  "

# game/a12/9castle_stories.rpy:341
translate english castle_stories_8034013d:

    # regis "Даже если мы выбрали пусть противостояния. Он все равно может быть полезен. Не нужно губить больше людей, чем требуется."
    regis "即使我们选择了对抗的道路，外交官也可能有用处。没必要牺牲比所需更多的人。  "

# game/a12/9castle_stories.rpy:342
translate english castle_stories_33de8412:

    # ragval "...хорошо."
    ragval "……好吧。  "

# game/a12/9castle_stories.rpy:343
translate english castle_stories_ed624849:

    # regis "Сегодня он будто... в хорошем настроении."
    regis "他今天看起来……心情不错。  "

# game/a12/9castle_stories.rpy:344
translate english castle_stories_f1a477f7:

    # ragval "Тогда стоило попросить об этом самому."
    ragval "那你就该自己向他提这件事。  "

# game/a12/9castle_stories.rpy:345
translate english castle_stories_5452b98f:

    # regis "Прости, не хотел разрушить его милость, он позволил мне остаться."
    regis "对不起，我不想破坏他的恩赐，他毕竟允许我留下了。  "

# game/a12/9castle_stories.rpy:346
translate english castle_stories_e353dbcf:

    # ragval "Я слышал."
    ragval "我听说了。  "

# game/a12/9castle_stories.rpy:348
translate english castle_stories_aef8c715:

    # ragval "Отец."
    ragval "父亲。  "

# game/a12/9castle_stories.rpy:349
translate english castle_stories_de93af59:

    # bloodking "План выполняется?"
    bloodking "计划在推进吗？  "

# game/a12/9castle_stories.rpy:350
translate english castle_stories_ca2dab55:

    # ragval "Да. Леонард занят блокадой. Я уже подготовил авангард, думаю мы займем города до самой хладной реки без боя."
    ragval "是的。Leonard正忙于封锁。我已经准备好了先锋部队，我估计我们能不战而夺取冷河以南的所有城镇。  "

# game/a12/9castle_stories.rpy:351
translate english castle_stories_d65af9cb:

    # bloodking "Хорошо. Что с Западом?"
    bloodking "很好。西方的情况怎么样？  "

# game/a12/9castle_stories.rpy:352
translate english castle_stories_6098bfd6:

    # ragval "Мы координируем действия. Когда мы атакуем - они введут войска со стороны Черной Косы."
    ragval "我们在协同行动。当我们发动进攻时，他们会从黑镰地区派兵进入。  "

# game/a12/9castle_stories.rpy:353
translate english castle_stories_9ff0934d:

    # bloodking "Что с Югом?"
    bloodking "南方呢？  "

# game/a12/9castle_stories.rpy:354
translate english castle_stories_81be53b8:

    # ragval "Там... неспокойно. Я бы не снимал оттуда гарнизоны."
    ragval "那边……不太安静。我可不建议从那里抽调守军。  "

# game/a12/9castle_stories.rpy:355
translate english castle_stories_d34e1c55:

    # bloodking "Затаились. Почуяли кровь и ждут, крысы."
    bloodking "他们潜伏起来了。嗅到了血腥味，正等着呢，像一群老鼠。  "

# game/a12/9castle_stories.rpy:356
translate english castle_stories_d40cdafc:

    # ragval "Ну... подати они высылают так что формально у нас нет поводов сомневаться в их лояльности."
    ragval "嗯……他们还在上缴贡税，形式上我们没有理由怀疑他们的忠诚。  "

# game/a12/9castle_stories.rpy:357
translate english castle_stories_1ff49614:

    # bloodking "Формально нет. Но если они сами не давят свои восстания, значит они их и организуют."
    bloodking "形式上没有。但如果他们自己不镇压自己的叛乱，那就说明这些叛乱就是他们自己组织的。  "

# game/a12/9castle_stories.rpy:358
translate english castle_stories_3e18c2e0:

    # ragval "Это восстание рабов."
    ragval "那可是奴隶起义。  "

# game/a12/9castle_stories.rpy:359
translate english castle_stories_e6969068:

    # bloodking "Умоляю тебя, ты не настолько наивен, правда? Это повод не отправлять нам войска. Если мы победим, они тут же подавят восстания за считанные дни."
    bloodking "拜托，你没这么天真吧，对吗？这只是个不给我们派兵的借口。一旦我们赢了，他们几天之内就能镇压下去。  "

# game/a12/9castle_stories.rpy:360
translate english castle_stories_a8376544_1:

    # ragval "..."
    ragval "..."

# game/a12/9castle_stories.rpy:361
translate english castle_stories_6ea24df2:

    # bloodking "А Долина?"
    bloodking "那山谷呢？  "

# game/a12/9castle_stories.rpy:362
translate english castle_stories_96d2954c:

    # ragval "Эльфы все еще мешают проезду по тракту. Но западные лорды атакуют со своей стороны, им необязательно пересекать Долину."
    ragval "精灵们还在阻碍商道的通行。但西方领主们从他们那一侧进攻，不必穿过山谷。  "

# game/a12/9castle_stories.rpy:363
translate english castle_stories_48533a73:

    # bloodking "Ублюдки, стоит снова ввести награду за их уши, а Долину сжечь вместе с их лесами и болотами."
    bloodking "这帮混蛋，应该重新悬赏他们的耳朵，连同他们的森林和沼泽，一起把山谷烧掉。  "

# game/a12/9castle_stories.rpy:364
translate english castle_stories_a8376544_2:

    # ragval "..."
    ragval "..."

# game/a12/9castle_stories.rpy:365
translate english castle_stories_79f22f6c:

    # bloodking "Что молчишь? Трахать эльфиек тебе нравится больше, чем их убивать?"
    bloodking "你怎么不说话？比起杀精灵，你更喜欢干精灵吗？  "

# game/a12/9castle_stories.rpy:367
translate english castle_stories_ab533a94:

    # ragval "Я не..."
    ragval "我没有……  "

# game/a12/9castle_stories.rpy:368
translate english castle_stories_d6a96399:

    # bloodking "Не делай из меня идиота, Рагвелион. Я знаю, кто грел тебе постель в холодные ночи походов."
    bloodking "别把我当傻子，Ragvelion。我知道在战场上那些寒冷的夜晚，是谁给你暖床。  "

# game/a12/9castle_stories.rpy:369
translate english castle_stories_a8376544_3:

    # ragval "..."
    ragval "..."

# game/a12/9castle_stories.rpy:370
translate english castle_stories_34379fe3:

    # bloodking "Что? Они вскружили тебе голову? Забыл кто ты есть?"
    bloodking "怎么？她们把你迷得晕头转向？忘了你是谁了吗？  "

# game/a12/9castle_stories.rpy:371
translate english castle_stories_8f35ade9:

    # ragval "Я ведь не женился на них, просто..."
    ragval "我又没娶她们，只是……  "

# game/a12/9castle_stories.rpy:372
translate english castle_stories_70e8aeb6:

    # bloodking "Еще бы ты на них женился. Ты порочил наш род связью с нашими древнейшими врагами."
    bloodking "你还敢娶她们？你已和我们最古老的敌人私通，玷污了我们家族的血脉。  "

# game/a12/9castle_stories.rpy:373
translate english castle_stories_64a4f483:

    # ragval "Это в прошлом, отец."
    ragval "那都是过去的事了，父亲。  "

# game/a12/9castle_stories.rpy:374
translate english castle_stories_17963a58:

    # bloodking "Правда? А та шлюха, что оставалась с тобой чаще остальных? Ту, которую ты потом всюду за тобой таскал, пока ее живот не округлился. Она тоже в прошлом? А твои бастарды?"
    bloodking "是吗？那那个待在你身边最久的婊子呢？那个后来你一直带在身边，直到她肚子大起来的。这也是过去吗？你的那些私生子呢？  "

# game/a12/9castle_stories.rpy:375
translate english castle_stories_a8376544_4:

    # ragval "..."
    ragval "..."

# game/a12/9castle_stories.rpy:376
translate english castle_stories_18ffe621:

    # bloodking "Ты думал я этого не вижу?"
    bloodking "你以为我看不到这些吗？  "

# game/a12/9castle_stories.rpy:377
translate english castle_stories_a17a3ba1:

    # ragval "Я бился с тобой у Синих Гор, проливал свою кровь, кровь своих друзей."
    ragval "我在蓝山与你并肩作战，流淌着我自己的血，流淌着我朋友的血。  "

# game/a12/9castle_stories.rpy:378
translate english castle_stories_5bb4422e:

    # bloodking "И поэтому заслужил засадить эльфийке? Заслужил порочить имя Стархэдов связью с этой мерзостью?"
    bloodking "这就给了你权利去上精灵吗？就给了你权利以这种污秽的联结玷污Starhead的姓氏？  "

# game/a12/9castle_stories.rpy:379
translate english castle_stories_a8376544_5:

    # ragval "..."
    ragval "..."

# game/a12/9castle_stories.rpy:380
translate english castle_stories_96b3920a:

    # bloodking "Ты служишь своим желаниям или Империи?"
    bloodking "你是在为你的欲望服务，还是为帝国服务？  "

# game/a12/9castle_stories.rpy:381
translate english castle_stories_ba4dc140:

    # ragval "Империи, отец."
    ragval "为帝国，父亲。  "

# game/a12/9castle_stories.rpy:382
translate english castle_stories_dce202aa_2:

    # bloodking "..."
    bloodking "..."

# game/a12/9castle_stories.rpy:383
translate english castle_stories_509d65f7:

    # ragval "Прости. Ты прав. Я подвел и тебя и..."
    ragval "对不起。你是对的。我辜负了你，也辜负了……  "

# game/a12/9castle_stories.rpy:384
translate english castle_stories_dbdc208e:

    # bloodking "Я тут не при чем, сын. Близится конец времен. Конец времени людей. И мы - единственные, кто может этому помешать."
    bloodking "这不关我的事，儿子。末日将近。人类时代的终结。而我们是唯一能够阻止它的人。  "

# game/a12/9castle_stories.rpy:385
translate english castle_stories_da960afa:

    # bloodking "У нас нет права на слабость. Понимаешь? Даже на самую маленькую."
    bloodking "我们没有权利软弱，明白吗？哪怕是极细微的软弱也不行。  "

# game/a12/9castle_stories.rpy:386
translate english castle_stories_60869e36:

    # bloodking "Я был слишком увлечен заботой об объединении людей и забыл, что должен воспитывать тех, кто унаследует Империю. Кто будет вести людей в главный бой этого мира."
    bloodking "我太专注于统一人类的事业，却忘了教导即将继承帝国的人。忘了教导那个将带领人类走向这世界最终之战的人。  "

# game/a12/9castle_stories.rpy:387
translate english castle_stories_bd578581:

    # me "Так он был недоволен тобой?"
    me "这么说，他对你很不满？  "

# game/a12/9castle_stories.rpy:388
translate english castle_stories_02d98837:

    # king "Можно и так сказать. Час спустя я узнал, что был последним, кто видел его живым. Его убили собственным мечом."
    king "可以这么说。一个小时后，我才得知我是最后一个看见他活着的人。他是被自己的剑杀死的。  "

# game/a12/9castle_stories.rpy:389
translate english castle_stories_44b3a19f:

    # king "{i}Меч. Сюда.{/i}"
    king "{i}剑。过来。{/i}  "

# game/a12/9castle_stories.rpy:391
translate english castle_stories_7ef16b4b:

    # king "Вот этим. Tenmir ostan. Фамильный меч. Выкован еще на заре времен."
    king "就用这个。Tenmir ostan。我们家族世代相传的剑。早在远古之初便已铸成。  "

# game/a12/9castle_stories.rpy:392
translate english castle_stories_3820771a:

    # me "..."
    me "..."

# game/a12/9castle_stories.rpy:393
translate english castle_stories_6628caaf:

    # king "Великое оружие неподвластное времени."
    king "一件不受时间侵蚀的伟大武器。  "

# game/a12/9castle_stories.rpy:394
translate english castle_stories_123dc106:

    # me "Он сохранился?"
    me "它被保留下来了？  "

# game/a12/9castle_stories.rpy:395
translate english castle_stories_3318643e:

    # king "Было бы кощунством, выбросить его, переплавить или продать после того что произошло. К тому же Красный Император не первый Стархэд, которого убили этим мечом."
    king "在发生了那种事之后，丢弃它，熔掉它，或者卖掉它，都会是亵渎。况且，红色皇帝并非第一个被这柄剑杀死的Starhead。  "

# game/a12/9castle_stories.rpy:396
translate english castle_stories_5a465c2f:

    # me "Эльфийский сплав?"
    me "精灵合金？  "

# game/a12/9castle_stories.rpy:397
translate english castle_stories_38a865de:

    # king "Да. Это еще из тех времен, когда мы захватили первые печи и кузнецов. Когда узнали секрет железа и стали его плавить."
    king "是的。那还是我们刚夺取了第一批熔炉和工匠的时代。我们那时了解了钢铁的秘密，学会了熔炼它。  "

# game/a12/9castle_stories.rpy:398
translate english castle_stories_4665b23c:

    # me "Tenmir."
    me "Tenmir."

# game/a12/9castle_stories.rpy:399
translate english castle_stories_5f21bf4c:

    # king "Да. С тех пор эльфы так и зовут нас."
    king "是啊。从那时起，精灵便这么称呼我们。  "

# game/a12/9castle_stories.rpy:400
translate english castle_stories_ec04d37b:

    # me "Можно?"
    me "我能看看吗？  "

# game/a12/9castle_stories.rpy:401
translate english castle_stories_4d330c43:

    # king "Конечно. Возьми."
    king "当然。拿去吧。  "

# game/a12/9castle_stories.rpy:403
translate english castle_stories_e8568c02:

    # me "Так... ты был последний, кто его видел?"
    me "所以……你是最后一个见到他的人？  "

# game/a12/9castle_stories.rpy:404
translate english castle_stories_71b10e0b:

    # king "Помимо убийцы очевидно."
    king "显然，除了凶手之外。  "

# game/a12/9castle_stories.rpy:405
translate english castle_stories_0b8af9d3:

    # me "Твой последний разговор с отцом был о том, как он тобой недоволен?"
    me "你和你父亲的最后一次谈话，是关于他对你的不满吗？  "

# game/a12/9castle_stories.rpy:406
translate english castle_stories_e78db481:

    # king "Нет."
    king "不是。  "

# game/a12/9castle_stories.rpy:407
translate english castle_stories_aaa0e22b:

    # me "Ты сказал он..."
    me "你说了他……  "

# game/a12/9castle_stories.rpy:408
translate english castle_stories_6bd6486c:

    # king "Наш разговор закончился по-другому. Он простил меня."
    king "我们的谈话结束时不一样。他原谅我了。  "

# game/a12/9castle_stories.rpy:409
translate english castle_stories_461d233a:

    # me "Простил?"
    me "原谅了？  "

# game/a12/9castle_stories.rpy:410
translate english castle_stories_d81054be:

    # king "Сказал, что сейчас не время для слабости."
    king "他说现在不是软弱的时候。  "

# game/a12/9castle_stories.rpy:411
translate english castle_stories_e124aab8:

    # me "Да, ты говорил, он упомянул конец времен? Что это значит?"
    me "是啊，你说过，他提到了末日将近？那是什么意思？  "

# game/a12/9castle_stories.rpy:412
translate english castle_stories_c6883c21:

    # king "Это то, на чем он закончил. На пророчестве."
    king "他是以此结束谈话的。那则预言。  "

# game/a12/9castle_stories.rpy:413
translate english castle_stories_42e12737:

    # me "Пророчество. Ну конечно. Какое из них?"
    me "预言。果然。是哪一个？  "

# game/a12/9castle_stories.rpy:414
translate english castle_stories_70fe9bdb:

    # king "Об этом пророчестве никто не знает. Кроме меня. Он был последним его носителем и успел передать его мне прямо перед самой смертью..."
    king "没人知道这个预言。除了我。他是这预言的最后一位持有者，并在临死前成功将它传给了我……  "

# game/a12/9castle_stories.rpy:415
translate english castle_stories_56b3e1f4:

    # me "Удивительно."
    me "真是惊人。  "

# game/a12/9castle_stories.rpy:416
translate english castle_stories_11186b41:

    # king "Порой судьба лучший драматург. Впрочем, если все предрешено..."
    king "有时候，命运就是最好的剧作家。不过，如果一切都早已注定……  "

# game/a12/9castle_stories.rpy:417
translate english castle_stories_2ea6c6d5:

    # me "Так... что за пророчество?"
    me "那……是什么预言？  "

# game/a12/9castle_stories.rpy:418
translate english castle_stories_cc7ce3b2:

    # king "То, что передается в нашем роду от отца к сыну. От человека в короне к тому, кто ее унаследует."
    king "那是我们家族世代父子相传的预言。从佩戴皇冠之人传至继承皇冠之人。  "

# game/a12/9castle_stories.rpy:420
translate english castle_stories_1a978df8:

    # king "Я расскажу тебе."
    king "我会告诉你。  "

# game/a12/9castle_stories.rpy:421
translate english castle_stories_cd83a5c7:

    # king "Как мой отец рассказал мне."
    king "就像我的父亲告诉我那样。  "

# game/a12/9castle_stories.rpy:423
translate english castle_stories_e6bd54b6:

    # king "Как каждый Золотой Император рассказывал своему сыну."
    king "就像每一位黄金皇帝告诉他儿子那样。  "

# game/a12/9castle_stories.rpy:424
translate english castle_stories_92ed98b5:

    # king "Вручал как тяжкий груз вместе с богатством и властью."
    king "连同财富与权柄一起，作为沉重的负担交托。  "

# game/a12/9castle_stories.rpy:426
translate english castle_stories_145539d3:

    # king "Как каждый из королей и королев смутного времени передавал своему наследнику."
    king "正如乱世中的每一位国王与女王传给他们的继承人。  "

# game/a12/9castle_stories.rpy:427
translate english castle_stories_7c7ecaf6:

    # king "Неся слово через кровь и дым битв."
    king "带着话语穿过血与硝烟之战。  "

# game/a12/9castle_stories.rpy:429
translate english castle_stories_f69c9fef:

    # king "Как первые из нас."
    king "正如我们中的先驱者。  "

# game/a12/9castle_stories.rpy:430
translate english castle_stories_baaa3ca8:

    # king "Как самый первый из Стархэдов."
    king "正如Starhead家族的第一人。  "

# game/a12/9castle_stories.rpy:432
translate english castle_stories_aab58e39:

    # lotric "Кто-нибудь есть?"
    lotric "有人吗？  "

# game/a12/9castle_stories.rpy:433
translate english castle_stories_7a4c9daa:

    # alach_palad_zaharia "Только эти бедолаги."
    alach_palad_zaharia "只有这些可怜虫。  "

# game/a12/9castle_stories.rpy:434
translate english castle_stories_885ac442:

    # lotric "Я имею в виду из вооруженных."
    lotric "我是问，有带武器的吗？  "

# game/a12/9castle_stories.rpy:435
translate english castle_stories_5e7a1967:

    # alach_palad_zaharia "Вроде нет. Наверное это что-то вроде храма."
    alach_palad_zaharia "好像没有。也许这是什么神殿。  "

# game/a12/9castle_stories.rpy:436
translate english castle_stories_325c76ad:

    # lotric "Так и знал, сука, надо было штурмовать город."
    lotric "我他妈就知道，就该攻城。  "

# game/a12/9castle_stories.rpy:437
translate english castle_stories_475611ca:

    # alach_palad_zaharia "Еще будет крови на твоем веку. Разведчики говорят этой земле нет конца и края."
    alach_palad_zaharia "你这辈子有的是机会见血。侦察兵说这片土地无边无际。  "

# game/a12/9castle_stories.rpy:438
translate english castle_stories_62edc194:

    # lotric "И все под этими ублюдками?"
    lotric "都归那些混蛋管？  "

# game/a12/9castle_stories.rpy:439
translate english castle_stories_843472b7:

    # alach_palad_zaharia "На Юге тоже люди. Только темнокожие и коротконогие."
    alach_palad_zaharia "南边也有人类。不过是黑皮肤、矮个子的。  "

# game/a12/9castle_stories.rpy:440
translate english castle_stories_09b1fc1c:

    # lotric "Не терпится сразиться с ними."
    lotric "真想马上和他们打一场。  "

# game/a12/9castle_stories.rpy:441
translate english castle_stories_c1926b6c:

    # alach_palad_zaharia "А мне - с гномами. Мы ведь дойдем до гор?"
    alach_palad_zaharia "我更想和矮人打。我们能打到大山那里吗？  "

# game/a12/9castle_stories.rpy:442
translate english castle_stories_0bca1063:

    # lotric "Обязательно. Как только закончим с этими."
    lotric "一定会的。等我们解决了这些家伙。  "

# game/a12/9castle_stories.rpy:443
translate english castle_stories_6ef88737:

    # alach_palad_zaharia "Проверю что за дверями."
    alach_palad_zaharia "我去看看门后面是什么。  "

# game/a12/9castle_stories.rpy:445
translate english castle_stories_f152fe91:

    # alach_palad_illis "Бедные ублюдки, убиваем их же оружием. Слабаки сраные."
    alach_palad_illis "可怜的蠢货，我们正用他们自己造的武器杀他们。真是群弱鸡废物。  "

# game/a12/9castle_stories.rpy:446
translate english castle_stories_6905d90c:

    # lotric "Как только это место падет - они дадут бой. Я уверен. Я ведь прав, эльф? Вы ведь все не будете просто ползать в своей крови?"
    lotric "等这里一陷落，他们就会反击。我肯定。我说的对吗，精灵？你们总不会一直趴在自己的血泊里打滚吧？  "

# game/a12/9castle_stories.rpy:447
translate english castle_stories_08c66c42:

    # elfm "Sanman Taed'dir. Oh Mirta."
    elfm "Sanman Taed'dir. Oh Mirta."

# game/a12/9castle_stories.rpy:448
translate english castle_stories_857bf570:

    # alach_palad_illis "Что он там бормочет?"
    alach_palad_illis "他在嘟囔什么？  "

# game/a12/9castle_stories.rpy:449
translate english castle_stories_869ab9eb:

    # lotric "Мирта это их богиня."
    lotric "Mirta是他们的女神。  "

# game/a12/9castle_stories.rpy:450
translate english castle_stories_7aab6800:

    # alach_palad_illis "Похоже она их оставила. Скоро присоединится к безымянным богам."
    alach_palad_illis "看来她抛弃他们了。很快就要加入那些无名神祇的行列里去了。  "

# game/a12/9castle_stories.rpy:451
translate english castle_stories_4f5e8384:

    # lotric "Может и не скоро."
    lotric "也许没那么快。  "

# game/a12/9castle_stories.rpy:452
translate english castle_stories_6102945d:

    # alach_palad_illis "Она исчезнет с последним вздохом этих бедолаг."
    alach_palad_illis "她会随着这些可怜虫咽下最后一口气而消失。  "

# game/a12/9castle_stories.rpy:454
translate english castle_stories_49f97b92:

    # lotric "Не-а. Поздно. Да и маловато одного меча на весь ваш храм, ты так не считаешь?"
    lotric "不会的。太迟了。再说，就一把剑对付你们整座神殿，你不觉得不够吗？  "

# game/a12/9castle_stories.rpy:455
translate english castle_stories_9773c88e:

    # elfm "Torael con'ma."
    elfm "Torael con'ma."

# game/a12/9castle_stories.rpy:456
translate english castle_stories_d1cfc079:

    # lotric "Вы молитесь своим богам?"
    lotric "你们向自己的神祈祷吗？  "

# game/a12/9castle_stories.rpy:457
translate english castle_stories_16cd3394:

    # elfm "Yal."
    elfm "Yal."

# game/a12/9castle_stories.rpy:458
translate english castle_stories_f4c89de7:

    # lotric "А мы приносим им жертву. Пополняем их ряды забытыми душами."
    lotric "而我们，则献祭给他们。用被遗忘的灵魂扩充他们的队列。  "

# game/a12/9castle_stories.rpy:459
translate english castle_stories_fdb5fd7c:

    # elfm "..."
    elfm "..."

# game/a12/9castle_stories.rpy:460
translate english castle_stories_465244df:

    # lotric "Как думаешь, кто победит, те, кто молится, или те, кто приносят жертвы?"
    lotric "你觉得，祈祷的和献祭的，谁会赢？  "

# game/a12/9castle_stories.rpy:461
translate english castle_stories_6b64ffce:

    # elfm "Mirta..."
    elfm "Mirta..."

# game/a12/9castle_stories.rpy:463
translate english castle_stories_40ee1b2f:

    # elfm "АГРХ!"
    elfm "啊——！  "

# game/a12/9castle_stories.rpy:464
translate english castle_stories_6507b161:

    # lotric "Неверный ответ."
    lotric "回答错误。  "

# game/a12/9castle_stories.rpy:465
translate english castle_stories_0e4801db:

    # elf_oracle "As'ta piet'tas u Mindon Аl'darie."
    elf_oracle "As'ta piet'tas u Mindon Аl'darie.  "

# game/a12/9castle_stories.rpy:466
translate english castle_stories_583ce189:

    # lotric "Вы слишком много разговариваете и слишком мало сражаетесь."
    lotric "你们话太多，打得太少。  "

# game/a12/9castle_stories.rpy:467
translate english castle_stories_bbb205a4:

    # elf_oracle "А какой в этом смысл?"
    elf_oracle "那有什么意义呢？  "

# game/a12/9castle_stories.rpy:468
translate english castle_stories_a72bf521:

    # lotric "А?"
    lotric "啊？  "

# game/a12/9castle_stories.rpy:469
translate english castle_stories_21a94aec:

    # elf_oracle "Все было предсказанно."
    elf_oracle "一切早已被预言。  "

# game/a12/9castle_stories.rpy:470
translate english castle_stories_2abc9451:

    # lotric "Мне кажется или ты говоришь на нашем языке, эльф?"
    lotric "我感觉，你在说我们的语言，精灵？  "

# game/a12/9castle_stories.rpy:472
translate english castle_stories_6b2228f9:

    # elf_oracle "Я изучил его за пару месяцев, что вы здесь. Ваш язык даже примитивнее, чем ваша культура."
    elf_oracle "你们在这里待了几个月，我学会了。你们的语言比你们的文化更原始。  "

# game/a12/9castle_stories.rpy:473
translate english castle_stories_fedc91b3:

    # lotric "Наверное обидно умирать от таких примитивных варваров, да эльф?"
    lotric "死在这么原始的野蛮人手上，大概很委屈吧，精灵？  "

# game/a12/9castle_stories.rpy:474
translate english castle_stories_aa26f323:

    # elf_oracle "Обидно? Это значит mussaetal на вашем языке."
    elf_oracle "委屈？这个用你们的语言叫... mussaetal。  "

# game/a12/9castle_stories.rpy:475
translate english castle_stories_2091cf68:

    # lotric "Понятия не имею, что ты там только что сказал."
    lotric "完全不知道你刚才说了啥。  "

# game/a12/9castle_stories.rpy:476
translate english castle_stories_c98c9189:

    # elf_oracle "В вашем языке нет слова выражающего досаду от предсказанной судьбы."
    elf_oracle "你们的语言里没有词可以表达那种因注定的命运而感到的懊恼。  "

# game/a12/9castle_stories.rpy:477
translate english castle_stories_e014674a:

    # lotric "Потому что мы вершим ее сами, эльф."
    lotric "因为，精灵，我们是自己创造命运的。  "

# game/a12/9castle_stories.rpy:478
translate english castle_stories_a3df2226:

    # elf_oracle "Правда? Ты так думаешь?"
    elf_oracle "真的？你这么想吗？  "

# game/a12/9castle_stories.rpy:479
translate english castle_stories_7975c819:

    # lotric "Я держу свою судьбу в своих руках. Я выплавил ее в ваших печах и покрываю вашей кровью."
    lotric "我的命运握在我自己手里。我在你们的熔炉里冶炼了它，用你们的血淬火。  "

# game/a12/9castle_stories.rpy:480
translate english castle_stories_7b8cffcd:

    # elf_oracle "Довольствуйся победой сколько угодно. Так делали все до тебя."
    elf_oracle "尽情享受胜利吧。你这之前的所有人都是这样的。  "

# game/a12/9castle_stories.rpy:481
translate english castle_stories_a72bf521_1:

    # lotric "А?"
    lotric "什么？  "

# game/a12/9castle_stories.rpy:482
translate english castle_stories_17a8c2b0:

    # elf_oracle "И после тебя все повторится."
    elf_oracle "在你之后，一切也都会重演。  "

# game/a12/9castle_stories.rpy:483
translate english castle_stories_09cfcb40:

    # lotric "О чем ты пищишь, умирающая крыса?"
    lotric "你这将死的老鼠，在念叨什么？  "

# game/a12/9castle_stories.rpy:484
translate english castle_stories_f838a826:

    # elf_oracle "Мы все просто часть бесконечного цикла."
    elf_oracle "我们都只是无尽循环的一部分。  "

# game/a12/9castle_stories.rpy:485
translate english castle_stories_8d5091fc:

    # lotric "Какого еще цикла? Я захвачу твою землю, эльф. Буду жить в твоих дворцах, буду пить вино, выращенное в твоих садах, буду ковать металл, добытый из твоих гор, буду срать в яму, где будет похоронен весь твой народ."
    lotric "什么循环？我会占领你的土地，精灵。我会住在你的宫殿里，喝你花园里种出的酒，用你山中采出的金属锻造，在你整个民族被埋葬的坑里拉屎。  "

# game/a12/9castle_stories.rpy:487
translate english castle_stories_625c3f28:

    # elf_oracle "Ахахахахаха!"
    elf_oracle "啊哈哈哈哈！  "

# game/a12/9castle_stories.rpy:488
translate english castle_stories_697b26b0:

    # lotric "Да ты видно обезумел перед смертью."
    lotric "你真是临死前疯了。  "

# game/a12/9castle_stories.rpy:489
translate english castle_stories_79b60af3:

    # elf_oracle "Все так думали... все торжествовали. Мы, когда отняли эту землю у Mostara. Mostara, когда отняли эту землю у Mindaga'ar, Mindaga'ar, когда отняли эту землю у Saute'ele."
    elf_oracle "所有人都这么想……所有人都曾这样欢庆胜利。我们，从莫斯塔拉手中夺走这片土地时。莫斯塔拉，从明达加尔手中夺走这片土地时。明达加尔，从索特埃尔手中夺走这片土地时。  "

# game/a12/9castle_stories.rpy:490
translate english castle_stories_4dcc7003:

    # elf_oracle "Никто и никогда не побеждал захватчиков. В лучшем случае умоляли о пощаде или бежали далеко. В любом случае, все что им оставалось - участь угасающего народа."
    elf_oracle "没有人曾真正战胜过入侵者。最好的情况也只是乞求怜悯或逃得远远的。无论如何，等待他们的，都是凋零民族的命运。  "

# game/a12/9castle_stories.rpy:491
translate english castle_stories_e987f4f9:

    # lotric "Что за народы ты перечислил?"
    lotric "你列举的这些都是什么种族？  "

# game/a12/9castle_stories.rpy:492
translate english castle_stories_1504f1a7:

    # elf_oracle "Не имеет значения. Они все канули в лету. Их цивилизация пала. Даже самые стойкие вынуждены жить далеко в горах, растеряв все свое было величие."
    elf_oracle "不重要。他们都已沉入遗忘之河。他们的文明都已陨落。即使是最顽强的，也不得不远居深山，丧失了所有昔日的辉煌。  "

# game/a12/9castle_stories.rpy:493
translate english castle_stories_b1ffb3bb:

    # lotric "Ты о дфорфах?"
    lotric "你是说矮人吗？  "

# game/a12/9castle_stories.rpy:494
translate english castle_stories_04aba031:

    # elf_oracle "Дфорфы... Орки? Какая разница? Когда мой народ прибыл сюда с Запада, десятки тысяч орочих кланов топтали континент. Теперь всех орков вместе взятых не больше десятка тысяч. Когда придет черед твоего народа, их не останется вовсе."
    elf_oracle "矮人……兽人？有什么关系？当我的族人从西方乘船来此时，成千上万的兽人氏族还在大陆上横行。而今所有兽人加起来还不到一万。待到你们种族的时刻来临时，他们便再不会剩下一人了。  "

# game/a12/9castle_stories.rpy:495
translate english castle_stories_80c0e93e:

    # lotric "..."
    lotric "..."

# game/a12/9castle_stories.rpy:496
translate english castle_stories_7b3fb132:

    # elf_oracle "Нам всем уже давно уготован sa'vahn."
    elf_oracle "我们所有人，都早已被安排了 sa'vahn。  "

# game/a12/9castle_stories.rpy:497
translate english castle_stories_7bed92cf:

    # lotric "И чему тогда ты радуешься, идиот?"
    lotric "那你高兴个什么劲，你这傻瓜？  "

# game/a12/9castle_stories.rpy:498
translate english castle_stories_9f223cd3:

    # elf_oracle "Тому что твой народ закончит также, как и мой."
    elf_oracle "高兴的是，你的种族结局会和我的一样。  "

# game/a12/9castle_stories.rpy:499
translate english castle_stories_1da07b54:

    # lotric "Я не верю в ту чушь, что ты наплел."
    lotric "我不信你编的这套鬼话。  "

# game/a12/9castle_stories.rpy:500
translate english castle_stories_56c5ed98:

    # elf_oracle "Не веришь? Я тоже сначала не верил. Но пришлось, когда тысяча парусов показались из-за горизонта."
    elf_oracle "你不信？我起初也不信。但当地平线外出现了千张船帆的时候，我不得不信。  "

# game/a12/9castle_stories.rpy:501
translate english castle_stories_896a6445:

    # lotric "Там, откуда мы прибыли, больше нет деревьев ни на один корабль."
    lotric "在我们来的那片土地上，已经再也找不到一棵树来造船了。  "

# game/a12/9castle_stories.rpy:502
translate english castle_stories_f842ab4f:

    # elf_oracle "Ахахахах. Не сейчас. Но когда твой народ падет, ты уже давно будешь мертв. Деревья успеют отрасти, Tenmir carandar падет и как Elentári melda. Корабли приплывут снова. С Запада или с Востока."
    elf_oracle "啊哈哈哈。不是现在。但当你的种族陨落时，你早已死去多时了。树木会重新长出，Tenmir carandar 会像 Elentári melda 一样陨落。船帆会再次出现。从西方或东方。  "

# game/a12/9castle_stories.rpy:503
translate english castle_stories_e8fe57e3:

    # lotric "А если не приплывут?"
    lotric "那要是不出现呢？  "

# game/a12/9castle_stories.rpy:504
translate english castle_stories_c1b302f3:

    # elf_oracle "Приплывут. Все повторится. Мы изучали храмы на Юге, что старше самого времени, все случается одинаково."
    elf_oracle "会的。一切都会重演。我们研究过南方那些比时间本身还古老的庙宇，一切发生得都一样。  "

# game/a12/9castle_stories.rpy:505
translate english castle_stories_fd15766e:

    # lotric "Как?"
    lotric "怎么说？  "

# game/a12/9castle_stories.rpy:507
translate english castle_stories_f0f303dc:

    # elf_oracle "Гора родит огонь а земля - дрожь, там, откуда вы прибыли уже год стоят столбы из пепла до самого неба."
    elf_oracle "大山分娩出火焰，大地——分娩出震动，在你们来的那片土地上，已经有一年时间，烟柱直达天际了。  "

# game/a12/9castle_stories.rpy:508
translate english castle_stories_80c0e93e_1:

    # lotric "..."
    lotric "..."

# game/a12/9castle_stories.rpy:509
translate english castle_stories_5b31f345:

    # elf_oracle "Сначала зашепчут горы, затем задрожит земля. Но вы не внемлите предупреждению, так же как и мы."
    elf_oracle "先是群山低语，然后大地颤抖。但你们不会听取这警告，正如我们一样。  "

# game/a12/9castle_stories.rpy:510
translate english castle_stories_f065ef46:

    # elf_oracle "А здесь - река, что пустовала столетия, вновь разродится золотом. Мы радовались этому, как и тому что око бури в море стихло. Столетиями оно топило корабли, нарушая торговлю и путешествия."
    elf_oracle "而在这里——那条干涸了数个世纪的河流，将再度涌出黄金。我们为此欢庆，就像是庆祝海上风暴之眼的平息。数个世纪以来，它一直在击沉船只，阻断贸易与旅行。  "

# game/a12/9castle_stories.rpy:511
translate english castle_stories_b1fa4311:

    # elf_oracle "И вот... последняя туча рассеялась, ураган затих и из-за горизонта показались паруса."
    elf_oracle "再然后……最后一朵乌云散去，飓风平息，而从地平线之外，露出了片片船帆。  "

# game/a12/9castle_stories.rpy:512
translate english castle_stories_9d0a8362:

    # elf_oracle "."
    elf_oracle "."

# game/a12/9castle_stories.rpy:513
translate english castle_stories_f02b510b:

    # lotric "Это все уже произошло, умник."
    lotric "这些都已经发生了，聪明鬼。  "

# game/a12/9castle_stories.rpy:514
translate english castle_stories_10c3a1cf:

    # elf_oracle "Конечно. Тебе нужно будущее. Его ты почувствуешь, сам. Вы будете биться с легкостью. Будет казаться, будто сама природа и даже... звезды на вашей стороне."
    elf_oracle "当然。你需要的是未来。你会亲自感受到它的。你们会轻而易举地战斗。一切看起来都会是，仿佛自然本身，甚至……群星都站在你们这边。  "

# game/a12/9castle_stories.rpy:515
translate english castle_stories_01df5144:

    # lotric "То, что мы вас победим, я и так знаю."
    lotric "我们会赢这一点，不用你说我也知道。  "

# game/a12/9castle_stories.rpy:516
translate english castle_stories_641094c6:

    # elf_oracle "Победите. А когда ваш первый король взойдет на трон и наденет на себя корону - песочные часы перевернутся."
    elf_oracle "你们会赢。但当你们的第一位国王登上王座，戴上王冠的那一刻——沙漏就会翻转。  "

# game/a12/9castle_stories.rpy:517
translate english castle_stories_c72a19fa:

    # lotric "И я должен в это поверить?"
    lotric "我该相信这个吗？  "

# game/a12/9castle_stories.rpy:518
translate english castle_stories_c6b1b41d:

    # elf_oracle "Сейчас ты в это не веришь. Но знаки... знаки сами найдут тебя. До самой смерти ты будешь замечать их. А перед последним вздохом поймешь, что я был прав."
    elf_oracle "你现在不信。但预兆……预兆会自己找上你的。直到你死的那一刻，你都会注意到它们。而在最后一息间，你会明白，我说的都是真的。  "

# game/a12/9castle_stories.rpy:519
translate english castle_stories_70dc663f:

    # lotric "...какие знаки?"
    lotric "……什么预兆？  "

# game/a12/9castle_stories.rpy:520
translate english castle_stories_af468ec4:

    # elf_oracle "Луна сегодня особенно большая, заметил? Она наблюдает за становлением нового мира. И за смертью старого. Колесо снова дало оборот."
    elf_oracle "今晚的月亮特别大，注意到了吗？它在注视着新世界的成形，以及旧世界的死亡。巨轮又转动了一次。  "

# game/a12/9castle_stories.rpy:521
translate english castle_stories_1190b653:

    # lotric "Даже если ты то, что ты говоришь правда - я не допущу этого."
    lotric "就算你说的都是真的——我也不会容许它发生。  "

# game/a12/9castle_stories.rpy:522
translate english castle_stories_600cf0f1:

    # elf_oracle "Попробуй. Но к тому моменту, как новые паруса покажутся над Западом или Востоком, или знамена поднимутся над горами... к тому моменту ничего не останется даже от твоих костей."
    elf_oracle "尽管试吧。但等到新的船帆从西方或东方升起时，或等到新的旗帜从大山之巅升起时……那时，就连你的骨头也早已什么都不剩了。  "

# game/a12/9castle_stories.rpy:523
translate english castle_stories_9e922241:

    # lotric "Мы будем готовы."
    lotric "我们会准备好的。  "

# game/a12/9castle_stories.rpy:524
translate english castle_stories_933de795:

    # elf_oracle "Они тоже будут. Новый народ, новая раса уже рождена в пепле, грязи и морской соли. Ты поймешь, что я прав, еще прежде, чем ты умрешь."
    elf_oracle "他们也会准备好的。一个新的民族，一个新的种族，已在灰烬、泥土和海盐中诞生。在你死之前，你就会明白我是对的。  "

# game/a12/9castle_stories.rpy:525
translate english castle_stories_1a2f8b83:

    # elf_oracle "Небеса озарит цвет крови, когда родится последний правитель всех людей."
    elf_oracle "当所有人类的最后一位统治者诞生时，天空将被血的色彩照亮。  "

# game/a12/9castle_stories.rpy:527
translate english castle_stories_e2cce8cb:

    # me "И что же? Эти знаки? Они... появились?"
    me "那么？这些预兆？它们……出现了吗？  "

# game/a12/9castle_stories.rpy:528
translate english castle_stories_fdcaaa64:

    # king "Раз уж ты слышишь эту историю..."
    king "既然你都听到了这个故事……  "

# game/a12/9castle_stories.rpy:529
translate english castle_stories_eee67ca3:

    # me "И какие?"
    me "哪些？  "

# game/a12/9castle_stories.rpy:530
translate english castle_stories_48f6a09e:

    # king "Когда родился мой отец небо озарила красная комета. Поэтому он и взял себе имя Красного Императора."
    king "我父亲诞生时，一颗红色的彗星照亮了天空。因此他自称为红色皇帝。  "

# game/a12/9castle_stories.rpy:531
translate english castle_stories_9153db56:

    # me "Но ведь он не был последним правителем людей."
    me "但他并不是人类的最后一位统治者。  "

# game/a12/9castle_stories.rpy:532
translate english castle_stories_b7d6ea0c:

    # king "Не был. Он думал так. Он думал, что должен объединить всех под своей властью, чтобы дать отпор захватчикам. Но он действительно не был последним из правителей людей. Если конечно мой титул несет тоже значение."
    king "确实不是。他那时以为如此。他以为必须将所有人都统一在自己的权力下，才能抵抗入侵者。但他的确不是人类的最后一位统治者。除非，我拥有的头衔也带着同样的意义。  "

# game/a12/9castle_stories.rpy:533
translate english castle_stories_2b455e89:

    # king "Может имелся в виду последний правитель всех людей. Тогда он именно последним и был."
    king "也许这指的就是“所有人类”的最后一位统治者。这样一来，他还真是最后一个。  "

# game/a12/9castle_stories.rpy:534
translate english castle_stories_3820771a_1:

    # me "..."
    me "..."

# game/a12/9castle_stories.rpy:535
translate english castle_stories_e5d158fc:

    # king "А может это предсказание не о нем. Может небо в цвет крови должно было окрасить что-то другое?"
    king "又或者，这预言说的不是他。也许该被血色染红的，不是天空，而是别的什么东西？  "

# game/a12/9castle_stories.rpy:536
translate english castle_stories_bb04f677:

    # me "Почему ты так в это веришь?"
    me "你为什么如此相信它？  "

# game/a12/9castle_stories.rpy:537
translate english castle_stories_d0915520:

    # king "Потому что все остальное... все остальное сбывается. Торговля с востоком растет. Око бури стихло и на Западе тоже. Особенно отчаянные плывут даже в земли гоблинов."
    king "因为所有其他部分……所有其他部分都在应验。与东方的贸易在增长。风暴之眼在西边也已平息。特别不要命的家伙甚至都航行到了哥布林的地盘去了。  "

# game/a12/9castle_stories.rpy:538
translate english castle_stories_f57df102:

    # me "Оно ведь стихало и раньше."
    me "以前它不也平息过吗。  "

# game/a12/9castle_stories.rpy:539
translate english castle_stories_7906a980:

    # king "Стихало. Но никогда до конца. А теперь море совсем тихое. Будто ждет..."
    king "平息过。但从未彻底。而现在，大海一片寂静。仿佛在等待着什么……  "

# game/a12/9castle_stories.rpy:540
translate english castle_stories_ca0aa5f2:

    # me "И откуда? С Запада? С Востока?"
    me "那会从哪里来？西方？东方？  "

# game/a12/9castle_stories.rpy:541
translate english castle_stories_2285a29e:

    # king "Не знаю. Может вообще из-за гномьего разлома."
    king "不知道。说不定是从矮人的地底裂隙里面。  "

# game/a12/9castle_stories.rpy:542
translate english castle_stories_c73764ca:

    # me "Слишком мало доказательств... в это тяжело поверить."
    me "证据太少了……这很难让人相信。  "

# game/a12/9castle_stories.rpy:543
translate english castle_stories_e7c0302c:

    # king "Я думал также, как и ты. Но я слышал шепот гор, когда люди сошлись в крупнейшей битве друг с другом."
    king "我曾经也像你一样想。但当我听见群山低语时，人类正投身于彼此之间最大的一场战役。  "

# game/a12/9castle_stories.rpy:544
translate english castle_stories_5184dc0a:

    # me "...это...тебе могло показаться."
    me "……这……有可能只是你的错觉。  "

# game/a12/9castle_stories.rpy:545
translate english castle_stories_6de2c2b2:

    # king "Не мне одному. Когда мы ехали обратно у вольных городов нас застигло землетрясение. Тогда я не понимал, почему это обеспокоило отца больше чем проигранное сражение."
    king "不止我一个人。当我们从自由城邦那边回来时，我们遭遇了地震。那时我不明白，为什么那比输了仗还让父亲忧心。  "

# game/a12/9castle_stories.rpy:546
translate english castle_stories_3820771a_2:

    # me "..."
    me "..."

# game/a12/9castle_stories.rpy:547
translate english castle_stories_80bcfd08:

    # king "Но это не все. Река Златоносная. Что не давала золота уже сотни лет... ты ведь слышал, что она недавно вышла из берегов?"
    king "还不止这些。那条已经数百年不曾出产黄金的“金河”……你肯定也听说了吧，它最近又泛滥了？  "

# game/a12/9castle_stories.rpy:548
translate english castle_stories_2e3a24f0:

    # me "Да. Кажется разрушила пару мостов."
    me "是的。好像还冲毁了几座桥。  "

# game/a12/9castle_stories.rpy:549
translate english castle_stories_4868c699:

    # king "Ну... и конечно же сны и видения. Я знаю, что они есть у тебя тоже."
    king "嗯……当然还有那些梦境和异象。我知道，你也同样有。  "

# game/a12/9castle_stories.rpy:551
translate english castle_stories_17632612:

    # me "Если это правда... мне не просто нужно объединить Империю... я обязан сделать это."
    me "如果这都是真的……那我就不只是需要统一帝国……我必须做到。  "

# game/a12/9castle_stories.rpy:552
translate english castle_stories_a800edc1:

    # king "Верно."
    king "没错。  "

# game/a12/9castle_stories.rpy:553
translate english castle_stories_4d0a3e87:

    # me "И как же понять... когда наступит тот самый момент?"
    me "那要怎样才能知道……那一刻什么时候会来临？  "

# game/a12/9castle_stories.rpy:554
translate english castle_stories_5e826583:

    # king "Не знаю. Мой отец думал, что при его жизни. Я думал может эту буду я или ты. Может это будет твой сын."
    king "不知道。我父亲以为会在他这一代。我以为或许是我这一代，或者是你。也可能是你的儿子。  "

# game/a12/9castle_stories.rpy:555
translate english castle_stories_0251cb17:

    # me "Но... час близок?"
    me "但……时候已经临近了吗？  "

# game/a12/9castle_stories.rpy:556
translate english castle_stories_6d433cff:

    # king "Близок. Знамения набирают оборот."
    king "临近了。启示的征兆正在加速。  "

# game/a12/9castle_stories.rpy:557
translate english castle_stories_e4a1d50a:

    # me "Ты следил за небом, когда родился мой сын?"
    me "我儿子出生时，你留意天空了吗？  "

# game/a12/9castle_stories.rpy:558
translate english castle_stories_e0c6286c:

    # king "Следил. Оно было чистым."
    king "我留意了。天空是晴朗的。  "

# game/a12/9castle_stories.rpy:559
translate english castle_stories_3cfde4f6:

    # me "Значит последний из правителей еще не родился."
    me "那就是说，最后一位统治者还未诞生。  "

# game/a12/9castle_stories.rpy:560
translate english castle_stories_fa304c92:

    # king "Может быть. Может быть эта часть пророчества вообще говорит о чем-то другом. Или переврана и ошибочно передана через столетия."
    king "或许吧。也许预言的那一部分说的是别的意思。或者是历经数百年流传后被曲解和传错了。  "

# game/a12/9castle_stories.rpy:563
translate english castle_stories_6c538caa:

    # me "Этого вообще может не произойти."
    me "也许这根本就不会发生。  "

# game/a12/9castle_stories.rpy:564
translate english castle_stories_de8c62fa:

    # king "Может. Но мы должны быть готовы."
    king "有可能。但我们必须做好准备。  "

# game/a12/9castle_stories.rpy:565
translate english castle_stories_2f6117ff:

    # me "Должны... Об этом кто-нибудь еще знает?"
    me "必须……还有别人知道这个吗？  "

# game/a12/9castle_stories.rpy:566
translate english castle_stories_927d239b:

    # king "Разве что некоторые из эльфов."
    king "也许有。一些精灵可能知道。  "

# game/a12/9castle_stories.rpy:567
translate english castle_stories_c7af44a3:

    # me "Леди [alaina]?"
    me "[alaina]女士？  "

# game/a12/9castle_stories.rpy:568
translate english castle_stories_216373a9:

    # king "Может быть."
    king "可能。  "

# game/a12/9castle_stories.rpy:569
translate english castle_stories_21c667b1:

    # me "Я могу поговорить с ней об этом?"
    me "我能和她谈谈这个吗？  "

# game/a12/9castle_stories.rpy:570
translate english castle_stories_4f2fbbc1:

    # king "Конечно."
    king "当然。  "

# game/a12/9castle_stories.rpy:571
translate english castle_stories_3066598f:

    # me "Спасибо."
    me "谢谢。  "

# game/a12/9castle_stories.rpy:572
translate english castle_stories_b8a47c44:

    # king "Ты можешь идти. Только навести меня перед отправкой на Север."
    king "你可以走了。但在你出发去北方之前，再来看我一次。  "

# game/a12/9castle_stories.rpy:573
translate english castle_stories_b3176dea:

    # me "Конечно, отец."
    me "没问题，父亲。  "

# game/a12/9castle_stories.rpy:574
translate english castle_stories_c2519b23:

    # king "М, [mename], помни о пророчестве всегда, но не дай этим мыслям занять всю твою жизнь. Я уже однажды обжегся на этом и сделал только хуже."
    king "还有，[mename]，永远要记得预言，但别让这些思绪占据你全部的人生。我曾因此吃过亏，反而让事情变得更糟。  "

# game/a12/9castle_stories.rpy:575
translate english castle_stories_17a78fbc:

    # king "Тысячи часов за книгами и перед оракулами. Настоящими и фальшивыми. Это было бесполезно. Настоящий правитель не смотрит в будущее, в надежде узнать, что его ждет, он готовится ко всему сразу."
    king "花了几千个小时研读典籍，咨询真假神谕。那都是徒劳的。一个真正的统治者不会盯着未来，期待得知有什么在等着他，而是同时为一切可能性做好准备。  "

# game/a12/9castle_stories.rpy:579
translate english castle_stories_9fa0c0b1:

    # king "Главное не спеши, [mename]."
    king "关键是不要急，[mename]。  "

# game/a12/9castle_stories.rpy:580
translate english castle_stories_a86f061c:

    # me "Как я могу не спешить, когда все знаки сулят нашему народу скорую гибель?"
    me "当所有迹象都预示着我们的民族即将灭亡，我怎么能不急？  "

# game/a12/9castle_stories.rpy:581
translate english castle_stories_201cd5a7:

    # king "Этого вообще может не произойти. Но мы должны быть готовы. Лучше не спешить и делать все размеренно."
    king "也许这根本就不会发生。但我们必须做好准备。最好是从容行事，步步为营。  "

# game/a12/9castle_stories.rpy:582
translate english castle_stories_3820771a_3:

    # me "..."
    me "..."

# game/a12/9castle_stories.rpy:583
translate english castle_stories_f4da2ed1:

    # king "Ты же не хочешь оставить своего сына над еще большим числом осколков Империи людей?"
    king "你总不想留给你儿子一个更加破碎的人类帝国吧？  "

# game/a12/9castle_stories.rpy:584
translate english castle_stories_1457a622:

    # me "Не хочу."
    me "不想。  "

# game/a12/9castle_stories.rpy:585
translate english castle_stories_887c1345:

    # king "...вот и хорошо."
    king "……那就好。  "

# game/a12/9castle_stories.rpy:586
translate english castle_stories_b8a47c44_1:

    # king "Ты можешь идти. Только навести меня перед отправкой на Север."
    king "你可以走了。但在你出发去北方之前，再来看我一次。  "

# game/a12/9castle_stories.rpy:587
translate english castle_stories_b3176dea_1:

    # me "Конечно, отец."
    me "没问题，父亲。  "

# game/a12/9castle_stories.rpy:588
translate english castle_stories_c2519b23_1:

    # king "М, [mename], помни о пророчестве всегда, но не дай этим мыслям занять всю твою жизнь. Я уже однажды обжегся на этом и сделал только хуже."
    king "还有，[mename]，永远要记得预言，但别让这些思绪占据你全部的人生。我曾因此吃过亏，反而让事情变得更糟。  "

# game/a12/9castle_stories.rpy:589
translate english castle_stories_17a78fbc_1:

    # king "Тысячи часов за книгами и перед оракулами. Настоящими и фальшивыми. Это было бесполезно. Настоящий правитель не смотрит в будущее, в надежде узнать, что его ждет, он готовится ко всему сразу."
    king "花了几千个小时研读典籍，咨询真假神谕。那都是徒劳的。一个真正的统治者不会盯着未来，期待得知有什么在等着他，而是同时为一切可能性做好准备。  "

# game/a12/9castle_stories.rpy:592
translate english castle_stories2_7dac0600:

    # "Пару часов спустя."
    "几个小时以后。"

# game/a12/9castle_stories.rpy:593
translate english castle_stories2_e07edeb8:

    # me "{i}Вот она. Ждет.{/i}"
    me "{i}她就在那里。等着呢。{/i}  "

# game/a12/9castle_stories.rpy:594
translate english castle_stories2_3cc6a869:

    # me "{i}Как бы ей сказать, что мои мысли больше не заняты Долиной?{/i}"
    me "{i}该怎么告诉她，我的思绪已经不再被山谷占据了呢？{/i}  "

# game/a12/9castle_stories.rpy:595
translate english castle_stories2_ae3512bf:

    # me "{i}И эта луна...{/i}"
    me "{i}还有这轮月亮……{/i}  "

# game/a12/9castle_stories.rpy:596
translate english castle_stories2_fe40bfab:

    # me "{i}Она действительно словно наблюдает.{/i}"
    me "{i}它确实像是在观察。{/i}  "

# game/a12/9castle_stories.rpy:597
translate english castle_stories2_0a900cf4:

    # me "{i}Теперь видения... раскрываются для меня с другой стороны.{/i}"
    me "{i}现在，那些异象……在我眼中从另一个角度展开了。{/i}  "

# game/a12/9castle_stories.rpy:598
translate english castle_stories2_98ebdc1b:

    # me "{i}Но что за силы стоят за ними?{/i}"
    me "{i}但这背后又是什么力量在驱动呢？{/i}  "

# game/a12/9castle_stories.rpy:600
translate english castle_stories2_8dcc3e9e:

    # me "Леди [alaina]."
    me "[alaina]女士。  "

# game/a12/9castle_stories.rpy:601
translate english castle_stories2_23cee1c2:

    # ala "[mename]? Выглядишь обеспокоенным."
    ala "[mename]？你看起来忧心忡忡的。  "

# game/a12/9castle_stories.rpy:602
translate english castle_stories2_0288549d:

    # me "Потому что так и есть."
    me "因为事实的确如此。  "

# game/a12/9castle_stories.rpy:603
translate english castle_stories2_40453a95:

    # ala "Что-то случилось?"
    ala "发生什么事了？  "

# game/a12/9castle_stories.rpy:604
translate english castle_stories2_3820771a:

    # me "..."
    me "..."

# game/a12/9castle_stories.rpy:605
translate english castle_stories2_c959938c:

    # ala "[mename]?"
    ala "[mename]?"

# game/a12/9castle_stories.rpy:606
translate english castle_stories2_6f44d9f2:

    # me "Даже не знаю, как об этом сказать."
    me "我都不知道该怎么开口。  "

# game/a12/9castle_stories.rpy:607
translate english castle_stories2_9a54292f:

    # ala "Ну как-нибудь скажи."
    ala "总会有办法说出来的。  "

# game/a12/9castle_stories.rpy:608
translate english castle_stories2_84180341:

    # me "Я недавно узнал кое-что. О том как погибли эльфы."
    me "我最近了解到一些事。关于精灵是如何灭亡的。  "

# game/a12/9castle_stories.rpy:609
translate english castle_stories2_343d73b2:

    # ala "Я думала ты и раньше это знал."
    ala "我以为你早就知道了。  "

# game/a12/9castle_stories.rpy:610
translate english castle_stories2_43c17ba9:

    # me "Да. Но... я узнал про предсказания. Про циклы."
    me "是。但我了解到的是关于预言。关于那些循环。  "

# game/a12/9castle_stories.rpy:611
translate english castle_stories2_0b0c8a42:

    # ala "Ааа.. Наш народ любил... драматизировать свое падение."
    ala "啊……我们的族人曾喜欢……把自己的衰落加以戏剧化。  "

# game/a12/9castle_stories.rpy:612
translate english castle_stories2_3e9b0f7d:

    # me "Так это не правда?"
    me "所以这不是真的？  "

# game/a12/9castle_stories.rpy:614
translate english castle_stories2_436b7d8f:

    # ala "Этого я не говорила."
    ala "我可没这么说。  "

# game/a12/9castle_stories.rpy:615
translate english castle_stories2_3820771a_1:

    # me "..."
    me "..."

# game/a12/9castle_stories.rpy:616
translate english castle_stories2_c85556c6:

    # ala "Видишь ли... когда-то эльфы тоже завоевали это место."
    ala "你看……曾几何时，精灵也是征服了这片土地。  "

# game/a12/9castle_stories.rpy:617
translate english castle_stories2_dba09e85:

    # me "У орков."
    me "从兽人手中。  "

# game/a12/9castle_stories.rpy:618
translate english castle_stories2_069fab4a:

    # ala "Да. Мы приплыли на тысячах кораблей с Востока."
    ala "是的。我们乘着上千艘船，从东方驶来。  "

# game/a12/9castle_stories.rpy:619
translate english castle_stories2_4d9f9625:

    # me "Прямо как... "
    me "就像是……  "

# game/a12/9castle_stories.rpy:620
translate english castle_stories2_981fb737:

    # ala "Как Tenmir carandar. Как люди приплыли с Запада."
    ala "就像是Tenmir carandar。就像人类从西方乘船而来。  "

# game/a12/9castle_stories.rpy:621
translate english castle_stories2_b156c530:

    # me "Так это правда."
    me "所以这是真的。  "

# game/a12/9castle_stories.rpy:622
translate english castle_stories2_23b4e8a0:

    # ala "Что правда? Что эта земля лакомый кусочек? Или что расы прибывают сюда согласно каким-то циклам?"
    ala "什么是真的？这片土地是块肥肉？还是说，种族是根据某种循环迁徙至此的？  "

# game/a12/9castle_stories.rpy:623
translate english castle_stories2_3820771a_2:

    # me "..."
    me "..."

# game/a12/9castle_stories.rpy:624
translate english castle_stories2_95e73b9f:

    # ala "Вся жизнь строится на циклах. Бабочка выходит из кокона, собирает пыльцу и откладывает яица, из них появляется гусеница, что пожирает растительность и сворачивается в кокон."
    ala "所有的生命都建立在循环之上。蝴蝶破茧而出，采集花粉，产下卵，卵里生出毛虫，毛虫啃食草木，然后结茧。  "

# game/a12/9castle_stories.rpy:625
translate english castle_stories2_905581f8:

    # ala "Так же и мы. Рождаемся, живем и умираем. Это можно увеличивать в размерах и до целых народов и рас."
    ala "我们也是一样。诞生、活着、逝去。这可以被放大到整个民族乃至种族。  "

# game/a12/9castle_stories.rpy:626
translate english castle_stories2_c64b1faa:

    # me "Но вторжение из-за моря это не слишком обычная для природы часть цикла."
    me "但从海外入侵，对于自然而言，可不是循环中寻常的一部分。  "

# game/a12/9castle_stories.rpy:627
translate english castle_stories2_a19218f6:

    # ala "Давай пройдемся."
    ala "我们走走吧。  "

# game/a12/9castle_stories.rpy:629
translate english castle_stories2_817022d5:

    # ala "Расы живут, развиваются и ищут себе новый дом, если старый сгорел, утонул или захвачен."
    ala "种族在其间生存、发展，并在旧家园被烧毁、淹没或占领时，寻找新的家园。  "

# game/a12/9castle_stories.rpy:630
translate english castle_stories2_9e590dcc:

    # me "И что же случилось со старой землей эльфов?"
    me "那精灵们的旧家园发生了什么？  "

# game/a12/9castle_stories.rpy:631
translate english castle_stories2_a47823e4:

    # ala "Гоблины. Наверное. Это было так давно, что никто и не помнит. Но раз уже там теперь земли гоблинов, видимо наши предки бежали от них."
    ala "哥布林。我猜是。那已太过久远，没人记得了。但既然那里现在是哥布林的土地，想必我们的祖先是为逃离他们而来的。  "

# game/a12/9castle_stories.rpy:632
translate english castle_stories2_d4d2032f:

    # me "И орки тоже захватили эти земли у дворфов."
    me "兽人也是从矮人手中夺取了这些土地。  "

# game/a12/9castle_stories.rpy:633
translate english castle_stories2_34d81e0e:

    # ala "Насчет этого я не уверена. Но даже если это и так, что с того?"
    ala "对此我不太确定。但即便如此，又如何呢？  "

# game/a12/9castle_stories.rpy:634
translate english castle_stories2_06d34f8b:

    # me "Это цикл."
    me "这就是循环。  "

# game/a12/9castle_stories.rpy:635
translate english castle_stories2_0fe21698:

    # ala "Ты... смотришь слишком поверхностно. Нужно зреть в корень. Настоящий цикл не в захвате этого континента. В конце концов он один из многих."
    ala "你……看得还是太表面了。需要看到深层的东西。真正的循环不在于征服这片大陆。毕竟它不过是众多大陆中的一个。  "

# game/a12/9castle_stories.rpy:636
translate english castle_stories2_26782f84:

    # me "...а в чем же?"
    me "……那在于什么？  "

# game/a12/9castle_stories.rpy:637
translate english castle_stories2_ac9549db:

    # ala "В рождении рас. Чтобы не порождало их, земля, звезды, небо, морские глубины... это что-то и формирует цикл."
    ala "在于种族的诞生。无论催生它们的是什么——土地、群星、天空、深海……是那个东西，形成了周期循环。  "

# game/a12/9castle_stories.rpy:638
translate english castle_stories2_d2b04ecc:

    # me "Как?"
    me "怎么形成？  "

# game/a12/9castle_stories.rpy:639
translate english castle_stories2_50ff329a:

    # ala "А разве непонятно? Это... какой-то механизм, что древнее самого времени. Раса рождается, множится и бежит сюда или еще куда-нибудь от другой расы или какой-нибудь природной катастрофы."
    ala "难道还不明白吗？这……是某种比时间本身还要古老的机制。一个种族诞生，繁衍，并从另一场灾难中——无论是另一种族还是自然灾变——逃离到此处或别处。  "

# game/a12/9castle_stories.rpy:640
translate english castle_stories2_1511efdf:

    # ala "Если у нее получается - она остается жить. А если нет..."
    ala "如果它成功了——就活了下来。如果不行……  "

# game/a12/9castle_stories.rpy:641
translate english castle_stories2_aef3a438:

    # me "Те, что приходят, что вторгаются, всегда побеждают."
    me "那些后来的，那些入侵的，永远会胜出。  "

# game/a12/9castle_stories.rpy:642
translate english castle_stories2_3a18c4fe:

    # ala "Этого мы не можем знать наверняка. Нам знакомы только последние три итерации."
    ala "我们无法确定这一点。我们只知道最近三次的迭代。  "

# game/a12/9castle_stories.rpy:643
translate english castle_stories2_af6f300d:

    # me "А как же дворфы и сирены?"
    me "那矮人和海妖呢？  "

# game/a12/9castle_stories.rpy:644
translate english castle_stories2_6951c526:

    # ala "Еще не известно, кто из них жил тут раньше."
    ala "还不知道他们谁在此居住得更早。  "

# game/a12/9castle_stories.rpy:645
translate english castle_stories2_3820771a_3:

    # me "..."
    me "..."

# game/a12/9castle_stories.rpy:647
translate english castle_stories2_ebc7da86:

    # ala "Единственное, что мы знаем наверняка - мы все появились в разное время. Никто из эльфов, орков, дворфов и сирен никогда и ничего не слышали о людях, прежде чем они появились на Востоке."
    ala "我们唯一确定的是——我们都是不同时间出现的。在精灵、兽人、矮人和海妖之前，关于人类出现在东方之前的事，谁也没有一点耳闻。  "

# game/a12/9castle_stories.rpy:648
translate english castle_stories2_c0737855:

    # me "И с остальными было также?"
    me "其他种族也是如此吗？  "

# game/a12/9castle_stories.rpy:649
translate english castle_stories2_d3f12f54:

    # ala "Да."
    ala "是的。  "

# game/a12/9castle_stories.rpy:650
translate english castle_stories2_5b0b1ea0:

    # me "Ну... может мы просто бежали с разных мест?"
    me "嗯……可能我们只是从不同的地方跑来的呢？  "

# game/a12/9castle_stories.rpy:651
translate english castle_stories2_7e08e93b:

    # ala "И никто никогда не видел друг друга до этого? Маловероятно. В древних храмах на Юге есть надписи, что не может прочитать ни одна раса на континенте."
    ala "但在那之前，彼此间竟从无人见过？这可能性不大。在南方那些古老神殿里，有些铭文是这片大陆上任何种族都无法阅读的。  "

# game/a12/9castle_stories.rpy:652
translate english castle_stories2_2325fa76:

    # me "И что?"
    me "那又怎样？  "

# game/a12/9castle_stories.rpy:653
translate english castle_stories2_189ec95d:

    # ala "А еще там изображения рас, что ни одна раса никогда не видела."
    ala "而且那里还有这些种族从未见过的其他种族的图画。  "

# game/a12/9castle_stories.rpy:654
translate english castle_stories2_df47cc52:

    # me "...я об этом не слышал."
    me "……我从没听说过这个。  "

# game/a12/9castle_stories.rpy:655
translate english castle_stories2_4296a25e:

    # ala "Южане никого туда не впускают, кроме своих."
    ala "南方人不放任何外人进去，除了他们自己。  "

# game/a12/9castle_stories.rpy:656
translate english castle_stories2_f303ca2d:

    # me "А откуда ты знаешь?"
    me "你又是怎么知道的？  "

# game/a12/9castle_stories.rpy:657
translate english castle_stories2_a9aa2929:

    # ala "Я? Когда-то эльфов там жаловали. Когда мы соседствовали на континенте на равных."
    ala "我吗？在精灵还能与大陆上其它种族平等相邻的时代，我们在那里曾是受欢迎的。  "

# game/a12/9castle_stories.rpy:658
translate english castle_stories2_ecf0e9ac:

    # me "И что это значит?"
    me "那这意味着什么？  "

# game/a12/9castle_stories.rpy:659
translate english castle_stories2_caad2165:

    # ala "Это значит, что расы продолжают рождаться и умирать долгое время. Очень долгое. Вот он, настоящий цикл."
    ala "这意味着，种族不断诞生和消亡，已经持续了很久。极久。这才是真正的循环。  "

# game/a12/9castle_stories.rpy:660
translate english castle_stories2_b4f7e1e9:

    # me "...что же порождает их? Магия?"
    me "……是什么在催生它们？魔法吗？  "

# game/a12/9castle_stories.rpy:661
translate english castle_stories2_5ff265a8:

    # ala "Мне это неведомо."
    ala "这非我所能知晓。  "

# game/a12/9castle_stories.rpy:662
translate english castle_stories2_3820771a_4:

    # me "..."
    me "..."

# game/a12/9castle_stories.rpy:665
translate english castle_stories2_210e02f6:

    # ala "Не думай об этом слишком много."
    ala "别在这上面想太多。  "

# game/a12/9castle_stories.rpy:666
translate english castle_stories2_eada53ed:

    # me "Почему? Может завтра сюда приплывет еще тысяча кораблей."
    me "为什么？也许明天就又有一千艘船开到这里。  "

# game/a12/9castle_stories.rpy:667
translate english castle_stories2_82ef3988:

    # ala "И как размышления об этом тебе помогут? Поверь мне, наша раса пережила это на своем опыте, тяжелые размышления о судьбе своего народа делают все только хуже."
    ala "想这些能帮到你什么呢？相信我，我们的种族经历过这些，沉重的命运忧思只会让一切更糟。  "

# game/a12/9castle_stories.rpy:668
translate english castle_stories2_3820771a_5:

    # me "..."
    me "..."

# game/a12/9castle_stories.rpy:669
translate english castle_stories2_9965e32b:

    # ala "Кстати о нашем народе. Я должна поблагодарить тебя, за то, что ты не отдал никому Долину."
    ala "说起我的族人。我必须感谢你，没有把山谷交给任何人。  "

# game/a12/9castle_stories.rpy:670
translate english castle_stories2_1bd736b8:

    # me "Я подумал это будет справедливым."
    me "我觉得这是公平的做法。  "

# game/a12/9castle_stories.rpy:671
translate english castle_stories2_ea148ad9:

    # ala "Конечно. Ты справедлив, [mename]. Справедлив и милосерден к нашему народу. Позволь мне кое-что тебе показать."
    ala "当然。你是个公正的人，[mename]。对我们的族人既公正又仁慈。请允许我给你看些东西。  "

# game/a12/9castle_stories.rpy:675
translate english castle_stories2_d4dd29f4:

    # me "Мне нужно идти."
    me "我得走了。  "

# game/a12/9castle_stories.rpy:676
translate english castle_stories2_5b43bec8:

    # ala "Конечно. Ты всегда знаешь, где меня найти, если захочется поговорить о чем-то таком."
    ala "当然。你始终知道在哪里能找到我，只要你想再谈论这样的事。  "

# game/a12/9castle_stories.rpy:677
translate english castle_stories2_37954f90:

    # me "Спасибо, [alaina]."
    me "谢谢，[alaina]。  "

# game/a12/9castle_stories.rpy:678
translate english castle_stories2_537d86af:

    # ala "Не за что."
    ala "没什么。  "

# game/a12/9castle_stories.rpy:682
translate english castle_stories3_fc7d3a18:

    # "Пару минут спустя."
    "几分钟以后。"

# game/a12/9castle_stories.rpy:683
translate english castle_stories3_51c2c17c:

    # me "Что это?"
    me "这是什么？  "

# game/a12/9castle_stories.rpy:684
translate english castle_stories3_36162d0a:

    # ala "Elentár'doran. Эльфийское древо. Одно из последних на континенте. Они растут до определенного размера, а потом могут простоять так хоть тысячу лет."
    ala "Elentár'doran。精灵之树。大陆上仅存的几棵之一。它们长到一定大小，然后就可以这样矗立上一千年。  "

# game/a12/9castle_stories.rpy:685
translate english castle_stories3_e582843e:

    # me "Я видел его в детстве. Мы еще удивлялись с [elin] откуда оно здесь взялось."
    me "我小时候见过它。那时我和[elin]还奇怪它是怎么出现在这里的。  "

# game/a12/9castle_stories.rpy:686
translate english castle_stories3_349ae7cb:

    # ala "Хочешь узнать? Так узнай."
    ala "你想知道吗？那就知道吧。  "

# game/a12/9castle_stories.rpy:687
translate english castle_stories3_d2b04ecc:

    # me "Как?"
    me "怎么知道？  "

# game/a12/9castle_stories.rpy:688
translate english castle_stories3_3683f4f4:

    # ala "В тебе кровь Elentári melda, прикоснись и оно само расскажет тебе свою историю."
    ala "你体内流淌着 Elentári melda 的血。触摸它，它自会告诉你它的故事。  "

# game/a12/9castle_stories.rpy:689
translate english castle_stories3_95daaaf5:

    # me "Звучит..."
    me "听起来……  "

# game/a12/9castle_stories.rpy:690
translate english castle_stories3_838af427:

    # ala "В этом дереве течет магия эльфов. Попробуй."
    ala "这棵树里流淌着精灵的魔法。试试。  "

# game/a12/9castle_stories.rpy:691
translate english castle_stories3_01822020:

    # me "Ладно."
    me "好的。  "

# game/a12/9castle_stories.rpy:693
translate english castle_stories3_3820771a:

    # me "..."
    me "..."

# game/a12/9castle_stories.rpy:694
translate english castle_stories3_11ad07cb:

    # ala "Ну? Что-нибудь чувствуешь?"
    ala "怎样？感觉到了什么吗？  "

# game/a12/9castle_stories.rpy:695
translate english castle_stories3_52bc5669:

    # me "Нет... хотя... я чувствую его грусть?"
    me "没……等等……我感觉到它的悲伤？  "

# game/a12/9castle_stories.rpy:696
translate english castle_stories3_89a79304:

    # ala "..."
    ala "..."

# game/a12/9castle_stories.rpy:697
translate english castle_stories3_5d26d78f:

    # me "Я чувствую его одиночество."
    me "我感觉到它的孤独。  "

# game/a12/9castle_stories.rpy:698
translate english castle_stories3_56991d3f:

    # ala "Да. Оно одиноко. Когда-то их было много. Прямо как нас."
    ala "是的。它很孤独。曾经，它们有许多。就像我们一样。  "

# game/a12/9castle_stories.rpy:699
translate english castle_stories3_3820771a_1:

    # me "..."
    me "..."

# game/a12/9castle_stories.rpy:700
translate english castle_stories3_299d29d8:

    # ala "Что-нибудь еще?"
    ala "还有别的吗？  "

# game/a12/9castle_stories.rpy:701
translate english castle_stories3_ca7db4a6:

    # me "Оно хочет мне что-то показать."
    me "它想展示些什么给我。  "

# game/a12/9castle_stories.rpy:702
translate english castle_stories3_f9390869:

    # ala "Не сопротивляйся. Это не опасно."
    ala "别抗拒。这不危险。  "

# game/a12/9castle_stories.rpy:703
translate english castle_stories3_bbc9f7af:

    # me "Я..."
    me "我……  "

# game/a12/9castle_stories.rpy:705
translate english castle_stories3_8c1a5802:

    # elarion "Es'uros nuas tessa....что ты здесь делаешь? Ты должна быть уже в храме."
    elarion "Es'uros nuas tessa....你在这里做什么？你应该已经在神殿里了。  "

# game/a12/9castle_stories.rpy:706
translate english castle_stories3_ae117808:

    # tessa "Ты совершаешь подвиг, Эларион."
    tessa "你正在完成一项壮举，埃拉里昂。  "

# game/a12/9castle_stories.rpy:707
translate english castle_stories3_0cc81aa8:

    # elarion "Не больше того, что совершил и еще предстоит совершить всему нашему народу."
    elarion "并不比我整个民族已经和将要做的更多。  "

# game/a12/9castle_stories.rpy:708
translate english castle_stories3_3772bd7a:

    # tessa "В храме остались маги и постарше..."
    tessa "神殿里还有更年长的法师……  "

# game/a12/9castle_stories.rpy:709
translate english castle_stories3_0c57f733:

    # elarion "Мы не варвары. Я не стану менять свою жизнь на жизнь того, кому якобы суждено прожить меньше. Тем более многие из них сильнее меня в магии, они еще пригодятся нам в будущих войнах."
    elarion "我们不是野蛮人。我不会用自己的命去换那些据传寿命本就更短的人。何况他们许多在魔法上都比我强，在未来战争中还会对我们有用。  "

# game/a12/9castle_stories.rpy:710
translate english castle_stories3_d0178c09:

    # tessa "Ты... ты же помнишь защитное заклинание?"
    tessa "你……你还记得防御咒语吗？  "

# game/a12/9castle_stories.rpy:711
translate english castle_stories3_11c3ce8b:

    # elarion "Оно не поможет, Тесса. Разве ты не слышишь как гудит воздух? Когда я произнесу слово, здесь все взлетит на воздух."
    elarion "那没用的，苔莎。你没听见空气中的嗡鸣吗？等我念出那个词，这里的一切都会炸上天。  "

# game/a12/9castle_stories.rpy:712
translate english castle_stories3_33851f5f:

    # tessa "...я буду тебя помнить."
    tessa "……我会记住你的。  "

# game/a12/9castle_stories.rpy:713
translate english castle_stories3_132a137c:

    # elarion "И я буду. Встретимся за ужином с Миртой. Я буду тебя ждать."
    elarion "我也会的。我们与Mirta共进晚餐时再见。我会等你。  "

# game/a12/9castle_stories.rpy:714
translate english castle_stories3_780333c3:

    # tessa "Эларион..."
    tessa "埃拉里昂……  "

# game/a12/9castle_stories.rpy:715
translate english castle_stories3_127890e8:

    # elarion "Иди. А то я начинаю думать, что ты хочешь умереть вместе со мной."
    elarion "去吧。不然我该以为你想和我一起死了。  "

# game/a12/9castle_stories.rpy:716
translate english castle_stories3_4e921d7e:

    # tessa "..."
    tessa "..."

# game/a12/9castle_stories.rpy:717
translate english castle_stories3_84affda1:

    # elarion "Тебе еще нужно успеть в храм."
    elarion "你还得赶回神殿去呢。  "

# game/a12/9castle_stories.rpy:719
translate english castle_stories3_aa041c09:

    # tessa "Надеюсь ты услышишь, как их кости и кожа будут плавиться и как они будут кричать."
    tessa "希望你能听到他们的骨肉熔化的声音，还有他们的惨叫声。  "

# game/a12/9castle_stories.rpy:720
translate english castle_stories3_d1925b0c:

    # elarion "Думаю я умру гораздо раньше."
    elarion "我想我会死得比你快得多。  "

# game/a12/9castle_stories.rpy:721
translate english castle_stories3_f2f4b57a:

    # elarion "Ты ушла?"
    elarion "你走了吗？  "

# game/a12/9castle_stories.rpy:722
translate english castle_stories3_1d74b91b:

    # elarion "Хорошо."
    elarion "好的。  "

# game/a12/9castle_stories.rpy:723
translate english castle_stories3_20d69c8d:

    # elarion "Это наш последний миг вместе, приятель."
    elarion "这是我们一起度过的最后时光了，老伙计。  "

# game/a12/9castle_stories.rpy:724
translate english castle_stories3_f505a0bc:

    # elarion "Рад, что встречаю его с тобой."
    elarion "我很高兴是和你一起面对。  "

# game/a12/9castle_stories.rpy:725
translate english castle_stories3_5e6e8ef6:

    # elarion "Ты боишься? Не бойся. Однажды мы воспрянем. Твои и мои братья и сестра снова заселят эти земли. Я это знаю."
    elarion "你在害怕吗？别怕。我们终有一日会卷土重来。你和我所有的兄弟姐妹们，会重新布满这片大地。我知道会这样。  "

# game/a12/9castle_stories.rpy:726
translate english castle_stories3_5ddd3950:

    # elarion "..."
    elarion "..."

# game/a12/9castle_stories.rpy:727
translate english castle_stories3_46862488:

    # elarion "А в прочем? Я могу попробовать спасти тебя. Огонь сожжет меня. Заклинания мне не помогут. А вот тебе..."
    elarion "至于其他？我可以试着救你。火焰会吞噬我。咒语帮不了我。但对你……  "

# game/a12/9castle_stories.rpy:728
translate english castle_stories3_c94b4cab:

    # elarion "Придется отрастить все листья заново. Надеюсь ты не против."
    elarion "你得重新长出所有叶子。希望你别介意。  "

# game/a12/9castle_stories.rpy:729
translate english castle_stories3_3e701c84:

    # elarion "Ты рад... я тоже. Надеюсь ты однажды расскажешь мою историю."
    elarion "你高兴……我也一样。希望有一天，你能讲述我的故事。  "

# game/a12/9castle_stories.rpy:731
translate english castle_stories3_5504717a:

    # warriors "Здесь кто-то есть?"
    warriors "有人在这里吗？  "

# game/a12/9castle_stories.rpy:732
translate english castle_stories3_632f063e:

    # elarion "Saendir Aermo."
    elarion "Saendir Aermo."

# game/a12/9castle_stories.rpy:733
translate english castle_stories3_dbc8204c:

    # warriors "Здесь тоже пусто! Ушли, твари! Что же они так отчаянно сражались за это место, если трусливо сбежали?"
    warriors "这里也是空的！他们跑了，这些畜生！既然害怕得逃跑了，那他们之前干嘛又死活守着这个地方？  "

# game/a12/9castle_stories.rpy:734
translate english castle_stories3_9ff460ce:

    # elarion "Надеюсь всех моих сил будет достаточно."
    elarion "希望我的全部力量足够。  "

# game/a12/9castle_stories.rpy:735
translate english castle_stories3_a55e8736:

    # warriors "Куда? Они были в осаде. Отсюда им некуда было бежать!"
    warriors "往哪跑？他们一直在被围困。他们从这里无路可逃！  "

# game/a12/9castle_stories.rpy:736
translate english castle_stories3_2a5b1161:

    # elarion "Почти всех. Надеюсь ты простишь меня. Кое-что надо было оставить для огня."
    elarion "几乎耗尽。希望你能原谅我。得留点东西烧。  "

# game/a12/9castle_stories.rpy:737
translate english castle_stories3_0808431f:

    # warriors "Значит жмутся на самом верху! Не останавливайтесь."
    warriors "那就是挤在最高处了！别停下。  "

# game/a12/9castle_stories.rpy:738
translate english castle_stories3_9c7e6157:

    # elarion "Увидимся. Через пару секунд или через тысячу лет."
    elarion "再会了。几秒后，或是千年之后。  "

# game/a12/9castle_stories.rpy:739
translate english castle_stories3_5384789d:

    # warriors "Мне уже не терпится отрубить парочку голов! Вижу кого-то!"
    warriors "我已经等不及要砍几颗脑袋了！我看到人了！  "

# game/a12/9castle_stories.rpy:740
translate english castle_stories3_cb88c384:

    # elarion "Пора."
    elarion "时候到了。  "

# game/a12/9castle_stories.rpy:742
translate english castle_stories3_4cdaeb44:

    # elarion "Avernus!"
    elarion "Avernus!"

# game/a12/9castle_stories.rpy:745
translate english castle_stories3_973f6e26:

    # me "Я видел последнего защитника этого храма, прежде чем он..."
    me "我看到了这神殿的最后一名守卫者，就在他……  "

# game/a12/9castle_stories.rpy:746
translate english castle_stories3_4f69aa04:

    # ala "Удивительно. Ты только посмотри."
    ala "这真惊人。快看。  "

# game/a12/9castle_stories.rpy:747
translate english castle_stories3_ad02f53a:

    # me "Что?"
    me "什么？  "

# game/a12/9castle_stories.rpy:748
translate english castle_stories3_949a9d59:

    # ala "Древо... оно окрасило часть листьев в красный."
    ala "那棵树……它让一部分叶子变成了红色。  "

# game/a12/9castle_stories.rpy:749
translate english castle_stories3_a019f1e5:

    # me "Это хорошо или..."
    me "是好还是……  "

# game/a12/9castle_stories.rpy:750
translate english castle_stories3_e896cdfa:

    # ala "Оно чувствует, что ты готов проливать за него кровь."
    ala "它感知到，你已准备好为它流血。  "

# game/a12/9castle_stories.rpy:751
translate english castle_stories3_a0cd80d8:

    # me "Я чувствую... дерево будто благодарно мне за что-то."
    me "我感觉……这棵树似乎在感激我，为了什么而感激。  "

# game/a12/9castle_stories.rpy:752
translate english castle_stories3_6c1e54ba:

    # ala "Elan'or. Mirt'teller. Ты избранный. Я всегда это знала."
    ala "Elan'or。 Mirt'teller。你是天选者。我一直都知道。  "

# game/a12/9castle_stories.rpy:753
translate english castle_stories3_3beb7d33:

    # me "Избранный?"
    me "天选者？  "

# game/a12/9castle_stories.rpy:754
translate english castle_stories3_31139260:

    # ala "Ты поведешь наш народ. Я знала это."
    ala "你将领导我们的民族。我一直知道。  "

# game/a12/9castle_stories.rpy:755
translate english castle_stories3_d1203ea6:

    # me "Куда поведу?"
    me "领导去哪里？  "

# game/a12/9castle_stories.rpy:756
translate english castle_stories3_1a308af1:

    # ala "К свободе! Я знаю это и дерево тоже это чувствует."
    ala "向着自由！我知道这一点，这棵树也感觉到了。  "

# game/a12/9castle_stories.rpy:757
translate english castle_stories3_3820771a_2:

    # me "..."
    me "..."

# game/a12/9castle_stories.rpy:758
translate english castle_stories3_22072681:

    # ala "Больше нет надобности скрывать в тени. Не прячьтесь. Он должен все услышать."
    ala "不需要再隐藏于阴影中了。别躲了。他应该听到一切。  "

# game/a12/9castle_stories.rpy:760
translate english castle_stories3_4afbfb73:

    # arion "Думаешь он и вправду Mirt'teller?"
    arion "你觉得他真的是 Mirt'teller 吗？  "

# game/a12/9castle_stories.rpy:761
translate english castle_stories3_5b528306:

    # noira "Когда я касалась этого дерева, оно тоже краснело... мне кажется."
    noira "我碰这棵树时，它也变红过……我感觉是。  "

# game/a12/9castle_stories.rpy:762
translate english castle_stories3_7c9a98fb:

    # me "Давно не виделись. Это... надо бы объяснить."
    me "好久不见。这个……得解释一下。  "

# game/a12/9castle_stories.rpy:763
translate english castle_stories3_0ca440b4:

    # ala "Они не шпионили за тобой. Я должна была с ними встретится здесь. Но решила, что ты и сам должен стать частью разговора."
    ala "他们没有暗中监视你。我本应在此与他们见面。但我决定，你也应该成为这次谈话的一份子。  "

# game/a12/9castle_stories.rpy:764
translate english castle_stories3_41b91aa6:

    # arion "Я может и не шпионил. А вот она с тебя глаз не сводит."
    arion "我可能没监视。但她可对你目不转睛。  "

# game/a12/9castle_stories.rpy:765
translate english castle_stories3_f28e469a:

    # noira "Заткнись, может он действительно Mirt'teller."
    noira "闭嘴，也许他真的是 Mirt'teller。  "

# game/a12/9castle_stories.rpy:766
translate english castle_stories3_c6bd1c49:

    # me "Я думал вы действуете на Западе."
    me "我以为你们在西方活动。  "

# game/a12/9castle_stories.rpy:767
translate english castle_stories3_9fb1ce24:

    # arion "Ты сделал за нас всю работу. Так что там теперь делать нечего."
    arion "你把我们所有的活儿都干完了。所以那里现在没什么可做的了。  "

# game/a12/9castle_stories.rpy:768
translate english castle_stories3_4a5cbed8:

    # noira "Ага. Похоже новым полем боя станет Север?"
    noira "啊哈。看来新的战场要转向北方了？  "

# game/a12/9castle_stories.rpy:769
translate english castle_stories3_2c36a1f2:

    # me "Вы и об этом знаете? И кто же вам рассказал? Леди [alaina]?"
    me "这你们也知道了？那又是谁告诉你们的？[alaina]女士？  "

# game/a12/9castle_stories.rpy:770
translate english castle_stories3_26407275:

    # ala "[mename]..."
    ala "[mename]..."

# game/a12/9castle_stories.rpy:771
translate english castle_stories3_ae109cf5:

    # arion "Леди [alaina]? Ты будто глухой булрок. Сам не осознаешь, какой шум создаешь."
    arion "[alaina]女士？你真像个聋了的公牛。自己还不知道自己弄出了多大动静？  "

# game/a12/9castle_stories.rpy:772
translate english castle_stories3_4a3f5b26:

    # noira "Эльфы живут везде. Мы просто предположили, что ты не упустишь такую возможность воссоединить Империю."
    noira "精灵无处不在。我们只是推测，你不会放过这个重新统一帝国的机会。  "

# game/a12/9castle_stories.rpy:773
translate english castle_stories3_ffc51265:

    # me "Понятно."
    me "明白了。  "

# game/a12/9castle_stories.rpy:775
translate english castle_stories3_94022c1a:

    # selest "И что он здесь делает?"
    selest "他在这儿干嘛？  "

# game/a12/9castle_stories.rpy:776
translate english castle_stories3_36f2ff20:

    # me "И с вами тоже давно не виделись. Привет."
    me "和你们也是好久不见了。你好。  "

# game/a12/9castle_stories.rpy:777
translate english castle_stories3_28feea82:

    # ala "Селестина."
    ala "萨拉斯蒂娜。  "

# game/a12/9castle_stories.rpy:778
translate english castle_stories3_165a81e7:

    # selest "Что? Уговор был другой."
    selest "怎么？当初说好的可不一样。  "

# game/a12/9castle_stories.rpy:779
translate english castle_stories3_bb325fb3:

    # me "Кажется леди [alaina] решила, что обстоятельства изменились."
    me "看来[alaina]女士决定了，情况已经改变。  "

# game/a12/9castle_stories.rpy:780
translate english castle_stories3_bd98e8c1:

    # ala "Верно. Он заслуживает знать, все что мы делаем."
    ala "没错。他理应知道我们正在做的一切。  "

# game/a12/9castle_stories.rpy:781
translate english castle_stories3_800ac28e:

    # selest "Да ну."
    selest "哦，算了吧。  "

# game/a12/9castle_stories.rpy:782
translate english castle_stories3_d3f12f54:

    # ala "Да."
    ala "是的。  "

# game/a12/9castle_stories.rpy:783
translate english castle_stories3_b0d2a067:

    # selest "Ты искренне в это веришь?"
    selest "你真心这么相信？  "

# game/a12/9castle_stories.rpy:784
translate english castle_stories3_364658ce:

    # ala "Я это знаю."
    ala "我知道就是这么回事。  "

# game/a12/9castle_stories.rpy:785
translate english castle_stories3_cd4eb829:

    # selest "..."
    selest "..."

# game/a12/9castle_stories.rpy:786
translate english castle_stories3_119c5d46:

    # me "Ну... если меня не приглашали на этот разговор..."
    me "那么……要是没邀请我参加这次谈话……  "

# game/a12/9castle_stories.rpy:787
translate english castle_stories3_30156dfd:

    # ala "Нет. Останься."
    ala "不，留下。  "

# game/a12/9castle_stories.rpy:789
translate english castle_stories3_10d813ce:

    # selest "Дерево говорило с тобой?"
    selest "树跟你交谈了吗？  "

# game/a12/9castle_stories.rpy:790
translate english castle_stories3_fc30fd2b:

    # me "Да."
    me "谈了。  "

# game/a12/9castle_stories.rpy:791
translate english castle_stories3_4fd4f8bd:

    # ala "Оно окрасила ветвь в красный."
    ala "它让一根枝条变成了红色。  "

# game/a12/9castle_stories.rpy:792
translate english castle_stories3_708c6412:

    # selest "В тот же цвет они окрашивались, когда его предки резали нас как свиней."
    selest "它变成那种颜色时，正是他的祖先像宰猪一样屠杀我们的时候。  "

# game/a12/9castle_stories.rpy:793
translate english castle_stories3_66b3053a:

    # ala "Ты забываешь, что его предки умирали здесь по обе стороны противостояния."
    ala "你忘了，他的祖先也曾在这对峙的双方之中死去。  "

# game/a12/9castle_stories.rpy:794
translate english castle_stories3_37b1f812:

    # selest "И какая из его сторон сильнее? Дерево окрасило ветвь в красный... Может оно просто боится? "
    selest "那他哪一方的血更浓？树让枝条变红……或许它只是害怕了？  "

# game/a12/9castle_stories.rpy:795
translate english castle_stories3_1b0f2d33:

    # me "Оно доверяет мне."
    me "它信任我。  "

# game/a12/9castle_stories.rpy:796
translate english castle_stories3_73670ac2:

    # selest "Откуда мне знать, что ты не лжешь?"
    selest "我怎么知道你不是在撒谎？  "

# game/a12/9castle_stories.rpy:797
translate english castle_stories3_3ff5705d:

    # ala "Спроси у дерева сама."
    ala "那就自己问这棵树。  "

# game/a12/9castle_stories.rpy:798
translate english castle_stories3_cd4eb829_1:

    # selest "..."
    selest "..."

# game/a12/9castle_stories.rpy:799
translate english castle_stories3_3c4e4b17:

    # ala "Ну?"
    ala "怎样？  "

# game/a12/9castle_stories.rpy:800
translate english castle_stories3_327269bf:

    # selest "...ну хорошо. Допустим дерево ему верит. Это ничего не меняет. Ты нарушила уговор. Мы должны были встретится наедине."
    selest "……好吧。假设这棵树信任他。这改变不了什么。你违背了约定。我们本该单独见面的。  "

# game/a12/9castle_stories.rpy:801
translate english castle_stories3_84571c0a:

    # ala "Уговор изменился. Теперь [mename] его часть."
    ala "约定变了。现在，[mename]是其中的一部分。  "

# game/a12/9castle_stories.rpy:802
translate english castle_stories3_730c268b:

    # selest "Чем он заслужил такую милость от тебя, [alaina]?"
    selest "他到底做了什么，值得你如此恩宠，[alaina]？  "

# game/a12/9castle_stories.rpy:803
translate english castle_stories3_a510ce10:

    # ala "Как минимум тем, что я жива."
    ala "至少他让我活着。  "

# game/a12/9castle_stories.rpy:805
translate english castle_stories3_3214f1ed:

    # selest "То, что он соизволил тебя не казнить мы будем считать его достоинством? Спасибо, господин человек, что не засунули в солнечную камеру эльфа, как только его увидел."
    selest "就因为他开恩没有处决你，这就算他的功绩了？谢谢您，人类大人，因为您一看见精灵没把她关进日晒牢房。  "

# game/a12/9castle_stories.rpy:806
translate english castle_stories3_3d1a15f0:

    # ala "Он не только сохранил мне жизнь. Он спас меня. Он пошел наперекор члену своей семьи. Это многое значит."
    ala "他不仅保住了我的命。他还救了我。他违逆了自家人的意见。这意义重大。  "

# game/a12/9castle_stories.rpy:807
translate english castle_stories3_e09f68e1:

    # selest "Может ты ему как вторая мамочка. Он помогает тебе, потому что знает с самого детства."
    selest "也许他把你当第二个妈妈了。他帮你是因为他从小就认识你。  "

# game/a12/9castle_stories.rpy:808
translate english castle_stories3_641540b4:

    # ala "Он спас еще одну эльфийку. Ту, что обворовала его. Он не только пощадил ее, но и пожертвовал репутацией, защитив от городского трибунала."
    ala "他还救过另一个精灵女性。就是偷了他东西的那个。他不仅放过了她，还牺牲自己名誉，在城市法庭上保护了她。  "

# game/a12/9castle_stories.rpy:809
translate english castle_stories3_1df74ffa:

    # selest "Замечательно. Теперь мы знаем, что ему нравятся эльфийки."
    selest "好极了。现在我们知道了，他喜欢精灵姑娘。  "

# game/a12/9castle_stories.rpy:810
translate english castle_stories3_9a0733c5:

    # ala "Ты серьезно сейчас? Неужели мое слово больше для тебя ничего не значит?"
    ala "你现在是认真的吗？难道我所说的话在你那里已经一点分量也没有了？  "

# game/a12/9castle_stories.rpy:811
translate english castle_stories3_cd4eb829_2:

    # selest "..."
    selest "..."

# game/a12/9castle_stories.rpy:812
translate english castle_stories3_61ab93f0:

    # ala "Он выбрал поддержать мятежников на Западе, помнишь? Выполнил твою работу."
    ala "还记得吗？他选择支持西方的反抗军。替你完成了你的工作。  "

# game/a12/9castle_stories.rpy:813
translate english castle_stories3_16dbf4cb:

    # selest "Он не один ее выполнял."
    selest "那工作又不是他一个人完成的。  "

# game/a12/9castle_stories.rpy:814
translate english castle_stories3_37fc2a21:

    # ala "Конечно. И все же."
    ala "当然。不过依然。  "

# game/a12/9castle_stories.rpy:815
translate english castle_stories3_f9887943:

    # selest "Может он не захотел оставлять власть у Лордов, что предали его деда."
    selest "也许他只是不想把权力留给出卖了他祖父的领主们。  "

# game/a12/9castle_stories.rpy:816
translate english castle_stories3_5903d978:

    # me "Большая часть из них никого не предавала."
    me "那些领主大部分没出卖过谁。  "

# game/a12/9castle_stories.rpy:817
translate english castle_stories3_5fbbb68a:

    # ala "Сегодня он подписал документ, который оставляет Долину свободной имперской территорией. Что на это скажешь."
    ala "今天他签署了一份文件，让山谷保持自由帝国领地的地位。这个你倒是说说看。  "

# game/a12/9castle_stories.rpy:818
translate english castle_stories3_5ea4d818:

    # selest "Опять совпадение. Просто не захотел давать своим лордам больше власти."
    selest "又是巧合。他只是不想给他的领主们更多权力罢了。  "

# game/a12/9castle_stories.rpy:819
translate english castle_stories3_73e77ce6:

    # me "Не многовато ли совпадений?"
    me "这巧合未免太多了点？  "

# game/a12/9castle_stories.rpy:820
translate english castle_stories3_c4f29923:

    # ala "Он прав. Ты несправедлива."
    ala "他说得对。你这么说不公平。  "

# game/a12/9castle_stories.rpy:821
translate english castle_stories3_dc43fb2a:

    # noira "Мам..."
    noira "妈……  "

# game/a12/9castle_stories.rpy:822
translate english castle_stories3_5ef14563:

    # arion "Вынужден тут согласиться с сестрой и с леди Алейной."
    arion "我在这里不得不认同我的姊妹和Alaina夫人。  "

# game/a12/9castle_stories.rpy:823
translate english castle_stories3_4f5a0a8f:

    # selest "Если ты правда один из нас, если ты правда Mirt'teller... ты готов помочь нам еще один раз?"
    selest "如果你确实是我们中的一员，如果你真的是 Mirt'teller……你愿意再帮我们一次吗？  "

# game/a12/9castle_stories.rpy:825
translate english castle_stories3_432b53e1:

    # me "А вы поможете мне?"
    me "那你们会帮助我吗？  "

# game/a12/9castle_stories.rpy:826
translate english castle_stories3_7b6d4fa0:

    # selest "Да."
    selest "会的。  "

# game/a12/9castle_stories.rpy:827
translate english castle_stories3_09de6368:

    # me "Тогда я согласен. Дело в Севере?"
    me "那我同意。是为了北方的事吗？  "

# game/a12/9castle_stories.rpy:828
translate english castle_stories3_9dd8a29c:

    # ala "Да. На Севере полно эльфов."
    ala "对。北方有许多精灵。  "

# game/a12/9castle_stories.rpy:829
translate english castle_stories3_cf3cc35a:

    # selest "И там уже давно пора менять власть."
    selest "而且那里的政权早就该换了。  "

# game/a12/9castle_stories.rpy:830
translate english castle_stories3_60d337f0:

    # me "Вы поможете мне сделать Север частью Империи?"
    me "你们会协助我，让北方成为帝国的一部分吗？  "

# game/a12/9castle_stories.rpy:831
translate english castle_stories3_3fc75a05:

    # ala "Мы поможем тебе."
    ala "我们会帮助你的。  "

# game/a12/9castle_stories.rpy:832
translate english castle_stories3_57741a30:

    # selest "Если ты..."
    selest "如果你……  "

# game/a12/9castle_stories.rpy:833
translate english castle_stories3_55f6284d:

    # me "Мне нужно выбрать кого-то конкретного?"
    me "需要我选择支持某个具体的人吗？  "

# game/a12/9castle_stories.rpy:834
translate english castle_stories3_88982a51:

    # selest "Мне нравится как ты мыслишь, но пока рано делать такие выводы. Все что я могу сказать сейчас - ты не должен помогать горцам. Они убивают эльфов и всегда будут это делать."
    selest "我喜欢你思考的方式，但现在就下结论还太早。我现在只能说——你不能帮助高地人。他们杀害精灵，并且会一直这样做。  "

# game/a12/9castle_stories.rpy:835
translate english castle_stories3_ffc51265_1:

    # me "Понятно."
    me "明白了。  "

# game/a12/9castle_stories.rpy:836
translate english castle_stories3_21e4c41e:

    # ala "Орден безымянного пути собирает все больше сторонников."
    ala "无名之路教团正在聚集越来越多的支持者。  "

# game/a12/9castle_stories.rpy:837
translate english castle_stories3_af052d8d:

    # selest "А еще один из лордов проявляет явный интерес... к переустройству королевства."
    selest "另外还有一位领主，对于……王国的重组表现出明显的兴趣。  "

# game/a12/9castle_stories.rpy:838
translate english castle_stories3_64ee60c6:

    # me "Что за лорд?"
    me "是哪位领主？  "

# game/a12/9castle_stories.rpy:839
translate english castle_stories3_b37b0c64:

    # ala "Мы дадим тебе знать, когда ты прибудешь на место. Мы всегда будем рядом."
    ala "等你到了那里，我们会告诉你的。我们总会跟在你身边。  "

# game/a12/9castle_stories.rpy:840
translate english castle_stories3_acc14cb5:

    # me "Так... возможностей несколько?"
    me "所以……存在多种可能？  "

# game/a12/9castle_stories.rpy:841
translate english castle_stories3_56e76f18:

    # selest "Да. В этот раз сторон силы явно больше чем две. Нужно будет все обдумать на месте."
    selest "对。这次的势力数量，明显大于两方。需要到当地后好好想想。  "

# game/a12/9castle_stories.rpy:842
translate english castle_stories3_55d3a440:

    # me "...хорошо."
    me "……好。  "

# game/a12/9castle_stories.rpy:843
translate english castle_stories3_9de357e4:

    # ala "Mirt'teller, он сделает все как надо."
    ala "Mirt'teller，他会把一切都做好的。  "

# game/a12/9castle_stories.rpy:844
translate english castle_stories3_78b4c941:

    # selest "Видит Мирта, если он действительно поможет нам и там - я сама буду его так называть."
    selest "Mirta在上，如果他在那里也真的帮助我们——我会自己这么称呼他的。  "

# game/a12/9castle_stories.rpy:845
translate english castle_stories3_45fd39fa:

    # ala "Все эльфы однажды будут."
    ala "所有的精灵，终有一日都会的。  "

# game/a12/9castle_stories.rpy:850
translate english castle_stories3_d7b026a9:

    # ala "...ну что?"
    ala "……嗯，怎样？  "

# game/a12/9castle_stories.rpy:851
translate english castle_stories3_973f6e26_1:

    # me "Я видел последнего защитника этого храма, прежде чем он..."
    me "我看到了这神殿的最后一名守卫者，就在他……  "

# game/a12/9castle_stories.rpy:852
translate english castle_stories3_d1c9562e:

    # ala "Прежде чем все здесь превратилось в руины. "
    ala "就在这里的一切化为废墟之前。  "

# game/a12/9castle_stories.rpy:853
translate english castle_stories3_ced6c52e:

    # me "Дерево испытало великую боль."
    me "这棵树承受了巨大的痛苦。  "

# game/a12/9castle_stories.rpy:854
translate english castle_stories3_36509d3c:

    # ala "Как и весь наш народ. И все же оно выжило."
    ala "就像我们整个民族。然而，它还是活了下来。  "

# game/a12/9castle_stories.rpy:855
translate english castle_stories3_fc30fd2b_1:

    # me "Да."
    me "是的。  "

# game/a12/9castle_stories.rpy:856
translate english castle_stories3_213d7a52:

    # ala "Циклы это не приговор, [mename]. Да, орки и сирены почти полностью вымерли. Но дворфы живы. Не благоденствуют, но еще далеки от вымирания."
    ala "循环并不是判决，[mename]。是的，兽人和海妖几乎彻底消亡了。但矮人还活着。虽未兴盛，但离灭绝还很远。  "

# game/a12/9castle_stories.rpy:857
translate english castle_stories3_a6ad1159:

    # ala "И мы тоже. Может мы будем первыми?"
    ala "我们也一样。也许我们会是第一个？  "

# game/a12/9castle_stories.rpy:858
translate english castle_stories3_5504ddea:

    # me "Первыми?"
    me "第一个？  "

# game/a12/9castle_stories.rpy:859
translate english castle_stories3_7a96ae2d:

    # ala "Первыми, кто нарушит цикл?"
    ala "第一个打破循环的种族？  "

# game/a12/9castle_stories.rpy:860
translate english castle_stories3_3820771a_3:

    # me "..."
    me "..."

# game/a12/9castle_stories.rpy:861
translate english castle_stories3_f5ef4c6f:

    # ala "Первыми, кто вернет себе свой дом или хотя бы законное право жить в нем как раньше."
    ala "第一个夺回自己的家园，或者至少是合法生活在那里的权利的种族？  "

# game/a12/9castle_stories.rpy:862
translate english castle_stories3_1a798ee2:

    # ala "Задумайся. Может, чтобы помешать новому циклу, надо просто не дать закончится старому?"
    ala "想一想。也许要阻止新循环，只需要不让旧循环结束？  "

# game/a12/9castle_stories.rpy:863
translate english castle_stories3_15abdb75:

    # ala "Ты. Ты можешь все изменить. Помни об этом."
    ala "你。你可以改变一切。要记得这一点。  "

