    me "我们走吧。"

# game/a12/6wife_brith.rpy:1273
translate english wife_brith3_aur_f6b9211f:

    # aurora "Да... пойдем."
    aurora "好……走吧。"

# game/a12/6wife_brith.rpy:1275
translate english wife_brith3_aur_23212821:

