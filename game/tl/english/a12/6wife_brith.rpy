    # aurora "Потом поем. Ты мне принесешь."
    aurora "我回头再吃。你给我带点来。"

# game/a12/6wife_brith.rpy:1319
translate english wife_brith3_aur_83a6f5e3:

    # me "Аврора?"
    me "Aurora？"

# game/a12/6wife_brith.rpy:1320
