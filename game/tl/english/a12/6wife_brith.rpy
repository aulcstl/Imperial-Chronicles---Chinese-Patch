    isi "躺下吧。"

# game/a12/6wife_brith.rpy:1141
translate english wife_brith_late_back_0beb0433:

    # isi "Ты думал как его назвать?"
    isi "想过给他起什么名吗？"

# game/a12/6wife_brith.rpy:1142
translate english wife_brith_late_back_5a7a7577:

    # me "Нет."
    me "没。"

# game/a12/6wife_brith.rpy:1143
translate english wife_brith_late_back_a88e4ba6:

    # isi "Это не очень хорошо. Потому что я тоже не думала."
    isi "这可不太好。因为我也没想过。"

# game/a12/6wife_brith.rpy:1144
translate english wife_brith_late_back_97133289:

    # me "Придумаем."
    me "会想出来的。"

