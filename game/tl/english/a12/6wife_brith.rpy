translate english wife_brith3_aur_42eae5a7:

    # me "Вдруг что? Что может произойти? Пожар? Обрушение стен?"
    me "万一什么？能发生什么？火灾吗？墙壁倒塌吗？"

# game/a12/6wife_brith.rpy:1278
translate english wife_brith3_aur_0050fdbf:

    # aurora "А камин хорошо потушен?"
    aurora "壁炉的火确实灭了吧？"

# game/a12/6wife_brith.rpy:1279
translate english wife_brith3_aur_b42c4f9f:

