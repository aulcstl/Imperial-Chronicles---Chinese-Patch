    # isi "Сильно не затягиваем. Нельзя наследнику Империи не носить имя."
    isi "别拖太久。帝国的继承人不能没个名字。"

# game/a12/6wife_brith.rpy:1146
translate english wife_brith_late_back_260237ff:

