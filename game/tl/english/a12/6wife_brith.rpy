    me "那可太好了。咱们走吧。"

# game/a12/6wife_brith.rpy:1230
translate english wife_brith3_aur_fc7d3a18:

    # "Пару минут спустя."
    "几分钟以后。"

# game/a12/6wife_brith.rpy:1231
translate english wife_brith3_aur_70a81c41:

    # me "Ты закончила?"
    me "你喂好了吗？"

# game/a12/6wife_brith.rpy:1232
translate english wife_brith3_aur_4a981408:

    # aurora "Да. Почти."
    aurora "嗯。差不多了。"

# game/a12/6wife_brith.rpy:1233
translate english wife_brith3_aur_ec06f4a6:

    # me "Нравится?"
    me "喜欢吗？"

# game/a12/6wife_brith.rpy:1234
translate english wife_brith3_aur_b633ebe3:

    # lia "Угу. Смешной. Маленький такой."
    lia "嗯。真好玩。小小的一个。"

# game/a12/6wife_brith.rpy:1235
translate english wife_brith3_aur_f9d64e3f:

    # me "Похож на меня?"
    me "像我吗？"

# game/a12/6wife_brith.rpy:1236
translate english wife_brith3_aur_9c08a4ab:

