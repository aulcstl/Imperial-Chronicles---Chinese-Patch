translate english wife_brith3_aur_49b4273b:

    # lia "Нет. Я ему видимо нравлюсь."
    lia "没有。看来他挺喜欢我。"

# game/a12/6wife_brith.rpy:1269
translate english wife_brith3_aur_9010a61d:

    # aurora "Т-только не доставайте его без надобности."
    aurora "没，没事的话别把他从摇篮里抱出来。"

# game/a12/6wife_brith.rpy:1270
translate english wife_brith3_aur_35f3a72a:

