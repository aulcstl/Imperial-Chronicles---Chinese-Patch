translate english wife_brith3_aur_cbc85b0e:

    # slug "Я знаю что в таких случаях делать. Я нянчила шестерых братьев и сестер."
    slug "遇到那种情况我懂得怎么处理。我带大过六个弟弟妹妹。"

# game/a12/6wife_brith.rpy:1258
translate english wife_brith3_aur_d30990ba:

    # aurora "А если..."
    aurora "可万一……"

# game/a12/6wife_brith.rpy:1259
translate english wife_brith3_aur_1ccac3f2:

    # me "Аврора."
    me "Aurora。"

# game/a12/6wife_brith.rpy:1260
translate english wife_brith3_aur_aae9669d:

    # aurora "Да... ладно, пойдем."
    aurora "好吧……走吧。"

# game/a12/6wife_brith.rpy:1262
translate english wife_brith3_aur_0164bf3a:

    # lia "Привееет. Я твоя тетя."
    lia "你好呀。我是你姨妈。"

# game/a12/6wife_brith.rpy:1263
translate english wife_brith3_aur_41a5ba82:

    # aurora "[nsname] проснулся?"
    aurora "[孩子名]醒了？"

