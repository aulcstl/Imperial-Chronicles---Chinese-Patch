    # aurora "Можно мы вернемся? Или хотя бы я одна?"
    aurora "咱们能回去吗？或者至少我一个人回去？"

# game/a12/6wife_brith.rpy:1321
translate english wife_brith3_aur_cc92f87a:

    # me "Ну ты даешь."
    me "你可真行。"

