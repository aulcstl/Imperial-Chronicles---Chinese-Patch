    # midw "Не забывай тужиться."
    midw "别忘了使劲。"

# game/a12/6wife_brith.rpy:118
translate english wife_brith_aur_913497a5:

    # aurora "{size=+5}Мгм...{/size}"
    aurora "{size=+5}嗯……{/size}"

# game/a12/6wife_brith.rpy:120
translate english wife_brith_aur_578658c3:

    # aurora "{size=+5}Ах....{/size}"
    aurora "{size=+5}啊……{/size}"

# game/a12/6wife_brith.rpy:121
translate english wife_brith_aur_ef2275a5:

    # doc "У нее довольно узкий таз, так что возможен повышенный болевой симптом."
    doc "她的骨盆比较窄，所以疼痛感可能会加剧。"

# game/a12/6wife_brith.rpy:122
translate english wife_brith_aur_37b9551f:

    # me "Но она же... с ней все будет нормально?"
    me "可她是……她不会有事的吧？"

# game/a12/6wife_brith.rpy:123
translate english wife_brith_aur_67edb599:

    # aurora "{size=+5}АХ! СУКА!{/size}"
    aurora "{size=+5}啊！操！{/size}"

# game/a12/6wife_brith.rpy:124
translate english wife_brith_aur_8c03150f:

    # doc "Да. Я сообщу если что-то будет не так."
    doc "会的。要是有什么不对，我会通知您。"

# game/a12/6wife_brith.rpy:125
translate english wife_brith_aur_85a228b4:

    # me "А может что-то быть не так?"
    me "会有什么不对的可能吗？"

# game/a12/6wife_brith.rpy:126
translate english wife_brith_aur_5ece905b:

    # aurora "{size=+5}ЧТО? ЧТО НЕ ТАК?{/size}"
    aurora "{size=+5}什么？什么不对？{/size}"

# game/a12/6wife_brith.rpy:127
translate english wife_brith_aur_c67bd0ba:

    # doc "Все хорошо, дорогая. У тебя все нормально, продолжай дышать."
    doc "一切都好，亲爱的。你一切正常，继续深呼吸。"

# game/a12/6wife_brith.rpy:128
translate english wife_brith_aur_83a6f5e3:

    # me "Аврора?"
    me "Aurora？"

# game/a12/6wife_brith.rpy:129
translate english wife_brith_aur_0995e64b:

    # aurora "{size=+5}О, НЕВЕДОМЫЙ ДАЙ МНЕ СИЛ!{/size}"
    aurora "{size=+5}哦，无名的神明，赐我力量！{/size}"

# game/a12/6wife_brith.rpy:130
translate english wife_brith_aur_e7f1cb89:

    # doc "Ваша поддержка ей сейчас ни к чему, уверяю. Я позову вас, когда все закончится."
    doc "您现在的支持对她没什么用，我保证。等结束了我会叫您。"

# game/a12/6wife_brith.rpy:131
translate english wife_brith_aur_71d3b8c8:

    # me "Хорошо."
    me "好吧。"

# game/a12/6wife_brith.rpy:133
translate english wife_brith_aur_50cffe01:

    # aurora "{size=+5}Я ДЫШУ, Я ДЫШУ, Я ДЫШУ...{/size}"
    aurora "{size=+5}我深呼吸，我深呼吸，我深呼吸……{/size}"

# game/a12/6wife_brith.rpy:134
translate english wife_brith_aur_dd6dd286:

    # doc "Молодец."
    doc "好样的。"

# game/a12/6wife_brith.rpy:135
translate english wife_brith_aur_b74b0607_1:

    # midw "Не забывай тужиться."
    midw "别忘了用力。"

# game/a12/6wife_brith.rpy:136
translate english wife_brith_aur_231d70e7:

    # aurora "{size=+5}Еще... МОЖНО ЕЩЕ ЭФИРА...{/size}"
    aurora "{size=+5}再来点……能再给点乙醚吗……{/size}"

# game/a12/6wife_brith.rpy:137
translate english wife_brith_aur_c9ca0337:

    # doc "Нет. Иначе ты потеряешь чувствительность."
    doc "不行。否则你会失去知觉。"

# game/a12/6wife_brith.rpy:138
translate english wife_brith_aur_55bcdbb3:

    # aurora "{size=+5}РАЗВЕ СМЫСЛ НЕ В ЭТОМ?{/size}"
    aurora "{size=+5}那不正是目的所在吗？{/size}"

# game/a12/6wife_brith.rpy:139
translate english wife_brith_aur_83e4158b:

    # doc "Нет. Тогда роды замедлятся. Продолжай тужиться."
    doc "不是。那样分娩会变慢。继续用力。"

# game/a12/6wife_brith.rpy:140
translate english wife_brith_aur_b46ecebe:

    # aurora "{size=+5}А Я ЧТО МАТЬ ВАШУ ДЕЛАЮ?{/size}"
    aurora "{size=+5}我这不是他妈的在使劲吗？{/size}"

# game/a12/6wife_brith.rpy:144
translate english wife_brith_isi_23f78fd2:

    # "Пару месяцев спустя."
    "几个月以后。"

# game/a12/6wife_brith.rpy:145
translate english wife_brith_isi_f9eefb6f:

    # me "И что это? Восстание?"
    me "这算什么？暴动吗？"

# game/a12/6wife_brith.rpy:146
translate english wife_brith_isi_acb6e78b:

    # isi "Я не разбираюсь в тонкостях политики на Севере."
    isi "我不太懂北方的政治门道。"

# game/a12/6wife_brith.rpy:147
translate english wife_brith_isi_6fb07de7:

    # me "На Юге все решается по-другому?"
    me "南方处理事情的方式不一样？"

# game/a12/6wife_brith.rpy:148
translate english wife_brith_isi_60e1d7f4:

    # isi "На Юге это уже была бы война до последнего выжившего. Нужно уничтожать всех, кто даже думает о том, чтобы посягнуть на твой авторитет правителя. Я уже не говорю о том, когда против твоей власти выступают открыто..."
    isi "在南方，这早就成了打到只剩最后一人的战争了。任何胆敢觊觎你统治者权威的人，都必须斩草除根。更别提那些公开站出来反对你权力的人了……"

# game/a12/6wife_brith.rpy:149
translate english wife_brith_isi_2b097119:

    # me "У них выборная система. Они голосуют за короля на вече."
    me "他们是选举制。他们在维切大会上给国王投票。"

# game/a12/6wife_brith.rpy:150
translate english wife_brith_isi_3c648a59:

    # isi "И что?"
    isi "那又怎样？"

# game/a12/6wife_brith.rpy:151
translate english wife_brith_isi_00f58808:

    # me "Разве они не могут просто выбрать кого-то другого?"
    me "他们难道不能干脆选别人吗？"

# game/a12/6wife_brith.rpy:152
translate english wife_brith_isi_4e86bb03:

    # isi "А если недовольных меньшинство?"
    isi "要是心怀不满的是少数派呢？"

# game/a12/6wife_brith.rpy:153
translate english wife_brith_isi_3820771a:

    # me "..."
    me "..."

# game/a12/6wife_brith.rpy:154
translate english wife_brith_isi_05124353:

    # isi "Знаешь, даже сама идея, что один человек может представлять интересы сразу всех - полный абсурд."
    isi "要知道，就连一个人能代表所有人的利益这种想法本身，就完全是荒谬的。"

# game/a12/6wife_brith.rpy:155
translate english wife_brith_isi_14d55fd6:

    # me "Разве здесь и на Юге не так? Мы не представляем интересы всех подданных?"
    me "难道这里和南方不也一样吗？我们不也代表所有臣民的利益？"

# game/a12/6wife_brith.rpy:157
translate english wife_brith_isi_57fe3bbd:

    # isi "Хахаха. [mename], не смеши меня."
    isi "哈哈哈，[mename]，别逗我了。"

# game/a12/6wife_brith.rpy:158
translate english wife_brith_isi_bb5124ed:

    # me "Что? Я помню ты сама говорила, что не стоит злить простолюдинов."
    me "怎么了？我记得你自己也说过，不应该激怒平民百姓。"

# game/a12/6wife_brith.rpy:159
translate english wife_brith_isi_d2d6110c:

    # isi "Злить может и не стоит. Но представлять их интересы? Опомнись. У власти всегда самый сильный. Вот и вся наука."
    isi "也许是不该激怒他们。但代表他们的利益？你清醒点吧。掌权的永远是最强者。道理就这么简单。"

# game/a12/6wife_brith.rpy:160
translate english wife_brith_isi_ad268a71:

    # me "Все так просто?"
    me "就那么简单？"

# game/a12/6wife_brith.rpy:161
translate english wife_brith_isi_2b04de18:

    # isi "Да. Тем более этот конфликт не с простолюдинами. Даже на Западе, среди повстанцев были дети Лордов. А тут все еще проще. Это просто внутренний конфликт за власть."
    isi "对。更何况这次冲突不是跟平民百姓闹起来的。即使在西部，叛军里也有领主的孩子。而这里的事情更简单。这纯粹就是内部权力冲突。"

# game/a12/6wife_brith.rpy:162
translate english wife_brith_isi_1e0fb5b7:

    # me "Но он же не возникает на пустом месте? Они двадцать лет жили под властью переизбираемого короля и вдруг что-то поменялось."
    me "可这冲突不会凭空产生吧？他们在一位可连任的国王统治下过了二十年，突然就变了。"

# game/a12/6wife_brith.rpy:163
translate english wife_brith_isi_731b6562:

    # isi "[mename], да брось. Ты же прекрасно знаешь, что произошло."
    isi "[mename]，得了吧。你很清楚发生了什么。"

# game/a12/6wife_brith.rpy:164
translate english wife_brith_isi_ad02f53a:

    # me "Что?"
    me "什么？"

# game/a12/6wife_brith.rpy:165
translate english wife_brith_isi_490be042:

    # isi "Ты присоединил к Империи Запад."
    isi "你把西部并入了帝国。"

# game/a12/6wife_brith.rpy:166
translate english wife_brith_isi_2325fa76:

    # me "И что?"
    me "那又如何？"

# game/a12/6wife_brith.rpy:167
translate english wife_brith_isi_e100f749:

    # isi "Это как в притче про прутик и жабу."
    isi "这就像那个树枝和蟾蜍的寓言。"

# game/a12/6wife_brith.rpy:168
translate english wife_brith_isi_3e9912b1:

    # me "Что за притча?"
    me "什么寓言？"

# game/a12/6wife_brith.rpy:169
translate english wife_brith_isi_11a8930b:

    # isi "Жаба вешала камыши на деревянный прутик. Он гнулся и трещал, а она все вешала и вешала..."
    isi "蟾蜍往一根木棍上挂芦苇。木棍弯了，喀喀作响，它还一直往上挂，一直挂……"

# game/a12/6wife_brith.rpy:170
translate english wife_brith_isi_0b16b034:

    # me "И прутик все же сломался."
    me "结果木棍还是断了。"

# game/a12/6wife_brith.rpy:171
translate english wife_brith_isi_7effd10f:

    # isi "Нет. Он выдержал вес, но пока жаба вешала камыши на прутик, мимо шел волк и наступил на него, тот лопнул и жаба вместе с камышами полетела в воду."
    isi "不，它撑住了重量，可正当蟾蜍往木棍上挂芦苇时，有只狼路过，踩到了它，木棍啪地断了，蟾蜍连同芦苇一起掉进了水里。"

# game/a12/6wife_brith.rpy:173
translate english wife_brith_isi_e792209a:

    # me "...У всех притч с Юга нет никакой морали?"
    me "……你们南方的寓言都没什么寓意吗？"

# game/a12/6wife_brith.rpy:174
translate english wife_brith_isi_af221899:

    # isi "Мораль в том, что прутик может быть сломался бы и сам, но его сломал волк, что просто шел мимо. Неминуемость события может быть ускорена случайностью."
    isi "寓意在于，那根木棍或许自己迟早会断，但它偏偏是被一头路过的狼给踩断的。一件事的必然性可能会因偶然事件而加速发生。"

# game/a12/6wife_brith.rpy:175
translate english wife_brith_isi_f9e7c0ac:

    # me "Так я выходит этот самый волк."
    me "这么说，我就是那头狼了。"

# game/a12/6wife_brith.rpy:176
translate english wife_brith_isi_ef2183aa:

    # isi "Большой и страшный."
    isi "又大又可怕。"

# game/a12/6wife_brith.rpy:177
translate english wife_brith_isi_15edf74f:

    # me "Ладно... этот разговор все равно не имеет смысла. Мы понятия не имеем, что там случилось."
    me "算了……这场讨论反正也没意义。我们对那里到底发生了什么一无所知。"

# game/a12/6wife_brith.rpy:178
translate english wife_brith_isi_346f067b:

    # isi "А нужно бы узнать..."
    isi "但我们应该去弄清楚……"

# game/a12/6wife_brith.rpy:179
translate english wife_brith_isi_d368d7c7:

    # me "Ты что-то замыслила?"
    me "你在打什么主意？"

# game/a12/6wife_brith.rpy:180
translate english wife_brith_isi_0c64dff4:

    # isi "Ты что-то замыслил."
    isi "是你在打什么主意吧。"

# game/a12/6wife_brith.rpy:181
translate english wife_brith_isi_3820771a_1:

    # me "..."
    me "..."

# game/a12/6wife_brith.rpy:182
translate english wife_brith_isi_03ffedf8:

    # isi "В городе полно малых домов твоей семьи."
    isi "城里到处都是你家的小分支。"

# game/a12/6wife_brith.rpy:183
translate english wife_brith_isi_f95c9fc9:

    # me "И?"
    me "那又怎样？"

# game/a12/6wife_brith.rpy:184
translate english wife_brith_isi_b24a8917:

    # isi "Возьми какую-нибудь троюродную кузину или кузена и повези... налаживать связи."
    isi "随便找个远房表姐或表弟，带过去……建立联系。"

# game/a12/6wife_brith.rpy:185
translate english wife_brith_isi_dd218421:

    # me "О дипломатических браках договариваются заранее. Это же не деревенская ярмарка с коровами."
    me "政治联姻都是提前商定的。这又不是乡村集市上买卖牲口。"

# game/a12/6wife_brith.rpy:186
translate english wife_brith_isi_fa0527e1:

    # isi "Да брось, [mename], это же просто повод. Они будут не рады, если ты вмешаешься. Поэтому ты приедешь заключать... династический брак например."
    isi "哎，算了吧，[mename]，这不过是个由头罢了。你要是插手进去，他们反倒不会高兴。所以你去就是为了缔结……比如，联姻。"

# game/a12/6wife_brith.rpy:187
translate english wife_brith_isi_4548e5a1:

    # me "С троюродной кузиной."
    me "跟一个远房表姐。"

# game/a12/6wife_brith.rpy:188
translate english wife_brith_isi_a2adfd6e:

    # isi "У тебя скоро родится сын или дочь, чем не повод для свадебной дипломатии? Мою мать пообещали отцу, когда ей не было и года."
    isi "你很快就会有儿子或女儿了，这难道不是进行联姻外交的好理由吗？我母亲许配给我父亲的时候，还不满一岁呢。"

# game/a12/6wife_brith.rpy:189
translate english wife_brith_isi_3f09d602:

    # me "Возможно... но наш ребенок вообще пока не родился."
    me "也许吧……但我们的孩子现在都还没出生呢。"

# game/a12/6wife_brith.rpy:191
translate english wife_brith_isi_ad4bc79d:

    # isi "Похоже... это скоро изменится... [mename]?"
    isi "看来……这情况很快就会变了……[mename]？"

# game/a12/6wife_brith.rpy:192
translate english wife_brith_isi_60782264:

    # me "Что случилось?"
    me "出什么事了？"

# game/a12/6wife_brith.rpy:193
translate english wife_brith_isi_e3c776ab:

    # isi "Не знаю..."
    isi "不知道……"

# game/a12/6wife_brith.rpy:194
translate english wife_brith_isi_77102083:

    # me "Боли?"
    me "疼？"

# game/a12/6wife_brith.rpy:195
translate english wife_brith_isi_bc197fc8:

    # isi "Боли? Похоже что-то посерьезнее."
    isi "疼？看起来好像更严重了。"

# game/a12/6wife_brith.rpy:196
translate english wife_brith_isi_bde2b858:

    # me "Ты рожаешь?"
    me "你要生了？"

# game/a12/6wife_brith.rpy:197
translate english wife_brith_isi_d4379724:

    # isi "Понятия не имею. Я же не рожала раньше."
    isi "没概念。我以前又没生过。"

# game/a12/6wife_brith.rpy:198
translate english wife_brith_isi_b90c5c71:

    # me "Ну это... новые ощущения или просто... тянет как раньше?"
    me "嗯，这个……是新的感觉，还是就像之前那种……抽痛？"

# game/a12/6wife_brith.rpy:199
translate english wife_brith_isi_385b3dc0:

    # isi "Это... новые... определенно."
    isi "这个感觉……绝对是……新的。"

# game/a12/6wife_brith.rpy:201
translate english wife_brith_isi_307fbf84:

    # isi "[mename], мне страшно!"
    isi "[mename]，我好怕！"

# game/a12/6wife_brith.rpy:202
translate english wife_brith_isi_4425dd93:

    # me "Все нормально. Это же должно было когда-то начаться."
    me "没事的。这事儿总归是要开始的。"

# game/a12/6wife_brith.rpy:203
translate english wife_brith_isi_9e60da7a:

    # isi "...пиздец."
    isi "……真是操蛋。"

# game/a12/6wife_brith.rpy:204
translate english wife_brith_isi_cde57a53:

    # me "Я позову слуг, они подготовят кровать."
    me "我去叫仆人，让他们把床铺准备好。"

# game/a12/6wife_brith.rpy:205
translate english wife_brith_isi_47925f40:

    # isi "Лучше сразу доктора."
    isi "最好直接把医生叫来。"

# game/a12/6wife_brith.rpy:206
translate english wife_brith_isi_bc09a8e2:

    # me "Доктора?"
    me "医生？"

# game/a12/6wife_brith.rpy:207
translate english wife_brith_isi_c118e66f:

    # isi "У меня что-то по ноге стекает."
    isi "我腿上好像有东西流下来。"

# game/a12/6wife_brith.rpy:208
translate english wife_brith_isi_672a5a4c:

    # me "Ты серьезно?"
    me "真的假的？"

# game/a12/6wife_brith.rpy:209
translate english wife_brith_isi_a7fc7e79:

    # isi "Да. У меня похоже отходят воды."
    isi "真的。我好像破水了。"

# game/a12/6wife_brith.rpy:210
translate english wife_brith_isi_3820771a_2:

    # me "..."
    me "..."

# game/a12/6wife_brith.rpy:211
translate english wife_brith_isi_ffd3b4af:

    # isi "..."
    isi "..."

# game/a12/6wife_brith.rpy:212
translate english wife_brith_isi_2f67ee96:

    # isime "Блядь."
    isime "操。"

# game/a12/6wife_brith.rpy:213
translate english wife_brith_isi_3887efaf:

    # me "Я отведу тебя в покои."
    me "我带你回寝宫。"

# game/a12/6wife_brith.rpy:215
translate english wife_brith_isi_79d82858:

    # "Десять минут спустя."
    "十分钟以后。"

