# game/a12/8valley_talk.rpy:747
translate english valley_talk_l_bb76cf58:

    # mom "Привет, [mename]. Какое же густое, да?"
    mom "嗨，[mename]。真稠啊，是吧？"

# game/a12/8valley_talk.rpy:748
translate english valley_talk_l_4907682a:

    # me "Это что?"
    me "这是什么？"

# game/a12/8valley_talk.rpy:749
translate english valley_talk_l_0a9900fc:

    # mom "Масло."
    mom "油。"

# game/a12/8valley_talk.rpy:750
translate english valley_talk_l_eb804ff8:

    # me "Я вижу, что масло. Зачем оно?"
    me "我知道是油。它用来干嘛的？"

# game/a12/8valley_talk.rpy:751
translate english valley_talk_l_f89999e9:

    # mom "Ну... в этот раз беременность идет для меня сложновато. Кожа часто пересыхает и тяжесть... что-то подобное было когда я вынашивала тебя и [elin]."
    mom "嗯...这次怀孕对我来说有点辛苦。皮肤经常干燥，身子也沉...怀你和[elin]时也差不多是这样。"

# game/a12/8valley_talk.rpy:752
translate english valley_talk_l_ffc51265:

    # me "Понятно."
    me "明白了。"

# game/a12/8valley_talk.rpy:753
translate english valley_talk_l_f864b487:

    # mom "..."
    mom "..."

# game/a12/8valley_talk.rpy:754
translate english valley_talk_l_3820771a:

    # me "..."
    me "..."

# game/a12/8valley_talk.rpy:755
translate english valley_talk_l_a16cf911:

    # mom "Ты поговорил с отцом?"
    mom "你和你父亲谈过了吗？"

# game/a12/8valley_talk.rpy:756
translate english valley_talk_l_dd73651f:

    # me "Еще нет."
    me "还没。"

# game/a12/8valley_talk.rpy:757
translate english valley_talk_l_0b59ebeb:

    # mom "Почему?"
    mom "为什么？"

# game/a12/8valley_talk.rpy:758
translate english valley_talk_l_8bf17525:

    # me "Сначала хотел узнать... ну... жива ли ты как минимум."
    me "我想先确认...嗯...至少你还活着。"

# game/a12/8valley_talk.rpy:760
translate english valley_talk_l_586fc6cc:

    # mom "Ты правда так обо мне волнуешься?"
    mom "你就这么担心我吗？"

# game/a12/8valley_talk.rpy:761
translate english valley_talk_l_dae36352:

    # me "Правда."
    me "真的。"

# game/a12/8valley_talk.rpy:762
translate english valley_talk_l_5a1864b6:

    # mom "Мне очень приятно, спасибо."
    mom "真贴心，谢谢。"

# game/a12/8valley_talk.rpy:763
translate english valley_talk_l_1fe7cd27:

    # me "Так..."
    me "那么..."

# game/a12/8valley_talk.rpy:764
translate english valley_talk_l_d16cdc21:

    # mom "Ну я жива."
    mom "嗯，我还活着。"

# game/a12/8valley_talk.rpy:765
translate english valley_talk_l_e9c4c329:

    # me "Это я вижу. А еще вижу что ты перестала скрывать беременность. Говорила о ней с доктором."
    me "我看见了。我还看见你不再隐瞒怀孕的事了。还和医生谈了这事。"

# game/a12/8valley_talk.rpy:766
translate english valley_talk_l_d38157a0:

    # mom "Верно."
    mom "没错。"

# game/a12/8valley_talk.rpy:767
translate english valley_talk_l_938c4f9d:

    # me "А еще ты не собираешь вещи так что... все прошло хорошо?"
    me "而且你也没收拾行李，所以...一切都顺利吗？"

# game/a12/8valley_talk.rpy:768
translate english valley_talk_l_14efdd54:

    # mom "Можно и так сказать."
    mom "可以这么说吧。"

# game/a12/8valley_talk.rpy:769
translate english valley_talk_l_fa93c945:

    # me "Мам. Мне правда нужно это из тебя выуживать?"
    me "妈妈。非让我一点点从你嘴里套话吗？"

# game/a12/8valley_talk.rpy:771
translate english valley_talk_l_41a58053:

    # mom "Я поговорила с твоим отцом. Он позволил мне остаться."
    mom "我和你父亲谈过了。他允许我留下来。"

# game/a12/8valley_talk.rpy:772
translate english valley_talk_l_c3f092c5:

    # me "А что насчет... ну знаешь... отцовства ребенка."
    me "那关于...你知道的...孩子的父亲..."

# game/a12/8valley_talk.rpy:773
translate english valley_talk_l_058a3547:

    # mom "Я ничего ему не говорила. Но он выглядел так, будто всё знает."
    mom "我什么都没跟他说。但他看起来好像什么都知道了。"

# game/a12/8valley_talk.rpy:774
translate english valley_talk_l_3820771a_1:

    # me "..."
    me "..."

# game/a12/8valley_talk.rpy:775
translate english valley_talk_l_c3fb9f9b:

    # mom "Не волнуйся [mename], это был разговор о нас двоих. Ты тут не при чем."
    mom "别担心，[mename]，那只是关于我们俩的谈话。不关你的事。"

# game/a12/8valley_talk.rpy:776
translate english valley_talk_l_db759ce7:

    # me "Ну вообще-то причем. Тем более если он знает."
    me "当然关我的事。尤其如果他已经知道了。"

# game/a12/8valley_talk.rpy:777
translate english valley_talk_l_451964a1:

    # mom "На тебя это не повлияет, обещаю."
    mom "我保证，这不会影响到你。"

# game/a12/8valley_talk.rpy:778
translate english valley_talk_l_5d4e16cd:

    # me "Но он же не мог просто позволить тебе остаться. Это как-то..."
    me "但他不可能就这么简单地允许你留下。这有点..."

# game/a12/8valley_talk.rpy:779
translate english valley_talk_l_d73c313a:

    # mom "А он и не позволял 'просто' остаться. Он не будет признавать этого ребенка."
    mom "他当然不会'简单'地允许。他不会承认这个孩子。"

# game/a12/8valley_talk.rpy:780
translate english valley_talk_l_7e536c6d:

    # me "Он будет бастардом? "
    me "那他会成为私生子吗？"

# game/a12/8valley_talk.rpy:781
translate english valley_talk_l_a242f1a0:

    # mom "Что-то посередине. Будет носить фамилию, но отец лишит его титулов... непублично."
    mom "介于两者之间吧。会有姓氏，但你父亲会...非公开地剥夺他的头衔。"

# game/a12/8valley_talk.rpy:782
translate english valley_talk_l_b78c6e26:

    # me "А ты?"
    me "那你呢？"

# game/a12/8valley_talk.rpy:783
translate english valley_talk_l_54909d41:

    # mom "У меня и не было никакого титула, кроме королевы-матери."
    mom "我本来除了王太后也没什么头衔。"

# game/a12/8valley_talk.rpy:784
translate english valley_talk_l_0f06f141:

    # me "И все же ты ведешь официальную переписку."
    me "可你还在处理官方信件。"

# game/a12/8valley_talk.rpy:785
translate english valley_talk_l_6a9b03ee:

    # mom "По-твоему я делаю это без дозволения твоего отца?"
    mom "你觉得没你父亲的允许我能这么做吗？"

# game/a12/8valley_talk.rpy:786
translate english valley_talk_l_3820771a_2:

    # me "..."
    me "..."

# game/a12/8valley_talk.rpy:787
translate english valley_talk_l_e6f6d960:

    # mom "Все будет нормально, [mename]. Это лучший исход для этой ситуации из возможных."
    mom "一切都会好的，[mename]。在这情况下，这已经是最好的结果了。"

# game/a12/8valley_talk.rpy:788
translate english valley_talk_l_b27182f3:

    # me "Пожалуй. Помочь с кремом?"
    me "也是。需要我帮你涂油吗？"

# game/a12/8valley_talk.rpy:789
translate english valley_talk_l_03d5c0e4:

    # mom "Не надо. Он очень надолго впитывается в кожу. Будешь еще неделю пахнуть пустотелкой."
    mom "不用。这油吸收到皮肤里要很长时间。你会带着一身空心草味过上一周。"

# game/a12/8valley_talk.rpy:791
translate english valley_talk_l_91b52ccd:

    # me "Я настаиваю."
    me "我坚持要帮你。"

# game/a12/8valley_talk.rpy:792
translate english valley_talk_l_dc2a52cf:

    # mom "[mename]?"
    mom "[mename]?"

# game/a12/8valley_talk.rpy:793
translate english valley_talk_l_69997204:

    # me "Это мой ребенок. Я обязан о нем заботиться, так что пока он в тебе, я обязан заботиться о тебе."
    me "这是我的孩子。我有责任照顾他，所以只要他还在你肚子里，我就有责任照顾你。"

# game/a12/8valley_talk.rpy:794
translate english valley_talk_l_edaceca4:

    # mom "Ну..."
    mom "嗯..."

# game/a12/8valley_talk.rpy:795
translate english valley_talk_l_ad02f53a:

    # me "Что?"
    me "怎么了？"

# game/a12/8valley_talk.rpy:796
translate english valley_talk_l_6f693c1c:

    # mom "Ты не обязан. Я могу и сама это сделать."
    mom "你没有这个责任。我可以自己来。"

# game/a12/8valley_talk.rpy:797
translate english valley_talk_l_3567903c:

    # me "Я хочу."
    me "我想做。"

# game/a12/8valley_talk.rpy:798
translate english valley_talk_l_fdeb8d13:

    # mom "Правда?"
    mom "真的吗？"

# game/a12/8valley_talk.rpy:799
translate english valley_talk_l_fc30fd2b:

    # me "Да."
    me "是的。"

# game/a12/8valley_talk.rpy:800
translate english valley_talk_l_c1d2235a:

    # mom "...ладно."
    mom "...好吧。"

# game/a12/8valley_talk.rpy:801
translate english valley_talk_l_3448d5b9:

    # me "Ты так удивляешься, будто это какой-то подвиг. "
    me "你惊讶的样子，好像这是什么壮举似的。"

# game/a12/8valley_talk.rpy:802
translate english valley_talk_l_284c5e38:

    # mom "Не подвиг. Но... мне приятно, что ты обо мне заботишься."
    mom "不是壮举。但是...你照顾我，让我很高兴。"

# game/a12/8valley_talk.rpy:803
translate english valley_talk_l_7797e82e:

    # me "Я не могу иначе."
    me "我别无选择。"

# game/a12/8valley_talk.rpy:805
translate english valley_talk_l_6f8a567d:

    # mom "Потому что я беременна?"
    mom "就因为我怀孕了？"

# game/a12/8valley_talk.rpy:806
translate english valley_talk_l_81e15f4d:

    # me "И поэтому тоже. Еще я тебя люблю."
    me "这也是原因之一。还有，我爱你。"

# game/a12/8valley_talk.rpy:807
translate english valley_talk_l_f864b487_1:

    # mom "..."
    mom "..."

# game/a12/8valley_talk.rpy:808
translate english valley_talk_l_41813ad3:

    # me "И потому что ты очень красивая, мам."
    me "还因为你非常美，妈妈。"

# game/a12/8valley_talk.rpy:809
translate english valley_talk_l_2b9d8fe2:

    # mom "Просто живот еще не слишком большой."
    mom "只是肚子还没那么大。"

# game/a12/8valley_talk.rpy:810
translate english valley_talk_l_40f209e8:

    # me "С большим животом будешь еще красивее."
    me "肚子大起来你会更美。"

# game/a12/8valley_talk.rpy:811
translate english valley_talk_l_51c1d40e:

    # mom "Ладно, льстец, покажи что ты умеешь работать не только языком."
    mom "行了，马屁精，让我看看你不光会耍嘴皮子，手活儿怎么样。"

# game/a12/8valley_talk.rpy:813
translate english valley_talk_l_3820771a_3:

    # me "..."
    me "..."

# game/a12/8valley_talk.rpy:814
translate english valley_talk_l_f864b487_2:

    # mom "..."
    mom "..."

# game/a12/8valley_talk.rpy:815
translate english valley_talk_l_6215010e:

    # me "Получается?"
    me "这样行吗？"

# game/a12/8valley_talk.rpy:816
translate english valley_talk_l_eec00336:

    # mom "Да. Неплохо."
    mom "挺好。不错。"

# game/a12/8valley_talk.rpy:817
translate english valley_talk_l_ff0c0e9d:

    # me "Это чтобы кожа не сохла?"
    me "这是为了防止皮肤干燥？"

# game/a12/8valley_talk.rpy:818
translate english valley_talk_l_557f875b:

    # mom "Не только. Это помогает справиться с тяжестью и растяжками."
    mom "不止。这也有助于缓解沉重感和妊娠纹。"

# game/a12/8valley_talk.rpy:819
translate english valley_talk_l_008b1b56:

    # me "Растяжками?"
    me "妊娠纹？"

# game/a12/8valley_talk.rpy:820
translate english valley_talk_l_d8f9cba7:

    # mom "[mename], ты же видел, как от ребенка вздувается живот. Кожа натягивается. Если регулярно ее не увлажнять, после родов останется куча растяжек."
    mom "[mename]，你肯定见过怀孩子会把肚子撑多大。皮肤绷得很紧。要是不定期滋润，生完孩子会留下很多妊娠纹。"

# game/a12/8valley_talk.rpy:821
translate english valley_talk_l_ffc51265_1:

    # me "Понятно."
    me "明白了。"

# game/a12/8valley_talk.rpy:822
translate english valley_talk_l_09bd6e98:

    # mom "Они останутся в любом случае. Но исчезнут быстрее и их будет меньше, если использовать масло."
    mom "反正总会留下一些的。但用油的话，它们消得更快，也会少一些。"

# game/a12/8valley_talk.rpy:824
translate english valley_talk_l_1cc78d25:

    # me "Женское тело хранит от меня множество тайн."
    me "女性的身体对我藏着好多秘密啊。"

# game/a12/8valley_talk.rpy:825
translate english valley_talk_l_39882bcb:

    # mom "Растяжки бывают не только у женщин."
    mom "出现妊娠纹的可不止是女人。"

# game/a12/8valley_talk.rpy:826
translate english valley_talk_l_752e937b:

    # me "Да ну."
    me "是吗。"

# game/a12/8valley_talk.rpy:827
translate english valley_talk_l_9b6b8e4d:

    # mom "Конечно. Одна из причин, почему тебе не нужно налегать на еду. Особенно с возрастом."
    mom "当然。这就是你不能暴饮暴食的原因之一。尤其是随着年龄增长。"

# game/a12/8valley_talk.rpy:828
translate english valley_talk_l_b9f8d04b:

    # me "Теперь буду оставлять последнюю ложку с едой на тарелке."
    me "那我以后每餐都得在盘子里留最后一口饭了。"

# game/a12/8valley_talk.rpy:829
translate english valley_talk_l_fbbcde68:

    # mom "Не нужно. Я скажу тебе, если ты начнешь переедать."
    mom "没必要。如果你真吃太多，我会告诉你的。"

# game/a12/8valley_talk.rpy:830
translate english valley_talk_l_ba50432c:

    # me "Хорошо. Следи."
    me "好的。盯着我。"

# game/a12/8valley_talk.rpy:831
translate english valley_talk_l_5c315c78:

    # mom "У тебя хорошо получается."
    mom "你做得挺好。"

# game/a12/8valley_talk.rpy:832
translate english valley_talk_l_489a247d:

    # me "Правда?"
    me "真的吗？"

# game/a12/8valley_talk.rpy:833
translate english valley_talk_l_16160f1e:

    # mom "Мгм. Я думала ты будешь грубоват."
    mom "嗯。我还以为你会有点粗鲁。"

# game/a12/8valley_talk.rpy:835
translate english valley_talk_l_8bc9c823:

    # me "Грубоват? С моей императрицей? С собственной матерью? С матерью моего..."
    me "粗鲁？对我的皇后？对我的亲生母亲？对我未出世的...的母亲？"

# game/a12/8valley_talk.rpy:836
translate english valley_talk_l_e028d5e0:

    # mom "Не продолжай, пожалуйста. Я поняла."
    mom "求你别说了。我懂了。"

# game/a12/8valley_talk.rpy:837
translate english valley_talk_l_603612db:

    # me "Я нанесу масло на ноги тоже."
    me "我给腿上也要涂些油。"

# game/a12/8valley_talk.rpy:838
translate english valley_talk_l_01350e1b:

    # mom "Нанеси, раз уж начал."
    mom "既然都开始了，就涂吧。"

# game/a12/8valley_talk.rpy:839
translate english valley_talk_l_3820771a_4:

    # me "..."
    me "..."

# game/a12/8valley_talk.rpy:840
translate english valley_talk_l_f864b487_3:

    # mom "..."
    mom "..."

# game/a12/8valley_talk.rpy:841
translate english valley_talk_l_f2cfe0bf:

    # me "Вроде все намазал."
    me "好像都抹遍了。"

# game/a12/8valley_talk.rpy:842
translate english valley_talk_l_16327264_1:

    # mom "Да."
    mom "嗯。"

# game/a12/8valley_talk.rpy:843
translate english valley_talk_l_5044d36c:

    # me "Что-то еще намазать?"
    me "还要抹别的吗？"

# game/a12/8valley_talk.rpy:844
translate english valley_talk_l_b1d7cf62:

    # mom "Не надо."
    mom "不用了。"

# game/a12/8valley_talk.rpy:845
translate english valley_talk_l_ed22a759:

    # me "Мы закончили?"
    me "我们涂完了？"

# game/a12/8valley_talk.rpy:846
translate english valley_talk_l_3c247f42:

    # mom "Да. Спасибо."
    mom "嗯。谢谢。"

# game/a12/8valley_talk.rpy:847
translate english valley_talk_l_c6edb536:

    # me "Я заслужил поцелуй, моя императрица?"
    me "我应得一个吻吧，我的皇后？"

# game/a12/8valley_talk.rpy:848
translate english valley_talk_l_8ec18d8b:

    # mom "...один маленький поцелуйчик."
    mom "...就一个小小的吻。"

# game/a12/8valley_talk.rpy:850
translate english valley_talk_l_2f40c825:

    # mom "Мнмм."
    mom "嗯～"

# game/a12/8valley_talk.rpy:851
translate english valley_talk_l_7ed8132a:

    # me "{i}Почему настолько неправильные вещи могут приносить столько удовольствия?{/i}"
    me "{i}为什么如此错误的事情，却能带来如此多的快乐？{/i}"

# game/a12/8valley_talk.rpy:852
translate english valley_talk_l_2ef15b47:

    # me "{i}Наверное я никогда этого не узнаю.{/i}"
    me "{i}也许我永远也不会明白了。{/i}"

# game/a12/8valley_talk.rpy:853
translate english valley_talk_l_4d5d9d32:

    # me "{i}Я чувствую к ней точно что-то большее, чем должен.{/i}"
    me "{i}我对她感受到的，肯定是不应该产生的更深的情感。{/i}"

# game/a12/8valley_talk.rpy:854
translate english valley_talk_l_e4fc067a:

    # me "{i}Должен ли я винить себя за это?{/i}"
    me "{i}我该为此责备自己吗？{/i}"

# game/a12/8valley_talk.rpy:855
translate english valley_talk_l_18f65813:

    # me "{i}Это часть моей природы. Часть меня самого.{/i}"
    me "{i}这是我天性的一部分。是我自身的一部分。{/i}"

# game/a12/8valley_talk.rpy:856
translate english valley_talk_l_0a88bf22:

    # me "{i}Я не могу от этого отказаться. Только спрятать.{/i}"
    me "{i}我无法放弃。只能深藏。{/i}"

# game/a12/8valley_talk.rpy:857
translate english valley_talk_l_526547f0:

    # me "{i}Но если уж принц-регент не может позволить себе не держать это внутри, то кто может?{/i}"
    me "{i}但如果连摄政王子都无法直面内心，那还有谁可以呢？{/i}"

# game/a12/8valley_talk.rpy:858
translate english valley_talk_l_a4f39092:

    # me "{i}Я хочу ее любить и я буду это делать.{/i}"
    me "{i}我想爱她，我也会继续爱下去。{/i}"

# game/a12/8valley_talk.rpy:860
translate english valley_talk_l_c415bfe3:

    # mom "Так. Ну всё-всё. Хватит."
    mom "好了。就这样吧。够了。"

# game/a12/8valley_talk.rpy:861
translate english valley_talk_l_e101bba0:

    # me "Может еще один поцелуй?"
    me "也许再亲一下？"

# game/a12/8valley_talk.rpy:862
translate english valley_talk_l_f8756449:

    # mom "Нет. Я знаю куда это нас приведет."
    mom "不行。我知道这会引向哪里。"

# game/a12/8valley_talk.rpy:863
translate english valley_talk_l_33c06ab2:

    # me "Вроде уже привело."
    me "好像已经引向过了。"

# game/a12/8valley_talk.rpy:864
translate english valley_talk_l_d24e5085:

    # mom "Вот именно. Ты должен был встретиться и поговорить с отцом, ты помнишь?"
    mom "正是。你该去见你父亲，和他谈谈了，记得吗？"

# game/a12/8valley_talk.rpy:865
translate english valley_talk_l_3820771a_5:

    # me "..."
    me "..."

# game/a12/8valley_talk.rpy:866
translate english valley_talk_l_dc2a52cf_1:

    # mom "[mename]?"
    mom "[mename]?"

# game/a12/8valley_talk.rpy:867
translate english valley_talk_l_a37b6d1c:

    # me "Помню-помню. Просто я хотел..."
    me "记得记得。只是我原本想..."

# game/a12/8valley_talk.rpy:868
translate english valley_talk_l_28bc0ce6:

    # mom "Нет. Хватит. Я тоже тебя люблю, но я не для этого провела самый тяжелый разговор в своей жизни полчаса назад, чтобы снова... ставить чувства выше долга."
    mom "不。够了。我也爱你，但我半小时前刚经历过这辈子最艰难的谈话，不是为了又把感情置于责任之上。"

# game/a12/8valley_talk.rpy:869
translate english valley_talk_l_74fc8c8c:

    # me "Это же не значит..."
    me "这不意味着..."

# game/a12/8valley_talk.rpy:870
translate english valley_talk_l_9e07dd0c:

    # mom "Не значит. Но не сейчас. Не время. У тебя разговор с Императором."
    mom "不意味着。但不是现在。不是时候。你得去和皇帝谈话了。"

# game/a12/8valley_talk.rpy:871
translate english valley_talk_l_ed84754b:

    # me "Да. Конечно."
    me "好。当然。"

# game/a12/8valley_talk.rpy:872
translate english valley_talk_l_5e8cbfbe:

    # mom "Иди уже."
    mom "去吧。"

