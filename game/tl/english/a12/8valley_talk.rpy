# game/a12/8valley_talk.rpy:707
translate english valley_talk_8df2a5aa:

    # mom "Да. Мне даже не стыдно. Почти что."
    mom "是的。我甚至不觉得羞耻。几乎不。"

# game/a12/8valley_talk.rpy:709
