translate english sec_retalk2_efe374cc:

    # lartua_y "Мой Император."
    lartua_y "我的皇帝陛下。"

# game/a12/1sec_retalk.rpy:178
translate english sec_retalk2_a6d9c96e:

    # leonard "Мой Император."
    leonard "我的皇帝陛下。"

# game/a12/1sec_retalk.rpy:179
translate english sec_retalk2_0ab33eee:

    # lagg "Мой Император."
    lagg "我的皇帝陛下。"

# game/a12/1sec_retalk.rpy:180
translate english sec_retalk2_1984a8d2:

    # me "Мой Император."
    me "我的皇帝陛下。"

# game/a12/1sec_retalk.rpy:181
translate english sec_retalk2_8015af23:

    # king2 "Кажется кого-то не хватает, но время было объявлено заранее, так что начнем. Какие тема у нас основная?"
    king2 "好像少了个人，不过时间早就定好了，那我们就开始吧。我们今天的主要议题是什么？"

