# game/a12/4cassbass.rpy:849
translate english cassbass_breake_c32f18f8:

    # cass "ЧТО? [mename]?"
    cass "什么？[mename]？"

# game/a12/4cassbass.rpy:850
translate english cassbass_breake_a026af70:

    # fake_spy "Тсс... не двигайся, девочка."
    fake_spy "嘘……别动，姑娘。"

# game/a12/4cassbass.rpy:851
translate english cassbass_breake_ac3e9352:

    # me "Будь с ней аккуратней. Она может быть... дикой."
    me "对她下手轻点。她可能会……很野。"

# game/a12/4cassbass.rpy:852
translate english cassbass_breake_f6762728:

    # cass "КАКОГО ХУЯ ПРОИСХОДИТ?"
    cass "他妈的怎么回事？"

# game/a12/4cassbass.rpy:853
translate english cassbass_breake_591d6a52:

    # fake_spy "Не шевелись. Не хочется бить тебя головой о стол."
    fake_spy "别乱动。我可不想把你脑袋往桌子上撞。"

# game/a12/4cassbass.rpy:854
translate english cassbass_breake_89b2285e:

    # cass "НЕ ПОНИМАЮ...."
    cass "我不明白...."

# game/a12/4cassbass.rpy:856
translate english cassbass_breake_80947037:

    # me "Что именно тебе непонятно?"
    me "有什么不明白的？"

# game/a12/4cassbass.rpy:857
translate english cassbass_breake_f49118a7:

    # cass "Зачем? Ты оплатил мой побег? Зачем? Чтобы что? Чтобы убить меня без суда?"
    cass "为什么？你花钱帮我越狱？为什么？为了什么？为了不经审判就杀了我？"

# game/a12/4cassbass.rpy:858
translate english cassbass_breake_60e397ee:

    # me "Убить? Раба убивать нельзя. Это же имущество. Я не стану ломать свое имущество без причины."
    me "杀？奴隶是不能杀的。那是财产。我可不会无缘无故损坏自己的财产。"

# game/a12/4cassbass.rpy:859
translate english cassbass_breake_e4375d59:

    # cass "О боги, да ты не оплачивал мой побег... не нанимал этого человека..."
    cass "天哪，你没花钱雇人帮我越狱……也没雇这个人……"

# game/a12/4cassbass.rpy:860
translate english cassbass_breake_73809e9c:

    # me "Ты начинаешь понимать."
    me "你开始明白了。"

# game/a12/4cassbass.rpy:861
translate english cassbass_breake_f4fdeb06:

    # cass "Это с самого начала был театр!"
    cass "从一开始就是一场戏！"

# game/a12/4cassbass.rpy:862
translate english cassbass_breake_f0701b7b:

    # me "Хороший раб. Умный. Сообразительный."
    me "好奴隶。聪明。有悟性。"

# game/a12/4cassbass.rpy:863
translate english cassbass_breake_abaad55a:

    # cass "Зачем?"
    cass "为什么？"

# game/a12/4cassbass.rpy:864
translate english cassbass_breake_18217e0e:

    # me "Как зачем? Чтобы проверить."
    me "什么为什么？当然是为了检验你。"

# game/a12/4cassbass.rpy:865
translate english cassbass_breake_c9eb358d:

    # cass "Проверить что?"
    cass "检验什么？"

# game/a12/4cassbass.rpy:867
translate english cassbass_breake_b0c1eaac:

    # me "Проверить насколько ты была послушной девочкой."
    me "检验一下你到底有多听话。"

# game/a12/4cassbass.rpy:868
translate english cassbass_breake_f20fa4e0:

    # cass "Ублюдок!"
    cass "你这杂种！"

# game/a12/4cassbass.rpy:869
translate english cassbass_breake_1408e9e8:

    # me "Кстати, насколько? Она отказалась от любого предложения..."
    me "顺便问一句，有多听话？她拒绝了所有的提议……"

# game/a12/4cassbass.rpy:870
translate english cassbass_breake_34fefa29:

    # fake_spy "От любого. Сказала, что не будет мстить ни тебе, ни Императору."
    fake_spy "所有。说她不会报复你，也不会报复皇帝。"

# game/a12/4cassbass.rpy:871
translate english cassbass_breake_aed03737:

    # cass "Если бы я знала, что устроил, я бы согласилась. С удовольствием провернула кинжал у тебя в горле."
    cass "早知道是你在背后搞鬼，我就答应了。我多想把匕首刺进你喉咙里。"

# game/a12/4cassbass.rpy:872
translate english cassbass_breake_9f6a1d64:

    # me "А вот так говорить не стоит."
    me "这么说可不太好。"

# game/a12/4cassbass.rpy:873
translate english cassbass_breake_24e2be64:

    # cass "Пошел нахуй!"
    cass "去你妈的！"

# game/a12/4cassbass.rpy:874
translate english cassbass_breake_8628a0cb:

    # me "Ты показала, что ты хороший раб. Сбежала - но рабы часто сбегают, главное, что ты не захотела вредить своему хозяину."
    me "你证明了你是个好奴隶。你逃跑了——但奴隶常逃跑，重要的是，你没想伤害你的主人。"

# game/a12/4cassbass.rpy:875
translate english cassbass_breake_208aa34b:

    # cass "Я передумала! Дай мне кинжал и я тебе выколю глаза."
    cass "我改主意了！给我一把匕首，看我不挖出你的眼睛。"

# game/a12/4cassbass.rpy:876
translate english cassbass_breake_43854bd8:

    # me "Все еще буйная. Удивительно."
    me "还是这么桀骜不驯。真叫人惊讶。"

# game/a12/4cassbass.rpy:877
translate english cassbass_breake_bc24ed0d:

    # cass "Ну и что ты сделаешь? Отправишь меня в подземелье еще на месяц?"
    cass "好吧，你想怎么办？把我再扔回地牢关一个月？"

# game/a12/4cassbass.rpy:878
translate english cassbass_breake_935c9f7b:

    # me "Нет. С этим мы закончили. Для раба ты уже достаточно безопасна, но для слуги еще слишком строптива. Думаю время для перевоспитания."
    me "不。地牢那一段已经结束了。作为一个奴隶，你已经够安全了，但作为一个仆人，你还太倔强。我想是时候进行再教育了。"

# game/a12/4cassbass.rpy:879
translate english cassbass_breake_db1fa2c5:

    # cass "Что ты несешь, ублюдок?"
    cass "你在说什么鬼话，你这杂种？"

# game/a12/4cassbass.rpy:880
translate english cassbass_breake_f56ac334:

    # me "Сир Сеймур?"
    me "西摩尔爵士？"

# game/a12/4cassbass.rpy:881
translate english cassbass_breake_665cc61c:

    # fake_spy "Давно пора."
    fake_spy "早就该来了。"

# game/a12/4cassbass.rpy:883
translate english cassbass_breake_56eba64b:

    # cass "Сука!"
    cass "贱人！"

# game/a12/4cassbass.rpy:884
translate english cassbass_breake_8f6b993d:

    # woman "{size=-6}Вставай.{/size}"
    woman "{size=-6}起来。{/size}"

# game/a12/4cassbass.rpy:885
translate english cassbass_breake_74306baa:

    # woman "{size=-4}Вставай, говорю.{/size}"
    woman "{size=-4}起来，我叫你起来。{/size}"

# game/a12/4cassbass.rpy:886
translate english cassbass_breake_da50dc1f:

    # woman "{size=-2}Не притворяйся, что спишь.{/size}"
    woman "{size=-2}别装睡了。{/size}"

# game/a12/4cassbass.rpy:888
translate english cassbass_breake_e8e79711:

    # cass "Что..."
    cass "什么……"

# game/a12/4cassbass.rpy:889
translate english cassbass_breake_275bb8fe:

    # woman "Ты два дня провалялась в кровати. Думаешь хоть кто-то из слуг может себе это позволить?"
    woman "你在床上躺了两天了。你以为哪个仆人能这么自在？"

# game/a12/4cassbass.rpy:890
translate english cassbass_breake_bfcc9ad0:

    # cass "Голова..."
    cass "头……"

# game/a12/4cassbass.rpy:891
translate english cassbass_breake_80e8af92:

    # woman "Голова болит? Встань на ноги и пройдет."
    woman "头疼？站起来走走就好了。"

# game/a12/4cassbass.rpy:892
translate english cassbass_breake_651ccc28_3:

    # cass "..."
    cass "..."

# game/a12/4cassbass.rpy:893
translate english cassbass_breake_4bd64f3d:

    # woman "Выглядишь здоровой как по мне."
    woman "照我看，你看起来健康得很。"

# game/a12/4cassbass.rpy:894
translate english cassbass_breake_7e7ba657:

    # cass "Я в темнице?"
    cass "我是在地牢吗？"

# game/a12/4cassbass.rpy:895
translate english cassbass_breake_6f33d8a0:

    # woman "Здесь темно?"
    woman "这儿黑吗？"

# game/a12/4cassbass.rpy:896
translate english cassbass_breake_4c606f26:

    # cass "Нет... я не в тюрьме?"
    cass "不黑……我不在监狱？"

# game/a12/4cassbass.rpy:898
translate english cassbass_breake_a4c922aa:

    # woman "Хуже. Ты на кухне."
    woman "更糟。你在厨房。"

# game/a12/4cassbass.rpy:899
translate english cassbass_breake_63b87047:

    # cass "Что... кто ты?"
    cass "什么……你是谁？"

# game/a12/4cassbass.rpy:900
translate english cassbass_breake_ec56348d:

    # melissa "Меня зовут Мелисса."
    melissa "我叫梅丽莎。"

# game/a12/4cassbass.rpy:901
translate english cassbass_breake_abd45132:

    # cass "Мне это имя ничего не говорит."
    cass "这名字对我没意义。"

# game/a12/4cassbass.rpy:902
translate english cassbass_breake_ef9593b6:

    # melissa "И не должно. У меня нет титула, так что у меня просто имя. Оно ничего не говорит, кроме того, как ты будешь ко мне обращаться."
    melissa "本来就没意义。我没有头衔，所以我就叫个名字。除了你要怎么称呼我之外，这名字毫无意义。"

# game/a12/4cassbass.rpy:903
translate english cassbass_breake_651ccc28_4:

    # cass "..."
    cass "..."

# game/a12/4cassbass.rpy:904
translate english cassbass_breake_bcfcc36e:

    # melissa "Впрочем если титул это обозначение иерархии - можешь называть меня королевой, мне насрать. Главное - я тобой командую."
    melissa "不过，如果头衔代表等级，你可以叫我女王，我他妈不在乎。重要的是，我管着你。"

# game/a12/4cassbass.rpy:905
translate english cassbass_breake_07b6ad76:

    # cass "Командуешь."
    cass "你管着我。"

# game/a12/4cassbass.rpy:906
translate english cassbass_breake_f424c66a:

    # melissa "Да. Вставай."
    melissa "是的。起来。"

# game/a12/4cassbass.rpy:907
translate english cassbass_breake_6188efe2:

    # cass "Ладно..."
    cass "好吧……"

# game/a12/4cassbass.rpy:909
translate english cassbass_breake_a6bc104b:

    # melissa "Каждый день распорядок действий на кухне меняется в зависимости от того, что господа в замке захотят поесть."
    melissa "厨房的每日工作安排，会随着老爷们在城堡里想吃什么而变。"

# game/a12/4cassbass.rpy:910
translate english cassbass_breake_651ccc28_5:

    # cass "..."
    cass "..."

# game/a12/4cassbass.rpy:911
translate english cassbass_breake_6def91b2:

    # melissa "Но каждое утро одинаковое. Утром один из слуг подготавливает приправы и другие ингредиенты, которые можно приготовить на день заранее и они не потеряют вкусовых свойств."
    melissa "但每天早上都一样。早上，会有一个仆人提前准备好香料和其他食材，这些可以提前一天做好，且不失风味。"

# game/a12/4cassbass.rpy:912
translate english cassbass_breake_c97bf3a2:

    # cass "Эм..."
    cass "呃……"

# game/a12/4cassbass.rpy:913
translate english cassbass_breake_16953c57:

    # melissa "Утренним слугой будешь ты. Вот твое рабочее место. Как пользоваться ступой знаешь?"
    melissa "早上的活就归你干。这是你的工作台。会用杵吗？"

# game/a12/4cassbass.rpy:914
translate english cassbass_breake_e65e3069:

    # cass "Наверное..."
    cass "大概会……"

# game/a12/4cassbass.rpy:915
translate english cassbass_breake_6f06c418:

    # melissa "Замечательно. Зелень будешь щипать на мелкие кусочки, хлеб рвать на крошки. Будешь хорошо справляться - дадим тебе нож."
    melissa "非常好。青菜要撕成小片，面包要掰成碎末。做得好，我们就给你用刀。"

# game/a12/4cassbass.rpy:916
translate english cassbass_breake_403d42fb:

    # cass "Хорошо справляться?"
    cass "做得好？"

# game/a12/4cassbass.rpy:917
translate english cassbass_breake_a9985d61:

    # melissa "Цедру лимона будешь тереть на терке."
    melissa "柠檬皮用擦板擦成丝。"

# game/a12/4cassbass.rpy:918
translate english cassbass_breake_ecc8c0cb:

    # cass "Слушай, Мелисса..."
    cass "听着，梅丽莎……"

# game/a12/4cassbass.rpy:919
translate english cassbass_breake_3cd47b2c:

    # melissa "Когда закончишь с этим, скажешь мне - я принесу еще. Если кто-то захочет десерт прямо с утра, будешь взбивать сливки."
    melissa "做完这些告诉我，我再给你拿别的来。如果有人一大早就想吃甜点，你就得打奶油。"

# game/a12/4cassbass.rpy:920
translate english cassbass_breake_ee8c073c:

    # cass "Я ничего не понимаю..."
    cass "我什么都不明白……"

# game/a12/4cassbass.rpy:923
translate english cassbass_breake_7fa39f05:

    # melissa "Соберись мать твою!"
    melissa "给我打起精神，操！"

# game/a12/4cassbass.rpy:924
translate english cassbass_breake_c4a29347:

    # cass "Ай!"
    cass "啊！"

# game/a12/4cassbass.rpy:925
translate english cassbass_breake_4dbce769:

    # melissa "Я не собираюсь объяснять тебе все несколько раз."
    melissa "我不会跟你解释好几遍。"

# game/a12/4cassbass.rpy:927
translate english cassbass_breake_b7c0d9d9:

    # cass "Какого хрена..."
    cass "搞什么鬼……"

# game/a12/4cassbass.rpy:928
translate english cassbass_breake_76e5cd75:

    # melissa "Ты все запомнила?"
    melissa "你都记住了吗？"

# game/a12/4cassbass.rpy:929
translate english cassbass_breake_651ccc28_6:

    # cass "..."
    cass "..."

# game/a12/4cassbass.rpy:930
translate english cassbass_breake_5a4d1700:

    # melissa "Если что-то непонятно - спрашивай сейчас."
    melissa "要是有不懂的，现在就问。"

# game/a12/4cassbass.rpy:931
translate english cassbass_breake_2c6cab11:

    # cass "Почему сейчас?"
    cass "为什么是现在？"

# game/a12/4cassbass.rpy:932
translate english cassbass_breake_7ebdfb13:

    # melissa "Потому что если ты спросишь потом, когда на это не будет времени - я тебя выпорю."
    melissa "因为如果你之后再问，等忙起来没时间回答的时候，我就抽你。"

# game/a12/4cassbass.rpy:933
translate english cassbass_breake_7beeb5bc:

    # cass "Выпорешь?"
    cass "抽我？"

# game/a12/4cassbass.rpy:934
translate english cassbass_breake_e8e41a78:

    # melissa "Да. Сниму твои портки и выпорю. До крови. Будешь ходить по кухне с кровоточащей задницей."
    melissa "对。扒下你的裤子，抽你。抽到见血。让你屁股流着血在厨房里走来走去。"

# game/a12/4cassbass.rpy:935
translate english cassbass_breake_e1681757:

    # cass "Да что ты."
    cass "你试试看。"

# game/a12/4cassbass.rpy:936
translate english cassbass_breake_5c34386e:

    # melissa "Я воспитала не одно поколение слуг, можешь поверить мне на слово."
    melissa "我调教过不止一代仆人了，你最好相信我的话。"

# game/a12/4cassbass.rpy:937
translate english cassbass_breake_58254162:

    # cass "Понятно..."
    cass "明白了……"

# game/a12/4cassbass.rpy:938
translate english cassbass_breake_8807c889:

    # melissa "Так ты запомнила все что должна будешь сделать?"
    melissa "好了，你记住该做什么了吗？"

# game/a12/4cassbass.rpy:939
translate english cassbass_breake_1063baaa:

    # cass "Запомнила... СУКА!"
    cass "记住了……贱人！"

# game/a12/4cassbass.rpy:942
translate english cassbass_breake_e5bd76b9:

    # cass "АРГХ!"
    cass "呃！"

# game/a12/4cassbass.rpy:943
translate english cassbass_breake_1e2f551e:

    # melissa "Далеко собралась?"
    melissa "你想跑哪儿去？"

# game/a12/4cassbass.rpy:944
translate english cassbass_breake_b4b2d8b8:

    # cass "БЛЯДЬ!"
    cass "操！"

# game/a12/4cassbass.rpy:945
translate english cassbass_breake_01332348:

    # melissa "Ты кажется не поняла..."
    melissa "看来你还没明白……"

# game/a12/4cassbass.rpy:947
translate english cassbass_breake_55ca4424:

    # melissa "...этот стол - твое родное место на долгое время. Ты не будешь видеть ничего кроме него, понятно?"
    melissa "……这张桌子，在今后很长一段时间里，就是你的家了。除了它，你什么也看不到，明白吗？"

# game/a12/4cassbass.rpy:948
translate english cassbass_breake_651ccc28_7:

    # cass "..."
    cass "..."

# game/a12/4cassbass.rpy:949
translate english cassbass_breake_81930515:

    # melissa "Час за часом, день за днем, месяц за месяцем."
    melissa "一个小时接一个小时，一天接一天，一个月接一个月。"

# game/a12/4cassbass.rpy:950
translate english cassbass_breake_508ee22b:

    # melissa "Только этот стол и ингредиенты на нем."
    melissa "只有这张桌子，和它上面的食材。"

# game/a12/4cassbass.rpy:951
translate english cassbass_breake_7a2d1878:

    # cass "Я не..."
    cass "我不……"

# game/a12/4cassbass.rpy:952
translate english cassbass_breake_3a82107a:

    # melissa "Ты привыкнешь. Тут очень простые правила, если будешь работать хорошо - будешь вкусно есть, будешь работать плохо - будешь жрать одни объедки."
    melissa "你会习惯的。这里的规矩很简单，活儿干得好，就能吃好的；活儿干得糟，就只配吃泔水。"

# game/a12/4cassbass.rpy:953
translate english cassbass_breake_651ccc28_8:

    # cass "..."
    cass "..."

# game/a12/4cassbass.rpy:954
translate english cassbass_breake_95a97552:

    # melissa "Все то же самое касается сна, гигиены и развлечений. Будешь вести себя совсем плохо - вернешься гнить в подземелье."
    melissa "睡觉、个人卫生和娱乐也都一样。表现太差，就滚回地牢烂掉。"

# game/a12/4cassbass.rpy:955
translate english cassbass_breake_faf19698:

    # melissa "Так что запомни этот стол. Молись богам, проси у них силы для твоих рук и терпения. Потому что все что будет интересовать тебя в ближайшее время, это как быстро ты сможешь измолоть перец."
    melissa "所以，记住这张桌子。向众神祈祷吧，祈求他们赐予你双手和耐心。因为，在接下来的一段时间里，你唯一需要关心的，就是你碾胡椒能碾多快。"

# game/a12/4cassbass.rpy:956
translate english cassbass_breake_651ccc28_9:

    # cass "..."
    cass "..."

# game/a12/4cassbass.rpy:957
translate english cassbass_breake_cd21c7e4:

    # melissa "Этот стол придется полюбить. Эту ступу, терку и ложку. Все это твои лучшие друзья на время твоего воспитания."
    melissa "你必须要爱上这张桌子。这把杵、这把擦板和这把勺子。它们就是你接受教育期间最好的朋友。"

# game/a12/4cassbass.rpy:958
translate english cassbass_breake_1cfea23c:

    # melissa "Ты поняла меня, свинка?"
    melissa "你听明白了吗，你这头小猪？"

# game/a12/4cassbass.rpy:960
translate english cassbass_breake_d287fb41:

    # cass "Я тебе не свинка. Я [cassa]."
    cass "我不是小猪。我是[cassa]。"

# game/a12/4cassbass.rpy:961
translate english cassbass_breake_7b624a68:

    # melissa "[cassa]? Ты ей была. Теперь ты свинка."
    melissa "[cassa]？那是过去式了。现在你是小猪。"

# game/a12/4cassbass.rpy:962
translate english cassbass_breake_091fc310:

    # cass "ИДИ НАХУЙ!"
    cass "去你妈的！"

# game/a12/4cassbass.rpy:963
translate english cassbass_breake_b61bb916:

    # melissa "А вот это зря. Сегодня жрешь объедки."
    melissa "这就不好了。你今天吃泔水。"

# game/a12/4cassbass.rpy:964
translate english cassbass_breake_e0530fb0:

    # cass "Мне насрать, я не стану готовить жратву, ублюдкам из замка."
    cass "我不在乎，我不会给城堡里的混蛋们做吃的。"

# game/a12/4cassbass.rpy:965
translate english cassbass_breake_4d989420:

    # melissa "Будешь. Не сегодня так завтра."
    melissa "你会的。不是今天，就是明天。"

# game/a12/4cassbass.rpy:966
translate english cassbass_breake_c5fbf9b5:

    # cass "Ты меня не заставишь."
    cass "你逼不了我。"

# game/a12/4cassbass.rpy:967
translate english cassbass_breake_cbb72477:

    # melissa "Заставлю."
    melissa "逼得了。"

# game/a12/4cassbass.rpy:968
translate english cassbass_breake_2ba4c3a3:

    # cass "Нет."
    cass "不。"

# game/a12/4cassbass.rpy:969
translate english cassbass_breake_376b28d4:

    # melissa "Я ломала девчонок и покрепче. Пару месяцев и ты будешь украшать пирожные сердечками из взбитых сливок."
    melissa "更倔的姑娘我都治服过。不出几个月，你就会用打发的奶油在蛋糕上挤小爱心了。"

# game/a12/4cassbass.rpy:970
translate english cassbass_breake_86830a82:

    # cass "Никогда!"
    cass "绝不！"

# game/a12/4cassbass.rpy:971
translate english cassbass_breake_fbad324b:

    # melissa "О... 'никогда' это мое любимое слово."
    melissa "哦……“绝不”是我最喜欢的词。"

