    # me "..."
    me "..."

# game/a12/4cassbass.rpy:410
translate english cassbass_green3_651ccc28:

    # cass "..."
    cass "..."

# game/a12/4cassbass.rpy:411
translate english cassbass_green3_cdf3f2df:

    # me "Только кое-кто или..."
    me "只是有人，还是……"

# game/a12/4cassbass.rpy:412
translate english cassbass_green3_235bfce8:

    # cass "Только она."
    cass "只有她。"

# game/a12/4cassbass.rpy:414
translate english cassbass_green3_a7455734:

    # me "Ты убила леди Алейну?"
    me "你杀了Alaina夫人？"

# game/a12/4cassbass.rpy:415
translate english cassbass_green3_9c24fdef:

    # cass "Да. Я солгала. Сказала, что давно хотела с ней поговорить. Пронесла кинжал в рукаве."
    cass "是的。我说了谎。说我一直想和她谈谈。把匕首藏在袖子里带了进去。"

# game/a12/4cassbass.rpy:416
translate english cassbass_green3_4e609c46:

    # me "Ты в крови... ты точно не ранена?"
    me "你身上有血……你真的没受伤？"

# game/a12/4cassbass.rpy:417
translate english cassbass_green3_296cfc68:

    # cass "Нет. Я долго говорила с ней. Делала вид, что ничего не знаю, хотя внутри горел огонь."
    cass "没有。我和她谈了很久。装作什么都不知道，尽管内心在燃烧。"

# game/a12/4cassbass.rpy:418
translate english cassbass_green3_bf3e0682:

    # me "[cass]..."
    me "[cass]..."

# game/a12/4cassbass.rpy:419
translate english cassbass_green3_dde27807:

    # cass "Я хотела вонзить клинок ей в глаза прямо там. Но я сдерживалась. Понимала, что она слишком опасна."
    cass "我当时就想把刀子捅进她的眼睛里。但我忍住了。我知道她太危险了。"

# game/a12/4cassbass.rpy:420
translate english cassbass_green3_d8788b6a:

    # me "И... что случилось?"
    me "然后……发生了什么？"

# game/a12/4cassbass.rpy:421
translate english cassbass_green3_c2647cfd:

    # cass "Я плела ей какую-то чушь. Что хочу убить отца. Что боюсь, что он меня арестует."
    cass "我编了些鬼话。说我想杀了我父亲。说我害怕他会逮捕我。"

# game/a12/4cassbass.rpy:422
translate english cassbass_green3_3820771a_1:

    # me "..."
    me "..."

# game/a12/4cassbass.rpy:423
translate english cassbass_green3_d63635af:

    # cass "Что хочу отомстить ему за мать..."
    cass "说我想为母亲报仇……"

# game/a12/4cassbass.rpy:424
translate english cassbass_green3_abf2a4bf:

    # cass "И потом она улыбнулась. Так... коротко...знаешь. Будто у нее в голове созрел новый план. Как использовать меня. Как направить мою месть против невиновного. Как воспользоваться тем, что она убила мою мать."
    cass "然后她笑了。那么……短暂地……你知道的。就像她脑子里又生出一个新计划。想着怎么利用我。想着怎么把我的仇恨引向一个无辜的人。如何利用她杀害了我母亲这件事。"

# game/a12/4cassbass.rpy:425
translate english cassbass_green3_bf3e0682_1:

    # me "[cass]..."
    me "[cass]..."

# game/a12/4cassbass.rpy:426
translate english cassbass_green3_aa266922:

    # cass "Никакого раскаяния. Даже не тени вины. Я смотрела на ее глаза и там был только расчет. Холодный и практический."
    cass "毫无悔意。甚至没有一丝愧疚。我望着她的眼睛，那里只有算计。冰冷而实际。"

# game/a12/4cassbass.rpy:427
translate english cassbass_green3_9cb98882:

    # cass "[mename]..."
    cass "[mename]..."

# game/a12/4cassbass.rpy:428
