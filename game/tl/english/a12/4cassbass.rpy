# game/a12/4cassbass.rpy:16
translate english cassbass_green_dba4e06b:

    # "Несколько дней спустя."
    "几天以后。"

# game/a12/4cassbass.rpy:17
translate english cassbass_green_fde682ff:

    # me "{i}Эх... как же просто расслабиться после напряженной недели.{/i}"
    me "{i}唉……紧张了一周之后，放松下来是多么简单啊。{/i}"

# game/a12/4cassbass.rpy:18
translate english cassbass_green_d59c81e8:

    # me "{i}Встречи, приемы, советы....{/i}"
    me "{i}会议、接见、御前会议……{/i}"

# game/a12/4cassbass.rpy:19
translate english cassbass_green_8a55a94d:

    # me "{i}Фух... а ведь это еще не кончилось. Если бы я знал что за присоединением Запада последует столько формальностей.{/i}"
    me "{i}呼……而这还没结束呢。要是我早知道吞并西部会带来这么多繁文缛节。{/i}"

# game/a12/4cassbass.rpy:20
translate english cassbass_green_5c76dbe7:

    # me "{i}...{/i}"
    me "{i}...{/i}"

# game/a12/4cassbass.rpy:21
translate english cassbass_green_dc065bf8:

    # me "{i}Я бы все равно его присоединил.{/i}"
    me "{i}我还是会吞并它的。{/i}"

# game/a12/4cassbass.rpy:22
translate english cassbass_green_0022d833:

    # me "{i}Но сейчас это не важно.{/i}"
    me "{i}但眼下这不重要。{/i}"

# game/a12/4cassbass.rpy:23
translate english cassbass_green_dc5a8538:

    # me "{i}Сейчас я отдыхаю и ничего этому не помешает.{/i}"
    me "{i}现在我要休息，没什么能打扰我。{/i}"

# game/a12/4cassbass.rpy:25
translate english cassbass_green_a75927a3:

    # cass "Все отмокаешь?"
    cass "还在泡着呢？"

# game/a12/4cassbass.rpy:26
translate english cassbass_green_1de25d0b:

    # me "...кроме этого."
    me "……除了这个。"

# game/a12/4cassbass.rpy:27
translate english cassbass_green_bb338a8d:

    # cass "Знаешь, как минимум три Императора Золотой Империи умерло в этих купальнях."
    cass "你知道吗，至少有三位黄金帝国的皇帝死在了这间浴池里。"

# game/a12/4cassbass.rpy:28
translate english cassbass_green_3b631fba:

    # me "И что? Никогда больше не мыться?"
    me "那又怎样？难道就永远不洗澡了？"

# game/a12/4cassbass.rpy:29
translate english cassbass_green_272446ea:

    # cass "Ты такой расслабленный и беззащитный. Лежишь тут с закрытыми глазами, так и хочется вонзить тебе кинжал в шею."
    cass "你看起来这么放松，毫无防备。躺在这儿闭着眼，真让人想把匕首刺进你的脖子。"

# game/a12/4cassbass.rpy:30
translate english cassbass_green_3820771a:

    # me "..."
    me "..."

# game/a12/4cassbass.rpy:31
translate english cassbass_green_798b776d:

    # cass "Шутка... наверное."
    cass "开玩笑的……大概吧。"

# game/a12/4cassbass.rpy:32
translate english cassbass_green_eb655f0d:

    # me "[cass]?"
    me "[cass]?"

# game/a12/4cassbass.rpy:33
translate english cassbass_green_c2487b65:

    # cass "Что?"
    cass "什么？"

# game/a12/4cassbass.rpy:34
translate english cassbass_green_cd16a0a7:

    # me "Тебе скучно и ты пришла испортить мне настроение?"
    me "你无聊了，所以来破坏我的心情？"

# game/a12/4cassbass.rpy:36
translate english cassbass_green_aee59ade:

    # cass "Может я просто пришла выпить вина."
    cass "也许我只是来喝杯酒。"

# game/a12/4cassbass.rpy:37
translate english cassbass_green_9753baee:

    # me "В купальнях?"
    me "在浴池里？"

# game/a12/4cassbass.rpy:38
translate english cassbass_green_eef0d107:

    # cass "В купальнях. Мне нужна приятная компания, разве я виновата, что весь остальной дворец набит напыщенными Лордами, знатью и их тупоголовыми женами?"
    cass "在浴池里。我需要愉快的陪伴，难道整个王宫里挤满了傲慢的领主、贵族和他们愚笨的妻子，这是我的错吗？"

# game/a12/4cassbass.rpy:39
translate english cassbass_green_b9348228:

    # me "А я значит не такой?"
    me "那我就不一样了？"

# game/a12/4cassbass.rpy:40
translate english cassbass_green_939be263:

    # cass "Конечно нет, иначе я бы не сделала тебя Императором."
    cass "当然不一样，否则我也不会选你做皇帝。"

# game/a12/4cassbass.rpy:41
translate english cassbass_green_61b8a5ff:

    # me "Эм... спасибо?"
    me "呃……谢谢？"

# game/a12/4cassbass.rpy:42
translate english cassbass_green_46e339dc:

    # cass "Не благодари, твоей заслуги здесь нет, тебе просто досталась хорошая кровь."
    cass "不用谢，这不是你的功劳，你只是继承了好血统罢了。"

# game/a12/4cassbass.rpy:43
translate english cassbass_green_3820771a_1:

    # me "..."
    me "..."

# game/a12/4cassbass.rpy:44
translate english cassbass_green_4559a097:

    # cass "Династическими браками можно вывести насколько захочешь хорошую кровь. Ты просто качественный плод, сорванный с дерева селекционером."
    cass "通过联姻，想要多好的血统就能培养出多好的血统。你不过是从育种者树上摘下的一个优良果实。"

# game/a12/4cassbass.rpy:45
translate english cassbass_green_3f9cfd06:

    # me "А селекционер это ты?"
    me "那个育种者就是你？"

# game/a12/4cassbass.rpy:46
translate english cassbass_green_c8ffb70b:

    # cass "...может быть."
    cass "……也许是吧。"

# game/a12/4cassbass.rpy:47
translate english cassbass_green_1dd53550:

    # me "Тогда ты опоздала. Жену я себе выбрал сам. Кстати о женитьбе..."
    me "那你来晚了。我的妻子是我自己选的。说到结婚……"

# game/a12/4cassbass.rpy:49
translate english cassbass_green_eb797a1b:

    # cass "Да?"
    cass "嗯？"

# game/a12/4cassbass.rpy:50
translate english cassbass_green_0186c8da:

    # me "Этот Дюран..."
    me "那个Duran……"

# game/a12/4cassbass.rpy:51
translate english cassbass_green_449ff230:

    # cass "Что с ним?"
    cass "他怎么了？"

# game/a12/4cassbass.rpy:52
translate english cassbass_green_a6f7a3fd:

    # me "Там, в зале мне показалось, что он хочет попросить твоей руки."
    me "在大厅里，我觉得他想向你求婚。"

# game/a12/4cassbass.rpy:53
translate english cassbass_green_625cb25c:

    # cass "Может быть, а что? Ревнуешь?"
    cass "也许吧，怎么了？你吃醋了？"

# game/a12/4cassbass.rpy:54
translate english cassbass_green_a21761dc:

    # me "Он выглядел... крайне лояльным тебе. Так что подозреваю, это предложение не от чистого сердца так сказать."
    me "他看起来……对你极其忠诚。所以我怀疑，这个求婚，怎么说呢，并非发自真心。"

# game/a12/4cassbass.rpy:55
translate english cassbass_green_44173f81:

    # cass "Хочешь сказать он на самом деле меня не любит?"
    cass "你是想说，他不是真的爱我？"

# game/a12/4cassbass.rpy:56
translate english cassbass_green_8911232e:

    # me "Хочу сказать, что это ты его подговорила предложить тебе себя в качестве супруга."
    me "我是想说，是你怂恿他，让他把自己当作配偶献给您的。"

# game/a12/4cassbass.rpy:57
translate english cassbass_green_4b48e866:

    # cass "Какой ты проницательный."
    cass "你还真是洞察入微。"

# game/a12/4cassbass.rpy:58
translate english cassbass_green_227a65dd:

    # me "Ну и... зачем?"
    me "那么……为什么？"

# game/a12/4cassbass.rpy:59
translate english cassbass_green_7e25bd5e:

    # cass "Может я просто устала быть одной, пока все вокруг женятся и рожают детей."
    cass "也许我只是厌倦了独自一人，看着周围所有人结婚生子。"

# game/a12/4cassbass.rpy:60
translate english cassbass_green_3820771a_2:

    # me "..."
    me "..."

# game/a12/4cassbass.rpy:62
translate english cassbass_green_c2487b65_1:

    # cass "Что?"
    cass "什么？"

# game/a12/4cassbass.rpy:63
translate english cassbass_green_4c8654a3:

    # me "Я правда должен в это поверить?"
    me "我真的该相信这个？"

# game/a12/4cassbass.rpy:64
translate english cassbass_green_01d9e4ac:

    # cass "Считаешь я не могу влюбиться?"
    cass "你觉得我不可能爱上别人？"

# game/a12/4cassbass.rpy:65
translate english cassbass_green_3820771a_3:

    # me "..."
    me "..."

# game/a12/4cassbass.rpy:66
translate english cassbass_green_9a665e46:

    # cass "У тебя странное обо мне представление."
    cass "你对我的看法真奇怪。"

# game/a12/4cassbass.rpy:67
translate english cassbass_green_c0cba1a3:

    # me "Я знаю тебя лучше, чем ты думаешь. В чем причина на самом деле?"
    me "我比你想象的更了解你。真正的原因是什么？"

# game/a12/4cassbass.rpy:68
translate english cassbass_green_a1681119:

    # cass "Ну..."
    cass "唔……"

# game/a12/4cassbass.rpy:69
translate english cassbass_green_8bcc5de2:

    # me "Давай, рассказывай."
    me "说吧，告诉我。"

# game/a12/4cassbass.rpy:70
translate english cassbass_green_ba80c207:

    # cass "Просто политика, знаешь ли. Раз уж Лорд Дюран теперь представляет и защищает интересы Империи на Западе..."
    cass "只是政治，你知道的。既然Duran领主现在代表并保护帝国在西部的利益……"

# game/a12/4cassbass.rpy:71
translate english cassbass_green_7990c6dc:

    # me "За ним нужен дополнительный присмотр? Для этого не обязательно становиться ему женой."
    me "需要对他进行额外的监督？要达成这个目的，不一定非要成为他的妻子。"

# game/a12/4cassbass.rpy:72
translate english cassbass_green_bf833569:

    # cass "Не обязательно. Но вдруг он... заболеет или еще чего похуже?"
    cass "不一定。但万一他……病了，或者更糟怎么办？"

# game/a12/4cassbass.rpy:73
translate english cassbass_green_3820771a_4:

    # me "..."
    me "..."

# game/a12/4cassbass.rpy:74
translate english cassbass_green_c1b1faeb:

    # cass "К тому же Западные Лорды довольно свободолюбивы, они и так не восторге что ими будет управлять человек из Черной Косы."
    cass "况且西部领主们相当崇尚自由，他们对由一个黑辫子的人来统治他们本就不满。"

# game/a12/4cassbass.rpy:75
translate english cassbass_green_864d5728:

    # cass "А если они будут чувствовать, что его решения несамостоятельны, что ими просто опосредованно руководят из Столицы - это подорвет авторитет Лорда-протектора."
    cass "如果他们觉得他的决定并非出自他本人，觉得他只是间接地接受首都的遥控指挥，这会损害护国公大人的权威。"

# game/a12/4cassbass.rpy:76
translate english cassbass_green_7b309e9a:

    # me "А если им будет руководить его жена..."
    me "但如果是由他的妻子来指导他……"

# game/a12/4cassbass.rpy:77
translate english cassbass_green_e2b66fe1:

    # cass "Я буду просто давать ему советы. Это формальность. Я думала ты уже привык к этому слову."
    cass "我只会给他建议。这只是走个形式。我以为你已经习惯这个词了。"

# game/a12/4cassbass.rpy:78
translate english cassbass_green_5c000d81:

    # me "Если я к нему привык, это еще не значит, что оно мне по нраву."
    me "就算我习惯了，也不代表我喜欢。"

# game/a12/4cassbass.rpy:79
translate english cassbass_green_d0d34709:

    # cass "Слушай, может поговорим... в более уединенном месте? Не люблю обсуждать государственные дела в местах, где слуги греют уши."
    cass "听着，我们能……换个更僻静的地方谈吗？我不喜欢在仆人竖着耳朵听的地方讨论国事。"

# game/a12/4cassbass.rpy:80
translate english cassbass_green_71d3b8c8:

    # me "Хорошо."
    me "好。"

# game/a12/4cassbass.rpy:82
translate english cassbass_green_2c7ed201:

    # "10 минут спустя."
    "十分钟以后."

# game/a12/4cassbass.rpy:83
translate english cassbass_green_f8f8d358:

    # cass "...мой любимый обеденый зал."
    cass "……我最喜欢的宴会厅。"

# game/a12/4cassbass.rpy:84
translate english cassbass_green_bf79c523:

    # me "Потому что он закрытый?"
    me "因为它封闭？"

# game/a12/4cassbass.rpy:85
translate english cassbass_green_fc0768b3:

    # cass "Потому что тут две двери до коридора, стены достаточно толстые, чтобы через них ничего не было слышно, а со стороны окон обрыв до самой реки."
    cass "因为这里距离走廊有两道门，墙壁足够厚，声音传不出去，而窗户那边是直通河流的悬崖。"

# game/a12/4cassbass.rpy:86
translate english cassbass_green_5e0864ff:

    # me "Так здесь ты взращиваешь свои злодейские планы?"
    me "所以你那些邪恶计划就是在这里酝酿的？"

# game/a12/4cassbass.rpy:87
translate english cassbass_green_afe90e2f:

    # cass "Нет, их я взращиваю у себя в голове, тут я их реализую."
    cass "不，那些我在脑子里酝酿，这里是我执行它们的地方。"

# game/a12/4cassbass.rpy:88
translate english cassbass_green_604a6da2:

    # me "А эти... стражники всюду с тобой ходят?"
    me "这些……卫兵，一直跟着你吗？"

# game/a12/4cassbass.rpy:89
translate english cassbass_green_7fa6fb7b:

    # cass "Времена нынче опасные, весь Дворец в каких-то проходимцах."
    cass "现在时局危险，整个王宫里到处都是形迹可疑的家伙。"

# game/a12/4cassbass.rpy:90
translate english cassbass_green_6250666e:

    # me "Часть уже уехала."
    me "一部分已经离开了。"

# game/a12/4cassbass.rpy:91
translate english cassbass_green_bf384752:

    # cass "Но часть все еще осталась."
    cass "但还有一些留了下来。"

# game/a12/4cassbass.rpy:92
translate english cassbass_green_3820771a_5:

    # me "..."
    me "..."

# game/a12/4cassbass.rpy:93
translate english cassbass_green_c233c2e7:

    # cass "Так на чем мы остановились в купальнях?"
    cass "那么，我们在浴池里说到哪儿了？"

# game/a12/4cassbass.rpy:94
translate english cassbass_green_60358084:

    # me "Эм..."
    me "呃……"

# game/a12/4cassbass.rpy:96
translate english cassbass_green_61ae508b:

    # cass "Вроде на твоей неприкрытой ревности."
    cass "好像是说你毫不掩饰的嫉妒心。"

# game/a12/4cassbass.rpy:97
translate english cassbass_green_67c5f2d1:

    # me "Чего?"
    me "什么？"

# game/a12/4cassbass.rpy:98
translate english cassbass_green_5c98f59c:

    # cass "Ну признайся. Тебя волнует не политика в этом вопросе, а то что твоя любимая старшая сестренка будет делить ложе с другим мужчиной."
    cass "承认吧。你在这件事上关心的不是政治，而是你最爱的姐姐要和另一个男人同床共枕了。"

# game/a12/4cassbass.rpy:99
translate english cassbass_green_4046a794:

    # me "Ложе?"
    me "同床共枕？"

# game/a12/4cassbass.rpy:100
translate english cassbass_green_bce8904f:

    # cass "Ты бы видел сейчас свое лицо."
    cass "你该看看你现在的表情。"

# game/a12/4cassbass.rpy:101
translate english cassbass_green_df997ffe:

    # me "Нет...я просто..."
    me "不……我只是……"

# game/a12/4cassbass.rpy:102
translate english cassbass_green_a682ef56:

    # cass "Расслабься. Это просто политический союз, ничего более. Просто жена имеет куда больший доступ к мужу и контроль над ним. Жена эффективнее любого имперского инспектора."
    cass "放轻松。这只是一个政治联盟，仅此而已。只是妻子对丈夫的控制和影响力要大得多。妻子比任何帝国监察官都更有效。"

# game/a12/4cassbass.rpy:103
translate english cassbass_green_5382243f:

    # me "И он... не против?"
    me "那他……不反对？"

# game/a12/4cassbass.rpy:104
translate english cassbass_green_80f8d62d:

    # cass "Мы привели его род к управлению огромным регионом, это небольшая плата, не думаешь?"
    cass "我们让他的家族统治了一个巨大的地区，这只是微小的代价，你不觉得吗？"

# game/a12/4cassbass.rpy:105
translate english cassbass_green_dd4be575:

    # me "Его послушность... может измениться со временем."
    me "他的顺从……可能会随着时间改变。"

# game/a12/4cassbass.rpy:106
translate english cassbass_green_9d583b8e:

    # cass "Наверняка изменится. Для этого я и буду рядом."
    cass "肯定会改变。正因如此，我才要在他身边。"

# game/a12/4cassbass.rpy:107
translate english cassbass_green_4bed34f1:

    # me "Ты будешь жить на Западе?"
    me "你会住在西部？"

# game/a12/4cassbass.rpy:108
translate english cassbass_green_7d800572:

    # cass "Не обязательно. Регулярно навещать моего... супруга будет достаточным."
    cass "不一定。定期去探望我的……配偶就足够了。"

# game/a12/4cassbass.rpy:109
translate english cassbass_green_f4cf16f8:

    # me "Понятно. А что насчет других Лордов Запада?"
    me "明白了。那西部的其他领主呢？"

# game/a12/4cassbass.rpy:110
translate english cassbass_green_649121e5:

    # cass "А что с ними?"
    cass "他们怎么了？"

# game/a12/4cassbass.rpy:111
translate english cassbass_green_08bd1a64:

    # me "Они могут догадаться, что ты просто... дополнительный гарант его лояльности."
    me "他们可能会猜到，你不过是他忠诚的……额外保障。"

# game/a12/4cassbass.rpy:113
translate english cassbass_green_21cc5373:

    # cass "И что? Все формальности будет соблюдены. Это династический брак. К тому же я сама наполовину с Запада. Я буду абсолютно легитимной женой."
    cass "那又如何？所有形式上的手续都会办妥。这是联姻。况且我自己也有一半西部血统。我会是一个完全合法的妻子。"

# game/a12/4cassbass.rpy:114
translate english cassbass_green_1881bfbf:

    # me "Женой-имперским инспектором."
    me "一个身为帝国监察官的妻子。"

# game/a12/4cassbass.rpy:115
translate english cassbass_green_55922ab2:

    # cass "Все верно. По-моему, это довольно разумное решение, ты так не считаешь."
    cass "完全正确。依我看，这是个相当合理的决定，你不觉得吗？"

# game/a12/4cassbass.rpy:116
translate english cassbass_green_58f7af09:

    # me "Разумное?"
    me "合理？"

# game/a12/4cassbass.rpy:117
translate english cassbass_green_1ba11775:

    # cass "Полезное. Для Империи полезное. Лорд-Протектор над Западом будет всего в одном шаге от тебя."
    cass "有用。对帝国有用。西部的护国公将与你仅一步之遥。"

# game/a12/4cassbass.rpy:118
translate english cassbass_green_a734c854:

    # me "В одной старшей сестре."
    me "是隔着一个姐姐。"

# game/a12/4cassbass.rpy:119
translate english cassbass_green_969c3ce2:

    # cass "Все так. Мы должны заботиться об Империи, а это сделает коммуникацию на высшем уровне... удобнее."
    cass "正是如此。我们必须为帝国着想，而这会让最高层面的沟通……更方便。"

# game/a12/4cassbass.rpy:120
translate english cassbass_green_cb9f1a4a:

    # me "Контроль. Ты любишь это, да?"
    me "控制。你喜欢这个，对吗？"

# game/a12/4cassbass.rpy:121
translate english cassbass_green_34a4cb36:

    # cass "Ты будущий Император. Ты полюбишь это тоже или закончишь как Красный Император."
    cass "你是未来的皇帝。你也会喜欢上它的，否则你的下场就会和红皇帝一样。"

# game/a12/4cassbass.rpy:122
translate english cassbass_green_8c5fb818:

    # me "Кажется он тоже был помешан на контроле."
    me "我觉得他也痴迷于控制。"

# game/a12/4cassbass.rpy:123
translate english cassbass_green_d62eebd1:

    # cass "Он был помешан на казнях несогласных. Я предлагаю куда более тонкие решения."
    cass "他痴迷的是处决异见者。我提出的方案要精巧得多。"

# game/a12/4cassbass.rpy:124
translate english cassbass_green_3820771a_6:

    # me "..."
    me "..."

# game/a12/4cassbass.rpy:126
translate english cassbass_green_e4baa456:

    # cass "Надеюсь я смогла удовлетворить твое любопытство."
    cass "希望我满足了你的好奇心。"

# game/a12/4cassbass.rpy:127
translate english cassbass_green_e35a61f3:

    # me "Пожалуй. Ты уходишь?"
    me "算是吧。你要走了？"

# game/a12/4cassbass.rpy:128
translate english cassbass_green_2dfc347b:

    # cass "А у тебя есть еще темы для разговоров?"
    cass "你还有别的话题要谈吗？"

# game/a12/4cassbass.rpy:129
translate english cassbass_green_7ced1328:

    # me "Я думал мы ужинаем."
    me "我以为我们要共进晚餐。"

# game/a12/4cassbass.rpy:130
translate english cassbass_green_db641ecf:

    # cass "Да брось, эти тарелки... просто твоя нелюбимая формальность."
    cass "得了吧，这些盘子……不过是你讨厌的形式主义罢了。"

# game/a12/4cassbass.rpy:131
translate english cassbass_green_7aac953b:

    # me "М, понимаю. Мы не обсуждали контроль над Западом. Мы просто ужинали. И перед кем ты разыгрывала этот маленький спектакль? Перед слугами?"
    me "嗯，懂了。我们没有讨论对西部的控制。我们只是吃了顿晚饭。你这场小小的表演是演给谁看的？仆人吗？"

# game/a12/4cassbass.rpy:132
translate english cassbass_green_e5db5524:

    # cass "[mename], самые придирчивые критики не в зрительном зале, а за кулисами."
    cass "[mename]，最挑剔的评论家可不在观众席上，而是在幕后。"

# game/a12/4cassbass.rpy:133
translate english cassbass_green_6aee989d:

    # me "Как скажешь, [cass]."
    me "随你怎么说，[cass]。"

# game/a12/4cassbass.rpy:134
translate english cassbass_green_f916cdee:

    # cass "До встречи."
    cass "再会。"

# game/a12/4cassbass.rpy:135
translate english cassbass_green_a8080c3f:

    # me "{i}Сейчас наверное самое подоходящее время, что рассказать ей правду.{/i}"
    me "{i}现在或许是最合适的时机，告诉她真相。{/i}"

# game/a12/4cassbass.rpy:136
translate english cassbass_green_5b8dc3c6:

    # cass "Ты на меня как-то странно смотришь. Не хочешь чтобы я уходила?"
    cass "你看我的眼神有点奇怪。不想让我走吗？"

# game/a12/4cassbass.rpy:137
translate english cassbass_green_cb97f8c3:

    # me "{i}Если я действительно хочу обо всем рассказать, я должен сделать это сейчас. Либо не говорить об этом с ней никогда.{/i}"
    me "{i}如果我真的想和盘托出，就必须现在说。否则就永远别跟她提这件事。{/i}"

# game/a12/4cassbass.rpy:142
translate english cassbass_green_f5e81540:

    # me "Да... постой. Я хочу кое о чем рассказать."
    me "嗯……等等。我有件事要告诉你。"

# game/a12/4cassbass.rpy:143
translate english cassbass_green_16039490:

    # cass "О чем?"
    cass "什么事？"

# game/a12/4cassbass.rpy:145
translate english cassbass_green_fc7d3a18:

    # "Пару минут спустя."
    "几分钟以后。"

# game/a12/4cassbass.rpy:146
translate english cassbass_green_7439c246:

    # cass "...я бы не поверила тебе, но не могу представить зачем бы тебе все это выдумывать."
    cass "……我本不敢相信你，但我想不出你有什么理由要编造这一切。"

# game/a12/4cassbass.rpy:147
translate english cassbass_green_755645c9:

    # me "Я не лгу тебе. Это все чистая правда. По крайней мере два человека подтвердили мне это."
    me "我没有骗你。这全是千真万确的事实。至少有两个人向我证实了。"

# game/a12/4cassbass.rpy:148
translate english cassbass_green_651ccc28:

    # cass "..."
    cass "..."

# game/a12/4cassbass.rpy:149
translate english cassbass_green_3820771a_7:

    # me "..."
    me "..."

# game/a12/4cassbass.rpy:150
translate english cassbass_green_5a024537:

    # cass "Так он даже мне не отец."
    cass "所以他甚至不是我的父亲。"

# game/a12/4cassbass.rpy:151
translate english cassbass_green_423043a6:

    # me "Да..."
    me "是的……"

# game/a12/4cassbass.rpy:152
translate english cassbass_green_74e77d28:

    # cass "Зачем? Зачем он делал вид, что я его дочь?"
    cass "为什么？他为什么要假装我是他的女儿？"

# game/a12/4cassbass.rpy:153
translate english cassbass_green_d04d5733:

    # me "Разве не понятно?"
    me "难道还不明显吗？"

# game/a12/4cassbass.rpy:154
translate english cassbass_green_3ad56cab:

    # cass "Понятно. Но он... вечно твердил, что его погубит его самое сильное семя. Намекал на меня. Даже перед тем, как был отравлен."
    cass "明显。但他……一直在说，他最强壮的那颗种子会毁了他。暗示的是我。甚至在他被毒害之前也这么说。"

# game/a12/4cassbass.rpy:155
translate english cassbass_green_1255b6e0:

    # cass "А если я не его дочь... Не понимаю. Почему он не арестовал меня, когда пришел в себя?"
    cass "但如果我不是他的女儿……我不明白。他醒过来后，为什么没有逮捕我？"

# game/a12/4cassbass.rpy:156
translate english cassbass_green_37d1bfaf:

    # me "Может потому что тогда бы пришлось арестовать и меня?"
    me "也许因为那样一来，他也得逮捕我？"

# game/a12/4cassbass.rpy:157
translate english cassbass_green_f6255896:

    # cass "Глупость. Он бы с легкостью тебя выгородил, если бы захотел."
    cass "愚蠢。如果他愿意，完全可以轻易把你摘出去。"

# game/a12/4cassbass.rpy:158
translate english cassbass_green_a14f7dec:

    # me "Может он любит тебя, несмотря на то, что ты не его дочь?"
    me "也许他爱你，就算你不是他的女儿？"

# game/a12/4cassbass.rpy:159
translate english cassbass_green_4a0867f2:

    # cass "Ты сам то в это веришь?"
    cass "你自己信吗？"

# game/a12/4cassbass.rpy:160
translate english cassbass_green_e393b9a0:

    # me "Ну... это можно узнать только у него."
    me "嗯……这只有问他本人才知道了。"

# game/a12/4cassbass.rpy:161
translate english cassbass_green_55b67afe:

    # cass "И как ты это себе представляешь? 'Здравствуй, ненастоящий Регис, почему ты не убил меня и не арестовал? Потому что ты любишь меня, как папочка, хотя ты не мой настоящий папочка?'"
    cass "你想让我怎么问？'你好，不是真Regis的Regis，你为什么不杀了我或者逮捕我？是因为你像个老爸一样爱我吗，虽然你不是我真老爸？'"

# game/a12/4cassbass.rpy:162
translate english cassbass_green_d8125eeb:

    # cass "Он всю жизнь смотрел на меня этими глазами... теперь я понимаю почему. Скрытое презрение. Я семя от человека, что предал его и убил его отца."
    cass "他这辈子都用那种眼神看我……现在我明白为什么了。是隐藏的轻蔑。我是那个背叛他、杀了他的父亲的人留下的种子。"

# game/a12/4cassbass.rpy:163
translate english cassbass_green_ab507c6b:

    # me "Этого я не говорил... возможно настоящий Регис не убивал Красного Императора."
    me "我没这么说……也许真Regis没有杀红皇帝。"

# game/a12/4cassbass.rpy:164
translate english cassbass_green_3ce8b046:

    # cass "Зато он обвинил нашего отца... твоего отца в этом. Этого достаточно. Теперь я действительно понимаю, почему он не любил меня. И вдвойне не понимаю, зачем он кидался своими пророчествами в меня, если знал, что я не его дочь."
    cass "但他确实指控了我们的父亲……你的父亲是凶手。这就够了。现在我真正明白，他为什么不爱我了。也加倍不明白，既然他知道我不是他女儿，为什么还要拿他的那些预言来针对我。"

# game/a12/4cassbass.rpy:165
translate english cassbass_green_3820771a_8:

    # me "..."
    me "..."

# game/a12/4cassbass.rpy:169
translate english cassbass_green_e961acd2:

    # cass "А ты! Ты хуже всех!"
    cass "还有你！你最可恶！"

# game/a12/4cassbass.rpy:170
translate english cassbass_green_de5dd677:

    # me "Я?"
    me "我？"

# game/a12/4cassbass.rpy:171
translate english cassbass_green_7d3aa3b9:

    # cass "Ты! Ты знал! Знал, что леди Алейна убила мою мать! И ты просто отпустил ее!"
    cass "你！你早就知道！你知道Alaina夫人杀了我的母亲！而你居然就这么放她走了！"

# game/a12/4cassbass.rpy:172
translate english cassbass_green_296321ba:

    # me "Я в этом не уверен..."
    me "我对此并不确定……"

# game/a12/4cassbass.rpy:173
translate english cassbass_green_12b75482:

    # cass "Да брось! Она единственный ненужный свидетель! Кто еще и зачем мог ее убить?"
    cass "得了吧！她就是唯一那个多余的人证！除了她，还有谁会、又有什么理由杀我母亲？"

# game/a12/4cassbass.rpy:174
translate english cassbass_green_bf3e0682:

    # me "[cass]..."
    me "[cass]..."

# game/a12/4cassbass.rpy:175
translate english cassbass_green_18e60fe1:

    # cass "Что? Она освобождала место для твоей матери, разве не понятно?"
    cass "什么？她在为你母亲腾位子，这还不明白吗？"

# game/a12/4cassbass.rpy:176
translate english cassbass_green_bbc9f7af:

    # me "Я..."
    me "我……"

# game/a12/4cassbass.rpy:177
translate english cassbass_green_ccf139f9:

    # cass "Что? Пожалел ее, потому что без нее никогда не появился бы на свет? Она твоя вторая мамочка?"
    cass "怎么？可怜她，因为没有她，你就不会来到这个世上？她算是你的第二个妈妈？"

# game/a12/4cassbass.rpy:178
translate english cassbass_green_cd5711bc:

    # me "Дело не в этом..."
    me "不是因为这个……"

# game/a12/4cassbass.rpy:179
translate english cassbass_green_207186c7:

    # cass "А в чем, мать твою!? Ты знал, что она сделала! И ты отпустил ее."
    cass "那他妈是因为什么！？你知道她做了什么！你却放走了她。"

# game/a12/4cassbass.rpy:180
translate english cassbass_green_6ce3abb2:

    # me "Я ее изгнал."
    me "我流放了她。"

# game/a12/4cassbass.rpy:181
translate english cassbass_green_c47ebc34:

    # cass "А. Еще лучше. Теперь она никогда не ответит за убийство моей матери!"
    cass "啊。那更好了。现在她永远不用为我母亲的死负责了！"

# game/a12/4cassbass.rpy:182
translate english cassbass_green_a4a346c0:

    # me "Та сама только что говорила, что мы должны думать об Империи."
    me "你自己刚才还在说，我们得为帝国着想。"

# game/a12/4cassbass.rpy:183
translate english cassbass_green_1b67ca90:

    # cass "И как ее жалкая жизнь поможет Империи? Признайся. Ты просто пожалел ее. Ты не мог держать ее при себе, потому что больше не доверял, но ты пожалел ее, потому что ты ее творение."
    cass "她那贱命怎么能帮到帝国？承认吧。你只是可怜她。你不能把她留在身边，因为你不再信任她了，但你可怜她，因为你是她的造物。"

# game/a12/4cassbass.rpy:184
translate english cassbass_green_d5e8cf2e:

    # me "...[cass]."
    me "...[cass]."

# game/a12/4cassbass.rpy:186
translate english cassbass_green_21a30b6a:

    # cass "Да пошел ты, ублюдок."
    cass "去你妈的，你这杂种。"

# game/a12/4cassbass.rpy:187
translate english cassbass_green_7ff13741:

    # me "Я ведь не стал лгать тебе."
    me "我没有对你说谎。"

# game/a12/4cassbass.rpy:188
translate english cassbass_green_d19f7f48:

    # cass "Лучше бы солгал. Теперь я навечно буду жить в мире, где убийца моей матери спокойно дышит."
    cass "你不如说谎。现在我要永远活在一个我母亲的凶手逍遥自在的世界里了。"

# game/a12/4cassbass.rpy:189
translate english cassbass_green_d5e8cf2e_1:

    # me "...[cass]."
    me "...[cass]."

# game/a12/4cassbass.rpy:190
translate english cassbass_green_cb1d5c8f:

    # cass "Иди нахуй, [mename]!"
    cass "滚你妈的，[mename]！"

# game/a12/4cassbass.rpy:191
translate english cassbass_green_c3e87c24:

    # me "{i}...Да уж.{/i}"
    me "{i}……唉。{/i}"

# game/a12/4cassbass.rpy:192
translate english cassbass_green_de6c5ec5:

    # me "{i}Возможно я зря это сделал.{/i}"
    me "{i}也许我不该这么做。{/i}"

# game/a12/4cassbass.rpy:193
translate english cassbass_green_fbd2f961:

    # me "{i}Хотя... чего я еще ожидал?{/i}"
    me "{i}不过……我还能指望什么呢？{/i}"

# game/a12/4cassbass.rpy:194
translate english cassbass_green_0c90e217:

    # me "{i}Может и хорошо, что Леди Алейна в изгнании, а иначе ее жизнь оборвалось бы прямо сейчас.{/i}"
    me "{i}也许Alaina夫人被流放了也好，要不然她的命现在可能就没了。{/i}"

# game/a12/4cassbass.rpy:195
translate english cassbass_green_bc4eaac4:

    # me "{i}...впрочем я уже переживаю за все эльфийские рощи в Долине.{/i}"
    me "{i}……不过，我已经开始为谷地里所有的精灵树林担心了。{/i}"

# game/a12/4cassbass.rpy:196
translate english cassbass_green_086b7ede:

    # me "{i}Поговорю с ней, когда она остынет.{/i}"
    me "{i}等她气消了，我再和她谈谈。{/i}"

# game/a12/4cassbass.rpy:202
translate english cassbass_green_fdaef29e:

    # cass "А леди Алейна?"
    cass "那Alaina夫人呢？"

# game/a12/4cassbass.rpy:203
translate english cassbass_green_1d0533d3:

    # me "Сбежала, когда я поддержал Конрада."
    me "在我支持Conrad的时候就跑了。"

# game/a12/4cassbass.rpy:204
translate english cassbass_green_d3dfb719:

    # cass "Змея сраная. Почувствовала, что ей грозит опасность."
    cass "该死的毒蛇。她感觉到危险逼近了。"

# game/a12/4cassbass.rpy:205
translate english cassbass_green_2edc6114:

    # me "Возможно."
    me "可能吧。"

# game/a12/4cassbass.rpy:206
translate english cassbass_green_17671de3:

    # cass "Тебе... стоило быть аккуратнее."
    cass "你应该……更小心一点。"

# game/a12/4cassbass.rpy:207
translate english cassbass_green_149b3064:

    # me "В каком смысле?"
    me "什么意思？"

# game/a12/4cassbass.rpy:208
translate english cassbass_green_cf8812a5:

    # cass "Надо было усыпить ее бдительность. Сделать вид, что ты на ее стороне."
    cass "你该麻痹她的警惕心。假装站在她那边。"

# game/a12/4cassbass.rpy:209
translate english cassbass_green_4cdcab0a:

    # me "Хочешь сказать я виноват, что она сбежала? Я не был уверен, на что она готова пойти. Эти игры могли дорого мне стоить."
    me "你是说，她跑了是我的错？我不确定她准备做到哪一步。这些把戏差点要了我的命。"

# game/a12/4cassbass.rpy:210
translate english cassbass_green_ec52dd28:

    # cass "Ну да... ты прав. Прости. Просто..."
    cass "好吧……你说得对。抱歉。只是……"

# game/a12/4cassbass.rpy:211
translate english cassbass_green_caaeb35f:

    # me "...просто хочешь отомстить."
    me "……只是你想报仇。"

# game/a12/4cassbass.rpy:212
translate english cassbass_green_b7c8f5f0:

    # cass "Да."
    cass "是。"

# game/a12/4cassbass.rpy:213
translate english cassbass_green_7e7c115b:

    # me "У нас еще будет время это сделать."
    me "我们以后还有时间这么做。"

# game/a12/4cassbass.rpy:214
translate english cassbass_green_b984ce38:

    # cass "Она уже далеко и глубоко в эльфийских рощах."
    cass "她已经远远地躲进精灵树林深处了。"

# game/a12/4cassbass.rpy:215
translate english cassbass_green_775715ca:

    # me "Я чувствую, будто мы еще встретимся."
    me "我有种感觉，我们还会再见面的。"

# game/a12/4cassbass.rpy:216
translate english cassbass_green_8afff3cb:

    # cass "Может быть... может быть... Спасибо, что рассказал мне обо всем этом."
    cass "也许吧……也许吧……谢谢你告诉我这一切。"

# game/a12/4cassbass.rpy:217
translate english cassbass_green_313c27aa:

    # me "Ты должна была знать."
    me "你应该知道真相。"

# game/a12/4cassbass.rpy:218
translate english cassbass_green_a2cf2e38:

    # cass "...мне нужно это обдумать."
    cass "……我需要好好想想。"

# game/a12/4cassbass.rpy:219
translate english cassbass_green_9cd0e45a:

    # me "Конечно, сестренка."
    me "当然，姐姐。"

# game/a12/4cassbass.rpy:220
translate english cassbass_green_0cbab059:

    # cass "Я ведь не... до встречи, [mename]."
    cass "那我就不……再会了，[mename]。"

# game/a12/4cassbass.rpy:225
translate english cassbass_green_6cfd3b1e:

    # cass "Так ты... казнил ее..."
    cass "这么说你……处决了她……"

# game/a12/4cassbass.rpy:226
translate english cassbass_green_7b523d95:

    # me "Нет. Не буду тебе лгать. Я казнил ее не только чтобы восстановить справедливость, она представляла угрозу Золотому Порядку."
    me "不。我不会骗你。我处决她不止是为了伸张正义，她对黄金秩序构成了威胁。"

# game/a12/4cassbass.rpy:227
translate english cassbass_green_651ccc28_1:

    # cass "..."
    cass "..."

# game/a12/4cassbass.rpy:228
translate english cassbass_green_0a375cda:

    # me "Я бы мог доверить это тебе. Но время поджимало. Все случилось в считанные дни. Она действовала непредсказуемо и скрывалась, так что мне пришлось действовать... публично."
    me "我本可以把这事交给你。但时间太紧。所有事情都发生在几天之内。她行事难以预测，又躲了起来，所以我不得不……公开行事。"

# game/a12/4cassbass.rpy:229
translate english cassbass_green_52857a46:

    # cass "Понятно. Так [elin] тоже знали?"
    cass "明白了。那么[elin]也知道？"

# game/a12/4cassbass.rpy:230
translate english cassbass_green_ba3f44f7:

    # me "Только моя мать. [elin] узнала позже, как и ты."
    me "只有我母亲知道。[elin]和你一样，是后来才知道的。"

# game/a12/4cassbass.rpy:231
translate english cassbass_green_651ccc28_2:

    # cass "..."
    cass "..."

# game/a12/4cassbass.rpy:232
translate english cassbass_green_33cf0c08:

    # me "Ты злишься на меня?"
    me "你生我的气吗？"

# game/a12/4cassbass.rpy:233
translate english cassbass_green_4031769c:

    # cass "Нет... нет... ты все сделал правильно. Просто сожалею, что не смогла задушить ее собственными руками."
    cass "不……不……你做得对。只是遗憾没能亲手掐死她。"

# game/a12/4cassbass.rpy:234
translate english cassbass_green_73a2bf43:

    # me "Понимаю."
    me "我理解。"

# game/a12/4cassbass.rpy:235
translate english cassbass_green_c8d4df00:

    # cass "...помнишь где мы гуляли в детстве, когда поднимались в эльфийские руины?"
    cass "……还记得我们小时候爬精灵废墟时常去的那个地方吗？"

# game/a12/4cassbass.rpy:236
translate english cassbass_green_a9c3d3df:

    # me "Пик Ласточки? Помню. А что?"
    me "燕子崖？记得。怎么了？"

# game/a12/4cassbass.rpy:237
translate english cassbass_green_02407047:

    # cass "Встретимся там через полчаса, ладно?"
    cass "半小时后我们在那儿见，好吗？"

# game/a12/4cassbass.rpy:238
translate english cassbass_green_3820771a_9:

    # me "..."
    me "..."

# game/a12/4cassbass.rpy:239
translate english cassbass_green_13ed3ed3:

    # cass "Пожалуйста."
    cass "求你了。"

# game/a12/4cassbass.rpy:240
translate english cassbass_green_01822020:

    # me "Ладно."
    me "好吧。"

# game/a12/4cassbass.rpy:244
translate english cassbass_green_60ca251e:

    # cass "А леди Алейна..."
    cass "那Alaina夫人……"

# game/a12/4cassbass.rpy:245
translate english cassbass_green_6465d3d5:

    # me "Я в этом не уверен."
    me "我对此并不确定。"

# game/a12/4cassbass.rpy:246
translate english cassbass_green_976ebb56:

    # cass "Да брось, моя мать была единственным незаинтересованным свидетелем."
    cass "少来了，我母亲是唯一没有利益关系的证人。"

# game/a12/4cassbass.rpy:247
translate english cassbass_green_0e087f26:

    # me "Отчасти заинтересованным. Она ведь убила твоего отца."
    me "某种程度上她也有利益关系。毕竟她杀了你父亲。"

# game/a12/4cassbass.rpy:248
translate english cassbass_green_1748b87a:

    # cass "Да. Но она явно мешала найти твоему отцу новую жену."
    cass "是的。但她显然妨碍了你父亲寻找新的妻子。"

# game/a12/4cassbass.rpy:249
translate english cassbass_green_3820771a_10:

    # me "..."
    me "..."

# game/a12/4cassbass.rpy:250
translate english cassbass_green_8b31f6c5:

    # cass "Леди Алейна сделала это. Больше некому. Регис... ненастоящий Регис. Твой отец был просто марионеткой."
    cass "是Alaina夫人干的。没有别人了。Regis……那个假Regis。你父亲当时只是个傀儡。"

# game/a12/4cassbass.rpy:251
translate english cassbass_green_3820771a_11:

    # me "..."
    me "..."

# game/a12/4cassbass.rpy:252
translate english cassbass_green_dcdf7f02:

    # cass "Я всю жизнь думала, что он убил ее. А оказывается... что я была полной дурой. О, боги..."
    cass "我一辈子都以为是他杀了我母亲。结果……我完全是个傻瓜。哦，诸神啊……"

# game/a12/4cassbass.rpy:253
translate english cassbass_green_bf3e0682_1:

    # me "[cass]..."
    me "[cass]..."

# game/a12/4cassbass.rpy:254
translate english cassbass_green_651ccc28_3:

    # cass "..."
    cass "..."

# game/a12/4cassbass.rpy:255
translate english cassbass_green_882b8037:

    # me "Ты же..."
    me "你是不是……"

# game/a12/4cassbass.rpy:256
translate english cassbass_green_c8d4df00_1:

    # cass "...помнишь где мы гуляли в детстве, когда поднимались в эльфийские руины?"
    cass "……还记得我们小时候爬精灵废墟时常去的那个地方吗？"

# game/a12/4cassbass.rpy:257
translate english cassbass_green_a9c3d3df_1:

    # me "Пик Ласточки? Помню. А что?"
    me "燕子崖？记得。怎么了？"

# game/a12/4cassbass.rpy:258
translate english cassbass_green_02407047_1:

    # cass "Встретимся там через полчаса, ладно?"
    cass "半小时后我们在那儿见，好吗？"

# game/a12/4cassbass.rpy:259
translate english cassbass_green_3820771a_12:

    # me "..."
    me "..."

# game/a12/4cassbass.rpy:260
translate english cassbass_green_13ed3ed3_1:

    # cass "Пожалуйста."
    cass "求你了。"

# game/a12/4cassbass.rpy:261
translate english cassbass_green_01822020_1:

    # me "Ладно."
    me "好吧。"

# game/a12/4cassbass.rpy:266
translate english cassbass_green_513cf9b3:

    # me "Да так. Ничего. Забудь."
    me "算了。没什么。忘了吧。"

# game/a12/4cassbass.rpy:267
translate english cassbass_green_055fb97e:

    # cass "М? Ты что-то скрываешь?"
    cass "嗯？你在隐瞒什么吗？"

# game/a12/4cassbass.rpy:268
translate english cassbass_green_37b8ce30:

    # me "Нет. Иди уже."
    me "没有。你走吧。"

# game/a12/4cassbass.rpy:269
translate english cassbass_green_b91043e2:

    # cass "Ну смотри мне. Я за тобой приглядываю."
    cass "哼，给我注意点。我会盯着你的。"

# game/a12/4cassbass.rpy:273
translate english cassbass_green2_83749a03:

    # "Полчаса спустя."
    "半个小时以后。"

# game/a12/4cassbass.rpy:274
translate english cassbass_green2_ab473b6b:

    # me "{i}...может действительно стоило дать [cass] возможность отомстить...{/i}"
    me "{i}……或许真的应该给[cass]一个报仇的机会……{/i}"

# game/a12/4cassbass.rpy:275
translate english cassbass_green2_fdd61d4b:

    # me "{i}Хотя...{/i}"
    me "{i}不过……{/i}"

# game/a12/4cassbass.rpy:276
translate english cassbass_green2_e0f2d853:

    # me "{i}Это могло бы закончиться не очень хорошо.{/i}"
    me "{i}结局可能不会太好。{/i}"

# game/a12/4cassbass.rpy:277
translate english cassbass_green2_22e7895d:

    # me "{i}Для леди Алейны точно. Но и [cass] могла бы пострадать.{/i}"
    me "{i}对Alaina夫人来说肯定不好。但[cass]也可能受到伤害。{/i}"

# game/a12/4cassbass.rpy:278
translate english cassbass_green2_a80aaccd:

    # me "{i}Так что я сделал все правильно.{/i}"
    me "{i}所以我做的是正确的。{/i}"

# game/a12/4cassbass.rpy:279
translate english cassbass_green2_79312ace:

    # me "{i}Ее мать отомщена.{/i}"
    me "{i}她母亲的仇报了。{/i}"

# game/a12/4cassbass.rpy:280
translate english cassbass_green2_6b0b48a5:

    # me "{i}И [cass] в полном порядке.{/i}"
    me "{i}而且[cass]安然无恙。{/i}"

# game/a12/4cassbass.rpy:281
translate english cassbass_green2_7f4c3a7d:

    # me "{i}...по крайней мере физически.{/i}"
    me "{i}……至少身体上没事。{/i}"

# game/a12/4cassbass.rpy:283
translate english cassbass_green2_5b7e0eb0:

    # cass "Ты все же пришел."
    cass "你还是来了。"

# game/a12/4cassbass.rpy:284
translate english cassbass_green2_bd7388fb:

    # me "А ты опоздала."
    me "你倒是迟到了。"

# game/a12/4cassbass.rpy:285
translate english cassbass_green2_af612aae:

    # cass "Прости. Давно не была здесь. Забираться на уступы и пробираться через дикий кустарник проще, когда ты ребенок."
    cass "抱歉。很久没来这里了。攀爬岩壁、穿越野生灌木丛，还是小孩子的时候更容易些。"

# game/a12/4cassbass.rpy:286
translate english cassbass_green2_d9f575d1:

    # me "С этим трудно поспорить."
    me "这倒是没法反驳。"

# game/a12/4cassbass.rpy:287
translate english cassbass_green2_d88b29d7:

    # cass "Я обдумала... все что ты сказал."
    cass "我仔细想了想……你所说的一切。"

# game/a12/4cassbass.rpy:288
translate english cassbass_green2_f95c9fc9:

    # me "И?"
    me "然后呢？"

# game/a12/4cassbass.rpy:289
translate english cassbass_green2_c473b633:

    # cass "Ну... знаешь это действительно много меняет."
    cass "嗯……你知道，这确实改变了很多事。"

# game/a12/4cassbass.rpy:290
translate english cassbass_green2_e473fa2f:

    # me "Например?"
    me "比如？"

# game/a12/4cassbass.rpy:291
translate english cassbass_green2_d9d8333a:

    # cass "Знай я это раньше... я бы не стала убивать отца."
    cass "要是我早点知道……我就不会去杀父亲了。"

# game/a12/4cassbass.rpy:292
translate english cassbass_green2_d7c73c66:

    # me "Он жив."
    me "他还活着。"

# game/a12/4cassbass.rpy:293
translate english cassbass_green2_0f01ecf8:

    # cass "Ты понял о чем я."
    cass "你知道我的意思。"

# game/a12/4cassbass.rpy:295
translate english cassbass_green2_21b9342d:

    # me "Я думал ты делаешь это из-за заботы об Империи."
    me "我以为你那么做是出于对帝国的关心。"

# game/a12/4cassbass.rpy:296
translate english cassbass_green2_94797018:

    # cass "Так и было. Но... недовольство политикой отца... Региса... даже не знаю как его сейчас называть. Недовольство неэффективным управлением отца это одно... А... как бы объяснить."
    cass "确实如此。但是……对父亲……Regis……我都不知道该叫他什么了。对父亲低效统治的不满是一回事……而……怎么说呢。"

# game/a12/4cassbass.rpy:297
translate english cassbass_green2_81863d12:

    # cass "Знаешь, будто сера, что отравляет воздух в шахте. Ее становится все больше и больше, но взрыва не будет, пока не будет зажжен огонь. Нужен катализатор."
    cass "你知道吗，就像矿井里污染空气的硫磺。它越积越多，但没有明火就不会爆炸。需要催化剂。"

# game/a12/4cassbass.rpy:298
translate english cassbass_green2_dfdafab1:

    # me "Я думал ты всегда думала, что отец убил твою мать."
    me "我以为你一直认为父亲杀了你母亲。"

# game/a12/4cassbass.rpy:299
translate english cassbass_green2_4e080b65:

    # cass "Я подозревала. Но Леди Алейна..."
    cass "我怀疑过。但Alaina夫人……"

# game/a12/4cassbass.rpy:300
translate english cassbass_green2_7c6510a1:

    # me "Предоставила доказательства?"
    me "提供了证据？"

# game/a12/4cassbass.rpy:301
translate english cassbass_green2_4e131b5b:

    # cass "Да. Теперь то я знаю, что просто была пешкой в ее игре."
    cass "是的。现在我知道了，我那时只是她棋局中的一枚棋子。"

# game/a12/4cassbass.rpy:302
translate english cassbass_green2_b1159387:

    # me "Я тоже был."
    me "我也是。"

# game/a12/4cassbass.rpy:303
translate english cassbass_green2_7357ecc0:

    # cass "Ты был фигурой покрупнее."
    cass "你这枚棋子比我的份量重多了。"

# game/a12/4cassbass.rpy:304
translate english cassbass_green2_ccd64d47:

    # me "С чего ты взяла?"
    me "为什么这么想？"

# game/a12/4cassbass.rpy:305
translate english cassbass_green2_58eaa833:

    # cass "Разве ты не понял? Она спровоцировала меня специально. Я должна была убить твоего отца, а ты должен был занять его место."
    cass "你还不明白吗？她是故意刺激我的。我本该杀了你的父亲，而你应该继承他的位子。"

# game/a12/4cassbass.rpy:306
translate english cassbass_green2_f95c9fc9_1:

    # me "И?"
    me "然后呢？"

# game/a12/4cassbass.rpy:307
translate english cassbass_green2_66ea87a7:

    # cass "Моя роль на этом заканчивалась. Я должна была быть убита. Тобой, вассалами отца, не важно. Если бы ты не поддержал меня - я была бы мертва."
    cass "我的角色到此为止。我那时注定要死。无论是被你，还是被你父亲的封臣杀死，都一样。如果你当时没有支持我，我已经死了。"

# game/a12/4cassbass.rpy:309
translate english cassbass_green2_8d08da0a:

    # me "Выходит наша дружба спасла тебе жизнь."
    me "这么说，我们的友谊救了你一命。"

# game/a12/4cassbass.rpy:310
translate english cassbass_green2_b93a2e13:

    # cass "Ну... можно и так сказать."
    cass "嗯……也可以这么说吧。"

# game/a12/4cassbass.rpy:311
translate english cassbass_green2_de143823:

    # me "Было ошибкой ставить нас на соседние клетки, да?"
    me "把我们放在相邻的格子里，是她的失误，对吧？"

# game/a12/4cassbass.rpy:312
translate english cassbass_green2_40cf28cf:

    # cass "Это... это только твоя заслуга. Я послушно выполнила роль, что она мне приготовила."
    cass "这……这全是你的功劳。我只是乖乖地扮演了她给我安排的角色。"

# game/a12/4cassbass.rpy:313
translate english cassbass_green2_4bdbe249:

    # me "Да брось."
    me "拜托。"

# game/a12/4cassbass.rpy:314
translate english cassbass_green2_34289b40:

    # cass "Так и было. Мне просто повезло."
    cass "事实如此。我只是运气好。"

# game/a12/4cassbass.rpy:315
translate english cassbass_green2_7be5f00f:

    # me "Думаю везение тут не причем. Я бы никогда не лишил игрока за доской головы, если бы по-настоящему не дорожил фигурой рядом."
    me "我想这不单单是运气。我绝不会把棋盘上的一个棋手砍头，要是我不是真正珍惜旁边的那枚棋子。"

# game/a12/4cassbass.rpy:316
translate english cassbass_green2_aa10d107:

    # cass "[mename]. Я даже не твоя сестра. Ты понимаешь?"
    cass "[mename]。我甚至都不是你的姐姐。你明白吗？"

# game/a12/4cassbass.rpy:317
translate english cassbass_green2_20af9aa6:

    # me "Родство не всегда определяется кровью, [cass]. Я это понял благодаря тебе."
    me "血缘并不总是定义亲情，[cass]。我是因为你才明白这点的。"

# game/a12/4cassbass.rpy:318
translate english cassbass_green2_74494ba6:

    # cass "Ты сейчас серьезно?"
    cass "你是认真的吗？"

# game/a12/4cassbass.rpy:319
translate english cassbass_green2_18f3c194:

    # me "Серьезнее некуда."
    me "再认真不过了。"

# game/a12/4cassbass.rpy:320
translate english cassbass_green2_9cb98882:

    # cass "[mename]..."
    cass "[mename]..."

# game/a12/4cassbass.rpy:321
translate english cassbass_green2_39ea146d:

    # me "Я ведь все еще могу тебя называть старшей сестренкой?"
    me "我还能继续叫你姐姐吗？"

# game/a12/4cassbass.rpy:323
