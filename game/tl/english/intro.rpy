# TODO: Translation updated at 2023-09-02 19:58

# game/intro.rpy:3
translate english intro_b5ebca9d:

    # vall "Проклятье, нож совсем затупился."
    vall "该死的，刀完全钝了。"

# game/intro.rpy:4
translate english intro_ebd8d679:

    # vall "Я ведь попросила наточить его."
    vall "我可是让你磨过它的。"

# game/intro.rpy:5
translate english intro_c235ff5d:

    # vall "Теперь провожусь с этими стрелами целую вечность."
    vall "现在我得跟这些箭耗上整整一辈子了。"

# game/intro.rpy:6
translate english intro_7bd9987a:

    # vall "А нам еще нужно достать картины из рам."
    vall "我们还得把画从画框里取出来呢。"

# game/intro.rpy:7
translate english intro_1f1991f7:

    # vall "Алесса, слышишь что я говорю?"
    vall "Alessa，你听见我说话了吗？"

# game/intro.rpy:9
translate english intro_11d4ae07:

    # vall "Алесса?"
    vall "Alessa？"

# game/intro.rpy:10
translate english intro_0dc054af:

    # vall "{size=+8}Я же просила тебя никуда не уходить. Ты нужна мне здесь.{/size}"
    vall "{size=+8}我告诉过你哪儿也别去。我这里需要你。{/size}"

# game/intro.rpy:11
translate english intro_534a6c8e:

    # vall "{size=+8}У нас еще полно работы.{/size}"
    vall "{size=+8}我们还有一大堆活儿要干。{/size}"

# game/intro.rpy:12
translate english intro_5b2c4f28:

    # vall "{size=+8}Алесса?{/size}"
    vall "{size=+8}Alessa？{/size}"

# game/intro.rpy:13
translate english intro_cab570d2:

    # vall "{size=+8}Не заставляй меня тебя искать.{/size}"
    vall "{size=+8}别逼我去找你。{/size}"

# game/intro.rpy:15
translate english intro_7503a734:

    # vall "{size=+8}Ты же знаешь я не люблю эти игры.{/size}"
    vall "{size=+8}你知道我不喜欢这种把戏。{/size}"

# game/intro.rpy:16
translate english intro_6661c221:

    # vall "{size=+8}Алесса!{/size}"
    vall "{size=+8}Alessa！{/size}"

# game/intro.rpy:18
translate english intro_e0e5ea59:

    # aless "{size=+8}Ты чего кричишь?{/size}"
    aless "{size=+8}你喊什么？{/size}"

# game/intro.rpy:19
translate english intro_3b28bfaf:

    # vall "Ну ты же не отвечаешь."
    vall "那不是因为你不搭理我嘛。"

# game/intro.rpy:20
translate english intro_638d0e7d:

    # aless "Я слежу нет ли за нами хвоста."
    aless "我在盯梢，看有没有尾巴跟着我们。"

# game/intro.rpy:21
translate english intro_79b54b74:

    # vall "Они не знают, кто, когда и как украл их картины, с чего бы за нами должен быть хвост?"
    vall "他们根本不知道是谁、什么时候、怎么偷了他们的画，凭什么会有人跟踪我们？"

# game/intro.rpy:22
translate english intro_8d177050:

    # aless "Ну мало ли..."
    aless "那谁知道呢……"

# game/intro.rpy:23
translate english intro_c88abcf2:

    # vall "Ты только привлекаешь внимание, ошиваясь на этом дереве. Если не хочешь, чтобы люди тебя на нем же и повесили..."
    vall "你在这棵树上晃悠，只会引人注意。你要是不想让人把你吊在这棵树上……"

# game/intro.rpy:24
translate english intro_9568e396:

    # aless "Ладно-ладно. Я поняла."
    aless "行啦，行啦，我懂了。"

# game/intro.rpy:26
translate english intro_9ec0af26:

    # vall "Помоги мне с картинами. Нужно аккуратно вырезать холст из рамы."
    vall "来帮我弄这些画。得小心地把画布从框上割下来。"

# game/intro.rpy:27
translate english intro_05e958a6:

    # aless "Ты же знаешь, аккуратность это не про меня."
    aless "你知道的，小心仔细这种事跟我可不沾边。"

# game/intro.rpy:28
translate english intro_784d699c:

    # vall "Я занята подготовкой к охоте. Но если ты хочешь добыть нам еды я готова поменяться."
    vall "我正忙着准备打猎呢。不过，如果你想给咱们弄点吃的回来，我倒乐意跟你换换。"

# game/intro.rpy:29
translate english intro_9751f1b3:

    # aless "Зачем их вообще доставать из рам?"
    aless "干嘛非要把它们从框里弄出来？"

# game/intro.rpy:30
translate english intro_9478e2ff:

    # vall "Потому что в палатке поместятся либо холсты и мы либо только картины целиком."
    vall "因为帐篷里要么放得下画布和我们，要么就只放得下整幅带框的画。"

# game/intro.rpy:31
translate english intro_56d6a7eb:

    # aless "Пусть стоят здесь, что с ними случится?"
    aless "就让它们放这儿呗，能出什么事？"

# game/intro.rpy:32
translate english intro_f4761c64:

    # vall "Ты издеваешься? Дождь, солнце, ветер. Испорченные они ничего не стоят."
    vall "你是在逗我吗？下雨、日晒、风吹。弄坏了它们就一文不值了。"

# game/intro.rpy:33
translate english intro_4f13ba28:

    # aless "...Ладно, ты меня убедила, я готова поспать на улице."
    aless "……行吧，你把我说服了，我准备好睡大街了。"

# game/intro.rpy:34
translate english intro_fd227d65:

    # vall "Алесса!"
    vall "Alessa！"

# game/intro.rpy:35
translate english intro_c553525f:

    # aless "Шутка."
    aless "开玩笑啦。"

# game/intro.rpy:37
translate english intro_0b94b98c:

    # aless "Какая-то мазня. Кому вообще нужна эта чушь?"
    aless "这画的什么东西，乱七八糟的，谁会要这种玩意儿？"

# game/intro.rpy:38
translate english intro_f68e3571:

    # vall "Это не чушь, а королевская свадьба в серебристом лесу недалеко от Тирантиса, кисти знаменитого художника ван дер Кейса."
    vall "这可不是乱七八糟的玩意儿，这是提兰提斯附近银月森林里的皇家婚礼，出自著名画家范德·凯斯之手。"

# game/intro.rpy:39
translate english intro_6b508c49:

    # aless "И что? Кто захочет смотреть на свадьбу каких-то давно умерших людей."
    aless "那又怎样？谁会想看那些早就入土的人的婚礼啊。"

# game/intro.rpy:40
translate english intro_8853e476:

    # vall "Людей? Вообще-то жена эльфийка. К тому же они живы."
    vall "人？那位夫人可是精灵。再说，他们还活着呢。"

# game/intro.rpy:41
translate english intro_a5b59e19:

    # aless "Оу..."
    aless "哦……"

# game/intro.rpy:42
translate english intro_34f45f9e:

    # vall "Да. Это нынешняя королева. Так что ничего удивительного, что эта картина висит...висела у какого-то дворянина."
    vall "没错。这就是当今的王后。所以这幅画会挂在……曾经挂在某个贵族的家里，一点也不稀奇。"

# game/intro.rpy:43
translate english intro_05c0dbc3:

    # aless "Это может и не удивительно, а вот то, что мы вынужденны воровать, чтобы есть, хотя королева этих земель одной с нами крови - вот это действительно странно."
    aless "这不稀奇，稀奇的是，我们居然得靠偷东西才有饭吃，而这片土地的王后跟我们同宗同源——这才叫真的怪事。"

# game/intro.rpy:44
translate english intro_36729b26:

    # vall "Все не так просто. Хочешь снова послушать мою историю?"
    vall "事情没那么简单。想再听一遍我的故事吗？"

# game/intro.rpy:52
translate english intro_lore_d447ccda:

    # aless "Расскажи."
    aless "讲讲吧。"

# game/intro.rpy:53
translate english intro_lore_2e1c8436:

    # vall "Ну тогда слушай внимательно."
    vall "那你就仔细听好了。"

# game/intro.rpy:55
translate english intro_lore_bfebc13d:

    # vall "Столетиями Золотая Империя процветала и росла."
    vall "数百年间，黄金帝国繁荣昌盛，疆域日广。"

# game/intro.rpy:56
translate english intro_lore_74d7d2fd:

    # vall "Империя почти не вела войн, ведь множество мелких княжеств и королевств примыкали к Империи добровольно, надеясь на ее защиту и желая получить доступ к крупнейшему рынку на континенте. Даже кочевые народы, такие как орки поступали на службу, исполняя роль защитников границ."
    vall "帝国几乎从不开战，因为无数的小公国和王国都自愿依附于帝国，寻求它的庇护，并希望借此进入这块大陆上最大的市场。甚至连那些游牧民族，比如兽人，也前来效力，扮演着边境守护者的角色。"

# game/intro.rpy:57
translate english intro_lore_b8068efc:

    # vall "Столица Империи была самым большим и красивым местом на всем континенте, красота ее улиц могла сравниться только с древними эльфийскими городами."
    vall "帝国的都城是整个大陆上最宏伟、最美丽的地方，它的街道之美，只有那些古老的精灵城市可以与之媲美。"

# game/intro.rpy:59
translate english intro_lore_aef82120:

    # vall "Все изменилось когда императором стал Лотрик 2, прозванный в народе красным."
    vall "一切都在Lotric II即位后改变了，这位皇帝在民间被称作“红皇”。"

# game/intro.rpy:60
translate english intro_lore_e6f2f585:

    # vall "И назван он был так не с проста. Император сменил все золотые знамена на кроваво-алые, приблизил к себе множество генералов армий и начал укреплять и централизовать власть в Империи, отнимая любую самостоятельность у своих подданных."
    vall "他这个称号可不是随便起的。这位皇帝撤换了所有金色的旗帜，代之以血红色的旗帜，他提拔了大量军队将领到身边，开始强化和集中皇权，剥夺他臣属的任何自主权。"

# game/intro.rpy:62
translate english intro_lore_92552aa5:

    # vall "Многие противились Алому Императору. Но когда кто-то пытался сохранить хотя бы часть своей прежней власти - красный король отнимал ее огнем и кровью."
    vall "许多人反抗这位猩红皇帝。但每当有人试图保留哪怕一丁点儿昔日的权力时——红皇便会用火与血将其夺走。"

# game/intro.rpy:63
translate english intro_lore_8bfa37fe:

    # vall "Долгих 20 лет кроваво-красный танец ходил по Империи, Император хотел получить всю власть которую только мог."
    vall "漫长的二十年里，这个血红色的舞步踏遍了整个帝国，这位皇帝想要攫取所有他能得到的权力。"

# game/intro.rpy:64
translate english intro_lore_0a7576b4:

    # vall "Люди страдали и беднели, торговцы уплывали за горизонт и не возвращались, солдаты гибли в бесконечных восстаниях, а эльфы спешно покидали города, в очередной раз оказавшись причиной всех бед для людей."
    vall "人们受苦受难，日益贫困，商人们驶向地平线，一去不返，士兵们在无休止的叛乱中死去，而精灵们则匆忙逃离城市，又一次成了人类眼中万恶的根源。"

# game/intro.rpy:66
translate english intro_lore_0224ed17:

    # vall "Головы летели с плеч как у крестьян, так и у королей, так что со временем даже самые гордые стали преклонять колени, объявляя свою вечную преданность красному Императору."
    vall "人头纷纷落地，无论是农民还是国王，以至于到最后，连最骄傲的人也弯下膝盖，向猩红皇帝宣告他们永恒的忠诚。"

# game/intro.rpy:67
translate english intro_lore_ad719927:

    # vall "В императорском дворе не было слышно даже шепота. Людям казалось что теперь не только тела, но и их души принадлежат новому красному хозяину."
    vall "在帝国的宫廷里，连窃窃私语都听不到了。人们觉得，如今不仅他们的身体，就连他们的灵魂也属于这位新的猩红主人。"

# game/intro.rpy:68
translate english intro_lore_6c9a4c81:

    # vall "Люди начали привыкать."
    vall "人们开始习惯了。"

# game/intro.rpy:70
translate english intro_lore_2b2761f8:

    # vall "Но не все... На севере зрел самый большой заговор - поддерживаемые гномами лорды тайно собрали и вооружили большую армию из недовольных со всей Империи."
    vall "但并非所有人……在北方，一场最大的阴谋正在酝酿——在矮人的支持下，北境诸侯们秘密地召集并武装起一支大军，其成员来自帝国各地对现状心怀不满的人。"

# game/intro.rpy:71
translate english intro_lore_6d4e790d:

    # vall "Когда заговор раскрылся, красный Император созвал знамена и двинулся покорять очередных мятежников."
    vall "当阴谋败露时，猩红皇帝召集了旗下诸军，前去平定又一伙叛贼。"

# game/intro.rpy:73
translate english intro_lore_ec0bea50:

    # vall "В битве у синих гор сошлись две армии. Битва длилась несколько дней и ночей. Мечи и копья пронзали тысячу тел, уставшие спали прямо на трупах погибших, а вороны склевали больше глаз чем осталось открытыми."
    vall "在蓝山脚下，两支大军相遇了。这场战斗持续了数天数夜。刀剑与长矛刺穿了无数的躯体，疲惫不堪的人们就倒在阵亡者的尸体上直接入睡，而乌鸦啄食的眼睛，比依然睁着的还要多。"

# game/intro.rpy:74
translate english intro_lore_84ff0b54:

    # vall "И все же красный Император проиграл. Армия его была разбита. А сам он вернулся в столицу с опущенными знаменами. Шепот вернулся в Имперский двор. "
    vall "然而，猩红皇帝还是战败了。他的军队被击溃了。他自己则垂着旗帜返回了帝都。窃窃私语又回到了帝国的宫廷。"

# game/intro.rpy:76
translate english intro_lore_66b8fc98:

    # vall "Северные лорды получили передышку и начали готовиться к новому походу красного Императора."
    vall "北境诸侯们得到了喘息的机会，开始着手准备应对猩红皇帝的下一次征讨。"

# game/intro.rpy:77
translate english intro_lore_7cdcdcf0:

    # vall "Тот что тот вернется, они не сомневались. Но теперь их мятеж уже не казался безнадежным. Многие лорды открыто покидали своего кровавого хозяина и вставали на сторону мятежа. В воздухе витал запах новой битвы."
    vall "对于他会卷土重来这件事，他们毫不怀疑。但眼下，他们的叛乱已不再显得毫无希望。许多诸侯公开背弃了他们那血腥的主人，站到了叛军一边。空气中弥漫着新一场大战在即的气息。"

# game/intro.rpy:79
translate english intro_lore_1dc3eb0d:

    # vall "Но битвы не произошло. Императора нашел смертельно раненным в покоях его младший сын Регис, он обвинил во всем старшего сына, и при поддержке небольшой группы дворян бросил его в темницу, в одночасье став ближе всего к короне нового Императора."
    vall "但大战并未发生。皇帝被他的小儿子Regis发现身受致命伤，倒在自己的寝宫里。小儿子将一切归咎于长子，并在一小群贵族的支持下，将兄长投入了地牢，一夜之间，他自己成了离新皇冠冕最近的人。"

# game/intro.rpy:81
translate english intro_lore_6756d5ff:

    # vall "Проведя суд, Регис назвал своего старшего брата отцеубийцей и лишил его права на престол, по праву древнего закона."
    vall "经过审判，Regis宣布他的哥哥为弑父者，并根据古老的法条，剥夺了他的王位继承权。"

# game/intro.rpy:82
translate english intro_lore_a0adb39e:

    # vall "Ненавидевшие красного Императора столичные дворяне и духовенство быстро признали законность суда и притязаний Региса на престол."
    vall "憎恨猩红皇帝的帝都贵族和教会人士，迅速承认了这次审判的合法性以及Regis对王位的要求。"

# game/intro.rpy:83
translate english intro_lore_e2513809:

    # vall "Трудно винить их в предательстве. Они видели в младшем сыне Императора возможность прекратить бесконечные войны внутри Империи и шанс на ослабление абсолютной власти."
    vall "很难指责他们背叛。他们在皇帝的小儿子身上看到了终结帝国内部无尽战争的可能性，以及削弱绝对皇权的契机。"

# game/intro.rpy:85
translate english intro_lore_3c7a888f:

    # vall "Но не все были готовы молча согласиться на такой захват власти."
    vall "但并非所有人都愿意对此等夺权行径默然顺从。"

# game/intro.rpy:86
translate english intro_lore_e0538c6a:

    # vall "Сотни преданных красному Императору людей толпились у его смертного одра, пытаясь выудить хоть слово о том, кто ранил его и кто должен стать наследником."
    vall "成百上千忠于猩红皇帝的人簇拥在他的灵床前，试图从他口中套出哪怕一个字，想知道是谁伤了他，谁又该是继承人。"

# game/intro.rpy:87
translate english intro_lore_59f30383:

    # vall "Но Император повторял только «Это не я, это не я.», пока не умер."
    vall "但皇帝只是不断重复着“那不是我，那不是我”，直到死去。"

# game/intro.rpy:89
translate english intro_lore_de6119b3:

    # vall "Наиболее лояльное красному Императору военное сословие, состоящее в основном из западных лордов было недовольно, что наследником стал не старший сын, они не верили, что это он убил своего отца. "
    vall "那些对猩红皇帝最为忠诚的军事阶层，主要由西境诸侯构成，对继承人不是长子感到非常不满，他们根本不相信是长子杀了自己的父亲。"

# game/intro.rpy:90
translate english intro_lore_cbe4beb8:

    # vall "Но так как их влияние было ослабленно громким поражением, они покинули столицу и вслед за северными лордами провозгласили независимость и в городах западных княжеств золотые и красные знамена быстро поменяли на зеленые."
    vall "但一场惨痛的大败已令他们势力大减，在影响力被削弱的情况下，他们离开了帝都，继北境诸侯之后，也宣布了独立。在西部各公国的城市中，金色和红色的旗帜迅速被换成了绿色的。"

# game/intro.rpy:92
translate english intro_lore_6be30c31:

    # vall "Орки также отказались продолжать служить незаконному королю, они, как и большинство людей в империи были уверены, что отца убил сам Регис, который в отличие от, заключенного в тюрьму брата не участвовал в походах отца, предпочитая плести интриги в столице."
    vall "兽人也拒绝继续为一个不合法的国王效力，他们和帝国内的多数人一样，深信是Regis本人杀害了父亲。毕竟，与他那个身陷囹圄的兄长不同，Regis并未随父出征，倒更喜欢在帝都里编织阴谋诡计。"

# game/intro.rpy:93
translate english intro_lore_61a5da1c:

    # vall "Орки демонстративно сожгли знамена и покинули и так обескровленную армию."
    vall "兽人示威性地烧毁了旗帜，离开了这本已大伤元气的军队。"

# game/intro.rpy:95
translate english intro_lore_97a0fb5b:

    # vall "Южные королевства тут же объявили о своей независимости. Гарнизоны были перебиты а, тела солдат завернули в алые знамена и выбросили за стены."
    vall "南方的各个王国也立刻宣布独立。驻军遭到屠杀，士兵们的尸体被裹在猩红的旗帜里，扔出城外。"

# game/intro.rpy:96
translate english intro_lore_1c09a330:

    # vall "Разрушение Империи приобрело необратимый характер."
    vall "帝国的分裂变得不可逆转。"

# game/intro.rpy:98
translate english intro_lore_4dc5c875:

    # vall "От моря и до моря люди жгли алые знамена и назначали себе новых королей."
    vall "从一片海到另一片海，人们焚烧着猩红旗帜，并给自己拥立新的国王。"

# game/intro.rpy:99
translate english intro_lore_45cf6978:

    # vall "Местные гарнизоны бежали, опасаясь, что их ждет расправа."
    vall "各地的驻军纷纷逃亡，生怕自己也遭到屠戮。"

# game/intro.rpy:100
translate english intro_lore_3395615d:

    # vall "Толпы дезертиров хлынули в имперский город, но измученная армия не имела никаких сил наказать их."
    vall "成群结队的逃兵涌入了帝国的都城，但早已筋疲力竭的军队根本没有力气去惩罚他们。"

# game/intro.rpy:102
translate english intro_lore_d09ef729:

    # vall "Пытаясь спасти хоть что-то Регис отказался от Императорской короны и объявил себя королем, тем самым уравнивая себя с другими королями и заключил брак с дочерью лорда Вагоса, вернув себе верность западных лордов."
    vall "为了尽可能挽救局面，Regis放弃了皇帝的头衔，仅自称国王，以此将自己放到与其他国王对等的地位上，并通过迎娶Vagos领主的女儿，重新赢回了西境诸侯的效忠。"

# game/intro.rpy:103
translate english intro_lore_f7999e22:

    # vall "На свадебной церемонии король произнес речь, в которой объявил свободу выходу из Империи, фактически уничтожив ее и окончив войну."
    vall "在婚礼庆典上，国王发表了演说，宣告允许自由脱离帝国，这实际上等于亲手瓦解了帝国，结束了战争。"

# game/intro.rpy:105
translate english intro_lore_56dad413:

    # vall "Дочь лорда Вагоса не отличалась здоровьем, после рождения дочери она рожала только мертворожденных девочек."
    vall "Vagos领主的女儿健康状况不佳，在产下一个女儿后，后来生下的都是死产的女婴。"

# game/intro.rpy:106
translate english intro_lore_a727ec98:

    # vall "Не выдержав насмешек дворян и давления мужа, окончательно убедившись, что не способна подарить королю наследника она отравила себя."
    vall "她再也无法忍受贵族们的嘲笑和丈夫施加的压力，在彻底确信自己无法为国王诞下继承人后，她服毒自尽了。"

# game/intro.rpy:107
translate english intro_lore_37adf990:

    # vall "Хотя зная репутацию короля, люди поговаривали, что это он убил ее."
    vall "虽然，考虑到这位国王名声在外，民间也流传着是他杀了她的说法。"

# game/intro.rpy:109
translate english intro_lore_d362f45c:

    # vall "Несколько лет спустя, достаточно укрепив власть, король предложил место своей королевы знатной эльфийке, поддавшись на уговоры придворных колдунов. Дворяне были разгневаны, кровь золотых королей и императоров была бы запятнана. Так еще и союз с эльфами, не имеющими своего государства, был абсолютно невыгоден короне."
    vall "几年后，国王在充分巩固了权力之后，听从了宫廷术士们的劝说，提议由一位高贵的精灵女性接任他的王后之位。贵族们勃然大怒，认为黄金国王与皇帝的血脉将会被玷污。更何况，与一个连自己国家都没有的精灵结盟，对王室来说简直百无一利。"

# game/intro.rpy:110
translate english intro_lore_b7a643f1:

    # vall "Но король был непреклонен. В серебристом лесу недалеко от Тирантиса он обьединил свою кровь с эльфийской."
    vall "但国王毫不动摇。在提兰提斯附近的银月森林，他将自己的血脉与精灵的血脉结合在了一起。"

# game/intro.rpy:112
translate english intro_lore_d0a8f6f6:

    # vall "Немногим позже родились разнополые близнецы."
    vall "不久后，一对龙凤胎诞生了。"

# game/intro.rpy:113
translate english intro_lore_e29bd19b:

    # vall "Королевская семья была счастлива. Хоть все немного и омрачалось гибридной лихорадкой - болезнью проявляющийся у детей, чьи родители принадлежали разным расам."
    vall "王室家庭一度其乐融融。虽然一切都被混血热症蒙上了一丝阴影——那是一种出现在父母分属不同种族的子女身上的疾病。"

# game/intro.rpy:114
translate english intro_lore_0e43dfce:

    # vall "И если у близнецов она проявлялась не сильно, то девочка, рожденная после практически была прикована к кровати."
    vall "如果说这对双胞胎身上的症状还不算严重，那么后来出生的那个女孩，则几乎完全无法离开病榻了。"

# game/intro.rpy:116
translate english intro_lore_ca34aa26:

    # vall "Время шло и король стал охладевать и к своей новой жене и руководству государством."
    vall "时光飞逝，国王对他的新王后和对治理国事一样，都渐渐冷淡了下去。"

# game/intro.rpy:117
translate english intro_lore_9ac074b8:

    # vall "Проводя все время в обществе колдунов он стал сверять каждое своей движение с их предсказаниями."
    vall "他开始把所有时间都花在与术士们为伍，将自己的一举一动都交由他们的预言来定夺。"

# game/intro.rpy:118
translate english intro_lore_1d0bc358:

    # vall "Древние тексты заняли все его внимание. И то ли поверив одному из них, то ли согласившись с одним из многочисленных творцов магии он решил, что его родной сын непременно должен его убить."
    vall "古老的文献占据了他全部的注意力。也不知是信了其中的某一段，还是听信了某个操纵魔法的高人的鬼话，他认定自己的亲生儿子注定会杀死他。"

# game/intro.rpy:120
translate english intro_lore_fb2e3cf4:

    # vall "Несмотря на то, что тот был только ребенком, король изгнал его из дворца, и приставив к нему несколько учителей и солдат отправил в самый дальний город королевства."
    vall "尽管那孩子当时还只是个孩童，国王还是将他逐出了宫殿，指派了几名老师和士兵跟随，将他送往了王国最偏远的城镇。"

# game/intro.rpy:121
translate english intro_lore_e66b7f8d:

    # vall "Никто не мог повлиять на его мнение. Даже некоторые колдуны, испугавшись за жизнь наследника стали нашептывать королю, что тот не так истолковал пророчества."
    vall "没人能改变他的想法。甚至有些术士，出于对王子安危的恐惧，也开始向国王悄悄进言，说他对预言的理解有误。"

# game/intro.rpy:122
translate english intro_lore_831256c6:

    # vall "Но решение уже было принято."
    vall "但决定已经做出。"

# game/intro.rpy:124
translate english intro_lore_dd928d51:

    # vall "Ночью небольшой отряд покинул имперский город, чтобы возможно навсегда отвести маленького принца как можно дальше от дома."
    vall "在一个夜晚，一小队人马离开了帝国都城，或许是为了将小王子送到离家尽可能远的地方，让他永远离开。"

# game/intro.rpy:125
translate english intro_lore_06b7f0a0:

    # vall "Наверное король мог бы просто убить сына, но то ли еще не совсем сошел с ума, то ли очередное пророчество запрещало ему это сделать."
    vall "也许国王本可以直接杀掉自己的儿子，但或许是还没彻底疯掉，又或许是又有哪条预言禁止他这么做。"

# game/intro.rpy:127
translate english intro_lore_2fa2308b:

    # vall "Принца увезли. И теперь никто не знает где он."
    vall "王子被带走了。如今，没人知道他在哪里。"

# game/intro.rpy:128
translate english intro_lore_10b3f555:

    # vall "На севере? На юге? В горах? В болотах? В городе или деревне? Где бы он ни был жизнь у него явно не королевская."
    vall "是在北方吗？南方？山区？沼泽？城市还是乡村？无论他在何处，他的生活显然与王子身份毫不相干。"

# game/intro.rpy:129
translate english intro_lore_d259a570:

    # vall "И все же он наша надежда понимаешь? Принц-полукровка. Эльф и человек. Может однажды он станет королем и нам больше не придется жить в лесу. Может эльфы снова отстроят свои прекрасные города и превратят этот гниющий континент в цветущий сад."
    vall "可他依然是我们的希望，你懂吗？一位半血混种王子。既是精灵，也是人类。也许有一天，他会成为国王，那样我们就不再需要住在森林里了。也许精灵们能再次建起他们美丽的城市，把这块腐朽的大陆变成繁花似锦的花园。"

# game/intro.rpy:133
translate english intro2_53808f6d:

    # aless "А ты думаешь он красивый?"
    aless "那你觉得他帅吗？"

# game/intro.rpy:134
translate english intro2_5b3359df:

    # vall "Кто...что? Кто красивый?"
    vall "谁……什么？谁帅不帅？"

# game/intro.rpy:135
translate english intro2_d660b600:

    # aless "Ну принц. Он ведь должен быть примерно моего возраста, да? Как думаешь он бы мог сделать меня своей королевой, когда взойдет на трон? "
    aless "我说那个王子啊。他应该跟我差不多大吧，对吧？你觉得等他有朝一日登上王位，他能让我当他的王后吗？"

# game/intro.rpy:136
translate english intro2_671384e3:

    # vall "Алесса..."
    vall "Alessa……"

# game/intro.rpy:138
translate english intro2_4e19b3be:

    # vall "Ты ведь опять ничего не слушала, да?"
    vall "你又什么都没听，对吗？"

# game/intro.rpy:139
translate english intro2_b79fffb4:

    # aless "Конечно слушала!"
    aless "我当然听了！"

# game/intro.rpy:140
translate english intro2_8e8ab2fb:

    # vall "И о чем я рассказывала?"
    vall "那我刚才讲的是什么？"

# game/intro.rpy:141
translate english intro2_78a1714a:

    # aless "Принц. Молодой. Полуэльф и живет не в замке. У меня все шансы. Хотя даже если бы жил в замке я бы нашла способ туда попасть. Замки я взламываю отменно."
    aless "一个王子。年轻。是半精灵，还不住在城堡里。我机会大得很。不过，就算他住在城堡里，我也有办法溜进去。开城堡的锁，我可是行家。"

# game/intro.rpy:142
translate english intro2_15902e69:

    # vall "Ты...ты очень трудный ребенок."
    vall "你……你真是个让人头疼的孩子。"

# game/intro.rpy:143
translate english intro2_5a781545:

    # aless "Что? Мне уже нельзя помечтать о принце?"
    aless "怎么了？我现在连做个跟王子有关的梦都不行了吗？"

# game/intro.rpy:144
translate english intro2_f3f61bb8:

    # vall "Ах...Ладно. Мечтай сколько угодно. Просто помоги уже с картинами ладно? Черт, недавно только тащили это из города и теперь обратно, нам не помешает лошадь."
    vall "唉……好吧。随便你怎么梦。先帮我弄这些画，行吧？见鬼，前不久才把它们从城里拖出来，现在又要拖回去，我们真需要一匹马。"

# game/intro.rpy:145
translate english intro2_e8fa40aa:

    # aless "Нам не помешает принц, он бы решил все наши проблемы будь я его женой."
    aless "我们需要的是一个王子，嫁给他，我们所有的问题就都解决了。"

# game/intro.rpy:146
translate english intro2_f9f351eb:

    # vall "Я уже жалею, что тебе все это рассказала."
    vall "我现在真后悔跟你讲了这些事。"

# game/intro.rpy:147
translate english intro2_a75de2b4:

    # aless "Интересно где же он... наверное сидит и грустит о своем родном доме, прямо как мы."
    aless "真想知道他现在在哪儿……大概正坐在那儿，跟我一样，思念着家乡，暗自神伤吧。"

# game/intro.rpy:148
translate english intro2_9df8c1da:

    # vall "Я слышала что, он..."
    vall "我听过他的传闻……"

# game/intro.rpy:161
translate english strength_perk_8fa6a553:

    # vall "Принц тратил почти все свободное время на совершествование своих боевых навыков."
    vall "王子把他几乎所有的空闲时间都花在了磨练自己的战斗技巧上。"

# game/intro.rpy:162
translate english strength_perk_eabd2a1a:

    # vall "Благодаря этому он стал значительно сильнее и уверенней в себе."
    vall "这让他变得远比以前更强，也对自己更有信心。"

# game/intro.rpy:172
translate english intelligence_perk_b1f1b174:

    # vall "Принц любит запах пыльных библиотек и шелест страниц старых манускриптов."
    vall "王子喜欢满是灰尘的图书馆里的气味，还有古老手稿的书页沙沙声。"

# game/intro.rpy:173
translate english intelligence_perk_4b48ef8d:

    # vall "Благодаря этому он обладает внушительным багажом знаний об окружающем мире, а также свободно говорит на почти всех языках континента."
    vall "这让他在关于周遭世界的知识上有了相当可观的储备，几乎能流利地说大陆上所有的语言。"

# game/intro.rpy:183
translate english mage_perk_127b9fbd:

    # vall "Принц не только обладает магическими способностями, но и активно развивает их."
    vall "王子不仅拥有魔法天赋，而且在积极将其发扬光大。"

# game/intro.rpy:184
translate english mage_perk_0b890b03:

    # vall "Благодаря этому он может использовать самые разные магические способности в самых разных ситуациях."
    vall "这足以让他在无数情况下使出千变万化的魔法。"

# game/intro.rpy:194
translate english intro3_808ddf7d:

    # juno "Ты везде прибралась?"
    juno "你把所有地方都收拾干净了？"

# game/intro.rpy:195
translate english intro3_b18359a4:

    # rosa "Ну как видишь. Только этот стол остался."
    rosa "喏，你也看见了。就只剩这张桌子了。"

# game/intro.rpy:196
translate english intro3_21e0b982:

    # juno "Все еще спит?"
    juno "他还在睡？"

# game/intro.rpy:197
translate english intro3_58d1a844:

    # rosa "А как ты думаешь?"
    rosa "这还用得着问？"

# game/intro.rpy:198
translate english intro3_2dc9b480:

    # juno "Думаю что он хорошо платит, но недостаточно, чтобы превращать это место в ночлежку."
    juno "他给的酒钱是不错，但还没多到可以把这儿当成客栈。"

# game/intro.rpy:199
translate english intro3_f24e87de:

    # rosa "Ну так разбуди его"
    rosa "那就把他叫醒呗。"

# game/intro.rpy:200
translate english intro3_d64a1711:

    # juno "Эй! Просыпайся. Как там тебя..."
    juno "喂！醒醒。你叫什么来着……"

# game/intro.rpy:202
translate english intro3_46af2e21:

    # juno "Просыпайся, [mc]."
    juno "醒醒，[mc]。"

# game/intro.rpy:203
translate english intro3_35f8d4e1:

    # mc "А? Солнце уже встало?"
    mc "嗯？太阳已经出来了吗？"

# game/intro.rpy:204
translate english intro3_09784afc:

    # juno "Давным-давно. Ты тут всю ночь проторчал."
    juno "早出来了。你在这儿都耗了一整晚了。"

# game/intro.rpy:205
translate english intro3_1b2a331a:

    # mc "Я заплатил за выпивку?"
    mc "我的酒钱付了吗？"

# game/intro.rpy:206
translate english intro3_5d8c191b:

    # juno "Ты? Нет. За тебя заплатил твой друг."
    juno "你？没付。是你朋友替你付的。"

# game/intro.rpy:207
translate english intro3_67d1ade9:

    # mc "Отлично."
    mc "那不错。"

# game/intro.rpy:208
translate english intro3_f09b58e3:

    # juno "Он заплатил за выпивку, а не за ночь под крышей."
    juno "他付的是酒钱，可不是让你在这儿睡一晚的钱。"

# game/intro.rpy:209
translate english intro3_fdd4d0d8:

    # mc "Я не занимал койку, просто уснул тут и..."
    mc "我又没占床位，就是在这儿睡着了，然后……"

# game/intro.rpy:211
translate english intro3_9051c965:

    # juno "Я не требую с тебя еще денег. Мне нужно отойти ненадолго, так что просто убери за собой и помоги Розе перетащить новые бочки с вином, взамен тех что осушили вчера, и мы в расчете."
    juno "我没打算再管你要钱。我得出去一小会儿，所以你只要把你自己的东西收拾好，再帮Rosa把新到的酒桶搬进来，顶替掉昨天喝光的那些，咱们就算两清了。"

# game/intro.rpy:212
translate english intro3_9bb63523:

    # rosa "С добрым утром."
    rosa "早安。"

# game/intro.rpy:213
translate english intro3_ac2b1457:

    # mc "Ладно..."
    mc "好吧……"

# game/intro.rpy:214
translate english intro3_eed01782:

    # juno "Вот и отлично. И передай другу чтобы прекратил расплачиваться золотыми монетами. В этом городе их не потратить."
    juno "那太好了。还有，跟你那个朋友说一声，别再用金币付账了。在这城里，金币根本就花不出去。"

# game/intro.rpy:215
translate english intro3_ac7e99e0:

    # mc "{i}Какому еще другу? Вроде вчера я был тут один.{/i}"
    mc "{i}什么朋友？我记得我昨天好像是一个人来的。{/i}"

# game/intro.rpy:217
translate english intro3_9f4f245e:

    # mc "Голова болит. Ничего не помню. С кем я вчера пил?"
    mc "头好疼。什么都不记得了。我昨天跟谁喝的酒？"

# game/intro.rpy:218
translate english intro3_1a9ed6fa:

    # rosa "Интересует кто-то конкретный? Потому что вчера ты угощал любого кто к тебе подсядет."
    rosa "你想找某个特定的人吗？因为昨天但凡有谁过来坐你边上，你就请谁喝酒。"

# game/intro.rpy:219
translate english intro3_9c214764:

    # mc "Кто заплатил за меня? Он выглядел как южанин или как старик? Может это была эльфийская женщина?"
    mc "是谁替我付的账？看着像个南方人还是像位老人？会不会是个精灵女子？"

# game/intro.rpy:220
translate english intro3_30db5d14:

    # rosa "Вау, боюсь представить чем ты занимаешься, если старик, эльфийка и южанин единственное кто могут заплатить за тебя в таверне. "
    rosa "哇哦，如果替你付酒钱的不是老人、精灵女子就是南方人，我真不敢想象你平时到底都在做什么。"

# game/intro.rpy:221
translate english intro3_6cef40c1:

    # mc "Так что?"
    mc "所以呢？"

# game/intro.rpy:222
translate english intro3_0d2c7d56:

    # rosa "Прости, я не помню, кажется это был просто обычный парень."
    rosa "抱歉，我不记得了，好像就是个普普通通的小伙子。"

# game/intro.rpy:224
translate english intro3_696a5295:

    # rosa "Ты слишком пьешь, [mc], тебе не кажется, что ты слишком молод для этого?"
    rosa "你喝得太多了，[mc]，你不觉得你这年纪作践自己太早了点吗？"

# game/intro.rpy:225
translate english intro3_0976a684:

    # mc "У меня трагическая судьба."
    mc "谁让我命苦呢。"

# game/intro.rpy:226
translate english intro3_3416bd24:

    # rosa "Правда? Ты никогда не рассказывал, хотя заходишь регулярно."
    rosa "是吗？这可从来没听你说起过，哪怕你隔三差五就来。"

# game/intro.rpy:227
translate english intro3_11de61d9:

    # mc "Это...ты все равно не поверишь."
    mc "这……我说了你也不会信的。"

# game/intro.rpy:228
translate english intro3_cc1ee929:

    # rosa "Да ладно тебе, в этой таверне каждый пьяница рассказывал мне что он король или истребитель чудовищ, я наслушалась всякого."
    rosa "行啦，在我这酒馆里，哪个酒鬼没跟我吹嘘过自己是国王或是猎魔大师，我什么没听过。"

# game/intro.rpy:229
translate english intro3_e1a3df51:

    # mc "Что за черт? Я с кем-то дрался вчера?"
    mc "见了个鬼？我昨天是跟谁打架了吗？"

# game/intro.rpy:230
translate english intro3_50b103a0:

    # rosa "С чего ты взял?"
    rosa "你怎么会这么想？"

# game/intro.rpy:231
translate english intro3_55e16ebe:

    # mc "У меня синяк кажется под глазом. Болит, черт возьми..."
    mc "我感觉我眼睛下面好像有块淤青。疼得要命，该死的……"

# game/intro.rpy:232
translate english intro3_93d82816:

    # rosa "А...синяк..."
    rosa "啊……那块淤青啊……"

# game/intro.rpy:234
translate english intro3_b3414eeb:

    # rosa "Это ты заработал от меня, нахальный мальчишка."
    rosa "你脸上这块啊，是我揍的，你这个放肆的小鬼。"

# game/intro.rpy:235
translate english intro3_6ba36e9c:

    # mc "Э? Ты меня ударила? За что?"
    mc "啊？你打的？为什么打我？"

# game/intro.rpy:236
translate english intro3_e3412f94:

    # rosa "Ты распускал руки. Опять."
    rosa "你到处乱摸。又犯了老毛病了。"

# game/intro.rpy:237
translate english intro3_ae35b8fa:

    # mc "Можно подумать я единственный тут, кто после пары кружек это делает."
    mc "搞得好像我是这儿唯一一个喝了几杯之后就这么干的人似的。"

# game/intro.rpy:238
translate english intro3_cd4ffcc0:

    # rosa "Да, но ты единственный, кому тут что-нибудь светит. Приходится контролировать не только тебя, но и себя."
    rosa "对，但你是唯一一个有希望能在这得手的人。所以我不仅得管住你，还得管住我自己。"

# game/intro.rpy:239
translate english intro3_3b435a5a:

    # mc "Поаккуратнее. Я же сейчас могу и второй синяк заработать."
    mc "轻点儿调情。我这会儿可经不起，说不定另一边眼睛也得来块淤青。"

# game/intro.rpy:240
translate english intro3_1c24822f:

    # rosa "Ага. Пойдем уже за вином."
    rosa "嗯哼。咱们去搬酒吧。"

# game/intro.rpy:242
translate english intro3_1c79170d:

    # mc "Темновато здесь."
    mc "这儿可真暗。"

# game/intro.rpy:243
translate english intro3_bd32491a:

    # rosa "Да. Здесь только большие, ты не унесешь. Кажется в углу есть маленькие бочки с веллебургским красным."
    rosa "对。这边都是大家伙，你搬不动的。角落里好像有几小桶韦勒堡红酒。"

# game/intro.rpy:244
translate english intro3_da06cc5f:

    # mc "Возьмем его?"
    mc "咱们就拿那个？"

# game/intro.rpy:245
translate english intro3_b8fc59ad:

    # rosa "Мы не увидим название, я принесу свечу, подожди."
    rosa "这样我们看不清上面写的什么，我去拿根蜡烛来，你等着。"

# game/intro.rpy:266
translate english intro_strength_50bab223:

    # mc "{i}Там и вправду ничего не видно.{/i}"
    mc "{i}那里头真是什么也看不见。{/i}"

# game/intro.rpy:267
translate english intro_strength_f9975203:

    # mc "{i}Хотя я мог бы взять и большую бочку...{/i}"
    mc "{i}虽然搬个大桶对我来说也不是什么难事……{/i}"

# game/intro.rpy:269
translate english intro_strength_e0beea8d:

    # rosa "Сейчас подойду и...ой. Ты взял большую? Тебе не тяжело?"
    rosa "我这就过来然后……哎哟。你搬了个大的？你不觉得重吗？"

# game/intro.rpy:270
translate english intro_strength_d89b133a:

    # mc "Нормально. Куда нести?"
    mc "还行。搬去哪儿？"

# game/intro.rpy:271
translate english intro_strength_3acad975:

    # rosa "Как это...тебе точно не тяжело?"
    rosa "这怎么……你真不觉得重吗？"

# game/intro.rpy:272
translate english intro_strength_6337892a:

    # mc "Ну если мы там и будем стоять, то рано или поздно тяжело мне станет."
    mc "呃，要是咱们就这么站在这儿，那迟早会变重的。"

# game/intro.rpy:274
translate english intro_strength_96243a44:

    # rosa "Я...просто...прости я просто удивилась, прости, но ты не выглядишь силачом, но кажется это все таки так."
    rosa "我……只是……抱歉，我只是吃了一惊，抱歉，你看起来不像个大力士，不过看来你确实是。"

# game/intro.rpy:275
translate english intro_strength_0b6b9fd5:

    # mc "Эта бочка не такая уж и тяжелая."
    mc "这桶也没那么重。"

# game/intro.rpy:276
translate english intro_strength_d39951d5:

    # rosa "Ну знаешь, Джуно например не может ее поднять."
    rosa "我跟你说，比如Juno就搬不动这个。"

# game/intro.rpy:277
translate english intro_strength_9dbf6ddc:

    # mc "Ну так он же старый."
    mc "可他毕竟老了嘛。"

# game/intro.rpy:278
translate english intro_strength_8e15dcc6:

    # rosa "Это правда. А ты молодой. И как оказывается очень даже сильный."
    rosa "这倒是真的。而你还年轻。而且看来还出奇的强壮。"

# game/intro.rpy:280
translate english intro_strength_3dac1514:

    # mc "Знаешь, Роза, я не только сильный, но еще и выносливый."
    mc "你知道吗，Rosa，我不仅强壮，还特别有耐力。"

# game/intro.rpy:281
translate english intro_strength_e6453a28:

    # rosa "да ладно, правда?"
    rosa "哦？真的假的？"

# game/intro.rpy:282
translate english intro_strength_f786a4af:

    # mc "Конечно. Могу тебе это продемонстрировать. Джуно еще долго не будет в таверне?"
    mc "当然是真的。嗯，我可以给你好好展示一下。Juno还有一阵子回不了酒馆吧？"

# game/intro.rpy:283
translate english intro_strength_2a4ca5c7:

    # rosa "Что за вопросы? Ему может не понравится твоя демонстрация?"
    rosa "你问这个干什么？你的展示他看到了可能不会高兴。"

# game/intro.rpy:284
translate english intro_strength_0cd9795d:

    # mc "Ему? Ему определенно нет, а вот тебе - да."
    mc "他？他是肯定不会高兴，你嘛——就不同了。"

# game/intro.rpy:285
translate english intro_strength_5bc2e576:

    # rosa "Не знаю, на что ты намекаешь, но я верная жена."
    rosa "我不知道你在暗示什么，但我是个忠贞的妻子。"

# game/intro.rpy:286
translate english intro_strength_d29a2fd9:

    # mc "Ну что ты, Роза, я ни на что не намекаю. Просто думаю что я лучше твоего мужа не только в поднимании бочек."
    mc "哎呀，Rosa，你这话说的，我怎么会暗示那种事。我只是在想，我比你丈夫强的地方，可不止是在搬酒桶上。"

# game/intro.rpy:288
translate english intro_strength_fd71746e:

    # rosa "Ты можешь поднять что-то еще?"
    rosa "你还能举起什么别的东西？"

# game/intro.rpy:289
translate english intro_strength_673b4583:

    # mc "Да. Например, тебя."
    mc "嗯，比如你。"

# game/intro.rpy:291
translate english intro_strength_fa46ebd1:

    # rosa "Ну и как? Я тяжелее бочки?"
    rosa "怎么样？我是不是比酒桶还重？"

# game/intro.rpy:292
translate english intro_strength_6a23f05d:

    # mc "Боюсь ответ тебя расстроит."
    mc "恐怕答案会让你失望了。"

# game/intro.rpy:293
translate english intro_strength_80bec52a:

    # rosa "Эй!"
    rosa "嘿！"

# game/intro.rpy:294
translate english intro_strength_935ef2f9:

    # mc "Шучу. Вы примерно одинаково весите. Но тебя держать почему-то гораздо приятнее."
    mc "开玩笑的。你俩差不多重。但不知怎的，抱着你感觉要舒服太多了。"

# game/intro.rpy:295
translate english intro_strength_16659820:

    # rosa "Почему же?"
    rosa "为什么这么说呢？"

# game/intro.rpy:296
translate english intro_strength_be5c223b:

    # mc "Как минимум потому что тебя можно поцеловать."
    mc "至少，抱着你的时候我还可以亲你。"

# game/intro.rpy:297
translate english intro_strength_d0e8cb80:

    # rosa "Бочку ты тоже можешь поцеловать."
    rosa "酒桶你也可以亲啊。"

# game/intro.rpy:298
translate english intro_strength_ce9b0970:

    # mc "Да. Но она не ответит мне тем же."
    mc "可以是可以。但它可不会回亲我。"

# game/intro.rpy:299
translate english intro_strength_c4813978:

    # rosa "С чего ты взял что я тебе отвечу?"
    rosa "你怎么就知道我会回亲你？"

# game/intro.rpy:300
translate english intro_strength_b3b7d02c:

    # mc "Это я сейчас и проверю."
    mc "我正要试试看呢。"

# game/intro.rpy:302
translate english intro_strength_2b35b6fe:

    # mc "..."
    mc "..."

# game/intro.rpy:303
translate english intro_strength_147e18c8:

    # rosa "..."
    rosa "..."

# game/intro.rpy:304
translate english intro_strength_85490622:

    # mc "{i}В ней пышет молодость. Тяжело ей наверное жить со стариком. Так и знал что нужно слегка надавить и она окажется в моих руках. Буквально.{/i}"
    mc "{i}她浑身都散发着青春活力。跟个老头子一起生活，日子肯定不好过。果然不出我所料，只要稍微加把劲，就能把她弄到手。字面意义上的弄到手。{/i}"

# game/intro.rpy:305
translate english intro_strength_c12ba4c1:

    # mc "{i}Нужно ковать железо пока оно горячо.{/i}"
    mc "{i}我得趁热打铁。{/i}"

# game/intro.rpy:307
translate english intro_strength_6144281e:

    # rosa "Ты что, вздумал меня трахнуть, [mc]?"
    rosa "你打算干我了吗，[mc]？"

# game/intro.rpy:308
translate english intro_strength_ba4d18dc:

    # mc "Ну ты же сама сказала, что я единственный у кого есть шанс, было бы ошибкой не попытаться."
    mc "你自己不也说了，我是唯一一个有希望得手的，不试试看岂不是太可惜了。"

# game/intro.rpy:309
translate english intro_strength_bfaf300e:

    # rosa "Только предупреждаю - это будет только один раз."
    rosa "先提醒你——这种事，只有这一次。"

# game/intro.rpy:310
translate english intro_strength_13d20695:

    # mc "Будет что?"
    mc "什么事只有这一次？"

# game/intro.rpy:311
translate english intro_strength_4f3f85c3:

    # rosa "Ох, не шути со мной. Я уже вся мокрая. И хочу твой член и я его получу."
    rosa "哎，别瞎闹了。我下面都湿透了。我想要你的肉棒，而且今天非尝到不可。"

# game/intro.rpy:312
translate english intro_strength_8063ba61:

    # mc "Я тоже хочу тебя, Роза, и уже давно."
    mc "我也想要你，Rosa，想很久了。"

# game/intro.rpy:313
translate english intro_strength_9fcd33ca:

    # rosa "Ну так чего мы ждем?"
    rosa "那还等什么？"

# game/intro.rpy:315
translate english intro_strength_6a7d2a1a:

    # "15 минут спустя"
    "过了15分钟"

# game/intro.rpy:316
translate english intro_strength_ca32bdfe:

    # rosa "[mc], заканчивай. Джуно скоро вернется."
    rosa "[mc]，快一点。Juno马上就要回来了。"

# game/intro.rpy:317
translate english intro_strength_73a482b2:

    # mc "Я еще не кончил."
    mc "可我还没射呢。"

# game/intro.rpy:318
translate english intro_strength_4789332a:

    # rosa "Я знаю, поэтому и прошу тебя..."
    rosa "我知道，所以我才让你……"

# game/intro.rpy:320
translate english intro_strength_d8a0e0ec:

    # rosa "...поторопиться."
    rosa "……快一点。"

# game/intro.rpy:321
translate english intro_strength_6a310c32:

    # mc "Ладно. А я думал тебе нравится."
    mc "好吧。我还以为你喜欢这样呢。"

# game/intro.rpy:322
translate english intro_strength_244a8f85:

    # rosa "Мне нравится, [mc], но еще мне нравится спать в своем доме, а не на улице."
    rosa "我是喜欢，[mc]，但我更喜欢睡在自己家里，而不是睡大街上。"

# game/intro.rpy:323
translate english intro_strength_f7783125:

    # mc "Будь моя воля ты бы спала со мной во Имперском дворце."
    mc "要是让我做主，我倒想让你跟我一起睡在帝国皇宫里。"

# game/intro.rpy:324
translate english intro_strength_b293feda:

    # rosa "А?"
    rosa "啊？"

# game/intro.rpy:325
translate english intro_strength_2793523c:

    # mc "Забудь. Лучше скажи мне - я лучше, чем твой муж?"
    mc "算了，当我没说。不如你告诉我——我是不是比你丈夫要强？"

# game/intro.rpy:326
translate english intro_strength_21dcc988:

    # rosa "[mc], он почти старик, как ты сам думаешь?"
    rosa "[mc]，他年纪都快能当我爹了，你说呢？"

# game/intro.rpy:327
translate english intro_strength_71ac75cf:

    # mc "Я хочу услышать ответ."
    mc "我想听你亲口说出来。"

# game/intro.rpy:328
translate english intro_strength_556bc05b:

    # rosa "Ты...ты лучше. Твой член больше, ты красивый и молодой, твой темперамент заставляет меня сгорать изнутри, ты сильный и здоровый, я бы...я бы...."
    rosa "你……你比他强。你的那活儿比他的大，你人又年轻又英俊，你的那股劲儿让我从身体深处开始燃烧，你又强壮又健康，我真想……我真想……"

# game/intro.rpy:329
translate english intro_strength_528370b1:

    # mc "Что ты?"
    mc "想怎样？"

# game/intro.rpy:330
translate english intro_strength_305e769e:

    # rosa "Нет, это глупость."
    rosa "不行，这太蠢了。"

# game/intro.rpy:331
translate english intro_strength_e72b90e6:

    # mc "Говори."
    mc "说嘛。"

# game/intro.rpy:332
translate english intro_strength_f036b231:

    # rosa "Если у меня будет от тебя ребенок, он будет похож на эльфа?"
    rosa "如果我怀上了你的孩子，孩子会长得像精灵吗？"

# game/intro.rpy:333
translate english intro_strength_71d0fc8a:

    # mc "Я полуэльф. Ребенок будет на четверть. Уши будут почти незаметны."
    mc "我是半精灵。那孩子就只会带四分之一的精灵血统。耳朵几乎看不出来的。"

# game/intro.rpy:334
translate english intro_strength_611c5fe7:

    # rosa "Ты уверен?"
    rosa "你确定？"

# game/intro.rpy:335
translate english intro_strength_7654f1d1:

    # mc "Конечно."
    mc "当然。"

# game/intro.rpy:336
translate english intro_strength_11ae609c:

    # rosa "Тогда..."
    rosa "那么……"

# game/intro.rpy:337
translate english intro_strength_62bdb3ef:

    # mc "Да?"
    mc "嗯？"

# game/intro.rpy:338
translate english intro_strength_dd2875f2:

    # rosa "[mc], сделаешь меня беременной?"
    rosa "[mc]，能让我怀上吗？"

# game/intro.rpy:340
translate english intro_strength_065433de:

    # mc "ЛЕГКО!"
    mc "乐意之至！"

# game/intro.rpy:341
translate english intro_strength_d574de30:

    # rosa "Поверить не могу, что я действительно это делаю."
    rosa "简直不敢相信我这会儿真的在做这种事。"

# game/intro.rpy:343
translate english intro_strength_9a7ea6cd:

    # mc "Надеюсь с доходами у вас все нормально, потому что я по-моему кончил достаточно, чтобы заделать тебе двойню или даже тройню."
    mc "但愿你们酒馆的收入还不错，因为就我刚才射进去的量，足够给你怀个双胞胎甚至三胞胎了。"

# game/intro.rpy:344
translate english intro_strength_9e4a166e:

    # rosa "Разве это так работает?"
    rosa "这玩意儿是这么算的吗？"

# game/intro.rpy:345
translate english intro_strength_f3072df8:

    # mc "Я не знаю. Наверное."
    mc "我也不清楚。可能吧。"

# game/intro.rpy:346
translate english intro_strength_dfe1d5cc:

    # rosa "Спермы так много что она вытекает наружу."
    rosa "你射了那么多，都流到外面来了。"

# game/intro.rpy:347
translate english intro_strength_4582d47f:

    # mc "С твоим мужем у тебя такого не бывает?"
    mc "跟你丈夫一块儿干的时候，没这么厉害？"

# game/intro.rpy:348
translate english intro_strength_e2d02d6a:

    # rosa "Нет, никогда. Думаю это потому что ты молодой."
    rosa "没有，从来没有。我想是因为你年轻吧。"

# game/intro.rpy:349
translate english intro_strength_12e76794:

    # rosa "К тому же мы занимаемся сексом только в кровати, да и то так редко, что теперь для меня будет проблемой уговорить его заняться сексом хотя бы в ближайшую неделю."
    rosa "况且我们只会在床上做爱，而且就算这样也少得可怜，所以现在让我说服他在未来一周内哪怕做一次都是个难题。"

# game/intro.rpy:350
translate english intro_strength_1d50499d:

    # mc "Я могу помочь?"
    mc "我能帮什么忙吗？"

# game/intro.rpy:351
translate english intro_strength_56e1bd92:

    # rosa "Чем? Дальше все заботы мои. Перетащи уже бочку. Я пока приберусь тут."
    rosa "怎么帮？剩下的都是我的事了。去把那个桶搬起来吧。我先收拾一下这边。"

# game/intro.rpy:355
translate english intro_mage_aa9a7140:

    # mc "Не нужно."
    mc "不用。"

# game/intro.rpy:356
translate english intro_mage_bd89b997:

    # rosa "Вау. Что это?"
    rosa "哇哦。这是什么？"

# game/intro.rpy:357
translate english intro_mage_6a9c04ea:

    # mc "Ты никогда не видела магии раньше?"
    mc "你以前从来没见过法术吗？"

# game/intro.rpy:358
translate english intro_mage_c0a67a86:

    # rosa "Только в детстве... В нашу деревню приезжал бродячий маг. С тех пор прошло столько лет. Я и забыла как это красиво."
    rosa "只在小时候见过……有个流浪法师来过我们村子。从那时候到现在多少年了。我都快忘了，原来法术这么美。"

# game/intro.rpy:359
translate english intro_mage_42a397b4:

    # mc "Тебе и в правду так нравится?"
    mc "你真的这么喜欢吗？"

# game/intro.rpy:360
translate english intro_mage_91fd9511:

    # rosa "Выглядит чудесно."
    rosa "简直太奇妙了。"

# game/intro.rpy:361
translate english intro_mage_e1d2f554:

    # mc "Ну тогда могу сделать это еще красивее."
    mc "那我还能让它变得更美。"

# game/intro.rpy:363
translate english intro_mage_0cf499ab:

    # rosa "Невероятно!"
    rosa "不可思议！"

# game/intro.rpy:364
translate english intro_mage_4e5b5164:

    # mc "Нравится?"
    mc "喜欢吗？"

# game/intro.rpy:365
translate english intro_mage_5ace15b3:

    # rosa "Ничего красивее не видела в своей жизни."
    rosa "我这辈子都没见过比这更美的东西了。"

# game/intro.rpy:366
translate english intro_mage_7d12246d:

    # mc "Это магические светлячки."
    mc "这些是魔法萤火虫。"

# game/intro.rpy:367
translate english intro_mage_6dfe8964:

    # rosa "Светлячки?"
    rosa "萤火虫？"

# game/intro.rpy:368
translate english intro_mage_c50ea64f:

    # mc "Да. Когда детей учат этому заклинанию блуждающего света, они должны представлять у себя в голове какой-нибудь образ, я представлял светлячков. "
    mc "对。教孩子们这种舞光术的时候，要他们在脑子里想象一个形象，我当时想的就是萤火虫。"

# game/intro.rpy:369
translate english intro_mage_f9dc4432:

    # rosa "Ты можешь менять их?"
    rosa "你能改变它们的样子吗？"

# game/intro.rpy:370
translate english intro_mage_8be2de07:

    # mc "Нет. Они теперь такие навсегда. Но они бывают разные, моя сестра представляла единорога и теперь блуждающие огни у нее в форме единорогов."
    mc "不能。它们现在这个样子是永远改变不了了。但每个人创造出来的都不一样，我妹妹想的是独角兽，所以她的飘浮光芒就是独角兽的形状。"

# game/intro.rpy:371
translate english intro_mage_a0d6188e:

    # rosa "Это так интересно. Как жаль, что во мне нет магии."
    rosa "真是太有趣了。可惜我身上没有魔法。"

# game/intro.rpy:373
translate english intro_mage_a8cc6ad5:

    # mc "Откуда ты это знаешь?"
    mc "你怎么知道没有呢？"

# game/intro.rpy:374
translate english intro_mage_090e7ab5:

    # rosa "Я...я не могу делать что-то подобное."
    rosa "我……我没法使出像你那样的东西。"

# game/intro.rpy:375
translate english intro_mage_97bbe872:

    # mc "Все потому что рядом с тобой не было человека, который мог бы попробовать найти в тебе зачатки магии, пока ты была ребенком."
    mc "那是因为你小时候，身边没有人尝试着帮你探索你体内是否潜藏着魔法的种子。"

# game/intro.rpy:376
translate english intro_mage_775ce749:

    # rosa "[mc]?"
    rosa "[mc]?"

# game/intro.rpy:377
translate english intro_mage_c4bf3c2d:

    # mc "Так жаль, что я потерял, то, что имел, я бы мог показать тебе чудеса куда более интересные, чем эти."
    mc "真是可惜，我把我曾经拥有的东西都丢了，不然我还能给你展示比这不可思议得多的奇迹。"

# game/intro.rpy:378
translate english intro_mage_f3b1755d:

    # rosa "Это очень мило, [mc]."
    rosa "你真好，[mc]。"

# game/intro.rpy:379
translate english intro_mage_44f4560b:

    # mc "Нет, правда, ты заслуживаешь лучшей жизни."
    mc "不我说真的，你应该过上更好的生活。"

# game/intro.rpy:380
translate english intro_mage_46e50585:

    # rosa "Спасибо."
    rosa "谢谢。"

# game/intro.rpy:382
translate english intro_mage_f70a84d8:

    # mc "Вот например что это? Очередной пьяница размахивал руками?"
    mc "那么比如这个是怎么回事呢？又一个酒鬼张牙舞爪留下的？"

# game/intro.rpy:383
translate english intro_mage_ddad35ae:

    # rosa "Это...это просто мелочь. Шрам будет почти незаметный."
    rosa "这……不过是件小事。留下的疤也几乎看不见的。"

# game/intro.rpy:384
translate english intro_mage_7676bfb5:

    # mc "Это портит твою красоту. Красоту которую нужно беречь."
    mc "这东西配不上你的美丽。这份美丽是应当被珍惜的。"

# game/intro.rpy:385
translate english intro_mage_41cf907b:

    # rosa "У меня такая работа, [mc]."
    rosa "我的工作就是跟这些打交道，[mc]。"

# game/intro.rpy:386
translate english intro_mage_a09e11bd:

    # mc "Я знаю, я знаю как ты стараешься. Как отдаешь все силы, просто, чтобы прокормить свою семью. Как ужасно несправедливо, что ты вынуждена страдать."
    mc "我知道，我知道你有多努力。你是如何拼尽全力，就为了养活你的家。你不得不受这些苦，真是太不公平了。"

# game/intro.rpy:388
translate english intro_mage_159c9088:

    # rosa "Что...что ты делаешь?"
    rosa "你……你在做什么？"

# game/intro.rpy:389
translate english intro_mage_6697a254:

    # mc "Тсс. Тише."
    mc "嘘。安静。"

# game/intro.rpy:390
translate english intro_mage_dc212656:

    # rosa "Я чувствую какое-то жжение, ты..."
    rosa "我感觉到有点灼热感，你……"

# game/intro.rpy:392
translate english intro_mage_d46678d4:

    # rosa "О боги! Где моя ранка? Ты убрал ее?"
    rosa "诸神在上！我的小伤口呢？你让它消失了？"

# game/intro.rpy:393
translate english intro_mage_49a24abc:

    # mc "Да. Я пожертвовал своим здоровьем, ради твоей красоты."
    mc "对。我牺牲了自己的健康，来换回你的美丽。"

# game/intro.rpy:394
translate english intro_mage_63182925:

    # rosa "Что значит пожертвовал?"
    rosa "牺牲是什么意思？"

# game/intro.rpy:395
translate english intro_mage_a517638e:

    # mc "Каждый раз, когда маг лечит чьи-то раны, сам он отдает несколько дней своей жизни."
    mc "每次有法师治疗别人的伤口时，他自己就要折损掉几天的寿命。"

# game/intro.rpy:396
translate english intro_mage_108b2dd7:

    # rosa "[mc], о боги, не стоило этого делать."
    rosa "[mc]，噢神啊，你不该这么做的。"

# game/intro.rpy:397
translate english intro_mage_498f4eaa:

    # mc "Все в порядке. Пусть я буду жить на несколько дней меньше, зато в оставшиеся я буду наслаждаться твоей красотой, Роза."
    mc "没关系的。就算我要少活几天，但剩下的日子里，我却能欣赏到你的美丽，Rosa。"

# game/intro.rpy:398
translate english intro_mage_33f7631b:

    # rosa "Мне никто и никогда не говорил такого, и не делал для меня что-то подобное..."
    rosa "从来没有人对我说过这样的话，也从未有人为我做过这样的事……"

# game/intro.rpy:399
translate english intro_mage_ffecb762:

    # mc "Я могу тебя поцеловать?"
    mc "我能亲你一下吗？"

# game/intro.rpy:400
translate english intro_mage_ba31d945:

    # rosa "Да, [mc]..."
    rosa "好的，[mc]……"

# game/intro.rpy:402
translate english intro_mage_5285d73a:

    # mc "{i}Этот трюк со светлячками и заживлением пары царапин работает безотказно.{/i}"
    mc "{i}这招萤火虫加愈合小伤口的把戏，真是百试不爽。{/i}"

# game/intro.rpy:403
translate english intro_mage_34e7b608:

    # mc "{i}Спасибо уроками магии за регулярный секс.{/i}"
    mc "{i}感谢魔法课，让我能有这么规律的性生活。{/i}"

# game/intro.rpy:404
translate english intro_mage_d97a77a5:

    # mc "{i}Осталось лишь немного дожать{/i}"
    mc "{i}就差最后再添把火了。{/i}"

# game/intro.rpy:406
translate english intro_mage_167ee2f6:

    # rosa "[mc], что ты делаешь?"
    rosa "[mc]，你在干什么？"

# game/intro.rpy:407
translate english intro_mage_a755f520:

    # mc "Прости, Роза, но я больше не могу. Если я не смогу насладиться твоей красотой я просто умру."
    mc "对不起，Rosa，可我实在忍不住了。要是不能好好欣赏你的美丽，我真会死的。"

# game/intro.rpy:408
translate english intro_mage_6d1257ee:

    # rosa "Умрешь?"
    rosa "你会死？"

# game/intro.rpy:409
translate english intro_mage_9de64972:

    # mc "Я давно смотрю за тобой, наслаждаюсь твоей грацией посреди грязной таверны, твоим чудесным голосом посреди пьяных песен, твоей добротой посреди этого гнилого мира."
    mc "我已经偷偷看着你很久了，在这肮脏的酒馆中央，沉醉于你的优雅，在酒醉的歌声中，迷醉于你美妙的嗓音，在这个腐烂的世界上，倾慕着你的善良。"

# game/intro.rpy:410
translate english intro_mage_7778ed11:

    # rosa "Ах, [mc]..."
    rosa "啊，[mc]……"

# game/intro.rpy:411
translate english intro_mage_d75ed5ed:

    # mc "Я люблю тебя, Роза."
    mc "我爱你，Rosa。"

# game/intro.rpy:413
translate english intro_mage_187fb504:

    # rosa "[mc], постой."
    rosa "[mc]，等等。"

# game/intro.rpy:414
translate english intro_mage_5fde3b32:

    # mc "Прошу, Роза, дай мне лишь одно мгновенье насладиться тобой."
    mc "求你了，Rosa，就让我跟你亲热片刻吧。"

# game/intro.rpy:415
translate english intro_mage_b7b26b5d:

    # rosa "Ты правда любишь меня?"
    rosa "你真的爱我吗？"

# game/intro.rpy:416
translate english intro_mage_3ca145b0:

    # mc "Больше всего на свете!"
    mc "胜过世间一切！"

# game/intro.rpy:417
translate english intro_mage_b25b4505:

    # mc "{i}Ну может не больше всего на свете, но ты точно где-то среди темного пива и купания в холодной реке летом.{/i}"
    mc "{i}唔，也许不是胜过世间一切，但你至少也排得跟冰过的黑啤、夏天在凉河里洗澡差不多。{/i}"

# game/intro.rpy:419
translate english intro_mage_3f8502f0:

    # mc "Ах, [mc], пожалуйста, только быстрее, ладно?"
    mc "啊，[mc]，求你了，快一点，好吗？"

# game/intro.rpy:420
translate english intro_mage_84155237:

    # rosa "Ах, да. Твой муж. Он тебя совсем не ценит. Но я уважаю вашу любовь и вашу семью. Я попытаюсь сделать все быстро."
    rosa "啊，对。你丈夫。他一点也不珍惜你。但我尊重你们的爱情和你们的家庭。我会试着快一点结束。"

# game/intro.rpy:422
translate english intro_mage_bfbbb960:

    # mc "{i}Что за чушь я несу?{/i}"
    mc "{i}我到底在胡扯些什么？{/i}"

# game/intro.rpy:423
translate english intro_mage_c3187d41:

    # rosa "Что ты делаешь?"
    rosa "你在干什么？"

# game/intro.rpy:424
translate english intro_mage_4d6daee5:

    # mc "{i}Кажется эффект он моих сладких речей не будет длиться вечно.{/i}"
    mc "{i}看来我甜言蜜语的效果不是永恒的。{/i}"

# game/intro.rpy:425
translate english intro_mage_b161f543:

    # mc "{i}Нужно заканчивать свое грязное дело и уходить.{/i}"
    mc "{i}得赶紧把我的坏事办完然后开溜。{/i}"

# game/intro.rpy:427
translate english intro_mage_c53bc34d:

    # mc "Я никогда не чувствовал себя так хорошо. Ты чудесна, Роза."
    mc "我从来没感觉这么好过。你真是太美妙了，Rosa。"

# game/intro.rpy:428
translate english intro_mage_63732b0a:

    # rosa "Правда?"
    rosa "真的？"

# game/intro.rpy:429
translate english intro_mage_0fb8d05e:

    # mc "Конечно. Ты так удивлялась красоте магических светлячков, хотя никакой светлячок не сравниться в красоте с тобой."
    mc "当然。你刚才还为那些魔法萤火虫的美丽而惊叹，可这世上哪有什么光点能跟你比美。"

# game/intro.rpy:430
translate english intro_mage_bf65f71b:

    # rosa "Ты...ты ведь не говоришь так всем?"
    rosa "你……你对谁不是都这么说吧？"

# game/intro.rpy:431
translate english intro_mage_6bfecc54:

    # mc "{i}Конечно да.{/i}"
    mc "{i}当然是了。{/i}"

# game/intro.rpy:432
translate english intro_mage_06be3f13:

    # mc "Конечно нет! Знаешь, только сейчас я понял, что такое заниматься любовью. До этого я лишь утолял свои плотские желания."
    mc "当然不是！你知道吗，我到现在才明白，什么叫作真正的做爱。在这之前，我不过是满足肉欲罢了。"

# game/intro.rpy:433
translate english intro_mage_47ad159d:

    # rosa "А со мной?"
    rosa "那跟我呢？"

# game/intro.rpy:434
translate english intro_mage_4244669b:

    # mc "С тобой все по-другому, Роза. Я чувствую как бьется твое сердце, я так хочу чтобы оно было моим... Как жаль что ты отдала его другому..."
    mc "跟你一切都不同了，Rosa。我能感觉到你的心跳，我是多么希望这颗心能属于我……可惜，你却把它交给了别人……"

# game/intro.rpy:435
translate english intro_mage_61a1fb62:

    # rosa "Я могла бы... Мы можем убежать, [mc]."
    rosa "我可以……我们可以私奔，[mc]。"

# game/intro.rpy:436
translate english intro_mage_bba0af0a:

    # mc "{i}Вот черт.{/i}"
    mc "{i}见鬼。{/i}"

# game/intro.rpy:437
translate english intro_mage_e2154622:

    # mc "Я бы хотел этого. Я был бы так счастлив... Но боги были свидетелями твоего брака. Как я могу плюнуть на тех, кто наградил тебя этой красотой?"
    mc "我也想这样。能那样我该多幸福……但诸神见证过你的婚姻。他们赐予了你如此的美貌，我又怎能唾弃他们呢？"

# game/intro.rpy:438
translate english intro_mage_b6221627:

    # rosa "Я...я не знаю. Я запуталась."
    rosa "我……我不知道。我脑子全乱了。"

# game/intro.rpy:439
translate english intro_mage_b8187151:

    # mc "Я тоже, Роза. Жизнь такое тяжелое испытание. Как хорошо...."
    mc "我也是，Rosa。生活真是个沉重的考验。真好啊……"

# game/intro.rpy:440
translate english intro_mage_71a1efb6:

    # rosa "Как хорошо, что?"
    rosa "真好啊，什么？"

# game/intro.rpy:442
translate english intro_mage_f5329187:

    # mc "Мне сейчас ХОРОШО!"
    mc "此刻，我好得不得了！"

# game/intro.rpy:443
translate english intro_mage_57fb2ce6:

    # rosa "Ты сделал это внутрь?"
    rosa "你全都射在里面了？"

# game/intro.rpy:444
translate english intro_mage_c22231f2:

    # mc "Прости меня, Роза. Прости меня!"
    mc "原谅我，Rosa。饶恕我吧！"

# game/intro.rpy:445
translate english intro_mage_4b227024:

    # rosa "Все... все нормально."
    rosa "没……没事。"

# game/intro.rpy:446
translate english intro_mage_87d88ceb:

    # mc "Точно?"
    mc "真的？"

# game/intro.rpy:447
translate english intro_mage_2228e1e5:

    # rosa "Да... Когда мы увидимся снова?"
    rosa "对……我们什么时候能再见面？"

# game/intro.rpy:448
translate english intro_mage_4a8ceecf:

    # mc "Я не знаю. Сейчас мне так стыдно!"
    mc "我不知道。现在我心里充满了羞愧！"

# game/intro.rpy:449
translate english intro_mage_56f6bd4a:

    # rosa "Стыдно?"
    rosa "羞愧？"

# game/intro.rpy:451
translate english intro_mage_6c6f4bfe:

    # mc "Стыдно, что я не смог сдержать себя и изнасиловал тебя!"
    mc "羞愧我竟然没能控制住自己，玷污了你！"

# game/intro.rpy:452
translate english intro_mage_19b2f9e2:

    # rosa "Ты меня не насиловал. Я сама хотела."
    rosa "你没有玷污我。是我自己自愿的。"

# game/intro.rpy:453
translate english intro_mage_1dd507b4:

    # mc "Я знаю, но все равно я сделал это из-за своих желаний. Я переспал с замужней и это моя вина, полностью. Не твоя. Я хочу побыть один и обдумать."
    mc "我知道，但终归是我为了满足自己的欲望才这么做。我跟一个有夫之妇上了床，这完全是我的错。不是你的。我想一个人待会儿，好好想想。"

# game/intro.rpy:454
translate english intro_mage_a4b4ff69:

    # rosa "Ты больше не вернешься?"
    rosa "你不会再来了吗？"

# game/intro.rpy:455
translate english intro_mage_97e89103:

    # mc "Вернусь..."
    mc "会再来的……"

# game/intro.rpy:456
translate english intro_mage_ba62f011:

    # mc "{i}Когда снова захочу тебя трахнуть.{/i}"
    mc "{i}等下次想干你的时候。{/i}"

# game/intro.rpy:457
translate english intro_mage_24850ed1:

    # mc "Когда моя душа снова будет рваться на куски от того что я не вижу мою любовь..."
    mc "等我无法见到我的挚爱而灵魂痛苦破碎的时候……"

# game/intro.rpy:461
translate english intro_intelligence_a51a6e60:

    # mc "Странно, это не дубовая бочка."
    mc "有点奇怪，这橡木桶不是橡木的。"

# game/intro.rpy:462
translate english intro_intelligence_0414246d:

    # rosa "И что?"
    rosa "那又怎样？"

# game/intro.rpy:463
translate english intro_intelligence_9fbd5cf3:

    # mc "А то, веллебургское красное хранится только в дубе. Это традиция."
    mc "什么那又怎样，韦勒堡红酒只用橡木桶贮存。这是传统。"

# game/intro.rpy:464
translate english intro_intelligence_f657c020:

    # rosa "Ну может у них там дубы кончились?"
    rosa "说不定他们那儿的橡树死光了呢？"

# game/intro.rpy:465
translate english intro_intelligence_1f761b35:

    # mc "Я думаю это подделка. Восковая печать имеет дефекты. Скорее всего она наносилась не штампом, а вдавливалась отдельными деталями, например деревяшками."
    mc "我看这是假货。蜡封有瑕疵。极有可能这不是用印模盖出来的，而是用零散的工具压上去的，比如用木片之类。"

# game/intro.rpy:466
translate english intro_intelligence_a649118f:

    # rosa "Откуда ты это знаешь? Ты работаешь с вином?"
    rosa "你怎么会知道这个？你是跟酒打交道的吗？"

# game/intro.rpy:467
translate english intro_intelligence_0f87f1e3:

    # mc "Нет, у меня очень придирчивый учитель. Благодаря ему я кажется знаю все об имперских землях."
    mc "不，是我有个吹毛求疵的老师。托他的福，我大概知道了帝国领土上所有的知识。"

# game/intro.rpy:468
translate english intro_intelligence_74dbafb8:

    # rosa "Даже о вине?"
    rosa "连酒都包括在内？"

# game/intro.rpy:470
translate english intro_intelligence_e602d1a3:

    # mc "Конечно, вино это не просто напиток. То, какое вино пьет человек, и как он его пьет - может многое рассказать о человеке без всяких слов."
    mc "当然了，酒可不单单是饮料。一个人喝什么样的酒，怎么喝酒——不用开口说话，这些细节就能透露很多关于这个人的信息。"

# game/intro.rpy:471
translate english intro_intelligence_fa2990b7:

    # mc "Например гномьи вина с примесью грибной эссенции пьют на севере. Оно не отличается изысканным вкусом и запахом, зато пьянеют от него быстро и выдержать больше пары бокалов могу только самые крепкие."
    mc "比方说，掺了蘑菇精华的矮人酒是在北方喝的。这酒不以精致的口感和香味见长，但后劲来得快，而且能挺得过几大杯还不倒的，也只剩硬汉中的硬汉。"

# game/intro.rpy:472
translate english intro_intelligence_3a18ee1c:

    # mc "На юге напротив ценят вкус. При этом южан можно отличить не только по цвету кожи, но и по привычке делать первый глоток из кубка который они наливают вам."
    mc "而在南方，人们则恰恰看重品味。而且，要分辨南方人，不光靠肤色，也靠他们倒酒给您后自己先抿一小口杯中酒的习惯。"

# game/intro.rpy:473
translate english intro_intelligence_2a2f7acd:

    # mc "Все из-за того, что юг это родина ядов, и гостя часто нужно убеждать что ты не собрался его убить."
    mc "全因为南方是毒药的发源地，常常需要让客人确信你没打算要毒死他。"

# game/intro.rpy:474
translate english intro_intelligence_b3534f9c:

    # mc "На западе вообще предпочитают пиво, а вино там принято пить только без еды."
    mc "而在西部，大家普遍更爱啤酒，在那里喝葡萄酒时通常是不吃东西的。"

# game/intro.rpy:475
translate english intro_intelligence_74f66bd4:

    # mc "Стоит ли говорить, что видов вина там не очень много."
    mc "更不必提，那里的酒种也不是很多。"

# game/intro.rpy:477
translate english intro_intelligence_3fd6c64f:

    # mc "То ли дело столица! Там пьют десятки видов вина."
    mc "但帝都可就另当别论了！那里的人们喝几十种酒。"

# game/intro.rpy:478
translate english intro_intelligence_4cff7323:

    # mc "Там говорят если человек не пьет вино он либо ребенок, либо умер."
    mc "那儿有这么种说法，说人要是不喝酒，要么是小孩，要么就是死人。"

# game/intro.rpy:479
translate english intro_intelligence_e7249ea8:

    # mc "В столице его все пьют и все по-разному."
    mc "在帝都，人人都喝，但每个人的喝法又都各有千秋。"

# game/intro.rpy:480
translate english intro_intelligence_07f1423a:

    # mc "Например если человек не опускает кубок с вином на стол пока его не допьет, значит он почти наверняка дворянин. Есть у них такая традиция."
    mc "比如，要是有人不把酒杯放回桌上，端着直到喝干，那这个人几乎肯定是位贵族。他们有这个传统。"

# game/intro.rpy:481
translate english intro_intelligence_0002739a:

    # mc "Крестьяне первый глоток отдают земле. Солдаты бьются кубками о кубки, проливая вино во все стороны."
    mc "农民们会把第一口酒敬献土地。士兵们则会让杯与杯重重相碰，将酒洒得四处都是。"

# game/intro.rpy:482
translate english intro_intelligence_72ae9246:

    # mc "А в императорской семье, теперь уже в королевской принято пить только аранское золотое."
    mc "而在皇室——如今只好称王室了——则只喝阿兰黄金酒。"

# game/intro.rpy:484
translate english intro_intelligence_0f49c0d8:

    # mc "Рассказать про него... Ты слушаешь, Роза?"
    mc "要细说这酒的话……你在听吗，Rosa？"

# game/intro.rpy:485
translate english intro_intelligence_147e18c8:

    # rosa "..."
    rosa "..."

# game/intro.rpy:486
translate english intro_intelligence_2a72ed89:

    # mc "Ты уснула?"
    mc "你睡着了？"

# game/intro.rpy:487
translate english intro_intelligence_147e18c8_1:

    # rosa "..."
    rosa "..."

# game/intro.rpy:488
translate english intro_intelligence_97023b47:

    # mc "{i}Мда, жаль не многие могут понять всю значимость культуры потребления вина.{/i}"
    mc "{i}唉，可惜没几个人能领悟酒文化中蕴含的深意。{/i}"

# game/intro.rpy:489
translate english intro_intelligence_41aacbac:

    # mc "{i}Впрочем плевать. Кажется надо было отнести эту бочку наверх.{/i}"
    mc "{i}不过算了。看样子我得自己把这桶搬上去了。{/i}"

# game/intro.rpy:493
translate english intro4_90c66e21:

    # "Некоторое время спустя."
    "过了一会儿。"

# game/intro.rpy:494
translate english intro4_b18bacb1:

    # mc "Кажется эта последняя."
    mc "这好像是最后一桶了。"

# game/intro.rpy:496
translate english intro4_5f29aa93:

    # juno "Закончил с бочками?"
    juno "酒桶搬完了？"

# game/intro.rpy:497
translate english intro4_2c45ebe6:

    # mc "Да. Могу идти?"
    mc "嗯。我可以走了吗？"

# game/intro.rpy:498
translate english intro4_69656807:

    # juno "Странный ты парень, [mc]. Влиятельные люди интересуются тобой. Друзья твои платят золотыми монетами. Сам ты полуэльф, при это не побираешься и не живешь в лесу."
    juno "你还真是个奇怪的家伙，[mc]。有头有脸的人在打听你。你的朋友付账用金币。你自己又是个半精灵，却不乞讨，也不住在森林里。"

# game/intro.rpy:499
translate english intro4_2b35b6fe:

    # mc "..."
    mc "..."

# game/intro.rpy:500
translate english intro4_3ceb20d5:

    # juno "Чую накликаешь ты беду на меня."
    juno "我感觉你迟早会给我招来祸事。"

# game/intro.rpy:501
translate english intro4_b371f34d:

    # mc "Короче я пошел."
    mc "总之我先走了。"

# game/intro.rpy:502
translate english intro4_3583b8f1:

    # juno "Иди, [mc], иди. Пусть боги благославлят твою дорогу. Надеюсь она будет приводить тебя к мне пореже."
    juno "走吧，[mc]，走吧。愿诸神保佑你的路。希望这条路以后能少些把你带到我这儿来。"

# game/intro.rpy:503
translate english intro4_054bbe14:

    # mc "Ага, вечером зайду в таверну у моста. Местная хозяйка всегда рада моим деньгам."
    mc "嗯，我傍晚会去桥头那边的酒馆。那儿的老板娘可一向欢迎我的钱。"

# game/intro.rpy:505
translate english intro4_d174dc7c:

    # mc "Очередное утро в это богом забытом месте."
    mc "在这个被神遗忘的鬼地方，又迎来了一个早晨。"

# game/intro.rpy:506
translate english intro4_1a300dec:

    # mc "Кажется я пропустил тренировку. И магические занятия. И уроки геральдики. Черт я вчера кажется целый день только пил."
    mc "我好像错过了训练。还有魔法课。还有纹章学课。见鬼，我昨天怕是喝了一整天的酒。"

# game/intro.rpy:507
translate english intro4_028b39de:

    # mc "Пора домой."
    mc "该回家了。"

# game/intro.rpy:511
translate english intro5_84f126e8:

    # mc "{i}Прошло столько лет, с тех пор как меня сюда привезли. Я уже начинаю забывать как выглядел имперский двор, где провел детство.{/i}"
    mc "{i}我被送到这里已经过去这么多年了。我都快要开始忘记我度过童年的帝国皇宫是什么模样了。{/i}"

# game/intro.rpy:512
translate english intro5_189e3ce6:

    # mc "{i}Интересно, отец хоть когда-нибудь вернет меня обратно? А если он умрет? Что-то я не думаю, что кто-то пошлет за мной, как за наследником. Неужели я и сгнию здесь?{/i}"
    mc "{i}真是好奇，父亲到底会不会把我接回去？要是他死了呢？我怎么觉得没人会派人来接我回去当继承人。难道我就真在这儿烂掉吗？{/i}"

# game/intro.rpy:513
translate english intro5_99ab8b8a:

    # mc "{i}Хотя это не самое плохое место. Люди здесь простые, добрые и...{/i}"
    mc "{i}不过，这地方也不算最差。这里的人淳朴、善良，而且……{/i}"

# game/intro.rpy:515
translate english intro5_60d12092:

    # kitg "БУ!"
    kitg "哇！"

# game/intro.rpy:516
translate english intro5_4b24a8bd:

    # mc "Воу, девочка, ты чего?"
    mc "嚯，小姑娘，你这是干嘛？"

# game/intro.rpy:517
translate english intro5_a3e7a2a4:

    # kitg "Страшно?"
    kitg "吓着了吧？"

# game/intro.rpy:518
translate english intro5_eba90524:

    # mc "Не очень, но если это была засада, то ты застала меня врасплох."
    mc "不怎么怕，但如果这算是埋伏，那你确实打得我措手不及。"

# game/intro.rpy:519
translate english intro5_6ad75ed0:

    # kitg "Это не засада! Я великая волшебница и прорицательница! Наша встреча предрешена, как и все последующие."
    kitg "这可不是埋伏！我是伟大的法师和预言家！我们的相遇是注定的，就像往后一切的发生一样！"

# game/intro.rpy:520
translate english intro5_ab245c3a:

    # mc "Прорицательница?"
    mc "预言家？"

# game/intro.rpy:522
translate english intro5_a778d43d:

    # kitg "Ага. Дай руку, я тебе погадаю."
    kitg "嗯哼。把手伸出来，我给你算算命。"

# game/intro.rpy:523
translate english intro5_f077cb18:

    # mc "У меня ничего ценного нет, можешь даже не надеяться меня обокрасть."
    mc "我身上没带什么值钱的东西，想偷我那是痴心妄想。"

# game/intro.rpy:524
translate english intro5_42eed3b2:

    # kitg "Я же говорю - я прорицательница, а не воровка."
    kitg "我不是说了嘛——我是预言家，不是贼。"

# game/intro.rpy:525
translate english intro5_6acbdda4:

    # mc "Нда? И почему же ты хочешь предсказать будущее именно мне?"
    mc "是吗？那你为什么偏挑我来预言未来呢？"

# game/intro.rpy:526
translate english intro5_77f54e21:

    # kitg "Ты кровь от крови, двойной приплод и дурное семя. Таких не много, но тот что разрушит и цепи и шеи - один."
    kitg "你是血中之血，双倍的孽种，坏种子。这种人不多，但那个会摧毁锁链也会摧毁脖颈的人——只有一个。"

# game/intro.rpy:527
translate english intro5_c4f0c18f:

    # mc "Эм...мне этого ничего не говорит."
    mc "呃……我听不懂你在说什么。"

# game/intro.rpy:528
translate english intro5_6f9cb3fd:

    # kitg "Дай руку, я расскажу больше."
    kitg "伸出手来，我跟你细说。"

# game/intro.rpy:533
translate english future_13aff538:

    # mc "Ну ладно, предсказывай."
    mc "得，行，那你预言吧。"

# game/intro.rpy:534
translate english future_8a6e50f9:

    # kitg "..."
    kitg "..."

# game/intro.rpy:535
translate english future_2b35b6fe:

    # mc "..."
    mc "..."

# game/intro.rpy:536
translate english future_8a6e50f9_1:

    # kitg "..."
    kitg "..."

# game/intro.rpy:537
translate english future_9ce00065:

    # mc "Ты будешь..."
    mc "你将……"

# game/intro.rpy:538
translate english future_1d7622ff:

    # kitg "Три змеи обвили твою шею, elan'or, не душат и не кусают, но следят за каждым твоим движением."
    kitg "三条蛇缠绕在你的脖颈间， elan'or，它们既不窒息也不噬咬，却监视着你的一举一动。"

# game/intro.rpy:539
translate english future_7dbdd6fd:

    # kitg "Хвосты их тянутся так далеко, что по ним ты можешь взобраться к себе домой."
    kitg "它们的尾巴拖向远处，远到你沿着它们就能爬回你故乡的家。"

# game/intro.rpy:540
translate english future_9e7b1982:

    # kitg "Один хвост тянется в колыбель, другой обвивает трон, третий держит кинжал над золотой короной."
    kitg "一条尾巴没入摇篮，另一条缠绕王座，第三条则握着一把匕首，悬在金王冠之上。"

# game/intro.rpy:541
translate english future_ac266744:

    # oldg "{b}Помни, Anor d'Anor, отрежешь голову одной змее - остальные начнут душить тебя и друг друга, отрежешь голову всем и упадешь в бездну.{/b}"
    oldg "{b}记着，Anor d'Anor，若你斩下一条蛇的头——其余蛇就会开始勒死你和彼此，若你将所有蛇头统统斩下，你就会坠入深渊。{/b}"

# game/intro.rpy:542
translate english future_dba0938b:

    # mc "{i}Что произошло с ее голосом?{/i}"
    mc "{i}她的声音是怎么了？{/i}"

# game/intro.rpy:544
translate english future_bd73940f:

    # oldg "Это все, [mc]."
    oldg "说完了，[mc]。"

# game/intro.rpy:545
translate english future_2ceff1ce:

    # mc "Какого хрена..."
    mc "这他妈什么鬼……"

# game/intro.rpy:546
translate english future_65bd5c4b:

    # oldg "Дашь монетку бабушке, за предсказание?"
    oldg "给老人家一枚硬币吧，就当为这预言付个账？"

# game/intro.rpy:548
translate english future_acafb2ea:

    # mc "Что это еще за херня, ты же была ребенком!"
    mc "这他娘的又是什么玩意儿，你刚才明明还是个小孩子！"

# game/intro.rpy:549
translate english future_3e0a0b0b:

    # oldg "Я? Я никогда никем и не была, [mc], БЕГИ! БЕГИ ПОКА ТВОИ НОГИ ЕЩЕ НЕ СВЯЗАННЫ, ААХАХХАХАХА!"
    oldg "我？我从来什么都不是，什么也不是，[mc]，快跑！趁你的双腿还没被捆住，快跑，啊哈哈哈哈哈哈！"

# game/intro.rpy:550
translate english future_7a876076:

    # mc "Что это за..."
    mc "这到底是……"

# game/intro.rpy:552
translate english future_2e01447b:

    # mc "...магия?"
    mc "……什么妖法？"

# game/intro.rpy:553
translate english future_7dd3e126:

    # mc "{i}Надеюсь это не последствия моих частых посещений таверны. Нет. Это определенно было взаправду. Она сказала что-то там про змей и просто испарилась?{/i}"
    mc "{i}希望这不是我泡酒馆太勤的后果。不。这绝对是真真切切发生的。她叽里呱啦说了堆关于蛇的话然后就这么人间蒸发了？{/i}"

# game/intro.rpy:554
translate english future_cee2bab8:

    # mc "{i}Оставила бы хотя бы записку. У меня от страха все их головы вылетело.{/i}"
    mc "{i}至少留张字条啊。吓得我那些蛇头什么的全都忘光了。{/i}"

# game/intro.rpy:559
translate english future_f4c4d64b:

    # mc "Мне предсказания не нужны."
    mc "我不需要预言。"

# game/intro.rpy:560
translate english future_829e29f8:

    # kitg "Хм... Такого я не ожидала, ты интереснее, чем мне сначала показалось."
    kitg "嗯……这可没料到，你比我对你最初的感觉更有意思啊。"

# game/intro.rpy:565
translate english intro6_81d344d5:

    # mc "{i}Мил полон странных людей.{/i}"
    mc "{i}这世界上尽是些奇怪的人。{/i}"

# game/intro.rpy:566
translate english intro6_1682695d:

    # mc "{i}Некоторых из них можно встретить даже за пределами таверны.{/i}"
    mc "{i}其中有一些，居然在酒馆外面也能碰到。{/i}"

# game/intro.rpy:568
translate english intro6_ccef45a1:

    # aker "Стоять, принц, за вашу голову назначена награда. И я намерен ее получить."
    aker "站住，王子，你这颗脑袋可是值一大笔赏金。我打算把它领走。"

# game/intro.rpy:569
translate english intro6_3f939a30:

    # mc "Кого? Голову или награду?"
    mc "领什么？我的脑袋还是赏金？"

# game/intro.rpy:570
translate english intro6_48217931:

    # aker "И то и другое конечно же."
    aker "当然是两样都要了。"

# game/intro.rpy:571
translate english intro6_9860fba4:

    # mc "А может мы сможем договориться?"
    mc "那，咱们能不能打个商量？"

# game/intro.rpy:572
translate english intro6_08686a68:

    # aker "Не думаю, награду предлагают колоссальную. Я бы и сестре свой голову отрезал за такие деньжищи."
    aker "恐怕没戏，那赏金可实在多到吓人。为了这么多钱，哪怕是我亲妹妹的脑袋，我也照砍不误"

# game/intro.rpy:574
translate english intro6_c2cab73a:

    # aker "Ну и что будешь делать, юный принц? Ждать пока я убью тебя?"
    aker "那你现在打算怎么办，年轻的王子？就等着我把你宰了吗？"

# game/intro.rpy:575
translate english intro6_61fba94e:

    # mc "Я...я кажется потерял меч."
    mc "我……我好像把剑弄丢了。"

# game/intro.rpy:576
translate english intro6_b15da225:

    # aker "Опять? Может ты опять заложил его в таверне?"
    aker "又弄丢了？你该不是又把它押在酒馆了吧？"

# game/intro.rpy:577
translate english intro6_67b4a878:

    # mc "Нет, ты же заплатил за меня вчера."
    mc "没有，你昨天不是替我付了酒钱嘛。"

# game/intro.rpy:578
translate english intro6_adca6ef2:

    # aker "Я? Еще чего. Я трачу серебро только на женщин и оружие. И кстати не увиливай, я все еще намерен напасть и убить тебя."
    aker "我？怎么可能。我的银子要么花在女人身上，要么就花在兵刃上。对了，别想扯开话题，我还是打算袭击你，然后干掉你。"

# game/intro.rpy:581
translate english intro6_17367639:

    # mc "А как же правило чести? Может хотя бы дашь мне нож?"
    mc "那荣誉准则呢？至少给我把刀吧？"

# game/intro.rpy:582
translate english intro6_0814c666:

    # aker "По-твоему наемный убийца даст тебе нож? Ну ты и мечтатель, [mc]."
    aker "你觉得我一个杀手会给你武器？你可真会做梦，[mc]。"

# game/intro.rpy:583
translate english intro6_322fdf26:

    # mc "Я может и мечтатель, зато ты ведрятель."
    mc "我可能是在做梦，但你可是个酒桶。"

# game/intro.rpy:584
translate english intro6_d9328a46:

    # aker "Что?"
    aker "什么？"

# game/intro.rpy:586
translate english intro6_92894644:

    # mc "А вот что!"
    mc "看招！"

# game/intro.rpy:587
translate english intro6_f95b54db:

    # aker "Ауч!"
    aker "哎哟！"

# game/intro.rpy:588
translate english intro6_e3a9bd05:

    # mc "Как тебе такое?"
    mc "这一下子滋味如何？"

# game/intro.rpy:590
translate english intro6_b92d596b:

    # aker "Использование окружающей обстановки, очень изобретательно..."
    aker "利用周围环境里的东西，你还真有想法……"

# game/intro.rpy:591
translate english intro6_c34ba252:

    # mc "Это еще не все!"
    mc "还没完呢！"

# game/intro.rpy:593
translate english intro6_4ed755ba:

    # mc "Подножка, удар по спине, выпад и я отрубаю тебе голову."
    mc "腿下一扫，背上一击，再挺身一刺，便能取你项上首级！"

# game/intro.rpy:594
translate english intro6_b024a6a5:

    # aker "Невидимым мечом?"
    aker "拿那柄看不见的隐形剑？"

# game/intro.rpy:595
translate english intro6_54c25197:

    # mc "Ну я бы отрубил тебе голову ведром, но оно откатилось в сторону."
    mc "我原本是想用水桶砍你脑袋的，可它自个儿滚一边去了。"

# game/intro.rpy:596
translate english intro6_2c5ded66:

    # aker "Ладно, сделаем вид, что я умер от твоей шутки про ведрятеля."
    aker "行吧，就当我被你那段关于酒桶的傻话给乐死了吧。"

# game/intro.rpy:597
translate english intro6_2e622608:

    # mc "Эй, а вот это обидно."
    mc "嘿，这也太伤人了。"

# game/intro.rpy:600
translate english intro6_d8611d6c:

    # mc "В таком случае я прямо сейчас лишу тебя зрения."
    mc "既然这样，我现在就让你失去视力。"

# game/intro.rpy:601
translate english intro6_e334d38c:

    # aker "Постоянно забываю, что ты сраный волшебник. Это на долго?"
    aker "我总是忘了你这家伙还是个操蛋的法师。这能持续多久？"

# game/intro.rpy:602
translate english intro6_1772799d:

    # mc "Слепота? От нескольких секунд до нескольких часов. Зависит от того, хочешь ли ты все еще меня убить."
    mc "致盲术？从几秒到几小时不等吧。那得看，你是不是还想着要杀我了。"

# game/intro.rpy:603
translate english intro6_11313681:

    # aker "Нужно сказать, что желание пропадает."
    aker "不得不说，我这念头现在快没了。"

# game/intro.rpy:604
translate english intro6_9399b81f:

    # mc "Кстати от этого заклинания еще хрен не стоит пару дней."
    mc "还有，顺便一提，中了这法术，接下来几天你那玩意儿会硬不起来。"

# game/intro.rpy:605
translate english intro6_692e6592:

    # aker "Я сдаюсь."
    aker "我投降。"

# game/intro.rpy:608
translate english intro6_22802ab2:

    # mc "Согласно грамоте вольных городов любое убийство на их территории безоружного человека карается смертью."
    mc "依照自由城市契约，任何在其地界上杀害手无寸铁之人的行径，都将被处以死刑。"

# game/intro.rpy:609
translate english intro6_74508bce:

    # aker "И что?"
    aker "那又怎样？"

# game/intro.rpy:610
translate english intro6_465d8f38:

    # mc "А то. Сейчас день, вокруг полно народу. Даже если ты убьешь меня за считаные секунды я успею закричать, люди тут же доложат страже и твоя поимка и казнь дело пары часов."
    mc "就是那样。现在是白天，周围全是人。就算你能几秒内了结我，但足够我呼救，到时候人们立马就会报告给守卫，逮捕你然后将你正法，不过是几个时辰的事。"

# game/intro.rpy:611
translate english intro6_df61b70b:

    # aker "По-твоему это сработает на наемного убийцу?"
    aker "你觉得这套说辞对一个杀手有用吗？"

# game/intro.rpy:612
translate english intro6_b05577b5:

    # mc "Ну если он не полный идиот, то попытается убить меня более незаметно, например отравит мне пиво."
    mc "他要不是个彻头彻尾的蠢货，就会换个更隐秘的杀法，比如在我酒里下毒。"

# game/intro.rpy:613
translate english intro6_f69398ef:

    # aker "Хех, ну такой шанс мне еще представится."
    aker "呵，行啊，往后这种机会还多的是呢。"

# game/intro.rpy:615
translate english intro6_f87d6d53:

    # aker "Что-то ты стал пропускать тренировки, [mc]."
    aker "你最近可是越来越爱翘训练了，[mc]。"

# game/intro.rpy:616
translate english intro6_7eef462d:

    # mc "Можно подумать ты сильно расстроен."
    mc "说得好像你有多失落似的。"

# game/intro.rpy:617
translate english intro6_5f77c2dc:

    # aker "Будущему королю важно уметь орудовать мечом."
    aker "对未来的国王来说，精通剑术那可是关键得很啊。"

# game/intro.rpy:618
translate english intro6_a5763691:

    # mc "Ага. Будущему королю чего? Блох, этой улицы? Я же тут и сдохну."
    mc "啊哈。我算什么未来国王什么的？这个街区的跳蚤之王吗？我怕是得死在这里了。"

# game/intro.rpy:619
translate english intro6_ef4ba037:

    # aker "Так вот почему ты не вылазишь из таверн. Тревожит судьба трона? Не волнуйся. Нужно будет мы твоему папаше отрубим голову, если решит лишить тебя короны."
    aker "原来你老在酒馆里泡着不是为了这个。担心王位不保？别愁眉苦脸的。管他那么多，要是你那老东西老子敢不认你这王冠，我们砍他脑袋就是。"

# game/intro.rpy:620
translate english intro6_5ec3d9e6:

    # mc "Спасибо, Акер."
    mc "谢了啊，Aker。"

# game/intro.rpy:621
translate english intro6_4d1a4793:

    # aker "Не переживай так, пацан, у нас на юге отцы иногда высылают сыновей сразу на плаху, так что у тебя еще все не так плохо."
    aker "别太揪心，小子，我们南边那儿，当爹的有时候直接把儿子送上断头台，你这边还不算坏。"

# game/intro.rpy:622
translate english intro6_f3a3c923:

    # mc "Ага, наверное."
    mc "嗯，大概吧。"

# game/intro.rpy:623
translate english intro6_4540538f:

    # aker "Ладно. Не буду отвлекать. Приходи завтра на плац. Помну тебе бока, принц. Кхм-кхм, точнее сказать блошиный король."
    aker "好了。不打搅你了。明天到营地来。我好好捶你一顿，让你松松骨头，王子殿下。咳咳，该说是跳蚤之王才对。"

# game/intro.rpy:625
translate english intro6_adc863b7:

    # mc "{i}Пахну я и вправду как блошиный король.{/i}"
    mc "{i}我身上的味儿闻起来确实跟跳蚤王差不多。{/i}"

# game/intro.rpy:626
translate english intro6_1e3cea16:

    # mc "{i}Нужно прекращать спать в тавернах. Особенно в тех, где посетители предпочитают блевать и ссать прямо на пол.{/i}"
    mc "{i}不能再在酒馆里过夜了。尤其是那些酒客们酷爱直接在地板上呕吐撒尿。{/i}"

# game/intro.rpy:627
translate english intro6_d397aa07:

    # mc "{i}Сегодня у меня занятия по магии, но думаю леди [alaina] лучше подождет, чем будет вдыхать это трупные ароматы.{/i}"
    mc "{i}我今天还有魔法课呢，但我觉得[alaina]女士宁愿多等一等，也不会想闻我这身死人般的臭味。{/i}"

# game/intro.rpy:629
translate english intro6_eef98b25:

    # mc "{i}Хорошо, что Людвиг всегда держит тут все наготове.{/i}"
    mc "{i}好在Ludwig总在这里把一切都备好了。{/i}"

# game/intro.rpy:630
translate english intro6_21385f12:

    # mc "{i}Ну поджигайся же.{/i}"
    mc "{i}唔，倒是烧起来啊。{/i}"

# game/intro.rpy:631
translate english intro6_406727d9:

    # mc "{i}Опа. Готово. Теперь спущусь вниз и начну греть воду.{/i}"
    mc "{i}嚯，成了。这下我得下楼去，把水烧起来了。{/i}"

# game/intro.rpy:633
translate english intro6_396c128f:

    # "Час спустя."
    "一个小时以后。"

# game/intro.rpy:634
translate english intro6_308f7779:

    # mc "{i}Одно из лучших чувств на земле. Теплая ванна.{/i}"
    mc "{i}世间最美妙的感受之一。泡个热水澡。{/i}"

# game/intro.rpy:635
translate english intro6_80a1abd4:

    # mc "{i}Какое наслаждение. Ничего не сможет испортить мне этот момент.{/i}"
    mc "{i}多么享受啊。此刻没有任何事能破坏我的心情。{/i}"

# game/intro.rpy:637
translate english intro6_135fdbf2:

    # ludwig "Кхм-кхм. Значит вы все-таки вернулись домой. Надо же, в этот раз у вас всего один синяк и даже деревенскую девку с собой не привели. Надо полагать еще несколько десятков лет и вы все же станете неким подобием дворянина. "
    ludwig "咳。这么说，您总算还是回了家。难得啊，这回脸上只有一处淤青，也没有把什么乡下妞儿带回来。大概再过个几十年，您终归能有点贵族的模样了。"

# game/intro.rpy:638
translate english intro6_5783b827:

    # mc "И тебе привет, Людвиг."
    mc "也向你问好，Ludwig。"

# game/intro.rpy:639
translate english intro6_f08f8d8e:

    # ludwig "Если конечно вас к этому моменту не сгубит выпивка."
    ludwig "当然，除非在那之前，您没让酒给毁了。"

# game/intro.rpy:640
translate english intro6_b51441ea:

    # mc "Да ладно тебе, это первый раз за всю неделю."
    mc "得了吧，这一整个星期我不过头一回喝点酒。"

# game/intro.rpy:641
translate english intro6_d1c14e66:

    # ludwig "Наверное мне стоило бы обрадоваться вашей исключительной силе воли, мой принц, но к моему величайшему сожалению сейчас второй день недели."
    ludwig "也许我该为您超凡的意志力而欣喜，我的王子，但遗憾的是，今天才不过是这星期的第二天。"

# game/intro.rpy:642
translate english intro6_e660849a:

    # mc "Правда? Я как то не слежу за временем."
    mc "是吗？我不太留意时间的。"

# game/intro.rpy:643
translate english intro6_4fd852cd:

    # ludwig "Удивительно. Как человек не следящий за временем умудряется спать именно в те часы, когда он должен учить геральдику."
    ludwig "真是奇了。一个不留心时间的人，为何偏偏能挑在您本该上纹章学课的时候睡得正香。"

# game/intro.rpy:645
translate english intro6_439dcb63:

    # mc "Да уж. Неловкая случайность. Что поделать? Может когда-нибудь потом."
    mc "唉，这可真是，不巧得很。能怎么办呢？将就往后推推吧。"

# game/intro.rpy:646
translate english intro6_3b92f75e:

    # ludwig "Ну уж нет. Если вы не ходите на занятия, мой принц, занятия будут ходить за вами. Сейчас мы будем учить гербы северного междуречья."
    ludwig "那可不行。既然您不愿去上课，我的王子，课就会跟着您来。现在，我们来学习一下北方河间地的家族纹章。"

# game/intro.rpy:647
translate english intro6_787a4c23:

    # mc "Я вообще-то моюсь. Отдыхаю."
    mc "我还在洗澡呢。正休息呢。"

# game/intro.rpy:648
translate english intro6_c52edfce:

    # ludwig "Вы вообще-то принц. Будущий король. Было бы ужасно неловко, если бы вы не знали гербы своих вассалов, верно?"
    ludwig "您终究是位王子。未来的国王。要是您连自己封臣的纹章都不认得，那岂不是尴尬得要命，对吧？"

# game/intro.rpy:649
translate english intro6_09a39a62:

    # mc "Думаешь они не стали бы выполнять мои приказы, если бы я не знал у кого какого размера орел на гербе дома?"
    mc "你是认为，就因为我没记住某个家族纹章上的鹰有多大，他们就会拒不执行我的命令吗？"

# game/intro.rpy:650
translate english intro6_66653a33:

    # ludwig "Зависит от того, сколько вы бы выпили перед тем как раздавать приказы, когда вы пришли пьяным в прошлый раз я с трудом понял, что вы хотите в туалет..."
    ludwig "这得取决于，您下令前到底灌了多少黄汤，上回您喝得醉醺醺回来，我费了老大劲才弄清，原来您是想上茅房……"

# game/intro.rpy:651
translate english intro6_b9767c5b:

    # mc "Ладно-ладно, я понял, учим гербы."
    mc "行行行，我懂了，学纹章，我学。"

# game/intro.rpy:653
translate english intro6_599cffb5:

    # ludwig "Отлично. Просто чтобы вы понимали - делаю это не чтобы вас помучить."
    ludwig "很好。只是为了跟您说明白——我这么做，并不是为了折磨您。"

# game/intro.rpy:654
translate english intro6_ab8fc8e5:

    # mc "Я знаю, Людвиг. У тебя священный учительских долг. Ты кстати как собрался читать в такой темноте?"
    mc "我知道，Ludwig。你严守着你神圣的为师职责。不过，这么暗，你怎么看书？"

# game/intro.rpy:655
translate english intro6_2d2ed076:

    # ludwig "Я вас умоляю, я читал эту книгу столько раз, что могу по первой строчке вспомнить, что было на странице."
    ludwig "您就放心吧，这本书我读过太多遍了，随便看到第一行字，我都能想起整页纸写的是什么。"

# game/intro.rpy:656
translate english intro6_3b84064c:

    # mc "У тебя была веселая молодость, да, Людвиг?"
    mc "你年轻时候过得还挺有意思吧，Ludwig？"

# game/intro.rpy:657
translate english intro6_1bc28a3d:

    # ludwig "Всю молодость я провел на войне оруженосцем. Так что если под понятием веселье вы понимаете пьянство и похоть, то пожалуй веселья у меня было гораздо меньше, чем у вас."
    ludwig "我整个青年时代，都是在战争中以侍从身份度过的。所以，如果“有意思”在您嘴里指的是烂醉和纵欲，那我这辈子“有意思”的时候大概比您少得多。"

# game/intro.rpy:658
translate english intro6_bdf9a271:

    # mc "Но все же было, да? Хех. Старый пройдоха."
    mc "但总归还是有的，对吧？嘿，老滑头。"

# game/intro.rpy:659
translate english intro6_f1d0963d:

    # ludwig "Не отвлекайтесь от занятия, мой принц."
    ludwig "别分心，专心听课，我的王子。"

# game/intro.rpy:662
translate english intro6_4f8ca0dd:

    # mc "Забудь, Людвиг. Эту книгу я прочел еще когда жил в королевском замке."
    mc "省省吧，Ludwig。这本书我还在王宫里住的时候就全读过了。"

# game/intro.rpy:663
translate english intro6_4ac2296e:

    # ludwig "Прочесть не значит запомнить."
    ludwig "读过不等于记得住。"

# game/intro.rpy:664
translate english intro6_34bb1771:

    # mc "Я читал ее несколько раз. Мне нравились истории про то как северные лорды убивали друг друга, а гномы обрушивали горы на реки."
    mc "我读过好几次呢。我喜欢里头那些北境领主们互相杀戮，以及矮人们推倒山岳、断截河流的故事。"

# game/intro.rpy:665
translate english intro6_cf81f5b1:

    # ludwig "Это не относится к геральдике. Вот как выглядит герб Стархедов?"
    ludwig "这跟纹章学无关。告诉我，斯达海德家族的纹章是什么样的？"

# game/intro.rpy:666
translate english intro6_2faeda39:

    # mc "Падающая звезда над рекой. Говорят основатель дома, сир Лотрик выковал себе корону из упавшей звезды - отсюда и название дома."
    mc "斗转星落于河川之上。传说他们家的始祖，Lotric爵士，用一颗天坠陨星锻造了自己的冠冕——家族的名号也由此得来。"

# game/intro.rpy:667
translate english intro6_51d7d95e:

    # ludwig "Дом Мосли."
    ludwig "莫斯利家族呢。"

# game/intro.rpy:668
translate english intro6_c89b26fc:

    # mc "Воющая собака на лугу. У нее противный длинный язык. Кажется они разводят охотничьих собак, отсюда и герб."
    mc "吠叫的猎犬立于草甸之上。那狗耷拉着一条讨厌的长舌头。他们好像是培育猎犬的吧，所以才会有这纹章。"

# game/intro.rpy:669
translate english intro6_bb370f89:

    # ludwig "Дом Бартани."
    ludwig "巴塔尼家族。"

# game/intro.rpy:670
translate english intro6_711355a3:

    # mc "Семь белых цветков в форме пирамидки. Вроде только у них растет какой-то редкий цветок."
    mc "七朵呈金字塔状的白色小花。没搞错的话，只有他们家才种着一种罕见的花。"

# game/intro.rpy:671
translate english intro6_c8a6997d:

    # ludwig "Мой принц, кажется это занятие вам и вправду не нужно."
    ludwig "我的王子，看来这堂课对您确实没什么必要。"

# game/intro.rpy:672
translate english intro6_4642eec1:

    # mc "Ага. В следующий раз поищи что-нибудь поинтереснее, ладно, Людвиг?"
    mc "嗯。下次找点更有趣的东西，成吗，Ludwig？"

# game/intro.rpy:673
translate english intro6_aae11c0f:

    # ludwig "Как скажете, мой принц."
    ludwig "如您所愿，我的王子。"

# game/intro.rpy:676
translate english intro6_d2a5d2ef:

    # ludwig "Дом Лартуа - старейший в междуречье, герб - три перекрещенных меча и череп волка. Основатель дома - сир Сонари Лартуа..."
    ludwig "拉尔图亚家族——河间地最古老的家族，纹章是三柄交叉的剑与一具狼的头骨。家族的奠基人——索纳里·拉尔图亚爵士……"

# game/intro.rpy:677
translate english intro6_cf982040:

    # mc "О боги..."
    mc "诸神在上……"

# game/intro.rpy:678
translate english intro6_97dc838b:

    # ludwig "Дом Мосли. Герб - воющий сторожевой пес на лугу, основатель дома - сир Гватар Мосли, по легенде вместе со своим псом месяц охранял императорское золото на холме, пока..."
    ludwig "莫斯利家族。纹章是草甸上警戒的猎犬，奠基者瓜塔·莫斯利爵士，传说中与他忠犬在山上守护了帝国的黄金整整一个月，期间……"

# game/intro.rpy:679
translate english intro6_8d6972d0:

    # mc "{i}Как же это скучно...{/i}"
    mc "{i}这可真是无聊透顶……{/i}"

# game/intro.rpy:681
translate english intro6_251ce08c:

    # ludwig "Дом Саланта, верный союзник и вассал дома Мосли, герб - горная роза и четыре красных полосы..."
    ludwig "萨兰塔家族，莫斯利家的忠实盟友和封臣，纹章是高山玫瑰与四道红色条纹……"

# game/intro.rpy:682
translate english intro6_b29c3df6:

    # mc "{i}Наверное я бы мог убить себя, если бы прямо сейчас набрал полны легкие воды.{/i}"
    mc "{i}也许我现在让水灌满肺，就可以马上解脱了。{/i}"

# game/intro.rpy:683
translate english intro6_9002db59:

    # ludwig "Дом Бартани..."
    ludwig "巴塔尼家族……"

# game/intro.rpy:684
translate english intro6_df583010:

    # mc "{i}Может хотя бы после смерти нет уроков геральдики.{/i}"
    mc "{i}或许死了以后就不用上这纹章课了。{/i}"

# game/intro.rpy:685
translate english intro6_ae93045b:

    # ludwig "Дом Рамовских..."
    ludwig "拉莫夫斯基家族……"

# game/intro.rpy:686
translate english intro6_0851fa08:

    # mc "{i}С другой стороны никто не знает что там, по ту сторону жизни, может после смерти ты только и делаешь, что учишь гербы каких-нибудь богов, в таком случае я бы хотел жить вечно.{/i}"
    mc "{i}可话又说回来，谁知道死后那一边是什么样呢，说不定在那边，你唯一要干的事，就是去学那些个神祇的纹章，要真那样，那我情愿永生不死。{/i}"

# game/intro.rpy:688
translate english intro6_80f07717:

    # ludwig "Юный принц помнит, что сегодня у него уроки магии?"
    ludwig "年轻的王子是否记得，今天还有他的魔法课？"

# game/intro.rpy:689
translate english intro6_0e230450:

    # mc "А? Да. Конечно."
    mc "啊？嗯。当然记得。"

# game/intro.rpy:690
translate english intro6_73095811:

    # ludwig "В таком случае не буду его задерживать. Леди [alaina], очень не любит, когда что-то или кто-то отвлекает принца от занятий. Книгу оставлю у вас на полке."
    ludwig "既然如此，那我便不再耽搁他了。[alaina]女士，最痛恨有任何事或任何人分散王子学业的注意力。这本书我留在您的书架上了。"

# game/intro.rpy:691
translate english intro6_aa737ac0:

    # ludwig "А так как юный принц пропустил вчерашние занятия, думаю леди [alaina] уже невероятно раздражена."
    ludwig "对了，年轻的王子既然错过了昨天的课，我想[alaina]女士现在一定已经怒不可遏了。"

# game/intro.rpy:692
translate english intro6_20834a31:

    # mc "Ты говорил с ней? Она снова будет на меня кричать, может поможешь Людвиг?"
    mc "你跟她聊过了？她肯定又得冲我发火了，你帮帮忙成吗，Ludwig？"

# game/intro.rpy:693
translate english intro6_0a86cf31:

    # ludwig "Чем? Кажется у вас есть на такой случай ваш кровный защитник."
    ludwig "怎么帮？依我看，您这种场合，有您那位血誓护卫就够了。"

# game/intro.rpy:694
translate english intro6_e0acc01a:

    # mc "Ты думаешь потребуется меч?"
    mc "你是指这得动刀剑？"

# game/intro.rpy:695
translate english intro6_cc5e5547:

    # ludwig "Если вы не поторопитесь возможно потребуется гроб."
    ludwig "如果您不快点，可能就得用上棺材了。"

# game/intro.rpy:696
translate english intro6_2be48012:

    # mc "Вот черт, ладно вылажу."
    mc "见鬼，好吧，我这就出来。"

# game/intro.rpy:698
translate english intro6_763ba70e:

    # mc "{i}Леди [alaina] страшна в гневе. До сих пор помню как она зачаровывала мои руки, чтобы они роняли бутылку с выпивкой на землю.{/i}"
    mc "{i}[alaina]女士发怒时可是很可怕的。到现在我都还记得，那时候她对我的双手施了法，让我拿起酒瓶就掉地上。{/i}"

# game/intro.rpy:699
translate english intro6_641b2005:

    # mc "{i}Хорошо что я способен пить используя только рот. Поведение не достойное короля конечно. Но зато я доказал, что могу найти выход из любой ситуации.{/i}"
    mc "{i}幸好，我只用嘴也能喝酒。当然，这不是国王该有的行径。但至少我证明了自己在任何困境下都能找到出路。{/i}"

# game/intro.rpy:700
translate english intro6_c1387ec1:

    # mc "{i}Ладно, хватит воспоминаний, а то я сейчас опоздаю и к ним добавиться еще одно.{/i}"
    mc "{i}好了，别再回忆了，不然真要迟到，又得多一段痛苦的记忆了。{/i}"

# game/intro.rpy:704
translate english intro7_deb8b74f:

    # mc "Тук-тук. Я могу войти?"
    mc "咚咚。我能进来吗？"

# game/intro.rpy:705
translate english intro7_7680ae12:

    # ala "Ты опоздал. А вчера и вовсе не пришел."
    ala "你迟到了。而昨天，你索性连来都没来。"

# game/intro.rpy:706
translate english intro7_fd8f9847:

    # mc "Да...тут такое дело...Я совсем потерял ход времени. Сначала хотел зайти к кузнецу, чтобы он выковал мне новый меч и..."
    mc "是……是这么回事……我完全忘记了时间。我本来是打算先去铁匠铺，让他给我打把新剑，然后……"

# game/intro.rpy:707
translate english intro7_c2ab8c49:

    # ala "Избавь меня от своих лживых оправданий."
    ala "省省你那套虚假的辩解吧。"

# game/intro.rpy:708
translate english intro7_2b35b6fe:

    # mc "..."
    mc "..."

# game/intro.rpy:709
translate english intro7_89a79304:

    # ala "..."
    ala "..."

# game/intro.rpy:710
translate english intro7_439eabe4:

    # mc "Так я могу зайти?"
    mc "那我能进来吗？"

# game/intro.rpy:711
translate english intro7_f7576050:

    # ala "Заходи, [mc]."
    ala "进来吧，[mc]。"

# game/intro.rpy:713
translate english intro7_a90ae2b7:

    # mc "Что? Даже не будете на меня кричать?"
    mc "怎么？您不冲我嚷嚷了吗？"

# game/intro.rpy:714
translate english intro7_8b7cf83c:

    # ala "Я бы очень хотела, но думаю в этом больше нет смысла."
    ala "我是想冲你大喊，可惜我觉得这已经没意义了。"

# game/intro.rpy:715
translate english intro7_d0b1c0b9:

    # mc "Почему?"
    mc "为什么？"

# game/intro.rpy:716
translate english intro7_c5e27cee:

    # ala "Твоя беззаботная жизнь на краю мира заканчивается, [mc]."
    ala "你在世界边缘无忧无虑的日子走到头了，[mc]。"

# game/intro.rpy:717
translate english intro7_16e53adf:

    # mc "Что вы имеете в виду."
    mc "您这话是什么意思？"

# game/intro.rpy:718
translate english intro7_07dbd04b:

    # ala "Ты скоро все узнаешь сам. Садись. Сегодня у нас снова будет сеанс внутренней памяти."
    ala "你很快就会自己明白一切的。坐下。今天，我们又要进行一次内在记忆的冥想。"

# game/intro.rpy:719
translate english intro7_7d00a03a:

    # mc "А может просто снова поучимся задувать свечи на расстоянии, или может гнуть мечи взглядом?"
    mc "咱们能不能再练练隔空吹蜡烛，或者用目光弯折铁剑什么的？"

# game/intro.rpy:720
translate english intro7_6211918a:

    # ala "Сядь в круг, [mc]."
    ala "进到圈里坐好，[mc]。"

# game/intro.rpy:722
translate english intro7_f3ffface:

    # mc "У меня голова болит после подобных занятий."
    mc "这种课，每上一回我都头疼。"

# game/intro.rpy:723
translate english intro7_72193d01:

    # ala "У меня от тебя голова болит постоянно, я же не жалуюсь."
    ala "你这么说我倒是该抱怨，我可是天天为你头疼，而且没抱怨过。"

# game/intro.rpy:724
translate english intro7_c9acbb75:

    # mc "Просто не понимаю зачем это нужно."
    mc "我实在不明白，为什么要这么做。"

# game/intro.rpy:725
translate english intro7_2bb6b9a4:

    # ala "Любой маг..."
    ala "任何法师……"

# game/intro.rpy:726
translate english intro7_a7ff4ee9:

    # mc "Да-да, черпает энергию из себя самого, поэтому так важно познать свою суть и бла-бла."
    mc "是是是，都是从自身内部汲取能量，所以了解自身本质极其重要云云。"

# game/intro.rpy:727
translate english intro7_d1c5af1e:

    # ala "Мне показалось или ты только что пытался меня передразнивать? Лучше прекрати это и займи позу для медитации."
    ala "是我听错了，还是你刚刚在模仿嘲弄我？你最好马上停下，摆好冥想的姿势。"

# game/intro.rpy:729
translate english intro7_3a49ff41:

    # ala "Расслабься. Постарайся думать о себе в прошлом. Ощути бег времени и..."
    ala "放松。试着回想过去的自己。感受时间的流逝和……"

# game/intro.rpy:730
translate english intro7_58f151c3:

    # mc "Я знаю, что делать."
    mc "我知道该怎么做。"

# game/intro.rpy:731
translate english intro7_c71ac7c2:

    # ala "Отлично. Тогда приступим."
    ala "很好。那我们就开始吧。"

# game/intro.rpy:733
translate english intro7_c1d0ce81:

    # ala "Есть пожелания? Ранее детство? Может первый поцелуй? Первая драка? Первая выпитая бутылка веллебургского красного?"
    ala "有什么想看的方向吗？童年早期？或者是初吻？第一次打架？第一次饮尽一瓶韦勒堡红酒？"

# game/intro.rpy:734
translate english intro7_07d07073:

    # mc "Все что вы описали обычно происходит в один и тот же день."
    mc "这些事按您的描述，经常都发生在同一天里。"

# game/intro.rpy:735
translate english intro7_8c8fb369:

    # ala "Может что-нибудь что ты хотел бы забыть?"
    ala "要不要回想一下什么你想忘记的事？"

# game/intro.rpy:736
translate english intro7_21a81295:

    # mc "Я ведь хочу это забыть, зачем мне это вспоминать?"
    mc "既然我想忘记，为什么还要去记起来？"

# game/intro.rpy:737
translate english intro7_0754725b:

    # ala "Может что-нибудь...запретное? Первый раз, когда ты познал природу власти? Когда твой взгляд впервые задержался на короне твоего отца дольше нужного? Когда ты впервые понял, что мог бы убить и быть убитым?"
    ala "那……窥探一下什么禁忌之事呢？你初次体会到权力本质的时候？你头一回目光在自己父亲的王冠上逗留得过久的时候？你第一次明白，自己既可以去杀害他人，也可能被他人杀害的时候？"

# game/intro.rpy:738
translate english intro7_3693193e:

    # mc "Э... а может просто что-нибудь из недавнего?"
    mc "呃……要不就随便回忆下近来的事算了？"

# game/intro.rpy:740
translate english intro7_8117dbbc:

    # ala "Возьми мою руку. Думаю твоя память сама даст ответ."
    ala "握住我的手。我猜你的记忆会自己给出答案。"

# game/intro.rpy:741
translate english intro7_2a83a5bd:

    # mc "Мне не нужно ничего вспоминать?"
    mc "我不用去刻意回想什么？"

# game/intro.rpy:742
translate english intro7_b6972560:

    # ala "Нет. Давай попробуем дать магии самой переплестись с твоими воспоминаниями."
    ala "不用。我们试着让魔法本身与你的回忆交织共舞吧。"

# game/intro.rpy:743
translate english intro7_ac2b1457:

    # mc "Ладно..."
    mc "好吧……"

# game/intro.rpy:744
translate english intro7_8d7256ba:

    # ala "Laurelin amin nauro sîr menelna sîr enwina i nai lambë i coias"
    ala "Laurelin amin nauro sîr menelna sîr enwina i nai lambë i coias"

# game/intro.rpy:745
translate english intro7_2b35b6fe_1:

    # mc "..."
    mc "..."

# game/intro.rpy:746
translate english intro7_0949c82a:

    # ala "Пусть разум твой, elan'or, откроется теням прошлого."
    ala "elan'or，让你的心智，向过往的阴影敞开。"

# game/intro.rpy:748
translate english intro7_e8c8d8de:

    # mc "Я...я вижу...вижу себя..."
    mc "我……我看见了……我看见了，我自己……"

# game/intro.rpy:749
translate english intro7_89a79304_1:

    # ala "..."
    ala "..."

# game/intro.rpy:750
translate english intro7_eddcd748:

    # mc "Незадолго до того как меня отослали сюда..."
    mc "那是在我被送到这里之前不久……"

# game/intro.rpy:751
translate english intro7_da38e0a3:

    # ala "Lenda naa elan'or."
    ala "Lenda naa elan'or."

# game/intro.rpy:753
translate english intro7_baa50441:

    # mc "Не догонишь, не догонишь!"
    mc "追不上，追不上！"

# game/intro.rpy:754
translate english intro7_de51d9ca:

    # elin "Стой, [mc], так не честно! Ты побежал первый!"
    elin "站住，[mc]，这不公平！你自己先开始跑的！"

# game/intro.rpy:755
translate english intro7_85bcbe94:

    # mc "Даже не знаю, [elin], ты точно моя [sister]? Как так вышло, что я намного быстрее тебя?"
    mc "真拿你没办法，[elin]，你到底是不是我[sister]啊？你怎么会跑得比我慢这么多？"

# game/intro.rpy:756
translate english intro7_6d21c325:

    # elin "У меня сапоги неудобные!"
    elin "我这靴子穿着挤脚！"

# game/intro.rpy:757
translate english intro7_7d50055e:

    # mc "А еще ноги слабоваты. И руки. Да и в целом ты слабовата, потому что девчонка."
    mc "还有你的腿也不够壮实。胳膊也是。反正你整个儿就不行，谁叫你是丫头片子呢。"

# game/intro.rpy:758
translate english intro7_c2b647b1:

    # elin "У тебя голова слабовата! Я тебя сейчас догоню и сапог на голову одену."
    elin "你才是脑子不好使呢！我这就追上你，拿靴子扣你脑袋上。"

# game/intro.rpy:759
translate english intro7_e4d56680:

    # mc "Тогда бежать станет еще неудобнее!"
    mc "那你这下跑起来就更别扭啦！"

# game/intro.rpy:761
translate english intro7_a2a16270:

    # elin "Стой, нам нельзя туда, [mc]!"
    elin "停下，咱们不能去那边，[mc]！"

# game/intro.rpy:762
translate english intro7_94ecccbc:

    # mc "Ой, я такая маленькая трусливая курочка, я боюсь бегать куда запрещают, ведь я просто девчонка!"
    mc "哟，我是胆小如鼠的小丫头片子，我怕去那些不准去的地方，谁让我只是个丫头呢！"

# game/intro.rpy:763
translate english intro7_0743ea7f:

    # elin "[mc]!"
    elin "[mc]!"

# game/intro.rpy:764
translate english intro7_426103e9:

    # mc "Бе-бе-бе! Можешь остаться здесь, [elin]."
    mc "咧-咧-咧！你就留在这儿好了，[elin]。"

# game/intro.rpy:765
translate english intro7_f36925e1:

    # elin "Я тебя сейчас убью!"
    elin "我这就去把你杀了！"

# game/intro.rpy:766
translate english intro7_0aca74c3:

    # mc "Сначала догони."
    mc "先追上我再说吧。"

# game/intro.rpy:767
translate english intro7_20c75c6d:

    # elin "Дурак! Там призраки водятся!"
    elin "笨蛋！那边闹鬼的！"

# game/intro.rpy:768
translate english intro7_c7279a39:

    # mc "Говорю же - трусишка!"
    mc "我就说了吧——胆小鬼！"

# game/intro.rpy:770
translate english intro7_00da2f67:

    # elin "[mc]! Стой!"
    elin "[mc]！ 你站住！"

# game/intro.rpy:771
translate english intro7_9716587c:

    # elin "Если здесь водятся призраки, я тебя спасать не буду, ты меня называл девчонкой!"
    elin "要是这里真的闹鬼，我可不会来救你，你刚才还说我是丫头片子来着！"

# game/intro.rpy:773
translate english intro7_e5637538:

    # elin "[mc]? Ты где? Выходи."
    elin "[mc]？ 你在哪儿？快出来。"

# game/intro.rpy:774
translate english intro7_5915c6f8:

    # elin "[mc]..."
    elin "[mc]..."

# game/intro.rpy:775
translate english intro7_87fcbed8:

    # elin "[mc], это уже не смешно! Ты где?"
    elin "[mc]，你这玩笑一点都不好笑！你在哪儿呢？"

# game/intro.rpy:776
translate english intro7_4945aa70:

    # elin "[mc], если ты сейчас не выйдешь я пойду за Людвигом! Он тебе всыпет!"
    elin "[mc]，你要是再不出来，我就去找Ludwig了！他会狠狠揍你一顿的！"

# game/intro.rpy:778
translate english intro7_c050e5c1:

    # mc "БУ!"
    mc "哇！"

# game/intro.rpy:779
translate english intro7_744455e2:

    # elin "Ой!"
    elin "啊哟！"

# game/intro.rpy:780
translate english intro7_10f9b600:

    # mc "Я ЗлОй ПрИзРаК УщЕлЬя СМеРтИ! Я ПРиШеЛ чТОбЫ оТруБиТЬ гОлОВу ТеБЕ и....и ВсЕМ ДевЧоНкАМ!"
    mc "吾乃死亡峡谷之恶灵！吾前来此，为汝与天下所有女娃，取汝之首级，还有..."

# game/intro.rpy:781
translate english intro7_99a0d90e:

    # elin "Ахахахаха, [mc], где ты это нашел?"
    elin "啊哈哈哈哈哈哈，[mc]，你从哪儿找来的这东西？"

# game/intro.rpy:782
translate english intro7_a25707c9:

    # mc "[mc]? Кто такой [mc]? Твой [brother]? Он много наших положил, почти убил короля призраков, но пал, как герой!"
    mc "[mc]？ 谁是[mc]？ 你说的可是你那位[brother]？ 他杀了我弟兄无数，险些取我幽灵之王的首级，可终究是力战而死，真不愧为英雄！"

# game/intro.rpy:783
translate english intro7_a50315e0:

    # elin "Умер и не защитил сестру? Какой же он тогда герой?"
    elin "都死了还没保护好自己的妹妹？这算哪门子英雄？"

# game/intro.rpy:784
translate english intro7_ac31ba9b:

    # mc "Ну как какой...мертвый. Но он еще вернется призраком-рыцарем, только добрым, чтобы защищать Золотую Империю!"
    mc "什么叫什么样的……死了呀。但他还会回来的，以幽灵骑士的身份，不过这次是善良的，为了保护黄金帝国！"

# game/intro.rpy:785
translate english intro7_d5edd75e:

    # elin "А что будет со мной? Я могу стать призраком-рыцарем?"
    elin "那我呢？我能当幽灵骑士吗？"

# game/intro.rpy:786
translate english intro7_64d584ea:

    # mc "Ты? Ты же девочка, нет конечно, тебе я отрублю голову! "
    mc "你？你不是丫头片子嘛，当然不行，我要砍掉你的脑袋！"

# game/intro.rpy:788
translate english intro7_932de2ba:

    # mc "Ой!"
    mc "哎哟！"

# game/intro.rpy:789
translate english intro7_e23e1216:

    # elin "Ахахаха, сир призрак, вы в порядке?"
    elin "哈哈哈哈，幽灵爵士，您还好吗？"

# game/intro.rpy:790
translate english intro7_8be3daa0:

    # mc "Нет, у меня в ушах звенит."
    mc "不，我耳朵里嗡嗡响。"

# game/intro.rpy:791
translate english intro7_c4779d7d:

    # elin "Но вы же призрак, откуда у вас уши?"
    elin "可您是幽灵啊，哪来的耳朵呢？"

# game/intro.rpy:792
translate english intro7_39f03661:

    # mc "У призраков вообще-то есть уши!"
    mc "幽灵当然有耳朵！"

# game/intro.rpy:793
translate english intro7_53540556:

    # elin "А вот и нет!"
    elin "就是没有！"

# game/intro.rpy:794
translate english intro7_6670bc4f:

    # mc "А вот и да! Я сам видел!"
    mc "就有！我自己就亲眼见过！"

# game/intro.rpy:795
translate english intro7_084e9016:

    # elin "Врешь ты все."
    elin "你就是在撒谎。"

# game/intro.rpy:796
translate english intro7_64951858:

    # mc "Нет, правда, Людвиг рассказывал, в подземельях под замком слышен звон метала и ходит призрак в маске! "
    mc "不骗你，Ludwig说，城堡底下的地牢里常有金属铿锵声，还说有一个戴着面具的幽灵走来走去！"

# game/intro.rpy:797
translate english intro7_c88686c5:

    # elin "Так Людвиг рассказывал или ты сам видел? Совсем заврался, [bro]."
    elin "那到底是Ludwig说的，还是你自己亲眼看见的？你也太会撒谎了吧，[bro]。"

# game/intro.rpy:798
translate english intro7_2209cb8a:

    # mc "Ничего я не заврался! И вообще ты девочка, что ты смыслишь в призраках, вам только лошади нравятся!"
    mc "我才没撒谎呢！再说了你一个丫头片子，哪懂什么幽灵，你们就只喜欢马！"

# game/intro.rpy:800
translate english intro7_316d770e:

    # elin "Глупость какая, мне много что нравится."
    elin "胡说八道，我喜欢的东西多了。"

# game/intro.rpy:801
translate english intro7_a332c462:

    # mc "Например? Шитье?"
    mc "比如说？针线活儿？"

# game/intro.rpy:802
translate english intro7_454c2413:

    # elin "Фу, дурак. Мне нравится магия, леди [alaina] и ее уроки."
    elin "呸，笨蛋。我喜欢的是魔法，还有[alaina]女士和她的魔法课。"

# game/intro.rpy:803
translate english intro7_92aa0291:

    # mc "Уроки, фу! Я же говорю девочкам только ерунда нравится."
    mc "上课，恶心！我就说吧，女孩子只喜欢没劲的东西。"

# game/intro.rpy:804
translate english intro7_e5824220:

    # elin "Я хотя бы жуков не давлю."
    elin "至少我可不像你，会去碾死甲虫。"

# game/intro.rpy:805
translate english intro7_9d870fcb:

    # mc "Я их уже давно не давлю, не придумывай. К тому же желтые жуки перешли границу между камнем и рекой, там была граница с муравьями. Я дал клятву муравьям защищать их."
    mc "我早就不碾甲虫了，你少瞎编。再说了，那些黄甲虫侵占了石头和小河间的边界，那边本来是蚂蚁的地盘。我向蚂蚁发过誓要保护它们。"

# game/intro.rpy:806
translate english intro7_890a6f0c:

    # elin "Какая глупость!"
    elin "你这都是什么歪理！"

# game/intro.rpy:807
translate english intro7_59c912c9:

    # mc "И ничего не глупость."
    mc "这就不是歪理。"

# game/intro.rpy:809
translate english intro7_93f87b71:

    # elin "Давай лучше купаться."
    elin "我们干脆去游泳吧。"

# game/intro.rpy:810
translate english intro7_06d840ba:

    # mc "Погоди, ты слышала?"
    mc "等等，你听见没？"

# game/intro.rpy:811
translate english intro7_6b6e7570:

    # elin "Что?"
    elin "听见什么？"

# game/intro.rpy:812
translate english intro7_cc8c6afe:

    # mc "Вроде голоса там, дальше по террасе."
    mc "那边，好像台阶上面有声音。"

# game/intro.rpy:813
translate english intro7_10b021cc:

    # elin "Мы и так далеко зашли. Людвиг не разрешает сюда подниматься."
    elin "我们已经跑得够远了。Ludwig不准我们上那儿去的。"

# game/intro.rpy:814
translate english intro7_5dcec368:

    # mc "Может это воры?"
    mc "会不会是贼？"

# game/intro.rpy:815
translate english intro7_f87cefb0:

    # elin "Воры? На руинах старого замка? И что они воруют? Камни? Лучше залазь сюда, водичка очень тепленькая."
    elin "贼？老城堡的废墟里有贼？他们来偷什么？石头吗？还是下来吧，这水好暖和啊。"

# game/intro.rpy:820
translate english memory1_4ca25199:

    # mc "Поберегись!"
    mc "闪开点！"

# game/intro.rpy:821
translate english memory1_b8650529:

    # elin "Лучше сам поберегись - здесь неглубоко."
    elin "还是你闪开点吧——这里水又不深。"

# game/intro.rpy:825
translate english memory1_8e639ee7:

    # mc "Я хочу проверить, что там."
    mc "我想去看看那是干什么的。"

# game/intro.rpy:826
translate english memory1_da564cf3:

    # elin "Только не уходи далеко, ладно?"
    elin "那你可别跑太远，行吗？"

# game/intro.rpy:830
translate english intro7_bath_c8f4c368:

    # mc "Вода действительно теплая."
    mc "这水还真是暖的。"

# game/intro.rpy:831
translate english intro7_bath_c4e95ebc:

    # elin "Это так специально построено, чтобы солнце грело воду целый день."
    elin "这是特别设计成这样，好让太阳一整天把水晒热。"

# game/intro.rpy:832
translate english intro7_bath_070519d8:

    # elin "Жаль, что этот замок сожгли. Людвиг говорит это построили эльфы, только у них замки были до самого неба."
    elin "真可惜，这城堡被烧毁了。Ludwig说这是精灵建的，只有他们的城堡能高到捅破天。"

# game/intro.rpy:833
translate english intro7_bath_06fccea8:

    # mc "А что толку замка до неба, если они все равно проиграли людям?"
    mc "城堡都捅破云了又有什么用，到头来不还是输给了人类。"

# game/intro.rpy:834
translate english intro7_bath_b252ab91:

    # elin "Тебе их не жалко?"
    elin "你不为他们感到难过吗？"

# game/intro.rpy:835
translate english intro7_bath_6ff32922:

    # mc "Эльфов? Нет. Если проиграли значит были слабее."
    mc "为精灵吗？不。输了就说明他们弱。"

# game/intro.rpy:836
translate english intro7_bath_1cfb489b:

    # elin "Ну..слабый не значит плохой."
    elin "呃……弱又不代表坏。"

# game/intro.rpy:837
translate english intro7_bath_712f3c6f:

    # mc "Наверное. Ты вот слабая, но вроде не плохая."
    mc "大概吧。比如你就弱，但你好像也不坏。"

# game/intro.rpy:838
translate english intro7_bath_a541d930:

    # elin "Вроде?"
    elin "好像？"

# game/intro.rpy:839
translate english intro7_bath_7fbd33f7:

    # mc "Ага. Ладно. Наверное ты все-таки хорошая, ты меня не сдала, когда я вино стащил с кухни."
    mc "呃。行吧。我觉得你大概还是挺好的，那时候我从厨房偷了酒，你没出卖我。"

# game/intro.rpy:841
translate english intro7_bath_630e4276:

    # mc "И все равно, хотели бы победить надо было больше оружия делать, а не замки строить."
    mc "但不管怎么说，要是精灵想赢，他们就该多造点兵器，而不是去修城堡。"

# game/intro.rpy:842
translate english intro7_bath_d4d7b5e9:

    # elin "А может что-нибудь другое обсудим? Завоеванию континента уже тысяча лет. Староватая тема, не находишь?"
    elin "我们能不能聊点别的？这大陆都是千年以前征服的。你觉不觉得这话题有点太老太旧了？"

# game/intro.rpy:843
translate english intro7_bath_eb98a821:

    # mc "А что ты предлагаешь обсудить?"
    mc "那你想聊什么？"

# game/intro.rpy:844
translate english intro7_bath_9a72d1db:

    # elin "Ты когда-нибудь целовался?"
    elin "你接过吻没有？"

# game/intro.rpy:845
translate english intro7_bath_4abfb626:

    # mc "Чего? С девчонкой что ли?"
    mc "什么？跟一个丫头片子？"

# game/intro.rpy:846
translate english intro7_bath_a38c3430:

    # elin "Ну да. А с кем еще? "
    elin "对啊。不然还能跟谁。"

# game/intro.rpy:847
translate english intro7_bath_a294ea1c:

    # mc "Ну...было дело. Пару раз."
    mc "嗯……算是有过。那么一两次吧。"

# game/intro.rpy:848
translate english intro7_bath_0da316b7:

    # elin "Врешь!"
    elin "骗人！"

# game/intro.rpy:849
translate english intro7_bath_a471466d:

    # mc "Не вру!"
    mc "没骗人！"

# game/intro.rpy:850
translate english intro7_bath_880f405f:

    # elin "Докажи! Меня поцелуй!"
    elin "你证明给我看啊！亲我一下！"

# game/intro.rpy:851
translate english intro7_bath_9d1282e2:

    # mc "Чего?"
    mc "什么？"

# game/intro.rpy:852
translate english intro7_bath_437c143e:

    # elin "Ну ты же умеешь! Чего тебе стоит? Или ты наврал?"
    elin "你不是接过吻嘛！那对你有什么难的？除非你是在撒谎！"

# game/intro.rpy:854
translate english intro7_bath_bbde4570:

    # elin "Я закрою глаза, чтобы тебе было легче, вот."
    elin "我闭眼了，这样你能轻松点，喏。"

# game/intro.rpy:855
translate english intro7_bath_ccd8a4fa:

    # mc "Эм..."
    mc "呃……"

# game/intro.rpy:856
translate english intro7_bath_68a7c8a2:

    # elin "Ммммм...."
    elin "唔……"

# game/intro.rpy:857
translate english intro7_bath_22b2e7a7:

    # mc "{i}Не надо было ей врать, это что, мне придется сейчас девчонку целовать? Фу!{/i}"
    mc "{i}真不该跟她吹牛，现在怎么办，我还非得亲一个丫头片子了？恶心！{/i}"

# game/intro.rpy:862
translate english memory2_1d1b40e2:

    # mc "{i}Фу! Какой кошмар! Отвратительно.{/i}"
    mc "{i}呸！真是一场噩梦！恶心透了。{/i}"

# game/intro.rpy:863
translate english memory2_81fb6714:

    # mc "{i}...{/i}"
    mc "{i}...{/i}"

# game/intro.rpy:864
translate english memory2_0ae48e6f:

    # mc "{i}Хотя вроде ничего такого...{/i}"
    mc "{i}不过好像也没什么大不了的……{/i}"

# game/intro.rpy:865
translate english memory2_1b3f4966:

    # mc "{i}Даже забавно.{/i}"
    mc "{i}甚至还有点意思。{/i}"

# game/intro.rpy:866
translate english memory2_69e407f2:

    # mc "{i}Мне нравится, я бы попробовал еще, только главное не предлагать самому, а то буду выглядеть жалко.{/i}"
    mc "{i}我喜欢，有机会还想再亲一回，只是千万不能我先提，不然就太丢脸了。{/i}"

# game/intro.rpy:868
translate english memory2_e4b86218:

    # elin "Ты что, действительно целовался раньше? С кем?"
    elin "你之前真的亲过？跟谁？"

# game/intro.rpy:869
translate english memory2_2d5265fd:

    # mc "Ну...у меня куча вариантов, я же все-таки принц."
    mc "唔……选择那可就多了去，我可是王子。"

# game/intro.rpy:870
translate english memory2_c14eea18:

    # elin "Назови пару имен."
    elin "说几个名字呗。"

# game/intro.rpy:871
translate english memory2_d7e91aad:

    # mc "Эм...сейчас, дай вспомню."
    mc "呃……等一下，让我想想。"

# game/intro.rpy:872
translate english memory2_9cb6a2c9:

    # elin "Так и знала, врешь."
    elin "我就知道，你在撒谎。"

# game/intro.rpy:873
translate english memory2_4e17f67f:

    # mc "Не вру я! Просто из головы вылетело."
    mc "我没撒谎！就是一时想不起来了。"

# game/intro.rpy:874
translate english memory2_cd164508:

    # elin "Кухарка наверное? За то что ты у нее вино украл тебя чмокнула? Ну что ты обманываешь?"
    elin "是女厨娘吗？因为你偷了她的酒，她亲了你一口？你干嘛这样糊弄我？"

# game/intro.rpy:875
translate english memory2_ec96835a:

    # mc "{i}Что-то у меня в голове все плывет...{/i}"
    mc "{i}我脑子里怎么天旋地转的……{/i}"

# game/intro.rpy:877
translate english memory2_f58b009d:

    # elin "[mc]! У ТЕБЯ КРОВЬ!"
    elin "[mc]！ 你流血了！"

# game/intro.rpy:878
translate english memory2_d92574af:

    # mc "Правда? Вот черт."
    mc "真的？见鬼。"

# game/intro.rpy:879
translate english memory2_62ea5f34:

    # elin "Ты в норме?!"
    elin "你没事吧？！"

# game/intro.rpy:880
translate english memory2_2880f345:

    # mc "Да, просто что-то мысли плывут..."
    mc "嗯，就是脑子有点乱……"

# game/intro.rpy:881
translate english memory2_e4874d64:

    # elin "Пойдем домой скорее!"
    elin "我们快回家去！"

