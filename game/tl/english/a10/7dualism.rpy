# game/a10/7dualism.rpy:4
translate english dualism_169ce204:

    # "Следующим вечером."
    "第二天晚上。"

# game/a10/7dualism.rpy:5
translate english dualism_dd2b1bac:

    # me "{i}Пора решить эту проблему.{/i}"
    me "{i}是时候解决这个问题了。{/i}"

# game/a10/7dualism.rpy:6
translate english dualism_565a37eb:

    # me "{i}Но для начала нужно выслушать обе стороны.{/i}"
    me "{i}但首先得听听双方的说法。{/i}"

# game/a10/7dualism.rpy:7
translate english dualism_5c76dbe7:

    # me "{i}...{/i}"
    me "{i}...{/i}"

# game/a10/7dualism.rpy:8
translate english dualism_d7034095:

    # me "{i}Ну где она?{/i}"
    me "{i}她在哪儿？{/i}"

# game/a10/7dualism.rpy:9
translate english dualism_7e2992ae:

    # me "{i}Договорились встретится на закате.{/i}"
    me "{i}我们说好日落时分见面。{/i}"

# game/a10/7dualism.rpy:11
translate english dualism_0ebafb31:

    # ala "[mename]."
    ala "[mename]."

# game/a10/7dualism.rpy:12
translate english dualism_8dcc3e9e:

    # me "Леди [alaina]."
    me "[alaina]女士。"

# game/a10/7dualism.rpy:13
translate english dualism_c605fd7d:

    # ala "Ты хотел поговорить?"
    ala "你想谈谈？"

# game/a10/7dualism.rpy:14
translate english dualism_fc30fd2b:

    # me "Да."
    me "是的。"

# game/a10/7dualism.rpy:15
translate english dualism_6592caea:

    # ala "О чем?"
    ala "谈什么？"

# game/a10/7dualism.rpy:16
translate english dualism_b7950309:

    # me "А ты не знаешь?"
    me "你不知道吗？"

# game/a10/7dualism.rpy:17
translate english dualism_130587cb:

    # ala "Эм..."
    ala "呃……"

# game/a10/7dualism.rpy:18
translate english dualism_3efe9aa8:

    # me "Вообще-то я думал это ты хочешь со мной поговорить. Но если это не так, то пойду."
    me "其实我以为是你想和我谈谈。但如果不是，那我就走了。"

# game/a10/7dualism.rpy:20
translate english dualism_57e134c0:

    # ala "Постой."
    ala "等等。"

# game/a10/7dualism.rpy:21
translate english dualism_44cb75d2:

    # me "Зачем мне оставаться? Никакой проблемы судя по всему нет."
    me "我为什么要留下？看来根本没什么问题。"

# game/a10/7dualism.rpy:22
translate english dualism_70e55133:

    # ala "Прости. Я ведь не знаю, что знаешь ты. А за последнее время проблем накопилось достаточно. Так что...просто конкретизируй ладно?"
    ala "抱歉。我毕竟不知道你知道些什么。而最近积攒的问题已经够多了。所以……直接说清楚，好吗？"

# game/a10/7dualism.rpy:23
translate english dualism_246dacbc:

    # me "Ладно. Все в замке только и твердят о вашем конфликте с моим дядей."
    me "好吧。城堡里所有人都在议论你和我叔叔之间的冲突。"

# game/a10/7dualism.rpy:24
translate english dualism_cc6ae7f5:

    # ala "Конфликт? Так они это называют?"
    ala "冲突？他们是这么叫的？"

# game/a10/7dualism.rpy:25
translate english dualism_b12c3bd0:

    # me "А что это?"
    me "那是什么？"

# game/a10/7dualism.rpy:26
translate english dualism_d1aac10a:

    # ala "Преследование. Из личных целей."
    ala "迫害。出于私人目的。"

# game/a10/7dualism.rpy:27
translate english dualism_e57714da:

    # me "Личных целей?"
    me "私人目的？"

# game/a10/7dualism.rpy:28
translate english dualism_a3f943e4:

    # ala "Ну да."
    ala "嗯，是的。"

# game/a10/7dualism.rpy:29
translate english dualism_0106f9a9:

    # me "Расскажи мне свою версию того, что происходит. Поподробнее."
    me "把你对正在发生的事情的看法告诉我。详细点。"

# game/a10/7dualism.rpy:30
translate english dualism_b8783d0f:

    # ala "Что именно тебя интересует?"
    ala "你具体对什么感兴趣？"

# game/a10/7dualism.rpy:31
translate english dualism_d1fffc63:

    # me "Все."
    me "一切。"

# game/a10/7dualism.rpy:33
translate english dualism_46d8d5d7:

    # ala "Все? Или все, что можно подтвердить?"
    ala "一切？还是所有能证实的事情？"

# game/a10/7dualism.rpy:34
translate english dualism_7b2a50c8:

    # me "Желательно второе."
    me "最好说说后者。"

# game/a10/7dualism.rpy:35
translate english dualism_22b41588:

    # ala "Такого не будет. У тебя будут только мои и его версии."
    ala "这不可能。你只能听到我和他的说法。"

# game/a10/7dualism.rpy:36
translate english dualism_72563ede:

    # me "Твоей версии я пытаюсь добиться уже минут десять."
    me "我已经花了十分钟试图了解你的说法的。"

# game/a10/7dualism.rpy:37
translate english dualism_89a79304:

    # ala "..."
    ala "..."

# game/a10/7dualism.rpy:38
translate english dualism_ae611665:

    # ala "Твой дядя считает, что я замыслила какой-то заговор или переворот или...только Мирта знает что у него в голове."
    ala "你叔叔认为我在策划什么阴谋、政变，或者……只有Mirta才知道他脑子里在想什么。"

# game/a10/7dualism.rpy:39
translate english dualism_135611af:

    # me "У него есть основания так считать?"
    me "他这么认为有根据吗？"

# game/a10/7dualism.rpy:40
translate english dualism_0ad6c311:

    # ala "Ему давно мозолит глаза эльф при дворе. И как только он дорвался до власти, по твоей милости, он сразу же начал пытаться меня вытравить отсюда."
    ala "他早就看不惯宫里有个精灵。而你一把权力交到他手里，他就立刻开始想方设法把我从这里赶出去。"

# game/a10/7dualism.rpy:41
translate english dualism_5074e0a5:

    # me "Что-то я не помню, чтобы Конрад испытывал какую-то ненависть к эльфам."
    me "我可不记得Conrad对精灵有什么仇恨。"

# game/a10/7dualism.rpy:42
translate english dualism_efc36177:

    # ala "Может он ее хорошо маскировал. Даже если дело не в моих длинных ушах, у него все равно нет оснований преследовать меня."
    ala "也许他伪装得很好。就算问题不在于我的长耳朵，他依然没有别的理由迫害我。"

# game/a10/7dualism.rpy:43
translate english dualism_f58644b5:

    # ala "К тому же все не ограничивается только преследованием."
    ala "而且，不仅仅是迫害。"

# game/a10/7dualism.rpy:44
translate english dualism_33a30eaf:

    # me "Что еще?"
    me "还有什么？"

# game/a10/7dualism.rpy:45
translate english dualism_04f19f65:

    # ala "Обыски, аресты."
    ala "搜查，逮捕。"

# game/a10/7dualism.rpy:46
translate english dualism_398233d3:

    # me "Тебя обыскивали или арестовывали?"
    me "你被搜查或逮捕了吗？"

# game/a10/7dualism.rpy:47
translate english dualism_ad43c830:

    # ala "Меня - нет. Но людей которые со мной связаны - да."
    ala "我没有。但跟我有关系的人被搜了。"

# game/a10/7dualism.rpy:48
translate english dualism_7c3c22c5:

    # me "Людей? Или эльфов?"
    me "人？还是精灵？"

# game/a10/7dualism.rpy:49
translate english dualism_0a61422f:

    # ala "А это имеет значение? На прошлой неделе Конрад перевернул лавку моего друга в нижнем городе. А он просто поставлял мне ингридиенты для алхимической лаборатории. И кстати - он человек."
    ala "这重要吗？上周Conrad把我朋友在下城区的店铺翻了个底朝天。他只是为我的炼金实验室提供原料。顺便说一句——他是人类。"

# game/a10/7dualism.rpy:51
translate english dualism_babeab8e:

    # me "Выходит дело не только в том, что ты эльф."
    me "这么说，问题不仅仅因为你是精灵。"

# game/a10/7dualism.rpy:52
translate english dualism_394a0a42:

    # ala "Знаешь, меня не особо интересует его мотивация, пока он всеми силами пытается найти причину для моего ареста."
    ala "你知道，我不是很关心他的动机，他只是在用尽手段试图找到逮捕我的理由。"

# game/a10/7dualism.rpy:53
translate english dualism_e780342a:

    # me "А такая причина есть?"
    me "这样的理由存在吗？"

# game/a10/7dualism.rpy:54
translate english dualism_7eaef767:

    # ala "Ты...ты будто уже занял сторону своего дяди."
    ala "你……你好像已经站在你叔叔那边了。"

# game/a10/7dualism.rpy:55
translate english dualism_6c9a6f38:

    # me "Я не занимал ничьих сторон. Но я хочу узнать правду. А ты вечно что-то скрываешь."
    me "我没有站任何一边。但我希望了解真相。而你总是遮遮掩掩的。"

# game/a10/7dualism.rpy:56
translate english dualism_89a79304_1:

    # ala "..."
    ala "..."

# game/a10/7dualism.rpy:57
translate english dualism_e9ad8663:

    # me "Что? Хочешь сказать я лгу? Ты всегда ведешь себя подозрительно."
    me "...什么？你想说我说的不对吗？你总是表现得鬼鬼祟祟。"

# game/a10/7dualism.rpy:58
translate english dualism_e97f49e0:

    # ala "Всегда?"
    ala "总是？"

# game/a10/7dualism.rpy:59
translate english dualism_20f177f2:

    # me "Может не всегда, но часто."
    me "也许不是一直，但经常。"

# game/a10/7dualism.rpy:60
translate english dualism_81e9f021:

    # ala "Например?"
    ala "比如？"

# game/a10/7dualism.rpy:61
translate english dualism_b959ade0:

    # me "Тебе нужны примеры?"
    me "你需要例子？"

# game/a10/7dualism.rpy:62
translate english dualism_e91ecdfe:

    # ala "Да. Если что-то в моем поведении тебе кажется странным, скажи мне. Я все тебе объясню."
    ala "是的。如果我有什么行为让你觉得奇怪，告诉我。我都可以解释。"

# game/a10/7dualism.rpy:65
translate english dualism_2a49d31e:

    # me "Хорошо. Мое изгнание."
    me "好。我们流放的事。"

# game/a10/7dualism.rpy:66
translate english dualism_c47685b2:

    # ala "А что с ним?"
    ala "它是怎么回事？"

# game/a10/7dualism.rpy:67
translate english dualism_c5e90d35:

    # me "Много лет я думал, что это отец изгнал меня."
    me "很多年，我都以为是父亲流放我的。"

# game/a10/7dualism.rpy:68
translate english dualism_12c68e25:

    # ala "Так оно и было."
    ala "事实就是这样。"

# game/a10/7dualism.rpy:69
translate english dualism_8dc2e495:

    # me "Но недавно я вспомнил один инцидент из детства. Вы гуляли с сестрой в этих руинах. Я нашел тебя и свою мать разговаривающими."
    me "但最近我回想起小时候的一件事。我和妹妹在这些废墟里散步。撞见你和我的母亲在交谈。"

# game/a10/7dualism.rpy:70
translate english dualism_b30961a9:

    # ala "И?"
    ala "然后？"

# game/a10/7dualism.rpy:71
translate english dualism_eb62daaa:

    # me "Оказалось вы тоже причастны к этому решению."
    me "原来你们也参与了那个决定。"

# game/a10/7dualism.rpy:72
translate english dualism_316fb817:

    # ala "Причастны. Это правда. Но разве это не ты выколол сестре глаз?"
    ala "参与了。确实是这样。但戳瞎你妹妹眼睛的难道不是你吗？"

# game/a10/7dualism.rpy:73
translate english dualism_3820771a:

    # me "..."
    me "..."

# game/a10/7dualism.rpy:74
translate english dualism_dd599af5:

    # ala "Я тебя не виню в этом. Это был просто удачный повод."
    ala "这件事上我不怪你。那只是一个合适的借口。"

# game/a10/7dualism.rpy:75
translate english dualism_19518595:

    # me "Повод?"
    me "借口？"

# game/a10/7dualism.rpy:76
translate english dualism_35bfd0df:

    # ala "Мы должны были защитить тебя [mename]."
    ala "我们应该保护你，[mename]。"

# game/a10/7dualism.rpy:77
translate english dualism_88a07f06:

    # me "защитить от чего?"
    me "保护？免受什么？"

# game/a10/7dualism.rpy:78
translate english dualism_2549adc0:

    # ala "Ты думаешь у тебя мало врагов? Ты единственный сын короля, а еще и полуэльф. Ты не помнишь этого, но когда ты был ребенком, много вассалов твоего отца недобро поглядывали на тебя."
    ala "你以为你的敌人很少吗？你是国王唯一的儿子，而且还是个半精灵。你不记得这些，但当你小的时候，很多你父亲的封臣都用不怀好意的眼光打量你。"

# game/a10/7dualism.rpy:79
translate english dualism_3369a1ca:

    # me "И это был повод изгнать тебя?"
    me "这就是放逐你的理由？"

# game/a10/7dualism.rpy:80
translate english dualism_b298e3b7:

    # ala "Защитить тебя вне дворца было проще. К тому же твой отец тогда колебался в твоей легитимности. По твоему тебя просто так не объявляли наследником?"
    ala "在宫外保护你更容易。何况那时你父亲还在犹豫你的合法性。你以为没有理由会迟迟不立你为储君吗？"

# game/a10/7dualism.rpy:81
translate english dualism_3820771a_1:

    # me "..."
    me "..."

# game/a10/7dualism.rpy:82
translate english dualism_d9b58bf6:

    # ala "У нас с твоей матерью была причина так поступить. А не рассказывала я тебе об этом, потому что ребенку это объяснить невозможно. Я на протяжении долгих лет должна была учить тебя, а тяжело учить того, кто тебя ненавидит."
    ala "我和你母亲有理由这么做。我没告诉你，是因为跟一个孩子解释不清。我本应教导你很多年，而去教一个恨你的人太难了。"

# game/a10/7dualism.rpy:83
translate english dualism_01822020:

    # me "Ладно."
    me "好吧。"

# game/a10/7dualism.rpy:86
translate english dualism_b7ff445a:

    # me "Что насчет писем?"
    me "那些信呢？"

# game/a10/7dualism.rpy:87
translate english dualism_d01ab1c0:

    # ala "О каких письмах речь?"
    ala "你说的哪些信？"

# game/a10/7dualism.rpy:88
translate english dualism_7084c088:

    # me "О тех, что ты слала моей матери."
    me "你寄给我母亲的那些。"

# game/a10/7dualism.rpy:89
translate english dualism_63e68bc4:

    # ala "Это была ее просьба. Она интересовалась твоей судьбой. Разве можно ее в этом винить."
    ala "那是她的请求。她关心你的命运。能在这事上责怪她吗？"

# game/a10/7dualism.rpy:90
translate english dualism_f188ee33:

    # me "Ты была...очень подробна в них."
    me "你写得很……详细。"

# game/a10/7dualism.rpy:91
translate english dualism_79b328c4:

    # ala "И что? Я не хотела ей врать."
    ala "那又怎样？我不想对她撒谎。"

# game/a10/7dualism.rpy:92
translate english dualism_3820771a_2:

    # me "..."
    me "..."

# game/a10/7dualism.rpy:93
translate english dualism_96123fdd:

    # ala "Это правда вызывает в тебе сомнения?"
    ala "这真的让你产生怀疑了吗？"

# game/a10/7dualism.rpy:94
translate english dualism_67e71498:

    # me "Ты делала это втайне от меня."
    me "你是瞒着我和她有信件往来的。"

# game/a10/7dualism.rpy:95
translate english dualism_69c79730:

    # ala "Ты был ребенком. Я не хотела смущать тебя."
    ala "你那时是个孩子。我不想让你困扰。"

# game/a10/7dualism.rpy:96
translate english dualism_01822020_1:

    # me "Ладно."
    me "好吧。"

# game/a10/7dualism.rpy:99
translate english dualism_62beb891:

    # me "А что насчет переворота моей сестры?"
    me "那我姐姐的政变呢？"

# game/a10/7dualism.rpy:100
translate english dualism_16e9c710:

    # ala "Спрашивай."
    ala "问吧。"

# game/a10/7dualism.rpy:101
translate english dualism_6c5be2ad:

    # me "Я долгое время просидел в темнице."
    me "我在牢里待了很长时间。"

# game/a10/7dualism.rpy:102
translate english dualism_400d9389:

    # ala "Я знаю. По-твоему, это была моя инициатива?"
    ala "我知道。你觉得这是我的主意？"

# game/a10/7dualism.rpy:103
translate english dualism_595d7b8c:

    # me "Не знаю."
    me "不知道。"

# game/a10/7dualism.rpy:104
translate english dualism_381c12b1:

    # ala "Я к этому не причастна."
    ala "我和那件事没关系。"

# game/a10/7dualism.rpy:105
translate english dualism_ccfb02d6:

    # me "Но ты этому не помешала."
    me "但你也没有阻止。"

# game/a10/7dualism.rpy:106
translate english dualism_f901b16b:

    # ala "Верно. Но..."
    ala "没错。但是……"

# game/a10/7dualism.rpy:107
translate english dualism_511310db:

    # me "Но?"
    me "但是？"

# game/a10/7dualism.rpy:108
translate english dualism_6bf0be50:

    # ala "Я расскажу."
    ala "听我继续说。"

# game/a10/7dualism.rpy:110
translate english dualism_a3c8022d:

    # norman "Все готово."
    norman "一切准备就绪。"

# game/a10/7dualism.rpy:111
translate english dualism_849b8554:

    # cass "Все гости пьяны?"
    cass "所有宾客都醉了？"

# game/a10/7dualism.rpy:112
translate english dualism_b78a18a2:

    # norman "Не все. Почти все."
    norman "没全部，差不多了。"

# game/a10/7dualism.rpy:113
translate english dualism_0181e7bf:

    # cass "Тогда начнем с трезвых."
    cass "那我们从清醒的开始。"

# game/a10/7dualism.rpy:114
translate english dualism_fad02ab7:

    # norman "А что насчет стражи?"
    norman "守卫呢？"

# game/a10/7dualism.rpy:115
translate english dualism_27747a2c:

    # cass "Всю стражу в покоях я подкупила. Кто не захотел брать деньги ты знаешь."
    cass "寝宫的所有卫兵我都贿赂了。那些不肯收钱的，你都知道。"

# game/a10/7dualism.rpy:116
translate english dualism_bb371250:

    # norman "А остальной замок?"
    norman "城堡的其他地方呢？"

# game/a10/7dualism.rpy:117
translate english dualism_66714a4b:

    # cass "Этим займется мой дядя."
    cass "这些我叔叔会处理。"

# game/a10/7dualism.rpy:118
translate english dualism_fcbe25e0:

    # norman "Хорошо. Когда начинать?"
    norman "好。什么时候开始？"

# game/a10/7dualism.rpy:119
translate english dualism_70d62d49:

    # cass "Как только Присцилла отравит отца. Я дам знак."
    cass "等Priscilla毒倒父亲，我就发信号。"

# game/a10/7dualism.rpy:120
translate english dualism_d0c8dc47:

    # cass "Возвращайся и расскажи остальным."
    cass "回去通知其他人。"

# game/a10/7dualism.rpy:121
translate english dualism_471ca67a:

    # norman "Хорошо."
    norman "好。"

# game/a10/7dualism.rpy:123
translate english dualism_ff2ae529:

    # ala "Кхм-кхм."
    ala "咳、咳。"

# game/a10/7dualism.rpy:124
translate english dualism_6a338f63:

    # cass "Ты меня напугала."
    cass "你吓到我了。"

# game/a10/7dualism.rpy:125
translate english dualism_05046933:

    # ala "Гости?"
    ala "宾客？"

# game/a10/7dualism.rpy:126
translate english dualism_c2487b65:

    # cass "Что?"
    cass "什么？"

# game/a10/7dualism.rpy:127
translate english dualism_fc9f26fb:

    # ala "Звучит опасно."
    ala "听起来很危险。"

# game/a10/7dualism.rpy:128
translate english dualism_63e3c642:

    # cass "Никто не пострадает."
    cass "没人会受伤。"

# game/a10/7dualism.rpy:129
translate english dualism_4b42c97f:

    # ala "Ага. Кроме пары стражников."
    ala "啊哈，除了几个卫兵。"

# game/a10/7dualism.rpy:131
translate english dualism_e157ad1d:

    # cass "Что тебе нужно? Хочешь мне помешать?"
    cass "你想要什么？想阻止我吗？"

# game/a10/7dualism.rpy:132
translate english dualism_eaf91a72:

    # ala "Хочу убедиться, что королевская семья в безопасности."
    ala "我想确保王室成员的安全。"

# game/a10/7dualism.rpy:133
translate english dualism_f9a0afe3:

    # cass "С ними все будет нормально. Почти со всеми."
    cass "他们会没事的。差不多所有的人。"

# game/a10/7dualism.rpy:134
translate english dualism_c959938c:

    # ala "[mename]?"
    ala "[mename]?"

# game/a10/7dualism.rpy:135
translate english dualism_44f1e94c:

    # cass "Успокойся...он на моей стороне."
    cass "冷静……他站在我们这边。"

# game/a10/7dualism.rpy:136
translate english dualism_4d124ea5:

    # ala "Ты уговорила его?"
    ala "你说服他了？"

# game/a10/7dualism.rpy:137
translate english dualism_90cd62b2:

    # cass "Да..."
    cass "是的……"

# game/a10/7dualism.rpy:138
translate english dualism_5ae06290:

    # ala "Звучишь неуверенно. Мне это не нравится."
    ala "听起来没什么底气。我不喜欢这样。"

# game/a10/7dualism.rpy:139
translate english dualism_5fb7851a:

    # cass "Слушай. Я же не дура. Я понимаю, что без него у меня нет шансов на успех."
    cass "听着。我不傻。我明白没有他我根本没有成功的机会。"

# game/a10/7dualism.rpy:140
translate english dualism_d1ba1170:

    # ala "Если он пострадает..."
    ala "如果他受伤了……"

# game/a10/7dualism.rpy:141
translate english dualism_e992ff5f:

    # cass "Он не пострадает, клянусь."
    cass "他不会受伤的，我发誓。"

# game/a10/7dualism.rpy:142
translate english dualism_b0403e6d:

    # ala "Я не особо верю словам..."
    ala "我不怎么相信言语……"

# game/a10/7dualism.rpy:143
translate english dualism_49972f58:

    # cass "Сама все проконтролируешь."
    cass "你就自己掌控一切吧。"

# game/a10/7dualism.rpy:144
translate english dualism_f9874f30:

    # ala "Я не хочу быть к этому причастна. Это твоя идея и твой план."
    ala "我不想插手。这是你的主意，你的计划。"

# game/a10/7dualism.rpy:145
translate english dualism_23c2bab0:

    # cass "Разрешаю сжечь меня живьем, если я нарушу слово."
    cass "如果我食言，允许你把我活活烧死。"

# game/a10/7dualism.rpy:148
translate english dualism_98b3d832:

    # me "И все же она нарушила слово."
    me "但她还是食言了。"

# game/a10/7dualism.rpy:149
translate english dualism_60442700:

    # ala "Не нарушила. Ты ведь в порядке."
    ala "她没有。你不是好好的吗。"

# game/a10/7dualism.rpy:150
translate english dualism_df87730a:

    # me "Она бросила меня в темницу."
    me "她把我扔进了地牢。"

# game/a10/7dualism.rpy:151
translate english dualism_248c282b:

    # ala "Я знаю, прости. Она ввела меня в заблуждение. Я правда думала, что это ваша совместная идея."
    ala "我知道，对不起。我被蒙蔽了。我真以为这是你俩共同的主意。"

# game/a10/7dualism.rpy:152
translate english dualism_582aac1f:

    # me "Переворот?"
    me "政变？"

# game/a10/7dualism.rpy:153
translate english dualism_d3f12f54:

    # ala "Да."
    ala "是的。"

# game/a10/7dualism.rpy:154
translate english dualism_e2b16074:

    # me "И почему же ты не сожгла ее, как обещала?"
    me "那你为什么不按保证的那样烧死她？"

# game/a10/7dualism.rpy:155
translate english dualism_d723d199:

    # ala "Потому что жизнь тебя, твоей матери и сестры были для меня первостепенны. Она держала вас всех в разных местах и я не была уверена, что смогу спасти сразу вас всех. И что случиться, если я убью [cass]."
    ala "因为你的、你母亲和你妹妹的生命对我而言是首要的。她把你们分开关押在不同的地方，我没有把握能一下子救下所有人。而且我若是杀了[cass]，会出什么事，我无法预料。"

# game/a10/7dualism.rpy:156
translate english dualism_3820771a_3:

    # me "..."
    me "..."

# game/a10/7dualism.rpy:157
translate english dualism_44cce34e:

    # ala "К тому моменту, как я выяснила как тебе помочь ты сбежал сам. Тогда я спасла твою мать и мы обе направлялись вызволять твою сестру."
    ala "等我弄清楚怎么救你时，你已经自己逃出来了。然后我救出了你母亲，我们俩打算再去救你妹妹。"

# game/a10/7dualism.rpy:158
translate english dualism_3820771a_4:

    # me "..."
    me "..."

# game/a10/7dualism.rpy:159
translate english dualism_16d0b17f:

    # ala "Прости. Я знаю, что подвела тебя. Но в этом не было никакого злого умысла."
    ala "对不起。我知道我辜负了你。但这事没有半点恶意。"

# game/a10/7dualism.rpy:162
translate english dualism_98b3d832_1:

    # me "И все же она нарушила слово."
    me "但她还是食言了。"

# game/a10/7dualism.rpy:163
