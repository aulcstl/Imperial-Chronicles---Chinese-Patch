    # ala "К тому моменту, как я разработала план, ты уже обманул ее сам."
    ala "等我制定好计划时，你已经自己骗过她了。"

# game/a10/7dualism.rpy:171
translate english dualism_3820771a_5:

    # me "..."
    me "..."

