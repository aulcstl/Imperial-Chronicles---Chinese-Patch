# game/a10/4backwife.rpy:323
translate english backwife_isi_929beb59:

    # isi "Здесь очень скучно, [mename], а меня такое только развлекает."
    isi "这里非常无聊，[mename]，只有这种事能帮我解闷。"

# game/a10/4backwife.rpy:324
