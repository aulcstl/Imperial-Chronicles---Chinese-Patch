    isi "你读了一封，就等于全读了。"

# game/a10/4backwife.rpy:316
translate english backwife_isi_149b3064:

    # me "В каком смысле?"
    me "什么意思？"

# game/a10/4backwife.rpy:317
translate english backwife_isi_669d0762:

