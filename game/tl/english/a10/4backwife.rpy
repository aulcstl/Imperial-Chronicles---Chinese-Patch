# game/a10/4backwife.rpy:9
translate english backwife_aur_591eb588:

    # "Ночью."
    "到了晚上。"

# game/a10/4backwife.rpy:10
translate english backwife_aur_ce65f479:

    # me "{i}Наконец-то я смогу поспать в своей кровати, а не на холодной земле у костра.{/i}"
    me "{i}终于能睡在自己的床上，而不是篝火旁冰冷的地面上了。{/i}"

# game/a10/4backwife.rpy:11
translate english backwife_aur_80e257a2:

    # me "{i}Главное не шуметь.{/i}"
    me "{i}主要是不要出声。{/i}"

# game/a10/4backwife.rpy:12
translate english backwife_aur_0939da37:

    # me "{i}Наверное Аврора уже спит.{/i}"
    me "{i}可能Aurora已经睡了。{/i}"

# game/a10/4backwife.rpy:14
translate english backwife_aur_95bafc0b:

    # me "{i}Да. Так и есть.{/i}"
    me "{i}是的。确实如此。{/i}"

# game/a10/4backwife.rpy:15
translate english backwife_aur_8be8be08:

    # me "{i}Легла ровно посередине, у меня не получится лечь, не потревожив ее.{/i}"
    me "{i}她正好躺在中间，我没法躺下而不打扰她。{/i}"

# game/a10/4backwife.rpy:16
translate english backwife_aur_5c76dbe7:

    # me "{i}...{/i}"
    me "{i}...{/i}"

# game/a10/4backwife.rpy:17
translate english backwife_aur_4b999e35:

    # me "{i}Ладно, пока переоденусь, может она сдвинется.{/i}"
    me "{i}好吧，先换个衣服，也许她会挪动。{/i}"

# game/a10/4backwife.rpy:19
translate english backwife_aur_cedd36b8:

    # aurora "Кто это?"
    aurora "是谁？"

# game/a10/4backwife.rpy:20
translate english backwife_aur_6737a792:

    # me "Прости. Не хотел тебя будить."
    me "抱歉。不想吵醒你。"

# game/a10/4backwife.rpy:21
translate english backwife_aur_b78a3b18:

    # aurora "[mename]?"
    aurora "[mename]?"

# game/a10/4backwife.rpy:22
translate english backwife_aur_aa0fc052:

    # me "Кто-то еще может войти в наши покои ночью?"
    me "还有谁能在晚上进入我们的寝室吗？"

# game/a10/4backwife.rpy:23
translate english backwife_aur_e0f42b14:

    # aurora "Нет."
    aurora "没有。"

# game/a10/4backwife.rpy:24
translate english backwife_aur_d892507a:

    # me "Тогда это я."
    me "那是我。"

# game/a10/4backwife.rpy:25
translate english backwife_aur_3dee56f2:

    # aurora "Не понимаю, это сон или..."
    aurora "不明白，这是梦还是..."

# game/a10/4backwife.rpy:26
translate english backwife_aur_05e025eb:

    # me "Нет, это не сон. Я правда вернулся."
    me "不，不是梦。我真的回来了。"

# game/a10/4backwife.rpy:27
translate english backwife_aur_311ff58a:

    # aurora "Почему ночью?"
    aurora "为什么在晚上？"

# game/a10/4backwife.rpy:28
translate english backwife_aur_fb2383eb:

    # me "Ты не рада меня видеть?"
    me "你不高兴见到我吗？"

# game/a10/4backwife.rpy:30
translate english backwife_aur_ea5032a5:

    # aurora "Рада конечно."
    aurora "当然高兴。"

# game/a10/4backwife.rpy:31
translate english backwife_aur_921e32af:

    # me "Тогда к чему эти вопросы?"
    me "那为什么这么问？"

# game/a10/4backwife.rpy:32
translate english backwife_aur_53a77092:

    # aurora "Прости. Я просто к такому не привыкла. Когда мой отец возвращался в замок, все начинали гудеть об этом еще за несколько дней."
    aurora "抱歉。我只是不习惯。我父亲回城堡时，所有人都会提前几天就开始嚷嚷。"

# game/a10/4backwife.rpy:33
translate english backwife_aur_2d517b2d:

    # me "Я решил обойтись без парадов и фанфар в этот раз, поэтому прибыл с передовым отрядом."
    me "我这次决定免去游行和吹捧，所以带着先遣队来了。"

# game/a10/4backwife.rpy:34
translate english backwife_aur_88b0b220:

    # aurora "Ты так спешил домой?"
    aurora "你那么急着回家？"

# game/a10/4backwife.rpy:35
translate english backwife_aur_820c1a1e:

    # me "Конечно. Хотел скорее увидеть мою любимую жену."
    me "当然。想快点见到我爱的妻子。"

# game/a10/4backwife.rpy:36
translate english backwife_aur_d2e5535d:

    # aurora "Правда?"
    aurora "真的吗？"

# game/a10/4backwife.rpy:37
translate english backwife_aur_fc30fd2b:

    # me "Да."
    me "是的。"

# game/a10/4backwife.rpy:38
translate english backwife_aur_2b71bc54:

    # aurora "..."
    aurora "..."

# game/a10/4backwife.rpy:39
translate english backwife_aur_3820771a:

    # me "..."
    me "..."

# game/a10/4backwife.rpy:42
translate english backwife_aur_7e30430f:

    # me "{i}Эй! Я должен был ее поцеловать.{/i}"
    me "{i}嘿！我应该吻她的。{/i}"

# game/a10/4backwife.rpy:43
translate english backwife_aur_1910b8a5:

    # me "{i}Она меня опередила.{/i}"
    me "{i}她抢先了。{/i}"

# game/a10/4backwife.rpy:44
translate english backwife_aur_5c76dbe7_1:

    # me "{i}...{/i}"
    me "{i}...{/i}"

# game/a10/4backwife.rpy:45
translate english backwife_aur_15fe0888:

    # me "{i}Надо сказать я тоже по ней соскучился.{/i}"
    me "{i}必须说，我也想她了。{/i}"

# game/a10/4backwife.rpy:46
translate english backwife_aur_58d47154:

    # me "{i}Возможно даже слишком.{/i}"
    me "{i}也许甚至太想了。{/i}"

# game/a10/4backwife.rpy:48
translate english backwife_aur_bd87d70a:

    # me "Я смотрю ты ждала меня не одна?"
    me "我看你等我的时候不是一个人？"

# game/a10/4backwife.rpy:49
translate english backwife_aur_48f01947:

    # aurora "Да. Сразу как ты уехал у меня стал расти живот."
    aurora "是的。你一走，我的肚子就开始大了。"

# game/a10/4backwife.rpy:50
translate english backwife_aur_06b40775:

    # me "И сколько еще..."
    me "还有多久..."

# game/a10/4backwife.rpy:51
translate english backwife_aur_eef4168d:

    # aurora "М?"
    aurora "嗯？"

# game/a10/4backwife.rpy:52
translate english backwife_aur_1f9531f5:

    # me "Ну...сколько осталось ждать."
    me "嗯...还要等多久。"

# game/a10/4backwife.rpy:53
translate english backwife_aur_d50100a8:

    # aurora "Думаю пару месяцев он еще будет во мне. Не могу сказать точный срок."
    aurora "我想他还会在我肚子里几个月。说不准确切时间。"

# game/a10/4backwife.rpy:54
translate english backwife_aur_5ac38cf1:

    # me "Почему?"
    me "为什么？"

# game/a10/4backwife.rpy:55
translate english backwife_aur_a30f4185:

    # aurora "Моя мать говорила, что после восьми месяцев беременности роды могут начаться в любой момент. Через день, а может еще через месяц."
    aurora "我母亲说，怀孕八个月后，随时都可能开始分娩。可能过一天，也可能再过一个月。"

# game/a10/4backwife.rpy:56
translate english backwife_aur_877a1691:

    # me "Как ты себя чувствуешь?"
    me "你感觉怎么样？"

# game/a10/4backwife.rpy:57
translate english backwife_aur_a09598a2:

    # aurora "На удивление нормально. Я думала будет гораздо хуже. А так - просто теперь ем за двоих и стало тяжело подниматься по лестницам."
    aurora "出奇地好。我本以为会更糟。而实际上——现在只是吃两人份，上楼梯变重了。"

# game/a10/4backwife.rpy:58
translate english backwife_aur_461c9c97:

    # me "Хочешь, я прикажу носить тебя?"
    me "要不要我命令人抬着你？"

# game/a10/4backwife.rpy:59
translate english backwife_aur_8c67be87:

    # aurora "Не нужно. Небольшая физическая нагрузка мне полезна. Я и так почти всегда торчу в этой спальне."
    aurora "不需要。少量身体活动对我有益。我本来就几乎一直窝在这卧室里。"

# game/a10/4backwife.rpy:60
translate english backwife_aur_3820771a_1:

    # me "..."
    me "..."

# game/a10/4backwife.rpy:61
translate english backwife_aur_2b71bc54_1:

    # aurora "..."
    aurora "..."

# game/a10/4backwife.rpy:62
translate english backwife_aur_ab27540c:

    # me "Как думаешь, это мальчик или девочка?"
    me "你觉得是男孩还是女孩？"

# game/a10/4backwife.rpy:63
translate english backwife_aur_5390c183:

    # aurora "Судя по его активности - мальчик. Часто пинается."
    aurora "从他活跃程度看——是男孩。经常踢腾。"

# game/a10/4backwife.rpy:68
translate english backwife_aur_f342df33:

    # me "Хочу послушать."
    me "想听听。"

# game/a10/4backwife.rpy:69
translate english backwife_aur_180699f6:

    # aurora "Он еще не успел проснуться."
    aurora "他还没醒呢。"

# game/a10/4backwife.rpy:70
translate english backwife_aur_14c37b2d:

    # me "Я думал они всегда спят, пока они в животе."
    me "我以为他们总在肚子里睡觉。"

# game/a10/4backwife.rpy:71
translate english backwife_aur_6480911d:

    # aurora "Конечно нет."
    aurora "当然不是。"

# game/a10/4backwife.rpy:72
translate english backwife_aur_5801863f:

    # me "У меня мало знаний. Это моя первая беременность...твоя первая...это мой первый ребенок."
    me "我知识少。这是我第一次怀孕...你的第一次...这是我的第一个孩子。"

# game/a10/4backwife.rpy:73
translate english backwife_aur_2b71bc54_2:

    # aurora "..."
    aurora "..."

# game/a10/4backwife.rpy:74
translate english backwife_aur_675ebb0a:

    # me "Он еще не родился, а я уже его люблю."
    me "他还没出生，我就已经爱他了。"

# game/a10/4backwife.rpy:75
translate english backwife_aur_e3b75cc3:

    # aurora "Уверена, он тоже тебя любит."
    aurora "确定，他也爱你。"

# game/a10/4backwife.rpy:76
translate english backwife_aur_3820771a_2:

    # me "..."
    me "..."

# game/a10/4backwife.rpy:78
translate english backwife_aur_88ac4b6c:

    # me "Погоди! Я что-то слышу."
    me "等等！我听到点什么。"

# game/a10/4backwife.rpy:79
translate english backwife_aur_d2e5535d_1:

    # aurora "Правда?"
    aurora "真的？"

# game/a10/4backwife.rpy:80
translate english backwife_aur_bdf01334:

    # me "Он просит в следующий раз пообедать аранской похлебкой и томатным соком!"
    me "他求下次午餐喝阿兰汤和番茄汁！"

# game/a10/4backwife.rpy:81
translate english backwife_aur_817745e1:

    # aurora "Тьфу ты. Я же поверила."
    aurora "呸。我都信了。"

# game/a10/4backwife.rpy:82
translate english backwife_aur_bb6b7c54:

    # me "Ну если честно, то я правда что-то слышу."
    me "老实说，我真听到点什么。"

# game/a10/4backwife.rpy:83
translate english backwife_aur_d8fc06da:

    # aurora "Да?"
    aurora "是吗？"

# game/a10/4backwife.rpy:84
translate english backwife_aur_204e18d3:

    # me "Угу. Сердцебиение."
    me "嗯。心跳声。"

# game/a10/4backwife.rpy:85
translate english backwife_aur_ab353ebe:

    # aurora "Это мое."
    aurora "这是我的。"

# game/a10/4backwife.rpy:86
translate english backwife_aur_015cf643:

    # me "Твое сердце повыше."
    me "你的心在上面点。"

# game/a10/4backwife.rpy:87
translate english backwife_aur_443a8702:

    # aurora "Его сердце еще слишком маленькое, чтобы его слышать."
    aurora "他的心还太小，听不到。"

# game/a10/4backwife.rpy:88
translate english backwife_aur_6caafcdc:

    # me "Тогда наверное это переваривается ужин."
    me "那大概是消化晚饭的声音。"

# game/a10/4backwife.rpy:89
translate english backwife_aur_b724096c:

    # aurora "[mename]."
    aurora "[mename]."

# game/a10/4backwife.rpy:91
translate english backwife_aur_35ef60a0:

    # aurora "Теперь, когда ты напомнил о еде, я захотела фруктов."
    aurora "现在你提起吃的，我想吃水果了。"

# game/a10/4backwife.rpy:92
translate english backwife_aur_f6969b02:

    # me "Прости. Принести тебе чего-нибудь?"
    me "抱歉。给你拿点什么吗？"

# game/a10/4backwife.rpy:93
translate english backwife_aur_92a61877:

    # aurora "Не нужно. У меня тут есть все что нужно у кровати."
    aurora "不需要。我床边什么都有。"

# game/a10/4backwife.rpy:94
translate english backwife_aur_d6079ddc:

    # me "Это ты захотела фруктов или он?"
    me "这是你想吃水果还是他想？"

# game/a10/4backwife.rpy:95
translate english backwife_aur_3124411b:

    # aurora "Или она. Я все еще не уверена."
    aurora "或是她想。我还是不确定。"

# game/a10/4backwife.rpy:96
translate english backwife_aur_ac7d6bc1:

    # me "Ты же сказала он очень активный."
    me "你不是说他很活跃？"

# game/a10/4backwife.rpy:97
translate english backwife_aur_9d0572b5:

    # aurora "Может это боевая девчонка. Как твоя сестра."
    aurora "可能是个好动的丫头。像你妹妹一样。"

# game/a10/4backwife.rpy:98
translate english backwife_aur_2552f441:

    # me "Какая из двух?"
    me "两个中的哪个？"

# game/a10/4backwife.rpy:99
translate english backwife_aur_9f82f2fc:

    # aurora "Офелия. Как только она узнала, что я беременна - она не отлипает от меня ни на секунду."
    aurora "Ophelia。她一知道我怀孕，就一刻不离地盯着我。"

# game/a10/4backwife.rpy:100
translate english backwife_aur_489a247d:

    # me "Правда?"
    me "真的？"

# game/a10/4backwife.rpy:101
translate english backwife_aur_5dc18792:

    # aurora "Да. Читает мне книги о беременности и родах, мажет мне живот какими-то кремами, выводит меня гулять во внутренний двор."
    aurora "是的。给我读怀孕和分娩的书，给我肚子涂什么霜，带我去内庭散步。"

# game/a10/4backwife.rpy:102
translate english backwife_aur_3a2a3856:

    # me "Хочешь я поговорю с ней и она отстанет."
    me "要不要我找她说，让她别再这样。"

# game/a10/4backwife.rpy:103
translate english backwife_aur_f8bc3267:

    # aurora "Не надо. Она хорошая девочка. Без нее мне будет скучно."
    aurora "不需要。她是个好姑娘。没她我会无聊的。"

# game/a10/4backwife.rpy:104
translate english backwife_aur_71d3b8c8:

    # me "Хорошо."
    me "好的。"

# game/a10/4backwife.rpy:105
translate english backwife_aur_71bdb886:

    # aurora "Ну что, так и будем болтать ночью? Может все-таки договорим с утра?"
    aurora "那么，我们就这样晚上聊天吗？要不早上再聊？"

# game/a10/4backwife.rpy:111
translate english backwife_aur_7c3a9dcb:

    # aurora "[mename], ты чего?"
    aurora "[mename]，你怎么了？"

# game/a10/4backwife.rpy:112
translate english backwife_aur_3e690519:

    # me "Погоди секунду. Дай мне насладится твоей красотой."
    me "等一秒。让我欣赏你的美。"

# game/a10/4backwife.rpy:113
translate english backwife_aur_660d73f7:

    # aurora "Красотой? Шутишь? У меня огромный живот."
    aurora "美？开玩笑？我肚子这么大。"

# game/a10/4backwife.rpy:114
translate english backwife_aur_b4a5dd07:

    # me "Это живот с моим ребенком. Он тебе очень идет."
    me "这是怀着我的孩子的肚子。你很好看。"

# game/a10/4backwife.rpy:115
translate english backwife_aur_2b71bc54_3:

    # aurora "..."
    aurora "..."

# game/a10/4backwife.rpy:117
translate english backwife_aur_925a01ef:

    # me "Когда Офелия читала тебе книги о беременности, она случайно не упоминала, можно ли беременным заниматься сексом?"
    me "Ophelia给你读怀孕书籍时，她没提过孕妇能不能做爱吗？"

# game/a10/4backwife.rpy:118
translate english backwife_aur_e0f42b14_1:

    # aurora "Нет."
    aurora "没有。"

# game/a10/4backwife.rpy:119
translate english backwife_aur_350c783d:

    # me "Нет - нельзя или нет - не упоминала."
    me "没有——是不能，还是没有——没提到。"

# game/a10/4backwife.rpy:120
translate english backwife_aur_40258fff:

    # aurora "Зачем бы ей о таком мне читать."
    aurora "她为什么给我读那种东西。"

# game/a10/4backwife.rpy:121
translate english backwife_aur_a8ba3f20:

    # me "А ты сама не знаешь?"
    me "你自己不知道吗？"

# game/a10/4backwife.rpy:122
translate english backwife_aur_984e365f:

    # aurora "Наверное можно, но..."
    aurora "大概可以，但..."

# game/a10/4backwife.rpy:123
translate english backwife_aur_511310db:

    # me "Но?"
    me "但？"

# game/a10/4backwife.rpy:124
translate english backwife_aur_b3ed366f:

    # aurora "Но нужно подобрать удобную позу."
    aurora "但需要找个舒适的姿势。"

# game/a10/4backwife.rpy:126
translate english backwife_aur_4f966bdf:

    # me "Ну конечно. Скажи как."
    me "当然。告诉我怎么做。"

# game/a10/4backwife.rpy:127
translate english backwife_aur_bcc3ecd9:

    # aurora "Эм..."
    aurora "呃..."

# game/a10/4backwife.rpy:128
translate english backwife_aur_473733e0:

    # me "Не стесняйся."
    me "别害羞。"

# game/a10/4backwife.rpy:129
translate english backwife_aur_8ec1258f:

    # aurora "Нельзя создавать нагрузку на живот."
    aurora "不能给肚子压力。"

# game/a10/4backwife.rpy:130
translate english backwife_aur_86b96415:

    # me "Это понятно."
    me "这明白。"

# game/a10/4backwife.rpy:131
translate english backwife_aur_77c5a9b1:

    # aurora "И нельзя перенапрягаться."
    aurora "而且不能过度紧张。"

# game/a10/4backwife.rpy:132
translate english backwife_aur_57587a4c:

    # me "Ага. Значит двигаться должен в основном я...есть у меня одна идейка."
    me "啊。所以主要是我动...有个想法。"

# game/a10/4backwife.rpy:134
translate english backwife_aur_fc3740cd:

    # me "Ну как?"
    me "怎么样？"

# game/a10/4backwife.rpy:135
translate english backwife_aur_ffaa6c8d:

    # aurora "Я могу держать ногу сама."
    aurora "我能自己扶着腿。"

