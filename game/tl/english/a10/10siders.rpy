# game/a10/10siders.rpy:322
translate english siders_ala_3b755290:

    # me "Я же сказал - я не буду обсуждать свое решение."
    me "我说了——我不会讨论我的决定。"

# game/a10/10siders.rpy:323
translate english siders_ala_e34a0cd5:

    # lia "Здравствуйте, леди [alaina]."
    lia "您好，[alaina]女士。"

# game/a10/10siders.rpy:324
translate english siders_ala_6693ae43:

    # ala "Здравствуй, [lia]. Я хотела поговорить не об этом."
    ala "你好，[lia]。我不是来谈那件事的。"

# game/a10/10siders.rpy:325
translate english siders_ala_6df5808a:

    # me "А о чем?"
    me "那是什么事？"

# game/a10/10siders.rpy:326
translate english siders_ala_c4ba9459:

    # ala "О кое-чем другом."
    ala "别的事。"

# game/a10/10siders.rpy:327
translate english siders_ala_3820771a:

    # me "..."
    me "..."

# game/a10/10siders.rpy:328
translate english siders_ala_d3b959a2:

    # lia "Мне выйти?"
    lia "要我出去吗？"

# game/a10/10siders.rpy:329
translate english siders_ala_74189200:

    # ala "Если не сложно."
    ala "如果可以的话。"

# game/a10/10siders.rpy:330
translate english siders_ala_1e1cb6d5:

    # lia "Ладно."
    lia "好吧。"

# game/a10/10siders.rpy:332
translate english siders_ala_ac2cf65d:

    # ala "Надеюсь я не сильно помешала."
    ala "希望我没太打扰。"

# game/a10/10siders.rpy:333
translate english siders_ala_b1233bc0:

    # me "Не сильно."
    me "还行。"

# game/a10/10siders.rpy:334
translate english siders_ala_89a79304:

    # ala "..."
    ala "..."

# game/a10/10siders.rpy:335
translate english siders_ala_f71c90f1:

    # me "Ну?"
    me "嗯？"

# game/a10/10siders.rpy:336
translate english siders_ala_eb75183a:

    # ala "Я пришла не тем, чтобы просить отменять твое решение. Честно. Не нужно злиться."
    ala "我不是来请求你撤销决定的。真的。别生气。"

# game/a10/10siders.rpy:337
translate english siders_ala_4f417eed:

    # me "Я не злюсь. Просто вы оба добавляете мне головной боли."
    me "我没生气。只是你们俩都增加了我的头疼事。"

# game/a10/10siders.rpy:338
translate english siders_ala_6f7da5d6:

    # ala "Понимаю. Быть правителем нелегко."
    ala "明白。当统治者不易。"

# game/a10/10siders.rpy:339
translate english siders_ala_ed7a05e0:

    # me "Я еще не правитель."
    me "我还不是统治者。"

# game/a10/10siders.rpy:340
translate english siders_ala_60a534cc:

    # ala "Но уже устал от его обязанностей."
    ala "但已经为他的职责感到疲惫了。"

# game/a10/10siders.rpy:341
translate english siders_ala_3e04892f:

    # me "...это не усталость. Просто раздражение."
    me "...那不是疲惫。只是烦躁。"

# game/a10/10siders.rpy:343
translate english siders_ala_2e005b2a:

    # ala "Я правда раздражаю тебя?"
    ala "我真的让你烦躁了吗？"

# game/a10/10siders.rpy:344
translate english siders_ala_af193843:

    # me "Вы оба. Я рассчитываю на вашу поддержку, поэтому эти склоки..."
    me "你们俩都是。我指望你们的支持，所以这些内讧..."

# game/a10/10siders.rpy:345
translate english siders_ala_42d574c6:

    # ala "Понимаю. Это мешает тебе быть принцем-регентом."
    ala "明白。这妨碍你当摄政王子了。"

# game/a10/10siders.rpy:346
translate english siders_ala_ab196231:

    # me "Ага. Можно и так сказать."
    me "啊哈。可以这么说。"

# game/a10/10siders.rpy:347
translate english siders_ala_9358126e:

    # ala "А мне кажется ты отлично справляешься."
    ala "可我觉得你处理得非常好。"

# game/a10/10siders.rpy:348
translate english siders_ala_dd3c40b8:

    # me "Я не люблю пустую лесть."
    me "我不喜欢空洞的奉承。"

# game/a10/10siders.rpy:349
translate english siders_ala_c64dd70a:

    # ala "Это не лесть. Я правда так считаю."
    ala "这不是奉承。我真这么觉得。"

# game/a10/10siders.rpy:350
translate english siders_ala_a1c19baf:

    # me "Ты пришла поговорить о том, как я хорошо справляюсь?"
    me "你来就是为了说我处理得有多好？"

# game/a10/10siders.rpy:351
translate english siders_ala_2d326d45:

    # ala "Нет."
    ala "不是。"

# game/a10/10siders.rpy:352
translate english siders_ala_51ff469d:

    # me "Тогда может уже перейдем к основному блюду?"
    me "那现在能上主菜了吗？"

# game/a10/10siders.rpy:354
translate english siders_ala_fc6b6891:

    # ala "...ладно."
    ala "...好吧。"

# game/a10/10siders.rpy:355
translate english siders_ala_01822020:

    # me "Ладно."
    me "好吧。"

# game/a10/10siders.rpy:356
translate english siders_ala_fb2a5324:

    # ala "Я хотела зайти издалека, но раз уж ты настолько мне не доверяешь, что всюду видишь лесть и обман..."
    ala "我本想绕个弯子，可既然你已经如此不信任我，到处都看到奉承和欺骗..."

# game/a10/10siders.rpy:357
translate english siders_ala_3820771a_1:

    # me "..."
    me "..."

# game/a10/10siders.rpy:358
translate english siders_ala_795173e1:

    # ala "Собственно об этом я и хотела поговорить."
    ala "其实，我想谈的正是这个。"

# game/a10/10siders.rpy:359
translate english siders_ala_74c20ff1:

    # me "О чем?"
    me "谈什么？"

# game/a10/10siders.rpy:360
translate english siders_ala_75a1c1ff:

    # ala "О недоверии и его причинах."
    ala "关于不信任，及其原因。"

# game/a10/10siders.rpy:361
translate english siders_ala_baa358ab:

    # me "Я жду."
    me "我等着呢。"

# game/a10/10siders.rpy:362
translate english siders_ala_3bf3f3e2:

    # ala "Видишь ли, [mename], ты абсолютно прав в том, что все подвергаешь сомнению. Вокруг очень много лжи."
    ala "你看，[mename]，你怀疑一切是绝对正确的。身边的谎言实在太多了。"

# game/a10/10siders.rpy:363
translate english siders_ala_b149200d:

    # ala "Маленькой лжи, большой и ... той лжи, которой лучше навсегда быть похороненной в вечном молчании."
    ala "细小的谎言，巨大谎言，以及...那种最好永远埋葬于永恒沉默中的谎言。"

# game/a10/10siders.rpy:364
translate english siders_ala_1d18ed60:

    # ala "Знаешь. Такая ложь, что должна остаться для всех правдой, а иначе она уничтожит все вокруг."
    ala "要知道。是那种必须让所有人都以为它是真相，否则就会摧毁周围一切的谎言。"

# game/a10/10siders.rpy:366
translate english siders_ala_c008ce6a:

    # me "Ближе к делу."
    me "说重点。"

# game/a10/10siders.rpy:367
translate english siders_ala_eed3b1ea:

    # ala "Конечно. Ты справедливо не доверял мне. Я действительно тебе лгала."
    ala "当然。你不信任我是对的。我确实对你说了谎。"

# game/a10/10siders.rpy:368
translate english siders_ala_d8e7f793:

    # me "В чем?"
    me "在什么事情上？"

# game/a10/10siders.rpy:369
translate english siders_ala_7685c405:

    # ala "Много в чем. Но сейчас я хочу рассказать тебе все правду. Чтобы ты понял - я лгала тебе во благо, [mename]."
    ala "很多方面。但现在，我想告诉你全部的真相。这样你就会明白——我是为了你好才说谎的，[mename]。"

# game/a10/10siders.rpy:370
translate english siders_ala_fd341de6:

    # me "Я слушаю."
    me "我听着呢。"

# game/a10/10siders.rpy:371
translate english siders_ala_5ffa540b:

    # ala "Что ты знаешь о своем отце?"
    ala "你对你的父亲了解多少？"

# game/a10/10siders.rpy:372
translate english siders_ala_149b3064:

    # me "В каком смысле?"
    me "什么方面？"

# game/a10/10siders.rpy:373
translate english siders_ala_334a322b:

    # ala "В прямом. Что тебе о нем известно?"
    ala "字面意思。你知道些关于他的什么？"

# game/a10/10siders.rpy:374
translate english siders_ala_863608ed:

    # me "Он был младшим сыном в семье Красного Императора, до того как родился Конрад, конечно. Когда мой дед потерпел поражение в битве у Синих Гор, он вернулся в столицу и был убит средним сыном."
    me "当然是在Conrad出生前，他是红帝家中的幼子。我的祖父在蓝山战役中失败后，他回到首都，被次子杀害了。"

# game/a10/10siders.rpy:375
translate english siders_ala_a12425bd:

    # me "Мой отец арестовал своего брата за отцеубийство, а позже казнил его. Дальше он женился на знатной девушке с Запада, стараясь сохранить регион в рушащейся Империи."
    me "我父亲以弑父罪名逮捕了他的兄弟，后来处决了他。之后，他娶了一位西方的贵族女子，试图在分崩离析的帝国中保住那个区域。"

# game/a10/10siders.rpy:376
translate english siders_ala_e9140dcf:

    # me "Потом родилась [cass], а ее мать умерла. Мой отец воевал несколько лет с эльфами. Чтобы предотвратить дальнейшее кровопролитие, он женился на моей матери."
    me "后来[cass]出生了，她母亲死了。我父亲与精灵打了好几年仗。为了防止进一步的流血冲突，他娶了我的母亲。"

# game/a10/10siders.rpy:377
translate english siders_ala_89a79304_1:

    # ala "..."
    ala "..."

# game/a10/10siders.rpy:378
translate english siders_ala_e4b7757e:

    # me "Продолжать?"
    me "还要继续吗？"

# game/a10/10siders.rpy:379
translate english siders_ala_7aedf881:

    # ala "Нет. Достаточно. Видишь ли. Кое-чего о своем отце ты не знаешь."
    ala "不。足够了。你看。关于你父亲，有些事情你并不知道。"

# game/a10/10siders.rpy:380
translate english siders_ala_4c5f0387:

    # me "Я догадываюсь."
    me "我猜到了。"

# game/a10/10siders.rpy:381
translate english siders_ala_82ade63b:

    # ala "Правда?"
    ala "真的吗？"

# game/a10/10siders.rpy:382
translate english siders_ala_db6558f5:

    # me "Ну да. Что ты скажешь? Наверно что это он на самом деле убил мать [cass]."
    me "嗯。你想说什么？大概是他杀了[cass]的母亲吧。"

# game/a10/10siders.rpy:383
translate english siders_ala_fcb71037:

    # ala "Нет. Твой отец не убивал мать [cass]. Видишь ли, отец [cass] умер раньше, чем ее мать."
    ala "不对。你父亲没有杀[cass]的母亲。你看，[cass]的父亲死得比她母亲早。"

# game/a10/10siders.rpy:384
translate english siders_ala_cc196945:

    # me "Что? Не понимаю? Как это?"
    me "什么？我不明白？怎么可能？"

# game/a10/10siders.rpy:385
translate english siders_ala_09981ca9:

    # ala "Понимаешь. У вас разные отцы."
    ala "你明白吗。你们有不同的父亲。"

# game/a10/10siders.rpy:386
translate english siders_ala_a3e4e7ba:

    # me "Это какой-то бред..."
    me "这是什么胡言乱语..."

# game/a10/10siders.rpy:387
translate english siders_ala_919ab0b3:

    # ala "Твой отец вовсе не Регис. Твой отец носит имя своего младшего брата, по случайности убитого своей женой."
    ala "你的父亲根本就不是Regis。你父亲用着他弟弟的名字，而他弟弟恰好是被他自己的妻子杀死的。"

# game/a10/10siders.rpy:389
translate english siders_ala_2a3a6a04:

    # me "ЧТО?"
    me "什么？"

# game/a10/10siders.rpy:390
translate english siders_ala_9558d758:

    # ala "Понимаю. Это шокирует."
    ala "我理解。这很让人震惊。"

# game/a10/10siders.rpy:391
translate english siders_ala_5ff43d0a:

    # me "Расскажи мне. Расскажи мне все."
    me "告诉我。把一切都告诉我。"

# game/a10/10siders.rpy:392
translate english siders_ala_88860dc0:

    # ala "Когда-то давно настоящий Регис привел меня ко двору, во время своих многочисленных вечеринок. Я заслужила его расположение и он назначил меня своим личным советником."
    ala "很久以前，在一次次的宴会上，真正的Regis把我带到了宫中。我赢得了他的青睐，他任命我为他的私人顾问。"

# game/a10/10siders.rpy:393
translate english siders_ala_c774514b:

    # ala "После битвы у Синих Гор и смерти Императора, Регис бросил твоего отца в темницу. Можешь не спрашивать кто на самом деле был убийцей, этого я не знаю."
    ala "蓝山战役和皇帝驾崩后，Regis把你的父亲投入了地牢。别问到底谁才是真正的凶手，这我就不知道了。"

# game/a10/10siders.rpy:394
translate english siders_ala_67c3dab3:

    # ala "Изначально я думала, что у настоящего Региса нет шансов. Но видимо я недооценила ненависть к Красному Императору."
    ala "最初我以为真正的Regis没有机会。但显然我低估了人们对红帝的憎恨。"

# game/a10/10siders.rpy:395
translate english siders_ala_ccaf7f75:

    # ala "Твой отец участвовал во всех походах Красного Императора, видимо знать боялась, что он слишком с ним связан."
    ala "你父亲参与了红帝的所有征战，看来贵族们担心他与他牵连太深。"

# game/a10/10siders.rpy:396
translate english siders_ala_53390f45:

    # ala "Поэтому они объединилась вокруг младшего сына и легитимизировали его правление, преклонив колено."
    ala "因此，他们团结在幼子周围，通过屈膝效忠，使他的统治合法化。"

# game/a10/10siders.rpy:397
translate english siders_ala_56c01ab0:

    # ala "Твоему отцу суждено было умереть, но я смогла убедить Региса сохранить ему жизнь."
    ala "你的父亲本该等死，但我设法说服Regis留了他一命。"

# game/a10/10siders.rpy:398
translate english siders_ala_39f3dd3d:

    # ala "Прошло время и Регис женился на матери [cass]. Мы подружились с ней."
    ala "时间过去，Regis娶了[cass]的母亲。我和她成了朋友。"

# game/a10/10siders.rpy:399
translate english siders_ala_4607e656:

    # ala "Он был избалован и его вздорный характер сыграл с ним злую шутку. Однажды Сибилла, мать [cass] пришла ко мне вся в крови. Оказалось она случайно убила Региса."
    ala "他被惯坏了，他骄纵的性格害了他。一天，[cass]的母亲西比拉浑身是血地来找我。原来她失手杀了Regis。"

# game/a10/10siders.rpy:400
translate english siders_ala_8acf5939:

    # ala "Нам повезло. Ни убийства ни ее никто не видел. Весь замок собрался на пиру в честь рождения [cass]."
    ala "我们很走运。没有人看见她，也没人看见谋杀。全城堡的人都聚集在庆祝[cass]诞生的宴会上。"

# game/a10/10siders.rpy:401
translate english siders_ala_5f3254a2:

    # me "И что дальше?"
    me "那后来呢？"

# game/a10/10siders.rpy:403
translate english siders_ala_8bc7277e:

    # ala "Дальше я приняла решение спасти королевство от дальнейшего распада. Знать бы не приняла старшего сына. А младший был мертв."
    ala "后来我决定拯救王国免于进一步的分裂。贵族们不会接受长子。而幼子已经死了。"

# game/a10/10siders.rpy:404
translate english siders_ala_e65c8087:

    # ala "Благо они были похожи друг на друга. Что было дальше думаю ты понимаешь. Немного магии, немного лжи о болезни и вот на троне старый новый, слегка потрепанный Регис."
    ala "幸好他们长得很像。之后的事我想你明白了。一点魔法，一点关于疾病的谎言，然后，王座上就是一个新的、有点磨损的旧Regis了。"

# game/a10/10siders.rpy:405
translate english siders_ala_c7358ffb:

    # me "Мой отец."
    me "我的父亲。"

# game/a10/10siders.rpy:406
translate english siders_ala_c42a128d:

    # ala "Да. Видишь ли, я бы не стала спасать королевство просто так. Я потребовала от твоего отца плату. Услугу. Понимаешь какую?"
    ala "是的。你看，我平白无故救下王国是不会的。我要求你父亲付出代价。一个恩情。你明白是什么吗？"

# game/a10/10siders.rpy:407
translate english siders_ala_052d1024:

    # me "Женитьба на моей матери."
    me "娶我的母亲。"

# game/a10/10siders.rpy:408
translate english siders_ala_79738ab3:

    # ala "Да. Но была проблема. Он вроде уже был женат."
    ala "是的。但有个问题。他当时已经结婚了。"

# game/a10/10siders.rpy:409
translate english siders_ala_d626fb44:

    # me "И что ты сделала?"
    me "那你做了什么？"

# game/a10/10siders.rpy:410
translate english siders_ala_aaa755d7:

    # ala "Я думаю ты понимаешь."
    ala "我想你明白的。"

# game/a10/10siders.rpy:411
translate english siders_ala_9ef3ab34:

    # me "Ты убила ее."
    me "你杀了她。"

# game/a10/10siders.rpy:412
translate english siders_ala_e889be6d:

    # ala "Мне было трудно это сделать. Но мне пришлось. Я убила ее. А дальше ты знаешь."
    ala "这么做很艰难。但我别无选择。我杀了她。之后的事你都知道了。"

# game/a10/10siders.rpy:413
translate english siders_ala_9139a8dd:

    # me "...но отец говорил что женился на матери из-за войны с эльфами Долины."
    me "...但父亲说，他娶母亲是因为和谷地精灵的战争。"

# game/a10/10siders.rpy:414
translate english siders_ala_7a12e157:

    # ala "Это вторая часть моей истории. Видишь ли. Все это время я действовала не одна."
    ala "这是我故事的第二部分。你看。所有这段时间，我并非孤身一人。"

# game/a10/10siders.rpy:415
translate english siders_ala_149b3064_1:

    # me "В каком смысле?"
    me "什么意思？"

# game/a10/10siders.rpy:416
translate english siders_ala_114b24e7:

    # ala "Наш народ. Он погибает, [mename]. Мы должны делать все, чтобы выжить. Поэтому мы наблюдаем из тени, ждем подходящего момента."
    ala "我的族人。他在灭亡，[mename]。为了生存，我们必须不择手段。所以，我们从暗处观察，等待时机。"

# game/a10/10siders.rpy:417
translate english siders_ala_3082aa1e:

    # ala "Пока я втиралась в доверие к настоящему Регису, мои братья и сестры тоже действовали."
    ala "当我赢取真正的Regis的信任时，我的兄弟姐妹们也在行动。"

# game/a10/10siders.rpy:418
translate english siders_ala_7d05dd83:

    # ala "Мы уже давно стремились попасть ко двору. Любым способом. Любым. Знаешь, во время походов бывает одиноко."
    ala "我们早就渴望进入宫廷。不惜任何代价。任何。要知道，征战途中会很孤独。"

# game/a10/10siders.rpy:419
translate english siders_ala_51a65bb8:

    # ala "Наши самые красивые девушки делили постель с солдатами и офицерами армии Красного Императора. Все они были чьими-то дочерями, сестрами и даже матерями."
    ala "我们最美的姑娘与红帝军队的士兵和军官同床共枕。她们都是某人的女儿、姐妹，甚至是母亲。"

# game/a10/10siders.rpy:420
translate english siders_ala_e130556f:

    # ala "Они жертвовали честью всего лишь ради шанса..."
    ala "她们牺牲了名誉，只为一个机会..."

# game/a10/10siders.rpy:421
translate english siders_ala_1c88edfe:

    # me "Шанса?"
    me "机会？"

# game/a10/10siders.rpy:422
translate english siders_ala_e7435a29:

    # ala "Шанса подобраться к Императорскому шатру."
    ala "接近帝王军帐的机会。"

# game/a10/10siders.rpy:423
translate english siders_ala_d363726b:

    # ala "Но там их ждала неудача. Император был верен жене. Зато его старший сын...был не прочь провести холодную ночь в объятиях эльфийки."
    ala "但她们在那里失败了。皇帝忠于他的妻子。然而，他的长子...却毫不介意在一个寒冷的夜晚拥抱着精灵女子。"

# game/a10/10siders.rpy:424
translate english siders_ala_c40e8b11:

    # ala "Он выбирал самых красивых и молодых, но никогда не проводил больше одной ночи с одной и той же. Пока однажды одна не запала ему в сердце."
    ala "他挑选最美、最年轻的，但从不在同一个身上花超过一晚的时间。直到有一天，一个精灵走进了他的心里。"

# game/a10/10siders.rpy:425
translate english siders_ala_69a58879:

    # ala "Это был еще один шанс. Он брал всюду ее с собой. Превратил в походную жену. Она даже родила ему детей."
    ala "这是另一个机会。他到哪儿都带着她。她成了他的随军妻子。她甚至为他生了孩子。"

# game/a10/10siders.rpy:426
translate english siders_ala_0f2b1a0a:

    # me "У моего отца есть еще дети?"
    me "我的父亲还有其他孩子？"

# game/a10/10siders.rpy:427
translate english siders_ala_bbf08e5b:

    # ala "Да. Но когда произошли события с Регисом и Сибиллой...мы решили, что легитимные наследники лучше бастардов. Так что твой отец взял твою мать в жены."
    ala "是的。但当Regis和西比拉的事件发生后...我们决定，婚生的继承人优于私生子。所以你父亲娶了你母亲为妻。"

# game/a10/10siders.rpy:428
translate english siders_ala_feb4b956:

    # ala "Конечно пришлось потянуть за некоторые ниточки, чтобы такой союз не был встречен восстанием."
    ala "当然，为了不让这种联盟引发叛乱，我们不得不动用了一些关系。"

# game/a10/10siders.rpy:429
translate english siders_ala_49f52169:

    # me "Ниточки?"
    me "关系？"

# game/a10/10siders.rpy:430
translate english siders_ala_6ecc942c:

    # ala "Да. Шантаж. Угрозы. Убийства. Сотни эльфов погибли, грабя караваны на тракте. Все ради шанса..."
    ala "是的。勒索。威胁。谋杀。数百精灵死在劫掠的道路商队上。一切都只为一个机会..."

# game/a10/10siders.rpy:431
translate english siders_ala_3820771a_2:

    # me "..."
    me "..."

# game/a10/10siders.rpy:432
translate english siders_ala_1abef119:

    # ala "Все ради тебя. Ты наш шанс, [mename]."
    ala "一切为了你。你就是我们的机会，[mename]。"

# game/a10/10siders.rpy:433
translate english siders_ala_37a4636d:

    # me "Этого не может быть..."
    me "这不可能..."

# game/a10/10siders.rpy:434
translate english siders_ala_4004886d:

    # ala "Все это правда, [mename]. Все до единого слова."
    ala "全都是真的，[mename]。一字不差。"

# game/a10/10siders.rpy:435
translate english siders_ala_a2b9da63:

    # me "Как я могу в это поверить?"
    me "我怎么能相信这个？"

# game/a10/10siders.rpy:436
translate english siders_ala_6d2616e4:

    # ala "Стала бы я лгать, если бы моя ложь привела меня на плаху?"
    ala "如果我撒谎会把我送上断头台，我还会撒谎吗？"

# game/a10/10siders.rpy:437
translate english siders_ala_1bcd16b2:

    # me "Я не знаю..."
    me "我不知道..."

# game/a10/10siders.rpy:438
translate english siders_ala_49ee6cd4:

    # ala "Это потому что я еще не закончила."
    ala "那是因为我还没说完。"

# game/a10/10siders.rpy:439
translate english siders_ala_759ed3ba:

    # ala "Видишь ли, [mename], я заботилась о тебе с самого начала. Я делала все, чтобы ты сел на трон."
    ala "你看，[mename]，从一开始我就在照顾你。我做的一切，都是为了让你坐上王座。"

# game/a10/10siders.rpy:440
translate english siders_ala_c657fbbc:

    # ala "Как только родились ты и твоя сестра, твой отец стал строптивым. Он понял, что теперь для стабильности королевства его жизнь стала важна. Вряд ли вассалы бы приняли малолетнего полуэльфа королем."
    ala "你和你的妹妹一出生，你父亲就变得难以驾驭。他意识到，为了王国的稳定，他的性命变得重要起来。封臣们大概不会接受一个幼小的半精灵当国王。"

# game/a10/10siders.rpy:441
translate english siders_ala_6056f668:

    # ala "Благо подвернулся удачный случай. Ты выколол своей сестре глаз и тебя изгнали...по моему совету."
    ala "幸好碰上个好机会。你挖出了你妹妹的一只眼睛，然后你被流放了...根据我的建议。"

# game/a10/10siders.rpy:442
translate english siders_ala_75823b01:

    # ala "Вдали от дворца защитить тебя было легче."
    ala "远离王宫，保护你更容易。"

# game/a10/10siders.rpy:443
translate english siders_ala_9329ecc9:

    # ala "Твой отец думал, что его положение улучшилось. Он стал сильнее. Но я отравила его. А мои помощники травили его все это время."
    ala "你父亲以为他的处境改善了。他变得更强了。但我毒害了他。而我的助手们一直在给他下毒。"

# game/a10/10siders.rpy:444
translate english siders_ala_b76881e3:

    # me "Травили?"
    me "下毒？"

# game/a10/10siders.rpy:446
translate english siders_ala_4f3cff8f:

    # ala "Особый яд. Пурпурная смоковница и болотный лук. Оказывает сильное влияние на...нижнюю часть тела."
    ala "一种特殊的毒药。紫榕和沼泽葱。对...下半身有强烈影响。"

# game/a10/10siders.rpy:447
translate english siders_ala_5e5ebfb6:

    # me "Ты сделала моего отца бесплодным?"
    me "你让我父亲失去生育能力了？"

# game/a10/10siders.rpy:448
translate english siders_ala_30490bbf:

    # ala "Ну ты же не хотел бы по возвращению встретить во дворце парочку бастардов? Кто знает чьи притязания на трон были бы более легитимными в глазах вассалов."
    ala "嗯，你不会希望在回来时在宫中遇到几个私生子吧？谁知道在封臣眼中，谁对王位的宣称会更合法呢。"

# game/a10/10siders.rpy:449
translate english siders_ala_9f3b8f47:

    # ala "Но это конечно не все. Я готовила множество рычагов влияния на твоего отца."
    ala "但这当然不是全部。我准备了大量的筹码来影响你的父亲。"

# game/a10/10siders.rpy:450
translate english siders_ala_79db05e5:

    # me "Оракулы?"
    me "神谕者？"

# game/a10/10siders.rpy:451
translate english siders_ala_e86fd84d:

    # ala "Да. Они самые. Но это был лишь способ влияния. Мне нужен был инструмент для...смещения твоего отца с трона."
    ala "是的。就是她们。但这只是一种影响方式。我需要一个工具，来...将你父亲从王座上赶下来。"

# game/a10/10siders.rpy:452
translate english siders_ala_c3332f4a:

    # ala "Поэтому я много лет состояла в переписке с Присциллой, сестрой Сибиллы. Она рвалась отомстить Регису, не зная, что тот уже мертв. Но я отговаривала ее, говорила что еще не время."
    ala "为此，多年来我一直与西比拉的姐妹Priscilla保持通信。她一心想向Regis复仇，却不知道他早已死了。但我劝阻了她，告诉她时机未到。"

# game/a10/10siders.rpy:453
translate english siders_ala_e2759860:

    # ala "Ну и конечно твоя сестра. Сначала я не хотела использовать ее. Но когда она стала подсылать своих оракулов...я поняла, что она может быть проблемой."
    ala "当然还有你的姐姐。起初我不想利用她。但当她开始派自己的神谕者来时...我意识到她可能会成为一个问题。"

# game/a10/10siders.rpy:454
translate english siders_ala_e7dffe8a:

    # ala "Благо был способ решить все эти проблемы просто столкнув их. Я сказала твоей сестре, что твой отец убил ее мать. Благо за годы переписок с Присциллой я собрала достаточно доказательств вины Региса."
    ala "幸好有个办法可以解决所有这些问题，就是让她们相互碰撞。我告诉你姐姐，是你的父亲杀了她的母亲。庆幸的是，在与Priscilla多年的通信中，我收集了足够证明Regis罪行的证据。"

# game/a10/10siders.rpy:455
translate english siders_ala_7ff1cb0e:

    # ala "Откуда им было знать, что он уже мертв?"
    ala "她们怎么能知道，他早就死了？"

# game/a10/10siders.rpy:456
translate english siders_ala_01a7d6ae:

    # me "Зачем....зачем ты мне это рассказываешь?"
    me "为什么....你为什么要告诉我这些？"

# game/a10/10siders.rpy:457
translate english siders_ala_60173902:

    # ala "Хочу, чтобы знал правду."
    ala "想让你知道真相。"

# game/a10/10siders.rpy:459
translate english siders_ala_356066eb:

    # ala "Если бы не эльфы, ты бы никогда не родился [mename], ты бы никогда не стал единственным наследником, ты бы никогда не занял трон в таком юном возрасте."
    ala "如果没有精灵，你永远不会出生，[mename]，你永远不会成为唯一的继承人，你也永远不会在如此年轻时坐上王座。"

# game/a10/10siders.rpy:460
translate english siders_ala_5b503876:

    # me "Я этого не просил."
    me "我没要求这些。"

# game/a10/10siders.rpy:461
translate english siders_ala_bd8f15a5:

    # ala "Но это уже случилось. Ты молодой принц-регент. Скоро ты станешь императором. В твоей власти судьбы миллионов."
    ala "但这一切已经发生了。你是年轻的摄政王子。很快你就会成为皇帝。数百万人的命运掌握在你手中。"

# game/a10/10siders.rpy:462
translate english siders_ala_3820771a_3:

    # me "..."
    me "..."

# game/a10/10siders.rpy:463
translate english siders_ala_e62b3192:

    # ala "Я сделала тебя тем, кто ты есть. Твоя жизнь- это великий шанс, шанс для нашего народа и для тебя."
    ala "我将你塑造成今天的你。你的生命是一个伟大的机会，是我族的机会，也是你的机会。"

# game/a10/10siders.rpy:464
translate english siders_ala_2d5e6206:

    # me "Шанс?"
    me "机会？"

# game/a10/10siders.rpy:465
translate english siders_ala_7e819f32:

    # ala "Шанс показать, что все это было не напрасно."
    ala "一个证明这一切都没有白费的机会。"

# game/a10/10siders.rpy:466
translate english siders_ala_3820771a_4:

    # me "..."
    me "..."

# game/a10/10siders.rpy:467
translate english siders_ala_91f0ed2a:

    # ala "После всего, что ты узнал, теперь ты доверяешь мне? Ты веришь, что тайна, что я хранила, а теперь хранишь и ты достойна того, чтобы никогда не быть раскрытой?"
    ala "在知道这一切之后，现在你信任我吗？你相信，我所守护的秘密，以及现在你所守护的秘密，值得永不揭开吗？"

# game/a10/10siders.rpy:468
translate english siders_ala_90f1a376:

    # ala "Твой дядя не знает ничего этого. Он преследует меня, думая что я хочу власти или богатств. Но я хочу шанса. Твоего шанса. Великого шанса."
    ala "你的叔叔对此一无所知。他迫害我，以为我贪图权力或财富。但我想要的是一个机会。你的机会。伟大的机会。"

# game/a10/10siders.rpy:469
translate english siders_ala_ff645bd4:

    # ala "Я помогу тебе, [mename]. Всем чем только смогу. Теперь, когда ты все знаешь, тебе просто нужно довериться мне."
    ala "我会帮助你的，[mename]。尽我所能。现在，你知道了一切，你只需信任我。"

# game/a10/10siders.rpy:473
translate english siders_ala_8633cf20:

    # me "Это безумие."
    me "这太疯狂了。"

# game/a10/10siders.rpy:474
translate english siders_ala_80a838ce:

    # ala "Знаю. Такое тяжело принять."
    ala "我知道。这很难接受。"

# game/a10/10siders.rpy:475
translate english siders_ala_4b90ee02:

    # me "Тяжело. Но у меня нет выбора. Все это время была ты. Ты дергала нитками. Если бы ты хотела - я был бы уже мертв. Если бы ты хотела - я бы даже не родился."
    me "是很难。但我别无选择。一直以来都是你。是你在背后操控一切。如果你愿意，我早就死了。如果你愿意，我甚至不会出生。"

# game/a10/10siders.rpy:476
translate english siders_ala_06c32589:

    # ala "И все же ты жив и ты на троне."
    ala "可你还活着，而且你在王座上。"

# game/a10/10siders.rpy:477
translate english siders_ala_6c5c4041:

    # me "Знаю. Поэтому я тебе верю. Я не чувствую в тебе личной корысти. Ты делаешь все ради своего народа."
    me "我知道。所以我信你。我感觉不到你对我有什么私心。你所做的全是为了你的族人。"

# game/a10/10siders.rpy:478
translate english siders_ala_952ba102:

    # ala "Это и твой народ."
    ala "这也是你的族人。"

# game/a10/10siders.rpy:479
translate english siders_ala_0aa47e43:

    # me "Да. Я тебе верю. Если бы ты считала меня просто инструментом, я бы никогда не услышал того, что услышал сегодня. Я тебе верю."
    me "是的。我信你。如果你只把我当成工具，我永远也不会听到我今天所听到的。我信你。"

# game/a10/10siders.rpy:480
translate english siders_ala_cd82db63:

    # ala "Хорошо, [mename]. Это все что я хотела услышать."
    ala "很好，[mename]。这就是我想听到的全部。"

# game/a10/10siders.rpy:481
translate english siders_ala_19ad577d:

    # me "Я немедленно отзову разрешение на слежку и обыски."
    me "我马上撤销监视和搜查的许可。"

# game/a10/10siders.rpy:482
translate english siders_ala_337abebc:

    # ala "Не стоит. Теперь когда мы друг другу доверяем - пусть твой дядя ищет что хочет. Он ничего не найдет."
    ala "不必了。既然现在我们彼此信任——就让你叔叔随便去找吧。他什么也找不到。"

# game/a10/10siders.rpy:483
translate english siders_ala_71d3b8c8:

    # me "Хорошо."
    me "好的。"

# game/a10/10siders.rpy:484
translate english siders_ala_cd88a224:

    # ala "До встречи, [mename]."
    ala "再见，[mename]。"

# game/a10/10siders.rpy:488
translate english siders_ala_5eaddf99:

    # me "Ты преступница."
    me "你是个罪犯。"

# game/a10/10siders.rpy:489
translate english siders_ala_b0ba20e9:

    # ala "Ты ничего не понял, да?"
    ala "你还是没明白，对吧？"

# game/a10/10siders.rpy:490
translate english siders_ala_463c04aa:

    # me "Я все понял. Я твой инструмент. И видимо должен подчиняться и благодарить тебя за то, что ты надела на меня корону."
    me "我全明白了。我是你的工具。而且显然，我必须服从并感谢你，因为你把王冠戴到了我的头上。"

# game/a10/10siders.rpy:491
translate english siders_ala_89a79304_2:

    # ala "..."
    ala "..."

# game/a10/10siders.rpy:492
translate english siders_ala_f4b8637d:

    # me "Этому не бывать. Я думаю ты боялась, боялась тайна вскроется и без твоей помощи. Поэтому и все мне рассказать."
    me "这绝不可能。我想你是害怕，害怕秘密会在没有你帮助的情况下暴露出来。所以你把一切都告诉了我。"

# game/a10/10siders.rpy:494
translate english siders_ala_489998a1:

    # me "Что ты делаешь?"
    me "你在做什么？"

# game/a10/10siders.rpy:495
translate english siders_ala_8a7dd3fe:

    # ala "Ухожу."
    ala "离开。"

# game/a10/10siders.rpy:496
translate english siders_ala_25f7abbc:

    # me "Куда?"
    me "去哪儿？"

# game/a10/10siders.rpy:497
translate english siders_ala_2d6b7e1f:

    # ala "Подальше отсюда. Я же не идиотка, [mename], если после того, как я все это тебе рассказала ты все еще мне не доверяешь..."
    ala "离这儿越远越好。我又不是傻瓜，[mename]，如果在我把所有事都告诉你之后，你还是不信任我..."

# game/a10/10siders.rpy:498
translate english siders_ala_45cb6b74:

    # ala "Значит теперь мое пребывание здесь небезопасно. Ты не самоубийца, чтобы раскрывать ВСЁ, что я тут тебе сказала."
    ala "那就意味着我再待在这里不安全了。你不会傻到去公开我对你说的‘一切’。"

# game/a10/10siders.rpy:499
translate english siders_ala_2d34a9aa:

    # ala "Но ты вполне можешь решить убить меня. Чтобы я никогда не смогла воспользоваться тем, что знаю."
    ala "但你完全可以决定杀掉我。这样我就永远无法利用我所知道的事情了。"

# game/a10/10siders.rpy:500
translate english siders_ala_3820771a_5:

    # me "..."
    me "..."

# game/a10/10siders.rpy:501
translate english siders_ala_cbde14ac:

    # ala "Прощай, [mename]. Мы еще встретимся. А пока помни о том, что я знаю."
    ala "再会了，[mename]。我们还会再见面的。同时，记住我所知道的一切。"

# game/a10/10siders.rpy:502
translate english siders_ala_7aedf677:

    # me "Если все что ты мне тут наплела, это вообще правда."
    me "如果你刚才对我胡扯的那些，整个都是真的的话。"

# game/a10/10siders.rpy:503
translate english siders_ala_1b9d11ac:

    # ala "Ооо, это правда. Спроси своего отца. Может у него хватит смелости подтвердить мои слова."
    ala "哦哦，这是真的。问问你父亲。或许他有勇气证实我的话。"

# game/a10/10siders.rpy:508
translate english siders_con_eb63207d:

    # conrad "Принцесса. Принц."
    conrad "公主。王子。"

# game/a10/10siders.rpy:509
translate english siders_con_d4709a8a:

    # me "Конрад, уйди, я не стану менять свое мнение."
    me "Conrad，走开，我不会改变我的想法。"

# game/a10/10siders.rpy:510
translate english siders_con_ff9e8554:

    # lia "Привет дядя Конрад!"
    lia "Conrad叔叔好！"

# game/a10/10siders.rpy:511
translate english siders_con_fdc000f7:

    # conrad "Я здесь не для этого."
    conrad "我不是为这个来的。"

# game/a10/10siders.rpy:512
translate english siders_con_f93f6d41:

    # me "А для чего."
    me "那是为了什么。"

# game/a10/10siders.rpy:513
translate english siders_con_bc1928a8:

    # conrad "Нужно поговорить."
    conrad "需要谈谈。"

# game/a10/10siders.rpy:514
translate english siders_con_3820771a:

    # me "..."
    me "..."

# game/a10/10siders.rpy:515
translate english siders_con_750e415f:

    # lia "Ну поговори с ним, [mename]."
    lia "你就和他谈谈吧，[mename]。"

# game/a10/10siders.rpy:516
translate english siders_con_9e84c635:

    # conrad "Я здесь не для того, чтобы просить поменять твое мнение."
    conrad "我不是来请求你改变看法的。"

# game/a10/10siders.rpy:517
translate english siders_con_f93f6d41_1:

    # me "А для чего."
    me "那是为了什么。"

# game/a10/10siders.rpy:518
translate english siders_con_77040892:

    # conrad "Разговор. Личный."
    conrad "谈谈。私下的。"

# game/a10/10siders.rpy:519
translate english siders_con_3d6eae10:

    # me "[lia], подождешь пару минут за дверью?"
    me "[lia]，你能在门外等几分钟吗？"

# game/a10/10siders.rpy:520
translate english siders_con_35f3a72a:

    # lia "Хорошо."
    lia "好。"

# game/a10/10siders.rpy:522
translate english siders_con_f71c90f1:

    # me "Ну?"
    me "嗯？"

# game/a10/10siders.rpy:523
translate english siders_con_4043c0df:

    # conrad "Я твой рыцарь-защитник, [mename]."
    conrad "我是你的守护骑士，[mename]。"

# game/a10/10siders.rpy:524
translate english siders_con_cd6e98a1:

    # me "Уже нет."
    me "不再是了。"

# game/a10/10siders.rpy:525
translate english siders_con_ac9955c8:

    # conrad "Знаю. Ты ведь и оставил меня присматривать за этим местом."
    conrad "知道。你不就是因此留下我，让我照看这个地方的吗。"

# game/a10/10siders.rpy:526
translate english siders_con_f9f0bdf8:

    # me "Ты перестарался."
    me "你做得太过了。"

# game/a10/10siders.rpy:527
translate english siders_con_52dafccf:

    # conrad "Это не так."
    conrad "并非如此。"

# game/a10/10siders.rpy:528
translate english siders_con_d0f278dd:

    # me "Это так. Слушай, ты вроде сказал, что пришел не за этим."
    me "就是这样。听着，你好像说过不是为这个来的。"

# game/a10/10siders.rpy:529
translate english siders_con_2b840775:

    # conrad "Верно. Ладно. Давай поговорим."
    conrad "没错。好吧。我们谈谈吧。"

# game/a10/10siders.rpy:530
translate english siders_con_129f2371:

    # me "Давай. О чем?"
    me "谈吧。谈什么？"

# game/a10/10siders.rpy:531
translate english siders_con_9055ade1:

    # conrad "О тайнах."
    conrad "关于秘密。"

# game/a10/10siders.rpy:533
translate english siders_con_c7edeb1a:

    # me "О тайнах? Звучит зловеще."
    me "秘密？听着真不祥。"

# game/a10/10siders.rpy:534
translate english siders_con_080e4812:

    # conrad "Я хочу рассказать тебе одну историю. Еще будучи ребенком я всегда мечтал стать рыцарем."
    conrad "我想给你讲个故事。从很小的时候起，我就梦想成为一名骑士。"

# game/a10/10siders.rpy:535
translate english siders_con_2d2cfeea:

    # me "У тебя получилось."
    me "你做到了。"

# game/a10/10siders.rpy:536
translate english siders_con_50f409c8:

    # conrad "Верно. Твой отец любил меня и назначил личным оруженосцем едва мне исполнилось двенадцать."
    conrad "对。你父亲很器重我，在我刚满十二岁的时候就任命我为他的贴身扈从。"

# game/a10/10siders.rpy:537
translate english siders_con_3b8eae79:

    # me "Я помню это. Ты охранял его даже за завтраком."
    me "我记得。你甚至在吃早餐时都护卫着他。"

# game/a10/10siders.rpy:538
translate english siders_con_538ef131:

    # conrad "Позволь мне продолжить."
    conrad "让我把话说完。"

# game/a10/10siders.rpy:539
translate english siders_con_8f9071f9:

    # me "Конечно."
    me "当然。"

# game/a10/10siders.rpy:540
translate english siders_con_ab32277a:

    # conrad "Я проводил много времени с твоим отцом. И за годы службы я вдруг понял, что он совершенно одинок."
    conrad "我和你父亲待在一起的时间很长。在服役的这些年里，我突然意识到他是多么孤独。"

# game/a10/10siders.rpy:541
translate english siders_con_19d1a587:

    # conrad "Они никогда, ни дня ни секунды не провел со своими друзьями или хотя бы подхалимами."
    conrad "他从未，没有一天，没有一秒，跟他的朋友们，哪怕跟阿谀奉承的人待在一起过。"

# game/a10/10siders.rpy:542
translate english siders_con_ba5d0479:

    # conrad "Я не мог понять, как это? Ведь у моего брата знали за пьянство и кутеж в молодости. Я не мог поверить, что человек так быстро поменялся."
    conrad "我想不明白怎么会这样？我可知道我哥哥年轻时以酗酒和宴饮闻名。我真不敢相信一个人会变得这么快。"

# game/a10/10siders.rpy:543
translate english siders_con_f093df74:

    # me "Действительно таинственная история."
    me "真是个神秘的故事。"

# game/a10/10siders.rpy:544
translate english siders_con_7887e8ce:

    # conrad "Слушай дальше. Я решил сделать твоему отцу приятное. Разыскать пару его друзей из прошлого. Я хотел расспросить старых слуг, чтобы узнать с кем Регис раньше общался, но оказалось что старых слуг в замке нет."
    conrad "接着听我说。我想为你父亲做点好事。找到几个他以前的朋友。我想问问老仆人，想了解Regis以前和谁交往，但结果，城堡里一个老仆人都没有。"

# game/a10/10siders.rpy:545
translate english siders_con_1b32cfea:

    # me "Как это?"
    me "怎么会这样？"

# game/a10/10siders.rpy:546
translate english siders_con_f93a46e2:

    # conrad "Вот так. Все слуги в замке появились не раньше рождения твоей старшей сестры."
    conrad "就这样。城堡里的所有仆人，都是在你大姐出生后才出现的。"

# game/a10/10siders.rpy:547
translate english siders_con_2cfff1f4:

    # conrad "Но дальше еще страннее. Я расспросил Людвига и он назвал мне пару имен. Я начал искать и..."
    conrad "但更奇怪的事还在后头。我问了Ludwig，他给了我几个名字。我开始去寻访，然后..."

# game/a10/10siders.rpy:548
translate english siders_con_f46c88fa:

    # conrad "Удивительно дело. Все они были мертвы. Все до единого. Кто-то неудачно упал. Кого-то убили разбойники. Кто-то и вовсе пропал."
    conrad "真是怪事。他们全死了。一个不剩。有人失足而死。有人被强盗杀了。还有人干脆失踪了。"

# game/a10/10siders.rpy:549
translate english siders_con_4bf3b0be:

    # conrad "Я решил узнать больше имен. Решил найти часто встречающиеся имена в замковых журналах. Но их не было. Пропали."
    conrad "我决定找到更多的名字。决定从城堡日志里找那些频繁出现的名字。但它们都不见了。失踪了。"

# game/a10/10siders.rpy:550
translate english siders_con_8d83da37:

    # conrad "Повезло что я знал, что старый звонарь переписывал все журналы для себя. Он так готовился встречать важных гостей, что прибывали в определенные дни...не важно."
    conrad "幸好我知道老敲钟人会为自己抄录所有的日志。他这么做是为了准备迎接特定某天到来的重要宾客...这不重要。"

# game/a10/10siders.rpy:551
translate english siders_con_f434f210:

    # conrad "Я выписал себе пару имен. Среди них оказались люди, что не особо знали твоего отца, но знали с кем он общался."
    conrad "我给自己抄了几个名字。其中有些人跟你父亲不熟，但认识跟他交往的人。"

# game/a10/10siders.rpy:552
translate english siders_con_3b49f6f7:

    # conrad "И знаешь что?"
    conrad "你猜怎么着？"

# game/a10/10siders.rpy:554
translate english siders_con_84918789:

    # me "Они все были мертвы?"
    me "他们也都死了？"

# game/a10/10siders.rpy:555
translate english siders_con_055b00f9:

    # conrad "Они все были мертвы."
    conrad "他们也都死了。"

# game/a10/10siders.rpy:556
translate english siders_con_f95c9fc9:

    # me "И?"
    me "所以呢？"

# game/a10/10siders.rpy:557
translate english siders_con_f1147408:

    # conrad "Я нашел одного торговца, что числился погибшим в кораблекрушении. Он согласился увидиться с Регисом. Я подговорил его представиться другим человеком. А твоему отцу сказал фальшивое имя."
    conrad "我找到了一个据说在海难中丧生的商人。他同意和Regis见面。我说服他伪装成另一个人。然后我告诉了你父亲一个假名字。"

# game/a10/10siders.rpy:558
translate english siders_con_0a7f9f1c:

    # conrad "И знаешь что? Твой отец якобы узнал его. Узнал его под фальшивым именем."
    conrad "你猜怎么着？你父亲好像认出了他。以一个假名认出了他。"

# game/a10/10siders.rpy:559
translate english siders_con_7f381ba3:

    # me "И что все это значит?"
    me "这到底意味着什么？"

# game/a10/10siders.rpy:560
translate english siders_con_38e82c72:

    # conrad "Я выложил все карты на стол. Твой отец признался мне кое в чем. Я дал клятву, что никогда не расскажу это никому... кроме тебя. Твой отец - не Регис."
    conrad "我把所有牌都摊在桌上了。你父亲向我坦白了一些事。我发了誓，永远不告诉任何人...除了你。你的父亲-不是Regis。"

# game/a10/10siders.rpy:561
translate english siders_con_1b32cfea_1:

    # me "Как это?"
    me "怎么回事？"

# game/a10/10siders.rpy:562
translate english siders_con_5e7c35c5:

    # conrad "Твой отец это мой старший брат. Самый старший. Тот, что якобы был казнен."
    conrad "你的父亲是我的长兄。最年长的那位。那个据称已被处决的人。"

# game/a10/10siders.rpy:563
translate english siders_con_2c8a0fe1:

    # me "Я ничего не понимаю."
    me "我完全听不懂。"

# game/a10/10siders.rpy:564
translate english siders_con_fecb1d50:

    # conrad "Сейчас все поймешь. Видишь ли, сразу после смерти Красного Императора, настоящий Регис пленил твоего отца. Знать поддержала его притязания на трон."
    conrad "你很快就会明白的。你看，就在红帝死后，真正的Regis俘虏了你的父亲。贵族们支持了他对王位的要求。"

# game/a10/10siders.rpy:565
translate english siders_con_d6ba28ed:

    # conrad "Твой отец клялся мне, что не убивал Красного Императора, так что подозреваю, что настоящий Регис и убил его."
    conrad "你父亲向我发誓，他没有杀红帝，所以我怀疑，是真正的Regis杀了他。"

# game/a10/10siders.rpy:566
translate english siders_con_1acf26ce:

    # me "Но как же мой отец оказался на троне?"
    me "但我父亲是怎么坐上王位的？"

# game/a10/10siders.rpy:567
translate english siders_con_618664a1:

    # conrad "Терпение. Я все расскажу."
    conrad "耐心。我会全告诉你的。"

# game/a10/10siders.rpy:568
translate english siders_con_fd341de6:

    # me "Я слушаю."
    me "我听着呢。"

# game/a10/10siders.rpy:570
translate english siders_con_0adfe767:

    # conrad "Не знаю, что случилось в замке, но оригинальный Регис умер, а его смерть осталась незамеченной, возможно это сделала леди [alaina], но я в этом не уверен."
    conrad "我不知道城堡里发生了什么，但原来的Regis死了，他的死没被发觉，可能是[alaina]女士做的，但我不能肯定。"

# game/a10/10siders.rpy:571
translate english siders_con_ddae82e4:

    # conrad "Что она точно сделала - это втайне заменила твоего отца не Региса, при помощи магии и мастерства Сирен, они изменили ему внешность."
    conrad "她确实做过的就是，在海妖的魔法和技艺帮助下，秘密地将你父亲替换成了Regis，他们改变了他的外貌。"

# game/a10/10siders.rpy:572
translate english siders_con_5df17382:

    # conrad "Естественно полностью скопировать все не получилось. Поэтому твоему отцу пришлось изображать другого человека, а леди [alaina] убила всех людей, которые знали оргинального Региса близко."
    conrad "自然，完全复制一切是不可能的。所以你父亲不得不扮演另一个人，而[alaina]女士则杀死了所有熟悉原来那个Regis的人。"

# game/a10/10siders.rpy:573
translate english siders_con_3a60584f:

    # conrad "Твой отец был в уязвимом положении. Так что его тяжело винить в том, что он во всем подчинялся леди Алейне."
    conrad "你父亲处境很脆弱。所以很难责怪他在所有事上都顺从Alaina女士。"

# game/a10/10siders.rpy:574
translate english siders_con_9cac1535:

    # me "И женитьба на моей матери..."
    me "包括娶我的母亲..."

# game/a10/10siders.rpy:575
translate english siders_con_1c78b06f:

    # conrad "Да. Теперь ты понимаешь, почему это произошло на самом деле?"
    conrad "是的。现在你明白事情真正的缘由了吧？"

# game/a10/10siders.rpy:576
translate english siders_con_fc30fd2b:

    # me "Да."
    me "是的。"

# game/a10/10siders.rpy:577
translate english siders_con_19d7a608:

    # conrad "Леди [alaina] не просто придворный маг. Она самый настоящий кукловод. Не знаю как, но вассалы не стали выступать против брака твоего отца именно из-за нее."
    conrad "[alaina]女士不仅仅是宫廷法师。她是个彻头彻尾的傀儡师。不知道怎么做到的，但正是因为她，封臣们才没有反对你父亲的婚事。"

# game/a10/10siders.rpy:578
translate english siders_con_9461116c:

    # conrad "Она посылала оракулов твоему отцу, пытаясь манипулировать им. Она убила мать [cass]. Она убила и мою мать."
    conrad "她不断给你父亲送神谕者，试图操控他。她杀了[cass]的母亲。她也杀了我的母亲。"

# game/a10/10siders.rpy:579
translate english siders_con_ff2cfba6:

    # me "Но твоя мать умерла при родах."
    me "可你母亲是死于难产的。"

# game/a10/10siders.rpy:580
translate english siders_con_b055a059:

    # conrad "Так мне сказали. Но я помню ее голубые глаза. Ее теплые и нежные руки... Мне кажется [alaina] прятала ее. Может надеялась договориться с ней, чтобы они признала нового Региса...старым Регисом..."
    conrad "他们是这么告诉我的。但我记得她蓝色的眼睛。她温暖而温柔的手...我觉得[alaina]把她藏起来了。或许她希望和她谈判，让她承认新的Regis...就是旧的Regis..."

# game/a10/10siders.rpy:581
translate english siders_con_f69032fe:

    # conrad "Но видимо моя мать отказалась."
    conrad "但显然我母亲拒绝了。"

# game/a10/10siders.rpy:582
translate english siders_con_38902c65:

    # me "А что говорит мой отец?"
    me "那我父亲怎么说？"

# game/a10/10siders.rpy:583
translate english siders_con_3d8fa2fe:

    # conrad "Он...насчет этого он не уверен. Говорит не видел нашу мать с моего рождения. Но леди [alaina] коварна. Впрочем, мне не нужно приписывать ей того, чего она может и не делала. Того, что она делала точно, достаточно, чтобы ей не доверять."
    conrad "他...对此，他也无法肯定。他说从我出生起就没再见过我们的母亲。但[alaina]女士非常狡猾。不过，我也没必要把她可能没做的事安在她头上。就凭她确切做过的事，就足够让人不再信任她了。"

# game/a10/10siders.rpy:584
translate english siders_con_4960bd78:

    # me "Но ведь получается...что даже сам факт моего существования..."
