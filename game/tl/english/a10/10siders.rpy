# TODO: Translation updated at 2025-07-13 20:55

# game/a10/10siders.rpy:4
translate english siders_861e0d8a:

    # "Несколькими часами позже."
    "几个小时以后。"

# game/a10/10siders.rpy:5
translate english siders_bb3ad894:

    # mes "...так что нам нужно выделить дополнительную охрану."
    mes "...所以我们得增派护卫。"

# game/a10/10siders.rpy:6
translate english siders_7d601715:

    # me "Но ведь вы отбились."
    me "可你们不是打退了吗？"

# game/a10/10siders.rpy:7
translate english siders_4a74f275:

    # mes "Отбились. Но раз уж теперь караваны с припасами будут ходить постоянно и нападения будут постоянными."
    mes "打退了。但现在补给车队会一直来，袭击也会一直有。"

# game/a10/10siders.rpy:8
translate english siders_c5f85c93:

    # me "Не понимаю, вы всех убили, а тех кто выжил - повесили вдоль дороги."
    me "我不明白，你把他们都杀了，活下来的也沿路吊死了。"

# game/a10/10siders.rpy:9
translate english siders_d90391d1:

    # mes "Верно. Это отпугнет любителей легкой наживы."
    mes "没错。这能吓退那些想捡便宜的。"

# game/a10/10siders.rpy:10
translate english siders_dfddd9cc:

    # me "...и зачем тогда вам дополнительная охрана?"
    me "...那你们为何还要增派护卫？"

# game/a10/10siders.rpy:11
translate english siders_85332bb0:

    # mes "Потому что это привлечет тех, кто готов рисковать."
    mes "因为这会引来那些敢冒险的。"

# game/a10/10siders.rpy:12
translate english siders_2a985733:

    # me "Кого?"
    me "谁？"

# game/a10/10siders.rpy:14
translate english siders_adf2255f:

    # mes "Эльфов Долины конечно."
    mes "当然是谷地精灵。"

# game/a10/10siders.rpy:15
translate english siders_fe32b6da:

    # me "Но ведь все это время торговля через Долину активно велась. Эльфы соблюдали договор."
    me "可谷地的贸易一直很活跃。精灵们也遵守了盟约。"

# game/a10/10siders.rpy:16
translate english siders_aea8f351:

    # mes "Это так. Но сейчас через долину будет ехать не картофель и специи, а мечи, копья и железо."
    mes "是这样。但现在通过谷地运送的不再是土豆和香料，而是刀剑、长矛和铁器。"

# game/a10/10siders.rpy:17
translate english siders_2687599b:

    # me "И вы предполагаете, что эльфы решат нарушить договор из-за мечей? По-вашему у них их нет?"
    me "你觉得精灵会因为刀剑就违背盟约？难道他们自己没有吗？"

# game/a10/10siders.rpy:18
translate english siders_7af01ba9:

    # mes "За сотни лет болота поглотили все шахты в Долине, так что да. Железа и оружия из него у эльфов в дефиците."
    mes "几百年来，沼泽吞没了谷地所有的矿坑，所以，是的。他们缺铁，缺铁制武器。"

# game/a10/10siders.rpy:19
translate english siders_f55ac546:

    # me "Королевство и так отправило слишком много своих сыновей на войну. Я доверяю союзу, что даровал мне мой брак и все же не хочу ослаблять оборону еще сильнее."
    me "王国已经送了太多子弟上战场。我信任我婚姻带来的联盟，但我也不想再削弱防御了。"

# game/a10/10siders.rpy:20
translate english siders_81aef917:

    # mes "..."
    mes "..."

# game/a10/10siders.rpy:21
translate english siders_aae23f25:

    # me "Но если ваше предположение окажется верным - я лично отправлюсь в Долину и буду убивать каждого эльфа, нарушившего договор."
    me "但如果你的猜测成真——我将亲赴谷地，杀死每一个背盟的精灵。"

# game/a10/10siders.rpy:22
translate english siders_d85aa54c:

    # mes "Если они вообще будут с вами биться, мой принц."
    mes "如果他们根本不跟您打呢，我的王子？"

# game/a10/10siders.rpy:23
translate english siders_09e5db34:

    # me "Если не будут, я сожгу лес вокруг тракта на десять лиг. Обещаю. Это вас успокоит?"
    me "不打，我就烧掉大道两旁十里的森林。我保证。这能让你安心吗？"

# game/a10/10siders.rpy:24
translate english siders_29614e87:

    # mes "Да."
    mes "能。"

# game/a10/10siders.rpy:25
translate english siders_d278a3cf:

    # me "Хорошо. Следующий."
    me "很好。下一个。"

# game/a10/10siders.rpy:27
translate english siders_fdda5bd1:

    # art "Мой принц, меня зовут Артур. Я сын лорда Лаггариуса, представляющего Северные Марки, лорда Пойнаса, лорда..."
    art "王子殿下，我叫亚瑟。我是代表北境边区的拉格留斯勋爵、Poinas勋爵、...勋爵之子..."

# game/a10/10siders.rpy:28
translate english siders_9ce0d8b6:

    # me "Ближе к делу, Артур."
    me "说重点，亚瑟。"

# game/a10/10siders.rpy:29
translate english siders_ae3117ca:

    # art "Мой отец велел мне обратиться к вам с просьбой, как только вы прибудете."
    art "家父命我，等您一到，就向您提出请求。"

# game/a10/10siders.rpy:30
translate english siders_789ff00b:

    # me "Что за просьба?"
    me "什么请求？"

# game/a10/10siders.rpy:31
translate english siders_26c3e5f4:

    # art "Мой отец сказал, что вы возможно захотите...что вы возможно сочтете нужным...что вы..."
    art "家父说，您或许想要...您或许认为有必要...您..."

# game/a10/10siders.rpy:32
translate english siders_2661aed2:

    # me "Ну же, парень."
    me "说吧，小子。"

# game/a10/10siders.rpy:33
translate english siders_7b73db4b:

    # art "Что вы возможно захотите посетить наше родовое поместье вместе с вашей супругой."
    art "您或许想和您的夫人一起，光临我们家族的庄园。"

# game/a10/10siders.rpy:34
translate english siders_3820771a:

    # me "..."
    me "..."

# game/a10/10siders.rpy:35
translate english siders_6710eaaf:

    # art "Это воистину жемчужина нашего королевства и вы можете рассчитывать на прием, достойный вашего положения."
    art "那真是我们王国的一颗明珠，您将受到与您身份相称的款待。"

# game/a10/10siders.rpy:36
translate english siders_32236fb9:

    # me "Ты сейчас серьезно? У меня вообще-то приемы по поводу войны."
    me "你是认真的吗？我在这儿可是为战争举行接见会。"

# game/a10/10siders.rpy:38
translate english siders_efe16d07:

    # art "Простите меня, мой принц. Я не хотел мешать. Я специально занял последнее место в очереди."
    art "请原谅我，王子殿下。我无意打扰。我特意排到了队伍最后一位。"

# game/a10/10siders.rpy:39
translate english siders_8508cd22:

    # me "Это правда?"
    me "是吗？"

# game/a10/10siders.rpy:40
translate english siders_70f344bb:

    # knight "Да, это последний."
    knight "是的，这是最后一个了。"

# game/a10/10siders.rpy:41
translate english siders_60d827d0:

    # me "Ладно. И зачем?"
    me "好吧。为什么邀请我？"

# game/a10/10siders.rpy:42
translate english siders_289b4206:

    # art "Мой отец сказал королевство ожидает появление наследника..."
    art "家父说，王国正期待着一位继承人的降临..."

# game/a10/10siders.rpy:43
translate english siders_e6fd0868:

    # me "Пока что я еще наследник королевства. Мой отец жив."
    me "目前，我还是王国的继承人。我的父亲还活着。"

# game/a10/10siders.rpy:44
translate english siders_a24854d0:

    # art "Конечно! Я имел в виду наследника...вашей семьи."
    art "当然！我是说...您家族的继承人。"

# game/a10/10siders.rpy:45
translate english siders_66948067:

    # me "Мгм."
    me "嗯。"

# game/a10/10siders.rpy:46
translate english siders_6eb6f5d2:

    # art "У нас чудесная природа и знаменитый серебрянный источник, и..."
    art "我们那儿有绝妙的自然风光和著名的银泉，还有..."

# game/a10/10siders.rpy:47
translate english siders_021e8978:

    # me "Я обязательно заеду к вам. Когда будет время."
    me "我一定会抽空拜访的。等我有时间。"

# game/a10/10siders.rpy:48
translate english siders_12a4ac54:

    # art "Благодарю! Мы будем ждать вашего визита, мой принц."
    art "感谢您！我们将恭候您的大驾，王子殿下。"

# game/a10/10siders.rpy:51
translate english siders_be6d095f:

    # calah "Ну как ты тут справляешься с королевскими обязанностями?"
    calah "你这国王的职责处理得怎么样？"

# game/a10/10siders.rpy:52
translate english siders_d75af7a2:

    # me "А с ними можно не справиться? Я просто говорю 'да' или 'нет' целый день вот и все."
    me "这还能处理不好？我就是整天说“是”或“否”而已。"

# game/a10/10siders.rpy:53
translate english siders_c53ad778:

    # calah "Ну, в зависимости от твоих 'да' или 'нет' может измениться ход войны."
    calah "嗯，你的“是”或“否”可是能改变战争走向的。"

# game/a10/10siders.rpy:54
translate english siders_6465d3d5:

    # me "Я в этом не уверен."
    me "我不太确定。"

# game/a10/10siders.rpy:55
translate english siders_d66e83a1:

    # calah "Почему же?"
    calah "为什么？"

# game/a10/10siders.rpy:56
translate english siders_f70105b0:

    # me "По-моему меня обманули, Каллахан."
    me "我觉得我被骗了，Callahan。"

# game/a10/10siders.rpy:57
translate english siders_767bf27a:

    # calah "Как же?"
    calah "怎么了？"

# game/a10/10siders.rpy:58
translate english siders_b43c446c:

    # me "Я поддался на сладкие речи своих вассалов и вернулся домой."
    me "我禁不住封臣们的甜言蜜语，回了家。"

# game/a10/10siders.rpy:59
translate english siders_4befcbf3:

    # calah "И в чем же обман?"
    calah "这算什么骗局？"

# game/a10/10siders.rpy:61
translate english siders_d3ff0ede:

    # me "Я бы вернулся сюда героем, если бы привез с собой корону, а теперь за меня это сделают мои вассалы, будто бы я и не при чем."
    me "我如果带着王冠回来，会像个英雄。可现在，我的封臣们会替我完成这事，好像跟我无关似的。"

# game/a10/10siders.rpy:62
translate english siders_6bc962f5:

    # calah "Ааа, жажда славы, понимаю."
    calah "啊，对荣耀的渴望，我懂了。"

# game/a10/10siders.rpy:63
translate english siders_4acba003:

    # me "Скорее жажда легитимности. Будут ли меня уважать мои новые подданные, если власть над ними мне отдадут, а не я возьму ее сам."
    me "更像是对合法性的渴望。如果权力是别人给的，而不是我自己夺来的，我的新臣民会尊重我吗？"

# game/a10/10siders.rpy:64
translate english siders_b63c6307:

    # calah "Смотря кого вы имеете в виду. Не стоит переоценивать вовлеченность простолюдинов и мещан в государственные дела. Торговцу и крестьянину все равно чей флаг над их лавкой или фермой, я вас уверяю."
    calah "那得看您指的是谁。别高估平民和市侩对国家大事的投入。我向您保证，商人和农民才不在乎自家店铺或农场上飘的是谁的旗帜。"

# game/a10/10siders.rpy:65
translate english siders_47c46913:

    # me "Может я говорю не о них."
    me "也许我说的不是他们。"

# game/a10/10siders.rpy:66
translate english siders_6008aeac:

    # calah "Правители...новые и старые, их лояльность это всегда просто условность. Договор. Временный."
    calah "统治者...新的和旧的，他们的忠诚永远只是权宜之计，一纸契约，暂时的。"

# game/a10/10siders.rpy:67
translate english siders_45d1325f:

    # me "Не понял."
    me "我不明白。"

# game/a10/10siders.rpy:68
translate english siders_f40e6c93:

    # calah "Можно купить их, но завтра им предложат больше."
    calah "你可以收买他们，但明天别人出价更高。"

# game/a10/10siders.rpy:69
translate english siders_779a17a5:

    # calah "Можно запугать их, но только дашь слабину - они вонзят нож в спину."
    calah "你可以恐吓他们，但只要你一露出弱点，他们就会背后捅刀。"

# game/a10/10siders.rpy:70
translate english siders_adc2b77b:

    # calah "Можно заставить их полюбить тебя, но только стоит тебе один раз оступиться и их любовь исчезнет."
    calah "你可以让他们爱上你，但你只要踏错一步，他们的爱就会消失。"

# game/a10/10siders.rpy:71
translate english siders_83412451:

    # me "И что же тогда делать?"
    me "那该怎么办？"

# game/a10/10siders.rpy:72
translate english siders_94998607:

    # calah "Знаешь главное правило торговли?"
    calah "你知道经商最重要的法则吗？"

# game/a10/10siders.rpy:73
translate english siders_5a7a7577:

    # me "Нет."
    me "不知道。"

# game/a10/10siders.rpy:74
translate english siders_5dbbcdcc:

    # calah "Ищи общий интерес. Не важно кто тебе дарует власть над ними. Пусть с тобой им будет выгодней, чем без тебя."
    calah "寻找共同利益。别管是谁给了你统治他们的权力。重要的是，跟着你比没有你更有利。"

# game/a10/10siders.rpy:75
translate english siders_10ba1b56:

    # calah "Империя развалилась не потому что твой дед был жесток, а потому что его бесконечные походы разорили всех его подданных."
    calah "帝国之所以崩溃，不是因为你的祖父残暴，而是因为他无休止的征战耗尽了所有臣民。"

# game/a10/10siders.rpy:76
translate english siders_97a687f0:

    # calah "Без него просто стало лучше, чем с ним."
    calah "没有他，日子反而更好了。"

# game/a10/10siders.rpy:77
translate english siders_4a68894d:

    # me "Спасибо за совет, Каллахан."
    me "谢谢你的建议，Callahan。"

# game/a10/10siders.rpy:78
translate english siders_89f290b7:

    # calah "Обращайся. Ты тут закончил?"
    calah "随时效劳。你这边的事完了吗？"

# game/a10/10siders.rpy:79
translate english siders_fc30fd2b:

    # me "Да."
    me "完了。"

# game/a10/10siders.rpy:80
translate english siders_1e22942f:

    # calah "Ваша младшая сестра вас искала. Говорит, что хочет добавить глав в королевские хроники."
    calah "您的妹妹一直在找您。她说想在皇家编年史里加几章。"

# game/a10/10siders.rpy:81
translate english siders_84fd65d3:

    # me "Хорошо. Я как раз закончил."
    me "知道了。我正好忙完了。"

# game/a10/10siders.rpy:84
translate english siders_2a2df022:

    # cass "Ну как ты тут?"
    cass "你在这儿还好吗？"

# game/a10/10siders.rpy:85
translate english siders_b11813af:

    # me "Закончил."
    me "忙完了。"

# game/a10/10siders.rpy:86
translate english siders_bfa51244:

    # cass "Надо было соглашаться."
    cass "你应该同意的。"

# game/a10/10siders.rpy:87
translate english siders_d355dc3b:

    # me "О чем ты?"
    me "你在说什么？"

# game/a10/10siders.rpy:88
translate english siders_32802d51:

    # cass "Я про паренька. Он чуть не обоссался от страха, пока предлагал тебе отдых на природе."
    cass "我说那个小伙子。他鼓起勇气邀请你去休养的时候，差点吓尿了。"

# game/a10/10siders.rpy:89
translate english siders_4dfb2cc5:

    # me "У меня сейчас нет на это времени."
    me "我现在没时间。"

# game/a10/10siders.rpy:90
translate english siders_e7f70dcb:

    # cass "Туда всего пару дней пути."
    cass "到那里就几天路程。"

# game/a10/10siders.rpy:91
translate english siders_cfc51cbb:

    # me "Откуда ты знаешь?"
    me "你怎么知道？"

# game/a10/10siders.rpy:92
translate english siders_e60ca58a:

    # cass "Я была там."
    cass "我去过。"

# game/a10/10siders.rpy:93
translate english siders_b85fbe16:

    # me "Ах, да. Лорд Лаггариус твой друг."
    me "啊，对。拉格留斯勋爵是你的朋友。"

# game/a10/10siders.rpy:95
translate english siders_587af127:

    # cass "Не подумай ничего такого. Мы просто сошлись на вере в одного перспективного молодого наследника для королевства."
    cass "你别想歪了。我们不过是都看好一位对王国来说前途无量的年轻继承人。"

# game/a10/10siders.rpy:96
translate english siders_3ce20cc2:

    # me "Для Империи."
    me "是帝国。"

# game/a10/10siders.rpy:97
translate english siders_3e9c9359:

    # cass "Да. Этим ты нам и понравился. Амбициозный. Сильный. Волевой."
    cass "对。我们就是看中你这一点。雄心勃勃，强大，意志坚定。"

# game/a10/10siders.rpy:98
translate english siders_3ed83ecb:

    # me "Это смешно, по-твоему?"
    me "你觉得这很好笑吗？"

# game/a10/10siders.rpy:99
translate english siders_f107e174:

    # cass "Похоже на то, что я смеюсь?"
    cass "我看上去像在笑吗？"

# game/a10/10siders.rpy:100
translate english siders_fc30fd2b_1:

    # me "Да."
    me "像。"

# game/a10/10siders.rpy:101
translate english siders_434d8fda:

    # cass "Ну разве что, чуть-чуть. Ты неплохо справился один в этот раз без мамочки."
    cass "好吧，可能，有一点点。这次没妈妈帮忙，你一个人做得不错。"

# game/a10/10siders.rpy:102
translate english siders_3820771a_1:

    # me "..."
    me "..."

# game/a10/10siders.rpy:103
translate english siders_7fcb3768:

    # cass "Прости. Ты просто такой милый, когда изображаешь прагматичного короля."
    cass "抱歉。只是你装出一副务实国王的样子时，实在太可爱了。"

# game/a10/10siders.rpy:104
translate english siders_0c296efe:

    # me "Ты подслушивала?"
    me "你在偷听？"

# game/a10/10siders.rpy:105
