translate english qwens_c5224473:

    # me "Прости, не хотел напрягать тебя, мам."
    me "对不起，我不是想让你心烦，妈妈。"

# game/a10/9qwens.rpy:207
translate english qwens_50cac73b:

    # mom "Что это?"
    mom "这是什么？"

# game/a10/9qwens.rpy:208
