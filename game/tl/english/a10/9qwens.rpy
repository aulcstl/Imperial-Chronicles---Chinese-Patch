translate english qwens2_a0c15e8c:

    # me "Ни один человек не ступал дальше этого места."
    me "再没有人类踏足过比这更远的地方了。"

# game/a10/9qwens.rpy:275
translate english qwens2_16327264:

    # mom "Да."
    mom "是啊。"

# game/a10/9qwens.rpy:276
translate english qwens2_1ece3e1b:

    # me "Этот разлом всегда был здесь?"
    me "这裂谷一直都在这里吗？"

# game/a10/9qwens.rpy:277
translate english qwens2_cadf57bb:

    # mom "Это предвестник. Говорят земля раскололась прямо перед тем, как людские паруса показались на горизонте."
    mom "这是前兆。传说就在人类的船帆出现在地平线上之前，大地裂开了。"

# game/a10/9qwens.rpy:278
translate english qwens2_3820771a:

    # me "..."
    me "..."

# game/a10/9qwens.rpy:279
translate english qwens2_f864b487_1:

    # mom "..."
    mom "..."

# game/a10/9qwens.rpy:280
translate english qwens2_a9d674ee:

    # me "И насколько он глубок?"
    me "那它有多深？"

# game/a10/9qwens.rpy:281
translate english qwens2_582af357:

    # mom "Говорят тут вообще нет дна."
    mom "据说这里根本没有底。"

# game/a10/9qwens.rpy:283
translate english qwens2_069b5560:

    # me "Как такое может быть?"
    me "这怎么可能？"

# game/a10/9qwens.rpy:284
translate english qwens2_648532c0:

    # mom "Хочешь узнать?"
    mom "你想知道吗？"

# game/a10/9qwens.rpy:285
translate english qwens2_997c151d:

    # me "Не особо."
    me "不太想。"

# game/a10/9qwens.rpy:286
translate english qwens2_cb4e53e7:

    # mom "Я тоже. Пойдем обратно."
    mom "我也是。我们回去吧。"

# game/a10/9qwens.rpy:287
translate english qwens2_925bed17:

    # me "У тебя еще есть силы?"
    me "你还有力气吗？"

# game/a10/9qwens.rpy:288
translate english qwens2_d76a09ea:

    # mom "На один портал хватит."
    mom "够再开一个传送门。"

# game/a10/9qwens.rpy:290
translate english qwens2_4ea74dc2:

    # me "Ух ты. Это уже что-то."
    me "哇。这才像样。"

# game/a10/9qwens.rpy:291
