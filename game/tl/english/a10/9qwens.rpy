# game/a10/9qwens.rpy:266
translate english qwens2_14efdd54:

    # mom "Можно и так сказать."
    mom "可以这么说吧。"

# game/a10/9qwens.rpy:267
translate english qwens2_ea47ac16:

    # me "Пахнет..."
    me "闻起来有……"

# game/a10/9qwens.rpy:268
translate english qwens2_be8818e6:

    # mom "Бездной."
    mom "深渊的味道。"

# game/a10/9qwens.rpy:270
