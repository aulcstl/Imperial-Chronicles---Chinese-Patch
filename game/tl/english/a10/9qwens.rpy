translate english qwens2_b533e874:

    # mom "Мы откроем всего парочку. Если не найдем ничего подходящего..."
    mom "我们只开几个。如果找不到合适的……"

# game/a10/9qwens.rpy:230
translate english qwens2_04b79c1e:

