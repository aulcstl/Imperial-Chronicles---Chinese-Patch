    # me "О, боги..."
    me "哦，天啊……"

# game/a10/9qwens.rpy:271
translate english qwens2_f864b487:

    # mom "..."
    mom "..."

# game/a10/9qwens.rpy:272
translate english qwens2_51c2c17c:

    # me "Что это?"
    me "这是什么？"

