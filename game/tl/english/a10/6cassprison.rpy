    # cass "Думаешь он захочет когда-нибудь еще меня увидеть?"
    cass "你觉得他会想再见到我吗？"

# game/a10/6cassprison.rpy:237
translate english cass_prison_break_373db32a:

    # me "Думаю да. Но точно не сейчас."
    me "我想会的。但肯定不是现在。"

# game/a10/6cassprison.rpy:238
translate english cass_prison_break_651ccc28_15:

    # cass "..."
    cass "..."

# game/a10/6cassprison.rpy:239
translate english cass_prison_break_143776a8:

    # me "Ложись спать, [cass]."
    me "睡吧，[cass]。"

# game/a10/6cassprison.rpy:241
translate english cass_prison_break_bb5c1bd4_1:

    # cass "Хорошо."
    cass "好。"

# game/a10/6cassprison.rpy:242
translate english cass_prison_break_d78fc624:

    # me "Спокойной ночи."
    me "晚安。"

# game/a10/6cassprison.rpy:243
translate english cass_prison_break_d2f4b588:

    # cass "Спокойной ночи, [mename]."
    cass "晚安，[mename]。"

# game/a10/6cassprison.rpy:244
translate english cass_prison_break_3820771a_8:

    # me "..."
    me "..."

# game/a10/6cassprison.rpy:245
translate english cass_prison_break_8396b148_1:

    # cass "Спасибо."
    cass "谢谢。"

# game/a10/6cassprison.rpy:246
translate english cass_prison_break_92279f92:

    # me "Не за что."
    me "不用谢。"

# game/a10/6cassprison.rpy:247
translate english cass_prison_break_93c8c2d1:

    # cass "Ты знаешь, что есть за что. Спасибо за...милосердие."
    cass "你知道有理由谢。谢谢你……的仁慈。"

# game/a10/6cassprison.rpy:248
translate english cass_prison_break_e3bb835f:

    # me "{i}Милосердие это слабость. К предателям не может быть никакого милосердия. Только к рабам.{/i}"
    me "{i}仁慈是软弱。对叛徒不能有任何仁慈。只有对奴隶才行。{/i}"

# game/a10/6cassprison.rpy:252
translate english cass_prison_break2_9f2a99fe:

    # "Утром."
    "早上。"

# game/a10/6cassprison.rpy:253
translate english cass_prison_break2_6ad06d8c:

    # me "Вставай."
    me "起来。"

# game/a10/6cassprison.rpy:254
translate english cass_prison_break2_62ec711a:

    # cass "М? Где я."
    cass "嗯？我在哪儿？"

# game/a10/6cassprison.rpy:255
translate english cass_prison_break2_18ddf0d4:

    # me "Дома."
    me "在家。"

# game/a10/6cassprison.rpy:256
translate english cass_prison_break2_9c29c5ec:

    # cass "Ох...после твердого пола темницы...я бы еще часов 20 спала."
    cass "哦……睡惯了地牢的硬地板后……我还能再睡二十个小时。"

# game/a10/6cassprison.rpy:257
translate english cass_prison_break2_39485a3e:

    # me "У тебя есть небольшое дело. Потом сможешь спать сколько захочешь."
    me "你有点小事要做。之后你想睡多久都行。"

# game/a10/6cassprison.rpy:258
translate english cass_prison_break2_4450219c:

    # cass "Нужно именно сейчас?"
    cass "必须现在吗？"

# game/a10/6cassprison.rpy:259
translate english cass_prison_break2_fc30fd2b:

    # me "Да."
    me "对。"

# game/a10/6cassprison.rpy:261
translate english cass_prison_break2_5e6b38b9:

    # cass "Ладно."
    cass "好吧。"

# game/a10/6cassprison.rpy:262
translate english cass_prison_break2_52ec3972:

    # me "Как спалось?"
    me "睡得怎么样？"

# game/a10/6cassprison.rpy:263
translate english cass_prison_break2_a7c94772:

    # cass "Я же говорю - после твердого пола темницы..."
    cass "我都说了——睡惯了地牢的硬地板后……"

# game/a10/6cassprison.rpy:264
translate english cass_prison_break2_99e330bd:

    # me "Я не об этом."
    me "我不是问这个。"

# game/a10/6cassprison.rpy:265
translate english cass_prison_break2_f12a20b4:

    # cass "М?"
    cass "嗯？"

# game/a10/6cassprison.rpy:266
translate english cass_prison_break2_c53c0b79:

    # me "Что-нибудь снилось?"
    me "做梦了吗？"

# game/a10/6cassprison.rpy:267
translate english cass_prison_break2_531a8a7d:

    # cass "Не знаю. Наверное нет."
    cass "不知道。大概没有。"

# game/a10/6cassprison.rpy:268
translate english cass_prison_break2_ec972266:

    # me "Это хорошо. Знаешь как говорят, только самый крепкий отдых не одаривает нас снами."
    me "那很好。你知道老话怎么说，只有最沉的睡眠才不给我们梦境。"

# game/a10/6cassprison.rpy:270
translate english cass_prison_break2_ede6606e:

    # cass "Так что за....дело?"
    cass "那……那件……事是什么？"

# game/a10/6cassprison.rpy:271
translate english cass_prison_break2_dfcceeac:

    # me "М?"
    me "嗯？"

# game/a10/6cassprison.rpy:272
translate english cass_prison_break2_bdc6c559:

    # cass "Когда ты разбудил меня, ты сказал у тебя есть какое-то дело."
    cass "你叫醒我的时候，说有事。"

# game/a10/6cassprison.rpy:273
translate english cass_prison_break2_78c770db:

    # me "Ах да. Ничего тяжелого. Просто клятва."
    me "啊，对。不是什么难事。只是一个誓言。"

# game/a10/6cassprison.rpy:274
translate english cass_prison_break2_1f48c755:

    # cass "Клятва? Какая клятва?"
    cass "誓言？什么誓言？"

# game/a10/6cassprison.rpy:276
translate english cass_prison_break2_c1e36937:

    # me "Клятва в вечной верности. Встань на колени и поцелуй мою руку."
    me "永恒的效忠誓言。跪下，亲吻我的手。"

# game/a10/6cassprison.rpy:277
translate english cass_prison_break2_e811e30c:

    # cass "Ты ведь еще не король."
    cass "你还没当上国王呢。"

# game/a10/6cassprison.rpy:278
translate english cass_prison_break2_87b6ff81:

    # me "Разве я сказал, что требую клятву верности королю? Я требую от тебя клятву верности себе. Вечную клятву. Клятву на коленях и с повиновением в глазах."
    me "我说了要你向国王效忠吗？我是要你向我效忠。永恒的誓言。跪下的誓言，眼中带着顺从。"

# game/a10/6cassprison.rpy:279
translate english cass_prison_break2_c2487b65:

    # cass "Что?"
    cass "什么？"

# game/a10/6cassprison.rpy:280
translate english cass_prison_break2_971e0306:

    # me "Ты что-то не услышала?"
    me "你没听清吗？"

# game/a10/6cassprison.rpy:281
translate english cass_prison_break2_fd38ff67:

    # cass "Я все услышала!"
    cass "我听清了！"

# game/a10/6cassprison.rpy:282
translate english cass_prison_break2_09df2d2f:

    # me "В таком случае я не понимаю, почему ты до сих пор не на коленях."
    me "既然如此，我不明白你为什么还不跪下。"

# game/a10/6cassprison.rpy:283
translate english cass_prison_break2_4882e7bc:

    # cass "Почему я должна это делать?"
    cass "我为什么要这么做？"

# game/a10/6cassprison.rpy:284
translate english cass_prison_break2_19b05eee:

    # me "Потому что я оказал тебе величайшую милость. Мало того, что твоя голова до сих пор у тебя на плечах, сегодняшнюю ночь ты провела в теплой постели, а не в темнице."
    me "因为我给了你最大的恩惠。不仅你的脑袋还在脖子上，昨晚你还睡在温暖的床上，而不是地牢。"

# game/a10/6cassprison.rpy:285
translate english cass_prison_break2_a8a84332:

    # cass "И?"
    cass "所以呢？"

# game/a10/6cassprison.rpy:286
translate english cass_prison_break2_cf8b914b:

    # me "Разве ты не хочешь поблагодарить меня?"
    me "你难道不想感谢我吗？"

# game/a10/6cassprison.rpy:288
translate english cass_prison_break2_f62b0b3d:

    # cass "Я отказываюсь."
    cass "我拒绝。"

# game/a10/6cassprison.rpy:289
translate english cass_prison_break2_905adf8d:

    # me "Ты отказываешься?"
    me "你拒绝？"

# game/a10/6cassprison.rpy:290
translate english cass_prison_break2_ba0eee71:

    # cass "Да. Я отказываюсь. Ты не король. Я не обязана тебе ни в чем клясться. Тем боле на коленях."
    cass "对。我拒绝。你不是国王。我没义务向你发任何誓。更何况是跪下。"

# game/a10/6cassprison.rpy:291
translate english cass_prison_break2_9c1c5c64:

    # me "Это не очень разумно."
    me "这不太明智。"

# game/a10/6cassprison.rpy:292
translate english cass_prison_break2_ab96cb15:

    # cass "Мне плевать. Хочешь убить меня - убей. Я не встану на колени."
    cass "我不在乎。想杀我就杀。我不会跪下。"

# game/a10/6cassprison.rpy:293
translate english cass_prison_break2_62464958:

    # me "Вчера ты была посговорчивей."
    me "昨天你还更顺从一些。"

# game/a10/6cassprison.rpy:294
translate english cass_prison_break2_d49d5017:

    # cass "Вчера ты не требовал от меня клясться в вечной верности на коленях."
    cass "昨天你没要求我跪下，宣誓永恒的效忠。"

# game/a10/6cassprison.rpy:295
translate english cass_prison_break2_42a43405:

    # me "Разве король, пусть и будущий, должен быть милостив к предателям?"
    me "一个国王，哪怕是未来的国王，难道该对叛徒仁慈吗？"

# game/a10/6cassprison.rpy:296
translate english cass_prison_break2_8a25ab89:

    # cass "Я еще раз повторяю - хочешь убить меня, убей."
    cass "我再重复一遍——想杀我，就杀。"

# game/a10/6cassprison.rpy:297
translate english cass_prison_break2_af702a17:

    # me "Нет. У меня идея получше."
    me "不。我有个更好的主意。"

# game/a10/6cassprison.rpy:298
translate english cass_prison_break2_3599de84:

    # me "{size=+10}Забирайте ее.{/size}"
    me "{size=+10}把她带走。{/size}"

# game/a10/6cassprison.rpy:300
translate english cass_prison_break2_75ed59a9:

    # knights "Да, мой принц."
    knights "是，我的王子。"

# game/a10/6cassprison.rpy:301
translate english cass_prison_break2_4145cc25:

    # me "И побыстрее."
    me "快点。"

# game/a10/6cassprison.rpy:302
translate english cass_prison_break2_d444f6fb:

    # cass "Куда? На казнь? Не хватает духу убить меня самому?"
    cass "去哪儿？去处决吗？没胆子亲手杀我？"

# game/a10/6cassprison.rpy:304
translate english cass_prison_break2_f0f49a97:

    # cass "Трус!"
    cass "懦夫！"

# game/a10/6cassprison.rpy:305
translate english cass_prison_break2_9f6c98c1:

    # me "Никакой казни не будет. Я уже пощадил тебя. А настоящий король должен держать свое слово."
    me "不会有什么处决。我已经饶恕了你。而真正的国王必须言出必行。"

# game/a10/6cassprison.rpy:306
translate english cass_prison_break2_63729e1a:

    # cass "Не трогайте меня!"
    cass "别碰我！"

# game/a10/6cassprison.rpy:307
translate english cass_prison_break2_da8bcf82:

    # knights "Не вертись, девочка, или придется оставить тебе пару синяков."
    knights "别乱动，丫头，不然只好给你留几处淤青了。"

# game/a10/6cassprison.rpy:308
translate english cass_prison_break2_c36ef64c:

    # me "Но я ведь не обещал тебе ничего больше?"
    me "但我没承诺你更多东西吧？"

# game/a10/6cassprison.rpy:309
translate english cass_prison_break2_c2487b65_1:

    # cass "Что?"
    cass "什么？"

# game/a10/6cassprison.rpy:310
translate english cass_prison_break2_7f41c5a9:

    # knights "Не вертись, говорю!"
    knights "别乱动，我说了！"

# game/a10/6cassprison.rpy:311
translate english cass_prison_break2_369f23e1:

    # me "Теплая спальня, мягкая кровать, вкусная еда, чистая одежда - все это привилегии. Они доступны только тем, кто верен мне, безоговорочно."
    me "温暖的卧室，柔软的床，美味的食物，干净的衣服——这些都是特权。只属于那些无条件效忠于我的人。"

# game/a10/6cassprison.rpy:312
translate english cass_prison_break2_f20fa4e0:

    # cass "Ублюдок!"
    cass "混蛋！"

# game/a10/6cassprison.rpy:313
translate english cass_prison_break2_872098a8:

    # me "Предателям, гордым предателям, что не желают встать на колени доступна только холодная темница и пытки. Уведите ее."
    me "叛徒，那些高傲到不愿跪下的叛徒，只有冰冷的地牢和折磨等着他们。带她走。"

# game/a10/6cassprison.rpy:314
translate english cass_prison_break2_75ed59a9_1:

    # knights "Да, мой принц."
    knights "是，我的王子。"

# game/a10/6cassprison.rpy:316
translate english cass_prison_break2_e245eb14:

    # cass "МРАЗЬ! УБЛЮДОК! Я НИКОГДА НЕ СКЛОНЮ ПЕРЕД ТОБОЙ КОЛЕНИ!"
    cass "杂种！混蛋！我永远不会向你屈膝！"

# game/a10/6cassprison.rpy:317
translate english cass_prison_break2_ef182583:

    # me "Посмотрим еще через пару месяцев."
    me "过几个月再看吧。"

# game/a10/6cassprison.rpy:318
translate english cass_prison_break2_3d61bfba:

    # cass "Я НЕ СТАНУ ЭТО ТЕРПЕТЬ."
    cass "我不会忍受这个！"

# game/a10/6cassprison.rpy:319
translate english cass_prison_break2_ccf1773f:

    # me "Тебе придется. Такова участь предателя."
    me "你必须忍受。这就是叛徒的命运。"

# game/a10/6cassprison.rpy:320
translate english cass_prison_break2_d37f820f:

    # cass "Я убью себя!"
    cass "我会自杀！"

# game/a10/6cassprison.rpy:321
translate english cass_prison_break2_4218ffd9:

    # me "Я обдумал эту возможность. Тебе не дадут умереть."
    me "我考虑过这个可能性。不会给你机会死的。"

# game/a10/6cassprison.rpy:322
translate english cass_prison_break2_580b40b4:

    # cass "Я не стану есть! Умру от голода!"
    cass "我不吃东西！饿死自己！"

# game/a10/6cassprison.rpy:323
translate english cass_prison_break2_1520fc9d:

    # me "Если понадобится, тебя будут кормить насильно."
    me "必要的话，会强迫喂你。"

# game/a10/6cassprison.rpy:324
translate english cass_prison_break2_a5407123:

    # cass "ЗАЧЕМ? ЗАЧЕМ ТЕБЕ ЭТО!?"
    cass "为什么？你为何要这样做！？"

# game/a10/6cassprison.rpy:325
translate english cass_prison_break2_12c9c68f:

    # me "Ты забыла наш первый разговор в подземелье? Когда тебя только арестовали?"
    me "你忘了我们在地牢的第一次谈话了吗？当你刚被逮捕时？"

# game/a10/6cassprison.rpy:326
translate english cass_prison_break2_b97a9878:

    # cass "Что...?"
    cass "什么……？"

# game/a10/6cassprison.rpy:327
translate english cass_prison_break2_34b40ae2:

    # me "Вспомни. Тогда ты поймешь зачем ты до сих пор жива. Все. Уведите ее."
    me "回忆一下。那时你就会明白你为什么还活着。好了。带走她。"

# game/a10/6cassprison.rpy:328
translate english cass_prison_break2_3301557b:

    # cass "Стойте..."
    cass "等等……"

# game/a10/6cassprison.rpy:329
translate english cass_prison_break2_89d118fb:

    # knights "Иди, если не хочешь, чтобы мы тебя тащили по полу."
    knights "走吧，除非你想我们把你拖在地上。"

# game/a10/6cassprison.rpy:330
translate english cass_prison_break2_8ff9b5f5:

    # me "До нескорой встречи, сестренка."
    me "再会遥遥无期，姐姐。"

# game/a10/6cassprison.rpy:334
translate english cass_prison_fix_c1d8b998:

    # "На следующее утро."
    "第二天早上。"

# game/a10/6cassprison.rpy:335
translate english cass_prison_fix_13a4aa1d:

    # knight "Мой, принц."
    knight "我的王子。"

# game/a10/6cassprison.rpy:336
translate english cass_prison_fix_9e2f669f:

    # me "Она здесь?"
    me "她在这儿吗？"

# game/a10/6cassprison.rpy:337
translate english cass_prison_fix_6971738d:

    # knight "Да. В библиотеке чуть дальше."
    knight "在。在前面的图书馆里。"

# game/a10/6cassprison.rpy:338
translate english cass_prison_fix_8648d2e2:

    # me "Как ты вы далековато, она же сбежит."
    me "你们怎么把她带到这么远的地方，她会跑掉的。"

# game/a10/6cassprison.rpy:339
translate english cass_prison_fix_e6b9eacf:

    # knight "Не сбежит, мой принц."
    knight "不会跑的，我的王子。"

# game/a10/6cassprison.rpy:340
translate english cass_prison_fix_91cd4e6c:

    # me "Вы ее плохо знаете."
    me "你们不了解她。"

# game/a10/6cassprison.rpy:341
translate english cass_prison_fix_a1b48207:

    # knight "Она уже пыталась несколько раз. Так что мы позаботились об этом....теперь точно не сбежит."
    knight "她已经试过几次了。所以我们处理好了这个问题……现在绝对跑不了了。"

# game/a10/6cassprison.rpy:342
translate english cass_prison_fix_b6626098:

    # me "А?"
    me "啊？"

# game/a10/6cassprison.rpy:343
translate english cass_prison_fix_4ee9cf58:

    # knight "Увидите сами."
    knight "您亲眼看看吧。"

# game/a10/6cassprison.rpy:345
translate english cass_prison_fix_ba6ebc72:

    # me "Ну здравствуй, сестра."
    me "日安，姐姐。"

# game/a10/6cassprison.rpy:346
translate english cass_prison_fix_9c5a140b:

    # cass "Здравствуй, [mename]."
    cass "日安，[mename]。"

# game/a10/6cassprison.rpy:347
translate english cass_prison_fix_c53690b9:

    # me "Отвлекаю?"
    me "打扰到你了吗？"

# game/a10/6cassprison.rpy:348
translate english cass_prison_fix_873ee46f:

    # cass "Я под арестом, так что могу выделить тебе пару часов, дней, недель, лет. В общем ты понял. Я никуда не спешу."
    cass "我被软禁着呢，所以我可以给你几小时、几天、几周、几年。总之你明白的。我一点也不急。"

# game/a10/6cassprison.rpy:349
translate english cass_prison_fix_305e5541:

    # me "Я пожалуй выберу пару часов."
    me "我想选几个小时吧。"

# game/a10/6cassprison.rpy:350
translate english cass_prison_fix_0040fb44:

    # cass "Не стесняйся. У меня все время мира."
    cass "别客气。我时间多的是。"

# game/a10/6cassprison.rpy:351
translate english cass_prison_fix_50c65077:

    # me "Ну тогда можно и денек."
    me "那干脆待一天也行。"

# game/a10/6cassprison.rpy:352
translate english cass_prison_fix_5e6b38b9:

    # cass "Ладно."
    cass "好。"

# game/a10/6cassprison.rpy:354
translate english cass_prison_fix_de87aa8c:

    # me "Как ты?"
    me "你怎么样了？"

# game/a10/6cassprison.rpy:355
translate english cass_prison_fix_43bb0200:

    # cass "Нормально. Увлеклась чтением."
    cass "还行。迷上了读书。"

# game/a10/6cassprison.rpy:356
translate english cass_prison_fix_50a33ae2:

    # me "Это здорово."
    me "那挺好啊。"

# game/a10/6cassprison.rpy:357
translate english cass_prison_fix_cfda331e:

    # cass "Да, я долго думала чем заняться во время ареста, чтением, чтением или чтением."
    cass "是啊，我想了很久被软禁时该做什么，读书，读书还是读书。"

# game/a10/6cassprison.rpy:358
translate english cass_prison_fix_40b30e48:

    # me "В замке полно развлечений."
    me "城堡里有很多消遣。"

# game/a10/6cassprison.rpy:359
translate english cass_prison_fix_6649ee0e:

    # cass "Да. Но меня теперь редко берут в помещения с больше чем одной дверью или окном."
    cass "是。但现在他们很少让我去超过一扇门或一扇窗的房间。"

# game/a10/6cassprison.rpy:360
translate english cass_prison_fix_25d05bcd:

    # me "Потому что ты пыталась сбежать?"
    me "因为你试图逃跑？"

# game/a10/6cassprison.rpy:361
translate english cass_prison_fix_01fb9021:

    # cass "Потому что я пыталась сбежать."
    cass "因为我试图逃跑。"

# game/a10/6cassprison.rpy:362
translate english cass_prison_fix_762d7c9c:

    # me "И на каком этапе тебя ловили?"
    me "你最多跑到了哪一步？"

# game/a10/6cassprison.rpy:363
translate english cass_prison_fix_ae09a17d:

    # cass "Один раз даже забралась на крепостную стену."
    cass "有一次甚至爬上了城墙。"

# game/a10/6cassprison.rpy:364
translate english cass_prison_fix_4b7fac0c:

    # me "Молодец. Шустрая."
    me "真厉害。够机灵的。"

# game/a10/6cassprison.rpy:365
translate english cass_prison_fix_8396b148:

    # cass "Спасибо."
    cass "谢谢。"

# game/a10/6cassprison.rpy:366
translate english cass_prison_fix_bd07085e:

    # me "Надеюсь никто не пострадал в процессе?"
    me "希望过程中没人受伤？"

# game/a10/6cassprison.rpy:367
translate english cass_prison_fix_fad8b22a:

    # cass "Только мое эго."
    cass "只有我的自尊心。"

# game/a10/6cassprison.rpy:368
translate english cass_prison_fix_7ff67ae1:

    # me "Отлично. Не хотелось бы, чтобы твое нахождение вне темницы вызывало вопросы. Больше не пытайся сбежать."
    me "很好。我可不想因为你不在牢房里而引起非议。别再尝试逃跑了。"

# game/a10/6cassprison.rpy:370
translate english cass_prison_fix_f9a3ecc2:

    # cass "После того как меня стали приковывать, желание как-то поубавилось."
    cass "自从他们开始把我铐起来，逃跑的想法就有点消退了。"

# game/a10/6cassprison.rpy:371
translate english cass_prison_fix_9234a323:

    # me "Ух...выглядит тяжелым."
    me "呃……看起来挺重的。"

# game/a10/6cassprison.rpy:372
translate english cass_prison_fix_9d8c189f:

    # cass "Оно и есть тяжелое. Но могло быть и хуже. Сейчас меня хотя бы приковывают к мебели. Раньше на другом конце был огромный металлический шар."
    cass "是很重。但本来可能更糟。现在至少把我铐在家具上。以前另一头是个巨大的金属球。"

# game/a10/6cassprison.rpy:373
translate english cass_prison_fix_6ef27166:

    # me "И как ты справлялась?"
    me "那你怎么应付的？"

# game/a10/6cassprison.rpy:374
translate english cass_prison_fix_f439f422:

    # cass "Сначала меня заставляли его носить на руках, но однажды я 'случайно' уронила его на ногу одному их охранников и с тех пор я прикована то к стулу, то к кровати."
    cass "开始他们逼我用手抱着它，但有一次我不小心把它砸到了一个卫兵脚上，从那时起我就被铐在椅子或床上了。"

# game/a10/6cassprison.rpy:375
translate english cass_prison_fix_1656a364:

    # me "А если ты захочешь погулять в саду, например?"
    me "那如果你想去花园散步呢？"

# game/a10/6cassprison.rpy:376
translate english cass_prison_fix_c10b51df:

    # cass "Тогда охранники приковывают меня к себе."
    cass "那卫兵就会把我铐在他们自己身上。"

# game/a10/6cassprison.rpy:377
translate english cass_prison_fix_476d436a:

    # me "Кстати не хочешь прогуляться?"
    me "对了，想出去走走吗？"

# game/a10/6cassprison.rpy:378
translate english cass_prison_fix_14a14900:

    # cass "А ты будешь меня приковывать к себе?"
    cass "你会把我铐在你身上吗？"

# game/a10/6cassprison.rpy:379
translate english cass_prison_fix_1cb8e8d6:

    # me "Думаю мы обойдемся без этого."
    me "我想应该不用到那一步。"

# game/a10/6cassprison.rpy:380
translate english cass_prison_fix_674e1c6e:

    # cass "Отлично. Тогда я согласна. Не попросишь ключик?"
    cass "太好了。那我愿意。能帮忙要一下钥匙吗？"

# game/a10/6cassprison.rpy:381
translate english cass_prison_fix_62823e20:

    # me "Сейчас."
    me "马上。"

# game/a10/6cassprison.rpy:383
translate english cass_prison_fix_fc7d3a18:

    # "Пару минут спустя."
    "几分钟以后。"

# game/a10/6cassprison.rpy:384
translate english cass_prison_fix_54c6edd2:

    # cass "...рука затекла."
    cass "……手臂麻了。"

# game/a10/6cassprison.rpy:385
translate english cass_prison_fix_de87aa8c_1:

    # me "Как ты?"
    me "你感觉怎样？"

# game/a10/6cassprison.rpy:386
translate english cass_prison_fix_f12a20b4:

    # cass "М?"
    cass "嗯？"

# game/a10/6cassprison.rpy:387
translate english cass_prison_fix_877a1691:

    # me "Как ты себя чувствуешь?"
    me "你感觉如何？"

# game/a10/6cassprison.rpy:388
translate english cass_prison_fix_91f1a1f5:

    # cass "Нормально, на самом деле иногда они снимают это херню, так что вроде все нормально."
    cass "还好，说实话他们有时会把这玩意儿取下来，所以好像一切正常。"

# game/a10/6cassprison.rpy:389
translate english cass_prison_fix_ea54aec4:

    # me "Я не о руке."
    me "我不是指你的手臂。"

# game/a10/6cassprison.rpy:390
translate english cass_prison_fix_f10b2843:

    # cass "А о чем?"
    cass "那是指什么？"

# game/a10/6cassprison.rpy:391
translate english cass_prison_fix_32c6f8bd:

    # me "О твоем положении. Ты же под арестом."
    me "你的处境。你在软禁中。"

# game/a10/6cassprison.rpy:392
translate english cass_prison_fix_db0ad3a1:

    # cass "Что именно тебя интересует?"
    cass "你到底想问什么？"

# game/a10/6cassprison.rpy:393
translate english cass_prison_fix_13053a70:

    # me "Меня интересует твое душевное состояние."
    me "我想问你的精神状态。"

# game/a10/6cassprison.rpy:394
translate english cass_prison_fix_1a149734:

    # cass "Нормально. Хотя иногда кажется, что я немного схожу с ума."
    cass "还好。虽然有时觉得自己快疯了。"

# game/a10/6cassprison.rpy:395
translate english cass_prison_fix_5ac38cf1:

    # me "Почему?"
    me "为什么？"

# game/a10/6cassprison.rpy:396
translate english cass_prison_fix_75cdcd69:

    # cass "Потому что я неделями ни с кем не говорю."
    cass "因为我好几周都没跟任何人说过话。"

# game/a10/6cassprison.rpy:397
translate english cass_prison_fix_f2a104b8:

    # me "А как же охранники."
    me "那卫兵呢？"

# game/a10/6cassprison.rpy:399
translate english cass_prison_fix_4ce9d048:

    # cass "Они не горят желанием общаться с отцеубийцей. Я пыталась им объяснить, что я его не убивала..."
    cass "他们可不想跟弑父者聊天。我试着跟他们解释，不是我杀的他……"

# game/a10/6cassprison.rpy:400
translate english cass_prison_fix_631c5c2b:

    # me "А просто помогла отравить. Просто помогла отравить родного отца."
    me "你只是协助下毒。只是协助毒害了自己的亲生父亲。"

# game/a10/6cassprison.rpy:401
translate english cass_prison_fix_6ceba5bc:

    # cass "Ну да. Они реагировали как-то похоже."
    cass "是啊。他们的反应差不多就这样。"

# game/a10/6cassprison.rpy:402
translate english cass_prison_fix_41dd73d0:

    # me "Не думал, что ты захочешь общаться с охранниками."
    me "没想到你会想和卫兵聊天。"

# game/a10/6cassprison.rpy:403
translate english cass_prison_fix_80c878f2:

    # cass "Попробуй несколько месяцев общаться только с пыльными манускриптами. Думаю ты поймешь почему может хотеться обменяться парой слов даже с полным идиотом."
    cass "你试试好几个月只跟落满灰尘的手稿打交道。你就明白为什么就算是个十足的傻瓜，你也想跟他交换几句话。"

# game/a10/6cassprison.rpy:404
translate english cass_prison_fix_74656a58:

    # me "Кстати об отце. Тебя теперь нельзя назвать отцеубийцей."
    me "说到父亲。你现在不能再被称为弑父者了。"

# game/a10/6cassprison.rpy:405
translate english cass_prison_fix_98bcf4da:

    # cass "Я и раньше не была отцеубийцей. Но сейчас тем более."
    cass "我以前也不是弑父者。但现在更不是了。"

# game/a10/6cassprison.rpy:406
translate english cass_prison_fix_a007014c:

    # me "Так ты знаешь?"
    me "这么说你知道了？"

# game/a10/6cassprison.rpy:407
translate english cass_prison_fix_437ca329:

    # cass "Ну да. Преториус вылечил его за пару дней до твоего возвращения с Запада."
    cass "嗯。Pretorius在你从西境回来前几天治好了他。"

# game/a10/6cassprison.rpy:408
translate english cass_prison_fix_01a21f1f:

    # me "Ты...ты и моем путешествии знаешь? Я думал охранники с тобой не разговаривают."
    me "你……你连我的旅程都知道？我以为卫兵不跟你说话。"

# game/a10/6cassprison.rpy:409
translate english cass_prison_fix_ca645ea6:

    # cass "А я узнала это не от охранников. Твоя сестра мне рассказала."
    cass "我不是从卫兵那里知道的。是你妹妹告诉我的。"

# game/a10/6cassprison.rpy:410
translate english cass_prison_fix_7b9273c5:

    # me "[lia]? Как тебе к ней подпустили?"
    me "[lia]？他们怎么会让她靠近你？"

# game/a10/6cassprison.rpy:411
translate english cass_prison_fix_5958b6f7:

    # cass "Меня к ней не подпускали. Она иногда прячется в библиотеке до моего прихода и потом мы с ней общаемся."
    cass "他们不让她靠近我。她有时在我到之前躲进图书馆，然后我们交流。"

# game/a10/6cassprison.rpy:413
translate english cass_prison_fix_036ed4c5:

    # me "Как это? Разве вас не слышат?"
    me "怎么会？难道他们听不见你们？"

# game/a10/6cassprison.rpy:414
translate english cass_prison_fix_1b172281:

    # cass "Она пишет мне записки и я ей отвечаю также."
    cass "她给我写纸条，我也这么回她。"

# game/a10/6cassprison.rpy:415
translate english cass_prison_fix_855b0b8d:

    # me "Вот же хитрая лиса..."
    me "真是只狡猾的狐狸……"

# game/a10/6cassprison.rpy:416
translate english cass_prison_fix_8ed8afe7:

    # cass "Не вини ее. Если бы не она я бы уже бросилась с окна от скуки."
    cass "别怪她。要不是她，我早就无聊得从窗户跳下去了。"

# game/a10/6cassprison.rpy:417
translate english cass_prison_fix_10aef3fe:

    # me "Я ее и не виню. Она поступает благородно, учитывая, что когда я видел вас вместе последний раз, ты угрожала ей навредить."
    me "我没怪她。她做得很高尚，尤其是考虑到我上次看到你们在一起时，你还威胁要伤害她。"

# game/a10/6cassprison.rpy:418
translate english cass_prison_fix_370f1909:

    # cass "Я блефовала. Мне нужно было заставить тебя ко мне присоединится."
    cass "我是吓唬人的。我需要迫使你加入我。"

# game/a10/6cassprison.rpy:419
translate english cass_prison_fix_daabdeeb:

    # me "И все же ты подвергла ее жизнь опасности."
    me "可你还是把她的生命置于危险之中。"

# game/a10/6cassprison.rpy:420
translate english cass_prison_fix_eea9cc68:

    # cass "Я уже извинилась перед ней. Хочешь чтобы я извинилась и перед тобой?"
    cass "我已经向她道过歉了。你想让我也向你道歉吗？"

# game/a10/6cassprison.rpy:421
translate english cass_prison_fix_496da9cc:

    # me "Было бы неплохо."
    me "那会挺好的。"

# game/a10/6cassprison.rpy:422
translate english cass_prison_fix_8c869896:

    # cass "Прости, [mename]. Прости, что похитила тебя и держала в тюрьме. Ну что? Стало легче?"
    cass "对不起，[mename]。对不起我绑架了你，把你关在牢里。怎么样？感觉好点了吗？"

# game/a10/6cassprison.rpy:423
translate english cass_prison_fix_3e498604:

    # me "Не слишком."
    me "没怎么好。"

# game/a10/6cassprison.rpy:424
translate english cass_prison_fix_50384091:

    # cass "Неудивительно."
    cass "没什么好奇怪的。"

# game/a10/6cassprison.rpy:425
translate english cass_prison_fix_56e22961:

    # me "Тяжело искупить то, что ты сделала словами. Много хороших людей умерли из-за тебя."
    me "用言语很难赎清你的所作所为。很多好人因你而死。"

# game/a10/6cassprison.rpy:426
translate english cass_prison_fix_651ccc28:

    # cass "..."
    cass "..."

# game/a10/6cassprison.rpy:427
translate english cass_prison_fix_d0577534:

    # me "Людвиг умер из-за тебя."
    me "Ludwig是为你而死的。"

# game/a10/6cassprison.rpy:429
translate english cass_prison_fix_922d3e3f:

    # cass "[mename]! Скажи мне, что тебе нужно?!"
    cass "[mename]！告诉我，你到底想要什么？！"

# game/a10/6cassprison.rpy:430
translate english cass_prison_fix_b6626098_1:

    # me "А?"
    me "啊？"

# game/a10/6cassprison.rpy:431
translate english cass_prison_fix_b2f93990:

    # cass "Зачем все это? Этот арест, эти прогулки в саду? К чему это?"
    cass "这一切是为了什么？这软禁，这花园的散步？到底为了什么？"

# game/a10/6cassprison.rpy:432
translate english cass_prison_fix_1461956e:

    # me "Тебе не нравится гулять в саду?"
    me "你不喜欢在花园散步吗？"

# game/a10/6cassprison.rpy:433
translate english cass_prison_fix_e2d8451d:

    # cass "Не изображай из себя идиота, ты понимаешь о чем я."
    cass "别装傻，你知道我在说什么。"

# game/a10/6cassprison.rpy:434
translate english cass_prison_fix_b8b88d2d:

    # me "Не совсем."
    me "不太知道。"

# game/a10/6cassprison.rpy:435
translate english cass_prison_fix_9e36b633:

    # cass "Вассалы отца хотят моей смерти, городской трибунал хочет моей смерти, законы Золотого Порядка требуют моей смерти."
    cass "父亲的封臣想要我死，城市法庭想要我死，黄金秩序的法律要求我死。"

# game/a10/6cassprison.rpy:436
translate english cass_prison_fix_731abec6:

    # cass "Почему я жива? Зачем тебе это? Зачем я нужна тебе живой? Ты же вредишь себе. Вредишь королевству. Зачем?"
    cass "为什么我还活着？你为何要这样？你需要我活着有什么用？你这是在害自己。害王国。为什么？"

# game/a10/6cassprison.rpy:438
translate english cass_prison_fix_835f4159:

    # me "Потому что ты моя сестра."
    me "因为你是我的姐姐。"

# game/a10/6cassprison.rpy:439
translate english cass_prison_fix_23cdbfee:

    # cass "А?"
    cass "啊？"

# game/a10/6cassprison.rpy:440
translate english cass_prison_fix_085f90e8:

