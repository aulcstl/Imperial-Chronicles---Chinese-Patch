    # me "Преториус нашел лекарство от белокровия."
    me "Pretorius找到了治疗白血病的药。"

# game/a10/6cassprison.rpy:230
translate english cass_prison_break_651ccc28_14:

    # cass "..."
    cass "..."

# game/a10/6cassprison.rpy:231
translate english cass_prison_break_3820771a_6:

    # me "..."
    me "..."

# game/a10/6cassprison.rpy:232
translate english cass_prison_break_e6bdc484:

    # cass "Ты же знаешь, что это была не я."
    cass "你知道那不是我干的。"

