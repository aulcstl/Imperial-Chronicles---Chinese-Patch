# game/a7/3wife_dos_i.rpy:3
translate english wife_dos_i_a4227ea0:

    # "Немного позже."
    "过了一会。"

# game/a7/3wife_dos_i.rpy:4
translate english wife_dos_i_658a905d:

    # me "Нам обязательно говорить здесь?"
    me "我们非得在这里谈话吗？"

# game/a7/3wife_dos_i.rpy:5
translate english wife_dos_i_51cd651b:

    # isi "Разве последние события не убедили тебя в том, что в замке не слишком безопасно?"
    isi "难道近期发生的事还没让你明白，城堡里并不怎么安全吗？"

# game/a7/3wife_dos_i.rpy:6
translate english wife_dos_i_971d89dd:

    # me "Я коронован."
    me "我已经加冕了。"

# game/a7/3wife_dos_i.rpy:7
translate english wife_dos_i_b371c9ac:

    # isi "И что? Поэтому у тебя пропали враги? Наоборот, их только прибавилось."
    isi "那又如何？难道你的敌人就因此消失了？恰恰相反，只会更多。"

# game/a7/3wife_dos_i.rpy:8
translate english wife_dos_i_3820771a:

    # me "..."
    me "..."

# game/a7/3wife_dos_i.rpy:10
translate english wife_dos_i_5a7504bd:

    # isi "Не пускайте никого на этот мост, пока мы здесь, понятно?"
    isi "我们在这里期间，任何人不得踏上这座桥，明白吗？"

# game/a7/3wife_dos_i.rpy:11
translate english wife_dos_i_0d4e1ef9:

    # rab_v "Yad, Kintara!"
    rab_v "Yad, Kintara!"

# game/a7/3wife_dos_i.rpy:12
translate english wife_dos_i_70d4df24:

    # isi "Можете идти."
    isi "你们可以下去了。"

# game/a7/3wife_dos_i.rpy:13
translate english wife_dos_i_0d4e1ef9_1:

    # rab_v "Yad, Kintara!"
    rab_v "Yad, Kintara!"

# game/a7/3wife_dos_i.rpy:14
translate english wife_dos_i_d025c96e:

    # me "Они понимают всеобщий?"
    me "他们听得懂通用语吗？"

# game/a7/3wife_dos_i.rpy:16
translate english wife_dos_i_6ac01532:

    # isi "Ну я же знала, куда я отправляюсь. Взяла с собой только знающих общий язык рабов."
    isi "我既然知道要去哪里，自然会带上只懂通用语的奴隶。"

# game/a7/3wife_dos_i.rpy:17
translate english wife_dos_i_38ca26fd:

    # me "Зачем? Ты могла бы отдавать им команды и на южном языке."
    me "何必呢？你用南方语言给他们下令也行啊。"

# game/a7/3wife_dos_i.rpy:18
translate english wife_dos_i_df33a3b9:

    # isi "Они здесь не только чтобы выполнять мои приказы, но и чтобы слушать...понимать, что происходит вокруг."
    isi "他们在这儿不仅是为了执行我的命令，也是为了倾听……知晓周围发生的一切。"

# game/a7/3wife_dos_i.rpy:19
translate english wife_dos_i_3820771a_1:

    # me "..."
    me "..."

# game/a7/3wife_dos_i.rpy:20
translate english wife_dos_i_ffd3b4af:

    # isi "..."
    isi "..."

# game/a7/3wife_dos_i.rpy:21
translate english wife_dos_i_7e2732f2:

    # me "Так о чем ты хотела поговорить?"
    me "那么，你想谈什么？"

# game/a7/3wife_dos_i.rpy:22
translate english wife_dos_i_b7ac9193:

    # isi "О твоей...безрассудной поездке на Запад."
    isi "关于你……前往西方那次鲁莽之行。"

# game/a7/3wife_dos_i.rpy:23
translate english wife_dos_i_fe8061e5:

    # me "Там не опасно."
    me "那里并不危险。"

# game/a7/3wife_dos_i.rpy:24
translate english wife_dos_i_0f5536b2:

    # isi "Может быть. Но правитель не должен покидать родных земель."
    isi "或许吧。但统治者不应该离开自己的故土。"

# game/a7/3wife_dos_i.rpy:25
translate english wife_dos_i_ae20e2da:

    # me "А как же ему отправляться на войну?"
    me "那他怎么出征打仗呢？"

# game/a7/3wife_dos_i.rpy:26
translate english wife_dos_i_6f92d822:

    # isi "Разве ты отправляешь на войну? Что-то я не видела, чтобы ты готовил армию."
    isi "难道你这是要去打仗吗？我可没见你集结军队。"

# game/a7/3wife_dos_i.rpy:27
translate english wife_dos_i_31b57276:

    # me "Войны бывают разные. На некоторые можно приходить и без армий."
    me "战争有多种形式。有些战争，不需要军队也能参与。"

# game/a7/3wife_dos_i.rpy:29
translate english wife_dos_i_0bb3f0bc:

    # isi "Может добавишь немного подробностей? Я все-таки твоя жена."
    isi "能不能再详细点？我好歹是你的妻子。"

# game/a7/3wife_dos_i.rpy:30
translate english wife_dos_i_f6265eb6:

    # me "Я хочу потребовать от лорда Аргуса справедливости."
    me "我想向Argus大人讨个公道。"

# game/a7/3wife_dos_i.rpy:31
translate english wife_dos_i_8057937e:

    # isi "Надеешься, что он вдруг упадет перед тобой на колени и отдаст свою корону из-за преступлений своей жены?"
    isi "你指望他会因为他妻子的罪行，突然跪倒在你面前，交出他的王冠吗？"

# game/a7/3wife_dos_i.rpy:32
translate english wife_dos_i_42e62aeb:

    # me "Нет. Но на определенные уступки ему придется пойти."
    me "不指望。但他将不得不做出某些让步。"

# game/a7/3wife_dos_i.rpy:33
translate english wife_dos_i_1e270690:

    # isi "С чего это вдруг? У тебя нет доказательств, что Присцилла действовала не в одиночку."
    isi "凭什么？你没有证据证明普丽西拉不是单独行动的。"

# game/a7/3wife_dos_i.rpy:34
translate english wife_dos_i_4c66e4ac:

    # me "Она его жена."
    me "她是他的妻子。"

# game/a7/3wife_dos_i.rpy:35
translate english wife_dos_i_f0e7a6e9:

    # isi "И?"
    isi "所以呢？"

# game/a7/3wife_dos_i.rpy:36
translate english wife_dos_i_21013feb:

    # me "Она запятнала его честь."
    me "她玷污了他的荣誉。"

# game/a7/3wife_dos_i.rpy:37
translate english wife_dos_i_ef679bb1:

    # isi "Честь? Я знаю, что на Западе ценят честь больше, чем на Юге. Но я все равно не думаю, что ты сможешь добиться чего-то существенного."
    isi "荣誉？我知道西方比南方更看重荣誉。但我还是觉得你争取不到什么实质性的东西。"

# game/a7/3wife_dos_i.rpy:38
translate english wife_dos_i_1a5c6432:

    # me "Может и нет."
    me "也许吧。"

# game/a7/3wife_dos_i.rpy:39
translate english wife_dos_i_bd0f3cda:

    # isi "Тогда зачем ты туда едешь?"
    isi "那你为什么还要去？"

# game/a7/3wife_dos_i.rpy:40
translate english wife_dos_i_5cb273a3:

    # me "Я должен попытаться. Западные земли всегда были с нами едины. А теперь, когда эльфы в долине больше не бунтуют, а Запад в кризисе из-за раздробленности, эпидемий и внутренних противоречий..."
    me "我必须试试。西部领地一直与我们同心同德。现在，谷地的精灵不再作乱，西方却因分裂割据、瘟疫流行和内部纷争而陷入危机……"

# game/a7/3wife_dos_i.rpy:41
translate english wife_dos_i_a5889938:

    # isi "...ты собираешься протянуть им руку помощи."
    isi "……你打算向他们伸出援手。"

# game/a7/3wife_dos_i.rpy:42
translate english wife_dos_i_eb77d3fa:

    # me "Думаешь это безумная идея?"
    me "你觉得这个想法很疯狂吗？"

# game/a7/3wife_dos_i.rpy:44
translate english wife_dos_i_26ef5807:

    # isi "Нет. Вообще-то я думаю это хорошая идея."
    isi "不。事实上，我觉得这是个好主意。"

# game/a7/3wife_dos_i.rpy:45
translate english wife_dos_i_489a247d:

    # me "Правда?"
    me "真的吗？"

# game/a7/3wife_dos_i.rpy:46
translate english wife_dos_i_b6c1dbc9:

    # isi "Да. Но я все равно сомневаюсь, что старые лорды Запада единогласно тебя поддержат."
    isi "是的。但我仍然怀疑，西方的那些老领主们会一致支持你。"

# game/a7/3wife_dos_i.rpy:47
translate english wife_dos_i_3820771a_2:

    # me "..."
    me "..."

# game/a7/3wife_dos_i.rpy:48
translate english wife_dos_i_938a8ae0:

    # isi "Я думаю тебе лучше сделать ставку на...другого всадника."
    isi "我觉得你最好把赌注押在……另一位骑手身上。"

# game/a7/3wife_dos_i.rpy:49
translate english wife_dos_i_d355dc3b:

    # me "О чем ты?"
    me "你指什么？"

# game/a7/3wife_dos_i.rpy:50
translate english wife_dos_i_4151691a:

    # isi "Внутренние противоречия, о которых ты говоришь... Птички напели мне, что они сильнее чем кажется. Молодая знать уже затеяла что-то вроде мятежа."
    isi "你所说的内部纷争……我有些耳闻，情况远比想象中严重。年轻贵族们似乎已经在谋划一场叛乱之类的事了。"

# game/a7/3wife_dos_i.rpy:51
translate english wife_dos_i_0d85d2c5:

    # me "Мятежа? Я об этом ничего не слышал."
    me "叛乱？我对此一无所知。"

# game/a7/3wife_dos_i.rpy:52
translate english wife_dos_i_8baacb5e:

    # isi "Их поразили больные идеи эльфийских мудрецов. Запад сохранил слишком много их культуры и теперь расплачивается за нетронутые статуи, дворцы, фонтаны и....книги."
    isi "他们被精灵贤者们那些病态的思想侵蚀了。西方保留了太多他们的文化，如今正为那些完好无损的雕像、宫殿、喷泉和……书籍付出代价。"

# game/a7/3wife_dos_i.rpy:53
translate english wife_dos_i_c68670c9:

    # me "Они затеяли мятеж из-за книг?"
    me "他们因为几本书就策划叛乱？"

# game/a7/3wife_dos_i.rpy:54
translate english wife_dos_i_2cafab61:

    # isi "Их вдохновляет государственное устройство эльфов. Когда у них еще было государство. Они называют это республикой."
    isi "是精灵的国体制度激励了他们。在他们的国家尚存之时。他们称之为……共和国。"

# game/a7/3wife_dos_i.rpy:55
translate english wife_dos_i_f7cd7da3:

    # me "И что? Они уже создали свою мятежную республику?"
    me "然后呢？他们已经建立起他们的叛乱共和国了吗？"

# game/a7/3wife_dos_i.rpy:56
translate english wife_dos_i_c5821605:

    # isi "Пока нет, но могут. Я знаю, что многие дети знатных лордов отказываются слушаться родителей, добровольно лишаются привилегий и сбегают в города..."
    isi "目前还没有，但有这个可能。我知道很多显赫领主的子女都拒绝听从父母之命，自愿放弃特权，逃往城市……"

# game/a7/3wife_dos_i.rpy:57
translate english wife_dos_i_f669f8d2:

    # me "Не думаю, что бежавшие дети лордов представляют хоть какую-то политическую силу."
    me "我不觉得这些离家出走的领主子女能构成什么政治力量。"

# game/a7/3wife_dos_i.rpy:58
translate english wife_dos_i_935b50f8:

    # isi "Они заражают своими идеями горожан и крестьян. А их силу и число недооценивать не стоит."
    isi "他们用他们的思想感染了市民和农民。而后者的力量和数量，不容低估。"

# game/a7/3wife_dos_i.rpy:59
translate english wife_dos_i_f5f0d808:

    # me "Ты предлагаешь помочь им устроить восстание?"
    me "你是建议我帮他们发动起义？"

# game/a7/3wife_dos_i.rpy:61
translate english wife_dos_i_b66b0590:

    # isi "Я думаю сейчас на Западе, как в пещере с черной серой, одна искра и..."
    isi "我认为现在的西方，就像一个满是黑火药的洞穴，只需要一点火星就会……"

# game/a7/3wife_dos_i.rpy:62
translate english wife_dos_i_f674c7b3:

    # me "Все взорвется..."
    me "全部引爆……"

# game/a7/3wife_dos_i.rpy:63
translate english wife_dos_i_2d864933:

    # isi "Да. А пепелищем будем владеть тот, кто первый воткнет туда флаг."
    isi "是的。而这片焦土将归属于第一个在那里插上旗帜的人。"

# game/a7/3wife_dos_i.rpy:64
translate english wife_dos_i_26923961:

    # me "Ты хочешь, чтобы они начали резню, а я героически это остановил? Для этого мне все равно нужна будет армия."
    me "你想让他们先自相残杀，然后我如同英雄般地去制止？为此我仍然需要一支军队。"

# game/a7/3wife_dos_i.rpy:65
translate english wife_dos_i_cbea4d1e:

    # isi "Вероятно. Но не сразу. Тебе сначала нужно поторговаться."
    isi "很可能需要。但不是立刻。你首先得去讨价还价。"

# game/a7/3wife_dos_i.rpy:66
translate english wife_dos_i_149b3064:

    # me "В каком смысле?"
    me "什么意思？"

# game/a7/3wife_dos_i.rpy:67
translate english wife_dos_i_4e2bd69e:

    # isi "Вассалы твоего отца собрали знамена из-за его отравления."
    isi "你父亲的封臣们因为他被毒杀而召集了军队。"

# game/a7/3wife_dos_i.rpy:68
translate english wife_dos_i_2325fa76:

    # me "И что?"
    me "所以呢？"

# game/a7/3wife_dos_i.rpy:69
translate english wife_dos_i_dc838831:

    # isi "Это значит, что один приказ и эти армии будут на Западе."
    isi "这意味着，只需一道命令，这些军队就能开赴西方。"

# game/a7/3wife_dos_i.rpy:70
translate english wife_dos_i_026ebd39:

    # me "Если они меня послушают."
    me "前提是他们听我的。"

# game/a7/3wife_dos_i.rpy:71
translate english wife_dos_i_ec9bc8ba:

    # isi "Послушают. Я уговорю их. Это не проблема. Ты очень выгодный союзник для обеих сторон конфликта."
    isi "他们会听的。我会说服他们。这不是问题。对于冲突双方来说，你都是非常有利可图的盟友。"

# game/a7/3wife_dos_i.rpy:72
translate english wife_dos_i_735492ce:

    # me "Предлагаешь по очереди говорить с лордами и их детьми, чтобы выторговывать для себя самые выгодные условия в обмен на помощь?"
    me "你是建议我轮流去和那些领主以及他们的子女谈，以支援为条件，为自己争取最优厚的待遇？"

# game/a7/3wife_dos_i.rpy:74
translate english wife_dos_i_b9b366cb:

    # isi "Молодец. Ты быстро понял. Будешь хорошим королем."
    isi "聪明。你理解得很快。你会成为一个好国王的。"

# game/a7/3wife_dos_i.rpy:75
translate english wife_dos_i_3e86cefa:

    # me "Этот план не учитывает одной мелочи."
    me "这个计划忽略了一个小细节。"

# game/a7/3wife_dos_i.rpy:76
translate english wife_dos_i_1a6c7a37:

    # isi "Какой?"
    isi "什么细节？"

# game/a7/3wife_dos_i.rpy:77
translate english wife_dos_i_e9fdcfd2:

    # me "А если они оба откажутся со мной торговаться?"
    me "要是他们双方都拒绝和我交易呢？"

# game/a7/3wife_dos_i.rpy:78
translate english wife_dos_i_9fccd845:

    # isi "Не откажутся. Но даже если это произойдет...тебе нужно будет просто помочь искре появиться."
    isi "他们不会拒绝。但即使真的发生了……你也只需要帮那颗火星出现就行了。"

# game/a7/3wife_dos_i.rpy:79
translate english wife_dos_i_58ada5b3:

    # me "И когда они поубивают друг друга...."
    me "等他们互相残杀得差不多了……"

# game/a7/3wife_dos_i.rpy:80
translate english wife_dos_i_140635c5:

    # isi "...ты войдешь с войсками и установишь порядок, как герой."
    isi "……你就率领军队进驻，恢复秩序，像个英雄一样。"

# game/a7/3wife_dos_i.rpy:81
translate english wife_dos_i_5954c7a9:

    # me "То есть ты уже не против моей поездки на Запад."
    me "这么说，你现在不反对我去西方了？"

# game/a7/3wife_dos_i.rpy:82
translate english wife_dos_i_b32a7531:

    # isi "Мы поговорили и теперь уже нет."
    isi "我们谈过之后，就不反对了。"

# game/a7/3wife_dos_i.rpy:83
translate english wife_dos_i_1c052684:

    # me "Пойдем обратно в замок?"
    me "我们回城堡吧？"

# game/a7/3wife_dos_i.rpy:84
translate english wife_dos_i_d2e60aa3:

    # isi "Постой. Может отведешь меня в эльфийские развалины. Всегда хотела посмотреть."
    isi "等等。或许你可以带我去看看那些精灵遗迹。我一直想看。"

# game/a7/3wife_dos_i.rpy:85
translate english wife_dos_i_01822020:

    # me "Ладно."
    me "好吧。"

# game/a7/3wife_dos_i.rpy:87
translate english wife_dos_i_396c128f:

    # "Час спустя."
    "一个小时以后。"

# game/a7/3wife_dos_i.rpy:88
translate english wife_dos_i_01479db6:

    # isi "Тут...довольно пусто."
    isi "这里……好空旷。"

# game/a7/3wife_dos_i.rpy:89
translate english wife_dos_i_719280dd:

    # me "А что ты хотела от развалин?"
    me "你对废墟还有什么期待？"

# game/a7/3wife_dos_i.rpy:90
translate english wife_dos_i_d89fe35f:

    # isi "Ну...в детстве я часто читала об эльфах и величии их цивилизации, но либо прошло слишком много времени, либо они строили точно также, как и люди."
    isi "嗯……我在童年时读过很多关于精灵和他们文明之伟大的书，但或许是时间过去太久了，又或者他们建造的东西其实和人类没什么两样。"

# game/a7/3wife_dos_i.rpy:91
translate english wife_dos_i_6addd005:

    # me "Это место ценится не из-за того, что его построили эльфы."
    me "这个地方的珍贵之处，并非因为它是精灵所建。"

# game/a7/3wife_dos_i.rpy:92
translate english wife_dos_i_ac80bc93:

    # isi "А почему?"
    isi "那是为什么？"

# game/a7/3wife_dos_i.rpy:93
