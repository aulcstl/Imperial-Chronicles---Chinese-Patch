# TODO: Translation updated at 2024-11-30 02:29

# game/a7/3wife_dos_a.rpy:3
translate english wife_dos_a_09bbaeb0:

    # me "{i}Кто притащил сюда стол?{/size}"
    me "{i}谁把这张桌子搬到这里的？{/i}"

# game/a7/3wife_dos_a.rpy:4
translate english wife_dos_a_55da7f2c:

    # me "{i}Аврора?{/i}"
    me "{i}是Aurora吗？{/i}"

# game/a7/3wife_dos_a.rpy:5
translate english wife_dos_a_f9705172:

    # me "{i}Нет. Она не смогла бы сделать это в одиночку.{/i}"
    me "{i}不。她一个人不可能搬得动。{/i}"

# game/a7/3wife_dos_a.rpy:6
translate english wife_dos_a_b0b0fa29:

    # me "{i}Наверняка попросила слуг.{/i}"
    me "{i}肯定是让仆人搬来的。{/i}"

# game/a7/3wife_dos_a.rpy:7
translate english wife_dos_a_62daca10:

    # me "{i}А зачем?{/i}"
    me "{i}但这是为什么呢？{/i}"

# game/a7/3wife_dos_a.rpy:9
translate english wife_dos_a_625789fd:

    # me "Угадай кто."
    me "猜猜看是谁。"

# game/a7/3wife_dos_a.rpy:10
translate english wife_dos_a_5d43c6ba:

    # aurora "Привет, [mename]."
    aurora "你好，[mename]。"

# game/a7/3wife_dos_a.rpy:11
translate english wife_dos_a_893cdac2:

    # me "Ты собираешься писать письма?"
    me "你要开始写信了吗？"

# game/a7/3wife_dos_a.rpy:12
translate english wife_dos_a_aa589aa0:

    # aurora "Я...может быть. Просто хочу сделать это место более уютным, раз уж это теперь мой новый дом."
    aurora "我……也许吧。我只是想让这里更舒适一些，毕竟这里现在是我的新家了。"

# game/a7/3wife_dos_a.rpy:13
translate english wife_dos_a_fe696b75:

    # me "Ну весь замок теперь твой новый дом."
    me "其实整座城堡都是你的新家。"

# game/a7/3wife_dos_a.rpy:14
translate english wife_dos_a_f43259c4:

    # aurora "Да, но в замке всегда есть кто-то еще, а эти покои только наши. И мне хочется их уютно обставить."
    aurora "是的，但城堡里总会有别人，而这几间房只属于我们。我想把它们布置得温馨些。"

# game/a7/3wife_dos_a.rpy:15
translate english wife_dos_a_3820771a:

    # me "..."
    me "..."

# game/a7/3wife_dos_a.rpy:16
translate english wife_dos_a_47d4e0f8:

    # aurora "Забудь. Не хочу тебя этим грузить, это просто привычки с Севера."
    aurora "算了。我不想用这些事烦你，这不过是我在北方养成的习惯罢了。"

# game/a7/3wife_dos_a.rpy:17
translate english wife_dos_a_ba770cfc:

    # me "Я прекрасно понимаю твое желание, просто десятилетие в изгнании рассеяло во мне всякое чувство уюта и дома."
    me "我完全理解你的想法，只是十年的流亡生活，早已把我心中对“舒适”和“家”的感觉消磨殆尽了。"

# game/a7/3wife_dos_a.rpy:18
translate english wife_dos_a_5d818efc:

    # aurora "Я попробую вернуть тебе это чувство."
    aurora "我会试着帮你找回这种感觉的。"

# game/a7/3wife_dos_a.rpy:20
translate english wife_dos_a_489a247d:

    # me "Правда?"
    me "真的吗？"

# game/a7/3wife_dos_a.rpy:21
translate english wife_dos_a_7e8d5bc1:

    # aurora "Правда. В конце концов это одна из функций жены - сделать саму мысль о возвращении домой для мужа приятной."
    aurora "真的。毕竟，让丈夫一想到回家就感到愉快，这本来就是妻子的职责之一。"

# game/a7/3wife_dos_a.rpy:22
translate english wife_dos_a_72fa2b7b:

    # me "То, что ты будешь меня ждать дома, уже делает мысль о возвращении приятной."
    me "只要想到你在家里等我，就已经足够让我归心似箭了。"

# game/a7/3wife_dos_a.rpy:23
translate english wife_dos_a_8c1458bc:

    # aurora "...тебя долго не будет?"
    aurora "……你要离开很久吗？"

# game/a7/3wife_dos_a.rpy:24
translate english wife_dos_a_843e2b28:

    # me "Я не знаю, учитывая дорогу туда и обратно - может пару месяцев. А что?"
    me "我不确定，算上来回的路程，也许要几个月。怎么了？"

# game/a7/3wife_dos_a.rpy:25
translate english wife_dos_a_efed4604:

    # aurora "...нет...ничего."
    aurora "……没……没什么。"

# game/a7/3wife_dos_a.rpy:26
translate english wife_dos_a_3cb45c04:

    # me "Если ты сильно заскучаешь всегда можешь поговорить с моей младшей сестрой. С теми, кто ей нравится, она может болтать и заниматься чем угодно часами."
    me "如果你实在感到寂寞，随时可以去找我妹妹聊聊。和她喜欢的人在一起，她能聊上几个小时，玩什么都行。"

# game/a7/3wife_dos_a.rpy:27
translate english wife_dos_a_55dcbb9b:

    # aurora "Я знаю. Сегодня она помогала мне выбирать цветы из сада для наших покоев."
    aurora "我知道。今天她还帮我从花园里挑选了装饰我们房间的鲜花呢。"

# game/a7/3wife_dos_a.rpy:28
translate english wife_dos_a_1d0ed7ec:

    # me "Я надеюсь никто в процессе не пострадал."
    me "我希望在这个过程中没人遭殃。"

# game/a7/3wife_dos_a.rpy:29
translate english wife_dos_a_8edde7d4:

    # aurora "Разве что моя голова разболелась, [lia] кажется прочитала книг о цветах больше чем я любых других за всю жизнь."
    aurora "除了我的头疼得厉害之外，[lia]读过的花卉书籍，好像比我这一辈子读的其他所有书都多。"

# game/a7/3wife_dos_a.rpy:30
translate english wife_dos_a_efc40969:

    # me "Знаешь, может пока я еще не уехал на Запад, украсим наши покои вместе?"
    me "你知道吗，也许在我动身去西方之前，我们可以一起装饰我们的房间？"

# game/a7/3wife_dos_a.rpy:31
translate english wife_dos_a_0504e82c:

    # aurora "Давай! Хорошая идея!"
    aurora "好啊！这主意棒极了！"

# game/a7/3wife_dos_a.rpy:34
translate english wife_dos_a_335006a0:

    # me "Мгм..."
    me "嗯……"

# game/a7/3wife_dos_a.rpy:35
translate english wife_dos_a_9753519c:

    # me "{i}Она впервые меня сама поцеловала.{/i}"
    me "{i}她第一次主动吻了我。{/i}"

# game/a7/3wife_dos_a.rpy:36
translate english wife_dos_a_ad714027:

    # me "{i}Хех.{/i}"
    me "{i}呵。{/i}"

# game/a7/3wife_dos_a.rpy:37
translate english wife_dos_a_9408137c:

    # me "{i}Кажется она меня любит.{/i}"
    me "{i}看来她是爱我的。{/i}"

# game/a7/3wife_dos_a.rpy:38
translate english wife_dos_a_8180bc1c:

    # me "{i}Не как жена мужа, а по-настоящему...{/i}"
    me "{i}不是那种妻子对丈夫的爱，而是真正的……{/i}"

# game/a7/3wife_dos_a.rpy:39
translate english wife_dos_a_1cd670fb:

    # me "{i}Либо очень искусно притворяется.{/i}"
    me "{i}要么就是她装得太像了。{/i}"

# game/a7/3wife_dos_a.rpy:41
translate english wife_dos_a_43e89fa2:

    # me "Ковры?"
    me "地毯？"

# game/a7/3wife_dos_a.rpy:42
translate english wife_dos_a_a027861b:

    # aurora "Ну да. Тебе не нравится?"
    aurora "嗯，是啊。你不喜欢吗？"

# game/a7/3wife_dos_a.rpy:43
translate english wife_dos_a_7f43a9f3:

    # me "Придется снимать обувь, иначе они быстро испачкаются."
    me "那我们就得脱鞋了，不然很快就会弄脏的。"

# game/a7/3wife_dos_a.rpy:44
translate english wife_dos_a_e1fbdbeb:

    # aurora "На Севере они повсюду."
    aurora "在北方，到处都铺着地毯。"

# game/a7/3wife_dos_a.rpy:45
translate english wife_dos_a_068b7a82:

    # me "Я знаю."
    me "我知道。"

# game/a7/3wife_dos_a.rpy:46
translate english wife_dos_a_bb787965:

    # aurora "Давай уберем, если тебе не нравится."
    aurora "要是你不喜欢，我们就把它撤掉吧。"

# game/a7/3wife_dos_a.rpy:47
translate english wife_dos_a_717c595d:

    # me "Все нормально. Стол нормально встал к стене?"
    me "不用，这样挺好。桌子靠墙放稳了吗？"

# game/a7/3wife_dos_a.rpy:48
translate english wife_dos_a_3cbe7166:

    # aurora "Да. Все хорошо."
    aurora "嗯。很好。"

# game/a7/3wife_dos_a.rpy:50
translate english wife_dos_a_226b5c66:

    # aurora "Как тебе этот запах цветов?"
    aurora "这些花的香味你觉得怎么样？"

# game/a7/3wife_dos_a.rpy:51
translate english wife_dos_a_f5098250:

    # me "Хороший."
    me "很好闻。"

# game/a7/3wife_dos_a.rpy:52
translate english wife_dos_a_821f5747:

    # aurora "Я и [lia] специально подбирали не слишком резкий аромат, чтобы он не мешал засыпать."
    aurora "我和[lia]特意选了不太浓烈的香味，这样就不会影响入睡。"

# game/a7/3wife_dos_a.rpy:53
translate english wife_dos_a_21f1f36a:

    # me "На Севере есть сады?"
    me "北方有花园吗？"

# game/a7/3wife_dos_a.rpy:54
translate english wife_dos_a_b8f861d0:

    # aurora "Временные. Почти все растения зимой погибают. Но мы растим некоторые в домашнем тепле."
    aurora "有临时性的。几乎所有植物到了冬天都会枯死。不过我们会在屋子里，借着炉火种一些。"

# game/a7/3wife_dos_a.rpy:55
translate english wife_dos_a_6262ee76:

    # me "А я думал растения не выживают без солнечного света."
    me "我还以为植物没有阳光就活不了呢。"

# game/a7/3wife_dos_a.rpy:56
translate english wife_dos_a_9ad33c66:

    # aurora "Некоторые могут и без него. Я оставлю тебя ненадолго. Мне нужно переодеться во что-то более удобное."
    aurora "有些植物是可以在无光环境下生存的。我先失陪一小会儿。我得去换件更舒服点的衣服。"

# game/a7/3wife_dos_a.rpy:57
translate english wife_dos_a_71d3b8c8:

    # me "Хорошо."
    me "好的。"

# game/a7/3wife_dos_a.rpy:64
translate english wife_dos_a_fc1e7905:

    # me "{i}Как же хорошо я получился на этой картине.{/i}"
    me "{i}我在这幅画里看起来真不错。{/i}"

# game/a7/3wife_dos_a.rpy:65
translate english wife_dos_a_59957a6d:

    # me "{i}У моей сестренки уникальный талант.{/i}"
    me "{i}我的妹妹真是个独一无二的天才。{/i}"

# game/a7/3wife_dos_a.rpy:66
translate english wife_dos_a_0038a324:

    # me "{i}Не всякий умелый художник сможет так запечатлеть реальность.{/i}"
    me "{i}不是每个技巧娴熟的画家都能如此栩栩如生地记录下现实。{/i}"

# game/a7/3wife_dos_a.rpy:67
translate english wife_dos_a_c2268e62:

    # me "{i}Надо бы попросить ее нарисовать наш общий семейный портрет.{/i}"
    me "{i}应该请她为我们画一幅全家福的。{/i}"

# game/a7/3wife_dos_a.rpy:68
translate english wife_dos_a_98cd6e94:

    # me "{i}Хотя это будет странным, учитывая что отец без сознания.{/i}"
    me "{i}不过这可能会有点奇怪，毕竟父亲现在昏迷不醒。{/i}"

# game/a7/3wife_dos_a.rpy:69
translate english wife_dos_a_300cc783:

    # me "{i}Хотя для портрета такая неподвижность это только преимущество...{/i}"
    me "{i}不过对画肖像来说，这种静止不动倒是个优点……{/i}"

# game/a7/3wife_dos_a.rpy:71
translate english wife_dos_a_35dd48a2:

    # me "{i}Второго кресла здесь точно не хватало.{/i}"
    me "{i}这里确实早就该添置第二把扶手椅了。{/i}"

# game/a7/3wife_dos_a.rpy:72
translate english wife_dos_a_6e43eb8c:

    # me "{i}Сидеть у камина вдвоем определенно уютнее.{/i}"
    me "{i}两个人一起坐在壁炉前肯定要舒适得多。{/i}"

# game/a7/3wife_dos_a.rpy:73
translate english wife_dos_a_110e8202:

    # me "{i}Я уже представлю себя лысым стариком, что греет кости у огня и ворчит на внуков...Эхх...славное это будет время. Не могу дождаться.{/i}"
    me "{i}我已经可以想象自己变成一个秃顶老头，在炉火边烤着骨头，对着孙辈们发牢骚了……唉……那将是多么美好的时光啊。我都等不及了。{/i}"

# game/a7/3wife_dos_a.rpy:75
translate english wife_dos_a_32cfca79:

    # aurora "Прости. Все никак не могла найти ничего удобного. Продолжим?"
    aurora "抱歉。我一直找不到什么舒服的衣服。我们继续吧？"

# game/a7/3wife_dos_a.rpy:76
translate english wife_dos_a_eefd62a3:

    # me "А есть что-то еще."
    me "还有别的东西要弄吗？"

# game/a7/3wife_dos_a.rpy:77
translate english wife_dos_a_7bc4a054:

    # aurora "Еще много чего!"
    aurora "还有好多呢！"

# game/a7/3wife_dos_a.rpy:78
translate english wife_dos_a_e473fa2f:

    # me "Например?"
    me "比如说？"

# game/a7/3wife_dos_a.rpy:79
translate english wife_dos_a_6f053be5:

    # aurora "Книжные полки, стол, еще цветы..."
    aurora "书架、书桌，还有鲜花……"

# game/a7/3wife_dos_a.rpy:80
translate english wife_dos_a_9fd4e7bc:

    # me "Еще..."
    me "还有……"

# game/a7/3wife_dos_a.rpy:81
translate english wife_dos_a_61a9f848:

    # aurora "Не волнуйся. Я попросила слуг и они все принесут прямо сюда."
    aurora "别担心。我已经吩咐过仆人，他们会把所有东西都直接搬到这儿来的。"

# game/a7/3wife_dos_a.rpy:83
translate english wife_dos_a_e5c73993:

    # me "Аж два книжных стеллажа?"
    me "居然要两个书架？"

# game/a7/3wife_dos_a.rpy:84
translate english wife_dos_a_9622dd25:

    # aurora "Я хотела один. Но [lia] посоветовала мне столько книг, что на один они бы точно все не поместились."
    aurora "我本来只想要一个的。但[lia]给我推荐了那么多书，一个书架根本放不下。"

# game/a7/3wife_dos_a.rpy:85
translate english wife_dos_a_aa440576:

    # me "Тебе не обязательно читать все что она советует."
    me "你没必要把她推荐的书全都读完的。"

# game/a7/3wife_dos_a.rpy:86
translate english wife_dos_a_d43117a2:

    # aurora "Боюсь что обязательно. Мне не хочется выглядеть дурой в глазах маленькой девочки."
    aurora "恐怕很有必要。我可不想在一个小姑娘面前显得像个傻瓜。"

# game/a7/3wife_dos_a.rpy:87
translate english wife_dos_a_4ef499a3:

    # me "Во-первых она уже не особо маленькая, а во-вторых она прочитала всю королевскую библиотеку, так что тебе с ней в любом случае не посоперничать."
    me "首先，她可不算是小姑娘了；其次，她读完了整个皇家图书馆的藏书，所以无论如何你都是没法跟她比的。"

# game/a7/3wife_dos_a.rpy:88
translate english wife_dos_a_7ea368a7:

    # aurora "Я и не надеялась на соперничество. Хотя бы поддержать разговор."
    aurora "我本来也没指望能比得上她。只要能搭上几句话就行了。"

# game/a7/3wife_dos_a.rpy:89
translate english wife_dos_a_34337aa6:

    # me "Она тебе нравится?"
    me "你喜欢她吗？"

# game/a7/3wife_dos_a.rpy:90
translate english wife_dos_a_2e4973ec:

    # aurora "[lia]? Да. Она хорошая девочка. Она напоминает мне мою младшую сестру."
    aurora "[lia]吗？喜欢。她是好女孩。她让我想起了我的小妹妹。"

# game/a7/3wife_dos_a.rpy:91
translate english wife_dos_a_622704e3:

    # me "У твоего отца только девочки?"
    me "你父亲只有女儿吗？"

# game/a7/3wife_dos_a.rpy:93
translate english wife_dos_a_b7e34204:

    # aurora "У моего отца были два сына, но они погибли во время восстания против Красного Императора."
    aurora "我父亲曾有过两个儿子，但他们在反抗红皇帝的起义中牺牲了。"

# game/a7/3wife_dos_a.rpy:94
translate english wife_dos_a_1a8984c1:

    # me "Мне жаль."
    me "我很遗憾。"

# game/a7/3wife_dos_a.rpy:95
translate english wife_dos_a_4f14c81d:

    # aurora "Я родилась уже после их смерти, так что я знаю о них только из рассказов матери."
    aurora "我是在他们死后才出生的，所以关于他们的事，我也只是从母亲的故事里听说过。"

# game/a7/3wife_dos_a.rpy:96
translate english wife_dos_a_85ef503d:

    # me "С тех пор у твоего отца не рождались сыновья?"
    me "从那以后，你父亲就没有再生过儿子了？"

# game/a7/3wife_dos_a.rpy:97
translate english wife_dos_a_4787f2f9:

    # aurora "Нет. Только я и мои сестры."
    aurora "没有了。只有我和我的姐妹们。"

# game/a7/3wife_dos_a.rpy:98
translate english wife_dos_a_bf54e28f:

    # me "Ну...у него еще есть время."
    me "呃……他还有点时间嘛。"

# game/a7/3wife_dos_a.rpy:99
translate english wife_dos_a_c403642e:

    # aurora "Не знаю...последний раз моя мать родила уже мертвого ребенка...боюсь она приблизилась к возрасту, когда о новых детях можно забыть."
    aurora "我不知道……我母亲最后一次生产，生下来的是死胎……恐怕她已经到了没法再生育的年纪了。"

# game/a7/3wife_dos_a.rpy:100
translate english wife_dos_a_dc306ef1:

    # me "Не стоило поднимать эту тему."
    me "我不该提起这个话题的。"

# game/a7/3wife_dos_a.rpy:101
translate english wife_dos_a_e4d8018e:

    # aurora "Все нормально. Это просто жизнь."
    aurora "没关系。这就是生活。"

# game/a7/3wife_dos_a.rpy:103
translate english wife_dos_a_780f6eaa:

