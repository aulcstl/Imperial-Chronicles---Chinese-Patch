# TODO: Translation updated at 2024-12-06 07:39

# game/a7/6road_portals.rpy:3
translate english elin_roads_9f2a99fe:

    # "Утром."
    "早上。"

# game/a7/6road_portals.rpy:4
translate english elin_roads_3cf41013:

    # me "{i}Ухх! Как же хорошо спать в кровати, а не на сырой земле.{/i}"
    me "{i}呼！睡在床上可真好，不像睡在湿地上。{/i}"

# game/a7/6road_portals.rpy:5
translate english elin_roads_ee38f919:

    # me "{i}Ненавижу долгие путешествия.{/i}"
    me "{i}我讨厌长途旅行。{/i}"

# game/a7/6road_portals.rpy:6
translate english elin_roads_b49ba70b:

    # me "{i}Конечно я мог бы путешествовать в карете...{/i}"
    me "{i}当然我也可以坐马车旅行...{/i}"

# game/a7/6road_portals.rpy:7
translate english elin_roads_587f4f00:

    # me "{i}Но это как-то не по-мужски.{/i}"
    me "{i}但那可不太有男子气概。{/i}"

# game/a7/6road_portals.rpy:9
translate english elin_roads_36c678e8:

    # me "{i}С другой стороны, лучше прокатится на карете, чем хромать, как мой отец.{/i}"
    me "{i}不过话说回来，坐马车总比像我父亲那样一瘸一拐地走路强。{/i}"

# game/a7/6road_portals.rpy:10
translate english elin_roads_44d8aab5:

    # me "{i}Хмм...а ведь он всегда был в Золотой Столице.{/i}"
    me "{i}嗯...可他一直待在黄金之都。{/i}"

# game/a7/6road_portals.rpy:11
translate english elin_roads_a1988bd4:

    # me "{i}Я его никогда верхом не видел.{/i}"
    me "{i}我从没见过他骑马。{/i}"

# game/a7/6road_portals.rpy:12
translate english elin_roads_7416f892:

    # me "{i}Тогда может быть наоборот? Нужно чаще ездить верхом, чтобы потом не хромать?{/i}"
    me "{i}那也许正相反？应该经常骑马，这样以后才不会瘸？{/i}"

# game/a7/6road_portals.rpy:13
translate english elin_roads_b4ca1207:

    # me "{i}Ладно, плевать, я хочу писать.{/i}"
    me "{i}算了，不管了，我要去小解。{/i}"

# game/a7/6road_portals.rpy:15
translate english elin_roads_3f03e2b2:

    # me "Ля-ля-ля, журчит водичка, ля-ля-ля, прекрасный день."
    me "啦-啦-啦，小溪水潺潺，啦-啦-啦，多美好的一天。"

# game/a7/6road_portals.rpy:16
translate english elin_roads_b706e252:

    # me "Что смотришь, лошадка? Я просто писаю."
    me "看什么看，小马？我只是在尿尿。"

# game/a7/6road_portals.rpy:17
translate english elin_roads_78c9e1f0:

    # me "Да. Прямо в ручей. Но это не стоячая вода, так что можно."
    me "是的。直接尿在溪水里。不过这不是死水，所以没关系。"

# game/a7/6road_portals.rpy:18
translate english elin_roads_7a98a23a:

    # me "Не смотри на меня так осуждающе."
    me "别用那么责备的眼神看我。"

# game/a7/6road_portals.rpy:19
translate english elin_roads_ad46c332:

    # me "Прекрати. Я серьезно. Мне и так стыдно. Я уже и сам не понимаю почему я решил пописать именно в ручей."
    me "够了。我是认真的。我已经够难为情的了。我自己都不明白为什么非要尿在溪水里。"

# game/a7/6road_portals.rpy:21
translate english elin_roads_0e264b4a:

    # elin "Ты с кем разговариваешь?"
    elin "你在跟谁说话？"

# game/a7/6road_portals.rpy:22
translate english elin_roads_cd708cd9:

    # me "Тьфу, [elin], ты чего подкрадываешься?"
    me "哎呀，[elin]，你干嘛偷偷摸摸地过来？"

# game/a7/6road_portals.rpy:23
translate english elin_roads_aca32f53:

    # elin "Я не подкрадывалась. Ты просто меня не услышал из-за разговоров во время мочеиспускания."
    elin "我没有偷偷摸摸。你只是因为在尿尿的时候说话，没听到我过来。"

# game/a7/6road_portals.rpy:24
translate english elin_roads_e79d0fd5:

    # me "Да?"
    me "是吗？"

# game/a7/6road_portals.rpy:25
translate english elin_roads_d62493cb:

    # elin "Да. Так с кем ты говорил? Сам с собой."
    elin "是的。那你刚才在跟谁说话？自言自语吗？"

# game/a7/6road_portals.rpy:26
translate english elin_roads_d76ccded:

    # me "Нет. С лошадью."
    me "不。跟马说话。"

# game/a7/6road_portals.rpy:27
translate english elin_roads_b0381870:

    # elin "И о чем ты говорил с лошадью?"
    elin "那你跟马说了些什么？"

# game/a7/6road_portals.rpy:29
translate english elin_roads_a4fd9f65:

    # me "Ну знаешь, иногда делаешь какую-нибудь глупость, а потом в середине самого действа это осознаешь, но уже поздно останавливаться."
    me "嗯，你知道，有时候你会做点蠢事，然后事情做到一半才意识到，但已经来不及停下了。"

# game/a7/6road_portals.rpy:30
translate english elin_roads_70fb04cd:

    # elin "Ну почему глупость, я иногда разговариваю с животными."
    elin "这有什么蠢的，我有时也会跟动物说话。"

# game/a7/6road_portals.rpy:31
translate english elin_roads_23b1508a:

    # me "Нет. Я про то, что я зачем-то пописал в ручей. Мне кажется местные берут отсюда воду. Я это как раз и обсуждал с лошадью."
    me "不是这个。我是说我怎么就在溪水里尿了。我觉得本地人是从这里取水的。我刚才就是在和马讨论这个。"

# game/a7/6road_portals.rpy:32
translate english elin_roads_92d397c8:

    # elin "..."
    elin "..."

# game/a7/6road_portals.rpy:33
translate english elin_roads_3820771a:

    # me "..."
    me "..."

# game/a7/6road_portals.rpy:34
translate english elin_roads_03005c8e:

    # elin "Как отдохнул?"
    elin "休息得怎么样？"

# game/a7/6road_portals.rpy:36
translate english elin_roads_9fe5e42b:

    # me "Отлично. После долгой дороги чувствовал себя разбитым."
    me "好极了。长途跋涉之后感觉累垮了。"

# game/a7/6road_portals.rpy:37
translate english elin_roads_eebd9be1:

    # elin "Я тоже."
    elin "我也是。"

# game/a7/6road_portals.rpy:38
translate english elin_roads_e2495e5e:

    # me "Ты тоже помылась?"
    me "你也洗澡了吗？"

# game/a7/6road_portals.rpy:39
translate english elin_roads_fed65f4d:

    # elin "Да. Но я тебя кстати на реке вчера не видела."
    elin "嗯。不过我昨天在河边没看见你。"

# game/a7/6road_portals.rpy:40
translate english elin_roads_811d642f:

    # me "У крестьян, что меня приютили, есть ванна."
    me "收留我的那个农户家有浴盆。"

# game/a7/6road_portals.rpy:41
translate english elin_roads_b6538b9c:

    # elin "Серьезно? Вот тебе повезло."
    elin "真的？那你可真走运。"

# game/a7/6road_portals.rpy:42
translate english elin_roads_5e4dd0ca:

    # me "Хочешь я попрошу у них погреть воды и тебе?"
    me "要不要我请他们给你也烧点热水？"

# game/a7/6road_portals.rpy:43
translate english elin_roads_8acbd6cd:

    # elin "Не надо."
    elin "不用了。"

# game/a7/6road_portals.rpy:44
translate english elin_roads_d364bee1:

    # me "Обоз еще не прибыл?"
    me "车队还没到吗？"

# game/a7/6road_portals.rpy:46
translate english elin_roads_2144afa9:

    # elin "Прибыл."
    elin "到了。"

# game/a7/6road_portals.rpy:47
translate english elin_roads_8d5f8ac8:

    # me "Печально. Значит эту ночь мы проведем в седле, а не в кровати."
    me "真遗憾。那今晚我们又得在马鞍上过夜，而不是睡床了。"

# game/a7/6road_portals.rpy:48
translate english elin_roads_dcd62dae:

    # elin "Они прибыли только недавно. Сейчас все будут отдыхать и дозакупаться провиантом у местных."
    elin "他们也是刚到。现在大家要休息一下，顺便跟当地人补充些给养。"

# game/a7/6road_portals.rpy:49
translate english elin_roads_dccec11e:

    # me "А мы что будем делать?"
    me "那我们做什么？"

# game/a7/6road_portals.rpy:50
translate english elin_roads_1a7919d5:

    # elin "Не знаю...можешь еще поспать."
    elin "不知道...你可以再睡会儿。"

# game/a7/6road_portals.rpy:51
translate english elin_roads_a7a6bf30:

    # me "Наверно я так и сделаю."
    me "大概我会这么做的。"

# game/a7/6road_portals.rpy:52
translate english elin_roads_bffb0656:

    # elin "Хотя...есть у меня одна идея, как развлечься."
    elin "不过...我倒是有一个找乐子的主意。"

# game/a7/6road_portals.rpy:53
translate english elin_roads_fb481cce:

    # me "Какая."
    me "什么主意。"

# game/a7/6road_portals.rpy:54
translate english elin_roads_79757a27:

    # elin "Порталы."
    elin "传送门。"

# game/a7/6road_portals.rpy:55
translate english elin_roads_3731482f:

    # me "Порталы? Нет."
    me "传送门？不行。"

# game/a7/6road_portals.rpy:57
translate english elin_roads_0105f216:

    # elin "Давай. В прошлый раз ведь было весело."
    elin "来吧。上次不是挺开心的嘛。"

# game/a7/6road_portals.rpy:58
translate english elin_roads_fef57fb2:

    # me "В прошлый раз был опасно."
    me "上次很危险。"

# game/a7/6road_portals.rpy:59
translate english elin_roads_fad88755:

    # elin "Да, опасно. Но весело."
    elin "是，很危险。但很开心。"

# game/a7/6road_portals.rpy:60
translate english elin_roads_fa9085d7:

    # me "Я не хочу."
    me "我不想去。"

# game/a7/6road_portals.rpy:61
translate english elin_roads_a5028750:

    # elin "Ты что, струсил?"
    elin "怎么，你胆小了？"

# game/a7/6road_portals.rpy:62
translate english elin_roads_e0186d6e:

    # me "Чего? Это тут не при чем."
    me "什么？跟那个没关系。"

# game/a7/6road_portals.rpy:63
translate english elin_roads_009bf0d3:

    # elin "И это будущий король? Мдауш."
    elin "就这还未来国王呢？啧啧。"

# game/a7/6road_portals.rpy:64
translate english elin_roads_efc90efe:

    # me "Не провоцируй меня."
    me "别激我。"

# game/a7/6road_portals.rpy:65
translate english elin_roads_28071e02:

    # elin "Король пугливых цыплят разве что."
    elin "充其量是个胆小鸡仔国王。"

# game/a7/6road_portals.rpy:66
translate english elin_roads_3ed4e2db:

    # me "[elin], я не"
    me "[elin]，我没有..."

# game/a7/6road_portals.rpy:67
translate english elin_roads_bae544b3:

    # elin "Прости, не понимаю на цыплячьем. Я слышу только 'Ко-ко-ко. Я маленький напуганный цыпленочек.'"
    elin "抱歉，我不懂鸡语。我只听到'咯咯咯。我是一只受惊的小鸡仔。'"

# game/a7/6road_portals.rpy:68
translate english elin_roads_9a5b71b4:

    # me "Ладно, но если мы умрем, я обещаю, что моя душа будет преследовать твою и причитать 'я же говорил' до конца времен."
    me "好吧，不过要是我们死了，我保证我的灵魂会纠缠你的灵魂，在你耳边念叨'我早就说过'直到永远。"

# game/a7/6road_portals.rpy:71
translate english elin_roads_84f1dff5:

    # elin "Меня это предложение устраивает."
    elin "我对这个提议很满意。"

# game/a7/6road_portals.rpy:72
translate english elin_roads_b3f13268:

    # elin "Laurelin amin nauro sîr duran quora ateass."
    elin "Laurelin amin nauro sîr duran quora ateass."

# game/a7/6road_portals.rpy:73
translate english elin_roads_55344d2d:

    # elin "Quora ateass!"
    elin "Quora ateass!"

# game/a7/6road_portals.rpy:74
translate english elin_roads_eae34b70:

    # me "Твой портал опять какой-то странной формы."
    me "你的传送门这次形状又有点奇怪。"

# game/a7/6road_portals.rpy:75
translate english elin_roads_309990fc:

    # elin "Да. Это все-таки ты виноват. Только рядом с тобой он такой."
    elin "是啊。这还得怪你。只有在你旁边它才会这样。"

# game/a7/6road_portals.rpy:76
translate english elin_roads_29e55312:

    # me "Мы так и не расспросили Преториуса или леди Алейну об этом."
    me "我们还没就这事问过Pretorius或是Alaina女士呢。"

# game/a7/6road_portals.rpy:77
translate english elin_roads_be52a81e:

    # elin "Потом расспросим. Сейчас нас ждут приключения."
    elin "之后再去问吧。现在有冒险在等着我们。"

# game/a7/6road_portals.rpy:78
translate english elin_roads_a33781ad:

    # me "Ты какая-то суицидальная. Ты зачем постоянно идешь на осознанный риск?"
    me "你有点太不惜命了。你为什么总要去冒这种明知故犯的风险？"

# game/a7/6road_portals.rpy:80
translate english elin_roads_f51d6067:

    # elin "Прости, я ничего не понимаю, ты снова перешел на цыплячьий язык."
    elin "抱歉，我完全听不懂，你又在说鸡仔语了。"

# game/a7/6road_portals.rpy:81
translate english elin_roads_26561f4f:

    # me "Эх..."
    me "唉..."

# game/a7/6road_portals.rpy:87
translate english elin_roads2_84f1dff5:

    # elin "Меня это предложение устраивает."
    elin "我对这个提议很满意。"

# game/a7/6road_portals.rpy:88
translate english elin_roads2_b3f13268:

    # elin "Laurelin amin nauro sîr duran quora ateass."
    elin "Laurelin amin nauro sîr duran quora ateass."

# game/a7/6road_portals.rpy:89
translate english elin_roads2_55344d2d:

    # elin "Quora ateass!"
    elin "Quora ateass!"

# game/a7/6road_portals.rpy:90
translate english elin_roads2_7eb5f0e5:

    # me "И куда мы направимся в этот раз?"
    me "那我们这次去哪儿？"

# game/a7/6road_portals.rpy:91
translate english elin_roads2_9bf43e11:

    # elin "Я этого знать не могу, забыл?"
    elin "这我可没法知道，忘了吗？"

# game/a7/6road_portals.rpy:92
translate english elin_roads2_c7fc7f97:

    # me "Знаешь. Я тут подумал..."
    me "你知道吗，我刚才在想..."

# game/a7/6road_portals.rpy:93
translate english elin_roads2_d65ff2b8:

    # elin "М?"
    elin "嗯？"

# game/a7/6road_portals.rpy:94
translate english elin_roads2_dee743be:

    # me "А что, если портал откроется над океаном? Тогда вернутся назад будет невозможно."
    me "万一传送门开在海洋上方怎么办？那可就回不来了。"

# game/a7/6road_portals.rpy:96
translate english elin_roads2_165850ed:

    # elin "Не откроется."
    elin "不会开在那的。"

# game/a7/6road_portals.rpy:97
translate english elin_roads2_238ce8d6:

    # me "Ты уверена?"
    me "你确定？"

# game/a7/6road_portals.rpy:98
translate english elin_roads2_b4965686:

    # elin "Нет. Но тогда я буду открывать портал за порталом, пока не попадем в нужное место."
    elin "不确定。但那样的话，我会开一个又一个传送门，直到我们找到合适的地方。"

# game/a7/6road_portals.rpy:99
translate english elin_roads2_03d189df:

    # me "Звучит очень надежно."
    me "听起来真可靠。"

# game/a7/6road_portals.rpy:101
translate english elin_roads2_859c4ce1:

    # elin "Да успокойся ты. Не открываются порталы над океанами, видишь?"
    elin "你就放心吧。传送门不会开在海洋上方的，瞧见没？"

# game/a7/6road_portals.rpy:102
translate english elin_roads2_be5b46cc:

    # me "А вдруг..."
    me "可是万一..."

# game/a7/6road_portals.rpy:103
translate english elin_roads2_e4d9a0b0:

    # elin "[mename]..."
    elin "[mename]..."

# game/a7/6road_portals.rpy:104
translate english elin_roads2_a7131285:

    # me "Ну ты ведь не знаешь наверняка."
    me "反正你又不确定。"

# game/a7/6road_portals.rpy:105
translate english elin_roads2_9c717882:

    # elin "Преториус говорит, что порталы открываются только в каких-то значимых местах."
    elin "Pretorius说，传送门只会开在一些有意义的地方。"

# game/a7/6road_portals.rpy:107
translate english elin_roads2_24688c00:

    # me "И чем значима эта пустыня?"
    me "那这片沙漠有什么意义？"

# game/a7/6road_portals.rpy:108
translate english elin_roads2_b147cdf7:

    # elin "Может здесь когда-нибудь была великая битва."
    elin "也许这里曾经发生过一场伟大的战役。"

# game/a7/6road_portals.rpy:109
translate english elin_roads2_f04131b0:

    # me "Великая битва между ветром и камнями максимум."
    me "顶多是风和石头之间的伟大战役。"

# game/a7/6road_portals.rpy:110
translate english elin_roads2_9bf9ef6d:

    # elin "Странное место, да?"
    elin "这地方有点怪，对吧？"

# game/a7/6road_portals.rpy:111
translate english elin_roads2_19af4b71:

    # me "Ага. Облака как-то слишком низко, не находишь?"
    me "嗯。你不觉得这些云有点太低了？"

# game/a7/6road_portals.rpy:112
translate english elin_roads2_8a4d9390:

    # elin "Наверное это какое-то нагорье."
    elin "可能这里是某个高地吧。"

# game/a7/6road_portals.rpy:113
translate english elin_roads2_47d364cc:

    # me "Хмм..."
    me "嗯..."

# game/a7/6road_portals.rpy:114
translate english elin_roads2_d45c1c84:

    # elin "Есть идеи?"
    elin "有什么想法？"

# game/a7/6road_portals.rpy:115
translate english elin_roads2_5a7a7577:

    # me "Нет."
    me "没有。"

# game/a7/6road_portals.rpy:119
translate english elin_roads2_5e280180:

    # me "Хотя...наверное это земли гоблинов."
    me "不过...这大概是地精的地盘。"

# game/a7/6road_portals.rpy:120
translate english elin_roads2_40042e03:

    # elin "Это за гномьим разломом?"
    elin "是在矮人裂谷那一带吗？"

# game/a7/6road_portals.rpy:121
translate english elin_roads2_b1a01001:

    # me "Это далеко на западе. Сюда можно попасть только через Море Восторга или..."
    me "是在很西边的地方。要去那里只能经过狂喜之海，或者..."

# game/a7/6road_portals.rpy:122
translate english elin_roads2_64c78a35:

    # elin "Или?"
    elin "或者？"

# game/a7/6road_portals.rpy:123
translate english elin_roads2_39ea68fd:

    # me "Или, если верить книге путешественника Бин Сада, наш континент соединяется далеко на севере с землями гоблинов."
    me "或者，如果旅行家宾萨德写的书可信的话，我们的大陆是在很北边的地方与地精的土地相连的。"

# game/a7/6road_portals.rpy:124
translate english elin_roads2_fece7e3a:

    # elin "Как интересно. Не знала, что ты такой начитанный."
    elin "真有意思。没想到你这么博学。"

# game/a7/6road_portals.rpy:125
translate english elin_roads2_ce225c84:

    # me "Спасибо. Это кстати запросто может оказаться каким-нибудь плато на Юге."
    me "谢谢。话说回来，这也有可能只是南边的某个高原。"

# game/a7/6road_portals.rpy:127
translate english elin_roads2_770fac2c:

    # elin "Может мы на Луне?"
    elin "说不定我们在月球上呢？"

# game/a7/6road_portals.rpy:128
translate english elin_roads2_67c5f2d1:

    # me "Чего?"
    me "什么？"

# game/a7/6road_portals.rpy:129
translate english elin_roads2_1921755b:

    # elin "Ну знаешь, это место похоже на гигантский сыр. А Луна похожа на гигантскую сырную головку."
    elin "你看，这地方看起来像一块巨大的奶酪。月亮看起来就像一个巨大的圆奶酪。"

# game/a7/6road_portals.rpy:130
translate english elin_roads2_4eed8a04:

    # me "Но ведь луна белая."
    me "但月亮是白的啊。"

# game/a7/6road_portals.rpy:131
translate english elin_roads2_d90c271a:

    # elin "Ну и сыр бывает белым."
    elin "那奶酪也有白的。"

# game/a7/6road_portals.rpy:132
translate english elin_roads2_4a606db1:

    # me "Да. Но здесь то земля желтая."
    me "是。但这儿的地面是黄的。"

# game/a7/6road_portals.rpy:133
translate english elin_roads2_f8286d2f:

    # elin "Не ломай мою стройную теорию. Дай чуть-чуть повоображать."
    elin "别拆穿我完美的理论嘛。让我稍微想象一下。"

# game/a7/6road_portals.rpy:134
translate english elin_roads2_93e7a0c5:

    # me "Здесь очень жарко."
    me "这里真热。"

# game/a7/6road_portals.rpy:135
translate english elin_roads2_2bee2293:

    # elin "И дышать нечем. Давай я открою еще один портал. Только сначала нужно вернуться назад."
    elin "还喘不过气来。我开个新的传送门吧。不过得先回去才行。"

# game/a7/6road_portals.rpy:136
translate english elin_roads2_7b37f276:

    # me "Упасть в ручей и дальше путешествовать мокрыми?"
    me "掉进溪水里，然后湿淋淋地继续旅行？"

# game/a7/6road_portals.rpy:137
translate english elin_roads2_f257f4ee:

    # elin "Да брось, там воды тебе едва по щиколотку будет."
    elin "拜托，那的水才到你脚踝深。"

# game/a7/6road_portals.rpy:139
translate english elin_roads2_01fcbb0e:

    # me "А тут глубокая ночь. Странно."
    me "可这里是深夜啊，奇怪。"

# game/a7/6road_portals.rpy:140
translate english elin_roads2_b0d8bc0a:

    # elin "Ничего странного. Порталы перемещают не только с севера на юг, но и запада на восток и обратно."
    elin "没什么奇怪的。传送门不仅能把你从北送到南，也能从西送到东，或者反过来。"

# game/a7/6road_portals.rpy:141
translate english elin_roads2_3820771a:

    # me "..."
    me "..."

# game/a7/6road_portals.rpy:142
translate english elin_roads2_69d127a1:

    # elin "Это значит, что там, где солнце встает..."
    elin "这就是说，太阳升起的地方..."

# game/a7/6road_portals.rpy:143
translate english elin_roads2_b6342473:

    # me "Можешь не объяснять принцип перемещения солнца с востока на запад. Я просто удивился что здесь...прямо глубокая ночь. Это место должно быть очень далеко от нас."
    me "你不用解释太阳从东向西移动的原理。我只是惊讶这里...已经是深夜了。这地方离我们一定非常遥远。"

# game/a7/6road_portals.rpy:144
translate english elin_roads2_9e5e2ad8:

    # elin "Наверно это земли Востока."
    elin "也许这里是东方之地吧。"

# game/a7/6road_portals.rpy:145
translate english elin_roads2_0e324e5d:

    # me "Ты думаешь?"
    me "你这么觉得？"

# game/a7/6road_portals.rpy:147
translate english elin_roads2_6656e36c:

    # elin "Да. Посмотри на эти изваяния. Я такого никогда не видела."
    elin "是的。看看这些雕像。我从来没见过这样的。"

# game/a7/6road_portals.rpy:148
translate english elin_roads2_a9448760:

    # me "Какой-то...дракон."
    me "某种...龙。"

# game/a7/6road_portals.rpy:149
translate english elin_roads2_963c2170:

    # elin "Корабли с востока часто приходят украшенные изображениями драконов."
    elin "来自东方的船只经常装饰着龙的形象。"

# game/a7/6road_portals.rpy:150
translate english elin_roads2_de70a7e2:

    # me "Это что-то вроде их бога?"
    me "这算是他们的神吗？"

# game/a7/6road_portals.rpy:151
translate english elin_roads2_51da9ead:

    # elin "Не знаю. Они же не пускают чужеземцев на свою землю под страхом смерти."
    elin "不知道。他们不允许外族人踏上他们的土地，违者处死。"

# game/a7/6road_portals.rpy:152
translate english elin_roads2_89a3f1da:

    # me "И как же они тогда с нами торгуют?"
    me "那他们怎么跟我们做生意的？"

# game/a7/6road_portals.rpy:153
translate english elin_roads2_7129d7a5:

    # elin "Когда наши торговцы приплывают к ним, они либо обмениваются товарам с корабля на корабль, либо дают высадиться в доки."
    elin "我们的商人到达时，他们要么在海面上直接从一艘船与另一艘船交换货物，要么就允许他们进入码头。"

# game/a7/6road_portals.rpy:154
translate english elin_roads2_eb294cf4:

    # me "А как же их запрет?"
    me "那他们的禁令呢？"

# game/a7/6road_portals.rpy:155
translate english elin_roads2_fc845019:

    # elin "Они ходят только по докам. Доки сделаны из дерева. А значит чужеземцы своими ногами на их землю не ступают."
    elin "他们只在码头上活动。码头是木头做的。这样一来，外族人就没用自己的脚踩上他们的土地。"

# game/a7/6road_portals.rpy:157
translate english elin_roads2_fde146b1:

    # me "Какой-то бред. По такой логике можно просто ходить по их земле, говоря что ты ее не касаешься, ведь твоя нога в обуви."
    me "什么歪理。照这个逻辑，完全可以走在他们土地上，声称你没有碰到土地，因为你脚下穿着鞋呢。"

# game/a7/6road_portals.rpy:158
translate english elin_roads2_520eb817:

    # elin "[mename], я, по-твоему, придумала эти культурные условности?"
    elin "[mename]，你觉得这些文化规矩是我编出来的吗？"

# game/a7/6road_portals.rpy:159
translate english elin_roads2_9a87fde2:

    # me "Не знаю. Ты?"
    me "不知道。是你编的吗？"

# game/a7/6road_portals.rpy:160
translate english elin_roads2_92d397c8:

    # elin "..."
    elin "..."

# game/a7/6road_portals.rpy:161
translate english elin_roads2_56623095:

    # me "Шучу. Посмотрим что-нибудь еще?"
    me "开玩笑的。再看看别的吧？"

# game/a7/6road_portals.rpy:162
translate english elin_roads2_bdfb4537:

    # elin "Да. Давай."
    elin "好。走吧。"

# game/a7/6road_portals.rpy:164
translate english elin_roads2_496082f5:

    # me "Огромные безжизненные скалы. Что-то они тоже не тянут на значимое место. Мне кажется теория Преториуса не состоятельна."
    me "巨大而毫无生机的岩石。这看起来也不算什么有意义的地方。我觉得Pretorius的理论站不住脚。"

# game/a7/6road_portals.rpy:165
translate english elin_roads2_ae98b3b9:

    # elin "Не спеши с выводами."
    elin "别急着下结论。"

# game/a7/6road_portals.rpy:166
translate english elin_roads2_69db60d9:

    # me "Да брось, посмотри вокруг. Тут не души. И никогда скорее всего и не было."
    me "拜托，看看周围。这里连个鬼影都没有。而且很可能从来就没有过。"

# game/a7/6road_portals.rpy:167
translate english elin_roads2_34a36010:

    # elin "Камни выглядят обточенными."
    elin "这些石头有被打磨过的痕迹。"

# game/a7/6road_portals.rpy:168
translate english elin_roads2_f95c9fc9:

    # me "И?"
    me "所以呢？"

# game/a7/6road_portals.rpy:169
translate english elin_roads2_a85c0e86:

    # elin "Значит что их кто-то обточил."
    elin "这说明有人打磨过它们。"

# game/a7/6road_portals.rpy:170
translate english elin_roads2_fb5579e6:

    # me "Дворфы обточили все свои горы и скалы. Они теперь все считаются 'значимыми местами'?"
    me "矮人把他们所有的山和岩石都打磨了一遍。那它们就都算是'有意义的地方'了吗？"

# game/a7/6road_portals.rpy:172
translate english elin_roads2_f5b71263:

    # elin "Может конкретно в этом месте легендарный герой сразил дракона, откуда нам знать."
    elin "说不定在这个特定地点，某位传奇英雄斩杀过一条龙，这我们哪知道。"

# game/a7/6road_portals.rpy:173
translate english elin_roads2_50987364:

    # me "Зная, как дворфы любят вспоминать свое былое величие, если бы здесь они сразили дракона, тут бы был их главный город."
    me "就矮人那喜欢追忆往日荣光的性子，要是他们真在这儿杀过龙，这儿早就变成他们的主城了。"

# game/a7/6road_portals.rpy:174
translate english elin_roads2_161721db:

    # elin "А вдруг здесь центр мира?"
    elin "万一这里是世界中心呢？"

# game/a7/6road_portals.rpy:175
translate english elin_roads2_c277e6dc:

    # me "В этой серой каменистой жопе?"
    me "在这灰石头的破旮旯里？"

# game/a7/6road_portals.rpy:176
translate english elin_roads2_83e18ac0:

    # elin "А что? Может центр мира это его задница."
    elin "怎么啦？没准世界的中心就是它的屁股呢。"

# game/a7/6road_portals.rpy:177
translate english elin_roads2_e7e55184:

    # me "Хахаха. Я конечно не в восторге от мира, но я все же не думаю, что в его центре именно жопа."
    me "哈哈哈。我当然对这个世界不怎么感冒，但也不觉得它的中心是个屁股。"

# game/a7/6road_portals.rpy:178
translate english elin_roads2_bd7bfed8:

    # elin "У меня еще есть силы на пару порталов. Пойдем."
    elin "我还有力气再开几个传送门。走吧。"

# game/a7/6road_portals.rpy:180
translate english elin_roads2_13c328f1:

    # me "Вот это вид!"
    me "这景色真壮观！"

# game/a7/6road_portals.rpy:181
translate english elin_roads2_5a4c7cb4:

    # elin "Потрясающе. Это больше тянет на центр мира?"
    elin "太棒了。这看起来更像世界中心了吗？"

# game/a7/6road_portals.rpy:182
translate english elin_roads2_f78f2c8c:

    # me "Это все те же безжизненные скалы только теперь со снегом."
    me "还是那些毫无生机的岩石，只是现在上面盖了雪。"

# game/a7/6road_portals.rpy:183
translate english elin_roads2_31eeaa48:

    # elin "Тебе не угодишь. Как, по-твоему, должен выглядеть центр мира?"
    elin "真难伺候你。那你觉得，世界中心该是什么样？"

# game/a7/6road_portals.rpy:184
translate english elin_roads2_f52860b5:

    # me "Как огромная вагина."
    me "像个巨大的阴道。"

# game/a7/6road_portals.rpy:185
translate english elin_roads2_6027beab:

    # elin "Чего? И ты еще смеялся над моей интерпретацией центра мира, как задницы?"
    elin "什么？你还笑话我把世界中心理解成屁股？"

# game/a7/6road_portals.rpy:186
translate english elin_roads2_90449b39:

    # me "Я просто чаще думаю о вагинах."
    me "我只是更常想到阴道罢了。"

# game/a7/6road_portals.rpy:188
translate english elin_roads2_957e0c24:

    # elin "Как же здесь холодно."
    elin "这儿可真冷啊。"

# game/a7/6road_portals.rpy:189
translate english elin_roads2_500c7123:

    # me "Дворфские горы?"
    me "是矮人的群山吗？"

# game/a7/6road_portals.rpy:190
translate english elin_roads2_a058f129:

    # elin "Там так холодно не было."
    elin "那里也没这么冷过。"

# game/a7/6road_portals.rpy:191
translate english elin_roads2_8a5a6ce7:

    # me "Может это очень далекие дворфские горы?"
    me "也许这是很偏远地方的矮人山？"

# game/a7/6road_portals.rpy:192
translate english elin_roads2_b0abfb49:

    # elin "Знаешь, когда мне холодно, у меня больше всего мерзнут ноги. Так что это наверное пятка мира или что-то вроде того."
    elin "你知道吗，我冷的时候，最冻的是脚。所以，这大概是世界的脚后跟或者类似的地方。"

# game/a7/6road_portals.rpy:193
translate english elin_roads2_12c08123:

    # me "Или нос. Нос тоже быстро мерзнет."
    me "或者是鼻子。鼻子也冻得快。"

# game/a7/6road_portals.rpy:194
translate english elin_roads2_203aaa91:

    # elin "У меня сейчас мой нос отмерзнет. Пойдем быстрее обратно."
    elin "我的鼻子现在快冻掉了。快点回去吧。"

# game/a7/6road_portals.rpy:195
translate english elin_roads2_f0f4cb13:

    # me "Только хотел предложить."
    me "我刚想提呢。"

# game/a7/6road_portals.rpy:197
translate english elin_roads2_3b1b503b:

    # elin "Ооо! Ну это выглядит пока лучше всего, по сравнению с тем, где мы сегодня были."
    elin "哦哦！嗯，比起我们今天去过的地方，这儿看起来总算好点了。"

# game/a7/6road_portals.rpy:198
translate english elin_roads2_0ab6336c:

    # me "Новый центр мира найден?"
    me "找到新的世界中心了？"

# game/a7/6road_portals.rpy:199
translate english elin_roads2_a1b150e9:

    # elin "Пока не знаю. Но здесь хотя бы тепло."
    elin "还不知道。但至少这里暖和。"

# game/a7/6road_portals.rpy:200
translate english elin_roads2_f1e98f31:

    # me "Растительность здесь буйная и необычная. Я такую в наших землях никогда не видел."
    me "这里的植被茂盛又奇特。我在我们土地上从没见过这样的。"

# game/a7/6road_portals.rpy:201
translate english elin_roads2_126df7c7:

    # elin "Наверное это Юг."
    elin "这儿大概是南方吧。"

# game/a7/6road_portals.rpy:202
translate english elin_roads2_5f9abfe2:

    # me "Уверена?"
    me "你确定吗？"

# game/a7/6road_portals.rpy:203
translate english elin_roads2_b0095000:

    # elin "А что? Ты думаешь Юг это одна большая пустыня?"
    elin "怎么啦？你以为南方就是一片大沙漠吗？"

# game/a7/6road_portals.rpy:204
translate english elin_roads2_6cbdec21:

    # me "Именно так я думаю."
    me "我还真是那么想的。"

# game/a7/6road_portals.rpy:206
translate english elin_roads2_0215ef5f:

    # elin "Странно. Когда я перемещалась в порталы одна, я всегда попадала в более...людные места."
    elin "奇怪。我一个人穿越传送门时，总是会到些更...有人气的地方。"

# game/a7/6road_portals.rpy:207
translate english elin_roads2_9f2b1c51:

    # me "Тебе помочь?"
    me "需要帮忙吗？"

# game/a7/6road_portals.rpy:208
translate english elin_roads2_3a70d57b:

    # elin "Я справлюсь."
    elin "我能行。"

# game/a7/6road_portals.rpy:209
translate english elin_roads2_01047852:

    # me "Может я как-то влияю на то, куда приведет портал?"
    me "会不会我以某种方式影响了传送门的目的地？"

# game/a7/6road_portals.rpy:210
translate english elin_roads2_5c4cd2f6:

    # elin "Думаешь портал как знает, что мы будем вместе и нарочно посылает нас в места без людей, чтобы ты меня не позорил?"
    elin "你觉得传送门知道我们会在一起，所以就故意送我们去没人的地方，好让我不会给你丢脸？"

# game/a7/6road_portals.rpy:211
translate english elin_roads2_95efcfe1:

    # me "Эй!"
    me "嘿！"

# game/a7/6road_portals.rpy:212
translate english elin_roads2_41904670:

    # elin "Шутка."
    elin "开玩笑啦。"

# game/a7/6road_portals.rpy:214
translate english elin_roads2_238e4dbf:

    # me "Может портал просто хочет, чтобы мы остались наедине?"
    me "也许传送门就是想让我们俩单独相处呢？"

# game/a7/6road_portals.rpy:215
translate english elin_roads2_9b70ec67:

    # elin "Это еще зачем?"
    elin "这又是为什么？"

# game/a7/6road_portals.rpy:216
translate english elin_roads2_6b9b00dc:

    # me "Ну...я думаю ты понимаешь..."
    me "嗯...我想你明白..."

# game/a7/6road_portals.rpy:217
translate english elin_roads2_fed37216:

    # elin "У тебя вечно одни пошлости на уме."
    elin "你脑子里永远都是那些下流念头。"

# game/a7/6road_portals.rpy:218
translate english elin_roads2_4bb25076:

    # me "Я не говорил, что имею в виду. Так что одни пошлости на уме у тебя.."
    me "我可没说我在暗示什么。所以脑子里都是下流念头的是你。"

# game/a7/6road_portals.rpy:220
translate english elin_roads2_6e76604e:

    # elin "Ух ты. Какая красивая вода."
    elin "哇哦。水真好看。"

# game/a7/6road_portals.rpy:221
translate english elin_roads2_a20ce0f7:

    # me "Мутная какая-то."
    me "有点浑浊啊。"

# game/a7/6road_portals.rpy:222
translate english elin_roads2_7d156c0b:

    # elin "Зато наверняка теплая."
    elin "但肯定很温暖。"

# game/a7/6road_portals.rpy:223
translate english elin_roads2_f0fc232d:

    # me "И потенциально опасная."
    me "而且可能有危险。"

# game/a7/6road_portals.rpy:224
translate english elin_roads2_26dece26:

    # elin "Снизу какие-то огоньки. Там подводная пещера."
    elin "下面有些光点。那儿有条水下洞穴。"

# game/a7/6road_portals.rpy:225
translate english elin_roads2_a4c19cdf:

    # me "[mename]..."
    me "[mename]..."

# game/a7/6road_portals.rpy:226
translate english elin_roads2_2d198f8e:

    # elin "Что? Я устала открывать новые порталы. Хочу искупаться."
    elin "什么？我累了，不想再开新的传送门了。我想游泳。"

# game/a7/6road_portals.rpy:227
translate english elin_roads2_3e3f5393:

    # me "Ты же вчера купалась."
    me "你昨天不是游过了吗。"

# game/a7/6road_portals.rpy:228
translate english elin_roads2_944f47bc:

    # elin "Я купалась в холодной реке."
    elin "我昨天在冰冷的河里游的。"

# game/a7/6road_portals.rpy:229
translate english elin_roads2_f5731779:

    # me "Не надо..."
    me "别..."

# game/a7/6road_portals.rpy:230
translate english elin_roads2_2044347e:

    # elin "Но я хочу искупаться!"
    elin "可我想游泳！"

# game/a7/6road_portals.rpy:235
translate english elin_roads2_7b6835a4:

    # me "Лучше этого не делать."
    me "最好别这么做。"

# game/a7/6road_portals.rpy:236
translate english elin_roads2_cb49922a:

    # elin "Какой ты скучный!"
    elin "你真没意思！"

# game/a7/6road_portals.rpy:240
translate english elin_roads3_17a374b9:

    # me "Слушай, это ведь правда может быть опасным. Мы даже не знаем где мы."
    me "听着，这真的有危险。我们甚至都不知道我们在哪。"

# game/a7/6road_portals.rpy:241
translate english elin_roads3_58e3e195:

    # elin "И что?"
    elin "那又怎样？"

# game/a7/6road_portals.rpy:242
translate english elin_roads3_672080c6:

    # me "Может здесь водятся какие-нибудь водные змеи?"
    me "万一这里有什么水蛇呢？"

# game/a7/6road_portals.rpy:243
translate english elin_roads3_4dc136b1:

    # elin "Что за чушь."
    elin "胡说八道什么。"

# game/a7/6road_portals.rpy:244
translate english elin_roads3_82c81b72:

    # me "[elin], ты зачем...."
    me "[elin]，你干嘛..."

# game/a7/6road_portals.rpy:246
translate english elin_roads3_83d9b617:

    # me "...раздеваешься."
    me "...脱衣服。"

# game/a7/6road_portals.rpy:247
translate english elin_roads3_7fe01c19:

    # elin "Давай со мной."
    elin "跟我一起来。"

# game/a7/6road_portals.rpy:248
translate english elin_roads3_5a7a7577:

    # me "Нет."
    me "不要。"

# game/a7/6road_portals.rpy:249
translate english elin_roads3_b0df920f:

    # elin "Ну давааааай."
    elin "来嘛。"

# game/a7/6road_portals.rpy:250
translate english elin_roads3_26561f4f:

    # me "Эх..."
    me "唉..."

# game/a7/6road_portals.rpy:252
translate english elin_roads3_b0dec6ca:

    # elin "Здесь у берега неглубоко."
    elin "岸边水不深。"

# game/a7/6road_portals.rpy:253
translate english elin_roads3_aaf3c2c3:

    # me "Ты же сказала тут подводная пещера."
    me "你不是说这下面有水下洞穴吗。"

# game/a7/6road_portals.rpy:254
translate english elin_roads3_f62f589a:

    # elin "Она дальше. Водичка очень теплая. Как в ванне."
    elin "那在更远的地方。水非常暖和。就像在浴盆里一样。"

# game/a7/6road_portals.rpy:255
translate english elin_roads3_34d5fb3d:

    # me "Я бы мог попросить сделать подогреть тебе воду для обычной ванны."
    me "我本可以让他们给你烧洗澡水的。"

# game/a7/6road_portals.rpy:256
translate english elin_roads3_344f81ce:

    # elin "Да что ты такой скучный? Залазь ко мне."
    elin "你怎么这么没意思？下来找我。"

# game/a7/6road_portals.rpy:257
translate english elin_roads3_3820771a:

    # me "..."
    me "..."

# game/a7/6road_portals.rpy:258
translate english elin_roads3_e56ed443:

    # elin "Давай. Не сиди там один."
    elin "来啊。别一个人坐在那儿。"

# game/a7/6road_portals.rpy:260
translate english elin_roads3_19a940de:

    # me "Вода и вправду теплая."
    me "水确实很暖。"

# game/a7/6road_portals.rpy:261
translate english elin_roads3_30c7ada5:

    # elin "Я же говорила."
    elin "我就说吧。"

# game/a7/6road_portals.rpy:262
translate english elin_roads3_0d614913:

    # me "Только я ногой чувствую что-то?"
    me "只是我脚好像碰到了什么东西？"

# game/a7/6road_portals.rpy:263
translate english elin_roads3_0454fd3b:

    # elin "Ага, конечно..."
    elin "嗯，当然了..."

# game/a7/6road_portals.rpy:264
translate english elin_roads3_42bbafc6:

    # me "Мне кажется это змея..."
    me "我感觉那是条蛇..."

# game/a7/6road_portals.rpy:265
translate english elin_roads3_28e63a68:

    # elin "[mename], не выдумывай."
    elin "[mename]，别瞎编了。"

# game/a7/6road_portals.rpy:266
translate english elin_roads3_3ce57a52:

    # me "Я серьезно...она злая! Чувствую что сейчас укусит!"
    me "我是认真的...它很凶！我感觉它马上就要咬了！"

# game/a7/6road_portals.rpy:267
translate english elin_roads3_ddd8c586:

    # elin "Я тебе не поверю не в жизнь."
    elin "我怎么都不会信你的。"

# game/a7/6road_portals.rpy:268
translate english elin_roads3_0ca1f499:

    # me "Надо как-то защититься от змеи."
    me "得想个办法防止蛇咬。"

# game/a7/6road_portals.rpy:270
translate english elin_roads3_fd5b7113:

    # me "Давай я закрою твою самую уязвимую часть тела."
    me "我来保护你身上最脆弱的部分吧。"

# game/a7/6road_portals.rpy:271
translate english elin_roads3_2662bef5:

    # elin "[mename], мы тут только вдвоем. Если хотел меня потрогать, мог бы просто спросить. Не обязательно придумывать эту дурацкую змею."
    elin "[mename]，这里就我们俩。你要是想摸我，直接问不就行了。没必要编出这蠢蛇的故事来。"

# game/a7/6road_portals.rpy:272
translate english elin_roads3_b7907980:

    # me "Я ничего не придумываю."
    me "我什么都没编。"

# game/a7/6road_portals.rpy:273
translate english elin_roads3_1649d076:

    # elin "Ага."
    elin "嗯哼。"

# game/a7/6road_portals.rpy:274
translate english elin_roads3_5056004d:

    # me "Водная змея-убийца настоящая. Она убивает всего одним укусом."
    me "夺命水蛇是真的。被它咬一口就死。"

# game/a7/6road_portals.rpy:275
translate english elin_roads3_d03e0584:

    # elin "Единственная змея в этом озере прямо сейчас упирается мне в задницу."
    elin "这湖里唯一的一条蛇，现在正顶着我的屁股呢。"

# game/a7/6road_portals.rpy:276
translate english elin_roads3_94fd78e4:

    # me "О боги, она на тебя нападает?"
    me "哦天哪，它要攻击你了吗？"

# game/a7/6road_portals.rpy:277
translate english elin_roads3_ffd26074:

    # elin "Нападет, если я не от нее не сбегу."
    elin "我要是逃不掉的话，它就会攻击。"

# game/a7/6road_portals.rpy:278
translate english elin_roads3_336b028a:

    # me "Он водной змеи-убийцы не..."
    me "夺命水蛇可没法..."

# game/a7/6road_portals.rpy:280
translate english elin_roads3_76b5253f:

    # me "...сбежать."
    me "...逃掉。"

# game/a7/6road_portals.rpy:281
translate english elin_roads3_0529a0cd:

    # me "{i}Она просто нырнула под воду?{/i}"
    me "{i}她就这么潜到水下去了？{/i}"

# game/a7/6road_portals.rpy:282
translate english elin_roads3_d4f1167a:

    # me "{i}И...что мне теперь делать?{/i}"
    me "{i}那...我现在该怎么办？{/i}"

# game/a7/6road_portals.rpy:283
translate english elin_roads3_c4f24eac:

    # me "{i}Только не плыви в пещеру, [elin].{/i}"
    me "{i}千万别游进洞穴，[elin]。{/i}"

# game/a7/6road_portals.rpy:285
translate english elin_roads3_0d8f116c:

    # me "{i}Ну естественно. Куда же еще ты можешь поплыть.{/i}"
    me "{i}果然。你还能游去哪儿。{/i}"

# game/a7/6road_portals.rpy:286
translate english elin_roads3_f5328a8a:

    # me "{i}Ну...мне ничего не остается, кроме как дождаться ее здесь.{/i}"
    me "{i}嗯...我除了在这儿等她，没别的办法了。{/i}"

# game/a7/6road_portals.rpy:287
translate english elin_roads3_f7a7578a:

    # me "{i}Просто...немного подождать....пока у нее кончится воздух....и она поплывет обратно...{/i}"
    me "{i}就...稍微等一会儿....等她没气了....她就会游回来了...{/i}"

# game/a7/6road_portals.rpy:288
translate english elin_roads3_5c76dbe7:

    # me "{i}...{/i}"
    me "{i}...{/i}"

# game/a7/6road_portals.rpy:289
translate english elin_roads3_9c7817e9:

    # me "{i}Ай, кого я обманываю?{/i}"
    me "{i}唉，我在骗谁呢？{/i}"

# game/a7/6road_portals.rpy:292
translate english elin_roads3_b14e6ee1:

    # me "{i}Вечно ты стремишься умереть.{/i}"
    me "{i}你总是这么找死。{/i}"

# game/a7/6road_portals.rpy:293
translate english elin_roads3_053a862d:

    # elin "{i}Ты дурак? Здесь не опасно!{/i}"
    elin "{i}你傻吗？这里一点也不危险！{/i}"

# game/a7/6road_portals.rpy:294
translate english elin_roads3_f7601cd7:

    # me "{i}Секунду, ты как это сказала?{/i}"
    me "{i}等等，你是怎么说出这句话的？{/i}"

# game/a7/6road_portals.rpy:295
translate english elin_roads3_8a901201:

    # elin "{i}Что сказала? Как это...стоп, что? Ты читаешь мои мысли?{/i}"
    elin "{i}我说了什么？怎么这样...等等，什么？你能读取我的想法？{/i}"

# game/a7/6road_portals.rpy:296
translate english elin_roads3_968c42dd:

    # me "{i}Похоже не то. Это твоя магия?{/i}"
    me "{i}看来是这样。这是你的魔法吗？{/i}"

# game/a7/6road_portals.rpy:297
translate english elin_roads3_9aac2ac7:

    # elin "{i}Я ничего не делала.{/i}"
    elin "{i}我什么都没做。{/i}"

# game/a7/6road_portals.rpy:298
translate english elin_roads3_b2edee3d:

    # me "{i}Но почему мы тогда...{/i}"
    me "{i}那我们为什么会...{/i}"

# game/a7/6road_portals.rpy:299
translate english elin_roads3_626d673e:

    # elin "{i}Может быть это из-за того, что мы вместе прошли через портал? Порталами обычно пользуются в одиночку, парное прохождение может вызвать некоторые аномалии.{/i}"
    elin "{i}也许是因为我们一起穿过了传送门？传送门通常是单独使用的，两个人一起通过可能会引发一些异常情况。{/i}"

# game/a7/6road_portals.rpy:300
translate english elin_roads3_304adf4a:

    # me "{i}Например чтение мыслей?{/i}"
    me "{i}比如读心术？{/i}"

# game/a7/6road_portals.rpy:301
translate english elin_roads3_95936355:

    # elin "{i}Я о таком не слышала...но всякие может быть. Надо будет спросить у Преториуса или леди Алейны.{/i}"
    elin "{i}我没听说过...不过什么事都有可能。得去问问Pretorius或者Alaina女士。{/i}"

# game/a7/6road_portals.rpy:302
translate english elin_roads3_10d36b2f:

    # elin "{i}Странно, мы начали слышать друг друга именно когда это нам понадобилось. Мы ведь и раньше проходили сквозь портал, но я твоих мыслей не слышал.{/i}"
    elin "{i}奇怪，我们是在正好需要的时候才开始能听到对方想法的。我们之前也一起穿过传送门，但那会儿我没听到过你的想法。{/i}"

# game/a7/6road_portals.rpy:303
translate english elin_roads3_3acde843:

    # me "{i}Ага. Ну что, поплыли обратно?{/i}"
    me "{i}嗯。那我们游回去？{/i}"

# game/a7/6road_portals.rpy:305
translate english elin_roads3_db138198:

    # elin "{i}Погоди, видишь?{/i}"
    elin "{i}等等，你看到了吗？{/i}"

# game/a7/6road_portals.rpy:306
translate english elin_roads3_a682de70:

    # me "{i}Что там? Кораллы?{/i}"
    me "{i}那是什么？珊瑚吗？{/i}"

# game/a7/6road_portals.rpy:307
translate english elin_roads3_95be84fb:

    # elin "{i}Посмотри как красиво! Они светятся. И рыбки рядом. Здесь все светится.{/i}"
    elin "{i}你看多漂亮啊！它们在发光。旁边还有小鱼。这里面的一切都在发光。{/i}"

# game/a7/6road_portals.rpy:308
translate english elin_roads3_f7f07989:

    # me "{i}Ага. Супер.{/i}"
    me "{i}嗯。真棒。{/i}"

# game/a7/6road_portals.rpy:309
translate english elin_roads3_afd755c2:

    # elin "{i}Ты какой-то странный. Неужели у тебя не перехватывает дух от этого зрелища?{/i}"
    elin "{i}你有点怪。这景象难道不让你激动得喘不过气吗？{/i}"

# game/a7/6road_portals.rpy:310
translate english elin_roads3_4caeea7a:

    # me "{i}Мне нравятся более сложные в своей красоте конструкции.{/i}"
    me "{i}我更喜欢构造复杂些的美景。{/i}"

# game/a7/6road_portals.rpy:311
translate english elin_roads3_7bb1f138:

    # elin "{i}Например?{/i}"
    elin "{i}比如？{/i}"

# game/a7/6road_portals.rpy:313
translate english elin_roads3_7787456d:

    # me "{i}Например ты.{/i}"
    me "{i}比如你。{/i}"

# game/a7/6road_portals.rpy:314
translate english elin_roads3_b3b2c1f4:

    # elin "{i}[mename]...{/i}"
    elin "{i}[mename]...{/i}"

# game/a7/6road_portals.rpy:315
translate english elin_roads3_4b41a89c:

    # me "{i}Что? Ты сама спросила.{/i}"
    me "{i}什么？这可是你自己问的。{/i}"

# game/a7/6road_portals.rpy:316
translate english elin_roads3_53e805f4:

    # elin "{i}...{/i}"
    elin "{i}...{/i}"

# game/a7/6road_portals.rpy:317
translate english elin_roads3_34ea1dfe:

    # me "{i}Хочешь я тебя поцелую?{/i}"
    me "{i}要我吻你吗？{/i}"

# game/a7/6road_portals.rpy:318
translate english elin_roads3_5da42960:

    # elin "{i}Под водой?{/i}"
    elin "{i}在水下？{/i}"

# game/a7/6road_portals.rpy:320
translate english elin_roads3_fe32a2ff:

    # me "{i}Да!{/i}"
    me "{i}对！{/i}"

# game/a7/6road_portals.rpy:321
translate english elin_roads3_53e805f4_1:

    # elin "{i}...{/i}"
    elin "{i}...{/i}"

# game/a7/6road_portals.rpy:322
translate english elin_roads3_5c76dbe7_1:

    # me "{i}...{/i}"
    me "{i}...{/i}"

# game/a7/6road_portals.rpy:323
translate english elin_roads3_8db4c28a:

    # elin "{i}Я его так люблю... Я бы ради него умерла...{/i}"
    elin "{i}我真爱他...我愿意为他而死...{/i}"

# game/a7/6road_portals.rpy:324
translate english elin_roads3_7dcf2b56:

    # me "{i}М? Ты бы ради меня умерла? Правда?{/i}"
    me "{i}嗯？你愿意为我而死？真的吗？{/i}"

# game/a7/6road_portals.rpy:325
translate english elin_roads3_72ddd367:

    # elin "{i}Ой! Хватит подслушивать мои мысли!{/i}"
    elin "{i}哎呀！别偷听我的想法！{/i}"

# game/a7/6road_portals.rpy:326
translate english elin_roads3_638c1df1:

    # me "{i}Я не специально. А еще у меня сейчас встанет член.{/i}"
    me "{i}我不是故意的。还有，我现在要勃起了。{/i}"

# game/a7/6road_portals.rpy:327
translate english elin_roads3_e1381cf8:

    # elin "{i}Ну...по крайней мере я твои секретные мысли тоже слышу.{/i}"
    elin "{i}唔...至少你的秘密想法我也听见了。{/i}"

# game/a7/6road_portals.rpy:328
translate english elin_roads3_f9ca7328:

    # me "{i}А это и не секретные мысли...{/i}"
    me "{i}这可不是什么秘密想法...{/i}"

# game/a7/6road_portals.rpy:329
translate english elin_roads3_7e4c9526:

    # elin "{i}Дурак...{/i}"
    elin "{i}傻瓜...{/i}"

# game/a7/6road_portals.rpy:331
translate english elin_roads3_f5cf794b:

    # me "Фух. Не привык я настолько долго задерживать дыхание."
    me "呼。我不太习惯屏住呼吸这么久。"

# game/a7/6road_portals.rpy:332
translate english elin_roads3_3820771a_1:

    # me "..."
    me "..."

# game/a7/6road_portals.rpy:333
translate english elin_roads3_30d14d64:

    # me "[elin]?"
    me "[elin]?"

# game/a7/6road_portals.rpy:334
translate english elin_roads3_2fd884af:

    # me "{size=+12}[elin]!{/size}"
    me "{size=+12}[elin]!{/size}"

# game/a7/6road_portals.rpy:335
translate english elin_roads3_93036751:

    # me "{i}{size=+12}[elin]!{/size}{/i}"
    me "{i}{size=+12}[elin]!{/size}{/i}"

