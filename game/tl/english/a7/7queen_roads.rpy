    me "{i}[elin]？你听得见我说话吗？{/i}"

# game/a7/7queen_roads.rpy:6
translate english queen_roads_8799dc8e:

    # me "{i}[elin]?{/i}"
    me "{i}[elin]?{/i}"

# game/a7/7queen_roads.rpy:7
translate english queen_roads_67b8803b:

    # me "{i}Нет. Похоже эта ментальная существует только из-за порталов.{/i}"
    me "{i}听不见。看来这种精神连接只在传送门附近才存在。{/i}"

# game/a7/7queen_roads.rpy:9
translate english queen_roads_a45864fa:

    # me "{i}Обоз должен быть тут.{/i}"
    me "{i}车队应该在这里。{/i}"

# game/a7/7queen_roads.rpy:10
translate english queen_roads_38b8c1a8:

    # me "{i}Нужно с кем-нибудь повидаться.{/i}"
    me "{i}得去见个人。{/i}"

# game/a7/7queen_roads.rpy:11
translate english queen_roads_9b515998:

    # me "{i}Например с достпочтенной королевой...{/i}"
    me "{i}比如，去见那位尊贵的女王……{/i}"

# game/a7/7queen_roads.rpy:12
translate english queen_roads_6caddbe0:

    # me "{i}Как раз вижу ее карету.{/i}"
    me "{i}正好看见她的马车。{/i}"

# game/a7/7queen_roads.rpy:14
translate english queen_roads_65b071bf:

    # me "{i}Но она кажется не здесь.{/i}"
    me "{i}但她好像不在里面。{/i}"

# game/a7/7queen_roads.rpy:15
translate english queen_roads_0ea598cd:

    # me "{i}Может быть отдыхает?{/i}"
    me "{i}也许在休息？{/i}"

# game/a7/7queen_roads.rpy:16
translate english queen_roads_d67e9608:

    # me "{i}Ладно, зачем гадать, просто спрошу.{/i}"
    me "{i}算了，何必猜，直接去问问。{/i}"

# game/a7/7queen_roads.rpy:18
translate english queen_roads_4ad80168:

    # knight "Мой принц."
    knight "王子殿下。"

# game/a7/7queen_roads.rpy:19
translate english queen_roads_c0007d42:

    # me "Королева в карете?"
    me "女王在马车里吗？"

# game/a7/7queen_roads.rpy:20
translate english queen_roads_13104dc1:

    # knight "Королева в лесу."
    knight "女王在森林里。"

# game/a7/7queen_roads.rpy:21
translate english queen_roads_28f3302b:

    # me "В лесу? Что она там делает?"
    me "森林里？她在那边做什么？"

# game/a7/7queen_roads.rpy:22
translate english queen_roads_6ff0cdc7:

    # knight "Не знаю, мой принц. Она взяла с собой слугу, а мне велела здесь остаться."
    knight "不知道，王子殿下。她带了个仆人过去，吩咐我留在这里。"

# game/a7/7queen_roads.rpy:23
translate english queen_roads_78f3ec8b:

    # me "Ты оставил мою мать без охраны?"
    me "你就这样让我母亲无人保护？"

# game/a7/7queen_roads.rpy:24
translate english queen_roads_9d53d992:

    # knight "Это был ее прямой приказ. Я не мог..."
    knight "这是她的直接命令。我没办法……"

# game/a7/7queen_roads.rpy:25
translate english queen_roads_cd45f1e1:

    # me "Ладно, расслабься. Куда она пошла?"
    me "行了，放松点。她往哪边去了？"

# game/a7/7queen_roads.rpy:26
translate english queen_roads_c7feaf53:

    # knight "В ту сторону, мой принц."
    knight "那边，王子殿下。"

# game/a7/7queen_roads.rpy:28
translate english queen_roads_530a5888:

    # me "{i}Действительно в лесу. Ну хоть недалеко ушли.{/i}"
    me "{i}果然在森林里。不过幸好走得不算远。{/i}"

# game/a7/7queen_roads.rpy:29
translate english queen_roads_5c76dbe7:

    # me "{i}...{/i}"
    me "{i}...{/i}"

# game/a7/7queen_roads.rpy:30
translate english queen_roads_fd308587:

    # me "{i}Что они там делают?{/i}"
    me "{i}她们在那边干什么？{/i}"

# game/a7/7queen_roads.rpy:31
translate english queen_roads_e7138bf1:

    # me "{i}Рассматривают землю?{/i}"
    me "{i}在查看地面？{/i}"

# game/a7/7queen_roads.rpy:32
translate english queen_roads_b1652d22:

    # me "{i}Надо пойти и узнать.{/i}"
    me "{i}得走过去看看。{/i}"

# game/a7/7queen_roads.rpy:34
translate english queen_roads_8b66e32f:

    # mom "[mename]! Я думала ты спишь."
    mom "[mename]！我以为你还在睡。"

# game/a7/7queen_roads.rpy:35
translate english queen_roads_031b51bb:

    # slug "Мой принц."
    slug "王子殿下。"

# game/a7/7queen_roads.rpy:36
translate english queen_roads_f06dc48b:

    # me "Я уже несколько часов как проснулся. Мы проводили время вместе с [elin], а сейчас я решил тебя проведать, раз уж обоз нас догнал."
    me "我醒了好几个钟头了。刚才和[elin]在一起，现在既然车队赶上了，我就想着来看看你。"

# game/a7/7queen_roads.rpy:37
translate english queen_roads_80b7bdca:

    # mom "А я тут грибы собираю."
    mom "我在采蘑菇呢。"

# game/a7/7queen_roads.rpy:38
translate english queen_roads_4048049a:

    # me "Я заметил. Смотрю ты уже много насобирала."
    me "我看出来了。你好像已经采了不少。"

# game/a7/7queen_roads.rpy:39
translate english queen_roads_96a15950:

    # mom "Это только с этой опушки! Ночью прошел дождь - значит к утру покажутся грибы."
    mom "这才刚在这片林边采的！夜里下了雨，到早上蘑菇就冒出来了。"

# game/a7/7queen_roads.rpy:40
translate english queen_roads_3709dfbc:

    # me "Я...я не разбираюсь в этих тонкостях природы."
    me "我……我不太懂这些大自然里的门道。"

# game/a7/7queen_roads.rpy:41
translate english queen_roads_60ffcf5e:

    # mom "А я выросла в этих местах. Собирала грибы и ягоды с самого детства."
    mom "我是在这一带长大的。从小就采蘑菇和浆果。"

# game/a7/7queen_roads.rpy:42
translate english queen_roads_c1dad572:

    # me "Точно. Я и забыл, что ты из эльфов долины."
    me "没错。我都忘了你是山谷那边的精灵出身。"

# game/a7/7queen_roads.rpy:43
translate english queen_roads_41cc3c2f:

    # mom "Ты наполовину тоже."
    mom "你也有一半血脉。"

# game/a7/7queen_roads.rpy:44
translate english queen_roads_212a5e8c:

    # me "А почему ты без охраны?"
    me "你怎么不带护卫？"

# game/a7/7queen_roads.rpy:45
translate english queen_roads_63932c05:

    # mom "Все рыцари ходят в тяжелых ботинках с железными пластинами."
    mom "那些骑士都穿着镶铁片的厚靴子。"

# game/a7/7queen_roads.rpy:46
translate english queen_roads_00a22f74:

    # me "Мы вроде ни от кого не скрываемя, следы оставлять можно."
    me "我们又没要躲着谁，留点脚印也无所谓。"

# game/a7/7queen_roads.rpy:47
translate english queen_roads_b05dda31:

    # mom "Следы оставляют и босые ноги. Я оставила Касселя у кареты не поэтому."
    mom "光着脚也会留下脚印。我把卡塞尔留在马车旁边，不是因为这个。"

# game/a7/7queen_roads.rpy:48
translate english queen_roads_977aad9c:

    # me "А почему?"
    me "那是为什么？"

# game/a7/7queen_roads.rpy:49
translate english queen_roads_41ee28ab:

    # mom "Это эльфийские леса. Наше последнее пристанище благославленное Миртой. Сюда не стоит ступать человеку с оружием и гневить духов."
    mom "这里是精灵森林。是Mirta赐福给我们的最后庇护所。不该带着武器的人踏足这里，免得触怒精灵。"

# game/a7/7queen_roads.rpy:50
translate english queen_roads_2febb077:

    # me "А...суеверия."
    me "啊……迷信那一套。"

# game/a7/7queen_roads.rpy:51
translate english queen_roads_0506630a:

    # mom "Скорее традиции. Ты можешь нас оставить, Люси."
    mom "更该说是传统。你可以退下了，露西。"

# game/a7/7queen_roads.rpy:52
translate english queen_roads_b69a5463:

    # slug "Да, моя королева."
    slug "是，女王陛下。"

# game/a7/7queen_roads.rpy:54
translate english queen_roads_2605dbf7:

    # me "Ты правда в это веришь?"
    me "你真的信这些？"

# game/a7/7queen_roads.rpy:55
translate english queen_roads_2b8877d5:

    # mom "В духов? Конечно."
    mom "精灵吗？当然信。"

# game/a7/7queen_roads.rpy:56
translate english queen_roads_1917d652:

    # me "И что бы они сделали, если бы разгневались?"
    me "要是他们发怒了，会怎么样？"

# game/a7/7queen_roads.rpy:57
translate english queen_roads_bfa22ffe:

    # mom "Что угодно. От смертельной болезни до плохого улова грибов."
    mom "什么事都有可能。从致命的疾病到采不到蘑菇。"

# game/a7/7queen_roads.rpy:58
translate english queen_roads_f9dd74cb:

    # me "И чьи это духи? Деревьев?"
    me "那是谁的精灵？树的？"

# game/a7/7queen_roads.rpy:59
translate english queen_roads_985144ad:

    # mom "Наших предков, [mename]. Однажды я... Ладно. Забудь."
    mom "我们祖先的，[mename]。有一次我……算了。忘了吧。"

# game/a7/7queen_roads.rpy:60
translate english queen_roads_ffb80ecc:

    # me "Нет, мам, договори, что начала."
    me "不，妈妈，把刚才的话说完。"

# game/a7/7queen_roads.rpy:61
translate english queen_roads_e81630f0:

    # mom "Однажды я познакомлю тебя с твоей семьей по моей линии. Но не сейчас."
    mom "终有一天，我会带你认识我这一边的家人。但不是现在。"

# game/a7/7queen_roads.rpy:62
translate english queen_roads_4ecd8073:

    # me "Почему не сейчас?"
    me "为什么不是现在？"

# game/a7/7queen_roads.rpy:63
translate english queen_roads_64468c3d:

    # mom "Потому что я смогу это сделать, только когда они этого захотят. А сейчас они боюсь тебе не доверяют."
    mom "因为只有当他们愿意时，我才能那样做。而现在，他们恐怕还信不过你。"

# game/a7/7queen_roads.rpy:64
translate english queen_roads_ecd5e310:

    # me "Что я им сделал?"
    me "我对他们做过什么？"

# game/a7/7queen_roads.rpy:65
translate english queen_roads_0582edb3:

    # mom "Вот именно, что пока ничего. Они возлагают на тебя большие надежды, [mename]. Я уверенна, что подари ты эльфам хотя бы немного больше прав - они захотят тебя увидеть."
    mom "问题就是你还没做过什么。他们对你有很大的期望，[mename]。我相信，只要你哪怕多给精灵一点点权利，他们就会愿意见你了。"

# game/a7/7queen_roads.rpy:66
translate english queen_roads_3820771a:

    # me "..."
    me "..."

# game/a7/7queen_roads.rpy:67
translate english queen_roads_c1788335:

    # mom "Думаю грибов достаточно. Нам все равно ехать осталось не так далеко."
    mom "我看蘑菇够多了。反正剩下的路程也不远了。"

# game/a7/7queen_roads.rpy:74
translate english queen_roads2_61af3595:

    # me "Да, кстати на счет этого..."
    me "对了，说到这个……"

# game/a7/7queen_roads.rpy:75
translate english queen_roads2_dc2a52cf:

    # mom "[mename]?"
    mom "[mename]?"

# game/a7/7queen_roads.rpy:76
translate english queen_roads2_f739d7d5:

    # me "Знаешь мы две недели в дороге..."
    me "你知道，我们赶了两星期的路……"

# game/a7/7queen_roads.rpy:77
translate english queen_roads2_2af774fc:

    # mom "И?"
    mom "所以？"

# game/a7/7queen_roads.rpy:78
translate english queen_roads2_9ec7602b:

    # me "Жена моя осталась дома..."
    me "我妻子留在了家里……"

# game/a7/7queen_roads.rpy:79
translate english queen_roads2_cff427c5:

    # mom "[mename], только не говори мне..."
    mom "[mename]，你该不会是想说……"

# game/a7/7queen_roads.rpy:80
translate english queen_roads2_19cebcae:

    # me "Может поможешь мне немного расслабиться?"
    me "能不能帮我稍微放松一下？"

# game/a7/7queen_roads.rpy:81
translate english queen_roads2_5951fb75:

    # mom "Ты невыносим."
    mom "你真是无可救药。"

# game/a7/7queen_roads.rpy:82
translate english queen_roads2_4e30f839:

    # me "Ну так что?"
    me "那到底行不行？"

# game/a7/7queen_roads.rpy:84
translate english queen_roads2_4ec6c8f6:

    # mom "Нас могу увидеть."
    mom "可能会被人看见。"

# game/a7/7queen_roads.rpy:85
translate english queen_roads2_464b7e73:

    # me "Ты отправила служанку к карете."
    me "你已经把侍女打发回马车了。"

# game/a7/7queen_roads.rpy:86
translate english queen_roads2_ceaebe16:

    # mom "А местные жители?"
    mom "那本地的居民呢？"

# game/a7/7queen_roads.rpy:87
translate english queen_roads2_c7e1ae06:

    # me "Что им здесь делать? Их поля в другой стороне."
    me "他们来这儿干嘛？他们的田地在另一边。"

# game/a7/7queen_roads.rpy:88
translate english queen_roads2_c56fe556:

    # mom "Все равно...может кто-нибудь отправится за грибами или ягодами..."
    mom "可还是……说不定有人来采蘑菇或浆果……"

# game/a7/7queen_roads.rpy:89
translate english queen_roads2_454b2776:

    # me "Ладно. Давай отойдем вот за этот камень."
    me "好吧。我们到那块石头后面去。"

# game/a7/7queen_roads.rpy:91
translate english queen_roads2_4bd50f9a:

    # mom "[mename], ты вообще осознаешь, что то что ты делаешь это просто ужасно?"
    mom "[mename]，你到底知不知道，你做的事有多糟糕？"

# game/a7/7queen_roads.rpy:92
translate english queen_roads2_8613242c:

    # me "Угу."
    me "嗯。"

# game/a7/7queen_roads.rpy:93
translate english queen_roads2_ae842504:

    # mom "Но ты все равно продолжаешь?"
    mom "可你还是不肯停？"

# game/a7/7queen_roads.rpy:94
translate english queen_roads2_fc30fd2b:

    # me "Да."
    me "对。"

# game/a7/7queen_roads.rpy:95
translate english queen_roads2_c0f0f3b6:

    # mom "То есть ты плохой человек?"
    mom "这么说，你是个坏人咯？"

# game/a7/7queen_roads.rpy:96
translate english queen_roads2_993b6906:

    # me "А я не человек, я полуэльф."
    me "我又不是人，我是半精灵。"

# game/a7/7queen_roads.rpy:98
translate english queen_roads2_6c6a2018:

    # mom "Эльфы тоже так не делают."
    mom "精灵也不做这种事。"

# game/a7/7queen_roads.rpy:99
translate english queen_roads2_3e5a4962:

    # me "Я думал вы живете большими семьями."
    me "我还以为你们是大家庭住在一起。"

# game/a7/7queen_roads.rpy:100
translate english queen_roads2_68b12c65:

    # mom "И что с того? По-твоему мы трахаемся там все друг с другом?"
    mom "那又怎样？难道你以为我们彼此之间随便乱搞？"

# game/a7/7queen_roads.rpy:101
translate english queen_roads2_4a66fa84:

    # me "Нет. Но я ведь тебя не трахаю, мам. А ты хочешь?"
    me "不是。但我又不是在跟你乱搞，妈妈。难道你想？"

# game/a7/7queen_roads.rpy:102
translate english queen_roads2_b15bc202:

    # mom "Что? НЕТ!"
    mom "什么？不想！"

# game/a7/7queen_roads.rpy:103
translate english queen_roads2_ce35d749:

    # me "Зачем тогда об этом говоришь?"
    me "那你干嘛提这个？"

# game/a7/7queen_roads.rpy:105
translate english queen_roads2_9ed0a4e7:

    # mom "Я говорю об этом? Это ты попытался оправдать свою извращенную природу своей расой."
    mom "是我提的吗？是你想用你的种族来为你那变态的本性开脱。"

# game/a7/7queen_roads.rpy:106
translate english queen_roads2_ddc35e17:

    # me "Но я ведь действительно не виноват, что я такой."
    me "可我变成这样，真的不是我的错。"

# game/a7/7queen_roads.rpy:107
translate english queen_roads2_f2593caa:

    # mom "Ты должен контролировать свои...низменные позывы."
    mom "你应该控制你那些……低级的冲动。"

# game/a7/7queen_roads.rpy:108
translate english queen_roads2_4f5f962f:

    # me "И страдать?"
    me "然后活受罪？"

# game/a7/7queen_roads.rpy:109
translate english queen_roads2_b3f5366d:

    # mom "У тебя есть жена."
    mom "你有妻子。"

# game/a7/7queen_roads.rpy:110
translate english queen_roads2_42363335:

    # me "Ее здесь нет."
    me "她不在这儿。"

# game/a7/7queen_roads.rpy:111
translate english queen_roads2_73ec87c9:

    # mom "И что? Я тебе вместо жены или что?"
    mom "那又怎样？我就得替她当你妻子吗？"

# game/a7/7queen_roads.rpy:112
translate english queen_roads2_27f2e2a8:

    # me "Всего на месяц, пока мы в дороге."
    me "就一个月，只是在路上这段时间。"

# game/a7/7queen_roads.rpy:114
translate english queen_roads2_3c833916:

    # mom "[mename]! Ты что делаешь?"
    mom "[mename]！你在干什么？"

# game/a7/7queen_roads.rpy:115
translate english queen_roads2_67436427:

    # me "Эм...ну я знаю только один способ...расслабления. Для этого мой член не должен быть в штанах."
    me "呃……我只知道一种……放松的办法。那就得把我的家伙从裤子里掏出来。"

# game/a7/7queen_roads.rpy:116
translate english queen_roads2_f864b487:

    # mom "..."
    mom "..."

# game/a7/7queen_roads.rpy:117
translate english queen_roads2_654c1288:

    # me "А моя теория про извращенность нашей с тобой расы по-моему верна. Ты собирала грибы без нижнего белья?"
    me "而且我觉得，关于我们种族变态倾向的理论是对的。你采蘑菇的时候，连内裤都没穿？"

# game/a7/7queen_roads.rpy:118
translate english queen_roads2_ad19c076:

