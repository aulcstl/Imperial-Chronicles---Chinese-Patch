# game/a7/6road_portals_mage.rpy:353
translate english elin_roads_mage_d735be42:

    # me "Мы из разных миров. В моем такого точно нет."
    me "我们来自不同的世界。在我那个世界肯定没这玩意儿。"

# game/a7/6road_portals_mage.rpy:354
translate english elin_roads_mage_a78c6c70:

    # elin_med "В моем тоже."
    elin_med "我的世界也没有。"

