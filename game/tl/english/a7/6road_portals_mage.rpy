# game/a7/6road_portals_mage.rpy:3
translate english elin_roads_mage_4b513be0:

    # elin_unk "..."
    elin_unk "..."

# game/a7/6road_portals_mage.rpy:4
translate english elin_roads_mage_2938575b:

    # elin_unk "Чем здесь все время воняет?"
    elin_unk "这儿怎么一直有股臭味？"

# game/a7/6road_portals_mage.rpy:5
translate english elin_roads_mage_d5cb92a9:

    # elin_unk "Он опять здесь жрал...что за мудак?"
    elin_unk "他又在这儿吃东西了……真是个混蛋？"

# game/a7/6road_portals_mage.rpy:6
translate english elin_roads_mage_2a9cf7f9:

    # elin_unk "Я ему сто раз говорила, что это место только для обмена..."
    elin_unk "我跟他说过一百遍了，这个地方只能用来交换……"

# game/a7/6road_portals_mage.rpy:7
translate english elin_roads_mage_b5dc4b66:

    # elin_unk "Но каждый раз, как я сюда прихожу здесь будто крыс жарили."
    elin_unk "但我每次来这儿，都搞得像在这儿烤过老鼠一样。"

# game/a7/6road_portals_mage.rpy:8
translate english elin_roads_mage_b9343b39:

    # elin_unk "Эх...ладно...Уговор есть уговор."
    elin_unk "唉……算了……约定就是约定。"

# game/a7/6road_portals_mage.rpy:10
translate english elin_roads_mage_4b513be0_1:

    # elin_unk "..."
    elin_unk "..."

# game/a7/6road_portals_mage.rpy:11
translate english elin_roads_mage_25e68a4b:

    # elin_unk "Если бы я увидела, как он касается этих книг своими жирными пальцами меня бы вырвало."
    elin_unk "要是我看到他油乎乎的手指碰这些书，我准会吐出来。"

# game/a7/6road_portals_mage.rpy:12
translate english elin_roads_mage_916886d7:

    # elin_unk "Интересно, он их читает?"
    elin_unk "真有意思，他会读这些书吗？"

# game/a7/6road_portals_mage.rpy:13
translate english elin_roads_mage_0effc893:

    # elin_unk "Черт, конечно нет, эта тупая скотина скорее всего не прочла ни страницы даже до войны."
    elin_unk "见鬼，当然不会，这头蠢猪在战前恐怕连一页都没读过。"

# game/a7/6road_portals_mage.rpy:14
translate english elin_roads_mage_9ba590b8:

    # elin_unk "Наверное просто выменивает их в Полисе на запеченных тушканчиков или что он там любит."
    elin_unk "大概只是在波利斯拿它们换烤跳鼠或者他喜欢的什么玩意儿吧。"

# game/a7/6road_portals_mage.rpy:16
translate english elin_roads_mage_6742bf7d:

    # me "{size=-5}Не перестаю удивляться твердости местного песка.{/size}"
    me "{size=-5}我对本地沙子的硬度老是惊讶不已。{/size}"

# game/a7/6road_portals_mage.rpy:17
translate english elin_roads_mage_0e16a57c:

    # elin "{size=-5}Он оплавился. Хрустит как стекло.{/size}"
    elin "{size=-5}它都熔化了，踩上去像玻璃一样嘎吱响。{/size}"

# game/a7/6road_portals_mage.rpy:18
translate english elin_roads_mage_f868edd7:

    # elin_unk "{i}Блядь! Это еще кто?{/i}"
    elin_unk "{i}操！这又是谁？{/i}"

# game/a7/6road_portals_mage.rpy:19
translate english elin_roads_mage_cda48299:

    # elin_unk "{i}Наверное услышали, как я сама с собой болтаю! Что за идиотская привычка!{/i}"
    elin_unk "{i}他们大概听见我自言自语了！真是个白痴习惯！{/i}"

# game/a7/6road_portals_mage.rpy:20
translate english elin_roads_mage_6dc9760e:

    # me "{size=-5}Интересно, что здесь произошло?{/size}"
    me "{size=-5}奇怪，这里发生了什么？{/size}"

# game/a7/6road_portals_mage.rpy:21
translate english elin_roads_mage_1dd5c7d6:

    # elin "{size=-5}Да. Мне тоже. Я бы занялась расспросом местных, но что-то в прошлый раз нас не очень хорошо встретили.{/size}"
    elin "{size=-5}是啊，我也好奇。我想找当地人问问，不过上次我们好像不太受欢迎。{/size}"

# game/a7/6road_portals_mage.rpy:22
translate english elin_roads_mage_e939fe7b:

    # me "{size=-5}Может никаких местных тут и нет и та девчонка была единственным жителем этих развалин.{/size}"
    me "{size=-5}也许这里根本没什么当地人，那姑娘是这片废墟唯一的居民。{/size}"

# game/a7/6road_portals_mage.rpy:23
translate english elin_roads_mage_3fc949aa:

    # elin_unk "{i}Что за чушь они несут?{/i}"
    elin_unk "{i}他们在胡扯些什么？{/i}"

# game/a7/6road_portals_mage.rpy:24
translate english elin_roads_mage_2eab2322:

    # elin_unk "{i}Это визгуны под напалмом? Блядь! Тогда лучше спрятаться.{/i}"
    elin_unk "{i}这是燃烧弹下的尖啸者吗？操！那最好躲起来。{/i}"

# game/a7/6road_portals_mage.rpy:26
translate english elin_roads_mage_51e63dc6:

    # me "{size=-5}Дышать здесь тяжело.{/size}"
    me "{size=-5}这儿呼吸真困难。{/size}"

# game/a7/6road_portals_mage.rpy:27
translate english elin_roads_mage_dbafcf07:

    # elin "{size=-5}Да. Я тоже заметила. Воздух какой-то густой.{/size}"
    elin "{size=-5}是啊，我也注意到了。空气感觉有点稠。{/size}"

# game/a7/6road_portals_mage.rpy:28
translate english elin_roads_mage_fed948a1:

    # elin_unk "{i}Не заходите сюда....не заходите, если хотите жить, ублюдки.{/i}"
    elin_unk "{i}别进来……想活命就别进来，你们这群杂种。{/i}"

# game/a7/6road_portals_mage.rpy:29
translate english elin_roads_mage_74871d54:

    # elin_unk "{i}Черт, сколько у меня патронов? Вроде четыре.{/i}"
    elin_unk "{i}见鬼，我还有多少发子弹？好像就四发。{/i}"

# game/a7/6road_portals_mage.rpy:30
translate english elin_roads_mage_b910f48d:

    # me "Смотри. Как думаешь для чего это?"
    me "你看，你觉得这是干嘛用的？"

# game/a7/6road_portals_mage.rpy:31
translate english elin_roads_mage_2ff0819b:

    # elin "Понятия не имею. Но вон та штуковина отличается от остальных и в ней кажется...книги?"
    elin "完全没概念。不过那边那个东西跟别的都不一样，里面好像……是书？"

# game/a7/6road_portals_mage.rpy:32
translate english elin_roads_mage_9b313405:

    # elin_unk "{i}Суки! Ну нет. Если я эти книги не выменяю, но жрать мне скоро будет нечего.{/i}"
    elin_unk "{i}母狗！不行。这些书要是换不成，我很快就没东西吃了。{/i}"

# game/a7/6road_portals_mage.rpy:33
translate english elin_roads_mage_94f0923b:

    # elin "Надо посмотреть."
    elin "得去看看。"

# game/a7/6road_portals_mage.rpy:34
translate english elin_roads_mage_77e31ce1:

    # elin_unk "{i}...Блядь...у меня нет выбора.{/i}"
    elin_unk "{i}……操……我没得选了。{/i}"

# game/a7/6road_portals_mage.rpy:36
translate english elin_roads_mage_b5be1f11:

    # elin_pa "{size=+5}СТОЙТЕ, ГДЕ СТОИТЕ, СУЧЬИ ДЕТИ!{/size}"
    elin_pa "{size=+5}站住，不许动，狗娘养的！{/size}"

# game/a7/6road_portals_mage.rpy:37
translate english elin_roads_mage_3e309fd4:

    # me "Ух, ты чего так кричишь? Ты меня напугала!"
    me "哇啊，你干嘛这么大声喊？吓了我一跳！"

# game/a7/6road_portals_mage.rpy:38
translate english elin_roads_mage_4eca343f:

    # elin_pa "Я сказала не шевелитесь. Потянитесь за оружием - вышибу вам мозги."
    elin_pa "我说了，别动。你们敢掏枪，我就打烂你们的脑袋。"

# game/a7/6road_portals_mage.rpy:39
translate english elin_roads_mage_59315a90:

    # elin "У нас нет оружия."
    elin "我们没有武器。"

# game/a7/6road_portals_mage.rpy:40
translate english elin_roads_mage_50427fbc:

    # me "А вот у нее похожая штука, ну что была у девушки в прошлый раз, помнишь? Ну та, что гнула металл?"
    me "可她有把差不多的玩意儿，就是上回那姑娘手里那东西，记得吗？能弯折金属的那个？"

# game/a7/6road_portals_mage.rpy:41
translate english elin_roads_mage_0f5d0cbb:

    # elin_pa "Я вам сейчас черепа погну, вы что здесь забыли?"
    elin_pa "我现在就能弯折你们的头盖骨。你们在这儿找什么？"

# game/a7/6road_portals_mage.rpy:42
translate english elin_roads_mage_adb2eead:

    # elin_pa "Стойте..."
    elin_pa "等等……"

# game/a7/6road_portals_mage.rpy:44
translate english elin_roads_mage_d9d75173:

    # elin_pa "Какого хуя...Я...я что, сплю?"
    elin_pa "搞什么鬼……我……我是在做梦吗？"

# game/a7/6road_portals_mage.rpy:45
translate english elin_roads_mage_0453a9e4:

    # me "Думаешь о том же, о чем и я?"
    me "你觉得我想的跟你一样吗？"

# game/a7/6road_portals_mage.rpy:46
translate english elin_roads_mage_02936b49:

    # elin "Да. Это я. Другая я. Как в том, последнем мире."
    elin "对，就是我。另一个我。就像上一个世界那样。"

# game/a7/6road_portals_mage.rpy:47
translate english elin_roads_mage_a4926cda:

    # elin_pa "[mename] и...я? Как это...вы укололи меня напалмом, пока я не видела? Что за хуйня здесь происходит?"
    elin_pa "[mename]和……我？这怎么……你们趁我没注意给我打了燃烧弹的迷魂针吗？这他妈的怎么回事？"

# game/a7/6road_portals_mage.rpy:48
translate english elin_roads_mage_edd8c97d:

    # me "Это долгая история."
    me "说来话长。"

# game/a7/6road_portals_mage.rpy:49
translate english elin_roads_mage_f8e7e1a3:

    # elin "Бедняга. Выглядит расстерянной."
    elin "可怜的家伙。她看上去真够困惑的。"

# game/a7/6road_portals_mage.rpy:50
translate english elin_roads_mage_b0238bcd:

    # elin_pa "Я не верю... вы не настоящие..."
    elin_pa "我不信……你们不是真的……"

# game/a7/6road_portals_mage.rpy:51
translate english elin_roads_mage_ef91703e:

    # me "Мы настоящие."
    me "我们是真的。"

# game/a7/6road_portals_mage.rpy:53
translate english elin_roads_mage_a4c043d4:

    # elin_pa "Вы...вы из плоти и крови. Я сошла с ума? Как это возможно."
    elin_pa "你们……你们有血有肉。是我疯了吗？这怎么可能。"

# game/a7/6road_portals_mage.rpy:54
translate english elin_roads_mage_cd6217ef:

    # me "Мы из другого мира."
    me "我们来自另一个世界。"

# game/a7/6road_portals_mage.rpy:55
translate english elin_roads_mage_bd2b63b6:

    # elin "Да. Мой магический портал стал работать как-то странно - и вот мы здесь. Заметил, что все эти места связаны?"
    elin "是啊。我的魔法传送门开始出怪毛病了——然后我们就到了这儿。你注意到没有，所有那些地方都有联系？"

# game/a7/6road_portals_mage.rpy:56
translate english elin_roads_mage_186eb98a:

    # me "Заметил ли я? Прямо сейчас вижу подтверждение твоих слов. Это же буквально ты."
    me "我注意到了吗？我现在就看到了证实你话的证据。这可是活生生的另一个你。"

# game/a7/6road_portals_mage.rpy:57
translate english elin_roads_mage_bf8aa3e1:

    # elin_pa "Это...это какой-то бред... вы правда настоящие?"
    elin_pa "这……这是胡扯……你们真的是真的吗？"

# game/a7/6road_portals_mage.rpy:58
translate english elin_roads_mage_be28d136:

    # me "Мы ответим на все интересующие тебя вопросы."
    me "我们会回答你所有感兴趣的问题。"

# game/a7/6road_portals_mage.rpy:59
translate english elin_roads_mage_e58f3d91:

    # elin "Да. Спрашивай, что хочешь."
    elin "对，想问什么就问吧。"

# game/a7/6road_portals_mage.rpy:60
translate english elin_roads_mage_e48aea61:

    # elin_pa "Я спрошу. Но не здесь. Не знаю, такие же вы, как и я анатомически, но... Здесь нельзя дышать без респиратора. В воздухе тяжелый песок с радиацией."
    elin_pa "我会问的。不过不在这儿。我不知道你们是不是跟我一样，在生理上，但……在这儿呼吸必须戴防毒面具。空气里弥漫着带辐射的重沙粒。"

# game/a7/6road_portals_mage.rpy:61
translate english elin_roads_mage_9f97a724:

    # me "С чем? Ради...что?"
    me "有啥？辐……什么？"

# game/a7/6road_portals_mage.rpy:62
translate english elin_roads_mage_84a4f20e:

    # elin_pa "Я провожу вас в место, где мы сможем поговорить. Идем."
    elin_pa "我带你们去个能说话的地方。走吧。"

# game/a7/6road_portals_mage.rpy:64
translate english elin_roads_mage_a89f85ee:

    # "30 минут спустя."
    "三十分钟以后."

# game/a7/6road_portals_mage.rpy:65
translate english elin_roads_mage_674375b2:

    # elin "...так что вот как это произошло."
    elin "……所以事情就是这样发生的。"

# game/a7/6road_portals_mage.rpy:66
translate english elin_roads_mage_9f4b7009:

    # elin_pa "Магия? Я не могу поверить, что такое может быть."
    elin_pa "魔法？我无法相信这种事情可能存在。"

# game/a7/6road_portals_mage.rpy:67
translate english elin_roads_mage_c17b0b9f:

    # elin "Придется. Как ты еще объяснишь наше здесь появление."
    elin "你必须相信。不然你能怎么解释我们出现在这儿？"

# game/a7/6road_portals_mage.rpy:68
translate english elin_roads_mage_b3d5bf29:

    # elin_pa "А в вашем мире...в вашем мире была война?"
    elin_pa "那你们的世界……你们的世界里发生过战争吗？"

# game/a7/6road_portals_mage.rpy:69
translate english elin_roads_mage_f5e2b3b4:

    # elin "В нашем мире постоянно идут войны. Но видя, как выглядит твой мир, я подозреваю, что ты спрашиваешь о чем-то другом."
    elin "我们的世界战争连绵不断。不过看到你的世界这个样子，我猜你问的是另一种东西。"

# game/a7/6road_portals_mage.rpy:70
translate english elin_roads_mage_8378f612:

    # elin_pa "Да. Я спрашиваю о ядерной войны."
    elin_pa "对。我问的是核战争。"

# game/a7/6road_portals_mage.rpy:71
translate english elin_roads_mage_7bf88cac:

    # elin "Прости, я не знаю, что это такое."
    elin "抱歉，我不知道那是什么。"

# game/a7/6road_portals_mage.rpy:72
translate english elin_roads_mage_f42fc179:

    # elin_pa "Тебе повезло."
    elin_pa "你很走运。"

# game/a7/6road_portals_mage.rpy:74
translate english elin_roads_mage_5408f791:

    # me "Ой! Я что-то нажал и..."
    me "哎呀！我好像按了什么，然后……"

# game/a7/6road_portals_mage.rpy:75
translate english elin_roads_mage_4dc01597:

    # elin "[mename], мы не знаем, как устроен этот мир, зачем ты все трогаешь?"
    elin "[mename]，我们根本不了解这个世界是怎么运作的，你干嘛乱摸东西？"

# game/a7/6road_portals_mage.rpy:76
translate english elin_roads_mage_94249882:

    # me "Мне было интересно, что это."
    me "我只是好奇那是什么。"

# game/a7/6road_portals_mage.rpy:77
translate english elin_roads_mage_ad671df7:

    # elin_pa "Все нормально. Это микроволновка."
    elin_pa "没事的。那是微波炉。"

# game/a7/6road_portals_mage.rpy:78
translate english elin_roads_mage_00ec0734:

    # me "Микро..."
    me "微波……"

# game/a7/6road_portals_mage.rpy:79
translate english elin_roads_mage_7f919112:

    # elin_pa "Это электрическая печь."
    elin_pa "就是一种电炉子。"

# game/a7/6road_portals_mage.rpy:80
translate english elin_roads_mage_f8ebfdc5:

    # me "Эм... Я все равно не понял ничего, кроме слова печь. Оно так и будет...."
    me "呃……除了'炉子'这个词，我还是啥也没懂。它难道就那样一直……"

# game/a7/6road_portals_mage.rpy:82
translate english elin_roads_mage_73971192:

    # elin_pa "Поверни ручку назад и она выключится."
    elin_pa "把那个旋钮往回转，它就会停了。"

# game/a7/6road_portals_mage.rpy:83
translate english elin_roads_mage_02d2aa5b:

    # me "Эм..вот так, да?"
    me "呃……这样，对吗？"

# game/a7/6road_portals_mage.rpy:84
translate english elin_roads_mage_e815d8a4:

    # elin "Извини."
    elin "抱歉。"

# game/a7/6road_portals_mage.rpy:85
translate english elin_roads_mage_1dcca0af:

    # elin_pa "Нет. Все нормально. Я соскучилась по проделкам моего брата."
    elin_pa "没事。真的没事。我只是想起了我弟弟的恶作剧。"

# game/a7/6road_portals_mage.rpy:86
translate english elin_roads_mage_37ab85f8:

    # elin "Твой [mename] живет не здесь?"
    elin "你的[mename]不住在这里吗？"

# game/a7/6road_portals_mage.rpy:87
translate english elin_roads_mage_dd3ba99f:

    # elin_pa "Мой [mename] умер."
    elin_pa "我的[mename]死了。"

# game/a7/6road_portals_mage.rpy:88
translate english elin_roads_mage_a087eb2f:

    # elin "Мне жаль."
    elin "我很遗憾。"

# game/a7/6road_portals_mage.rpy:89
translate english elin_roads_mage_5d0c4733:

    # me "А это что?"
    me "那这个又是什么？"

# game/a7/6road_portals_mage.rpy:90
translate english elin_roads_mage_0cf14aaf:

    # elin_pa "Это телефон. Он для связи между бункерами. Как бы обьяснить...можно позвонить и услышать человека на расстоянии."
    elin_pa "那是电话。它用来在地堡之间联系。怎么给你解释呢……你可以打过去，在很远的地方听到人的声音。"

# game/a7/6road_portals_mage.rpy:91
translate english elin_roads_mage_cc2e7a9b:

    # me "Да ладно? Как это работает, если в вашем мире нет магии?"
    me "真的假的？你们的世界没有魔法，这是怎么做到的？"

# game/a7/6road_portals_mage.rpy:92
translate english elin_roads_mage_a40047de:

    # elin_pa "Электричество."
    elin_pa "电。"

# game/a7/6road_portals_mage.rpy:93
translate english elin_roads_mage_dd739e7b:

    # me "Похоже в вашем мире кто-то просто назвал магию электричеством."
    me "看起来在你们的世界，有人不过是把魔法叫成了电。"

# game/a7/6road_portals_mage.rpy:94
translate english elin_roads_mage_43cb5f23:

    # elin "Слушай, [elin], нам пора..."
    elin "听着，[elin]，我们该走了……"

# game/a7/6road_portals_mage.rpy:96
translate english elin_roads_mage_e5c15642:

    # elin_pa "Стойте, вы серьезно? Уже?"
    elin_pa "等等，你们来真的？现在就要走？"

# game/a7/6road_portals_mage.rpy:97
translate english elin_roads_mage_c607d737:

    # me "Да, прости, но у нас есть дела и в нашем мире."
    me "对，抱歉，我们在我们的世界里也有事要办。"

# game/a7/6road_portals_mage.rpy:98
translate english elin_roads_mage_d2ac6c4c:

    # elin "К тому же нам нужно пройти сначала еще через несколько миров."
    elin "而且我们还得先穿过好几个世界。"

# game/a7/6road_portals_mage.rpy:99
translate english elin_roads_mage_51bb6e21:

    # elin_pa "Могу я пойти с вами?"
    elin_pa "我能跟你们一起走吗？"

# game/a7/6road_portals_mage.rpy:100
translate english elin_roads_mage_30d14d64:

    # me "[elin]?"
    me "[elin]?"

# game/a7/6road_portals_mage.rpy:101
translate english elin_roads_mage_313013cf:

    # elin "Я бы хотела этого, но мы сначала должны расспросить обо всем леди Алейну и Преториуса. Перемещать людей между мирами может быть опасным."
    elin "我倒想这样，但我们必须先把一切都问清楚，问问Alaina女士和Pretorius。在世界之间运送人可能会有危险。"

# game/a7/6road_portals_mage.rpy:102
translate english elin_roads_mage_ef0a9317:

    # me "По-твоему они что-то могут об этом знать?"
    me "你觉得他们会对这事儿有什么了解吗？"

# game/a7/6road_portals_mage.rpy:103
translate english elin_roads_mage_e66aed2a:

    # elin "Лучше не рисковать."
    elin "最好还是别冒险。"

# game/a7/6road_portals_mage.rpy:104
translate english elin_roads_mage_b64950c4:

    # elin_pa "Неужели вы меня просто оставите здесь? Мой мир умирает и я тут совсем одна."
    elin_pa "难道你们就这样把我丢在这里？我的世界在消亡，我在这儿完全孤身一人。"

# game/a7/6road_portals_mage.rpy:105
translate english elin_roads_mage_8b9d615f:

    # me "Мы еще вернемся."
    me "我们还会回来的。"

# game/a7/6road_portals_mage.rpy:106
translate english elin_roads_mage_9e6dfd0b:

    # elin "Верно. Мы тебя не бросаем. Нам просто нужно немного времени, чтобы понять как лучше тебе помочь."
    elin "没错。我们不会抛下你。我们只是需要一点时间，弄清楚怎么帮你最好。"

# game/a7/6road_portals_mage.rpy:108
translate english elin_roads_mage_0df5bf30:

    # elin_pa "Ладно...я проведу вас."
    elin_pa "好吧……我送你们走。"

# game/a7/6road_portals_mage.rpy:109
translate english elin_roads_mage_58b05289:

    # me "Не расстраивайся, [elin]."
    me "别难过，[elin]。"

# game/a7/6road_portals_mage.rpy:110
translate english elin_roads_mage_c1b857e4:

    # elin "Да. Мы обязательно вернемся."
    elin "是啊，我们一定回来。"

# game/a7/6road_portals_mage.rpy:111
translate english elin_roads_mage_6f3605dd:

    # elin_pa "Мы просто не представляете, каково это. Вы дали мне надежду, а теперь..."
    elin_pa "你们根本不明白这是什么感觉。你们给了我希望，而现在又……"

# game/a7/6road_portals_mage.rpy:112
translate english elin_roads_mage_a400480c:

    # me "Неужели в этом мире тебя больше ничего не держит?"
    me "难道在这个世界上，就没什么值得你留恋的了吗？"

# game/a7/6road_portals_mage.rpy:113
translate english elin_roads_mage_44d80798:

    # elin_pa "В этом мире есть только развалины, жженный песок и ублюдки, что пытаются выжить за счет других."
    elin_pa "这个世界上只有废墟、烧焦的沙子和靠牺牲他人来苟活的混蛋。"

# game/a7/6road_portals_mage.rpy:114
translate english elin_roads_mage_c0385ae4:

    # me "Мы заберем тебя отсюда. Просто чуть попозже."
    me "我们会把你从这里接走的。只是要稍微晚一点。"

# game/a7/6road_portals_mage.rpy:115
translate english elin_roads_mage_40983d5c:

    # elin "Если это будет возможно. В любом случае мы тебе поможем. Может взять в следующий раз с собой еду?"
    elin "只要有可能的话。无论如何我们都会帮你。要不下次我们给你带点吃的来？"

# game/a7/6road_portals_mage.rpy:116
translate english elin_roads_mage_47c14db0:

    # elin_pa "Ладно."
    elin_pa "好吧。"

# game/a7/6road_portals_mage.rpy:118
translate english elin_roads_mage_90c66e21:

    # "Некоторое время спустя."
    "过了一会."

# game/a7/6road_portals_mage.rpy:119
translate english elin_roads_mage_263ca678:

    # elin_pa "Вау. Выглядит удивительно."
    elin_pa "哇，真是惊人。"

# game/a7/6road_portals_mage.rpy:120
translate english elin_roads_mage_5e1bf09b:

    # me "Ага. Сквозь эту штуку мы и путешествуем."
    me "嗯哼。我们就是靠穿越这个东西旅行的。"

# game/a7/6road_portals_mage.rpy:121
translate english elin_roads_mage_cafdf3fa:

    # elin "Знаешь, что странно? Мы путешествуем сквозь разные миры, но во всех них есть мы."
    elin "你知道吗，奇怪的是，我们穿越了不同的世界，但在所有这些世界里都有我们。"

# game/a7/6road_portals_mage.rpy:122
translate english elin_roads_mage_a2c37df3:

    # me "Пока еще не во всех. Может во втором мире нас нет."
    me "现在还不是所有世界都有。也许在第二个世界里就没有我们。"

# game/a7/6road_portals_mage.rpy:123
translate english elin_roads_mage_70184975:

    # elin "Я почти уверена, что есть. Все на это указывает, к тому же ты заметил, что язык тут такой же, как и у нас?"
    elin "我几乎可以肯定那儿也有。一切都指向这一点，再说你注意到没有，这里的语言跟我们是一样的？"

# game/a7/6road_portals_mage.rpy:124
translate english elin_roads_mage_d3c98487:

    # me "Действительно. Я даже не подумал об этом."
    me "的确。我甚至都没想过这个。"

# game/a7/6road_portals_mage.rpy:125
translate english elin_roads_mage_5549d3a6:

    # elin "В этом точно есть какая-то закономерность. Ладно, пойдем."
    elin "这里面肯定有什么规律。好了，咱们走吧。"

# game/a7/6road_portals_mage.rpy:127
translate english elin_roads_mage_92af1445:

    # elin_med "Для этого лучше всего подойдет зелье номер один."
    elin_med "用这个一号药水最合适不过了。"

# game/a7/6road_portals_mage.rpy:128
translate english elin_roads_mage_b89ecd44:

    # cust "Вы уверены? У меня...тяжелый случай."
    cust "您确定吗？我……这个情况还挺棘手的。"

# game/a7/6road_portals_mage.rpy:129
translate english elin_roads_mage_2490fe78:

    # elin_med "Не беспокойтесь, работоспособность почти 90 процентов."
    elin_med "别担心，有效率差不多能达到90%。"

# game/a7/6road_portals_mage.rpy:130
translate english elin_roads_mage_40971ec7:

    # cust "А есть что-нибудь со 100?"
    cust "有没有100%的？"

# game/a7/6road_portals_mage.rpy:132
translate english elin_roads_mage_edc15e12:

    # elin_med "Есть. Но там больше побочных эффектов. Вы же не хотите ощущать боль в яичках или кровоточить глазами?"
    elin_med "有。不过那个副作用更大些。您总不想睾丸疼、或者眼睛流血吧？"

# game/a7/6road_portals_mage.rpy:133
translate english elin_roads_mage_22a90371:

    # cust "Нет, не хочу, я люблю свою жену, но это того не стоит."
    cust "不，我不想，我虽然爱我老婆，但这可不值得。"

# game/a7/6road_portals_mage.rpy:134
translate english elin_roads_mage_e3c9cb3e:

    # elin_med "Я уверен, что вам поможет зелье номер один, ваша жена будет довольна."
    elin_med "我相信一号药水就能帮到您，您夫人肯定会满意的。"

# game/a7/6road_portals_mage.rpy:135
translate english elin_roads_mage_afb9c190:

    # cust "Нужно принимать его...."
    cust "您需要……服用它。"

# game/a7/6road_portals_mage.rpy:136
translate english elin_roads_mage_251e2f17:

    # elin_med "За час до предполагаемого соития."
    elin_med "在预计房事前一个小时。"

# game/a7/6road_portals_mage.rpy:137
translate english elin_roads_mage_74a1a7c6:

    # cust "Сколько с меня?"
    cust "我该付您多少钱？"

# game/a7/6road_portals_mage.rpy:138
translate english elin_roads_mage_12ea1c05:

    # elin_med "Шесть флоренов."
    elin_med "六枚弗罗林。"

# game/a7/6road_portals_mage.rpy:140
translate english elin_roads_mage_bd316717:

    # cust "Спасибо."
    cust "谢谢。"

# game/a7/6road_portals_mage.rpy:141
translate english elin_roads_mage_d7351417:

    # elin_med "Спасибо, что посетили 'Зелья и Мази госпожи [elin]'. Надеюсь вам больше не придется заходить еще."
    elin_med "感谢您光临'[elin]女士的药水和软膏店'。希望您以后不必再来了。"

# game/a7/6road_portals_mage.rpy:142
translate english elin_roads_mage_bbfb837b:

    # cust "До свидания."
    cust "再见。"

# game/a7/6road_portals_mage.rpy:143
translate english elin_roads_mage_50a85c81:

    # elin_med "{size=-5}Что за повальное мужское бессилие в этом городе?{/size}"
    elin_med "{size=-5}这个城市的男人怎么遍地都是不行的？{/size}"

# game/a7/6road_portals_mage.rpy:144
translate english elin_roads_mage_588f5fa3:

    # elin_med "{size=-5}Это уже седьмой за сегодня.{/size}"
    elin_med "{size=-5}这已经是今天第七个了。{/size}"

# game/a7/6road_portals_mage.rpy:145
translate english elin_roads_mage_753dc807:

    # elin_med "{size=-5}Нужно чтобы [mename] снова нарвал в лесу белой кипариллы.{/size}"
    elin_med "{size=-5}得让[mename]再去林子里采些白色的柏木草回来。{/size}"

# game/a7/6road_portals_mage.rpy:147
translate english elin_roads_mage_e0efb836:

    # elin_med "Это еще что такое?"
    elin_med "这又是什么玩意儿？"

# game/a7/6road_portals_mage.rpy:148
translate english elin_roads_mage_20c77b5f:

    # elin "Аккуратнее."
    elin "小心点。"

# game/a7/6road_portals_mage.rpy:149
translate english elin_roads_mage_dbed0c32:

    # me "Я аккуратен."
    me "我很小心了。"

# game/a7/6road_portals_mage.rpy:150
translate english elin_roads_mage_51bb76ef:

    # elin "Надо было зайти чуть позже."
    elin "该晚点再进来就好了。"

# game/a7/6road_portals_mage.rpy:151
translate english elin_roads_mage_60302d0f:

    # me "Да я бы все равно упал."
    me "反正我总归还是会摔倒的。"

# game/a7/6road_portals_mage.rpy:152
translate english elin_roads_mage_babd1766:

    # elin "Да, но ты бы не упал на меня."
    elin "对，但你就不会砸在我身上了。"

# game/a7/6road_portals_mage.rpy:154
translate english elin_roads_mage_2a116cfa:

    # elin "[elin]! Ты зачем пошла за нами?"
    elin "[elin]！你怎么跟在我们后面来了？"

# game/a7/6road_portals_mage.rpy:155
translate english elin_roads_mage_75fefa41:

    # elin_pa "Я, блядь, там не останусь, даже не мечтайте."
    elin_pa "我他妈的绝对不要待在那儿，你们想都别想！"

# game/a7/6road_portals_mage.rpy:156
translate english elin_roads_mage_aa427a8a:

    # me "Так и знал..."
    me "我就知道……"

# game/a7/6road_portals_mage.rpy:157
translate english elin_roads_mage_b34e12d4:

    # elin "Ты же согласилась остаться."
    elin "你可答应了要留下的。"

# game/a7/6road_portals_mage.rpy:158
translate english elin_roads_mage_84845736:

    # elin_pa "Конечно я согласилась, иначе вы бы не взяли меня с собой к порталу."
    elin_pa "我当然答应了，不然你们才不会带我到传送门旁边去。"

# game/a7/6road_portals_mage.rpy:159
translate english elin_roads_mage_b390382c:

    # me "Надо ее вернуть."
    me "得把她送回去。"

# game/a7/6road_portals_mage.rpy:160
translate english elin_roads_mage_8e15bf6d:

    # elin_pa "Пошли нахуй! Даже не смейте меня трогать! Я вам бошки попростреливаю!"
    elin_pa "滚你妈的！你们碰都别想碰我！我打烂你们的脑袋！"

# game/a7/6road_portals_mage.rpy:161
translate english elin_roads_mage_c55331f3:

    # elin "[elin]!"
    elin "[elin]!"

# game/a7/6road_portals_mage.rpy:163
translate english elin_roads_mage_c0e3548c:

    # elin_med "Кхм-кхм... Не хотите объяснить, что вы устроили в моем магазине?"
    elin_med "咳咳……你们不打算解释一下，在我的店里搞什么吗？"

# game/a7/6road_portals_mage.rpy:164
translate english elin_roads_mage_0c4b50cd:

    # elin "Ой, простите..."
    elin "哎呀，对不起……"

# game/a7/6road_portals_mage.rpy:165
translate english elin_roads_mage_6c8d059c:

    # me "Это же..."
    me "这该不会是……"

# game/a7/6road_portals_mage.rpy:166
translate english elin_roads_mage_ea30d9c5:

    # elin "Да. Очередная я."
    elin "对，又一个我。"

# game/a7/6road_portals_mage.rpy:167
translate english elin_roads_mage_3dcbac75:

    # elin_med "Хватит переговариваться друг с другом. Я требую объяснений."
    elin_med "够了，别在那儿交头接耳了。我要求一个解释。"

# game/a7/6road_portals_mage.rpy:168
translate english elin_roads_mage_3b841194:

    # elin_med "Немедленно."
    elin_med "立刻。"

# game/a7/6road_portals_mage.rpy:169
translate english elin_roads_mage_5d274839:

    # elin "Ладно-ладно. Сейчас все расскажем."
    elin "好好好，我们这就全告诉你。"

# game/a7/6road_portals_mage.rpy:171
translate english elin_roads_mage_bd4e0cb3:

    # "5 минут спустя."
    "五分钟以后."

# game/a7/6road_portals_mage.rpy:172
translate english elin_roads_mage_c6b83f47:

    # elin_med "Быть того не может? Ты это я?"
    elin_med "这怎么可能？你就是我？"

# game/a7/6road_portals_mage.rpy:173
translate english elin_roads_mage_070ee3ab:

    # elin "Ну...не совсем. Видимо ты я...но немного другая версия."
    elin "呃……不完全是。看起来你是我……但算是稍微不同的一个版本。"

# game/a7/6road_portals_mage.rpy:174
translate english elin_roads_mage_b4455ce5:

    # me "Неужели здесь нет магии тоже?"
    me "难道这里也没有魔法吗？"

# game/a7/6road_portals_mage.rpy:175
translate english elin_roads_mage_cbdd5457:

    # elin_med "Определенно. Магией было бы не обанкротится до нового года."
    elin_med "肯定没有。要是有魔法，我就不会在新年前就破产了。"

# game/a7/6road_portals_mage.rpy:176
translate english elin_roads_mage_2db2d2cb:

    # elin_med "И все же...все же это невероятно. Я бы никогда в такое не поверила, если бы не стояли прямо передо мной."
    elin_med "可还是……还是太不可思议了。要不是你们就站在我面前，我死也不会相信这种事。"

# game/a7/6road_portals_mage.rpy:177
translate english elin_roads_mage_5584214f:

    # elin "Да. Все это удивительно. Начиная с того, что все миры говорят на одном языке и заканчивая тем, что везде есть версия нашей семьи с одинаковыми именами."
    elin "是啊，这一切都令人惊异。从所有世界都说同一种语言，到每个世界都有我们家的一个版本，带着同样的名字。"

# game/a7/6road_portals_mage.rpy:178
translate english elin_roads_mage_e84be87a:

    # me "Может все люди повторяются? Ты знаешь Людвига?"
    me "也许所有人都在重复出现？你认识Ludwig吗？"

# game/a7/6road_portals_mage.rpy:179
translate english elin_roads_mage_0bd53c0b:

    # elin_med "Кого?"
    elin_med "谁？"

# game/a7/6road_portals_mage.rpy:180
translate english elin_roads_mage_10c31529:

    # elin "Это не считается."
    elin "这个不算。"

# game/a7/6road_portals_mage.rpy:181
translate english elin_roads_mage_5ac38cf1:

    # me "Почему?"
    me "为什么？"

# game/a7/6road_portals_mage.rpy:183
translate english elin_roads_mage_f58b7510:

    # elin "Он же не член семьи. В этом мире наша семья могла с ним никогда не встретится."
    elin "他又不是我们家的成员。在这个世界，我们家可能从来就没遇见过他。"

# game/a7/6road_portals_mage.rpy:184
translate english elin_roads_mage_638b7d01:

    # elin_med "О ком вы?"
    elin_med "你们在说谁？"

# game/a7/6road_portals_mage.rpy:185
translate english elin_roads_mage_20fe95e9:

    # elin "Что насчет [ophie]?"
    elin "那[ophie]呢？"

# game/a7/6road_portals_mage.rpy:186
translate english elin_roads_mage_1e50f49b:

    # elin_med "Кто?"
    elin_med "谁？"

# game/a7/6road_portals_mage.rpy:187
translate english elin_roads_mage_58a82d22:

    # elin "[ophelia], у тебя есть младшая сестра?"
    elin "[ophelia]，你有个小妹妹吗？"

# game/a7/6road_portals_mage.rpy:188
translate english elin_roads_mage_3530eeda:

    # elin_med "Ах...была. Но она умерла много лет назад от болезни."
    elin_med "啊……有过。但她很多年前就生病去世了。"

# game/a7/6road_portals_mage.rpy:189
translate english elin_roads_mage_e0bbc866:

    # me "Ага... Отличие все же есть."
    me "啊哈……还是有区别的。"

# game/a7/6road_portals_mage.rpy:190
translate english elin_roads_mage_16ce0eb2:

    # elin "Это ни о чем не говорит. В предыдущем мире ты тоже умер. Надо искать базовые несостыковки. Чтобы отличие было заметным, нужно чтобы [lia] вообще не родилась в этом мире, понимаешь?"
    elin "这什么也说明不了。在上一个世界里你也死了。得找根本性的矛盾。那种区别要足够明显，也就是说[lia]在这个世界压根没出生，懂吗？"

# game/a7/6road_portals_mage.rpy:191
translate english elin_roads_mage_66948067:

    # me "Мгм."
    me "嗯。"

# game/a7/6road_portals_mage.rpy:192
translate english elin_roads_mage_0f761a0a:

    # elin "А так отличия незначительны. Просто у нас разная судьба. Это не объясняет почему у нас во всех мирах похожая внешность и имена."
    elin "不然的话，区别就微不足道了。只是我们的命运不同。这解释不了为什么我们在所有世界里外表和名字都如此相似。"

# game/a7/6road_portals_mage.rpy:193
translate english elin_roads_mage_b0abdf75:

    # elin "[mename]?"
    elin "[mename]?"

# game/a7/6road_portals_mage.rpy:195
translate english elin_roads_mage_dc7c2318:

    # elin "[mename]! Хватит пялиться на ее грудь!"
    elin "[mename]！不准再盯着她的胸看了！"

# game/a7/6road_portals_mage.rpy:196
translate english elin_roads_mage_5516cd56:

    # me "Я просто искал отличия."
    me "我只是在找区别。"

# game/a7/6road_portals_mage.rpy:197
translate english elin_roads_mage_9a133a63:

    # elin "Нашел? Да, у нее сиськи больше. Ты не том сконцентрирован."
    elin "找到了吗？对，她的奶子更大。你找的重点不对。"

# game/a7/6road_portals_mage.rpy:198
translate english elin_roads_mage_0efe371f:

    # me "Дело в не в этом. Ты говоришь, что отличий нет - но они есть. Выглядишь во всех мирах ты чуть по-разному, магии в этих мирах нет, сами миры отличаются и даже судьба у нас везде разная. Разве это недостаточно отличий?"
    me "重点不在这里。你刚才说没有区别——但区别是有的。你在每个世界里的样子都稍微有点不同，那些世界没有魔法，世界本身也各不相同，就连我们的命运也到处不一样。这难道还不足以说是区别吗？"

# game/a7/6road_portals_mage.rpy:199
translate english elin_roads_mage_fe5f950e:

    # elin "Ты думал об этом пока пялился?"
    elin "你一边盯着看一边就在想这个？"

# game/a7/6road_portals_mage.rpy:200
translate english elin_roads_mage_3c257118:

    # me "Я не пялился."
    me "我没盯着看。"

# game/a7/6road_portals_mage.rpy:201
translate english elin_roads_mage_3bcc2f3d:

    # elin "Ты пялился на ее шикарные сиськи. Бесцеремонно. Беспардонно."
    elin "你就是在盯着她那对儿美胸看。肆无忌惮，毫不避讳。"

# game/a7/6road_portals_mage.rpy:202
translate english elin_roads_mage_440a1caa:

    # me "Ничего я не пялился. Я просто развивал твою мысль."
    me "我根本就没盯着看。我只是在顺着你的思路往下想。"

# game/a7/6road_portals_mage.rpy:203
translate english elin_roads_mage_0a6e6f86:

    # elin "Ну конечно. Ты прямо сейчас пялишься."
    elin "是啊，当然。你现在就在盯着看。"

# game/a7/6road_portals_mage.rpy:204
translate english elin_roads_mage_c6a30557:

    # me "Я не пялюсь. Просто думаю странно, что в разных мирах разные члены нашей семьи мертвы, но ты везде жива."
    me "我没盯着看。我只是在想，真奇怪，在不同的世界里，我们家不同的成员死去了，而你无论在哪儿都活着。"

# game/a7/6road_portals_mage.rpy:205
translate english elin_roads_mage_18d2c892:

    # elin "Может не только я. [elin], в твоем мире мама...секунду..."
    elin "也许不止是我。[elin]，在你的世界里，妈妈……等一下……"

# game/a7/6road_portals_mage.rpy:207
translate english elin_roads_mage_d0b027bc:

    # elin "А где она?"
    elin "她在哪儿？"

# game/a7/6road_portals_mage.rpy:208
translate english elin_roads_mage_21191b37:

    # me "Пропала..."
    me "不见了……"

# game/a7/6road_portals_mage.rpy:209
translate english elin_roads_mage_859cbb9f:

    # elin "Она вошла в портал?"
    elin "她进传送门了吗？"

# game/a7/6road_portals_mage.rpy:210
translate english elin_roads_mage_46545360:

    # me "Я не видел."
    me "我没看到。"

# game/a7/6road_portals_mage.rpy:211
translate english elin_roads_mage_686adf49:

    # elin "Это плохо."
    elin "这可不妙。"

# game/a7/6road_portals_mage.rpy:212
translate english elin_roads_mage_5ac38cf1_1:

    # me "Почему?"
    me "为什么？"

# game/a7/6road_portals_mage.rpy:213
translate english elin_roads_mage_95cf845c:

    # elin "Если она вошла в портал он может скоро закрыться."
    elin "如果她进了传送门，门可能很快就会关上。"

# game/a7/6road_portals_mage.rpy:214
translate english elin_roads_mage_86f8f6b8:

    # me "Ты же его создала."
    me "那门是你创造的啊。"

# game/a7/6road_portals_mage.rpy:215
translate english elin_roads_mage_35f03b29:

    # elin "Да. Но ты забыл - что я это она."
    elin "对。可你忘了——我也就是她。"

# game/a7/6road_portals_mage.rpy:216
translate english elin_roads_mage_feaae9e9:

    # me "В ее мире нет магии."
    me "可她的世界里没有魔法。"

# game/a7/6road_portals_mage.rpy:217
translate english elin_roads_mage_6438fed0:

    # elin "Мы не знаем, как это работает. Никто не изучал работу порталов в условиях существования двойников."
    elin "我们不知道这到底是怎么运作的。没人研究过在有分身存在的情况下，传送门会如何运作。"

# game/a7/6road_portals_mage.rpy:218
translate english elin_roads_mage_1dcda6df:

    # me "Тогда нам нужно за ней."
    me "那我们得去找她。"

# game/a7/6road_portals_mage.rpy:219
translate english elin_roads_mage_d66e28dd:

    # elin "Да. И быстрее. Мы не знаем, как ее нахождение в других мирах может на них повлиять. Вдруг они уничтожатся как и ее мир?"
    elin "对，而且要快。我们不知道她停留在别的世界会对那些世界产生什么影响。万一它们像她的世界一样被毁灭了呢？"

# game/a7/6road_portals_mage.rpy:220
translate english elin_roads_mage_695021ad:

    # me "Тогда пойдем."
    me "那咱们走吧。"

# game/a7/6road_portals_mage.rpy:221
translate english elin_roads_mage_7da12c79:

    # elin_med "Что вы сказали?"
    elin_med "你们刚说什么？"

# game/a7/6road_portals_mage.rpy:223
translate english elin_roads_mage_103dfe07:

    # elin_pa "Ушли?"
    elin_pa "他们走了吗？"

# game/a7/6road_portals_mage.rpy:224
translate english elin_roads_mage_ca8c337e:

    # elin_med "Да. И ты отправляешься за ними."
    elin_med "是的。然后你也跟着他们去。"

# game/a7/6road_portals_mage.rpy:225
translate english elin_roads_mage_1c9c2706:

    # elin_pa "Э? Чего это?"
    elin_pa "呃？凭什么啊？"

# game/a7/6road_portals_mage.rpy:226
translate english elin_roads_mage_77a442d3:

    # elin_med "Слышала, что сказала другая [elin]? Я не хочу чтобы мой мир уничтожился."
    elin_med "你听到另一个[elin]说的话了吗？我不想让我的世界被毁灭。"

# game/a7/6road_portals_mage.rpy:227
translate english elin_roads_mage_1a4a5078:

    # elin_pa "Это бред собачий. Ничего не уничтожится."
    elin_pa "这纯属胡扯。什么都不会被毁灭。"

# game/a7/6road_portals_mage.rpy:228
translate english elin_roads_mage_46d33859:

    # elin_med "Откуда тебе знать?"
    elin_med "你怎么知道？"

# game/a7/6road_portals_mage.rpy:229
translate english elin_roads_mage_9ab7b816:

    # elin_pa "А ей откуда знать?"
    elin_pa "那她又怎么知道？"

# game/a7/6road_portals_mage.rpy:230
translate english elin_roads_mage_0fd4599e:

    # elin_med "Она открыла эту фиолетовую штуку, так что я доверяю ей."
    elin_med "是她打开了那道紫色的玩意儿，所以我信她。"

# game/a7/6road_portals_mage.rpy:231
translate english elin_roads_mage_5a47d7a2:

    # elin_pa "Слушай, мой мир - это пустыня с трупами..."
    elin_pa "听着，我的世界——不过是个堆满尸体的荒漠……"

# game/a7/6road_portals_mage.rpy:232
translate english elin_roads_mage_759b388a:

    # elin_med "Мне жаль, но я не хочу, чтобы мой превращался во что-то подобное. Так что иди следом за ними."
    elin_med "我很同情，但我不想让我的世界也变成那种样子。所以，你得跟着他们去。"

# game/a7/6road_portals_mage.rpy:233
translate english elin_roads_mage_7908969e:

    # elin_pa "Неа."
    elin_pa "不去。"

# game/a7/6road_portals_mage.rpy:234
translate english elin_roads_mage_5103b057:

    # elin_med "Да."
    elin_med "去。"

# game/a7/6road_portals_mage.rpy:235
translate english elin_roads_mage_7908969e_1:

    # elin_pa "Неа."
    elin_pa "不去。"

# game/a7/6road_portals_mage.rpy:236
translate english elin_roads_mage_648ab1b2:

    # elin_med "ДА."
    elin_med "去。"

# game/a7/6road_portals_mage.rpy:238
translate english elin_roads_mage_3a546115:

    # me "{i}Ух, пиздец.{/i}"
    me "{i}唔，真他妈的。{/i}"

# game/a7/6road_portals_mage.rpy:239
translate english elin_roads_mage_9c662528:

    # me "{i}По-моему я себе занозу в член вогнал.{/i}"
    me "{i}我好像扎了根刺到老二里了。{/i}"

# game/a7/6road_portals_mage.rpy:240
translate english elin_roads_mage_a790bfe0:

    # me "{i}Стоп, я опять голый?{/i}"
    me "{i}等等，我又光着身子了？{/i}"

# game/a7/6road_portals_mage.rpy:242
translate english elin_roads_mage_6db2813a:

    # me "{i}Определенно.{/i}"
    me "{i}显然如此。{/i}"

# game/a7/6road_portals_mage.rpy:243
translate english elin_roads_mage_be0e3439:

    # me "{i}Ну...в прошлый раз одежда менялась при каждом перемещении, так что прогресс есть.{/i}"
    me "{i}嗯……上回每次移动衣服都不一样，这次算是有进步了。{/i}"

# game/a7/6road_portals_mage.rpy:244
translate english elin_roads_mage_5838f556:

    # me "{i}Хотя бы я не появился в женской, как в прошлый раз.{/i}"
    me "{i}至少我这次没跟上回一样穿着女装出现。{/i}"

# game/a7/6road_portals_mage.rpy:245
translate english elin_roads_mage_90b0b2f0:

    # me "{i}Это было бы унизительно.{/i}"
    me "{i}那可太丢人了。{/i}"

# game/a7/6road_portals_mage.rpy:247
translate english elin_roads_mage_3820771a:

    # me "..."
    me "..."

# game/a7/6road_portals_mage.rpy:248
translate english elin_roads_mage_3e4f1003:

    # me "...здраствуйте..."
    me "……您好……"

# game/a7/6road_portals_mage.rpy:249
translate english elin_roads_mage_138f8561:

    # elsc_teach "Мистер Стархед, что это еще за выходки!?"
    elsc_teach "Starhead先生，你这又是在搞什么名堂！？"

# game/a7/6road_portals_mage.rpy:250
translate english elin_roads_mage_0fd8950f:

    # elsc_girl "Вау, [elin], ты не говорила что твой брат такой красавчик под одеждой."
    elsc_girl "哇，[elin]，你可没说过你弟弟在衣服底下这么帅。"

# game/a7/6road_portals_mage.rpy:251
translate english elin_roads_mage_2575c7f8:

    # me "Кхм...я..."
    me "咳……我……"

# game/a7/6road_portals_mage.rpy:252
translate english elin_roads_mage_fd9f4080:

    # elsc_teach "Немедленно выйди из класса, молодой человек! Я не потерплю такое в моем присутствии. Мне плевать, что твой отец - мэр, такое поведение неприемлимо! Как ты вообще пробрался в класс?"
    elsc_teach "年轻人，立刻滚出教室！我绝不容忍有人在我面前这样。我不管你爸是不是市长，这种行为绝对不可接受！你到底是怎么溜进教室的？"

# game/a7/6road_portals_mage.rpy:253
translate english elin_roads_mage_e6fa79b8:

    # elsc_boy "Все эльфы больные на голову, блин."
    elsc_boy "所有精灵脑子都有病，真是的。"

# game/a7/6road_portals_mage.rpy:254
translate english elin_roads_mage_dcfd605f:

    # me "Я...да...я сейчас выйду."
    me "我……这就……这就出去。"

# game/a7/6road_portals_mage.rpy:255
translate english elin_roads_mage_d9079101:

    # elsc_teach "Я звоню твоей матери! Оденься и немедленно к директору."
    elsc_teach "我要给你妈妈打电话！穿好衣服，立刻去见校长。"

# game/a7/6road_portals_mage.rpy:257
translate english elin_roads_mage_bb4e8d03:

    # elin_sh "Я его провожу!"
    elin_sh "我送他过去！"

# game/a7/6road_portals_mage.rpy:258
translate english elin_roads_mage_17a9238b:

    # elsc_teach "Убедись, что он попадет к директору, [elin]!"
    elsc_teach "确保他见到校长，[elin]！"

# game/a7/6road_portals_mage.rpy:259
translate english elin_roads_mage_df87d515:

    # elin_sh "Да, мистер Паркер."
    elin_sh "是，帕克先生。"

# game/a7/6road_portals_mage.rpy:260
translate english elin_roads_mage_acd507c5:

    # me "Эмм, извините."
    me "呃，对不起。"

# game/a7/6road_portals_mage.rpy:261
translate english elin_roads_mage_aa5c4279:

    # elsc_teach "Извинишься перед директором. А потом перед отцом."
    elsc_teach "留着你的对不起去跟校长说吧。然后再去跟你爸说。"

# game/a7/6road_portals_mage.rpy:262
translate english elin_roads_mage_faf8227a:

    # elin_sh "Идем за мной."
    elin_sh "跟我来。"

# game/a7/6road_portals_mage.rpy:263
translate english elin_roads_mage_e0867f8c:

    # elsc_girl "[mename], а ты уже расстался со своей девушкой?"
    elsc_girl "[mename]，你是不是已经跟你女朋友分手了？"

# game/a7/6road_portals_mage.rpy:264
translate english elin_roads_mage_ad26b2e1:

    # elin_sh "{size=-6}Куда тебя вести?{/size}"
    elin_sh "{size=-6}带你去哪儿？{/size}"

# game/a7/6road_portals_mage.rpy:266
translate english elin_roads_mage_1033b09a:

    # elin_pa "Пусти меня, дура!"
    elin_pa "放开我，你个白痴！"

# game/a7/6road_portals_mage.rpy:267
translate english elin_roads_mage_7362b742:

    # elin_med "Еще чего, если я тебя отпущу ты тут же сиганешь обратно в портал."
    elin_med "想得美，我要是放开你，你立马就跳回那个传送门去了。"

# game/a7/6road_portals_mage.rpy:268
translate english elin_roads_mage_a1cc0226:

    # elin_pa "Он не ведет обратно, идиотка! Ты теперь тут тоже застряла!"
    elin_pa "那门不往回走了，蠢货！你现在也跟我一样困在这儿了！"

# game/a7/6road_portals_mage.rpy:269
translate english elin_roads_mage_8a5d599d:

    # elin_med "Ну конечно."
    elin_med "是啊，信你才怪。"

# game/a7/6road_portals_mage.rpy:270
translate english elin_roads_mage_17d60f4b:

    # elin_pa "На кой хрен мне врать?! Отпусти меня!"
    elin_pa "我干嘛要骗你？！放开我！"

# game/a7/6road_portals_mage.rpy:271
translate english elin_roads_mage_4b0763c7:

    # elin_med "Не пущу. Сейчас придет другая [elin] и мы вернем тебя обратно."
    elin_med "我就不放。等另一个[elin]来了，我们就送你回去。"

# game/a7/6road_portals_mage.rpy:272
translate english elin_roads_mage_419b86ab:

    # elin_pa "Какая же ты тупая, невероятно!"
    elin_pa "你这蠢婆娘，简直蠢得没边了！"

# game/a7/6road_portals_mage.rpy:273
translate english elin_roads_mage_8b769930:

    # elin_med "Зато мой мир не погибнет!"
    elin_med "至少我的世界不会毁灭了！"

# game/a7/6road_portals_mage.rpy:275
translate english elin_roads_mage_052fd964:

    # elin_sh "Это...это о чем я думаю? Я сейчас сознание потеряю!"
    elin_sh "这……这就是我想的那个吗？我快晕了！"

# game/a7/6road_portals_mage.rpy:276
translate english elin_roads_mage_0e573ad7:

    # elin_pa "Да не вернусь я в портал, обещаю! Пусти меня, ебанутая!"
    elin_pa "我都说了我不会回传送门了，我保证！放开我，你这个疯子！"

# game/a7/6road_portals_mage.rpy:277
translate english elin_roads_mage_634dfbd7:

    # elin_med "Я тебе не верю."
    elin_med "我不信你。"

# game/a7/6road_portals_mage.rpy:278
translate english elin_roads_mage_5e66fe8c:

    # me "А где моя [elin]?"
    me "我的那个[elin]在哪儿？"

# game/a7/6road_portals_mage.rpy:279
translate english elin_roads_mage_346a41e5:

    # elin_sh "Вы можете потише? Сюда же кто-нибудь придет?"
    elin_sh "你们能小声点吗？待会儿会有人来的！"

# game/a7/6road_portals_mage.rpy:280
translate english elin_roads_mage_28728a72:

    # elin_pa "Я пытаюсь потише, но эта больная мне сейчас руку сломает."
    elin_pa "我已经尽量小声了，可这疯婆子快把我胳膊拧断了。"

# game/a7/6road_portals_mage.rpy:281
translate english elin_roads_mage_0a2d8f45:

    # elin_med "Не сломаю, если ты вертеться не будешь."
    elin_med "你不瞎扭，就不会断。"

# game/a7/6road_portals_mage.rpy:282
translate english elin_roads_mage_12ca7b22:

    # me "Помолчите хоть немного. Нам нужно найти [elin]."
    me "都安静一会儿吧。我们得找到[elin]。"

# game/a7/6road_portals_mage.rpy:283
translate english elin_roads_mage_6c0ea81f:

    # elin_sh "Какой ужас, если это кто-то увидит - моя жизнь кончена."
    elin_sh "太可怕了，要是被人看见，我这一辈子就完了。"

# game/a7/6road_portals_mage.rpy:284
translate english elin_roads_mage_a21f2d1f:

