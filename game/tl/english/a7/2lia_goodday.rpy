    # me "Ты все эти книги уже прочла?"
    me "这些书你都看过了？"

# game/a7/2lia_goodday.rpy:235
translate english liagoodday2_8b19de1d:

    # lia "Конечно!"
    lia "当然！"

# game/a7/2lia_goodday.rpy:236
translate english liagoodday2_83675915:

    # me "Что-нибудь не про лошадей."
    me "只要不是关于马的就行。"

