# game/a7/9west_wind.rpy:255
translate english west_wind1_be7aa58b:

    # me "...."
    me "...."

# game/a7/9west_wind.rpy:256
translate english west_wind1_9025b229:

    # me "Можешь выходить. Я тебя видел."
    me "出来吧。我看见你了。"

# game/a7/9west_wind.rpy:257
translate english west_wind1_3820771a_1:

    # me "..."
    me "..."

