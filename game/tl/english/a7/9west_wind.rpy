translate english west_wind1_b6626098:

    # me "А?"
    me "啊？"

# game/a7/9west_wind.rpy:12
translate english west_wind1_43308897:

    # elin "Мы прибыли."
    elin "我们到了。"

# game/a7/9west_wind.rpy:13
translate english west_wind1_f4f5bbb2:

    # me "А. Ага. Отлично."
    me "啊。嗯。好极了。"

# game/a7/9west_wind.rpy:14
translate english west_wind1_8119ab19:

    # elin "Ты в порядке? Ты последние несколько дней дороги сам не свой."
    elin "你没事吧？赶路的这几天你都魂不守舍的。"

# game/a7/9west_wind.rpy:15
translate english west_wind1_d41552be:

    # me "Я просто устал."
    me "我只是累了。"

# game/a7/9west_wind.rpy:16
translate english west_wind1_a3e8f2c9:

    # elin "Уверен? Ты будто все время думаешь о чем-то."
    elin "你确定？感觉你一直在想什么事。"

# game/a7/9west_wind.rpy:17
translate english west_wind1_6a4c110f:

    # me "Я думаю о встрече с лордом Аргусом."
    me "我在想与阿尔古斯大人会面的事。"

# game/a7/9west_wind.rpy:18
translate english west_wind1_a4dd703a:

    # elin "Все будет нормально. Он уважаемый человек."
    elin "一切都会好的。他是个可敬的人。"

# game/a7/9west_wind.rpy:20
translate english west_wind1_20621d93:

    # me "Погодите, мы же даже не въехали в город."
    me "等等，我们都没进城呢。"

# game/a7/9west_wind.rpy:21
translate english west_wind1_40b8f0f1:

    # lockhart "Ну если ты хочешь, чтобы твой визит был неожиданным - лучше остановится здесь."
    lockhart "如果你想让你此行出其不意——最好就住在这里。"

# game/a7/9west_wind.rpy:22
translate english west_wind1_ffe9dc7f:

    # me "Ну я не то чтобы хотел устраивать неприятный сюрприз..."
    me "我倒不是想制造不愉快的意外..."

# game/a7/9west_wind.rpy:23
translate english west_wind1_4cde3f7b:

    # lockhart "Тогда можем отправится во дворец хоть вечером."
    lockhart "那我们可以傍晚再进王宫。"

# game/a7/9west_wind.rpy:24
translate english west_wind1_2e7fffb5:

    # elin "Не стоит. Сначала лучше отдохнуть, помыться и переодеться."
    elin "不必了。最好先休息、洗漱、换身衣裳。"

# game/a7/9west_wind.rpy:25
translate english west_wind1_aeaa8195:

    # me "Наверное..."
    me "或许吧..."

# game/a7/9west_wind.rpy:26
translate english west_wind1_27c840e8:

    # elin "Не наверное. Пусть мы и приехали с законным требованием, нужно соблюдать этикет."
    elin "不是或许。即便我们是带着合法要求而来，也得遵守礼仪。"

# game/a7/9west_wind.rpy:27
translate english west_wind1_511f832b:

    # lockhart "Это самая приличная гостиница за городом. Можно и в самом городе остановиться, но слухи пойдут быстро...быстрее чем мы отдохнем, помоемся и переоденемся..."
    lockhart "这是城外最体面的旅店了。也可以住城里，但流言会比我们休息、洗漱、换衣服还快……"

# game/a7/9west_wind.rpy:28
translate english west_wind1_8f0959c2:

    # me "Ладно, здесь и остановимся."
    me "好吧，就住这里。"

# game/a7/9west_wind.rpy:29
translate english west_wind1_d5b92b23:

    # elin "Здесь есть, где оставить лошадей?"
    elin "这里能放马吗？"

# game/a7/9west_wind.rpy:30
translate english west_wind1_0f28f3a1:

    # lockhart "Да."
    lockhart "有。"

# game/a7/9west_wind.rpy:33
translate english west_wind1_eeac4eb0:

    # cass "Только не вздумай пойти на встречу с лордом Аргусом без меня."
    cass "千万别想着单独去见阿尔古斯大人。"

# game/a7/9west_wind.rpy:34
translate english west_wind1_8f8de749:

    # me "Это еще почему?"
    me "这又是为什么？"

# game/a7/9west_wind.rpy:35
translate english west_wind1_1affc835:

    # cass "Не хочу чтобы ты наговорил чего-нибудь, что будет противоречить нашему плану."
    cass "我不想你乱说些违背我们计划的话。"

# game/a7/9west_wind.rpy:36
translate english west_wind1_a78ec2e1:

    # elin "[mename] - принц-регент, ему решать."
    elin "[mename]是摄政亲王，由他决定。"

# game/a7/9west_wind.rpy:37
translate english west_wind1_3352feb5:

    # cass "Если принц-регент хочет стать императором, пусть слушает меня."
    cass "如果摄政亲王想当皇帝，就听我的。"

# game/a7/9west_wind.rpy:38
translate english west_wind1_78b54f2f:

    # me "Я позову тебя с собой."
    me "我会叫上你。"

# game/a7/9west_wind.rpy:39
translate english west_wind1_fa44c5c5:

    # cass "Хорошо. Долго не задерживайся. Лучше всего навестить лорда Аргуса завтра утром."
    cass "好。别耽搁太久。最好明早去见阿尔古斯大人。"

# game/a7/9west_wind.rpy:40
translate english west_wind1_1a0dec32:

    # me "Заметано."
    me "就这么定了。"

# game/a7/9west_wind.rpy:42
translate english west_wind1_54607c99:

    # elin "Тогда я займусь лошадями."
    elin "那我去安顿马匹。"

# game/a7/9west_wind.rpy:43
translate english west_wind1_71d3b8c8:

    # me "Хорошо."
    me "好。"

# game/a7/9west_wind.rpy:44
translate english west_wind1_decf8058:

    # lockhart "На сколько снять комнаты?"
    lockhart "房要订几天？"

# game/a7/9west_wind.rpy:45
translate english west_wind1_fd8f9e4a:

    # me "На пару дней. Думаю после встречи твой отец приютит нас?"
    me "一两天吧。会面之后，我想你父亲会收留我们吧？"

# game/a7/9west_wind.rpy:46
translate english west_wind1_7a7eaee7:

    # lockhart "Разумеется."
    lockhart "当然。"

# game/a7/9west_wind.rpy:47
translate english west_wind1_deae639a:

    # me "Что-то жрать охота."
    me "有点想吃东西了。"

# game/a7/9west_wind.rpy:48
translate english west_wind1_06b1eff0:

    # lockhart "[mename]..."
    lockhart "[mename]..."

# game/a7/9west_wind.rpy:51
translate english west_wind1_cc17646b:

    # lockhart "Ты помнишь наш разговор про моего брата?"
    lockhart "你还记得我们谈过我哥哥的事吗？"

# game/a7/9west_wind.rpy:52
translate english west_wind1_fc30fd2b:

    # me "Да."
    me "记得。"

# game/a7/9west_wind.rpy:53
translate english west_wind1_ed6a87a7:

    # lockhart "Ты ведь встретишься с ним?"
    lockhart "你会和他见面吧？"

# game/a7/9west_wind.rpy:54
translate english west_wind1_8084c27a:

    # me "Что? Сейчас?"
    me "什么？现在？"

# game/a7/9west_wind.rpy:55
translate english west_wind1_ee132e34:

    # lockhart "Я написал, что мы сами его найдем, но он идет сюда прямо сейчас..."
    lockhart "我信里说我们会去找他，可他这就过来了……"

# game/a7/9west_wind.rpy:58
translate english west_wind1_ad02f53a:

    # me "Что?"
    me "什么？"

# game/a7/9west_wind.rpy:59
translate english west_wind1_0f2f279c:

    # lockhart "Я забыл тебе сказать, но мой брат хочет с тобой встретится. И я сказал ему, когда и куда мы приедем."
    lockhart "我忘了告诉你，我哥哥想见你。而且我告诉了他我们抵达的时间和地点。"

# game/a7/9west_wind.rpy:60
translate english west_wind1_c787880f:

    # me "Ты охренел? В чем же тайность такой поездки?"
    me "你疯了吗？那这趟密行还有什么意义？"

# game/a7/9west_wind.rpy:61
translate english west_wind1_297730a6:

    # lockhart "Успокойся! Они с отцом враги."
    lockhart "冷静！他和我父亲是死对头。"

# game/a7/9west_wind.rpy:62
translate english west_wind1_2325fa76:

    # me "И что?"
    me "那又怎样？"

# game/a7/9west_wind.rpy:63
translate english west_wind1_86d9a823:

    # lockhart "Слушай, просто поговори с ним."
    lockhart "听着，和他谈谈就好。"

# game/a7/9west_wind.rpy:64
translate english west_wind1_d45ca563:

    # me "Ну ты даешь, Локхарт."
    me "你可真行，Lockhart。"

# game/a7/9west_wind.rpy:65
translate english west_wind1_f71f1e60:

    # lockhart "Извини. Но он нормальный! Честно. Он кстати идет сюда прямо сейчас."
    lockhart "抱歉。但他是个好人！真的。而且他现在正过来。"

# game/a7/9west_wind.rpy:66
translate english west_wind1_672a5a4c:

    # me "Ты серьезно?"
    me "你认真的？"

# game/a7/9west_wind.rpy:68
translate english west_wind1_eb2a4861:

    # henry "Добро пожаловать на Запад, принц-регент [mename] Стархед. Мое имя Генри, я брат твоего свояка."
    henry "欢迎来到西部，摄政亲王[mename]·Starhead。我叫亨利，是你连襟的哥哥。"

# game/a7/9west_wind.rpy:69
translate english west_wind1_2d42945b:

    # me "Ага."
    me "嗯。"

# game/a7/9west_wind.rpy:70
translate english west_wind1_ab9578a0:

    # henry "Я хочу пригласить тебя на..."
    henry "我想邀请你去……"

# game/a7/9west_wind.rpy:72
translate english west_wind1_39c49f9e:

    # knight "Тебе какого хрена надо?"
    knight "你他妈的到底想干什么？"

# game/a7/9west_wind.rpy:73
translate english west_wind1_ff3a1747:

    # henry "Если вы позволите - я все объясню."
    henry "请允许我，我自会解释。"

# game/a7/9west_wind.rpy:74
translate english west_wind1_ed4f9a09:

    # knight "Принц устал и не желает говорить - проваливай отсюда."
    knight "亲王累了，不想说话——快滚。"

# game/a7/9west_wind.rpy:75
translate english west_wind1_19011b33:

    # henry "Я отниму совсем немного его времени."
    henry "我不会占用他太多时间。"

# game/a7/9west_wind.rpy:76
translate english west_wind1_68f04471:

    # me "Все в порядке. Это брат Локхарта. Пусть говорит."
    me "没关系。他是Lockhart的哥哥。让他说。"

# game/a7/9west_wind.rpy:77
translate english west_wind1_a25d6337:

    # knight "Уверенны, мой принц?"
    knight "您确定吗，殿下？"

# game/a7/9west_wind.rpy:78
translate english west_wind1_fc30fd2b_1:

    # me "Да."
    me "是的。"

# game/a7/9west_wind.rpy:80
translate english west_wind1_19774ea6:

    # henry "Спасибо, друг мой. Я просто хотел поговорить с тобой, прежде, чем ты поговоришь с моим отцом."
    henry "谢谢你，我的朋友。我只想在你和我父亲谈话之前，先和你聊聊。"

# game/a7/9west_wind.rpy:81
translate english west_wind1_d34f4d9b:

    # me "О чем же?"
    me "聊什么？"

# game/a7/9west_wind.rpy:82
translate english west_wind1_b5e0d5ae:

    # henry "Не о том же, о чем вы будете говорить с ним."
    henry "不是聊你将和他谈的那些。"

# game/a7/9west_wind.rpy:83
translate english west_wind1_6b90f288:

    # me "Да ладно?"
    me "是吗？"

# game/a7/9west_wind.rpy:84
translate english west_wind1_464c6966:

    # henry "Мне жаль, что все случилось так, как случилось, но преступления матери Локхарта это..."
    henry "很遗憾事情变成这样，但Lockhart母亲的罪行……"

# game/a7/9west_wind.rpy:85
translate english west_wind1_d2c2f2b9:

    # me "А тебе она не мать?"
    me "她难道不是你母亲？"

# game/a7/9west_wind.rpy:86
translate english west_wind1_217b0e78:

    # henry "Она вместе с отцом лишили меня наследства, так что даже если я считал ее своей матерью - это в прошлом. Теперь я только называю ее так."
    henry "她和父亲一起剥夺了我的继承权，所以就算我曾视她为母——那也是从前了。如今我只是口头上这么叫。"

# game/a7/9west_wind.rpy:87
translate english west_wind1_e8d751be:

    # lockhart "Как будто ты сам на это не напрашивался..."
    lockhart "说得好像你不是自找似的……"

# game/a7/9west_wind.rpy:88
translate english west_wind1_697be92b:

    # henry "Может так оно и было... [mename], мой друг, давайте все вместе поговорим в более удобном месте."
    henry "或许是吧……[mename]，我的朋友，让我们换个更妥当的地方谈谈。"

# game/a7/9west_wind.rpy:89
translate english west_wind1_e473fa2f:

    # me "Например?"
    me "比如？"

# game/a7/9west_wind.rpy:91
translate english west_wind1_79d82858:

    # "Десять минут спустя."
    "十分钟以后。"

# game/a7/9west_wind.rpy:92
translate english west_wind1_e89ef076:

    # henry "Когда-то мы встречались в городе, но мой отец недавно запретил мне и это. Он думал что сможет подвергнуть меня таким образом остракизму, но мои товарищи последовали за мной."
    henry "以前我们在城里聚会，但最近父亲连这都禁止了。他以为这样能让我遭到放逐，可我的同伴们追随我而来。"

# game/a7/9west_wind.rpy:93
translate english west_wind1_735f612d:

    # henry "Кстати вот один из них. Как ты, Бернард?"
    henry "对了，这位就是其中之一。你还好吗，伯纳德？"

# game/a7/9west_wind.rpy:94
translate english west_wind1_8b82f2bf:

    # henry "Не отвечай, вижу, что хорошо."
    henry "不用答，看得出你挺好。"

# game/a7/9west_wind.rpy:95
translate english west_wind1_fa75588e:

    # lockhart "Я вижу вы все пьете?"
    lockhart "我看你们都在喝酒？"

# game/a7/9west_wind.rpy:96
translate english west_wind1_ecce44b8:

    # henry "Ну что ты, брат. Мы просто ждали прибытия принца, немного веселились по этому поводу."
    henry "哪里的话，兄弟。我们只是在恭候亲王驾到，为此小小欢庆一下。"

# game/a7/9west_wind.rpy:97
translate english west_wind1_58423f71:

    # lockhart "Это еще с чего вдруг? [mename], не обязан вам помогать."
    lockhart "这又是何必？[mename]没义务帮你们。"

# game/a7/9west_wind.rpy:98
translate english west_wind1_b82cd926:

    # henry "Может и так. Но я уверен, что она нам поможет. Общество Лозы в нем сейчас нуждается."
    henry "也许吧。但我相信她会帮我们。藤蔓社如今正需要他。"

# game/a7/9west_wind.rpy:99
translate english west_wind1_c1a8c563:

    # lockhart "Какое подходящее название..."
    lockhart "好恰当的名字……"

# game/a7/9west_wind.rpy:101
translate english west_wind1_89c3394d:

    # henry "Не обращайте внимание на моего брата, принц. Он вечно нами недоволен, но отцом он недоволен еще больше, я уверяю."
    henry "别理我兄弟，亲王。他向来对我们不满，可我向你保证，他对父亲更不满。"

# game/a7/9west_wind.rpy:102
translate english west_wind1_7ba3ac24:

    # me "И что вы делаете?"
    me "那你们做什么？"

# game/a7/9west_wind.rpy:103
translate english west_wind1_e8962d27:

    # henry "В каком смысле?"
    henry "什么意思？"

# game/a7/9west_wind.rpy:104
translate english west_wind1_8c49dc77:

    # me "Ну в вашем обществе Лозы вы же чем-то занимаетесь? Или просто пьете?"
    me "就你们藤蔓社，总得做点什么吧？还是光喝酒？"

# game/a7/9west_wind.rpy:105
translate english west_wind1_7f4b8bc9:

    # henry "Мы не просто пьем. Сейчас мы налаживаем вертикальные связи."
    henry "我们可不光喝酒。眼下我们正在打通上下关系。"

# game/a7/9west_wind.rpy:106
translate english west_wind1_dfcceeac:

    # me "М?"
    me "嗯？"

# game/a7/9west_wind.rpy:107
translate english west_wind1_e2574031:

    # lockhart "Пьют вместе с простолюдинами..."
    lockhart "他们和庶民同饮……"

# game/a7/9west_wind.rpy:109
translate english west_wind1_9a23d01d:

    # henry "Простолюдины это основа нашей будущей революции."
    henry "庶民是我们未来革命的根基。"

# game/a7/9west_wind.rpy:110
translate english west_wind1_d1c5e4c5:

    # me "Революции?"
    me "革命？"

# game/a7/9west_wind.rpy:111
translate english west_wind1_197cbfea:

    # henry "Пусть вас не пугает это слово, мой принц. Мы не крестьянский сброд, что решил перестать платить налоги. Мы просто хотим реформ...существенных реформ."
    henry "请别被这个词吓到，殿下。我们不是打算抗税的乡野暴民。我们只是想要改革……彻底的改革。"

# game/a7/9west_wind.rpy:112
translate english west_wind1_303d6547:

    # me "Насколько существенных?"
    me "有多彻底？"

# game/a7/9west_wind.rpy:113
translate english west_wind1_046046d3:

    # henry "Настолько существенных, что наши отцы выгоняют нас из замков и лишают наследства."
    henry "彻底到我们的父亲把我们赶出城堡，剥夺继承权。"

# game/a7/9west_wind.rpy:115
translate english west_wind1_7a17ff74:

    # henry "Но нам это только на пользу."
    henry "可这对我们反而有利。"

# game/a7/9west_wind.rpy:116
translate english west_wind1_37730b33:

    # me "Да ну?"
    me "哦？"

# game/a7/9west_wind.rpy:117
translate english west_wind1_25ff67cb:

    # henry "Конечно! Это сближает нас с городскими и крестьянами. Они видят, что мы не боимся пойти на жертвы."
    henry "当然！这让我们与市民和农民更亲近。他们看到我们不怕作出牺牲。"

# game/a7/9west_wind.rpy:118
translate english west_wind1_e04d0501:

    # me "И что же это за реформы?"
    me "那究竟是什么样的改革？"

# game/a7/9west_wind.rpy:119
translate english west_wind1_d7a9b0fd:

    # henry "Республика! Мы хотим сделать Запад местом свободы."
    henry "共和国！我们想把西部变成自由之地。"

# game/a7/9west_wind.rpy:120
translate english west_wind1_3820771a:

    # me "..."
    me "..."

# game/a7/9west_wind.rpy:121
translate english west_wind1_570cd2bb:

    # henry "Понимаю, вы хотите узнать, с чего вам нам помогать?"
    henry "我明白，你想知道凭什么要帮我们？"

# game/a7/9west_wind.rpy:122
translate english west_wind1_eb0d474a:

    # me "Верно."
    me "没错。"

# game/a7/9west_wind.rpy:123
translate english west_wind1_e30587ef:

    # henry "Локхарт, дальше тебе лучше не идти. Здесь все свои конечно, но много и гостей, если не хочешь, чтобы отец узнал..."
    henry "Lockhart，你最好别再跟来了。这里虽都是自己人，可宾客也很多，若不想让你父亲知道……"

# game/a7/9west_wind.rpy:124
translate english west_wind1_75fce0cd:

    # lockhart "Я подожду снаружи."
    lockhart "我在外面等。"

# game/a7/9west_wind.rpy:125
translate english west_wind1_94fccd7f:

    # henry "Спасибо, брат."
    henry "谢了，兄弟。"

# game/a7/9west_wind.rpy:127
translate english west_wind1_a2cdf748:

    # henry "Это моя жена - Жозефина."
    henry "这是我妻子——约瑟芬。"

# game/a7/9west_wind.rpy:128
translate english west_wind1_e05490a1:

    # me "Меня зовут..."
    me "我叫……"

# game/a7/9west_wind.rpy:129
translate english west_wind1_1dcfec2f:

    # josephine "Я знаю, как зовут, [mename]. Ваше имя на устах у всех на Западе последние несколько недель."
    josephine "我知道您的名字，[mename]。这几周来，整个西部都在谈论您。"

# game/a7/9west_wind.rpy:130
translate english west_wind1_489a247d:

    # me "Правда?"
    me "真的？"

# game/a7/9west_wind.rpy:131
translate english west_wind1_ab1e508b:

    # henry "Правда. Моя жена говорит без вас мы обречены. Я конечно более оптимистичен..."
    henry "真的。我妻子说，没有您我们注定灭亡。我嘛，当然更乐观些……"

# game/a7/9west_wind.rpy:132
translate english west_wind1_866c3d9a:

    # josephine "И все же ты привел принца сюда."
    josephine "可你还是把亲王带到了这里。"

# game/a7/9west_wind.rpy:133
translate english west_wind1_78d10979:

    # henry "Да."
    henry "是的。"

# game/a7/9west_wind.rpy:134
translate english west_wind1_09d180f2:

    # josephine "Прошу присаживайтесь, [mename]."
    josephine "请坐，[mename]。"

# game/a7/9west_wind.rpy:136
translate english west_wind1_c55389f4:

    # henry "На чем я остановился..."
    henry "我说到哪儿了……"

# game/a7/9west_wind.rpy:137
translate english west_wind1_d39d158b:

    # me "На моей выгоде."
    me "说到我的好处。"

# game/a7/9west_wind.rpy:138
translate english west_wind1_92297501:

    # henry "Ах, да! Ваша выгода очень проста, мой друг, если вы поможете нам, Запад снова станет субъектом Империи."
    henry "啊，对！您的利益很简单，我的朋友，只要您帮助我们，西部就会重新成为帝国的一部分。"

# game/a7/9west_wind.rpy:139
translate english west_wind1_cfb780d5:

    # me "Республика в составе Империи?"
    me "帝国属下的共和国？"

# game/a7/9west_wind.rpy:140
translate english west_wind1_884ff774:

    # henry "Ну...трибуналы например это наследие эльфийских республик. Но они существовали и в Империи и сейчас существуют."
    henry "呃……比如，法庭就是精灵共和国的遗产。但它们也曾在帝国存在，如今也还在。"

# game/a7/9west_wind.rpy:141
translate english west_wind1_4a59bc54:

    # me "Одно дело некоторые республиканские...институты...Другое дело целая другая система в составе Империи."
    me "个别共和制的……制度是一回事……在帝国内部搞出整个另一套体系又是另一回事。"

# game/a7/9west_wind.rpy:142
translate english west_wind1_803334fb:

    # henry "Мы будем Республикой для людей Запада, но будем уважать все имперские прерогативы. Будем платить имперский налог и присылать рекрутов в армию."
    henry "我们将是西部人民的共和国，但会尊重帝国所有的特权。我们会缴纳帝国赋税，并向军队输送新兵。"

# game/a7/9west_wind.rpy:143
translate english west_wind1_72f4b5a5:

    # me "А если имперские прерогативы будут противоречить вашим республиканским идеалам?"
    me "那要是帝国的特权与你们的共和理想相抵触呢？"

# game/a7/9west_wind.rpy:144
translate english west_wind1_3eda0939:

    # henry "..."
    henry "..."

# game/a7/9west_wind.rpy:145
translate english west_wind1_4631a389:

    # josephine "Решение Императора важнее всего."
    josephine "皇帝的决定高于一切。"

# game/a7/9west_wind.rpy:147
translate english west_wind1_42ca2c00:

    # henry "Верно."
    henry "是啊。"

# game/a7/9west_wind.rpy:148
translate english west_wind1_94dbd9d9:

    # me "Что-то ты потерял красноречие, когда я коснулся этой темы."
    me "我一触及这个话题，你的口才好像就消失了。"

# game/a7/9west_wind.rpy:149
translate english west_wind1_3addf44f:

    # henry "Я просто надеюсь, что вам не придется так поступать."
    henry "我只是希望你们不必那样做。"

# game/a7/9west_wind.rpy:150
translate english west_wind1_d2b04ecc:

    # me "Как?"
    me "哪样？"

# game/a7/9west_wind.rpy:151
translate english west_wind1_5b12350c:

    # henry "Мешать построению свободного и справедливого общества. Мы будем самым богатым, а значит полезным субьектом Империи, не думаю, что Императору понадобиться как-то нас унижать или что-то нам запрещать."
    henry "阻挠我们建立自由正义的社会。我们会是最富庶、因而也是对帝国最有用的属国，我不认为皇帝会有必要羞辱我们，或禁止我们什么。"

# game/a7/9west_wind.rpy:152
translate english west_wind1_524f8271:

    # me "С чего вы взяли, что мне вообще интересно присоединение Запада?"
    me "你们凭什么认为我对吞并西部感兴趣？"

# game/a7/9west_wind.rpy:153
translate english west_wind1_0db1ed04:

    # henry "Я не дурак. Вы не стали бы приезжать лично, если бы не хотели попросить что-то ощутимое за преступления моей матери."
    henry "我不傻。若不是想就我母亲的罪行索要些切实的利益，您不会亲自跑来。"

# game/a7/9west_wind.rpy:154
translate english west_wind1_dd202e6c:

    # me "А вдруг твой отец присоединить Запад к Империи безо всяких условий?"
    me "万一是你父亲无条件将西部并入帝国呢？"

# game/a7/9west_wind.rpy:156
translate english west_wind1_10faeadc:

    # valer "Это вряд ли."
    valer "这不太可能。"

# game/a7/9west_wind.rpy:157
translate english west_wind1_1b5e8ac4:

    # henry "Валериан..."
    henry "Valerian……"

# game/a7/9west_wind.rpy:158
translate english west_wind1_66b0b784:

    # valer "Что? Мы же не позволим принцу витать в плену иллюзий?"
    valer "怎么？我们总不能眼看着亲王被虚幻蒙蔽吧？"

# game/a7/9west_wind.rpy:159
translate english west_wind1_9de834fb:

    # me "Отсюда поподробнее."
    me "说说清楚。"

# game/a7/9west_wind.rpy:160
translate english west_wind1_0a479737:

    # valer "Республика это не только свобода для Запада, это еще и объединение для него."
    valer "共和国不仅带给西部自由，更带给他统一。"

# game/a7/9west_wind.rpy:161
translate english west_wind1_8072b713:

    # valer "Со смертью вашего деда, Запад развалился на множество разных мелких королевств на три деревни и замок. Даже если отец Генри решит присоединиться к вам, остальные его не поддержат."
    valer "自从您祖父去世，西部便分裂成许多小王国，管着三座村子一个堡。就算亨利的父亲决心归附，其他人也不会支持他。"

# game/a7/9west_wind.rpy:162
translate english west_wind1_fb352e35:

    # me "А в Республике мнение будет единогласным?"
    me "而在共和国就能意见一致？"

# game/a7/9west_wind.rpy:163
translate english west_wind1_a3710a0d:

    # valer "У Республики не будет выбора - она будет благодарна за сам факт своего существования, если вы понимаете о чем я..."
    valer "共和国别无选择——它会因自身得以存在而感恩，不知您明白我的意思没有……"

# game/a7/9west_wind.rpy:164
translate english west_wind1_571c2d0c:

    # me "Думаю, что понимаю."
    me "我想我明白。"

# game/a7/9west_wind.rpy:166
translate english west_wind1_684b0c50:

    # cassius "Зачем вы торгуетесь за свободу? Это отвратительно!"
    cassius "你们为什么拿自由做交易？真令人作呕！"

# game/a7/9west_wind.rpy:167
translate english west_wind1_a7a17cd0:

    # josephine "Кассиус!"
    josephine "卡西乌斯！"

# game/a7/9west_wind.rpy:168
translate english west_wind1_cda7bba2:

    # cassius "Что? Мы создали общество Лозы, а не общество имени золотого принца."
    cassius "怎么？我们组建的是藤蔓社，不是黄金亲王社。"

# game/a7/9west_wind.rpy:169
translate english west_wind1_675c4df7:

    # me "Но за помощью вы обращаетесь именно ко мне."
    me "可你们来寻求的正是我的帮助。"

# game/a7/9west_wind.rpy:170
translate english west_wind1_3f2dcdd1:

    # cassius "Вот именно, что за помощью. Разве ты не молод духом, [mename]? Твой отец одним указом изгнал тебя на Север. Ты же сам видишь, как несовершенна эта система! В твоих руках власть, которую можно превратить в свободу, а не кандалы!"
    cassius "正是求助。难道你精神已老了吗，[mename]？你父亲一纸诏书就把你放逐到北方。你亲眼所见，这体制有多不完善！你手握权力，而这权力可以化为自由，而非枷锁！"

# game/a7/9west_wind.rpy:171
translate english west_wind1_eef5dd56:

    # josephine "Кассиус, успокойся."
    josephine "卡西乌斯，冷静。"

# game/a7/9west_wind.rpy:172
translate english west_wind1_7818c3ad:

    # cassius "Я спокоен. Просто не могу смотреть, как вы тут обсуждаете судьбу моей родины, будто это кусок мяса."
    cassius "我很冷静。只是看不下去你们在这儿把我的祖国像块肉一样讨论它的命运。"

# game/a7/9west_wind.rpy:174
translate english west_wind1_80ad2c88:

    # valer "А это и есть кусок мяса, и нам выбирать, кому он достанется. Можно думать что он целиком влезет в один рот - а можно быть реалистами."
    valer "它确实就是块肉，由我们来选谁吃下它。可以觉得它整个能塞进一张嘴——也可以做个现实主义者。"

# game/a7/9west_wind.rpy:175
translate english west_wind1_d182c840:

    # cassius "Заткнись. Ты...ты...рассуждаешь как южанин!"
    cassius "闭嘴。你……你……满口南方人的论调！"

# game/a7/9west_wind.rpy:176
translate english west_wind1_a2ea6fd4:

    # valer "Твой идеализм приведет нас в могилу."
    valer "你的理想主义会送我们进坟墓。"

# game/a7/9west_wind.rpy:177
translate english west_wind1_ee6d5071:

    # cassius "Мой идеализм каждый день приводит в наше общество сотни людей."
    cassius "我的理想主义每天都让成百上千的人加入我们。"

# game/a7/9west_wind.rpy:178
translate english west_wind1_b486e929:

    # valer "Сотни крестьян."
    valer "成百上千的农民。"

# game/a7/9west_wind.rpy:179
translate english west_wind1_30dfe0b9:

    # cassius "И что? Они не люди?"
    cassius "那又怎样？他们不是人吗？"

# game/a7/9west_wind.rpy:180
translate english west_wind1_35b3149e:

    # valer "Ты хочешь чтобы мы договаривались с принцем, как с крестьянами?"
    valer "你想让我们像对农民那样和亲王商讨？"

# game/a7/9west_wind.rpy:181
translate english west_wind1_53b6ed45:

    # cassius "Он чем-то лучше их? Он такой же человек."
    cassius "他比他们高贵多少？他同样是个人。"

# game/a7/9west_wind.rpy:182
translate english west_wind1_86300975:

    # valer "Он человек с властью."
    valer "他是有权力的人。"

# game/a7/9west_wind.rpy:184
translate english west_wind1_3bd26866:

    # josephine "Господа. Покиньте нас."
    josephine "先生们，请离开。"

# game/a7/9west_wind.rpy:185
translate english west_wind1_48503f90:

    # me "Все в порядке. Мне даже интересно, чем закончится их спор."
    me "没关系。我倒好奇他们的争论会如何收场。"

# game/a7/9west_wind.rpy:186
translate english west_wind1_f5a6d60f:

    # josephine "Наш гость устал с дороги, а вы показываете нас не как альтернативную силу, а как разобщенных мятежников."
    josephine "我们的客人旅途疲惫，而你们把我们展现成了各怀私心的叛党，而非可替代的力量。"

# game/a7/9west_wind.rpy:187
translate english west_wind1_bacd414a:

    # josephine "Прошу, уйдите и дайте нам поговорить."
    josephine "请离开，让我们谈。"

# game/a7/9west_wind.rpy:188
translate english west_wind1_fbbd5cf3:

    # cassius "Как скажете. Но помните, что если свободу отдавать по кускам таким как он - она рано или поздно закончится."
    cassius "随你们。但记住，如果把自由一块块分给他这种人，它迟早会耗尽。"

# game/a7/9west_wind.rpy:189
translate english west_wind1_b2710f31:

    # valer "Заткнись уже нахуй!"
    valer "你他妈给我闭嘴！"

# game/a7/9west_wind.rpy:190
translate english west_wind1_c6147e03:

    # henry "Господа..."
    henry "诸位……"

# game/a7/9west_wind.rpy:192
translate english west_wind1_a510661d:

    # henry "Друг мой, прости меня за этих дураков."
    henry "我的朋友，原谅这帮蠢货。"

# game/a7/9west_wind.rpy:193
translate english west_wind1_3a59da50:

    # me "Все нормально."
    me "不要紧。"

# game/a7/9west_wind.rpy:194
translate english west_wind1_c2bb85e4:

    # josephine "Как ты мог заметить наше общество не слишком иерархично, так что мы приветствуем любые мнения."
    josephine "你可能已注意到，我们社内并不太讲等级，因此任何意见都欢迎。"

# game/a7/9west_wind.rpy:195
translate english west_wind1_c1b3fb9c:

    # me "Это я заметил."
    me "这我注意到了。"

# game/a7/9west_wind.rpy:196
translate english west_wind1_5368e9a3:

    # henry "Но наше предложение не поменялось."
    henry "但我们的提议没有变。"

# game/a7/9west_wind.rpy:197
translate english west_wind1_5bff0f33:

    # me "Не уверен, что оно именно ваше. Как я могу быть уверен, что Республика, которую я помогу вам создать, не развалится через неделю на другие мелкие республики с несогласными?"
    me "我不确定这真是你们的提议。我怎能保证，我帮忙建立的共和国，一周后不会因不服者分裂成其他小共和国？"

# game/a7/9west_wind.rpy:198
translate english west_wind1_6fe8f4e4:

    # josephine "Мы изберем своего единого представителя, как только ты согласишься нам помочь."
    josephine "只要你答应帮我们，我们就选出一位统一的代表。"

# game/a7/9west_wind.rpy:199
translate english west_wind1_00d68cd0:

    # me "Серьезно?"
    me "此话当真？"

# game/a7/9west_wind.rpy:200
translate english west_wind1_d52fa2ab:

    # henry "Да. Каждый дворянин в обществе лозы публично признает нового лидера над Западом и закрепит это кровью. А он в свою очередь признает над собой твою имперскую власть."
    henry "是的。藤蔓社的每位贵族都会公开承认西部的新领袖，并以血为誓。而他则会承认你在他之上的帝国权威。"

# game/a7/9west_wind.rpy:201
translate english west_wind1_f75514b1:

    # josephine "Это достаточно честно?"
    josephine "这够公平了吧？"

# game/a7/9west_wind.rpy:202
translate english west_wind1_96eba995:

    # me "И вы сможете всех уговорить это сделать?"
    me "你们能说服所有人这么做？"

# game/a7/9west_wind.rpy:203
translate english west_wind1_0384d406:

    # henry "Конечно. Если у нас не получится ты всегда сможешь отказать нам в помощи, верно?"
    henry "当然。若不成功，你总可以拒绝帮我们，对吗？"

# game/a7/9west_wind.rpy:205
translate english west_wind1_cd20a2c7:

    # lockhart "Ну что? Поговорили?"
    lockhart "怎么样？谈过了？"

# game/a7/9west_wind.rpy:206
