# game/a7/9west_wind.rpy:210
translate english west_wind1_98ee5811:

    # lockhart "Тебя это не беспокоит?"
    lockhart "你不担心吗？"

# game/a7/9west_wind.rpy:211
translate english west_wind1_66d6554c:

    # valer "Ну что ты. Это просто закон рынка. Но именно поэтому я и не беспокоюсь."
    valer "哪里的话。这只是市场规律。正因如此我才不担心。"

# game/a7/9west_wind.rpy:212
translate english west_wind1_dfcceeac_1:

    # me "М?"
    me "嗯？"

# game/a7/9west_wind.rpy:213
translate english west_wind1_c6e650cb:

    # valer "Тебя беспокоит надежность предложения Генри, но предложение лорда Аргуса будет еще хуже."
    valer "你担心亨利的提议不可靠，可阿尔古斯大人的提议只会更糟。"

# game/a7/9west_wind.rpy:214
translate english west_wind1_efc0e552:

    # me "Ты в этом так уверен?"
    me "你如此肯定？"

# game/a7/9west_wind.rpy:215
translate english west_wind1_b5332310:

    # valer "Я в этом уверен абсолютно."
    valer "我绝对肯定。"

# game/a7/9west_wind.rpy:216
translate english west_wind1_2e4059ad:

    # me "А я вот абсолютно уверен только в том, что очень хочу жрать."
    me "而我唯一绝对肯定的，就是我现在饿得要命。"

# game/a7/9west_wind.rpy:217
translate english west_wind1_ab43169b:

    # valer "О! С этим я помочь могу."
    valer "噢！这我倒能帮上忙。"

# game/a7/9west_wind.rpy:219
translate english west_wind1_90c66e21:

    # "Некоторое время спустя."
    "过了一会."

# game/a7/9west_wind.rpy:220
translate english west_wind1_569a567b:

    # valer "...вот такого окуня я выловил."
    valer "……我钓上来这么大一条鲈鱼。"

# game/a7/9west_wind.rpy:221
translate english west_wind1_1181d094:

    # lockhart "Ну конечно..."
    lockhart "嗯那是当然……"

# game/a7/9west_wind.rpy:222
translate english west_wind1_d672e32e:

    # valer "Я не вру."
    valer "我没说谎。"

# game/a7/9west_wind.rpy:223
translate english west_wind1_98109331:

    # lockhart "Но не было никого, кто бы это подтвердил?"
    lockhart "但没人能作证吗？"

# game/a7/9west_wind.rpy:224
translate english west_wind1_e066daa8:

    # valer "Это было ночью, так что там были твои любимые звезды - может спросишь у них?"
    valer "那是夜里，所以有你喜欢的星星在场——要不你问问它们？"

# game/a7/9west_wind.rpy:225
translate english west_wind1_4750306c:

    # lockhart "Я уже спросил, они сказали что ты великий обманщик."
    lockhart "我问过了，它们说你是大骗子。"

# game/a7/9west_wind.rpy:226
translate english west_wind1_05ea33dc:

    # valer "Ну не верьте, как хотите."
    valer "好吧，不信随你。"

# game/a7/9west_wind.rpy:227
translate english west_wind1_4df597d5:

    # me "А я верю."
    me "我信。"

# game/a7/9west_wind.rpy:228
translate english west_wind1_23c0006c:

    # valer "Правда?"
    valer "真的？"

# game/a7/9west_wind.rpy:229
translate english west_wind1_956f7452:

    # me "Да. Я однажды видел, как моряки вытащили на берег русалку, так что и в окуня такого размера верю."
    me "真的。我有回看见水手们把一条人鱼拖上岸，所以这么大的鲈鱼我也信。"

# game/a7/9west_wind.rpy:230
translate english west_wind1_ff6aa2a5:

    # valer "Серьезно?"
    valer "真的假的？"

# game/a7/9west_wind.rpy:231
translate english west_wind1_5a7a7577:

    # me "Нет."
    me "假的。"

# game/a7/9west_wind.rpy:232
translate english west_wind1_dc98ee7b:

    # valer "Вот так вот вы значит отвечаете на мое гостеприимство..."
    valer "这就是你们回报我盛情的方式吗……"

# game/a7/9west_wind.rpy:233
translate english west_wind1_1957aaaf:

    # me "Откуда у тебя это место?"
    me "这地方你怎么来的？"

# game/a7/9west_wind.rpy:234
translate english west_wind1_573c67c5:

    # valer "Мой отец сослал меня сюда работать, когда я поддержал Генри."
    valer "我支持亨利后，父亲便把我流放到这里干活。"

# game/a7/9west_wind.rpy:236
translate english west_wind1_97fbffa1:

    # me "И ты работал?"
    me "那你就干了？"

# game/a7/9west_wind.rpy:237
translate english west_wind1_dd91c3d4:

    # valer "Шутишь? Я сделал это место самым прибыльным в городе. Это так разозлило отца, что он его закрыл."
    valer "开玩笑？我把这里做成了全城最赚钱的地方。这气得父亲直接把它关了。"

# game/a7/9west_wind.rpy:238
translate english west_wind1_3cca392b:

    # lockhart "Я спать хочу..."
    lockhart "我想睡了……"

# game/a7/9west_wind.rpy:239
translate english west_wind1_f62137b1:

    # valer "Наверху кстати есть пару номером. Можете остановиться там. Таверна все равно не работает по решению лорда Аргуса."
    valer "楼上倒是有几个房间。你们可以住那儿。反正这酒馆因阿尔古斯大人的命令也停业了。"

# game/a7/9west_wind.rpy:240
translate english west_wind1_52b6eafc:

    # me "Я думал твой отец ее закрыл."
    me "我还以为是你父亲关的。"

# game/a7/9west_wind.rpy:241
translate english west_wind1_8f567f05:

    # valer "Конечное решение принимает местный лорд. Наши с Локхартом отцы старые друзья. Так что мой отец просто попросил и лорд Аргус закрыл это место."
    valer "最终决定权在本地领主。我和Lockhart的父亲是老朋友。所以我父亲只是开口，阿尔古斯大人就把这里关了。"

# game/a7/9west_wind.rpy:242
translate english west_wind1_b3d639ea:

    # me "Здесь удобно?"
    me "这里方便吗？"

# game/a7/9west_wind.rpy:243
translate english west_wind1_808f61fd:

    # valer "Всяко удобнее клоповника у которого вы остановились, да и искать вас здесь никто не будет."
    valer "怎么也比你们住的那个跳蚤窝强，而且没人会到这里来找你们。"

# game/a7/9west_wind.rpy:244
translate english west_wind1_8763d689:

    # me "Как тебе идея?"
    me "你觉得呢？"

# game/a7/9west_wind.rpy:245
translate english west_wind1_14bb3dde:

    # lockhart "Мне нравится."
    lockhart "我喜欢。"

# game/a7/9west_wind.rpy:247
translate english west_wind1_4400b448:

    # lockhart "Пойду позову остальных."
    lockhart "我去叫其他人。"

# game/a7/9west_wind.rpy:248
translate english west_wind1_79d0547b:

    # valer "А я пойду скажу управляющей, чтобы не впускала сюда своих родственников."
    valer "我去跟老板娘说，别放她亲戚进来。"

# game/a7/9west_wind.rpy:249
translate english west_wind1_e2c15dd1:

    # lockhart "Ты со мной?"
    lockhart "你和我一起？"

# game/a7/9west_wind.rpy:250
translate english west_wind1_15dcadf2:

    # me "Сначала доем."
    me "先吃完。"

# game/a7/9west_wind.rpy:251
translate english west_wind1_898f6842:

    # valer "Если что кухарка еще здесь. Можешь просить ее сделать что хочешь. Она сделает, если ингредиенты есть конечно."
    valer "对了，厨娘还在。想吃什么可以让她做。有食材的话她都会做。"

# game/a7/9west_wind.rpy:252
translate english west_wind1_2fbef7a0:

    # me "Хорошо, спасибо, Валериан."
    me "好，谢谢，Valerian。"

