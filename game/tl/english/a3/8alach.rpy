# TODO: Translation updated at 2024-03-06 23:32

# game/a3/8alach.rpy:4
translate english alach_8d2a1b90:

    # ala "Ну что, показал [val] мою лабораторию?"
    ala "怎么样，让[val]参观了我的实验室吗？"

# game/a3/8alach.rpy:5
translate english alach_4d9c8b4e:

    # mc "Да. Только вы забыли мне сказать, где она будет жить."
    mc "是的。只是您忘了告诉我，她将住在哪里。"

# game/a3/8alach.rpy:6
translate english alach_f9b3cdf3:

    # ala "Ну..пока что в моих покоях, потом найдем ей комнату в доме для слуг."
    ala "嗯……暂时先住我的房间，之后我们会在仆人房给她找个屋子。"

# game/a3/8alach.rpy:7
translate english alach_758f74f1:

    # mc "Ага. Я подумал также и отвел ее к вам. Надеюсь там нет ничего ценного на видном месте."
    mc "啊哈。我也这么想的，就把她带到您那儿去了。希望您显眼的地方没放什么贵重物品。"

# game/a3/8alach.rpy:8
translate english alach_1cc821dc:

    # ala "Неужели ты думаешь она попытается что-то украсть, тем более у меня?"
    ala "你难道觉得她会偷东西吗，更何况是偷我的？"

# game/a3/8alach.rpy:9
translate english alach_4d128267:

    # mc "Я шучу."
    mc "我开玩笑的。"

# game/a3/8alach.rpy:13
translate english alach_fast_aea59195:

    # ala "Это место...всегда навевает на меня тоску. Когда-то здесь кипела жизнь. Эльфийская жизнь. Теперь это просто руины."
    ala "这个地方……总是让我感到忧伤。这里曾经充满生机。精灵的生活。现在只剩废墟。"

# game/a3/8alach.rpy:14
translate english alach_fast_5dbdccb4:

    # mc "Когда здесь кипела жизнь вы еще не родились."
    mc "这里充满生机的时候，您还没出生呢。"

# game/a3/8alach.rpy:15
translate english alach_fast_ce9c1a5f:

    # ala "Откуда ты знаешь сколько мне лет."
    ala "你怎么知道我多大年纪。"

# game/a3/8alach.rpy:16
translate english alach_fast_82289510:

    # mc "Война была давно. Слишком давно даже по меркам эльфов."
    mc "那场战争是很久以前的事了。即使以精灵的标准来看也太久了。"

# game/a3/8alach.rpy:17
translate english alach_fast_1b4895e5:

    # ala "Это ничего не меняет. Пусть здесь уже давно все мертво, но все говорит со мной."
    ala "这改变不了什么。就算这里早已一片死寂，但一切都在对我诉说。"

# game/a3/8alach.rpy:18
translate english alach_fast_24ea6744:

    # mc "Говорит?"
    mc "诉说？"

# game/a3/8alach.rpy:20
translate english alach_fast_ead273a8:

    # ala "Белый камень, из такого строили только эльфы, а узоры на стенах? А растительность? Она жива даже спустя столько лет."
    ala "这白色的石头，只有精灵才会用这种石材建造，再看墙上的花纹？还有这些植物？即使过了这么多年，它们依然活着。"

# game/a3/8alach.rpy:21
translate english alach_fast_5f9c9d02:

    # ala "Все это строили наши предки для своих детей, не зная, что они последнее поколение, что видит это место неразрушенным."
    ala "所有这些都是我们的祖先为他们的孩子建造的，却不知他们已是最后一代能看到此地完好无损的人。"

# game/a3/8alach.rpy:22
translate english alach_fast_39dd70fd:

    # mc "Это...действительно вгоняет в тоску. Никогда не знаешь, когда сделаешь свой последний вздох, так еще и вещи, которые должны обессмертить нас в глазах наших потомков могут достаться не им."
    mc "这……确实令人忧伤。你永远不知道何时会咽下最后一口气，而那些本应在子孙眼中使我们不朽的东西，却可能落入他人之手。"

# game/a3/8alach.rpy:23
translate english alach_fast_ff7a4011:

    # ala "Ну...может однажды эльфы вернутся сюда."
    ala "嗯……也许有一天精灵会回到这里。"

# game/a3/8alach.rpy:24
translate english alach_fast_2b35b6fe:

    # mc "..."
    mc "..."

# game/a3/8alach.rpy:26
translate english alach_fast_e1ba36b0:

    # ala "Ах. Совсем забыла зачем мы здесь."
    ala "啊。我完全忘了我们来这儿的目的了。"

# game/a3/8alach.rpy:27
translate english alach_fast_838d790f:

    # mc "Что вы делаете?"
    mc "您在做什么？"

# game/a3/8alach.rpy:28
translate english alach_fast_6bbe477c:

    # ala "Ищу секретную нажимную плиту. "
    ala "找一块暗门压板。"

# game/a3/8alach.rpy:29
translate english alach_fast_d5f9a466:

    # mc "Я провел здесь с сестрой столько времени... я бы заметил даже самую секретную плиту."
    mc "我和妹妹曾在这里待过那么长时间……就算是最隐蔽的压板我也会发现的。"

# game/a3/8alach.rpy:30
translate english alach_fast_ec79ab61:

    # ala "Duran ossada!"
    ala "Duran ossada!"

# game/a3/8alach.rpy:32
translate english alach_fast_61e3e4a3:

    # mc "Что за?"
    mc "怎么回事？"

# game/a3/8alach.rpy:33
translate english alach_fast_6dcc35c8:

    # ala "Это не просто плита. Она дает нажать себя только тем, кто просит ее по-эльфийски."
    ala "这不是普通的压板。它只允许用精灵语请求它的人按下。"

# game/a3/8alach.rpy:34
translate english alach_fast_e51df265:

    # mc "Магия? Спустя столько лет?"
    mc "魔法？都过了这么多年了？"

# game/a3/8alach.rpy:35
translate english alach_fast_3efb3e02:

    # ala "Это место великой концентрации силы, разве [elin] не говорила тебе?"
    ala "这里是力量高度汇聚之地，[elin]难道没告诉你吗？"

# game/a3/8alach.rpy:37
translate english alach_fast_abd91354:

    # mc "Тайный проход...Ну да. Как я сразу не догадался!"
    mc "密道……哦，是的。我怎么就没想到呢！"

# game/a3/8alach.rpy:38
translate english alach_fast_27230b84:

    # ala "Здесь целая сеть тайных ходов. Отсюда защитники бежали, но и нас сам пик пробирались этим же путем."
    ala "这里有一整套密道网络。守卫者们由此逃离，而我们当初也正是沿此路潜入山峰的。"

# game/a3/8alach.rpy:39
translate english alach_fast_cc11920c:

    # mc "Я никогда об этом не слышал."
    mc "我从未听说过这个。"

# game/a3/8alach.rpy:41
translate english alach_fast_17e46477:

    # ala "Об этом знают только эльфы. До сих пор."
    ala "只有精灵才知道这件事。至今如此。"

# game/a3/8alach.rpy:42
translate english alach_fast_d01f1b34:

    # mc "Но как...была же война. Неужели ни один человек не узнал..."
    mc "可是……那场战争呢。难道就没有一个人发现……"

# game/a3/8alach.rpy:43
translate english alach_fast_8a6ae7c8:

    # ala "У нас свой язык и отличительная черта в виде светлых волос и длинных ушей, забыл? Чужак бы никогда не попал сюда."
    ala "我们有自己独特的语言，还有浅色头发和长耳朵这些明显特征，忘了吗？外人永远不可能进到这里。"

# game/a3/8alach.rpy:44
translate english alach_fast_cc0d8445:

    # mc "У захваченного в плен могли бы выпытать об этих тайных ходах."
    mc "他们本可以从俘虏口中拷问出这些密道的事。"

# game/a3/8alach.rpy:45
translate english alach_fast_f8be4adf:

    # ala "Откуда людям было знать, о чем спрашивать? Они и не подозревали об этом."
    ala "人类怎么会知道该问些什么呢？他们对此毫无察觉。"

# game/a3/8alach.rpy:47
translate english alach_fast_a9f8cafa:

    # mc "Но как же взрыв. Исчезновение всех защитников на пике?"
    mc "但那次爆炸呢？山峰上所有守卫者的消失呢？"

# game/a3/8alach.rpy:48
translate english alach_fast_9d4a4189:

    # ala "Все кто штурмовали пик испарились за долю секунды, люди думали, что они погибли вместе с защищающими пик эльфами."
    ala "所有进攻山峰的人都在一瞬间灰飞烟灭，人类以为他们是和守卫山峰的精灵同归于尽了。"

# game/a3/8alach.rpy:49
translate english alach_fast_a80df6e8:

    # mc "Но на самом деле..."
    mc "但实际上……"

# game/a3/8alach.rpy:50
translate english alach_fast_8afa35e2:

    # ala "Но на самом деле на пике был лишь один эльф, исполняющий детонирующее заклинание."
    ala "但实际上，山峰上只有一个精灵，在施展引爆咒语。"

# game/a3/8alach.rpy:51
translate english alach_fast_742f9d05:

    # mc "Хитро...хитро..."
    mc "狡猾……真狡猾……"

# game/a3/8alach.rpy:53
translate english alach_fast_c077eb86:

    # ala "Вот они, руины подземного храма."
    ala "这就是地下神殿的废墟了。"

# game/a3/8alach.rpy:54
translate english alach_fast_1f7b32e7:

    # mc "Подземный храм?"
    mc "地下神殿？"

# game/a3/8alach.rpy:55
translate english alach_fast_33edc604:

    # ala "Все ходы ведут сюда. Первый храм эльфов был именно здесь."
    ala "所有通道都通向这里。第一座精灵神殿就在这里。"

# game/a3/8alach.rpy:56
translate english alach_fast_809a36b7:

    # mc "Храм Мирты?"
    mc "米爾塔神殿？"

# game/a3/8alach.rpy:57
translate english alach_fast_ce43a5f8:

    # ala "Не совсем. Это место построено еще до того, как эльфы заселили эти земли."
    ala "不完全是。这个地方在精灵定居这片土地之前就已经建成了。"

# game/a3/8alach.rpy:59
translate english alach_fast_7e825dc0:

    # ala "Здесь она явилась нам. Открыла наше предназначение. Наша великая мать."
    ala "她是在这里显现于我们面前的。揭示了我们的使命。我们伟大的母亲。"

# game/a3/8alach.rpy:60
translate english alach_fast_67fa2073:

    # mc "Погоди...если не эльфы построили это место, то кто?"
    mc "等等……如果不是精灵建造的这个地方，那会是谁？"

# game/a3/8alach.rpy:61
translate english alach_fast_15e01f8b:

    # ala "Она."
    ala "是她。"

# game/a3/8alach.rpy:62
translate english alach_fast_54328103:

    # mc "Она? Мирта? Лично вытачивала храм в скале?"
    mc "她？米爾塔？亲自在岩石中开凿出神殿？"

# game/a3/8alach.rpy:63
translate english alach_fast_93352a66:

    # ala "Ей же нужно было где-то явиться нам."
    ala "她总得有个地方向我们显现吧。"

# game/a3/8alach.rpy:64
translate english alach_fast_8fe74a04:

    # mc "Могла бы сделать это в чистом поле. Не думаю, что появление бога омрачит неприглядная обстановка."
    mc "她本可以在旷野中显现。我不认为神的显现会因为环境寒酸而失色。"

# game/a3/8alach.rpy:66
translate english alach_fast_5c0334a2:

    # ala "Ты просто не видел красоту этого места."
    ala "你只是没见过这个地方有多美罢了。"

# game/a3/8alach.rpy:67
translate english alach_fast_ba8d987a:

    # "ЧТО? ЭТО ЖЕ МЕСТО ИЗ МОЕГО ВИДЕНИЯ!"
    "WHAT? THIS IS THE PLACE FROM MY VISION!"

# game/a3/8alach.rpy:68
translate english alach_fast_14913974:

    # ala "Впечатляет? Этому месту тысячи и тысячи лет!"
    ala "印象深刻吧？这地方可有数千上万年的历史了！"

# game/a3/8alach.rpy:69
translate english alach_fast_012f77a3:

    # mc "Впечатляет это не то слово..."
    mc "印象深刻这个词都远远不够……"

# game/a3/8alach.rpy:70
translate english alach_fast_02259aa6:

    # ala "Оно пережило землетрясения, потопы, извержения вулканов и даже войны. Это место построено Ей."
    ala "它经历了地震、洪水、火山喷发，甚至战争。这地方是“她”建造的。"

# game/a3/8alach.rpy:72
translate english alach_fast_1240f8c0:

    # mc "Только ей?"
    mc "只有她？"

# game/a3/8alach.rpy:73
translate english alach_fast_067dd42f:

    # ala "А кем еще? Безымянные боги людей являлись им в небе, океане, в скалах и огне, но не здесь. Единственное место в мире, о котором знают только эльфы."
    ala "还能有谁？人类那些无名的神祇会显现于天空、海洋、岩石与火焰之中，但不会在这里。这是世界上唯一一个只有精灵知晓的地方。"

# game/a3/8alach.rpy:74
translate english alach_fast_6c27615d:

    # mc "А что за предназначение? Что Мирта явила эльфам здесь?"
    mc "那使命是什么？米爾塔在这里向精灵揭示了什么？"

# game/a3/8alach.rpy:75
translate english alach_fast_e1b70e31:

    # ala "Лишь избранные знают. Те, кому она является лично. Мой дедушка был таким."
    ala "只有被选中者才知道。那些她亲身显现的人。我的祖父就是这样的人。"

# game/a3/8alach.rpy:76
translate english alach_fast_922a2841:

    # mc "А остальные? Слепо следуют указаниям?"
    mc "那其余人呢？就盲目地遵从指示吗？"

# game/a3/8alach.rpy:77
translate english alach_fast_7aea923e:

    # ala "Слепо? Мы ничего не делаем слепо. Она указывает нам путь."
    ala "盲目？我们做任何事都不盲目。她为我们指明道路。"

# game/a3/8alach.rpy:78
translate english alach_fast_ef63661c:

    # mc "Она и эльфы, с которыми она говорит."
    mc "她和那些能与她交谈的精灵。"

# game/a3/8alach.rpy:80
translate english alach_fast_794277c4:

    # ala "Что ты хочешь сказать?"
    ala "你想说什么？"

# game/a3/8alach.rpy:81
translate english alach_fast_0f3077ae:

    # mc "Почему она не говорит сразу со всеми?"
    mc "为什么她不直接和所有精灵交谈？"

# game/a3/8alach.rpy:82
translate english alach_fast_570c83a4:

    # ala "А почему пастух не носит каждую овцу на руках?"
    ala "那牧羊人为什么不亲手抱着每一只羊呢？"

# game/a3/8alach.rpy:83
translate english alach_fast_57012307:

    # mc "И все же это опрометчиво так доверять..."
    mc "话虽如此，如此信任还是太冒险了……"

# game/a3/8alach.rpy:84
translate english alach_fast_c5321f0c:

    # ala "Все кому она являлась говорят одно и то же. Они ничего не требуют для себя и являются образцом добродетели."
    ala "所有她曾显现于前的人，说的都是同样的话。他们不为自己索求任何东西，是美德的典范。"

# game/a3/8alach.rpy:85
translate english alach_fast_0de9d09e:

    # ala "Неужели ты думаешь, что эльфы настолько глупы?"
    ala "你难道觉得精灵们会如此愚蠢吗？"

# game/a3/8alach.rpy:86
translate english alach_fast_0c78e8f9:

    # mc "Нет, я..."
    mc "不，我……"

# game/a3/8alach.rpy:87
translate english alach_fast_b2a4b56b:

    # ala "?"
    ala "?"

# game/a3/8alach.rpy:91
translate english alach_fast_8db56876:

    # mc "Просто не могу сложить у себя все это в голове. Леди [alaina], я должен вам кое-что рассказать."
    mc "只是我脑子里没法把这些都联系起来。莱迪[alaina]，我得告诉您一些事。"

# game/a3/8alach.rpy:92
translate english alach_fast_f5b8fab2:

    # ala "Да?"
    ala "什么事？"

# game/a3/8alach.rpy:93
translate english alach_fast_936863df:

    # mc "Я видел это место раньше."
    mc "我以前见过这个地方。"

# game/a3/8alach.rpy:94
translate english alach_fast_1fb5d2de:

    # ala "Видел? Но как? Ты попал сюда с [elin], когда..."
    ala "见过？怎么会？你是和[elin]一起到这里的时候……？"

# game/a3/8alach.rpy:95
translate english alach_fast_49e4f2ae:

    # mc "Нет. Я видел его сегодня. В видениях. Когда потерял сознание после завтрака."
    mc "不。我是今天见到的。在幻象里。早餐后我昏迷过去的时候。"

# game/a3/8alach.rpy:96
translate english alach_fast_697db736:

    # ala "Продолжай."
    ala "继续说。"

# game/a3/8alach.rpy:97
translate english alach_fast_8ec83b7f:

    # mc "И я видел ЕЕ. Мирту."
    mc "我还见到了“她”。米爾塔。"

# game/a3/8alach.rpy:98
translate english alach_fast_8ba2db7c:

    # ala "Ох! Ты выбран ей! Ты как мой дедушка! Что она сказала тебе?"
    ala "哦！你被她选中了！就像我的祖父一样！她对你说了什么？"

# game/a3/8alach.rpy:99
translate english alach_fast_45364604:

    # mc "Давайте сначала присядем."
    mc "我们先坐下吧。"

# game/a3/8alach.rpy:103
translate english alach_fast_b4852265:

    # mc "Спасибо, что показали мне это место."
    mc "谢谢您给我看了这个地方。"

# game/a3/8alach.rpy:104
translate english alach_fast_dc4eb76c:

    # ala "Только пусть это будет нашей тайной, ладно?"
    ala "不过，请让这成为我们之间的秘密，好吗？"

# game/a3/8alach.rpy:105
translate english alach_fast_c729b209:

    # mc "Ну конечно."
    mc "那当然。"

# game/a3/8alach.rpy:106
translate english alach_fast_7920a143:

    # ala "Вернемся во дворец?"
    ala "我们回王宫吧？"

# game/a3/8alach.rpy:107
translate english alach_fast_2361aa97:

    # mc "Да. Самое время."
    mc "是的。是该回去了。"

# game/a3/8alach.rpy:111
translate english alach2_47dd4df7:

    # ala "Что-то было не так? Она была зла на тебя или..."
    ala "有什么不对劲吗？她对你发怒了还是……"

# game/a3/8alach.rpy:112
translate english alach2_89ac9d6e:

    # mc "Нет. Дело не в этом. Она была не одна."
    mc "不。不是因为这个。她不是独自一人。"

# game/a3/8alach.rpy:113
translate english alach2_3323e384:

    # ala "Не одна?"
    ala "不是独自一人？"

# game/a3/8alach.rpy:114
translate english alach2_a3f7cb9c:

    # mc "С ней был Красный Император."
    mc "红皇帝和她在一起。"

# game/a3/8alach.rpy:115
translate english alach2_6dd55b57:

    # ala "Красный Император? Как? Они оба говорили с тобой здесь?"
    ala "红皇帝？怎么会？他们俩一起在这里和你说话？"

# game/a3/8alach.rpy:116
translate english alach2_fa6714a5:

    # mc "Да. Как только вы осветили это место я узнал его. Разве что в видениях это место было и так светлым."
    mc "是的。您一照亮这个地方，我就认出它来了。只是在幻象里，这地方本就是明亮的。"

# game/a3/8alach.rpy:117
translate english alach2_c5e0bf3d:

    # ala "Что они говорили?"
    ala "他们说了什么？"

# game/a3/8alach.rpy:118
translate english alach2_1a64aed0:

    # mc "Я ничего не понял. Они спорили друг с другом, пытались что-то мне показать."
    mc "我什么也没听懂。他们彼此争论，试图向我展示些什么。"

# game/a3/8alach.rpy:120
translate english alach2_138f9eb7:

    # ala "Видимо Мирта хотела тебя о чем-то предупредить. Но кровь Tenmir carandar попыталась помешать."
    ala "显然，米爾塔想警告你些什么。但是Tenmir carandar的血脉试图阻止。"

# game/a3/8alach.rpy:121
translate english alach2_5823b0b1:

    # mc "И что мне делать?"
    mc "那我该怎么办？"

# game/a3/8alach.rpy:122
translate english alach2_1d9e07ea:

    # ala "Мы должны попробовать дать тебе поговорить с ней снова."
    ala "我们可以尝试让你再和她交谈一次。"

# game/a3/8alach.rpy:123
translate english alach2_cf8ed562:

    # mc "Как?"
    mc "怎么做？"

# game/a3/8alach.rpy:124
translate english alach2_54f4b8cc:

    # ala "Я помогу. Клади голову ко мне на колени."
    ala "我会帮助你。把头枕到我膝盖上。"

# game/a3/8alach.rpy:126
translate english alach2_dfc5103b:

    # mc "Что вы будете делать?"
    mc "您要做什么？"

# game/a3/8alach.rpy:127
translate english alach2_762d6b87:

    # ala "Сеанс памяти."
    ala "进行一次记忆回溯。"

# game/a3/8alach.rpy:128
translate english alach2_cdfdf198:

    # mc "Как это поможет связаться с Миртой?"
    mc "这怎么帮助我和米爾塔取得联系？"

# game/a3/8alach.rpy:129
translate english alach2_725e5d69:

    # ala "Это будет сеанс памяти, но не твой. Этого места. "
    ala "这将是一次记忆回溯，但不是你的。是这个地方的记忆。"

# game/a3/8alach.rpy:130
translate english alach2_dfd24fbc:

    # mc "Память места? При чем тут я?"
    mc "地方的记忆？这和我有什么关系？"

# game/a3/8alach.rpy:131
translate english alach2_a2baee45:

    # ala "Ты связан с этим местом больше, чем думаешь, если Мирта и вправду пыталась говорить с тобой, мы должны попробовать."
    ala "如果米爾塔真的想和你说话，那你和这地方的关联比你想象的要深，我们必须试一试。"

# game/a3/8alach.rpy:133
translate english alach2_121216ab:

    # mc "У этого могут быть какие-то неприятные последствия?"
    mc "这会有什么不好的后果吗？"

# game/a3/8alach.rpy:134
translate english alach2_96474293:

    # ala "Не думаю. Разве, что у нас просто ничего не получится."
    ala "我觉得不会。最多就是我们什么结果也得不到。"

# game/a3/8alach.rpy:135
translate english alach2_1c3c18c8:

    # ala "Laurelin amin nauro sîr...Mirta..."
    ala "Laurelin amin nauro sîr...Mirta..."

# game/a3/8alach.rpy:136
translate english alach2_fd44a575:

    # mc "Я...что-что вижу...."
    mc "我……看到了一些什么……"

# game/a3/8alach.rpy:145
translate english alach_elf_fdd78ef0:

    # "Беременная женщина?"
    "Pregnant woman?"

# game/a3/8alach.rpy:146
translate english alach_elf_4aaea481:

    # "Где я?"
    "Where am I?"

# game/a3/8alach.rpy:147
translate english alach_elf_a36284c5:

    # "Это явно не пещера."
    "This is clearly not an underground temple."

# game/a3/8alach.rpy:148
translate english alach_elf_7783de09:

    # "А это явно просто эльфийка, а не богиня."
    "And this is clearly just an elf and not a goddess."

# game/a3/8alach.rpy:150
translate english alach_elf_b8a1021c:

    # alach_elf_boy "Mara! Маra! Tenmir carandar!"
    alach_elf_boy "玛拉！玛拉！Tenmir carandar！"

# game/a3/8alach.rpy:151
translate english alach_elf_428c37c7:

    # alach_elf_girl "Мама! Тут железные люди!"
    alach_elf_girl "妈妈！这里有铁人！"

# game/a3/8alach.rpy:153
translate english alach_elf_2ac65c28:

    # alach_elf_alianna "Я же просила вас не бегать в саду!"
    alach_elf_alianna "我让你们别在花园里跑来跑去的！"

# game/a3/8alach.rpy:154
translate english alach_elf_b3080bda:

    # alach_elf_boy "As deper're nihost!"
    alach_elf_boy "As deper're nihost!"

# game/a3/8alach.rpy:155
translate english alach_elf_daa36ad5:

    # alach_elf_girl "Mara...там! Mara там пришли!"
    alach_elf_girl "玛拉……那里！玛拉，他们来了！"

# game/a3/8alach.rpy:156
translate english alach_elf_f5abd733:

    # alach_elf_alianna "Успокойся! Что случилось?"
    alach_elf_alianna "冷静点！发生什么事了？"

# game/a3/8alach.rpy:157
translate english alach_elf_76eabd74:

    # alach_elf_girl "Es'uros!"
    alach_elf_girl "Es'uros!"

# game/a3/8alach.rpy:158
translate english alach_elf_a598baca:

    # alach_elf_alianna "Es'uros? Говори на всеобщем."
    alach_elf_alianna "Es'uros？说通用语。"

# game/a3/8alach.rpy:160
translate english alach_elf_18968aff:

    # alach_elf_girl "Безухие! Люди! Они вошли в поместье."
    alach_elf_girl "没耳朵的人！人类！他们进庄园了。"

# game/a3/8alach.rpy:161
translate english alach_elf_849b9767:

    # alach_elf_alianna "О чем ты говоришь? Война на востоке."
    alach_elf_alianna "你在说什么？战事在东方。"

# game/a3/8alach.rpy:162
translate english alach_elf_776230cb:

    # alach_elf_girl "Я знаю, там же где папа. Но мы только что ходили возле фонтанов и увидели людей!"
    alach_elf_girl "我知道，爸爸就在那里。但我们刚才在水池边玩，看到人类了！"

# game/a3/8alach.rpy:163
translate english alach_elf_d940e518:

    # alach_elf_alianna "Может вам показалось..."
    alach_elf_alianna "也许是你们看错了……"

# game/a3/8alach.rpy:164
translate english alach_elf_74683144:

    # alach_elf_girl "Нет! Это люди! Они короткоухие."
    alach_elf_girl "不！就是人类！他们是短耳朵的。"

# game/a3/8alach.rpy:165
translate english alach_elf_54a95802:

    # alach_elf_alianna "Ты уверена?"
    alach_elf_alianna "你确定吗？"

# game/a3/8alach.rpy:167
translate english alach_elf_a6d869f0:

    # alach_elf_boy "Ah! Nai, híni alat sí, aglare!"
    alach_elf_boy "Ah! Nai, híni alat sí, aglare!"

# game/a3/8alach.rpy:168
translate english alach_elf_e561ebaa:

    # alach_palad_gascoigne "Маленький эльф. Мы старались подойти незаметно, а ты все равно нас увидел?"
    alach_palad_gascoigne "小精灵。我们本想悄悄靠近，可你还是看见我们了？"

# game/a3/8alach.rpy:169
translate english alach_elf_aa4d8d21:

    # alach_palad_gascoigne "Твое зрение нам пригодится."
    alach_palad_gascoigne "你的视力对我们会有用的。"

# game/a3/8alach.rpy:171
translate english alach_elf_655b6c8d:

    # alach_elf_alianna "Не трогай его!"
    alach_elf_alianna "别碰他！"

# game/a3/8alach.rpy:172
translate english alach_elf_6eddde88:

    # alach_palad_gascoigne "Или что?"
    alach_palad_gascoigne "不然呢？"

# game/a3/8alach.rpy:173
translate english alach_elf_4c589d05:

    # alach_elf_alianna "Пожалуйста, это просто ребенок, не убивай его!"
    alach_elf_alianna "求你了，他只是个孩子，别杀他！"

# game/a3/8alach.rpy:174
translate english alach_elf_557ccb08:

    # alach_palad_gascoigne "Убивать? Я не собираюсь его убивать. Это солдат нашей будущей армии."
    alach_palad_gascoigne "杀他？我没打算杀他。这会是我们未来军队的一名士兵。"

# game/a3/8alach.rpy:176
translate english alach_elf_7cf45a01:

    # alach_palad_gascoigne "Верно говорю, ребята?"
    alach_palad_gascoigne "伙计们，我说得对吗？"

# game/a3/8alach.rpy:177
translate english alach_elf_64a6e84c:

    # alach_palad_zaharia "Верно, только ушки чуть подрежем."
    alach_palad_zaharia "说得对，不过得把耳朵稍微割一下。"

# game/a3/8alach.rpy:178
translate english alach_elf_d75845ad:

    # alach_palad_illis "И волосы углем подкрасим, а то больно уж на девку смахивает."
    alach_palad_illis "再把头发用炭涂黑，不然太像个丫头了。"

# game/a3/8alach.rpy:179
translate english alach_elf_4fcebb2f:

    # alach_elf_boy "Aglare's!"
    alach_elf_boy "Aglare's!"

# game/a3/8alach.rpy:181
translate english alach_elf_0085e835:

    # alach_palad_gascoigne "Он не говорит на всеобщем? Прискорбно. Придется его учить."
    alach_palad_gascoigne "他不会讲通用语？真可惜。得好好教他了。"

# game/a3/8alach.rpy:182
translate english alach_elf_4c068522:

    # alach_elf_alianna "Что вы...что вам нужно..."
    alach_elf_alianna "你们……你们想要什么……"

# game/a3/8alach.rpy:183
translate english alach_elf_8fe4046b:

    # alach_palad_gascoigne "Я же только что сказал. Мы рекрутеры. Набираем в армию. Твоему сыну посчастливилось стать ее частью."
    alach_palad_gascoigne "我刚才说过了。我们是征兵官，来征召入伍的。你儿子有幸能成为军队的一员。"

# game/a3/8alach.rpy:184
translate english alach_elf_cb255c82:

    # alach_elf_alianna "Зачем...зачем вы это делаете?"
    alach_elf_alianna "为什么……你们为什么要这么做？"

# game/a3/8alach.rpy:185
translate english alach_elf_bf930a11:

    # alach_palad_gascoigne "Было бы отлично победить эльфов, ведя в атаку эльфов, ну или хотя бы поставив их в первые ряды. Надо же кому-то принимать на себя ваши смертоносные стрелы, верно?"
    alach_palad_gascoigne "要是能让精灵领头冲锋去打败精灵，或者至少把他们放在第一排，那可就太棒了。总得有人去抵挡你们那些致命的箭矢，对吧？"

# game/a3/8alach.rpy:186
translate english alach_elf_f3f46725:

    # alach_elf_alianna "Зачем вы нас убиваете..."
    alach_elf_alianna "你们为什么要杀我们……"

# game/a3/8alach.rpy:187
translate english alach_elf_7ee875e7:

    # alach_palad_gascoigne "На земле нет места двум коронам. Вы не захотели подчиниться значит вас ждет смерть."
    alach_palad_gascoigne "这片土地上容不下两顶王冠。你们不愿臣服，那就意味着死亡。"

# game/a3/8alach.rpy:188
translate english alach_elf_8e0b0435:

    # alach_elf_alianna "Вы не победите...."
    alach_elf_alianna "你们不会赢的……"

# game/a3/8alach.rpy:190
translate english alach_elf_442b7f4e:

    # alach_palad_gascoigne "Уверена? Вы совершенно не умеете воевать. Что за идиоты оставляют тыл неприкрытым?"
    alach_palad_gascoigne "你确定吗？你们根本不会打仗。怎么会有这种白痴，把后方毫无防备地暴露出来？"

# game/a3/8alach.rpy:191
translate english alach_elf_64165893:

    # alach_elf_alianna "..."
    alach_elf_alianna "..."

# game/a3/8alach.rpy:192
translate english alach_elf_45019230:

    # alach_palad_gascoigne "Мы бы никогда не оставили своих жен, дочерей и стариков без защиты."
    alach_palad_gascoigne "我们绝不会让自己的妻子、女儿和老人毫无保护。"

# game/a3/8alach.rpy:193
translate english alach_elf_f3cf905a:

    # alach_elf_alianna "Мы бы никогда не стали сражаться с теми, кто не держит оружия."
    alach_elf_alianna "我们绝不会和那些手无寸铁的人战斗。"

# game/a3/8alach.rpy:194
translate english alach_elf_187bc612:

    # alach_palad_gascoigne "А ты и не можешь сражаться в твоем-то положении..."
    alach_palad_gascoigne "但你现在的状况……确实没法战斗……"

# game/a3/8alach.rpy:195
translate english alach_elf_0e1727fe:

    # alach_palad_gascoigne "Зато кое-кто внутри тебя однажды сможет."
    alach_palad_gascoigne "不过，你肚子里的那个，有朝一日却可以。"

# game/a3/8alach.rpy:196
translate english alach_elf_a544cf69:

    # alach_elf_alianna "Прошу...не надо...заберите меня...заберите меня и сына и..."
    alach_elf_alianna "求您……不要……抓走我吧……抓走我和我儿子，然后……"

# game/a3/8alach.rpy:197
translate english alach_elf_2b86066e:

    # alach_palad_gascoigne "Сына мы заберем. А вы нам ни к чему. Вы так медленно растете, что к тому времени как твой ублюдок сможет держать в руках меч война уже закончиться."
    alach_palad_gascoigne "儿子我们会带走。而您对我们毫无用处。你们长得多慢啊，等你的小崽子能拿得动剑的那天，战争早就结束了。"

# game/a3/8alach.rpy:199
translate english alach_elf_45fd744e:

    # alach_palad_gascoigne "А значит вот единственный выход!"
    alach_palad_gascoigne "所以，这是唯一的出路了！"

# game/a3/8alach.rpy:200
translate english alach_elf_234e9386:

    # alach_elf_alianna "ААААААААА!"
    alach_elf_alianna "啊啊啊啊啊！"

# game/a3/8alach.rpy:201
translate english alach_elf_30f31e80:

    # alach_palad_gascoigne "Ну что ты, не кричи, я же сказал, раз вы не хотите сдаваться - будете уничтожены."
    alach_palad_gascoigne "哎，你别喊啊，我说了，既然你们不肯投降——就得被消灭。"

# game/a3/8alach.rpy:203
translate english alach_elf_e316b064:

    # alach_palad_gascoigne "Отвратительные создания. Моя жена вцепилась бы зубами в горло, чтобы хотя бы попытаться отомстить перед смертью."
    alach_palad_gascoigne "令人作呕的生物。我的妻子就算是临死前，也会用牙咬住敌人的喉咙，至少试着报仇。"

# game/a3/8alach.rpy:204
translate english alach_elf_a3c4af9c:

    # alach_palad_gascoigne "А это... овцы на забое."
    alach_palad_gascoigne "而这些……简直是待宰的羔羊。"

# game/a3/8alach.rpy:205
translate english alach_elf_7ee79560:

    # alach_palad_zaharia "Хорошее местечко. Я, когда война закончится, пожалуй перееду сюда."
    alach_palad_zaharia "这地方真不错。等战争结束了，我大概会搬到这里来。"

# game/a3/8alach.rpy:206
translate english alach_elf_b422ed76:

    # alach_palad_illis "Мечтай. Эльфы жгут все, когда отступают."
    alach_palad_illis "做梦吧。精灵撤退的时候会把一切都烧掉。"

# game/a3/8alach.rpy:207
translate english alach_elf_a17706ca:

    # alach_palad_gascoigne "Пусть жгут. От их мира ничего не останется. На этом континенте наступает эпоха людей."
    alach_palad_gascoigne "让他们烧去吧。他们的世界什么都不会剩下。这片大陆上，人类的时代来临了。"

# game/a3/8alach.rpy:208
translate english alach_elf_30f27f64:

    # alach_palad_zaharia "Хорошо сказано."
    alach_palad_zaharia "说得好。"

# game/a3/8alach.rpy:209
translate english alach_elf_eb7145c9:

    # alach_palad_illis "За это надо выпить. Я видел тут бочки с вином."
    alach_palad_illis "为这个可得喝一杯。我刚才看到那边有几桶葡萄酒。"

# game/a3/8alach.rpy:211
translate english alach_elf_cb5d26b6:

    # alach_palad_gascoigne "Никакого вина. Здесь еще много усадеб, нас ждет много работы."
    alach_palad_gascoigne "喝什么酒。还有好多庄园等着我们呢，活儿多着呢。"

# game/a3/8alach.rpy:212
translate english alach_elf_aa3bcb78:

    # alach_palad_zaharia "Эх...а вино то они умеют делать."
    alach_palad_zaharia "唉……但他们的酒酿得是真不错。"

# game/a3/8alach.rpy:213
translate english alach_elf_f5411503:

    # alach_palad_illis "Надо бы выпытать у них пару секретов."
    alach_palad_illis "得从他们嘴里撬出几个秘方才行。"

# game/a3/8alach.rpy:214
translate english alach_elf_0f3b79b8:

    # alach_palad_gascoigne "Пойдем уже."
    alach_palad_gascoigne "走吧。"

# game/a3/8alach.rpy:216
translate english alach_elf_4d35b947:

    # alach_elf_girl "Mara....mara!"
    alach_elf_girl "Mara....mara!"

# game/a3/8alach.rpy:217
translate english alach_elf_17d957a3:

    # alach_elf_alianna "Abey'an..."
    alach_elf_alianna "Abey'an..."

# game/a3/8alach.rpy:218
translate english alach_elf_2a7b62de:

    # alach_elf_girl "Nin septura....."
    alach_elf_girl "Nin septura....."

# game/a3/8alach.rpy:219
translate english alach_elf_59e07c9f:

    # alach_elf_girl "Salanori, Nin septura..."
    alach_elf_girl "Salanori, Nin septura..."

# game/a3/8alach.rpy:221
translate english alach_elf_bc850f86:

    # "Она умоляет мать не умирать..."
    "She's begging her mother not to die..."

# game/a3/8alach.rpy:222
translate english alach_elf_0e6191f9:

    # alach_palad_gascoigne "Да уж...вас совсем ничему не учат, кроме песен и танцев?"
    alach_palad_gascoigne "唉……你们除了唱歌跳舞，就真的什么都没人教吗？"

# game/a3/8alach.rpy:224
translate english alach_elf_d07ae263:

    # alach_palad_gascoigne "Правило охоты - за детенышами бегать не обязательно. Убей их мать и они выползут сами."
    alach_palad_gascoigne "狩猎法则——不必去追那些幼崽。杀了它们的母亲，它们自会爬出来。"

# game/a3/8alach.rpy:225
translate english alach_elf_0eb45a71:

    # alach_palad_gascoigne "Не бойся, тебя я убивать не буду. Если будешь послушной девочкой для тебя найдется место в новом мире."
    alach_palad_gascoigne "别怕，我是不会杀你的。只要你当个听话的小丫头，在新世界里会有你的位置的。"

# game/a3/8alach.rpy:226
translate english alach_elf_9c647d18:

    # alach_palad_gascoigne "В мире людей."
    alach_palad_gascoigne "在人类的世界里。"

# game/a3/8alach.rpy:227
translate english alach_elf_819065cb:

    # "Я...чувствую родство...с девочкой...и с этим человеком...они оба мои предки..."
    "I...feel a kinship...with a girl...and with this human...they are both my ancestors..."

# game/a3/8alach.rpy:228
translate english alach_elf_6c269070:

    # "Я чувствую как кровь внутри них бурлит. Как она сливается в один поток."
    "I can feel the blood rushing inside them. How it merges into one stream."

# game/a3/8alach.rpy:229
translate english alach_elf_a60f6daf:

    # "Они во мне. Их память."
    "They're in me. Their memory."

# game/a3/8alach.rpy:233
translate english alach_king_7737eeed:

    # alach_palad_zaharia "В долине сожгли обоз с зерном для армии. Наверное нас снова пошлют оборонять тракт."
    alach_palad_zaharia "山谷那边，他们给军队运粮的车队被烧了。大概又得派我们去守卫那条大路了。"

# game/a3/8alach.rpy:234
translate english alach_king_1cc3bced:

    # alach_palad_gascoigne "Чем дольше идет эта война, тем больше я понимаю, что мы не увидим ее конца."
    alach_palad_gascoigne "这仗打得越久，我就越发觉得我们看不到它结束了。"

# game/a3/8alach.rpy:235
translate english alach_king_3b10b0de:

    # alach_palad_zaharia "Может наши дети?"
    alach_palad_zaharia "也许我们的孩子能看到？"

# game/a3/8alach.rpy:236
translate english alach_king_28873f6e:

    # alach_palad_gascoigne "Может. А может эльфы будут воевать вечно."
    alach_palad_gascoigne "也许。也许精灵们会一直打下去，打个没完。"

# game/a3/8alach.rpy:237
translate english alach_king_1a2fbaf7:

    # alach_palad_zaharia "В каком смысле?"
    alach_palad_zaharia "什么意思？"

# game/a3/8alach.rpy:238
translate english alach_king_36a515bc:

    # alach_palad_gascoigne "Сначала они только что и делали, что проигрывали битвы. А сейчас они решили не биться вовсе."
    alach_palad_gascoigne "一开始，他们除了打败仗什么也不会。现在倒好，他们干脆不正面交战了。"

# game/a3/8alach.rpy:239
translate english alach_king_f37a954b:

    # alach_palad_zaharia "Вырежем их под корень и дело с концом."
    alach_palad_zaharia "把他们连根拔除，这事儿就了结了。"

# game/a3/8alach.rpy:241
translate english alach_king_99f6acec:

    # alach_palad_gascoigne "Легче сказать, чем сделать, они знают эти земли. Могут прятаться в них, как крысы, хоть сотню лет."
    alach_palad_gascoigne "说得容易做到难，他们熟悉这片土地。可以像老鼠一样藏在里面，藏上一百年。"

# game/a3/8alach.rpy:242
translate english alach_king_ff855025:

    # alach_palad_zaharia "Ну...может с ними договоримся, как с полуросликами."
    alach_palad_zaharia "嗯……也许能跟他们谈谈，像对半身人那样达成协议。"

# game/a3/8alach.rpy:243
translate english alach_king_3e729243:

    # alach_palad_gascoigne "Этого я и боюсь. Дворфы от нас почти не пострадали, у них нет такого пространства для ресентимента."
    alach_palad_gascoigne "这正是我担心的。矮人几乎没受到什么损害，他们没有那么多滋生怨恨的理由。"

# game/a3/8alach.rpy:244
translate english alach_king_efd83a38:

    # alach_palad_zaharia "А?"
    alach_palad_zaharia "啊？"

# game/a3/8alach.rpy:245
translate english alach_king_63a9ca1f:

    # alach_palad_gascoigne "Они будут мстить. Мы забрали их земли, их жизни. Они будут помнить об этом всегда, какие бы соглашения мы не заключали."
    alach_palad_gascoigne "他们会报仇的。我们夺走了他们的土地，他们的生命。他们会永远记住这些，无论我们签订什么样的协议。"

# game/a3/8alach.rpy:246
translate english alach_king_3820d67e:

    # alach_palad_zaharia "Значит продолжим убивать их, да?"
    alach_palad_zaharia "那就是说，继续杀他们，对吧？"

# game/a3/8alach.rpy:247
translate english alach_king_9e6d03ae:

    # alach_palad_illis "ЭЛЬФЫ!"
    alach_palad_illis "有精灵！"

# game/a3/8alach.rpy:249
translate english alach_king_767eed5a:

    # alach_palad_gascoigne "ТВОЮ МАТЬ..."
    alach_palad_gascoigne "他妈的……"

# game/a3/8alach.rpy:250
translate english alach_king_d95f56d9:

    # alach_palad_gascoigne "ЗА ОРУЖИЕ!"
    alach_palad_gascoigne "抄家伙！"

# game/a3/8alach.rpy:252
translate english alach_king_33495142:

    # alach_elf_gallivan "СДАВАЙТЕСЬ, УБЛЮДКИ!"
    alach_elf_gallivan "投降吧，你们这些杂种！"

# game/a3/8alach.rpy:253
translate english alach_king_4bb8f227:

    # alach_elf_gallivan "Бросайте оружие и мы сохраним вам жизнь!"
    alach_elf_gallivan "放下武器，我们就饶你们一命！"

# game/a3/8alach.rpy:255
translate english alach_king_85a74b2e:

    # alach_elf_jankoy "ЗА ПРАОТЦОВ!"
    alach_elf_jankoy "为了先祖！"

# game/a3/8alach.rpy:256
translate english alach_king_c1fa5d1b:

    # alach_palad_zaharia "ТЫ ОТПРАВИШЬСЯ К НИМ СКОРО, ЭЛЬФ."
    alach_palad_zaharia "你很快就会去见他们了，精灵。"

# game/a3/8alach.rpy:258
translate english alach_king_e116b018:

    # alach_palad_illis "Кто-нибудь, скачите в..."
    alach_palad_illis "来人，快骑马去……"

# game/a3/8alach.rpy:259
translate english alach_king_c3a8de0a:

    # alach_elf_fiona "Ты уже доскакался, человек."
    alach_elf_fiona "你已经骑到头了，人类。"

# game/a3/8alach.rpy:260
translate english alach_king_66905ec6:

    # alach_elf_fiona "Сдавайтесь или будете убиты все!"
    alach_elf_fiona "投降，否则格杀勿论！"

# game/a3/8alach.rpy:262
translate english alach_king_6b650f44:

    # alach_elf_gallivan "Убивайтесь всех, кто держит в руках оружие!"
    alach_elf_gallivan "杀光所有拿武器的人！"

# game/a3/8alach.rpy:263
translate english alach_king_5c00a2bc:

    # alach_elf_fiona "Это все. Здесь было только трое."
    alach_elf_fiona "就这么多了。这里只有三个。"

# game/a3/8alach.rpy:264
translate english alach_king_e40762ea:

    # alach_elf_jankoy "Septura Marda..."
    alach_elf_jankoy "Septura Marda..."

# game/a3/8alach.rpy:265
translate english alach_king_abd1a884:

    # alach_elf_gallivan "Говори на всеобщем, их друзья могут быть рядом."
    alach_elf_gallivan "说通用语，说不定他们的同伙就在附近。"

# game/a3/8alach.rpy:266
translate english alach_king_7dfcd460:

    # alach_elf_jankoy "Это отряд смерти."
    alach_elf_jankoy "这是死亡小队。"

# game/a3/8alach.rpy:268
translate english alach_king_f92e7320:

    # alach_elf_gallivan "Да. Я узнал их по форме. Эльфы ушли из своих домов и этим ублюдкам стало некого резать."
    alach_elf_gallivan "对，看制服我认出来了。精灵们都离开了自己的家，这些杂种没处可砍了。"

# game/a3/8alach.rpy:269
translate english alach_king_fb42f400:

    # alach_elf_fiona "У них многовато припасов для троих."
    alach_elf_fiona "他们带的补给对于三个人来说有点多。"

# game/a3/8alach.rpy:270
translate english alach_king_75144a0d:

    # alach_elf_jankoy "Наверное их переформатировали в патруль. Тройки охраняют тракт от нас. Трое идут на север, трое на юг. Третяя тройка отдыхает."
    alach_elf_jankoy "大概被改编成巡逻队了。三人小队负责守卫大路，不让我们靠近。三个人往北，三个人往南，第三队休息。"

# game/a3/8alach.rpy:271
translate english alach_king_6e9e4d77:

    # alach_elf_gallivan "Можем устроить засаду для остальных."
    alach_elf_gallivan "我们可以给剩下的人设个埋伏。"

# game/a3/8alach.rpy:272
translate english alach_king_e1a074d4:

    # alach_elf_fiona "Будешь переодеваться в их вонючие одежды?"
    alach_elf_fiona "你要换上他们那些臭烘烘的衣服吗？"

# game/a3/8alach.rpy:273
translate english alach_king_b34b5f0e:

    # alach_elf_jankoy "Прости, ты точно не забыла, что находишься на войне?"
    alach_elf_jankoy "抱歉，你是不是忘了自己还在打仗？"

# game/a3/8alach.rpy:275
translate english alach_king_1c0135b1:

    # alach_elf_fiona "Alga'sakari, Мрази...эти отрезают уши. Es Uros!"
    alach_elf_fiona "Alga'sakari，卑鄙的家伙……他们竟然割耳朵。Es Uros！"

# game/a3/8alach.rpy:276
translate english alach_king_ab6f0dcc:

    # alach_elf_jankoy "Им за это платят. Значит это точно Septura Marda. Стоило убить их даже если бы они сдались."
    alach_elf_jankoy "他们可是拿钱干这事的。所以这肯定是Septura Marda部队。就算他们投降也该杀。"

# game/a3/8alach.rpy:277
translate english alach_king_5b033e76:

    # alach_elf_fiona "Мы сражаемся с чудовищами..."
    alach_elf_fiona "我们是在和野兽作战……"

# game/a3/8alach.rpy:278
translate english alach_king_3f7ce67a:

    # alach_elf_jankoy "Надо сразу было вести войну по-другому."
    alach_elf_jankoy "一开始就该换个方式打这场仗。"

# game/a3/8alach.rpy:280
translate english alach_king_4c71227b:

    # alach_elf_gallivan "Поздно об этом думать. Когда они только высаживались со своих кораблей, они даже не знали, как выплавлять железо, а теперь гляньте..."
    alach_elf_gallivan "现在想这个太迟了。他们刚从船上来，连怎么炼铁都不知道的时候，再瞧瞧现在……"

# game/a3/8alach.rpy:281
translate english alach_king_ffef40bc:

    # alach_elf_gallivan "Даже кружки из железа делают. Теперь они называют себя железными людьми."
    alach_elf_gallivan "连杯子都用铁做了。现在他们管自己叫“铁人”。"

# game/a3/8alach.rpy:282
translate english alach_king_7236d0d4:

    # alach_elf_fiona "Мы и сами изменились, Гэлливан. В худшую сторону... Я все еще помню, что ты сделал в долине..."
    alach_elf_fiona "我们自己也在变，Gallivan。变得更糟……我还记得你在山谷做的事……"

# game/a3/8alach.rpy:283
translate english alach_king_2569a661:

    # alach_elf_jankoy "Всё крадут у нас. Живут в наших городах, будто сами их строили, пользуются нашими технологиями, крадут наших детей и женщин..."
    alach_elf_jankoy "他们什么都偷我们的。住在我们的城市里，好像城市是他们建的，用我们的技术，偷走我们的孩子和女人……"

# game/a3/8alach.rpy:284
translate english alach_king_cc1693ea:

    # alach_elf_gallivan "Хватит. Достаточно разговоров. Давайте сожжем это место."
    alach_elf_gallivan "够了。别说废话了。我们把这地方烧了吧。"

# game/a3/8alach.rpy:286
translate english alach_king_a90f2b4b:

    # alach_palad_gascoigne "Значит ты у них главный?"
    alach_palad_gascoigne "这么说，你是他们的头儿？"

# game/a3/8alach.rpy:287
translate english alach_king_95913fa1:

    # alach_elf_gallivan "Этот живой! Кто проверял тела?"
    alach_elf_gallivan "这个还活着！是谁检查的尸体？"

# game/a3/8alach.rpy:288
translate english alach_king_9477f175:

    # alach_palad_gascoigne "Не вини свой отряд, я очень убедительно притворяюсь мертвым."
    alach_palad_gascoigne "别怪你的小队，我装死装得很逼真。"

# game/a3/8alach.rpy:289
translate english alach_king_b53da1de:

    # "Я...чувствую родство...моя кровь..."
    "I...feel a kinship...my blood..."

# game/a3/8alach.rpy:290
translate english alach_king_afc52c23:

    # "Моя кровь течет в них обоих..."
    "My blood runs in both of them..."

# game/a3/8alach.rpy:291
translate english alach_king_25e15edf:

    # "Их кровь...она во мне...этот эльф и человек оба мои предки..."
    "Their blood...it's in me...this elf and human are both my ancestors..."

# game/a3/8alach.rpy:292
translate english alach_king_4be5310f:

    # alach_palad_gascoigne "Не двигайся, эльф или железо это клинка окажется у тебя в мозгах."
    alach_palad_gascoigne "别动，精灵，不然我剑刃的铁器就插进你脑袋里了。"

# game/a3/8alach.rpy:293
translate english alach_king_3e905322:

    # alach_elf_gallivan "Чего тебе нужно?"
    alach_elf_gallivan "你想要什么？"

# game/a3/8alach.rpy:294
translate english alach_king_52ceaba7:

    # alach_palad_gascoigne "Мне? Это вы на нас напали, забыл?"
    alach_palad_gascoigne "我？是你们袭击了我们，忘了吗？"

# game/a3/8alach.rpy:296
translate english alach_king_6cbc1c70:

    # alach_elf_fiona "Отпусти его."
    alach_elf_fiona "放开他。"

# game/a3/8alach.rpy:297
translate english alach_king_a9d39b1b:

    # alach_palad_gascoigne "Ага. Я похож на идиота?"
    alach_palad_gascoigne "哈，我看着像个白痴吗？"

# game/a3/8alach.rpy:298
translate english alach_king_6839bb67:

    # alach_elf_jankoy "Отпустишь его и мы тебя не тронем. Отправишься к своим."
    alach_elf_jankoy "你放了他，我们就不动你。放你回自己人那里去。"

# game/a3/8alach.rpy:299
translate english alach_king_699c9d11:

    # alach_palad_gascoigne "Да что вы, просто так отпустите своего врага? Что за идиотизм?"
    alach_palad_gascoigne "怎么，竟然就这么放敌人走？这是什么蠢事？"

# game/a3/8alach.rpy:300
translate english alach_king_8f4102d8:

    # alach_elf_jankoy "Да. Даем слово."
    alach_elf_jankoy "是的。我们给予承诺。"

# game/a3/8alach.rpy:301
translate english alach_king_572e4145:

    # alach_palad_gascoigne "..."
    alach_palad_gascoigne "..."

# game/a3/8alach.rpy:302
translate english alach_king_1ea98aad:

    # alach_elf_gallivan "В отличие от вас, мы всегда держим слово и соблюдаем правила войны!"
    alach_elf_gallivan "和你们不一样，我们永远信守诺言，遵守战争规则！"

# game/a3/8alach.rpy:303
translate english alach_king_6712628e:

    # alach_palad_gascoigne "Хех...я думал вы поменяетесь, но теперь я спокоен..."
    alach_palad_gascoigne "哈……我以为你们会改变，但现在我放心了……"

# game/a3/8alach.rpy:305
translate english alach_king_fa8a90db:

    # alach_palad_gascoigne "Вы проиграете! У войны нет правил, идиоты!"
    alach_palad_gascoigne "你们会输的！战争没有规则，白痴！"

# game/a3/8alach.rpy:306
translate english alach_king_1b8a4710:

    # alach_elf_gallivan "АААГРХ!"
    alach_elf_gallivan "啊啊啊啊！"

# game/a3/8alach.rpy:307
translate english alach_king_4e36a6e0:

    # alach_elf_jankoy "AGLAR'E!"
    alach_elf_jankoy "AGLAR'E!"

# game/a3/8alach.rpy:308
translate english alach_king_500eba30:

    # alach_palad_gascoigne "ЗА ЛЮДЕЙ! БУДЕТ ИХ ВЛАСТЬ СИЛЬНА И ВЕЧНА!"
    alach_palad_gascoigne "为了人类！愿人类的统治强大而永恒！"

# game/a3/8alach.rpy:310
translate english alach_king_1c9414d6:

    # alach_elf_fiona "ТЫ ВЫБРАЛ СМЕРТЬ!"
    alach_elf_fiona "你选择了死亡！"

# game/a3/8alach.rpy:311
translate english alach_king_4ab70683:

    # "Я БУДТО УМЕР ДВАЖДЫ! МОЯ ГОЛОВА!"
    "IT'S LIKE I'VE DIED TWICE! MY HEAD!"

# game/a3/8alach.rpy:315
translate english alach_human_efe68f22:

    # alach_human_peter "Давайте здесь."
    alach_human_peter "就在这里吧。"

# game/a3/8alach.rpy:316
translate english alach_human_1c3466fe:

    # alach_human_lisa "Ты дурак?"
    alach_human_lisa "你傻吗？"

# game/a3/8alach.rpy:317
translate english alach_human_4df934ba:

    # alach_human_peter "А что? Здесь хорошее место для дома."
    alach_human_peter "怎么了？这地方建房子多好。"

# game/a3/8alach.rpy:318
translate english alach_human_7e5b3f18:

    # alach_human_lisa "И из чего ты дом строить собрался? Видишь здесь много деревьев?"
    alach_human_lisa "那你打算用什么建房子呢？你看到这儿有很多树吗？"

# game/a3/8alach.rpy:320
translate english alach_human_f0b16097:

    # alach_human_peter "Можно как эльфы строить из камней."
    alach_human_peter "可以像精灵那样用石头建。"

# game/a3/8alach.rpy:321
translate english alach_human_cd6920bf:

    # alach_human_lisa "Да что ты. И ты знаешь как?"
    alach_human_lisa "哎哟，你知道怎么建吗？"

# game/a3/8alach.rpy:322
translate english alach_human_8a3018ef:

    # alach_human_peter "Нет. Но можно научится."
    alach_human_peter "不知道。但可以学嘛。"

