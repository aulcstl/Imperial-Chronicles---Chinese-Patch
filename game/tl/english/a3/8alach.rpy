translate english alach_human_7440812d:

    # alach_elf_gallivan "Ну что там?"
    alach_elf_gallivan "那边怎么样？"

# game/a3/8alach.rpy:346
translate english alach_human_c89c0f0e:

    # alach_elf_fiona "Зерно. Кожа. В бочках вино."
    alach_elf_fiona "谷物。皮革。桶里装的是酒。"

# game/a3/8alach.rpy:347
translate english alach_human_d2dee28a:

    # alach_elf_jankoy "Наверняка награбленное."
    alach_elf_jankoy "肯定是抢来的。"

# game/a3/8alach.rpy:348
translate english alach_human_6e8f3b52:

    # alach_elf_fiona "Пахнет плохо. Кожа жесткая. Кажется это действительно их вещи."
    alach_elf_fiona "味道不好闻。皮革很硬。好像还真是他们自己用的东西。"

# game/a3/8alach.rpy:349
translate english alach_human_3803f799:

    # alach_elf_jankoy "Значит это припасы. Везут в лагерь."
    alach_elf_jankoy "那就是补给。正往营地里送。"

# game/a3/8alach.rpy:351
translate english alach_human_d2092915:

    # alach_human_lisa "Они убили папу..."
    alach_human_lisa "他们杀了爸爸……"

# game/a3/8alach.rpy:352
translate english alach_human_254e06ab:

    # alach_human_hannah "Не смотри туда, милая..."
    alach_human_hannah "别往那边看，亲爱的……"

# game/a3/8alach.rpy:353
translate english alach_human_4dbcd4f7:

    # alach_elf_fiona "Я думаю это действительно просто фермеры, твой информатор солгал."
    alach_elf_fiona "我想这真的只是些农民，你的线人撒谎了。"

# game/a3/8alach.rpy:354
translate english alach_human_ed547b44:

    # alach_elf_gallivan "Чушь. Специально пускают обозы под видом фермеров, чтобы мы не нападали."
    alach_elf_gallivan "胡说。他们是故意假扮成农民派出的车队，好让我们不攻击。"

# game/a3/8alach.rpy:355
translate english alach_human_387b8fd0:

    # alach_elf_fiona "Гэлливан, по-твоему, у них так мало солдат?"
    alach_elf_fiona "Gallivan，你觉得他们士兵少成这样了吗？"

# game/a3/8alach.rpy:356
translate english alach_human_662e1d83:

    # alach_elf_gallivan "Они пойдут на любую хитрость, это же люди, мы должны бороться с ними, также как и они с нами, если мы хотим победить."
    alach_elf_gallivan "他们会用任何诡计，这毕竟是人类，如果我们想赢，也必须像他们对付我们一样对付他们。"

# game/a3/8alach.rpy:358
translate english alach_human_2f9c0987:

    # alach_elf_gallivan "Это война на уничтожения, Фиона."
    alach_elf_gallivan "这是一场灭绝之战，Fiona。"

# game/a3/8alach.rpy:359
translate english alach_human_ee658774:

    # alach_elf_fiona "Что ты собрался сделать?"
    alach_elf_fiona "你想干什么？"

# game/a3/8alach.rpy:360
translate english alach_human_13e3ef48:

    # alach_elf_gallivan "Вы же ничего не расскажете?"
    alach_elf_gallivan "你们不会说出去吧？"

# game/a3/8alach.rpy:361
translate english alach_human_63d30962:

    # alach_human_hannah "Нет! Клянемся богами! Мы ничего не расскажем!"
    alach_human_hannah "不！我们向众神发誓！我们什么也不会说出去！"

# game/a3/8alach.rpy:362
translate english alach_human_d1b82dae:

    # alach_elf_gallivan "Неверный ответ."
    alach_elf_gallivan "错误的回答。"

# game/a3/8alach.rpy:363
translate english alach_human_f38b59e9:

    # alach_elf_fiona "Гэлливан!"
    alach_elf_fiona "Gallivan！"

# game/a3/8alach.rpy:365
translate english alach_human_25e3efbb:

    # alach_human_hannah "АГРХ!"
    alach_human_hannah "啊！"

# game/a3/8alach.rpy:366
translate english alach_human_a6e070f4:

    # alach_human_lisa "МАМА!"
    alach_human_lisa "妈妈！"

# game/a3/8alach.rpy:367
translate english alach_human_34e3f181:

    # alach_elf_fiona "Что ты делаешь!? Ты спятил!?"
    alach_elf_fiona "你在干什么？！你疯了吗？！"

# game/a3/8alach.rpy:368
translate english alach_human_1231336e:

    # alach_elf_gallivan "Кровь за кровь, Фиона. Пора взять на вооружение их методы."
    alach_elf_gallivan "血债血偿，Fiona。是时候该用用他们的手段了。"

# game/a3/8alach.rpy:369
translate english alach_human_7ecd6cae:

    # alach_elf_fiona "Мы сражаемся, не для того, чтобы стать такими же как они!"
    alach_elf_fiona "我们战斗，不是为了变得和他们一样！"

# game/a3/8alach.rpy:370
translate english alach_human_b4048804:

    # alach_elf_gallivan "Мы сражаемся чтобы победить."
    alach_elf_gallivan "我们战斗是为了胜利。"

# game/a3/8alach.rpy:372
translate english alach_human_c59e05bd:

    # alach_elf_jankoy "Девчонка убегает."
    alach_elf_jankoy "那个小丫头跑了。"

# game/a3/8alach.rpy:373
translate english alach_human_cdd7d52b:

    # alach_elf_gallivan "Пусть убегает. Кто-то должен рассказать, что эльфы в долине убивают всех, кто осмеливается ехать по тракту."
    alach_elf_gallivan "由她去跑。总得有人去传话，说山谷里的精灵会杀死所有胆敢在大路上走的人。"

# game/a3/8alach.rpy:374
translate english alach_human_7330631b:

    # alach_elf_fiona "Я этого не одобряю. Это ужасно."
    alach_elf_fiona "我不赞成这事。这太可怕了。"

# game/a3/8alach.rpy:375
translate english alach_human_cc37c2a7:

    # alach_elf_gallivan "Правда? А мне казалось это твоя стрела попала бедолаге в голову."
    alach_elf_gallivan "是吗？可我分明看到是您的箭射中了那可怜家伙的头。"

# game/a3/8alach.rpy:376
translate english alach_human_9a593a60:

    # alach_elf_fiona "Я не знала, что фермеры, мы выслеживали военные обозы, забыл? А это...это совершенно другое."
    alach_elf_fiona "我不知道他们是农民，我们追踪的是军用辎重车队，你忘了吗？而这是……这完全是另一回事。"

# game/a3/8alach.rpy:377
translate english alach_human_20fe1a07:

    # alach_elf_gallivan "Не расстраивайся, у тебя еще есть возможность проявить сострадание. Доверяю судьбу мальчишки, спрятавшегося под телегой, тебе."
    alach_elf_gallivan "别难过，你还有机会表现你的同情心。我把藏在车下那个男孩的命运交给你处置。"

# game/a3/8alach.rpy:378
translate english alach_human_afc8ac18:

    # "Я...чувствую как кровь внутри этого мальчишки бурлит... Он мой предок...да..."
    "I ... can feel the blood rushing inside this boy... He's my ancestor...yes..."

# game/a3/8alach.rpy:379
translate english alach_human_4a5bf617:

    # "И этот эльф... что убил женщину...его кровь...он тоже мой предок."
    "And this elf..his blood...he's also my ancestor."

# game/a3/8alach.rpy:380
translate english alach_human_26fed4ff:

    # "Как это...во мне течет кровь их обоих...."
    "I have the blood of both of them in me..."

# game/a3/8alach.rpy:384
translate english alach3_076032ed:

    # mc "Аххх!!"
    mc "啊！！"

# game/a3/8alach.rpy:385
translate english alach3_2b97e750:

    # ala "Ты в порядке? Она говорила с тобой?"
    ala "你没事吧？她跟你说话了吗？"

# game/a3/8alach.rpy:386
translate english alach3_d17cc328:

    # mc "Что? Кто? Кто говорил?"
    mc "什么？谁？谁说话了？"

# game/a3/8alach.rpy:387
translate english alach3_43cb89fb:

    # ala "Мирта."
    ala "米爾塔。"

# game/a3/8alach.rpy:388
translate english alach3_a28a9261:

    # mc "Нет. Нет она со мной не говорила."
    mc "没有。没有，她没跟我说话。"

# game/a3/8alach.rpy:389
translate english alach3_50ac4585:

    # ala "Ты что-то видел."
    ala "你看到了什么。"

# game/a3/8alach.rpy:391
translate english alach3_bc5b427b:

    # mc "Лучше бы я этого не видел никогда."
    mc "我宁愿从没看到过。"

# game/a3/8alach.rpy:392
translate english alach3_3959782a:

    # ala "Что...что там было."
    ala "那里……那里发生了什么。"

# game/a3/8alach.rpy:393
translate english alach3_b8db643a:

    # mc "Не было там никакой Мирты. Было прошлое."
    mc "那里根本没有什么米爾塔。有的是过去。"

# game/a3/8alach.rpy:394
translate english alach3_90a90f24:

    # ala "Прошлое этого места?"
    ala "这地方的过去？"

# game/a3/8alach.rpy:395
translate english alach3_2ebf42d0:

    # mc "Прошлое моей крови...я видел своих предков. Предков от обоих народов. Я чувствовал в них свою кровь."
    mc "是我血脉的过去……我看到了我的祖先。两个民族的祖先。我能在他们身上感觉到我的血。"

# game/a3/8alach.rpy:396
translate english alach3_ce2b2141:

    # ala "Они разговаривали?"
    ala "他们说话了吗？"

# game/a3/8alach.rpy:398
translate english alach3_db8e7000:

    # mc "Разговаривали? Они убивали. Их кровь шептала мне. Шептала, мне что я их общий сын, сын великой войны."
    mc "说话？他们在杀戮。他们的血低语着告诉我。低语告诉我，我是他们共同的儿子，那场伟大战争的儿子。"

# game/a3/8alach.rpy:399
translate english alach3_5b417c6a:

    # ala "Может...может Мирта хотела тебе этим что-то показать?"
    ala "也许……也许米爾塔是想通过这个向你展示些什么？"

# game/a3/8alach.rpy:400
translate english alach3_61ff4a24:

    # mc "Я не думаю, что это Мирта. Это место...не зря в нем был Красный Император. Оно как-то объединяет два моих начала. Людское и Эльфийское."
    mc "我不觉得这是米爾塔。这地方……难怪红皇帝会出现在这里。它仿佛连接着我的两个本源。人的和精灵的。"

# game/a3/8alach.rpy:401
translate english alach3_02ba085e:

    # ala "Хочешь еще..."
    ala "你想再……"

# game/a3/8alach.rpy:402
translate english alach3_81299e24:

    # mc "Нет. С меня хватит. Я уже насмотрелся ужасов прошлого. Я вижу причин продолжать."
    mc "不。我受够了。我已经看够了过去的恐怖。我看不出有什么理由继续下去。"

# game/a3/8alach.rpy:403
translate english alach3_1b706bc8:

    # ala "...вернемся во дворец."
    ala "……我们回王宫吧。"

# game/a3/8alach.rpy:404
translate english alach3_622a8ee9:

    # mc "Пожалуй. Спасибо, что показала мне этого место."
    mc "好吧。谢谢你向我展示了这个地方。"

# game/a3/8alach.rpy:405
translate english alach3_e0219137:

    # ala "Если вдруг захочется заглянуть в прошлое еще раз - знаешь, где меня искать."
    ala "如果将来你还想再窥探过去——你知道该去哪里找我。"

translate english strings:

    # game/a3/8alach.rpy:88
    old "Рассказать ей что видел это место в видениях"
    new "告诉她，我在幻象中见过这个地方。"

    # game/a3/8alach.rpy:88
    old "Не говорить ей об этом"
    new "不要告诉她这件事。"

