translate english alach_human_ae370bae:

    # alach_human_lisa "О боги, папа!"
    alach_human_lisa "哦，众神啊，爸爸！"

# game/a3/8alach.rpy:342
translate english alach_human_23a91116:

    # alach_human_hannah "У нас нет оружия, мы простые фермеры, ищем землю, где осесть."
    alach_human_hannah "我们没有武器，我们只是普通的农民，在找地方安家。"

# game/a3/8alach.rpy:343
translate english alach_human_482d53f1:

    # alach_elf_jankoy "Это мы сейчас проверим."
    alach_elf_jankoy "这我们得检查一下。"

