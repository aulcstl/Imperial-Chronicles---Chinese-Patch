# game/a3/3trainingday.rpy:260
translate english training_day_strength_0a843fe7:

    # mc "Давно ты стала так рьяно чтить правила?"
    mc "你什么时候变得这么死守规则了？"

# game/a3/3trainingday.rpy:261
translate english training_day_strength_26928e71:

    # cass "[mename]...отпусти..."
    cass "[mename]……放开……"

# game/a3/3trainingday.rpy:262
translate english training_day_strength_16932b02:

    # mc "Просто сдайся... сдайся и все. Я прошу тебя о том же, о чем ты просила меня."
    mc "认输就好……认输就行了。我只是在要求你，做你刚才要求我的事。"

# game/a3/3trainingday.rpy:263
translate english training_day_strength_d8081408:

    # cass "Нет....я не сдамся...."
    cass "不……我绝不认输……"

# game/a3/3trainingday.rpy:264
translate english training_day_strength_9eab5b62:

    # mc "Как хочешь, для меня не принципиально, что произойдет раньше - ты сдашься или потеряешь сознание."
    mc "随便你了。我不在乎是先让你认输，还是先让你昏过去。"

# game/a3/3trainingday.rpy:266
translate english training_day_strength_be40d283:

    # aker "Ну хватит, ты победил, [mename]."
    aker "够了，你赢了，[mename]。"

# game/a3/3trainingday.rpy:267
translate english training_day_strength_df495be7:

    # mc "Она этого не сказала."
    mc "她还没说呢。"

# game/a3/3trainingday.rpy:268
translate english training_day_strength_4cc6145b:

    # aker "Она такая же упертая как и ты."
    aker "她的固执劲儿简直和你一模一样。"

# game/a3/3trainingday.rpy:269
translate english training_day_strength_6f7f7d2c:

    # mc "И ты лишил меня триумфа моей упертости над ее."
    mc "而你剥夺了我用我的固执战胜她的固执的机会。"

# game/a3/3trainingday.rpy:270
translate english training_day_strength_d836995d:

    # aker "Я не хочу чтобы вы друг друга покалечили."
    aker "我不想看你们两个互相把对方打残。"

# game/a3/3trainingday.rpy:271
translate english training_day_strength_ef1f405f:

    # mc "Ладно-ладно."
    mc "好吧，好吧。"

# game/a3/3trainingday.rpy:273
translate english training_day_strength_f7c43173:

    # cass "Кхм-кхам-кхем."
    cass "咳咳……咳咳……"

# game/a3/3trainingday.rpy:274
translate english training_day_strength_529d537a:

    # mc "Ты в норме?"
    mc "你没事吧？"

# game/a3/3trainingday.rpy:275
translate english training_day_strength_5a70602f:

    # cass "Ага...кхем-кхем...не стоило с тобой играться....надо было побеждать тебя сразу."
    cass "啊……咳咳……不该跟你闹着玩的……真该一开始就解决掉你。"

# game/a3/3trainingday.rpy:276
translate english training_day_strength_398ae3d4:

    # mc "Не стоило вынуждать меня сдаваться."
    mc "你不该逼我认输的。"

# game/a3/3trainingday.rpy:277
translate english training_day_strength_fbb26b7e:

    # cass "АГа..."
    cass "啊哈……"

# game/a3/3trainingday.rpy:279
translate english training_day_strength_cc8d56d8:

    # cass "А ты...ты сильнее чем я думал."
    cass "而你……你比我想的要强。"

# game/a3/3trainingday.rpy:280
translate english training_day_strength_d4ded1a7:

    # mc "Ну я все-таки мужчина."
    mc "唉，我好歹是个男人。"

# game/a3/3trainingday.rpy:281
translate english training_day_strength_5f6ed038:

    # cass "Я не об этом."
    cass "我指的不是这个。"

# game/a3/3trainingday.rpy:282
translate english training_day_strength_444b1f77:

    # mc "?"
    mc "?"

# game/a3/3trainingday.rpy:283
translate english training_day_strength_23227b80:

    # cass "Забудь. Тебе не пора обратно во дворец?"
    cass "算了。你是不是该回宫里了？"

# game/a3/3trainingday.rpy:284
translate english training_day_strength_39b23139:

    # mc "Ага. Как раз собирался уходить."
    mc "嗯。正打算走。"

# game/a3/3trainingday.rpy:289
translate english training_day_end1_afcf8d46:

    # cass "Ты удивительно несговорчив для человека в твоем положении."
    cass "以你这样的身份，你可真是出奇地不肯让步。"

# game/a3/3trainingday.rpy:290
translate english training_day_end1_e9fd508d:

    # cass "Может мне пару раз ударить тебя по горлу? Или выколоть глаз? Знаешь, [mename], я могу заставить тебя умолять..."
    cass "也许我该在你喉咙上敲几下？还是戳瞎你的眼睛？要知道，[mename]，我可以让你求饶……"

# game/a3/3trainingday.rpy:291
translate english training_day_end1_d1d2692e:

    # mc "[cass]..."
    mc "[cass]..."

# game/a3/3trainingday.rpy:292
translate english training_day_end1_de50adb4:

    # cass "Просто сдайся,[mename], сдайся и мне не придется этого делать, не придется резать тебя на куски, не придется тебя калечить."
    cass "认输就是了，[mename]，认输了我就不用做那些事，就不用把你大卸八块，就不用把你弄残废。"

# game/a3/3trainingday.rpy:293
translate english training_day_end1_5cf3b105:

    # mc "[cass], ты меня пугаешь..."
    mc "[cass]，你让我害怕了……"

# game/a3/3trainingday.rpy:295
translate english training_day_end1_8fbd5b8b:

    # conrad "Ладно, достаточно."
    conrad "好了，够了。"

# game/a3/3trainingday.rpy:296
translate english training_day_end1_2da7b09a:

    # cass "ЧТО ТЫ ДЕЛАЕШЬ?"
    cass "你在干什么？"

# game/a3/3trainingday.rpy:297
translate english training_day_end1_6c7c4c44:

    # conrad "Ты победила, хватит."
    conrad "你赢了，够了。"

# game/a3/3trainingday.rpy:298
translate english training_day_end1_fa997555:

    # cass "ОН НЕ СКАЗАЛ. ОН НЕ ПРИЗНАЛ ПОРАЖЕНИЕ!"
    cass "他没说。他还没承认失败！"

# game/a3/3trainingday.rpy:299
translate english training_day_end1_de8a6071:

    # conrad "Зато ты много чего сказала."
    conrad "可你刚才说了不少话。"

# game/a3/3trainingday.rpy:300
translate english training_day_end1_d7aa5a55:

    # cass "Я....я просто шутила. УРОД ОТПУСТИ МЕНЯ."
    cass "我……我只是在开玩笑。混蛋，放开我。"

# game/a3/3trainingday.rpy:301
translate english training_day_end1_46be3b85:

    # conrad "Ага. Конечно."
    conrad "啊哈。当然了。"

# game/a3/3trainingday.rpy:302
translate english training_day_end1_771de4f4:

    # mc "Отпусти ее Конрад. Я проиграл, [cass], признаю. Теперь ты успокоишься?"
    mc "放开她，Conrad。我认输了，[cass]，我承认。现在你满意了吗？"

# game/a3/3trainingday.rpy:303
translate english training_day_end1_819acded:

    # cass "...Да."
    cass "……嗯。"

# game/a3/3trainingday.rpy:305
translate english training_day_end1_f60401b5:

    # mc "Ладно. Встретимся в другой раз. Я подготовлюсь получше и возьму реванш."
    mc "好了。下次见面再比过。我会好好准备，然后报仇雪恨。"

# game/a3/3trainingday.rpy:306
translate english training_day_end1_cb8bc05c:

    # conrad "Ага. До встречи."
    conrad "嗯。到时见。"

# game/a3/3trainingday.rpy:308
translate english training_day_end1_426acc17:

    # cass "Не забудь взять свою няньку, а то вдруг твоя жопа снова окажется на полу."
    cass "别忘了带上你的保姆，省得到时候你的屁股又着了地。"

# game/a3/3trainingday.rpy:309
translate english training_day_end1_f3406eab:

    # aker "Ага. Приходите оба, мне понравилась драка."
    aker "啊哈。你们两个都来，我很喜欢这场架。"

# game/a3/3trainingday.rpy:310
translate english training_day_end1_5ebb7107:

    # conrad "Я приду, южанин."
    conrad "我会来的，南方佬。"

# game/a3/3trainingday.rpy:311
translate english training_day_end1_5fb56c6a:

    # aker "Буду ждать, дворянин."
    aker "等着你，贵族。"

# game/a3/3trainingday.rpy:312
translate english training_day_end1_8e5382f5:

    # mc "Только не делайте из этого привычку."
    mc "可别把这变成习惯了。"

# game/a3/3trainingday.rpy:317
translate english training_day_end2_4d336dcf:

    # mc "До встречи, Акер. [cass]...увидимся дома."
    mc "再见了，Aker。[cass]……家里见。"

# game/a3/3trainingday.rpy:318
translate english training_day_end2_c71e623a:

    # conrad "Ага. Еще встретимся."
    conrad "嗯。回头见。"

# game/a3/3trainingday.rpy:320
translate english training_day_end2_a29e267b:

    # cass "Пока-пока."
    cass "拜拜。"

# game/a3/3trainingday.rpy:321
translate english training_day_end2_7f10c216:

    # aker "В следующий раз деремся сразу кулаками."
    aker "下次我们直接上拳头。"

# game/a3/3trainingday.rpy:322
translate english training_day_end2_9258989d:

    # conrad "Согласен."
    conrad "同意。"

# game/a3/3trainingday.rpy:323
translate english training_day_end2_8e5382f5:

    # mc "Только не делайте из этого привычку."
    mc "可别把这变成习惯了。"

