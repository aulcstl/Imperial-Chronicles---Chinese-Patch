# TODO: Translation updated at 2024-03-04 17:08

# game/a3/7vall_free.rpy:3
translate english vall_free_90c66e21:

    # "Некоторое время спустя."
    "过了一会."

# game/a3/7vall_free.rpy:4
translate english vall_free_032ef671:

    # ala "Да..это может иметь неприятные последствия."
    ala "是啊……这可能会带来不好的后果。"

# game/a3/7vall_free.rpy:5
translate english vall_free_91350d24:

    # mc "Вы же сами сказали мне заступиться..."
    mc "是您让我挺身而出的……"

# game/a3/7vall_free.rpy:6
translate english vall_free_e9407e51:

    # ala "Ты сделал все правильно, просто Трибунал это влиятельная организация и я пытаюсь понять, что могут предпринять."
    ala "你做得对，只是仲裁庭是个有影响力的组织，我在试着弄明白他们可能会采取什么行动。"

# game/a3/7vall_free.rpy:7
translate english vall_free_54daab38:

    # mc "Ничего. Разве что отцу пожалуются. В крайнем случае я попрошу Акера отозвать обвинения и тогда без пострадавшей стороны им точно придется заткнуться."
    mc "没什么。顶多也就是向我父亲告状。最坏的情况下，我会请求Aker撤回指控，这样一来，连受害方都没了，他们肯定就得闭嘴了。"

# game/a3/7vall_free.rpy:8
translate english vall_free_992c8d49:

    # ala "Это...звучит хорошо."
    ala "这……听起来不错。"

# game/a3/7vall_free.rpy:9
translate english vall_free_2179edda:

    # mc "Да уж. А я и не верил, что трибунал может выносить такие жестокие приговоры только из-за расы обвиняемого."
    mc "是啊。我以前还不相信，仲裁庭仅仅因为被告的种族，就能做出如此残酷的判决。"

# game/a3/7vall_free.rpy:11
translate english vall_free_374bf344:

    # vall "Эй, вы чего такие грустные? Я же здесь, а не на рудниках, все обошлось."
    vall "嘿，你们为什么这么难过？我在这里，又没去矿场，一切都解决了。"

# game/a3/7vall_free.rpy:12
translate english vall_free_2bc2fcfe:

    # ala "Прости, что тебе пришлось пройти через это, думаю [mename] рассчитывал на честный суд."
    ala "很抱歉让你经历了这些，我以为[mename]是期望一场公正的审判。"

# game/a3/7vall_free.rpy:13
translate english vall_free_8ae53fec:

    # mc "Это верно. Думаю нужно сразу было вынести свое королевское решение."
    mc "确实。我想我们应该立刻做出王室裁决就好了。"

# game/a3/7vall_free.rpy:14
translate english vall_free_e695ebec:

    # vall "И какое оно будет?"
    vall "那会是什么裁决呢？"

# game/a3/7vall_free.rpy:15
translate english vall_free_c44140a3:

    # ala "Надеюсь справедливое."
    ala "希望是公正的裁决。"

# game/a3/7vall_free.rpy:16
translate english vall_free_db270f25:

    # mc "Возместить стоимость лошади все же нужно."
    mc "赔偿那匹马的钱还是需要的。"

# game/a3/7vall_free.rpy:17
translate english vall_free_2cf38374:

    # vall "Я могу работать, я многое умею - охота, рыбалка, травничество."
    vall "我可以工作，我会不少东西——打猎、捕鱼、草药学。"

# game/a3/7vall_free.rpy:19
translate english vall_free_4f8f920a:

    # ala "Травничество? Это отлично. Будешь моим подмастерьем в лаборатории."
    ala "草药学？这太好了。你来当我的实验室助手。"

# game/a3/7vall_free.rpy:20
translate english vall_free_d2a32e0c:

    # vall "У вас есть своя лаборатория?"
    vall "您有自己的实验室？"

# game/a3/7vall_free.rpy:21
translate english vall_free_8923a1c4:

    # ala "У меня многое есть, я тебе покажу. Научу тебя зельеварению."
    ala "我的东西多了，我会带你看看的。我会教你炼制药剂。"

# game/a3/7vall_free.rpy:22
translate english vall_free_893bc9d6:

    # vall "Звучит интересно."
    vall "听起来很有趣。"

# game/a3/7vall_free.rpy:23
translate english vall_free_fa329545:

    # ala "Не слишком. В основном я варю средства от мужского бессилия и различных форм кишечных болезней."
    ala "没那么有趣。我主要熬制治疗男性无能和各类肠道疾病的药剂。"

# game/a3/7vall_free.rpy:24
translate english vall_free_6bea80e9:

    # vall "Оу."
    vall "哦。"

# game/a3/7vall_free.rpy:25
translate english vall_free_053eed52:

    # ala "Но это прибыльное дело. Так что мы с тобой в миг отобьем Акеру стоимость его лошади."
    ala "但这是赚钱的生意。所以我们很快就会把Aker马匹的钱赚回来。"

# game/a3/7vall_free.rpy:26
translate english vall_free_e943043c:

    # ala "Сейчас мне нужно бежать на занятия с [elin]. [mename] проводи [vall] в мои покои."
    ala "现在我得赶去上[elin]的课。[mename]，带[vall]去我的房间。"

# game/a3/7vall_free.rpy:27
translate english vall_free_13a6a017:

    # mc "Хорошо. Вы не забыли, о своем обещании?"
    mc "好的。您没忘记您的承诺吧？"

# game/a3/7vall_free.rpy:28
translate english vall_free_c0fdd635:

    # vall "Ах, да. Встретимся в Mindon Аl'darie через пару часов."
    vall "啊，是的。几个小时后，在明登阿尔达里见。"

# game/a3/7vall_free.rpy:32
translate english vall_free_485d1070:

    # vall "Mindon Аl'darie?"
    vall "明登阿尔达里？"

# game/a3/7vall_free.rpy:33
translate english vall_free_70305e6d:

    # mc "Пик Ласточки, это эльфийские развалины на севере города рядом с дворцом."
    mc "燕子峰，那是城市北部王宫旁的精灵遗迹。"

# game/a3/7vall_free.rpy:34
translate english vall_free_c0a8e964:

    # vall "..."
    vall "..."

# game/a3/7vall_free.rpy:35
translate english vall_free_2b35b6fe:

    # mc "..."
    mc ".."

# game/a3/7vall_free.rpy:36
translate english vall_free_883b6e7c:

    # vall "[mename]... Спасибо тебе."
    vall "[mename]……谢谢你。"

# game/a3/7vall_free.rpy:37
translate english vall_free_4304a031:

    # mc "Не за что."
    mc "不用谢。"

# game/a3/7vall_free.rpy:40
translate english vall_free_9f739c2e:

    # vall "Ты и вправду справедлив и честен, Elan'or. Ты сдержал обещание и не дал меня в обиду."
    vall "你真的既公正又诚实，伊兰诺尔。你信守了承诺，没让我受欺负。"

# game/a3/7vall_free.rpy:41
translate english vall_free_4a9869fe:

    # mc "Мое слово должно что-то значить. Я же все-таки будущий король."
    mc "我的承诺总该有些分量。毕竟我是未来的国王。"

# game/a3/7vall_free.rpy:42
translate english vall_free_c7eaa0ab:

    # vall "Ты не только будущий король, Elan'or. Ты спаситель. Теперь я в этом уверена. Темное время для эльфов скоро закончится."
    vall "你不只是未来的国王，伊兰诺尔。你是救世主。现在我对这点确信无疑。精灵的黑暗时代很快就要结束了。"

# game/a3/7vall_free.rpy:43
translate english vall_free_d9e8a502:

    # mc "Ты делаешь какие-то поспешные выводы из одного моего хорошего поступка."
    mc "你仅仅根据我做了一件好事，就得出这么草率的结论。"

# game/a3/7vall_free.rpy:44
translate english vall_free_094a6923:

    # vall "Дело не в том, что ты сделал, а почему. Если ты готов рискнуть собой ради справедливости для одного эльфа, значит ты сделаешь это и для остальных, ты наш спаситель, [mename]."
    vall "关键不是你做了什么，而是你为何这么做。如果你愿意为了一位精灵的公正而甘冒风险，那就意味着你会为了所有精灵这么做。你是我们的救世主，[mename]。"

# game/a3/7vall_free.rpy:45
translate english vall_free_8c190912:

    # vall "Mírtaller."
    vall "Mírtaller."

# game/a3/7vall_free.rpy:46
translate english vall_free_f60e96cb:

    # mc "Эм...ну ладно."
    mc "呃……好吧。"

# game/a3/7vall_free.rpy:48
translate english vall_free_9f59e5c5:

    # vall "Можем идти?"
    vall "我们可以走了吗？"

# game/a3/7vall_free.rpy:50
translate english vall_free_6fea886e:

    # mc "Да, только сначала купим тебе обувь."
    mc "走吧，不过我们得先给你买双鞋。"

# game/a3/7vall_free.rpy:51
translate english vall_free_4afa133b:

    # vall "Зачем? Я могу ходить и босиком."
    vall "何必呢？我光着脚也能走路。"

# game/a3/7vall_free.rpy:52
translate english vall_free_bba98d30:

    # mc "Я знаю, вы, эльфы, любите так, но раз уж леди [alaina], устроила тебя подмастерьем в свою лабораторию, обувь тебе пригодится. Поверь, там лучше не ходить босиком."
    mc "我知道，你们精灵喜欢那样，但既然[alaina]女士安排你去她实验室当助手，鞋对你会有用的。相信我，那里最好还是不要光脚走路。"

# game/a3/7vall_free.rpy:53
translate english vall_free_0dedff9b:

    # vall "Может леди [alaina] подберет мне что-то из своей одежды?"
    vall "或许[alaina]女士会从她的衣服里找一些给我穿？"

# game/a3/7vall_free.rpy:54
translate english vall_free_6275a3ff:

    # mc "Из одежды может и подберет. А вот размер ноги у вас разный."
    mc "衣服或许可以找几件。但你们脚的大小不一样。"

# game/a3/7vall_free.rpy:55
translate english vall_free_c0a8e964_1:

    # vall "..."
    vall "..."

# game/a3/7vall_free.rpy:56
translate english vall_free_afe66631:

    # mc "Не беспокойся, я заплачу за обувь сам. И отрабатывать стоимость тебе не придется."
    mc "别担心，鞋的钱我自己出。而且你也不用想着还。"

# game/a3/7vall_free.rpy:58
translate english vall_free_023aa125:

    # vall "Спасибо..."
    vall "谢谢……"

# game/a3/7vall_free.rpy:59
translate english vall_free_a59bf16d:

    # mc "Ну что, пойдем?"
    mc "好了，我们走？"

# game/a3/7vall_free.rpy:61
translate english vall_free_90c66e21_1:

    # "Некоторое время спустя."
    "过了一会."

# game/a3/7vall_free.rpy:62
translate english vall_free_8f016c4b:

    # vall "Я никогда не носила что-то настолько красивое..."
    vall "我从没穿戴过这么漂亮的东西……"

# game/a3/7vall_free.rpy:63
translate english vall_free_f73565aa:

    # mc "Ты всю жизнь бродяжничала?"
    mc "你一辈子都在流浪吗？"

# game/a3/7vall_free.rpy:64
translate english vall_free_6a241533:

    # vall "Почти. Я родилась далеко на западе, на зеленых тропах. Когда Империя развалилась, я была молода и хотела попасть в армию свободных эльфов."
    vall "差不多。我出生在遥远的西部，在那绿荫小径上。当帝国崩溃时，我还年轻，一心想加入自由精灵的军队。"

# game/a3/7vall_free.rpy:65
translate english vall_free_7e250952:

    # mc "Ты воевала против моего отца?"
    mc "你与我父亲作战过？"

# game/a3/7vall_free.rpy:66
translate english vall_free_5016daca:

    # vall "Я не успела. Он женился на твоей матери, армию распустили и мне некуда было пойти."
    vall "我没来得及。他娶了你母亲，军队被解散了，我便无处可去。"

# game/a3/7vall_free.rpy:67
translate english vall_free_9a496bb4:

    # vall "Я до сих пор не знаю, в чем была наша выгода. Да, нас перестали убивать, но мы не добились автономии, нас все также не пускают в города и не берут на работу."
    vall "我至今不明白我们的利益在哪。是的，他们不再杀戮我们，但我们没有获得自治权，仍然不被允许进城，也找不到工作。"

# game/a3/7vall_free.rpy:68
translate english vall_free_6decb51d:

    # vall "Так что да, с тех самых пор я с сестрой ходим между поселениями, охотимся, рыбачим, иногда воруем, когда нам нужно золото на покупки в городе."
    vall "所以啊，从那时起，我和我妹妹就在各个定居点之间流浪，打猎、捕鱼，有时需要金子去城里买东西时，也偷窃。"

# game/a3/7vall_free.rpy:69
translate english vall_free_b54af468:

    # "... Это звучит странно. Эльфы ничего не получили? Надо бы спросить об этом кого-нибудь из участников тех событий. Может отца или мать."
    "... That sounds weird. The elves didn't get anything? I should have asked someone involved in those events about it. Maybe father or mother."

# game/a3/7vall_free.rpy:71
translate english vall_free_66e3c5fd:

    # vall "Знаешь, мне кажется эти сапоги не слишком подходят для лаборатории."
    vall "你知道吗，我感觉这双靴子不太适合在实验室里穿。"

# game/a3/7vall_free.rpy:72
translate english vall_free_5f8c1999:

    # mc "Ты сама их выбрала."
    mc "这可是你自己选的。"

# game/a3/7vall_free.rpy:73
translate english vall_free_18eeb9e7:

    # vall "Ты сказал выбирать, что захочу."
    vall "是你说选我想要的。"

# game/a3/7vall_free.rpy:74
translate english vall_free_e1978c08:

    # mc "Все нормально. Купим тебе сапоги и для лаборатории. А в этих можешь ходить куда-нибудь еще."
    mc "没关系。我们再给你买双适合在实验室穿的靴子。这双你可以穿去其他地方。"

# game/a3/7vall_free.rpy:75
translate english vall_free_af9ab27f:

    # vall "Например?"
    vall "比如说？"

# game/a3/7vall_free.rpy:76
translate english vall_free_a49eaf57:

    # mc "Не знаю. На свидания."
    mc "我不知道。去约会。"

# game/a3/7vall_free.rpy:78
translate english vall_free_d393a01d:

    # vall "Это приглашение?"
    vall "这是个邀请吗？"

# game/a3/7vall_free.rpy:79
translate english vall_free_1152a637:

    # mc "Ну-ну. Я скоро женюсь."
    mc "得了。我很快就要结婚了。"

# game/a3/7vall_free.rpy:80
translate english vall_free_0a73f845:

    # vall "Я вообще-то ничего подобного не имела в виду. Просто надеялась, что кто-нибудь покажет мне город."
    vall "我其实完全没有那个意思。我只是希望有人能带我逛逛这座城市。"

# game/a3/7vall_free.rpy:81
translate english vall_free_fb1291c6:

    # mc "Ну если мне что-нибудь понадобится, я возьму тебя с собой."
    mc "行吧，如果我需要出去办什么事，我会带你一起。"

# game/a3/7vall_free.rpy:82
translate english vall_free_a81eee7c:

    # vall "А Mindon Аl'darie? Я могу рассчитывать на небольшую экскурсию?"
    vall "那明登阿尔达里呢？我能指望有一次小小的参观吗？"

# game/a3/7vall_free.rpy:83
translate english vall_free_611ffeaa:

    # mc "Хм. А ты наглая. Еще не забыла, что тебе нужно выплатить Акеру ущерб?"
    mc "嗯。你可够直接的。没忘记你还欠Aker赔偿金吧？"

# game/a3/7vall_free.rpy:84
translate english vall_free_0ef62628:

    # vall "Конечно нет. Но я быстро с этим управлюсь, я трудолюбивая."
    vall "当然没忘。但我很快就能处理好的，我勤快得很。"

# game/a3/7vall_free.rpy:85
translate english vall_free_1951aefe:

    # mc "Хорошо. Как скопишь нужную сумму, вместе сходим в город за лошадью. А потом покажу тебе Mindon Аl'darie."
    mc "好。等你攒够了钱，我们一起去城里买马。然后我就带你看明登阿尔达里。"

# game/a3/7vall_free.rpy:86
translate english vall_free_e69e2d91:

    # vall "Договорились."
    vall "一言为定。"

# game/a3/7vall_free.rpy:88
translate english vall_free_3fb349c7:

    # vall "Муа!"
    vall "Mua！（亲吻声）"

# game/a3/7vall_free.rpy:89
translate english vall_free_89bdd3f9:

    # mc "Это в оплату не входит."
    mc "这可不包含在赔偿里。"

# game/a3/7vall_free.rpy:90
translate english vall_free_5644d094:

    # vall "Я знаю. Просто хочу еще раз сказать спасибо. Я и не рассчитывала, что после кражи мне дадут второй шанс. "
    vall "我知道。只是想再次说声谢谢。我本不指望在偷窃之后还能得到第二次机会。"

# game/a3/7vall_free.rpy:91
translate english vall_free_79fbcbac:

    # mc "Ладно, пойдем уже, отведу тебя на твое новое рабочее место."
    mc "好了，走吧，我带你去你新的工作地点。"

# game/a3/7vall_free.rpy:95
translate english vall_free2_f55a252d:

    # mc "Леди [alaina] ушла и ты как-то сразу потеряла настроение, что-то не так?"
    mc "[alaina]女士一走，你好像一下子就没了心情，有什么不对劲吗？"

# game/a3/7vall_free.rpy:96
translate english vall_free2_c3d14405:

    # vall "...Спасибо..."
    vall "……谢谢……"

# game/a3/7vall_free.rpy:97
translate english vall_free2_c47d0307:

    # mc "За что ты меня благодаришь?"
    mc "你谢我什么？"

# game/a3/7vall_free.rpy:98
translate english vall_free2_1caff3ef:

    # vall "За то, что не дал отправить меня на рудники."
    vall "谢谢你没让他们把我送去矿场。"

# game/a3/7vall_free.rpy:100
translate english vall_free2_7a3f2436:

    # mc "Ну что ты, цветочек. Я бы никогда и никому не позволил просто взять и отнять у меня мою собственность."
    mc "哎哟，说什么呢，小花朵。我可永远不会、也绝不允许任何人就这么轻易地夺走我的财产。"

# game/a3/7vall_free.rpy:101
translate english vall_free2_c0a8e964:

    # vall "..."
    vall "..."

# game/a3/7vall_free.rpy:102
translate english vall_free2_fadfdbf2:

    # mc "Что ты притихла? Что-то не так?"
    mc "你怎么不说话了？怎么了？"

# game/a3/7vall_free.rpy:103
translate english vall_free2_9b6f743f:

