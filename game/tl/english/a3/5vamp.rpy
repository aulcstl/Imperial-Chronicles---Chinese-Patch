translate english vamp_ire_suf_ac1aa58a_1:

    # sona "..."
    sona "..."

# game/a3/5vamp.rpy:239
translate english vamp_ire_suf_6632aac2:

    # mc "Я принесу воды. Нужно смыть с тебя кровь."
    mc "我去拿点水。得把你身上的血洗掉。"

# game/a3/5vamp.rpy:241
translate english vamp_ire_suf_a7051dc5:

    # mc "Можешь переночевать сегодня у меня."
    mc "你今晚可以在这儿过夜。"

# game/a3/5vamp.rpy:242
translate english vamp_ire_suf_e8d4935f:

    # mc "Оставаться надольше у меня нельзя. У слуг и моей семьи возникнут вопросы, сама понимаешь."
    mc "但你在我这儿不能久留。仆人还有我的家人会起疑心，这你明白。"

# game/a3/5vamp.rpy:243
translate english vamp_ire_suf_6fa26f33:

    # mc "Но я могу помочь тебе с деньгами, снимешь комнату..."
    mc "不过我可以帮你弄点钱，你去租个房间……"

# game/a3/5vamp.rpy:245
translate english vamp_ire_suf_88b95964:

    # mc "...в городе."
    mc "……在城里住下。"

# game/a3/5vamp.rpy:246
translate english vamp_ire_suf_c0ac58e7:

    # "Ага. И тебе пока и всего хорошего."
    "Yeah. Bye and good night to you, too."

# game/a3/5vamp.rpy:247
translate english vamp_ire_suf_ca29b35c:

    # "Сбежала. Может не захотела причинять мне больше неудобств?"
    "Ran away. Maybe she didn't want to cause me any more trouble??"

# game/a3/5vamp.rpy:248
translate english vamp_ire_suf_af0273d4:

    # "Или отправилась искать второго вампира?"
    "Or did she go looking for a second vampire?"

# game/a3/5vamp.rpy:249
translate english vamp_ire_suf_8764cfc3:

    # "Ладно. Обдумаю это уже завтра."
    "Okay. I'll think about it tomorrow."

# game/a3/5vamp.rpy:253
translate english vamp_ire_suf_b7a42b52:

    # mc "Вставай."
    mc "起来吧。"

# game/a3/5vamp.rpy:254
translate english vamp_ire_suf_e0f1554b:

    # sona "Куда мы?"
    sona "我们要去哪儿？"

# game/a3/5vamp.rpy:255
translate english vamp_ire_suf_dc69c0b4:

    # mc "В госпиталь. Тебе там помогут. Я не стану давать тебе моей крови."
    mc "去医务室。那里的人会帮你。我不会给你我的血了。"

# game/a3/5vamp.rpy:256
translate english vamp_ire_suf_a23ef21b:

    # sona "Ох. Ладно..."
    sona "啊。好吧……"

# game/a3/5vamp.rpy:257
translate english vamp_ire_suf_61117582:

    # "Я отвел Сону в госпиталь."
    "I took Sona to the hospital."

# game/a3/5vamp.rpy:258
translate english vamp_ire_suf_34cd6877:

    # "Почему-то мне кажется, она больше меня не потревожит..."
    "Somehow, I don't think she'll bother me anymore..."

