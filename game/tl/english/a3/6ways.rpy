# TODO: Translation updated at 2024-03-03 17:21

# game/a3/6ways.rpy:3
translate english ways_f3333816:

    # "Следующим утром."
    "Next morning."

# game/a3/6ways.rpy:4
translate english ways_4b67bc7f:

    # mc "Уйдите... уйдите я еще не выспался."
    mc "走开……走开，我还没睡够呢。"

# game/a3/6ways.rpy:5
translate english ways_1b2ee41b:

    # "Нужно было закрыть шторы, солнце светит прямо в лицо."
    "I had to close the curtains, the sun is shining right in my face."

# game/a3/6ways.rpy:6
translate english ways_2c3e2aa6:

    # mc "Кто...кто пришел?"
    mc "谁……谁来了？"

# game/a3/6ways.rpy:8
translate english ways_9ec6670e:

    # ala "Это я, [mename]."
    ala "是我，[mename]。"

# game/a3/6ways.rpy:9
translate english ways_bfb77a86:

    # mc "Ох, леди [alaina]...У нас сегодня запланированы уроки?"
    mc "哦，[alaina]女士……我们今天有安排课程吗？"

# game/a3/6ways.rpy:10
translate english ways_53068523:

    # ala "Нет, [mename], раз уж ты вернулся домой, больше никаких запланированных занятий, можешь приходить когда захочешь."
    ala "没有，[mename]，既然你都回到家了，就再没有什么安排好的课程了，你什么时候来都行。"

# game/a3/6ways.rpy:11
translate english ways_8b37d7f0:

    # mc "Ну хорошо. Эм... зачем тогда вы..."
    mc "好吧。呃……那您来是为了……"

# game/a3/6ways.rpy:12
translate english ways_bdfa861a:

    # ala "Твоя сестра вчера приходила, я думала ты будешь с ней."
    ala "你妹妹昨天来过了，我以为你会跟她在一起。"

# game/a3/6ways.rpy:13
translate english ways_55a08047:

    # mc "Я был у доктора."
    mc "我去看医生了。"

# game/a3/6ways.rpy:14
translate english ways_2a496b4f:

    # ala "Я знаю. Я предполагала что ты зайдешь после. Ты стал постоянно занят, как вернулся, так что я решила прийти сама."
    ala "我知道。我本以为你之后会过来。自从你回来后就一直很忙，所以我决定自己过来了。"

# game/a3/6ways.rpy:15
translate english ways_6099f91c:

    # mc "Я был...занят."
    mc "我是……有点儿忙。"

# game/a3/6ways.rpy:17
translate english ways_b4bc0d79:

    # ala "Ты стал постоянно занят, как вернулся, поэтому я и решила прийти сама."
    ala "自从你回来后就一直很忙，所以我才决定自己过来。"

# game/a3/6ways.rpy:18
translate english ways_5f37fa4d:

    # ala "К тому же утро самое лучше время для обучения."
    ala "而且早上是最好的学习时间。"

# game/a3/6ways.rpy:19
translate english ways_dd554b33:

    # mc "Так у нас все-таки запланированы занятия."
    mc "那咱们还是有安排课程咯。"

# game/a3/6ways.rpy:20
translate english ways_90949856:

    # ala "Не хочу тебя принуждать, так что если ты не в настроении..."
    ala "我不想强迫你，所以如果你没心情的话……"

# game/a3/6ways.rpy:21
translate english ways_2857674c:

    # mc "Я в настроении. Чудесное утро, можно чудесно отвлечься уроками магии от предстоящей свадьбы."
    mc "我有心情。美好的早晨，正好能用魔法课来好好分散一下注意力，免得去想即将到来的婚礼。"

# game/a3/6ways.rpy:22
translate english ways_a7897ef4:

    # ala "Знаешь, обычно это невесты напуганы будущем замужеством."
    ala "你知道，通常都是新娘才会对未来的婚姻感到害怕。"

# game/a3/6ways.rpy:23
translate english ways_713381fc:

    # mc "Я не напуган, просто хочется пропустить все формальности - все эти приемы, танцы, клятвы и прочее."
    mc "我不是害怕，只是想跳过所有的繁文缛节——所有这些招待会、舞会、誓言什么的。"

# game/a3/6ways.rpy:25
translate english ways_a7f93e58:

    # ala "И сразу перейти к первой брачной ночи?"
    ala "然后直接进入洞房花烛夜？"

# game/a3/6ways.rpy:26
translate english ways_ccd8a4fa:

    # mc "Эм..."
    mc "呃……"

# game/a3/6ways.rpy:27
translate english ways_51059e15:

    # ala "Шучу."
    ala "开玩笑的。"

# game/a3/6ways.rpy:28
translate english ways_d12c2281:

    # mc "А вот у моих родителей... Как у них все прошло?"
    mc "那我父母他们……他们当时是怎么过的？"

# game/a3/6ways.rpy:29
translate english ways_c35a2be6:

    # ala "Что конкретно тебя интересует?"
    ala "你具体对什么感兴趣？"

# game/a3/6ways.rpy:30
translate english ways_0ce8b8fc:

    # mc "Когда они впервые поговорили? У алтаря? У них вообще было время узнать друг друга или это был просто политический брак?"
    mc "他们第一次说话是在什么时候？在圣坛前吗？他们到底有没有时间互相了解，还是说那只是一场政治联姻？"

# game/a3/6ways.rpy:31
translate english ways_ef487979:

    # ala "Тебя интересует любили ли они друг друга?"
    ala "你感兴趣的是他们是否相爱？"

# game/a3/6ways.rpy:32
translate english ways_f34f69c2:

    # mc "Да."
    mc "是的。"

# game/a3/6ways.rpy:33
translate english ways_abcaf5c0:

    # ala "А сам ты как думаешь?"
    ala "那你自己是怎么想的？"

# game/a3/6ways.rpy:34
translate english ways_d929cc71:

    # mc "Я не знаю. Когда я впервые задумался об этом они уже спали в разных покоях."
    mc "我不知道。当我第一次思考这个问题的时候，他们已经分房睡了。"

# game/a3/6ways.rpy:36
translate english ways_a75b1bab:

    # ala "Ты слишком много думаешь о простых вещах."
    ala "你把简单的事情想得太复杂了。"

# game/a3/6ways.rpy:37
translate english ways_2ebdac15:

    # mc "Вы не ответили на мой вопрос."
    mc "您没有回答我的问题。"

# game/a3/6ways.rpy:38
translate english ways_75ad5579:

    # ala "Я не могу ответить на твой вопрос, [mename], я не знаю на него ответа. Но я могу дать тебе совет."
    ala "我无法回答你的问题，[mename]，我不知道答案。但我可以给你一个建议。"

# game/a3/6ways.rpy:39
translate english ways_2186b9ae:

    # mc "Какой?"
    mc "什么建议？"

# game/a3/6ways.rpy:40
translate english ways_d7fb5689:

    # ala "Не бойся отсутствия любви, когда о королях пишут хроники, там нет ни слова о том, были ли они счастливы в браке."
    ala "不要害怕缺少爱情，在记载国王的编年史里，只字未提他们的婚姻是否幸福。"

# game/a3/6ways.rpy:41
translate english ways_406c70f1:

    # ala "Ты рожден для великих дел, [mename], и будет хорошо, если жена будет тебе в делах нелюбимым помощником, а не обожаемым врагом."
    ala "你生来就是要成就伟业的，[mename]，如果你的妻子是你事业上不受宠爱的助手，而不是你深爱的敌人，那就很好了。"

# game/a3/6ways.rpy:42
translate english ways_7fea92c5:

    # ala "Выбирай кроткую и послушную. Вот и весь совет."
    ala "选个温顺听话的。这就是全部的建议。"

# game/a3/6ways.rpy:44
translate english ways_19690ab9:

    # mc "Твои слова натолкнули меня на одну мысль."
    mc "你的话让我产生了一个想法。"

# game/a3/6ways.rpy:45
translate english ways_84cda52e:

    # ala "Какую?"
    ala "什么想法？"

# game/a3/6ways.rpy:46
translate english ways_7f921d2b:

    # mc "Я хочу провести сеанс памяти."
    mc "我想进行一次记忆回溯。"

# game/a3/6ways.rpy:47
translate english ways_eb26ba21:

    # ala "Конечно. Что ты хочешь вспомнить?"
    ala "当然可以。你想回忆什么？"

# game/a3/6ways.rpy:48
translate english ways_a10858de:

    # mc "Верни меня в мой последний день, перед изгнанием."
    mc "带我回到我被流放前的最后一天。"

# game/a3/6ways.rpy:50
translate english ways_a7221793:

    # ala "Ты хочешь вспомнить что-то конкретное?"
    ala "你想回忆起什么特别的事情吗？"

# game/a3/6ways.rpy:51
translate english ways_59dcb21e:

    # mc "Да. Хочу вспомнить один разговор."
    mc "是的。我想回忆起一段对话。"

# game/a3/6ways.rpy:52
translate english ways_e3970e11:

    # ala "Что за разговор?"
    ala "什么对话？"

# game/a3/6ways.rpy:53
translate english ways_6e523693:

    # mc "Один...человек кое-что мне рассказывал. Я хочу вспомнить что. От этого зависит мое доверие к нему."
    mc "有个人……跟我说了些话。我想回忆起内容。这决定了我是否信任他。"

# game/a3/6ways.rpy:54
translate english ways_40906fb9:

    # ala "Что это за человек?"
    ala "这个人是谁？"

# game/a3/6ways.rpy:55
translate english ways_2953a7c8:

    # mc "Ты поможешь мне или нет?"
    mc "你到底帮不帮我？"

# game/a3/6ways.rpy:56
translate english ways_426daa71:

    # ala "Ладно. Глубоко вздохни. Очисти разум и оставь там только этот день."
    ala "好吧。深吸一口气。清空你的思绪，只留下那一天。"

# game/a3/6ways.rpy:57
translate english ways_2b35b6fe:

    # mc "..."
    mc "..."

# game/a3/6ways.rpy:59
translate english ways_8d7256ba:

    # ala "Laurelin amin nauro sîr menelna sîr enwina i nai lambë i coias"
    ala "Laurelin amin nauro sîr menelna sîr enwina i nai lambë i coias"

# game/a3/6ways.rpy:60
translate english ways_2b35b6fe_1:

    # mc "..."
    mc "..."

# game/a3/6ways.rpy:61
translate english ways_0949c82a:

    # ala "Пусть разум твой, elan'or, откроется теням прошлого."
    ala "愿你的心智，elan'or，向过去的阴影敞开。"

# game/a3/6ways.rpy:62
translate english ways_3778be78:

    # mc "Да...именно то, что я и хотел увидеть."
    mc "对……这正是我想看到的。"

# game/a3/6ways.rpy:63
translate english ways_da38e0a3:

    # ala "Lenda naa elan'or."
    ala "Lenda naa elan'or."

# game/a3/6ways.rpy:65
translate english ways_76c9b8eb:

    # "Да. Я помню тот день, я был зол на весь мир."
    "Yes. I remember that day, I was angry at the whole world."

# game/a3/6ways.rpy:66
translate english ways_acbc6d97:

    # "Я до конца не верил, что меня вышлют из дворца."
    "I didn't fully believe that I would be sent out of the palace."

# game/a3/6ways.rpy:67
translate english ways_124376e9:

    # "Но когда мать и отец сказали мне, что уже завтра я покину свой дом."
    "But when my mother and father told me that tomorrow I would leave my home..."

# game/a3/6ways.rpy:68
translate english ways_51426751:

    # "Мать стояла с поникшей головой. Отец грозно смотрел на меня... Но кто-то еще был там..."
    "The mother stood with her head bowed. My father was glaring at me... But someone else was there..."

# game/a3/6ways.rpy:70
translate english ways_d3ee2ed4:

    # ala "Так и знала, что ты будешь здесь [mename]."
    ala "就知道你会在这儿，[mename]。"

# game/a3/6ways.rpy:71
translate english ways_76ca32e3:

    # mc "Уходи!"
    mc "走开！"

# game/a3/6ways.rpy:72
translate english ways_766f5896:

    # ala "Ты злишься на меня?"
    ala "你在生我的气吗？"

# game/a3/6ways.rpy:73
translate english ways_76f0876d:

    # mc "Ты просто согласилась. Как и мама. Вы просто стояли там и ничего не делали."
    mc "你当时只是同意了。就像母亲一样。你们只是站在那儿，什么也没做。"

# game/a3/6ways.rpy:74
translate english ways_cc944325:

    # ala "Ты хотел, чтобы я пошла против воли короля?"
    ala "你想让我违抗国王的意志吗？"

# game/a3/6ways.rpy:75
translate english ways_1ee860d4:

    # mc "Я...вы могли бы хотя бы что-то сказать ему."
    mc "我……您至少可以跟他说点什么吧。"

# game/a3/6ways.rpy:76
translate english ways_86707f0a:

    # ala "Почему же ты не сказал?"
    ala "那你为什么不说呢？"

# game/a3/6ways.rpy:77
translate english ways_116d7b47:

    # mc "Я...я не знаю. Он зол на меня из-за [cass]. Но я же извинился!"
    mc "我……我不知道。他因为[cass]的事在生我的气。但我已经道歉了！"

# game/a3/6ways.rpy:79
translate english ways_1730e69a:

    # ala "Ты правда думаешь, что он отсылает тебя из-за одного выколотого глаза?"
    ala "你真的以为他送走你只是因为一只眼睛被戳瞎了吗？"

# game/a3/6ways.rpy:80
translate english ways_43d92060:

    # mc "Ну да."
    mc "呃，是啊。"

# game/a3/6ways.rpy:81
translate english ways_43e59c1c:

    # ala "Ты когда-нибудь замечал, как он смотрит на нее?"
    ala "你有没有注意过他是怎么看她的？"

# game/a3/6ways.rpy:82
translate english ways_c1b64e06:

    # mc "Нет. Как?"
    mc "没有。怎么看的？"

# game/a3/6ways.rpy:83
translate english ways_e1168d4f:

    # ala "Он презирает ее. Не любит. Она живое напоминание о его неудачном браке."
    ala "他鄙视她。不爱她。她是他失败婚姻的活生生的证明。"

# game/a3/6ways.rpy:84
translate english ways_734363b5:

    # mc "Неудачном?"
    mc "失败的婚姻？"

# game/a3/6ways.rpy:85
translate english ways_044e81c2:

    # ala "По-твоему в счастливых семьях кончают с собой?"
    ala "你觉得幸福的家庭里会有人自杀吗？"

# game/a3/6ways.rpy:86
translate english ways_56bef0d7:

    # mc "Но тогда я не понимаю, зачем отец так жестоко меня наказывает. Тем более это была случайность."
    mc "但那我就不明白了，父亲为什么要这么严厉地惩罚我。更何况那只是个意外。"

# game/a3/6ways.rpy:88
translate english ways_2a926e80:

    # ala "Видишь ту арку?"
    ala "看到那座拱门了吗？"

# game/a3/6ways.rpy:89
translate english ways_f34f69c2_1:

    # mc "Да."
    mc "看到了。"

# game/a3/6ways.rpy:90
translate english ways_e64fc93b:

    # ala "Ты любишь сидеть там?"
    ala "你喜欢坐在那儿吗？"

# game/a3/6ways.rpy:91
translate english ways_06aba162:

    # mc "Да. Откуда вы знаете?"
    mc "喜欢。您怎么知道的？"

# game/a3/6ways.rpy:92
translate english ways_1c3d43b7:

    # ala "Видела пару раз, когда была в белой крепости напротив."
    ala "有几次在对面白色堡垒的时候看到过。"

# game/a3/6ways.rpy:93
translate english ways_ea9a4f2a:

    # ala "Твои предки стояли прямо здесь, где ты любишь сидеть, и смотрели как люди сжигают их дома и убивают их любимых."
    ala "你的祖先们就站在这里，站在你喜欢坐的地方，眼睁睁看着人们烧毁他们的家园，杀死他们的爱人。"

# game/a3/6ways.rpy:95
translate english ways_b08dc61d:

    # mc "Их застали врасплох, люди на десятках тысяч кораблей в одночасье появились из-за горизонта."
    mc "他们被突袭了，成千上万的船只载着人类，一瞬间出现在地平线上。"

# game/a3/6ways.rpy:96
translate english ways_c8515fb7:

    # ala "Верно. Безмерное море захватчиков хлынуло в этот когда-то мирный эльфийский город. Но даже так эльфы смогли дать отпор."
    ala "没错。无边无际的入侵者如潮水般涌入这座曾经和平的精灵城市。但即便如此，精灵们仍然能进行反击。"

# game/a3/6ways.rpy:97
translate english ways_cf8ed562:

    # mc "Как?"
    mc "怎么反击的？"

# game/a3/6ways.rpy:98
translate english ways_ee3836c3:

    # ala "Mindon Аl'darie. Эльфийское название этого места. Все кто смог уцелеть после вторжения укрылись здесь."
    ala "明顿·艾尔达里。这是此地的精灵语名字。所有在入侵后幸存下来的人都躲到了这里。"

# game/a3/6ways.rpy:99
translate english ways_90decaf5:

    # mc "И что с ними случилось?"
    mc "那他们后来怎么样了？"

# game/a3/6ways.rpy:100
translate english ways_9cc9185c:

    # ala "Осада затянулась, люди начали штурмовать пик, но с удивлением обнаружили, что тут уже никого нет."
    ala "围城战拖延了很久，人类开始猛攻这座山峰，却惊讶地发现这里已经空无一人。"

# game/a3/6ways.rpy:102
translate english ways_b773f3bb:

    # ala "Как только они добрались до самой вершины раздался чудовищный магический взрыв. Тысячи захватчиков в ту же секунду испарились."
    ala "当他们到达山顶时，一声可怕的魔法爆炸响起。成千上万的入侵者在那一瞬间被蒸发。"

# game/a3/6ways.rpy:103
translate english ways_fd2e0317:

    # mc "Такого не было."
    mc "没有这回事。"

# game/a3/6ways.rpy:104
translate english ways_7b202b0a:

    # ala "Было. Город заняли за считанные дни, но только это место выглядит как руины, не думал почему? Из-за взрыва."
    ala "有的。这座城市几天内就被占领了，但只有这个地方看起来像废墟，你没想过为什么吗？就是因为那次爆炸。"

# game/a3/6ways.rpy:105
translate english ways_e0383ffb:

    # mc "Это место осаждали, использовали требушеты."
    mc "这个地方是被围攻的，用了投石机。"

# game/a3/6ways.rpy:106
translate english ways_5716d397:

    # ala "Интересно как интенсивно должны были обстреливать это место, чтобы от него остались лишь пару стен из белого камня."
    ala "有意思，那该是多么猛烈的轰击，才能让这里只剩下几堵白石墙壁？"

# game/a3/6ways.rpy:107
translate english ways_0bb5c9ab:

    # ala "И это через пару недель после того, как люди впервые ступили на эту землю."
    ala "而且这是在人类初次踏上这片土地仅仅几周后发生的事情。"

# game/a3/6ways.rpy:108
translate english ways_2b8a3842:

    # mc "...А куда делись те эльфы, что были здесь?"
    mc "……那这里的那些精灵去哪儿了？"

# game/a3/6ways.rpy:110
translate english ways_6504e3b2:

    # ala "Я покажу тебе, как только мы вернемся сюда из твоей ссылки."
    ala "等你流放归来，回到这里的时候，我就告诉你。"

# game/a3/6ways.rpy:111
translate english ways_75aa018e:

    # mc "Я хочу сейчас."
    mc "我现在就想知道。"

# game/a3/6ways.rpy:112
translate english ways_7d7699f4:

    # ala "Наберись терпения."
    ala "耐心点。"

# game/a3/6ways.rpy:113
translate english ways_8ba4e243:

    # mc "... Зачем вы мне это рассказали?"
    mc "……您为什么要告诉我这些？"

# game/a3/6ways.rpy:114
translate english ways_abcaf5c0_1:

    # ala "А сам ты как думаешь?"
    ala "那你觉得是为什么？"

# game/a3/6ways.rpy:116
translate english ways_560c9797:

    # mc "Не знаю..."
    mc "不知道……"

# game/a3/6ways.rpy:117
translate english ways_27c57025:

    # ala "Невозможно победить силой того, кто сильнее тебя. Можно только затаится, переждать, обхитрить. Наши предки поняли это еще в первые дни войны."
    ala "用武力是无法战胜比你更强大的人的。只能潜伏，等待，用计谋取胜。我们的祖先在战争的头几天就明白了这一点。"

# game/a3/6ways.rpy:118
translate english ways_e2924346:

    # mc "Как это связано со мной?"
    mc "这跟我有什么关系？"

# game/a3/6ways.rpy:119
translate english ways_fbd07ba4:

    # ala "В тебе течет кровь эльфов, [mename]. Твой отец видит это. Видит это в твоих глазах."
    ala "你体内流着精灵的血，[mename]。你父亲看到了这一点。在你的眼睛里看到了这一点。"

# game/a3/6ways.rpy:120
translate english ways_04ed075c:

    # mc "Он ненавидит меня, как и [cass]?"
    mc "他恨我，就像恨[cass]一样？"

# game/a3/6ways.rpy:121
translate english ways_53de971b:

    # ala "Ненавидит? О, нет. Он тебя боится."
    ala "恨？哦，不。他怕你。"

# game/a3/6ways.rpy:122
translate english ways_6e17a909:

    # mc "Боится? Почему?"
    mc "怕？为什么？"

# game/a3/6ways.rpy:123
translate english ways_a821b57c:

    # ala "Боится твоей крови. Боится, из-за того, что смешал кровь людских королей с кровью эльфов. Он боится, того чего предсказывают ему оракулы."
    ala "害怕你的血统。害怕，是因为他把人类国王的血统和精灵的血统混在了一起。他害怕神谕者向他预言的事情。"

# game/a3/6ways.rpy:124
translate english ways_a4629c83:

    # mc "Тогда я просто скажу, что не хочу ничего такого, не хочу навредить отцу!"
    mc "那我干脆去告诉他，我不想那些事，不想伤害父亲！"

# game/a3/6ways.rpy:125
translate english ways_89a79304:

    # ala "..."
    ala "[mename]..."

# game/a3/6ways.rpy:127
translate english ways_c89070b3:

    # ala "Видишь это кольцо?"
    ala "看到这枚戒指了吗？"

# game/a3/6ways.rpy:128
translate english ways_f34f69c2_2:

    # mc "Да."
    mc "看到了。"

# game/a3/6ways.rpy:129
translate english ways_4e1cd0c0:

    # ala "Мне дал его мой дедушка. Это кольцо возраста. Это эльфийская традиция менять палец, когда ты вступаешь в новую фазу жизни."
    ala "这是我祖父给我的。这是一枚年龄戒指。当你进入人生的新阶段时，更换手指戴戒指是精灵的传统。"

# game/a3/6ways.rpy:130
translate english ways_271911b5:

    # ala "У тебя нет такого, но сегодня ты вступаешь в новую фазу своей жизни."
    ala "你没有这样的戒指，但今天你正步入人生的新阶段。"

# game/a3/6ways.rpy:131
translate english ways_4f51bc71:

    # ala "Так что я поменяю палец за тебя."
    ala "所以，我替你换个手指来戴。"

# game/a3/6ways.rpy:133
translate english ways_8ea7b3e8:

    # ala "Авторитет твоего отца не будет вечен, чем ты раньше оторвешься от корней, тем лучше."
    ala "你父亲的权威不会是永恒的，你越早脱离根基越好。"

# game/a3/6ways.rpy:134
translate english ways_3bb3aa67:

    # mc "От всех корней?"
    mc "脱离所有的根基吗？"

# game/a3/6ways.rpy:135
translate english ways_6db6f920:

    # ala "От тех, от которых ты захочешь сам."
    ala "脱离你自己想脱离的那些。"

# game/a3/6ways.rpy:137
translate english ways_6662f986:

    # mc "Разве так можно?"
    mc "这真的可以吗？"

# game/a3/6ways.rpy:138
translate english ways_b14b56f8:

    # ala "В тебе равно течет кровь от обоих народов. Значит ты можешь выбирать сам."
    ala "你体内平等地流淌着两个民族的血脉。这意味着你可以自己选择。"

# game/a3/6ways.rpy:139
translate english ways_adfcab0d:

    # mc "Мне обязательно нужно выбрать?"
    mc "我必须得选吗？"

# game/a3/6ways.rpy:140
translate english ways_815da3e9:

    # ala "Если ТЫ не выберешь, это сделают за тебя."
    ala "如果你不选，别人就会替你选。"

# game/a3/6ways.rpy:141
translate english ways_06e70478:

    # mc "Но я не знаю как выбирать."
    mc "但我不知道怎么选。"

# game/a3/6ways.rpy:142
translate english ways_31c5ad3e:

    # ala "Ты просто должен чувствовать. Чувствовать, кто ты есть."
    ala "你只需要去感受。去感受你是谁。"

# game/a3/6ways.rpy:146
translate english ways_440ecedc:

    # mc "Я чувствую, что я эльф."
    mc "我感觉我是个精灵。"

# game/a3/6ways.rpy:147
translate english ways_136d37c8:

    # ala "Ну конечно. Когда ты станешь королем, ты сможешь это показать."
    ala "那当然了。等你当上国王，你就能展现这一点。"

# game/a3/6ways.rpy:148
translate english ways_7a17c068:

    # mc "Да. Я освобожу всех эльфов! Я дам им свободы и дом."
    mc "对。我要解放所有的精灵！我要给他们自由和家园。"

# game/a3/6ways.rpy:149
translate english ways_e0ded2a3:

    # ala "Молодец. Дом?"
    ala "好样的。家园？"

# game/a3/6ways.rpy:150
translate english ways_c707029f:

    # mc "Землю, которую у них отобрали. У орков же была автономия в Империи! Значит и эльфам нужно дать такую."
    mc "给他们被夺走的土地。兽人在帝国里都能有自治权！那精灵也应该拥有这些。"

# game/a3/6ways.rpy:151
translate english ways_cc6d1b58:

    # ala "А что если твои подданные воспротивятся этому?"
    ala "如果你的臣民反对怎么办？"

# game/a3/6ways.rpy:152
translate english ways_9c05bdec:

    # mc "Не важно, я знаю, что это правильно, а значит я буду делать все для этого, даже если буду один."
    mc "那不重要，我知道这是正确的，所以我将为此竭尽全力，哪怕只有我一个人。"

# game/a3/6ways.rpy:153
translate english ways_1c37a293:

    # ala "Ты будешь не один, обещаю."
    ala "你不会是一个人的，我保证。"

# game/a3/6ways.rpy:157
translate english ways_3caccd9d:

    # mc "Я чувствую себя и человеком и эльфом. Я не хочу выбирать."
    mc "我感觉自己既是人又是精灵。我不想选择。"

# game/a3/6ways.rpy:158
translate english ways_0a2b90c2:

    # ala "Люди вокруг..."
    ala "周围的人……"

# game/a3/6ways.rpy:159
translate english ways_de22b76c:

    # mc "Это не важно. Для хорошего правителя важна ни родословная, ни его кровь и количество драгоценных камней в короне."
    mc "这不重要。对于一个好的统治者来说，重要的不是他的血统、血脉或是王冠上宝石的数量。"

# game/a3/6ways.rpy:160
translate english ways_717089e0:

    # mc "Важна его воля. И у меня она есть."
    mc "重要的是他的意志。而我有这个意志。"

# game/a3/6ways.rpy:161
translate english ways_b2632c29:

    # ala "И какова будет твоя воля? Что ты будешь делать и для людей и для эльфов?"
    ala "那你的意志是什么？你将为人类和精灵做些什么？"

# game/a3/6ways.rpy:162
translate english ways_4d50e6dd:

    # mc "Все ради моего королевства."
    mc "一切为了我的王国。"

# game/a3/6ways.rpy:166
translate english ways_524d5719:

    # mc "В таком случае я человек. Я рожден человеком и буду человеком."
    mc "既然如此，那我就是人类。我生而为人，也将作为人类存在。"

# game/a3/6ways.rpy:167
translate english ways_183641a7:

    # ala "Разве я зря..."
    ala "那我岂不是白费……"

# game/a3/6ways.rpy:168
translate english ways_03e40db1:

    # mc "Я учту, что вы сказали, леди [alaina], но я не поменяю свое мнение."
    mc "您说的话我会考虑的，[alaina]女士，但我不会改变我的想法。"

# game/a3/6ways.rpy:169
translate english ways_d6b98169:

    # mc "Я - человек!"
    mc "我是人类！"

# game/a3/6ways.rpy:170
translate english ways_22562f8d:

    # ala "В твоем королевстве живут не только люди..."
    ala "你的王国里不仅仅居住着人类……"

# game/a3/6ways.rpy:171
translate english ways_0357b7c1:

    # mc "Пусть они не беспокоятся, я буду править ими в их интересах, но как человек."
    mc "让他们别担心，我将以人类的身份，为了他们的利益来统治他们。"

# game/a3/6ways.rpy:175
translate english ways_966726df:

    # "Что за..."
    "What the..."

# game/a3/6ways.rpy:176
translate english ways_30e885f9:

    # "Кажется я снова в чужих воспоминаниях."
    "I feel like I'm in someone else's memories again."

# game/a3/6ways.rpy:177
translate english ways_dab6d259:

    # "Что за ребенок?"
    "A child?"

# game/a3/6ways.rpy:178
translate english ways_5e138db3:

    # "Это леди [alaina]?"
    "Is that young lady [alaina]?"

# game/a3/6ways.rpy:180
translate english ways_d969f864:

    # ala_granpa "Теперь это кольцо всегда с тобой."
    ala_granpa "现在这枚戒指永远和你在一起了。"

# game/a3/6ways.rpy:181
translate english ways_8a6b4001:

    # ala_granpa "Меняй палец только когда почувствуешь, что твоя жизнь по-настоящему поменялась."
    ala_granpa "只有当你觉得你的生活真正改变时，才换手指戴它。"

# game/a3/6ways.rpy:182
translate english ways_e7950f06:

    # ala_granpa "Поняла?"
    ala_granpa "明白了吗？"

# game/a3/6ways.rpy:184
translate english ways_29ed3a58:

    # ala_granpa "[alaina]! Садись. Твое кольцо тоже готово."
    ala_granpa "[alaina]！坐下。你的戒指也准备好了。"

# game/a3/6ways.rpy:186
translate english ways_b157df30:

    # ala_granpa "Слышала, что я сказал о кольце?"
    ala_granpa "听到我关于戒指所说的话了吗？"

# game/a3/6ways.rpy:187
translate english ways_c80163a0:

    # ala "Да, дедушка, я все знаю."
    ala "是的，爷爷，我都知道。"

# game/a3/6ways.rpy:188
translate english ways_d9b24c48:

    # ala_granpa "Молодец. Тебе уготована великая дорога, ты это знаешь?"
    ala_granpa "好孩子。有一条伟大的道路在等待着你，你知道吗？"

# game/a3/6ways.rpy:189
translate english ways_b3a40855:

    # ala "Да, дедушка."
    ala "知道，爷爷。"

# game/a3/6ways.rpy:190
translate english ways_e4999427:

    # ala_granpa "Ты сделаешь все, чтобы эта дорога стала судьбой?"
    ala_granpa "你会不惜一切代价，让这条路成为你的命运吗？"

# game/a3/6ways.rpy:191
translate english ways_8e2e9955:

    # ala "Я сделаю все."
    ala "我会不惜一切。"

# game/a3/6ways.rpy:197
translate english ways2_af9fd62f:

    # ala "Ну как ты?"
    ala "感觉怎么样？"

# game/a3/6ways.rpy:198
translate english ways2_164c2d41:

    # mc "Нормально. Голова почти не болит."
    mc "还好。头几乎不疼了。"

# game/a3/6ways.rpy:199
translate english ways2_f1b3b880:

    # ala "Я про воспоминания."
    ala "我是问关于回忆的事。"

# game/a3/6ways.rpy:200
translate english ways2_3f6f0c30:

    # mc "Ага. Я вспомнил. Ты мне кое-что обещала."
    mc "嗯。我想起来了。你答应过我一件事。"

# game/a3/6ways.rpy:201
translate english ways2_28a6d90b:

    # ala "Я? Ты вспоминал меня?"
    ala "我？你刚才回忆的时候想起我来了？"

# game/a3/6ways.rpy:202
translate english ways2_f7ea439e:

    # mc "Куда же делись защитники Пика Ласточки?"
    mc "燕子峰的守卫到底去哪儿了？"

# game/a3/6ways.rpy:203
translate english ways2_ad996e0d:

    # ala "Ох..."
    ala "哦……"

# game/a3/6ways.rpy:204
translate english ways2_25786101:

    # mc "Ты же не лгала мне?"
    mc "你当时不是在对我撒谎吧？"

# game/a3/6ways.rpy:205
translate english ways2_995bee42:

    # ala "Нет. Я покажу тебе, [mename]."
    ala "没有。我会给你看，[mename]。"

# game/a3/6ways.rpy:208
translate english ways2_804d5fb2:

    # ala "Но сначала нам нужно кое-что сделать. [vall]."
    ala "但首先我们需要做一件事。[vall]。"

# game/a3/6ways.rpy:209
translate english ways2_88d2c74b:

    # mc "[vall]?"
    mc "[vall]?"

# game/a3/6ways.rpy:210
translate english ways2_68f93e0f:

    # ala "Эльфийка, которую ты привез в город для суда. Она уже несколько дней в темнице ожидает суда."
    ala "你带到城里来受审的那个精灵女孩。她已经在地牢里待了几天等待审判了。"

# game/a3/6ways.rpy:211
translate english ways2_7a3444c5:

    # mc "Ожидает?"
    mc "等待？"

# game/a3/6ways.rpy:212
translate english ways2_8581b893:

    # ala "Очередь в городской трибунал огромная, если мы не поможем, она будет ждать еще долго."
    ala "城市法庭的待审犯人排成了长队，如果我们不帮忙，她还得等很久。"

# game/a3/6ways.rpy:213
translate english ways2_afb12e6d:

    # mc "Ладно, пойдем."
    mc "好吧，我们走。"

# game/a3/6ways.rpy:217
translate english ways2_6dc63587:

    # ala "Пойдем в руины прямо сейчас?"
    ala "现在就马上去废墟吗？"

# game/a3/6ways.rpy:218
translate english ways2_f34f69c2:

    # mc "Да."
    mc "是的。"

# game/a3/6ways.rpy:222
translate english ways3_c8fcec8e:

    # mc "Когда ты говорила в темнице, ты действительно имела в виду темницу?"
    mc "你之前在说地牢的时候，真的就是指那种地牢？"

# game/a3/6ways.rpy:223
translate english ways3_dcd3a0a6:

    # ala "А что я еще могла иметь в виду?"
    ala "不然我还能指什么？"

# game/a3/6ways.rpy:224
translate english ways3_d291c6e0:

    # mc "Жуткое место."
    mc "真是个可怕的地方。"

# game/a3/6ways.rpy:225
translate english ways3_92c6bce1:

    # ala "А в детстве вам с [cass] нравилось."
    ala "可你小时候和[cass]都很喜欢这儿呢。"

# game/a3/6ways.rpy:226
translate english ways3_8a3dace5:

    # mc "Мы просто хотели напугать друг друга."
    mc "我们只是想吓唬对方罢了。"

# game/a3/6ways.rpy:228
translate english ways3_63432e45:

    # ala "И как? Получалось?"
    ala "怎么样？成功了吗？"

# game/a3/6ways.rpy:229
translate english ways3_6f65be27:

    # mc "Еще бы. В последний раз вышло так хорошо, что сестра осталась без глаза, а меня отправили в изгнание."
    mc "那还用说。上一次玩得太成功了，结果我妹妹丢了一只眼睛，而我被送去了流放地。"

# game/a3/6ways.rpy:230
translate english ways3_656f1f4b:

    # ala "Здесь держат сотни заключенных, искать мы будем долго."
    ala "这里关着几百个囚犯，我们得找很久。"

# game/a3/6ways.rpy:231
translate english ways3_cd635b77:

    # mc "Может спросим стражника на входе?"
    mc "也许可以问问门口的卫兵？"

# game/a3/6ways.rpy:232
translate english ways3_1bf8a975:

    # ala "Думаешь он знает? Здесь сидят те, у кого нет денег откупиться, или представители рас, у которых изначально нет прав."
    ala "你觉得他会知道？关在这里的，要么是没钱赎身的人，要么是来自一些根本没有权利的种族的人。"

# game/a3/6ways.rpy:233
translate english ways3_c4cfab8c:

    # ala "На этих бедняг всем плевать, я даже не уверена, что их кормят."
    ala "没人会在乎这些可怜虫，我甚至都不确定有没有人给他们吃的。"

# game/a3/6ways.rpy:235
translate english ways3_8d4a992c:

    # prisoner1 "Отвалите...не мешайте спать..."
    prisoner1 "滚开……别打扰我睡觉……"

# game/a3/6ways.rpy:236
translate english ways3_1726885c:

    # ala "Ужасные условия. Пару дней здесь и ты точно заболеешь."
    ala "条件太可怕了。在这儿待上几天，肯定会生病的。"

# game/a3/6ways.rpy:238
translate english ways3_1616e459:

    # mc "Здесь довольно тепло."
    mc "这里还挺暖和的。"

# game/a3/6ways.rpy:239
translate english ways3_c5323e13:

    # ala "Здесь крысы. Они заражают кровавой рвотой и чумой."
    ala "这里有老鼠。它们会传播呕血病和鼠疫。"

# game/a3/6ways.rpy:240
translate english ways3_e834ce5f:

    # mc "Ты шутишь..."
    mc "你在开玩笑吧……"

# game/a3/6ways.rpy:241
translate english ways3_886c5efe:

    # ala "нет."
    ala "没有。"

# game/a3/6ways.rpy:243
translate english ways3_7d6c1f84:

    # prisoner2 "Я ничего не знаю и вам не скажу, идите нахуй!"
