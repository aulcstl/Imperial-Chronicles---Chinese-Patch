    mc "但还是会抽筋？"

# game/a3/2medical.rpy:129
translate english medical3_897963a2:

    # lia "Бывает. Особенно когда у меня приступы."
    lia "有时会。尤其是发病的时候。"

# game/a3/2medical.rpy:131
translate english medical3_5755c5fe:

    # lia "Ой."
    lia "哎哟。"

# game/a3/2medical.rpy:132
translate english medical3_fc4e36c1:

    # mc "Проверяю чувствительность."
    mc "我在检查敏感度。"

# game/a3/2medical.rpy:133
translate english medical3_e285ade8:

    # lia "Мне приятно."
    lia "挺舒服的。"

# game/a3/2medical.rpy:134
translate english medical3_cec27a74:

    # mc "Приятно? Не щекотно? Чувствительность нормальная?"
    mc "舒服？不是痒吗？敏感度正常吗？"

# game/a3/2medical.rpy:135
translate english medical3_af39bbfc:

    # lia "Да. Все хорошо."
    lia "正常。一切都好。"

# game/a3/2medical.rpy:136
translate english medical3_a62cbb61:

    # mc "Ладно."
    mc "好。"

# game/a3/2medical.rpy:138
translate english medical3_e7b4cf56:

    # mc "Как у тебя с сердцебиением."
    mc "你的心跳怎么样？"

# game/a3/2medical.rpy:139
translate english medical3_63f509a7:

    # lia "Не знаю. Сам проверяй."
    lia "不知道。你自己检查。"

# game/a3/2medical.rpy:140
translate english medical3_11b6283b:

    # mc "Сердце стучит ровно, но часто."
    mc "心跳平稳，但跳得很快。"

# game/a3/2medical.rpy:141
translate english medical3_9b0276e9:

    # lia "Это от радости. Ты рядом."
    lia "这是因为高兴。有你在我身边。"

# game/a3/2medical.rpy:142
translate english medical3_af0e364b:

    # mc "Что насчет дыхания?"
    mc "呼吸方面呢？"

# game/a3/2medical.rpy:143
translate english medical3_5f34cb90:

    # lia "Бывает трудно дышать. Особенно перед самим приступом."
    lia "有时会呼吸困难。尤其是在快要发病之前。"

# game/a3/2medical.rpy:144
translate english medical3_979801b4:

    # mc "А после приступов?"
    mc "那发病之后呢？"

# game/a3/2medical.rpy:145
translate english medical3_fd6440a4:

    # lia "После все нормально."
    lia "之后一切正常。"

# game/a3/2medical.rpy:147
translate english medical3_cd10e7cd:

    # lia "Тебе помочь?"
    lia "要我帮忙吗？"

# game/a3/2medical.rpy:148
translate english medical3_5b8b8bbf:

    # mc "Я сам справлюсь."
    mc "我自己能应付。"

# game/a3/2medical.rpy:149
translate english medical3_22e1e369:

    # lia "Будешь проверять..."
    lia "你是要检查……"

# game/a3/2medical.rpy:151
translate english medical3_0ff01306:

    # lia "...онемение ног?"
    lia "……腿有没有发麻吗？"

# game/a3/2medical.rpy:152
translate english medical3_17d59061:

    # mc "Кровообращение не нарушено. Ноги теплые."
    mc "血液循环没有受阻。腿是热乎的。"

# game/a3/2medical.rpy:153
translate english medical3_bd35d859:

    # lia "Вообще-то у меня бывают холодными ступни."
    lia "其实我的脚有时候会发凉。"

# game/a3/2medical.rpy:154
translate english medical3_62bdb3ef:

    # mc "Да?"
    mc "是吗？"

# game/a3/2medical.rpy:155
translate english medical3_d93da696:

    # lia "Да. Иногда."
    lia "是的。有时候。"

# game/a3/2medical.rpy:156
translate english medical3_101c77cd:

    # mc "Хорошо, я запишу это."
    mc "好，我把这个记下来。"

# game/a3/2medical.rpy:159
translate english medical3_75372170:

    # mc "На этом все."
    mc "就这些了。"

# game/a3/2medical.rpy:164
translate english medical3_0d2d89f1:

    # lia "Ой...Что ТЫ...ахахахаха...что ты делаешь?"
    lia "哎呀……你干什……哈哈哈哈哈……你在做什么？"

# game/a3/2medical.rpy:165
translate english medical3_b1e0fd8c:

    # mc "Проверяю чувствительность твоих пяточек."
    mc "检查你脚后跟的敏感度。"

# game/a3/2medical.rpy:166
translate english medical3_6b7c26cc:

    # lia "Очень! ОЧЕНЬ ЧУВСТВИТЕЛЬНЫЕ...ХАХАХАХ ХВАТИТ!"
    lia "很敏感！太敏感了……哈哈哈，快停下！"

# game/a3/2medical.rpy:167
translate english medical3_4f061a0c:

    # mc "Уверена, что они чувствительные?"
    mc "你确定它们真的很敏感吗？"

# game/a3/2medical.rpy:168
translate english medical3_8641a354:

    # lia "ДА!! ПОЖАЛУЙСТА ХВАТИТ! УМОЛЯЮ! [mename]!"
    lia "确定！！求你了，停下！求你了！[mename]！"

# game/a3/2medical.rpy:169
translate english medical3_47451155:

    # mc "Ну ладно-ладно."
    mc "好啦好啦。"

# game/a3/2medical.rpy:171
translate english medical3_23898183:

    # mc "Давай проверим твою гибкость."
    mc "我们来检查一下你的柔韧性吧。"

# game/a3/2medical.rpy:172
translate english medical3_0bd662f1:

    # lia "Давай."
    lia "来吧。"

# game/a3/2medical.rpy:173
translate english medical3_8f754090:

    # mc "Не болит спина или поясница?"
    mc "后背或者腰疼不疼？"

# game/a3/2medical.rpy:174
translate english medical3_1d1408c0:

    # lia "Нет. Все отлично. Я очень гибкая."
    lia "不疼。都好得很。我身子很软的。"

# game/a3/2medical.rpy:175
translate english medical3_2faff0c1:

    # mc "Давай еще кое-что проверим."
    mc "我们再检查点别的。"

# game/a3/2medical.rpy:177
translate english medical3_c1fdc781:

    # lia "..."
    lia ".."

# game/a3/2medical.rpy:178
translate english medical3_5f8ff090:

    # mc "Можешь опускать ноги."
    mc "你可以把腿放下来了。"

# game/a3/2medical.rpy:179
translate english medical3_1e1cb6d5:

    # lia "Ладно."
    lia "好。"

# game/a3/2medical.rpy:181
translate english medical3_bb1b745f:

    # lia "Хочешь опять проверить сердцебиение?"
    lia "你该不会又想检查心跳吧？"

# game/a3/2medical.rpy:182
translate english medical3_4a843275:

    # mc "Нет скорее хочу оценить чувствительность твоих некоторых наружных органов."
    mc "不，我更想评估一下你某些外部器官的敏感度。"

# game/a3/2medical.rpy:183
translate english medical3_bf613fc9:

    # lia "М?"
    lia "嗯？"

# game/a3/2medical.rpy:185
translate english medical3_d66b13dc:

    # lia "Ах!"
    lia "啊！"

# game/a3/2medical.rpy:186
translate english medical3_87c9d098:

    # mc "Не больно?"
    mc "不疼吗？"

# game/a3/2medical.rpy:187
translate english medical3_26a13709:

    # lia "Немного...еще немного..."
    lia "有一点点……再有一点……"

# game/a3/2medical.rpy:188
translate english medical3_cf2f1806:

    # mc "Приятно?"
    mc "舒服吗？"

# game/a3/2medical.rpy:189
translate english medical3_30215ba2:

    # lia "Странное чувство... какое-то...тянущее..."
    lia "感觉怪怪的……有点儿……被扯着的感觉……"

# game/a3/2medical.rpy:190
translate english medical3_c9541e22:

    # mc "Тянущее потому что я тяну тебе за сосок. Так и запишем. Чувствительность в норме."
    mc "感觉被扯着是因为我在揪你的乳头。那就这样记录下来。敏感度正常。"

# game/a3/2medical.rpy:191
translate english medical3_e805ae47:

    # lia "Ага. Отлично."
    lia "啊哈。好极了。"

# game/a3/2medical.rpy:194
translate english medical3_5a678236:

    # mc "Ладно, мы закончили."
    mc "好了，我们检查完了。"

# game/a3/2medical.rpy:199
translate english medical3_d3072613:

    # lia "[mename]?"
    lia "[mename]?"

# game/a3/2medical.rpy:200
translate english medical3_687974bd:

    # mc "Знаешь у женщин есть одно место в организме... в нем концентрируется вся их чувствительность."
    mc "你知道吗，女人的身体上有一个部位……她们全部的敏感都集中在那里。"

# game/a3/2medical.rpy:201
translate english medical3_f54df437:

    # lia "Ты говоришь о..."
    lia "你是说……"

# game/a3/2medical.rpy:202
translate english medical3_0e991d5b:

    # mc "Так что если мы хотим провести осмотр до конца, нужно проверить и это место."
    mc "所以要是我们想把检查做彻底，那个地方也得查一查。"

# game/a3/2medical.rpy:203
translate english medical3_5a59b27f:

    # lia "Ты уверен?"
    lia "你确定吗？"

# game/a3/2medical.rpy:204
translate english medical3_9f6b0079:

    # mc "Абсолютно."
    mc "绝对确定。"

# game/a3/2medical.rpy:206
translate english medical3_eeaf441f:

    # lia "Ну ладно...это же просто в медицинских целях."
    lia "那好吧……这只是出于医疗目的嘛。"

# game/a3/2medical.rpy:207
translate english medical3_80d11f2b:

    # mc "Ну разумеется, ты мне доверяешь?"
    mc "那当然，你相信我吗？"

# game/a3/2medical.rpy:208
translate english medical3_a94ba325:

    # lia "Да."
    lia "相信。"

# game/a3/2medical.rpy:210
translate english medical3_33ce492c:

    # lia "Ой!"
    lia "哎呀！"

# game/a3/2medical.rpy:211
translate english medical3_90dd8889:

    # mc "Что-то чувствуешь?"
    mc "感觉到了什么吗？"

# game/a3/2medical.rpy:212
translate english medical3_af78121d:

    # lia "Да!"
    lia "感觉到了！"

# game/a3/2medical.rpy:213
translate english medical3_f69d69f6:

    # lia "Это...не могу описать это чувство. Мне немного стыдно..."
    lia "这……我形容不出这种感觉。我有点儿害羞……"

# game/a3/2medical.rpy:214
translate english medical3_0cac6a9d:

    # mc "Почему? Ты когда-нибудь касалась себя здесь?"
    mc "为什么？你以前自己碰过那个地方吗？"

# game/a3/2medical.rpy:215
translate english medical3_2084a2d2:

    # lia "Нет."
    lia "没有。"

# game/a3/2medical.rpy:216
translate english medical3_69bfa805:

    # mc "Не может быть."
    mc "不可能。"

# game/a3/2medical.rpy:217
translate english medical3_63f20fc0:

    # lia "Ну может иногда...очень редко."
    lia "好吧，也许有时候……很少很少的时候。"

# game/a3/2medical.rpy:218
translate english medical3_4ccbde56:

    # mc "Странно. Для девочки твоего возраста это абсолютно нормально. Трогать себя."
    mc "奇怪。在你这个年纪的女孩，这完全正常。抚弄自己。"

# game/a3/2medical.rpy:219
translate english medical3_d2da34fb:

    # lia "Зачем это делать?"
    lia "为什么要这么做？"

# game/a3/2medical.rpy:220
translate english medical3_c7c0b4b7:

    # mc "Разве тебе не приятно?"
    mc "难道不是让你很舒服吗？"

# game/a3/2medical.rpy:221
translate english medical3_1d25b21e:

    # lia "Мне приятно..."
    lia "是挺舒服的……"

# game/a3/2medical.rpy:222
translate english medical3_d175ea95:

    # mc "Ты действительно никогда раньше не мастурбировала?"
    mc "你以前真的从来没有自慰过吗？"

# game/a3/2medical.rpy:223
translate english medical3_fa403432:

    # lia "Мне кажется я не умею..."
    lia "我觉得我不会……"

# game/a3/2medical.rpy:224
translate english medical3_8f939588:

    # mc "Ты бы хотела, чтобы я тебя научил?"
    mc "你想让我教你吗？"

# game/a3/2medical.rpy:225
translate english medical3_84b63cce:

    # lia "Да..."
    lia "想……"

# game/a3/2medical.rpy:227
translate english medical3_9aa5da83:

    # lia "[mename]."
    lia "[mename]."

# game/a3/2medical.rpy:228
translate english medical3_5d150d79:

    # mc "М?"
    mc "嗯？"

# game/a3/2medical.rpy:229
translate english medical3_149b749f:

    # lia "Людвиг может вернуться в любое время, забыл?"
    lia "Ludwig随时都可能回来，你忘了？"

# game/a3/2medical.rpy:230
translate english medical3_d34be147:

    # mc "Ах точно."
    mc "啊，没错。"

# game/a3/2medical.rpy:231
translate english medical3_ac9b4537:

    # lia "Но я бы хотела....я бы хотела чтобы ты сделал мне так когда-нибудь еще."
    lia "不过我想……我想让你以后什么时候再这样对我一次。"

# game/a3/2medical.rpy:232
translate english medical3_6fa05502:

    # mc "Я обязательно найду для этого время."
    mc "我一定会找时间。"

# game/a3/2medical.rpy:233
translate english medical3_19075f13:

    # lia "Ты будешь записывать мои ощущения в журнал?"
    lia "你会把我的感受记到日志里吗？"

# game/a3/2medical.rpy:234
translate english medical3_431ffb2f:

    # mc "Думаю не стоит. Лучше я просто запомню."
    mc "我觉得还是别记了。我干脆记住就好。"

# game/a3/2medical.rpy:235
translate english medical3_101738be:

    # lia "Да. Лучше так и сделать."
    lia "对。还是这样做更好。"

# game/a3/2medical.rpy:239
translate english medical3_2_ee9585ea:

    # ludwig "Кажется доктор прихватил с собой всю лабораторию. Как вы тут?"
    ludwig "看来医生差不多把整间实验室都给搬走了。你们这边怎么样？"

# game/a3/2medical.rpy:240
translate english medical3_2_0f8fb2d2:

    # mc "Я закончил. Все по инструкции."
    mc "我检查完了。全是按说明做的。"

# game/a3/2medical.rpy:241
translate english medical3_2_d4abfeca:

    # ludwig "Отлично. Сейчас взглянем на ваше состояние, принц."
    ludwig "很好。现在来看看您的情况，王子。"

# game/a3/2medical.rpy:245
translate english medical4_b5490045:

    # ludwig "Как самочувствие после сегодняшнего приступа?"
    ludwig "今天发病过后感觉怎么样？"

# game/a3/2medical.rpy:246
translate english medical4_9796582c:

    # mc "Хорошо. Обычно у меня нет никаких дополнительных последствий."
    mc "挺好。通常我不会有任何额外的后遗症。"

# game/a3/2medical.rpy:247
translate english medical4_7971fbe0:

    # ludwig "Отлично. Насколько я помню последний приступ был несколько лет назад?"
    ludwig "很好。据我所知，您上一次发病是好几年前了？"

# game/a3/2medical.rpy:248
translate english medical4_89be5059:

    # mc "Ага. Очень давно."
    mc "嗯哼。很久之前了。"

# game/a3/2medical.rpy:249
translate english medical4_5ef7d623:

    # ludwig "Если кончено не брать в расчет, что приступы могли совпадать по времени с вашим пьяным беспамятством."
    ludwig "当然，这得排除那些可能与您烂醉失忆恰好同时发生的发病。"

# game/a3/2medical.rpy:250
translate english medical4_e968425d:

    # mc "Ну да...могли."
    mc "嗯，是啊……有可能。"

# game/a3/2medical.rpy:251
translate english medical4_0f3d82da:

    # ludwig "В твоем возрасте гибридная лихорадка становится слабее, меня беспокоит, что ты провел без сознания больше нескольких часов."
    ludwig "到了您这个年纪，混合热病本该减弱才对，您这次昏迷超过了好几个小时，我很担心。"

# game/a3/2medical.rpy:252
translate english medical4_2b35b6fe:

    # mc "..."
    mc "..."

# game/a3/2medical.rpy:253
translate english medical4_d147d5b9:

    # ludwig "Может это вовсе была не она."
    ludwig "说不定根本就不是这病呢。"

# game/a3/2medical.rpy:254
translate english medical4_39636101:

    # mc "А?"
    mc "嗯？"

# game/a3/2medical.rpy:255
translate english medical4_251b19a6:

    # ludwig "Откройте рот принц. Вы случайно не пили что-нибудь...необычное в последнее время?"
    ludwig "请张开嘴，王子。您最近该不会不小心喝了什么……不寻常的东西吧？"

# game/a3/2medical.rpy:256
translate english medical4_7acf4bfe:

    # mc "Намекаешь, что я отравился?"
    mc "你是在暗示我中毒了？"

# game/a3/2medical.rpy:258
translate english medical4_123ccab9:

    # ludwig "Возможно. Просто предполагаю."
    ludwig "有可能。只是猜测。"

# game/a3/2medical.rpy:259
translate english medical4_3a856313:

    # mc "Нет, это точно была лихорадка. Когда у меня приступ я начинаю...видеть всякое."
    mc "不，那肯定就是热病。我发病的时候会开始……看见一些东西。"

# game/a3/2medical.rpy:260
translate english medical4_efcca92f:

    # ludwig "Галлюцинации?"
    ludwig "幻觉吗？"

# game/a3/2medical.rpy:261
translate english medical4_09412d49:

    # mc "Ага. Скорее видения. В этот раз было то же самое."
    mc "嗯哼。更像是幻象。这次也一样。"

# game/a3/2medical.rpy:262
translate english medical4_234504a8:

    # ludwig "Не закрывайте рот, принц."
    ludwig "请不要把嘴合上，王子。"

# game/a3/2medical.rpy:263
translate english medical4_6cc5f044:

    # mc "А как мне тогда разговаривать..."
    mc "那我可怎么说话……"

# game/a3/2medical.rpy:265
translate english medical4_850ea948:

    # "Один осмотр спустя."
    "一次检查以后。"

# game/a3/2medical.rpy:266
translate english medical4_481a7923:

    # ludwig "Все готово. Я приготовлю вам микстуру, ее принесут вам перед сном."
    ludwig "全部弄好了。我会为您配制合剂，睡前会有人给您送去。"

# game/a3/2medical.rpy:267
translate english medical4_1ef647e0:

    # lia "Спасибо Людвиг!"
    lia "谢谢你，Ludwig！"

# game/a3/2medical.rpy:268
translate english medical4_00bb5442:

    # mc "Спасибо."
    mc "谢谢。"

# game/a3/2medical.rpy:269
translate english medical4_d6c24df7:

    # ludwig "Рад служить."
    ludwig "很乐意效劳。"

# game/a3/2medical.rpy:271
translate english medical4_5b56111c:

    # mc "И часто нужно будет эту микстуру пить?"
    mc "这合剂需要经常喝吗？"

# game/a3/2medical.rpy:272
translate english medical4_a2f0001f:

    # lia "Каждый день."
    lia "每天都得喝。"

