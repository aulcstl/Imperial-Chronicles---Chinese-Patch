# game/a3/2medical.rpy:4
translate english medical_da68c1c9:

    # "Немногим позднее."
    "过了一会。"

# game/a3/2medical.rpy:5
translate english medical_5de04a31:

    # conrad "Доктор Верзалиус знает свое дело."
    conrad "维尔扎利乌斯医生精通他的业务。"

# game/a3/2medical.rpy:6
translate english medical_db877131:

    # mc "Видимо слишком хорошо."
    mc "看来是精通得过头了。"

# game/a3/2medical.rpy:7
translate english medical_03d4064a:

    # conrad "М?"
    conrad "嗯？"

# game/a3/2medical.rpy:8
translate english medical_9e8ee10a:

    # mc "Поверить не могу, что члены королевской семьи должны ходить к нему, а не он к нам."
    mc "真不敢相信，王室成员得亲自去找他，而不是他来见我们。"

# game/a3/2medical.rpy:9
translate english medical_0bfe645c:

    # conrad "Он самый лучший, может сам ставить условия."
    conrad "他是最优秀的，有资格自己提条件。"

# game/a3/2medical.rpy:10
translate english medical_1995ceff:

    # mc "Неужели в столице больше нет хороших докторов?"
    mc "难道首都就再没有好医生了吗？"

# game/a3/2medical.rpy:12
translate english medical_b102e33f:

    # conrad "Есть. Но когда я сломал руку в нескольких местах и думал, что уже никогда не смогу пользоваться ей как прежде он вылечил ее."
    conrad "有。但我曾经把手臂摔断了好几处，以为这辈子都没法再像以前那样用它了，结果他给我治好了。"

# game/a3/2medical.rpy:13
translate english medical_9042ac14:

    # conrad "И посмотри - рука целее некуда. Кость срослась идеально. Раньше я думал, что на такое способна только магия."
    conrad "而且你看——这手臂完好得不能再好了。骨头愈合得十分完美。以前我还以为只有魔法才能做到这种地步。"

# game/a3/2medical.rpy:14
translate english medical_e16e53bf:

    # conrad "Но маг-целитель это редкость, ведь излечивая раны, он медленно убивает себя."
    conrad "可治疗法师是很罕见的，因为在治愈伤口的同时，他也是在慢慢地消耗自己。"

# game/a3/2medical.rpy:15
translate english medical_399d7858:

    # mc "Хороший доктор это тоже редкость, раз уж мы почти час ехали к нему верхом."
    mc "好医生同样很罕见，毕竟我们可是骑着马赶了将近一个小时才到他这儿。"

# game/a3/2medical.rpy:16
translate english medical_d28ff4c2:

    # conrad "Оно того стоит. Он здорово помог твоей сестре, когда придворный врач умер."
    conrad "这趟值得。当年御医去世的时候，他可是帮了你妹妹大忙。"

# game/a3/2medical.rpy:17
translate english medical_ad69d0f8:

    # mc "Ну мне уже не терпится увидеть этого чудо-таланта медицинских искусств."
    mc "好吧，我已经等不及要见见这位医学技艺的奇才了。"

# game/a3/2medical.rpy:19
translate english medical_4101bba1:

    # mc "Тук-тук. Я мог войти?"
    mc "咚咚。我能进来吗？"

# game/a3/2medical.rpy:20
translate english medical_97119044:

    # ludwig "[mename]? Заходи."
    ludwig "[mename]？进来吧。"

# game/a3/2medical.rpy:22
translate english medical_156649ef:

    # mc "Что за черт, Людвиг? Ты что здесь делаешь?"
    mc "搞什么鬼，Ludwig？你在这儿干嘛？"

# game/a3/2medical.rpy:23
translate english medical_fe667965:

    # lia "Он заменяет доктора."
    lia "他代替医生出诊。"

# game/a3/2medical.rpy:24
translate english medical_ccd8a4fa:

    # mc "Эм..."
    mc "呃……"

# game/a3/2medical.rpy:25
translate english medical_961238e2:

    # ludwig "Доктор Верзалиус отбыл в западные земли, там случилась необычная эпидемия желтой хвори."
    ludwig "维尔扎利乌斯医生赶往西部领地去了，那边爆发了罕见的黄热病疫情。"

# game/a3/2medical.rpy:26
translate english medical_30fefb39:

    # lia "Ага. Он будет помогать местным жителям!"
    lia "嗯哼。他要去帮当地的居民！"

# game/a3/2medical.rpy:27
translate english medical_0d95e5be:

    # ludwig "Ты проходи, не стой в дверях."
    ludwig "你进来呀，别堵在门口。"

# game/a3/2medical.rpy:28
translate english medical_cb2546f1:

    # lia "Ага. Людвиг и тебя посмотрит."
    lia "对。Ludwig也给你瞧瞧。"

# game/a3/2medical.rpy:30
translate english medical_3ace93d0:

    # mc "Не знал, что владеешь врачебным искусством."
    mc "我都不知道你还懂医术。"

# game/a3/2medical.rpy:31
translate english medical_f9b78de0:

    # ludwig "Я просто умею смотреть глазами и соотносить то, что я увидел, с тем, что написали седобородые мудрецы в книгах."
    ludwig "我不过是会用眼睛看，再把我看到的情形跟那些白胡子贤者写在书里的记载对照一下罢了。"

# game/a3/2medical.rpy:32
translate english medical_af76a0fb:

    # mc "А если в книге будет написано отрезать пациенту ногу?"
    mc "那要是书上写着要把病人的腿给截掉呢？"

# game/a3/2medical.rpy:33
translate english medical_4b06ba18:

    # ludwig "Не беспокойтесь, мой принц, я ничего отрезать не буду. Мой добрый друг доктор Верзалиус оставил мне инструкции по приготовлению микстуры."
    ludwig "请别担心，我的王子，我不会截任何东西。我的好朋友维尔扎利乌斯医生给我留了配制合剂的说明。"

# game/a3/2medical.rpy:34
translate english medical_3c4e06a0:

    # mc "А зачем тогда нужен осмотр?"
    mc "那检查又是为了什么？"

# game/a3/2medical.rpy:35
translate english medical_7d0f1672:

    # ludwig "От вашего состояния будет зависеть концентрация лекарств."
    ludwig "药的浓度要根据您的身体状况来定。"

# game/a3/2medical.rpy:37
translate english medical_fa0f24cb:

    # mc "Это может быть вредно?"
    mc "这会有什么害处吗？"

# game/a3/2medical.rpy:38
translate english medical_b4d145f3:

    # ludwig "Как и любое лекарство."
    ludwig "跟任何药物一样。"

# game/a3/2medical.rpy:39
translate english medical_e14b32db:

    # lia "[mename], не бойся, я выпила целое море всевозможных лекарств и со мной все в порядке."
    lia "[mename]，别怕，我喝过的各种药简直能汇成一片海了，而我什么事都没有。"

# game/a3/2medical.rpy:40
translate english medical_e948c705:

    # mc "Я не боюсь. Просто немного сомневаюсь в компетенции Людвига."
    mc "我不是害怕。只是对Ludwig的本事有点怀疑。"

# game/a3/2medical.rpy:41
translate english medical_48c0b19e:

    # ludwig "Вы меня обижаете, принц. Разве вы не помните сколько раз я спасал ваше здоровье после ваших сеансов пьянства?"
    ludwig "您这话可真伤我心，王子。您难道不记得，在您那么多次喝得烂醉之后，是我多少次保住了您的健康吗？"

# game/a3/2medical.rpy:42
translate english medical_0b958f72:

    # mc "Не думаю, что похмелье и гибридная лихорадка лечатся похожим образом."
    mc "我不觉得宿醉和混合热病能用差不多的方法治疗。"

# game/a3/2medical.rpy:43
translate english medical_c52c66b8:

    # lia "Ну ты и трусишка, [mename]."
    lia "你可真是个胆小鬼，[mename]。"

# game/a3/2medical.rpy:44
translate english medical_990f847e:

    # ludwig "Вынужден согласиться с принцессой."
    ludwig "我不得不赞同公主殿下的看法。"

# game/a3/2medical.rpy:45
translate english medical_eb3ce352:

    # mc "Я не...ладно давайте начинать."
    mc "我不是……算了，我们开始吧。"

# game/a3/2medical.rpy:48
translate english medical_2967e977:

    # ludwig "Кстати раз уж вы не доверяете моим навыкам и неоднократно сами читали труды по врачеванию, хотите провести осмотр сестры самостоятельно?"
    ludwig "对了，既然您不信任我的本领，而且您自己也不止一次读过医学著作，想不想亲自给令妹做检查？"

# game/a3/2medical.rpy:49
translate english medical_8bcabed3:

    # mc "Я никогда этого не делал..."
    mc "我从没做过这种事……"

# game/a3/2medical.rpy:50
translate english medical_cec38b21:

    # ludwig "В книге на столе все написано. Там не ошибиться."
    ludwig "桌上的书里全都写着呢。照着做就不会出错。"

# game/a3/2medical.rpy:54
translate english medical_7c74c158:

    # mc "Ну ладно."
    mc "那好吧。"

# game/a3/2medical.rpy:55
translate english medical_b3b8ba94:

    # ludwig "Отлично. Я пока схожу за дополнительными материалами."
    ludwig "太好了。我先去拿些补充材料。"

# game/a3/2medical.rpy:56
translate english medical_9ccc425e:

    # lia "Ура! Я и [mename] будем играть в доктора!"
    lia "乌拉！我和[mename]要玩医生游戏啦！"

# game/a3/2medical.rpy:59
translate english medical_65c85fda:

    # mc "Я...пожалуй откажусь."
    mc "我……还是算了。"

# game/a3/2medical.rpy:64
translate english medical2_dcf10377:

    # ludwig "С вашей сестрой я уже почти закончил, подождите немного, принц. Осталось проверить только отверстий в голове."
    ludwig "令妹这边我差不多检查完了，请稍等片刻，王子。只剩下检查一下她脑袋上的洞了。"

# game/a3/2medical.rpy:65
translate english medical2_e12fb2b3:

    # lia "Оверевия в алаве...ээээээаааааа."
    lia "检查……脑……袋上的……洞……呃呃呃啊啊啊啊。"

# game/a3/2medical.rpy:66
translate english medical2_39bb20a3:

    # ludwig "Не разговаривайте, принцесса."
    ludwig "请不要说话，公主。"

# game/a3/2medical.rpy:67
translate english medical2_c1fdc781:

    # lia "..."
    lia "..."

# game/a3/2medical.rpy:68
translate english medical2_75b8c8b1:

    # ludwig "Явное покраснение в горле..."
    ludwig "喉咙明显充血……"

# game/a3/2medical.rpy:69
translate english medical2_3b98f9c3:

    # lia "Я умру?"
    lia "我会死吗？"

# game/a3/2medical.rpy:70
translate english medical2_c62e7d12:

    # ludwig "Я же просил не разговаривать."
    ludwig "我都说了不要说话。"

# game/a3/2medical.rpy:72
translate english medical2_c0e92091:

    # mc "Проще осматривать ее пока она спит."
    mc "在她睡着的时候检查反倒更容易。"

# game/a3/2medical.rpy:73
translate english medical2_8e67b2ac:

    # ludwig "Учту. Но что-то мне подсказывает, что она и во сне будет мешать."
    ludwig "我记下了。但我有种预感，她就算睡着了也会捣乱。"

# game/a3/2medical.rpy:74
translate english medical2_25ef778b:

    # lia "Эй! Я просто хочу помочь."
    lia "喂！我只是想帮上忙。"

# game/a3/2medical.rpy:75
translate english medical2_44b5eaf8:

    # mc "Разговаривая без умолку?"
    mc "靠没完没了地说话来帮忙吗？"

# game/a3/2medical.rpy:76
translate english medical2_fcfd63cf:

    # ludwig "Ушные раковины в порядке..."
    ludwig "耳廓正常……"

# game/a3/2medical.rpy:77
translate english medical2_279795b1:

    # lia "Я чищу уши перед сном!"
    lia "我每天晚上睡觉前都清理耳朵的！"

# game/a3/2medical.rpy:78
translate english medical2_ca18b43b:

    # ludwig "Ладно, тут мы закончили, твой черед, [mename]."
    ludwig "好了，这边我们检查完了，轮到你了，[mename]。"

# game/a3/2medical.rpy:82
translate english medical3_744d5482:

    # lia "Ну? Чего ждешь?"
    lia "怎么了？还在等什么？"

# game/a3/2medical.rpy:83
translate english medical3_330cd998:

    # mc "Погоди, [lia], сначала мне нужно прочесть порядок действий."
    mc "等一下，[lia]，我得先读一遍操作步骤。"

# game/a3/2medical.rpy:84
translate english medical3_662bc315:

    # lia "Просто смотри где у меня что болит и записывай."
    lia "你就看我哪里疼，记下来就行了。"

# game/a3/2medical.rpy:85
translate english medical3_db82f027:

    # mc "А у тебя что-то болит?"
    mc "可你哪儿疼吗？"

# game/a3/2medical.rpy:86
translate english medical3_fa940700:

    # lia "Нет...это образное выражение. "
    lia "不疼……这是个比喻的说法。"

# game/a3/2medical.rpy:87
translate english medical3_833ac573:

    # mc "Ага. Вот. Нашел. Порядок действий при осмотре пациента страдающего гибридной лихорадкой."
    mc "啊哈。这里。找到了。对患有混合热病的病人进行检查的操作步骤。"

# game/a3/2medical.rpy:89
translate english medical3_73667277:

    # mc "Здесь...поразительное количество разных сочетаний. Полугоблин, полусирена, полуорк..."
    mc "这里的……组合种类多得惊人。半地精、半海妖、半兽人……"

# game/a3/2medical.rpy:90
translate english medical3_105c17af:

    # lia "Я полуэльф."
    lia "我是半精灵。"

# game/a3/2medical.rpy:91
translate english medical3_a78c8536:

    # mc "Полуэльф-полуконфетка."
    mc "半精灵半糖果。"

# game/a3/2medical.rpy:92
translate english medical3_26b6388a:

    # lia "Получеловек!"
    lia "半人类！"

# game/a3/2medical.rpy:93
translate english medical3_3dd73aae:

    # mc "Ага. Вот оно. Здесь записи Людвига. Он уже почти закончил осмотр."
    mc "啊哈。就是这里。这儿有Ludwig的记录。他的检查已经差不多快做完了。"

# game/a3/2medical.rpy:94
translate english medical3_777cd991:

    # lia "Давай заново."
    lia "我们从头来一遍。"

# game/a3/2medical.rpy:95
translate english medical3_b0b87747:

    # mc "Уверена?"
    mc "你确定吗？"

# game/a3/2medical.rpy:96
translate english medical3_d05ed252:

    # lia "Да! Тебе нужно тренироваться. Может ты однажды будешь первым королем-врачом."
    lia "确定！你需要练习。说不定将来你会成为第一位国王兼医师呢。"

# game/a3/2medical.rpy:97
translate english medical3_c80fd6cd:

    # mc "Ну ладно. Так...начнем с горла."
    mc "那好吧。那……我们从喉咙开始。"

# game/a3/2medical.rpy:99
translate english medical3_686512be:

    # mc "Скажи А."
    mc "说“啊”。"

# game/a3/2medical.rpy:100
translate english medical3_d6bf7aad:

    # lia "Ааааааа."
    lia "啊啊啊啊啊。"

# game/a3/2medical.rpy:101
translate english medical3_2aacf38f:

    # mc "Ага. Язык бледный. А вот в горле явные покраснения."
    mc "嗯哼。舌色偏淡。不过喉咙明显发红。"

# game/a3/2medical.rpy:102
translate english medical3_09b58dca:

    # lia "ОаАаАА!"
    lia "哦啊啊啊！"

# game/a3/2medical.rpy:103
translate english medical3_eb2ec2b8:

    # mc "Зубы нечищенные."
    mc "牙齿没刷干净。"

# game/a3/2medical.rpy:104
translate english medical3_6820570a:

    # lia "Што!? Я чифштила шубы!!"
    lia "色么！？我明明刷了牙牙的！！"

# game/a3/2medical.rpy:105
translate english medical3_de75da6e:

    # mc "Не закрывай рот."
    mc "别把嘴闭上。"

# game/a3/2medical.rpy:106
translate english medical3_72c5a09f:

    # lia "Не обманывай тогда."
    lia "那就别撒谎。"

# game/a3/2medical.rpy:108
translate english medical3_9a996ebb:

    # mc "Так. Проверяем зрение. Сколько пальцев видишь?"
    mc "好了。检查视力。你看见我伸出几根手指？"

# game/a3/2medical.rpy:109
translate english medical3_a7a7ea1f:

    # lia "Сорок пять."
    lia "四十五根。"

# game/a3/2medical.rpy:110
translate english medical3_c1d62ead:

    # mc "Я серьезно."
    mc "我是认真的。"

# game/a3/2medical.rpy:111
translate english medical3_e6ca7513:

    # lia "Тридцать семь."
    lia "三十七根。"

# game/a3/2medical.rpy:112
translate english medical3_c603fa5a:

    # mc "[lia]..."
    mc "[lia]..."

# game/a3/2medical.rpy:113
translate english medical3_941eaf49:

    # lia "Ну ладно-ладно. Тысяча сто пять."
    lia "好啦好啦。一千一百零五根。"

# game/a3/2medical.rpy:114
translate english medical3_363fdbb3:

    # mc "Ага. Тут сказано, если пациент видит неправильное количество его необходимо лишить всего сладкого на год."
    mc "啊哈。书上写着，要是病人看到的数量不对，就得罚他一整年不许吃任何甜的东西。"

# game/a3/2medical.rpy:115
translate english medical3_c0e75ae5:

    # lia "Один! Один палец вижу!"
    lia "一根！我看见一根手指！"

# game/a3/2medical.rpy:116
translate english medical3_e3db1e4c:

    # mc "А если серьезно? Палец не двоится? Глаза не болят когда двигаешь взгляд?"
    mc "那说认真的呢？手指有没有重影？转动视线的时候眼睛疼不疼？"

# game/a3/2medical.rpy:117
translate english medical3_12f35e6c:

    # lia "Нет. Все хорошо."
    lia "不疼。一切都好。"

# game/a3/2medical.rpy:118
translate english medical3_67d1ade9:

    # mc "Отлично."
    mc "很好。"

# game/a3/2medical.rpy:120
translate english medical3_476906f1:

    # lia "Что ты делаешь?"
    lia "你在做什么？"

# game/a3/2medical.rpy:121
translate english medical3_f5a92cb7:

    # mc "Проверяю твои ноги."
    mc "检查你的腿。"

# game/a3/2medical.rpy:122
translate english medical3_08f5d409:

    # lia "С ними все хорошо."
    lia "我的腿都很好。"

# game/a3/2medical.rpy:123
translate english medical3_f9ac7773:

    # mc "Не болят? Кожа не жжет?"
    mc "不疼吗？皮肤有没有灼烧感？"

# game/a3/2medical.rpy:124
translate english medical3_12f35e6c_1:

    # lia "Нет. Все хорошо."
    lia "没有。一切都好。"

# game/a3/2medical.rpy:126
translate english medical3_2d60ecbe:

    # mc "Как часто у тебя бывают судороги?"
    mc "你抽筋的频率高吗？"

# game/a3/2medical.rpy:127
translate english medical3_377ca3a8:

    # lia "Не очень часто."
    lia "不算很高。"

# game/a3/2medical.rpy:128
translate english medical3_81f8e6b3:

