# game/a3/9two_princess.rpy:8
translate english two_princess_90c66e21:

    # "Некоторое время спустя."
    "过了一会."

# game/a3/9two_princess.rpy:9
translate english two_princess_cda16407:

    # "Сегодня тот самый день."
    "Today is the day."

# game/a3/9two_princess.rpy:10
translate english two_princess_2c8f49c1:

    # "Обе принцессы прибывают в город."
    "Both princesses are coming to palace."

# game/a3/9two_princess.rpy:11
translate english two_princess_9b97c72e:

    # "Как я должен к этому относится? Не знаю."
    "How should I feel about this? I don't know."

# game/a3/9two_princess.rpy:12
translate english two_princess_be11f954:

    # "Но то что я точно знаю - я очень взволнован."
    "But what I know is that I'm very excited."

# game/a3/9two_princess.rpy:13
translate english two_princess_f159440a:

    # "Какие они?"
    "What are they like?"

# game/a3/9two_princess.rpy:15
translate english two_princess_dc2a52cf:

    # mom "[mename]?"
    mom "[mename]?"

# game/a3/9two_princess.rpy:16
translate english two_princess_84974ea2:

    # mc "Мам?"
    mc "妈妈？"

# game/a3/9two_princess.rpy:17
translate english two_princess_8cb0a7be:

    # mom "Скучаешь?"
    mom "想我了？"

# game/a3/9two_princess.rpy:18
translate english two_princess_b02f2238:

    # mc "Ага."
    mc "嗯。"

# game/a3/9two_princess.rpy:19
translate english two_princess_599b845a:

    # mom "Не хочешь прогуляться?"
    mom "想去散散步吗？"

# game/a3/9two_princess.rpy:20
translate english two_princess_96800b9d:

    # mc "Мам..."
    mc "妈妈……"

# game/a3/9two_princess.rpy:22
translate english two_princess_f4ef00e7:

    # mom "Да?"
    mom "怎么了？"

# game/a3/9two_princess.rpy:23
translate english two_princess_c92d28cc:

    # mc "Во что ты одета?"
    mc "你穿的这是什么？"

# game/a3/9two_princess.rpy:24
translate english two_princess_f422af06:

    # mom "Тебе не нравится?"
    mom "你不喜欢？"

# game/a3/9two_princess.rpy:25
translate english two_princess_77ea8f80:

    # mc "Нравится. Просто никогда не видел тебя раньше...такой."
    mc "喜欢。只是从没见过你……这样穿。"

# game/a3/9two_princess.rpy:26
translate english two_princess_ea9e819b:

    # mom "Какой?"
    mom "哪样？"

# game/a3/9two_princess.rpy:27
translate english two_princess_4601c70d:

    # mc "Эм...неформально одетой."
    mc "呃……穿得这么随便。"

# game/a3/9two_princess.rpy:29
translate english two_princess_cdcae87d:

    # mom "Это все потому что мы сегодня отправимся с тобой в город. А там не место для придворной одежды."
    mom "都是因为今天我们要进城去。那里可不是穿宫廷礼服的地方。"

# game/a3/9two_princess.rpy:30
translate english two_princess_0bb1f9a3:

    # mc "В город?"
    mc "进城？"

# game/a3/9two_princess.rpy:31
translate english two_princess_5936ff0d:

    # mom "Ну ты же хочешь посмотреть на принцесс?"
    mom "你不是想看看那些公主们吗？"

# game/a3/9two_princess.rpy:32
translate english two_princess_8598a6bc:

    # mc "Я ведь и так их увижу."
    mc "反正我总会见到她们的。"

# game/a3/9two_princess.rpy:33
translate english two_princess_bc6e1fdb:

    # mom "Это не то. Когда они будут представать перед тобой и говорить заученные текста, как им повезло быть здесь и как они счастливы с тобой познакомится..."
    mom "那可不一样。当她们站在你面前，说着那些背好的台词，说什么她们多幸运能来到这里，多高兴认识你……"

# game/a3/9two_princess.rpy:34
translate english two_princess_c4ccddca:

    # mom "Короче говоря у тебя сегодня возможно последний шанс посмотреть на них со стороны. Ты идешь или как?"
    mom "总之，今天可能是你最后的机会，能从旁观察她们了。你到底去不去？"

# game/a3/9two_princess.rpy:35
translate english two_princess_5ab64e84:

    # mc "Я иду."
    mc "我去。"

# game/a3/9two_princess.rpy:37
translate english two_princess_f77db1fa:

    # mom "Насколько я знаю, одну зовут Аврора, она из знатной семи Дубовитских, ее отца переизбирают королем севера уже в одиннадцатый раз."
    mom "据我所知，一个叫Aurora，来自显赫的Dubovitsky家族，她父亲已经第十一次连任北境之王了。"

# game/a3/9two_princess.rpy:38
translate english two_princess_513c1946:

    # mc "Эта та, что с севера?"
    mc "是那个北方来的？"

# game/a3/9two_princess.rpy:39
translate english two_princess_ea4d5db7:

    # mom "Конечно."
    mom "当然。"

# game/a3/9two_princess.rpy:40
translate english two_princess_6c930048:

    # mc "А вторая?"
    mc "那第二个呢？"

# game/a3/9two_princess.rpy:41
translate english two_princess_5c47deb5:

    # mom "О второй я почти ничего не знаю, политика на Юге это клубок змей, так что я даже не уверена, что ее семья занимает там серьезное положение."
    mom "第二个我几乎一无所知，南方的政坛就是个蛇窝，所以我甚至不确定她的家族在那边是否位高权重。"

# game/a3/9two_princess.rpy:42
translate english two_princess_13955494:

    # mc "С чего тогда отец решил, что брак с ней даст ему надежный союз?"
    mc "那父亲怎么会觉得娶她就能结成稳固的同盟？"

# game/a3/9two_princess.rpy:43
translate english two_princess_72fadb64:

    # mom "Не знаю, у тебя будет достаточно времени, чтобы выяснить так это или нет."
    mom "不知道。你会有足够的时间去弄清楚这点的。"

# game/a3/9two_princess.rpy:45
translate english two_princess_59a575eb:

    # mom "Подойди сюда. Первая принцесса прибыла."
    mom "过来。第一位公主到了。"

# game/a3/9two_princess.rpy:46
translate english two_princess_73e8d36e:

    # mc "А? Мы же должны были встретить их в городе."
    mc "啊？我们不是应该在城里迎接她们吗？"

# game/a3/9two_princess.rpy:47
translate english two_princess_44c2b3e3:

    # mom "Кажется одна из них решила явится без приглашения."
    mom "看来其中一位决定不请自来了。"

# game/a3/9two_princess.rpy:48
translate english two_princess_ddefc017:

    # mc "Ты серьезно?"
    mc "你认真的？"

# game/a3/9two_princess.rpy:49
translate english two_princess_8b6dd2e9:

    # mom "Может сам посмотришь?"
    mom "要不要自己看看？"

# game/a3/9two_princess.rpy:51
translate english two_princess_73b5ce3d:

    # ice_guard "Леди, мы прибыли."
    ice_guard "小姐，我们到了。"

# game/a3/9two_princess.rpy:52
translate english two_princess_4b7eaf4d:

    # aurora "Как, уже?"
    aurora "怎么，这么快？"

# game/a3/9two_princess.rpy:53
translate english two_princess_2a5e0150:

    # ice_guard "Да. Постойте я помогу вам выйти."
    ice_guard "是的。请稍等，我扶您下车。"

# game/a3/9two_princess.rpy:54
translate english two_princess_3b881e84:

    # aurora "Не нужно. Я сама."
    aurora "不用了。我自己来。"

# game/a3/9two_princess.rpy:56
translate english two_princess_2d6ae39a:

    # ice_guard "Позвольте сопроводить вас внутрь."
    ice_guard "请允许我护送您进去。"

# game/a3/9two_princess.rpy:57
translate english two_princess_b8cbe852:

    # aurora "Не нужно. Не хочу чтобы мой будущий муж думал, что я боюсь этого места."
    aurora "不用。我可不想让我未来的丈夫觉得我害怕这个地方。"

# game/a3/9two_princess.rpy:58
translate english two_princess_66971867:

    # ice_guard "Вы уверены?"
    ice_guard "您确定吗？"

# game/a3/9two_princess.rpy:59
translate english two_princess_6e0b5abc:

    # aurora "Да. Займитесь пока вещами. Я представлюсь сама."
    aurora "确定。你先去处理行李吧。我自己去引见。"

# game/a3/9two_princess.rpy:60
translate english two_princess_4cb025e7:

    # ice_guard "Здесь не север, леди. Ваша самостоятельность может быть не оценена по достоинству."
    ice_guard "小姐，这里不是北方。您的特立独行未必会受到赏识。"

# game/a3/9two_princess.rpy:61
translate english two_princess_7104a00f:

    # aurora "Я знаю, что делаю."
    aurora "我知道自己在做什么。"

# game/a3/9two_princess.rpy:63
translate english two_princess_f01e872c:

    # ice_guard "Как пожелаете, леди."
    ice_guard "如您所愿，小姐。"

# game/a3/9two_princess.rpy:64
translate english two_princess_24e208ca:

    # aurora "Ну здравствуй...новый дом."
    aurora "嗯，你好啊……新家。"

# game/a3/9two_princess.rpy:65
translate english two_princess_b97f66b6:

    # mom "Ну и как она тебе?"
    mom "你觉得她怎么样？"

# game/a3/9two_princess.rpy:66
translate english two_princess_c649b4b3:

    # mc "Светленькая...я бы даже сказал бледная."
    mc "浅色头发……我甚至会说有点苍白。"

# game/a3/9two_princess.rpy:67
translate english two_princess_b9b28d71:

    # mom "Ну конечно. Она же с севера. Нравится тебе?"
    mom "那当然了。她是从北方来的嘛。你喜欢她吗？"

# game/a3/9two_princess.rpy:68
translate english two_princess_bdc438e4:

    # mc "Понятия не имею, я с ней еще не общался."
    mc "不知道，我还没跟她说过话。"

# game/a3/9two_princess.rpy:69
translate english two_princess_8d62f0a1:

    # mom "Ну а внешне?"
    mom "那外表呢？"

# game/a3/9two_princess.rpy:70
translate english two_princess_ab7dce3d:

    # mc "А это важно?"
    mc "这很重要吗？"

# game/a3/9two_princess.rpy:71
translate english two_princess_5d78436c:

    # mom "Да ладно тебе, не придуривайся."
    mom "得了吧，别装傻。"

# game/a3/9two_princess.rpy:72
translate english two_princess_c96b00b6:

    # "У меня возникла хорошая идея. Я мог бы пообщаться с ней, пока она не знает, кто я. Может представиться слугой?"
    "I have a good idea. I could talk to her while she doesn't know who I am. Can I introduce myself as a servant?"

# game/a3/9two_princess.rpy:77
translate english two_princess_9925e020:

    # mc "Знаешь у меня возникла идея. Помнишь книгу босоногий король?"
    mc "你知道吗，我有个主意。还记得那本《赤脚国王》吗？"

# game/a3/9two_princess.rpy:78
translate english two_princess_5abd3aa2:

    # mom "М?"
    mom "嗯？"

# game/a3/9two_princess.rpy:79
translate english two_princess_0d7a811e:

    # mc "Там сказочный король переодевается в нищего, чтобы пройтись по городу и узнать мнение людей о себе."
    mc "书里那个童话国王打扮成乞丐到城里去，想听听百姓对他的真实看法。"

# game/a3/9two_princess.rpy:80
translate english two_princess_a4675bb6:

    # mom "К чему ты клонишь?"
    mom "你想说什么？"

# game/a3/9two_princess.rpy:81
translate english two_princess_03b3b76d:

    # mc "Я бы мог провернуть с ней то же самое. Ты же сама говорила, сегодня последний шанс посмотреть на принцесс со стороны."
    mc "我也可以对她这么做。你自己不也说了，今天是最后的机会，能从旁观察这些公主。"

# game/a3/9two_princess.rpy:82
translate english two_princess_91848080:

    # mom "Ты хочешь представиться ей слугой?"
    mom "你想在她面前假扮成仆人？"

# game/a3/9two_princess.rpy:83
translate english two_princess_ff7c0bf0:

    # mc "Например. Ее как раз должен кто-то встретить."
    mc "比如说。正好需要有人去接待她。"

# game/a3/9two_princess.rpy:84
translate english two_princess_0e11da81:

    # mom "Хорошо придумано. Только в таком случае ты не успеешь посмотреть на южную принцессу."
    mom "好主意。不过这样的话，你就没时间去看那位南方公主了。"

# game/a3/9two_princess.rpy:87
translate english two_princess_bdd07f47:

    # mc "Всегда нужно чем-то жертвовать. Я хочу проверить эту девушку."
    mc "人总要有所取舍。我想考验一下这个姑娘。"

# game/a3/9two_princess.rpy:90
translate english two_princess_9566fb9c:

    # mc "Ты права. Я хочу еще увидеть принцессу Юга."
    mc "你说得对。我还想看看南方公主。"

# game/a3/9two_princess.rpy:95
translate english two_princess2_2a228e9b:

    # mom "Она выглядит милой девушкой. Хочет показаться сильной северянкой."
    mom "她看起来像个可爱的姑娘。想要表现得像个坚强的北方女子。"

# game/a3/9two_princess.rpy:96
translate english two_princess2_1f511a5b:

    # mc "Она тебе понравилась?"
    mc "你喜欢她？"

# game/a3/9two_princess.rpy:97
translate english two_princess2_d52be990:

    # mom "Пока рано говорить, но надо сказать у меня плохие предчувствия по поводу ее...конкурентки."
    mom "现在说还太早，不过我得说，对她的……竞争对手，我有种不好的预感。"

# game/a3/9two_princess.rpy:99
translate english two_princess2_351f18c3:

    # mc "А я думал тебе нравятся южные девушки. Или они хороши только в качестве шлюх?"
    mc "我还以为你喜欢南方姑娘呢。还是说她们只适合当妓女？"

# game/a3/9two_princess.rpy:100
translate english two_princess2_0b4e3f93:

    # mom "[mename]..."
    mom "[mename]..."

# game/a3/9two_princess.rpy:101
translate english two_princess2_47451155:

    # mc "Ну ладно-ладно."
    mc "好啦好啦。"

# game/a3/9two_princess.rpy:102
translate english two_princess2_c21ec484:

    # mom "Как я и говорила - политика на Юге дело смертельно опасное. И воспитывает это место опасных людей."
    mom "就像我说过的——南方的政治是极其危险的事业。那片土地孕育出危险的人。"

# game/a3/9two_princess.rpy:103
translate english two_princess2_a69b3b04:

    # mc "Ты меня заинтриговала. Посмотрим на нее лично?"
    mc "你勾起我的兴趣了。我们亲自去看看她？"

# game/a3/9two_princess.rpy:104
translate english two_princess2_6f6f8925:

    # mom "Да. Только накинем плащи. Не хватало, только чтобы нас узнали."
    mom "好。不过得披上斗篷。可不能让人认出来。"

# game/a3/9two_princess.rpy:106
translate english two_princess2_53e7ed74:

    # mom "Вот эта таверна подойдет."
    mom "这家酒馆就不错。"

# game/a3/9two_princess.rpy:107
translate english two_princess2_5b5630bc:

    # mc "Принцесса любит припить дешевого вина?"
    mc "公主喜欢喝便宜酒？"

# game/a3/9two_princess.rpy:108
translate english two_princess2_f563af17:

    # mom "Очень смешно. Отсюда хорошо видна улица."
    mom "真好笑。从这里能清楚地看到街道。"

# game/a3/9two_princess.rpy:109
translate english two_princess2_1cf2b2b0:

    # mc "С чего ты взяла, что она будет проезжать именно по ней."
    mc "你怎么确定她一定会走这条路？"

# game/a3/9two_princess.rpy:110
translate english two_princess2_d6f17a36:

    # mom "Это самая широкая улица к которой ведет южный тракт. Не думаю, что наша гостья с Юга отличается такой же скромностью, как северянка."
    mom "这是通往南方大道最宽阔的一条街了。我不觉得我们这位南方来的客人会像北方姑娘那样低调。"

# game/a3/9two_princess.rpy:111
translate english two_princess2_db05af11:

    # mc "Что, по-твоему, она будет делать?"
    mc "那你觉得她会怎么做？"

# game/a3/9two_princess.rpy:112
translate english two_princess2_9fb3a7d0:

    # mom "Давай сначала присядем."
    mom "我们先坐下再说。"

# game/a3/9two_princess.rpy:114
translate english two_princess2_bb88aed8:

    # mom "Две кружки пива."
    mom "两大杯啤酒。"

# game/a3/9two_princess.rpy:115
translate english two_princess2_5f4ae36e:

    # mc "Пива? Я конечно не рассчитывал на аранское золотое, но пиво?"
    mc "啤酒？虽然我没指望喝到阿兰的金色葡萄酒，但啤酒？"

# game/a3/9two_princess.rpy:116
translate english two_princess2_361dc137:

    # mom "[mename], ты и так носишь волосы, не закрывая свои длинные уши, хочешь привлечь дополнительное внимание своим пристрастием к дорогим напиткам?"
    mom "[mename]，你都已经散着头发，不遮住你的长耳朵了，难道还想靠偏爱名贵饮料来引人注目吗？"

# game/a3/9two_princess.rpy:117
translate english two_princess2_2403e9e7:

    # mc "Ладно, я выпью пива."
    mc "好吧，我喝啤酒。"

# game/a3/9two_princess.rpy:118
translate english two_princess2_dc9f795f:

    # mom "Вот и отлично."
    mom "那就好。"

# game/a3/9two_princess.rpy:120
translate english two_princess2_90c66e21:

    # "Некоторое время спустя."
    "过了一会."

# game/a3/9two_princess.rpy:121
translate english two_princess2_b3d6a585:

    # mc "Знаешь, мам, ты такая красивая, что я понимаю, что легко бы женился и на эльфийке. А что? Почти всю жизнь молодая жена...это же мечта."
    mc "知道吗，妈妈，你真美，美到我觉得我都可以轻易娶个精灵了。为什么不呢？妻子几乎能青春永驻一辈子……这可是梦想啊。"

# game/a3/9two_princess.rpy:122
translate english two_princess2_5f4ea80d:

    # mom "Спасибо, [mename], но это будет уже слишком. Отца и так недолюбливают за то, что он смешал королевскую кровь."
    mom "谢谢你，[mename]，但那也太过了。因为你父亲混有王室血统，已经够招人恨的了。"

# game/a3/9two_princess.rpy:123
translate english two_princess2_31eb980f:

    # mc "Ну знаешь, Золотая Столица довольно свободное и терпимое место. Ни в какое сравнение с городами востока и севера. Особенно севера. Поверь мне я знаю."
    mc "你得知道，黄金都城是个相当自由开明的地方。东方和北方的城市根本没法比。尤其是北方。相信我，我知道。"

# game/a3/9two_princess.rpy:124
translate english two_princess2_f7f51297:

    # mom "Разве на севере ущемляют малые расы? Я слышала в армии, что сражалась против Красного Императора были и эльфы и гномы и даже сирены."
    mom "北方难道压迫少数种族吗？我听说，对抗红色皇帝的军队里，有精灵，有矮人，甚至还有海妖。"

# game/a3/9two_princess.rpy:125
translate english two_princess2_fdc1674c:

    # mc "Я говорю о терпимости и свободах другого рода..."
    mc "我说的宽容和自由是另一回事……"

# game/a3/9two_princess.rpy:126
translate english two_princess2_1e4691a1:

    # mom "Например?"
    mom "比如说？"

# game/a3/9two_princess.rpy:127
translate english two_princess2_8a99bda5:

    # mc "Например на западе полно полуэльфов, они даже служат в армии, в то же время северянин, узнавший, что его дочь понесла от эльфа, наверняка забил бы ее камнями."
    mc "比如说，西方有很多半精灵，他们甚至能在军队服役；但换作一个北方人，要是知道他女儿怀了精灵的孩子，他八成会用石头砸死她。"

# game/a3/9two_princess.rpy:128
translate english two_princess2_632c5fc8:

    # mom "Оказывается ты много знаешь о северных нравах."
    mom "看来你很了解北方的风俗嘛。"

# game/a3/9two_princess.rpy:129
translate english two_princess2_6c37603c:

    # mc "Я жил не совсем на севере. Но в вольных городах точно живут северяне. И да, они спокойно пустят в таверну эльфа или гнома, но в свой дом...никогда."
    mc "我本来没有完全住在北方。但自由城邦里住着的绝对是北方人。没错，他们会平静地让精灵或矮人进酒馆，但进他们家门……绝不可能。"

# game/a3/9two_princess.rpy:130
translate english two_princess2_355ecdbd:

    # mom "Люди бывают разные, [mename], не стоит всех равнять по месту рождения. Например, отец Авроры, девушки, что приехала к тебе с севера, помогал эльфам бежать из столицы, когда на них начались гонения."
    mom "人跟人是不一样的，[mename]，不能因为出生地就给所有人下定论。比方说，来找你的那个北方姑娘Aurora的父亲，在精灵开始受迫害时，就曾帮他们逃离都城。"

# game/a3/9two_princess.rpy:131
translate english two_princess2_1e7d3db5:

    # mc "Да...Людвиг и леди [alaina] говорили о чем-то таком. В любом случае у нас будет возможность проверить какие у кого нравы, жених [elin] с запада, а мои невесты севера и юга."
    mc "是的……Ludwig和[alaina]女士好像说起过类似的事。无论如何，我们以后有的是机会检验各方的品行，西边有新郎官[elin]，我的新娘们则来自南北。"

# game/a3/9two_princess.rpy:133
translate english two_princess2_305c481c:

    # mc "Кстати насчет южной принцессы, ты так и не сказала, что, по-твоему, она будет делать. Парад?"
    mc "对了，说到南方公主，你还没说你觉得她会怎么登场呢。会是游行吗？"

# game/a3/9two_princess.rpy:134
translate english two_princess2_41c707f2:

    # mom "Наверняка что-то подобное. Южане любят появляться громко."
    mom "八九不离十。南方人就喜欢声势浩大地出场。"

# game/a3/9two_princess.rpy:135
translate english two_princess2_ce569301:

    # mc "В таверне крикливый южанин, поет песни, бьет посуду, кричит и бросается на посетителей с кулаками. Хозяин не выдерживает, бьет ему морду и вышвыривает в канаву к попрошайкам."
    mc "酒馆里有个吵吵嚷嚷的南方人，唱歌、摔碗、大喊大叫、挥着拳头扑向其他客人。老板终于忍无可忍，朝他脸上揍了一拳，把他扔到街沟里和乞丐做伴。"

# game/a3/9two_princess.rpy:136
translate english two_princess2_ba282068:

    # mc "Проходит час и в таверну заходят попрошайки. Главный протягивает хозяину горсть монет и говорит."
    mc "过了一小时，一群乞丐走进酒馆。领头的捧着一把硬币递给老板，说。"

# game/a3/9two_princess.rpy:137
translate english two_princess2_423f0409:

    # mc "Можете, пожалуйста, забрать его обратно, вот, мы собрали ему на выпивку."
    mc "劳驾，您能把他请回去吗？喏，这是我们凑给他买酒的钱。"

# game/a3/9two_princess.rpy:138
translate english two_princess2_a9a72975:

    # mc "Южанин радостно кричит - отлично, я сегодня еще и выпью!"
    mc "那南方人高兴地大喊:“太好了，今晚还能再喝一顿！”"

# game/a3/9two_princess.rpy:139
translate english two_princess2_af03b123:

    # mom "Это..."
    mom "这是……"

# game/a3/9two_princess.rpy:140
translate english two_princess2_db42e277:

    # mc "Это анекдот, который мне рассказывали матросы."
    mc "这是水手们给我讲的一个笑话。"

# game/a3/9two_princess.rpy:141
translate english two_princess2_fa29a1e6:

    # mom "У меня складывается впечатление, что ты провел все изгнание в тавернах."
    mom "我总觉得，你流亡的那些年全泡在酒馆里了。"

# game/a3/9two_princess.rpy:142
translate english two_princess2_0e37ad86:

    # mc "Это недалеко от правды. В вольных городах это самые интересные места."
    mc "这离真相不远了。自由城邦里，酒馆是最有趣的地方。"

# game/a3/9two_princess.rpy:144
translate english two_princess2_473decc6:

    # mom "Ну...по крайней мере ты знаешь о чем говорят и думают простые люди."
    mom "嗯……至少你现在知道老百姓在谈论什么，想些什么了。"

# game/a3/9two_princess.rpy:145
translate english two_princess2_f3bced2d:

    # mc "Думаешь это был полезный опыт?"
    mc "你觉得这段经历有用吗？"

# game/a3/9two_princess.rpy:146
translate english two_princess2_856ab623:

    # mom "Не знаю. Наверное ты мог бы провести все это время с большей пользой, но не мне тебя судить."
    mom "不知道。或许你本可以更好地利用那段时间，但轮不到我来评判你。"

# game/a3/9two_princess.rpy:147
translate english two_princess2_4aefe514:

    # mc "По правде я не только пил в тавернах. Людвиг, Акер и леди [alaina] многому меня научили."
    mc "说实话，我在酒馆里可不光是喝酒。Ludwig、Aker，还有[alaina]女士教了我很多。"

# game/a3/9two_princess.rpy:148
translate english two_princess2_bb44147f:

    # mom "Я бесконечно благодарна им."
    mom "我无比感激他们。"

# game/a3/9two_princess.rpy:150
translate english two_princess2_55d9b84d:

    # mc "Леди [alaina] заслуживает отдельной благодарности, она, как оказывается, не только была моим личным телохранителем, но вела мои хроники задолго до того, как это делала [lia]."
    mc "[alaina]女士尤其值得单独感谢，现在看来，她不光是我的贴身护卫，更远在[lia]之前，她就在撰写我的生平记录了。"

# game/a3/9two_princess.rpy:151
translate english two_princess2_0b4e3f93_1:

    # mom "[mename]..."
    mom "[mename]..."

# game/a3/9two_princess.rpy:153
translate english two_princess2_2e3aeab0:

    # mc "Приятно тут... сидеть попивать дешевое пиво под треск огня."
    mc "坐在这儿真舒服……就着炉火的噼啪声，喝着廉价的啤酒。"

# game/a3/9two_princess.rpy:154
translate english two_princess2_e011718f:

    # mom "Только не усни. Пропустишь парад."
    mom "你可别睡着了。会错过游行的。"

# game/a3/9two_princess.rpy:155
translate english two_princess2_d946fccc:

    # mc "Так все таки будет парад?"
    mc "这么说，真的会有游行？"

# game/a3/9two_princess.rpy:156
translate english two_princess2_4b40d09a:

    # mom "Не знаю. Но булроки будут наверняка."
    mom "不知道。但战牛肯定会有。"

# game/a3/9two_princess.rpy:157
translate english two_princess2_89436115:

    # mc "Булроки? Жду не дождусь. Я видел их только в книгах."
    mc "战牛？我都等不及了。我只在书上见过它们。"

# game/a3/9two_princess.rpy:158
translate english two_princess2_8c3384b1:

    # mom "Я видела их кости. Здоровые твари."
    mom "我见过它们的骨头。那是些大家伙。"

# game/a3/9two_princess.rpy:159
translate english two_princess2_b9a13819:

    # mc "На улице какой-то шум."
    mc "外面街上有动静。"

# game/a3/9two_princess.rpy:161
translate english two_princess2_77edf9ef:

    # mom "Ага. Кажется начинается."
    mom "嗯。看来要开始了。"

# game/a3/9two_princess.rpy:162
translate english two_princess2_e8113e21:

    # mc "Видишь кого-нибудь?"
    mc "你看见什么人了吗？"

# game/a3/9two_princess.rpy:163
translate english two_princess2_691fe0dc:

    # mom "Ага. Смотри левее."
    mom "嗯。往左看。"

# game/a3/9two_princess.rpy:164
translate english two_princess2_ff3d309a:

    # mc "Ага. Выходят. Вижу."
    mc "嗯。出来了。看见了。"

# game/a3/9two_princess.rpy:165
translate english two_princess2_5e5825cd:

    # mom "Я была права. Тут целый парад."
    mom "我说对了。真是一整个游行队伍。"

# game/a3/9two_princess.rpy:167
translate english two_princess2_e3e6c54d:

    # mc "Зачем она взяла с собой столько солдат?"
    mc "她带这么多士兵干嘛？"

# game/a3/9two_princess.rpy:168
translate english two_princess2_2abf20bc:

    # mom "Тут сотня-две, не больше."
    mom "也就一两百人，不算多。"

# game/a3/9two_princess.rpy:170
translate english two_princess2_6686e9ec:

    # mc "Это на две сотни больше, чем взяла Аврора."
    mc "比Aurora带的多了两百人。"

# game/a3/9two_princess.rpy:171
translate english two_princess2_16100cca:

    # mom "Тебя это настораживает?"
    mom "这让你觉得不安了？"

# game/a3/9two_princess.rpy:172
translate english two_princess2_0abf72b1:

    # mc "Не знаю, южан в столице не любят, но не настолько, чтобы брать с собой маленькую армию."
    mc "不知道，都城的人是不喜欢南方人，但也没到要带一支小型军队来的地步。"

# game/a3/9two_princess.rpy:174
translate english two_princess2_0d7b7b04:

    # mom "Может быть это ее рабы?"
    mom "这些会不会是她的奴隶？"

# game/a3/9two_princess.rpy:175
translate english two_princess2_15cdf051:

    # mc "Рабы могут быть солдатами?"
    mc "奴隶能当士兵？"

# game/a3/9two_princess.rpy:176
translate english two_princess2_33e75a05:

    # mom "Институт рабства на Юге для меня малознакомая тема, но мне кажется даже сотню солдат содержать дорого."
    mom "南方那边的奴隶制度我不太了解，但我觉得，光是养活一百个士兵就很贵了。"

# game/a3/9two_princess.rpy:177
translate english two_princess2_6dfc0b5a:

    # mc "Понимаю к чему ты клонишь. Рабам платить не нужно."
    mc "我明白你的意思了。不用给奴隶付钱。"

# game/a3/9two_princess.rpy:179
translate english two_princess2_7d4a7b44:

    # mc "С другой стороны мы не знаем положения ее семьи. Может они сказочно богаты. Булрок наверняка стоит целое состояние."
    mc "但话又说回来，我们也不清楚她家族的地位。说不定他们富可敌国呢。光这头战牛肯定就价值连城了。"

# game/a3/9two_princess.rpy:180
translate english two_princess2_107d846b:

    # mom "Я...я не знаю. Но обязательно послушаю от тебя информацию об этом, как только ты узнаешь."
    mom "我……我不知道。不过等你查清楚之后，我肯定会听你详细说说。"

# game/a3/9two_princess.rpy:182
translate english two_princess2_0eef115b:

    # mc "Она выглядит самодовольной, хитрой и властной."
    mc "她看起来自鸣得意、狡猾又跋扈。"

# game/a3/9two_princess.rpy:183
translate english two_princess2_3e75f62d:

    # mom "Одним словом южанка."
    mom "一句话，典型的南方女人。"

# game/a3/9two_princess.rpy:184
translate english two_princess2_b02f2238:

    # mc "Ага."
    mc "嗯。"

# game/a3/9two_princess.rpy:185
translate english two_princess2_ebde055d:

    # mom "Она тебе нравится?"
    mom "你喜欢她吗？"

# game/a3/9two_princess.rpy:186
translate english two_princess2_59280ff5:

    # mc "Опять этот странный вопрос. Пока не знаю, мам."
    mc "又是这怪问题。现在还不清楚，妈妈。"

# game/a3/9two_princess.rpy:188
translate english two_princess2_b980e5eb:

    # mom "Выглядит она..."
    mom "她看起来……"

# game/a3/9two_princess.rpy:189
translate english two_princess2_4d8ee411:

    # mc "Да-да. Она симпатичная. Правда эта одежда...у них не принято прикрывать ноги?"
    mc "是是是。她很迷人。不过那衣服……她们那边不流行遮住腿吗？"

# game/a3/9two_princess.rpy:190
translate english two_princess2_77a0d81a:

    # mom "Тебе не нравится, что она слишком обнажена? Ты уже ее ревнуешь?"
    mom "你不喜欢她穿得太暴露？你这就在吃醋了？"

# game/a3/9two_princess.rpy:191
translate english two_princess2_c74de222:

    # mc "Что? Нет. Просто она контрастирует с северянкой."
    mc "什么？才没有。只是她和那位北方姑娘对比太鲜明了。"

# game/a3/9two_princess.rpy:192
translate english two_princess2_d58fd38c:

    # mom "Еще бы. Это два разных мира."
    mom "那当然了。这是两个完全不同的世界。"

# game/a3/9two_princess.rpy:197
translate english two_princess2_5db2a814:

    # mc "Знаешь, мам, а ведь здесь близко..."
    mc "我说，妈妈，这里离得挺近的……"

# game/a3/9two_princess.rpy:198
translate english two_princess2_484bb2f9:

    # mom "Близко что?"
    mom "什么挺近的？"

# game/a3/9two_princess.rpy:199
translate english two_princess2_c84cfc89:

    # mc "Мне сделать один хороший прыжок..."
    mc "我只要纵身一跳……"

# game/a3/9two_princess.rpy:200
translate english two_princess2_dc2a52cf:

    # mom "[mename]?"
    mom "[mename]?"

# game/a3/9two_princess.rpy:204
translate english two_princess2_a0f5b89f:

    # "Здесь близко...но оно того не стоит."
    "It's close here...but it's not worth it."

# game/a3/9two_princess.rpy:205
translate english two_princess2_58d367ce:

    # "Мало ли что может произойти."
    "You never know what might happen."

# game/a3/9two_princess.rpy:206
translate english two_princess2_907ff3b6:

    # mom "Ладно. Они отправились во дворец. И нам пора."
    mom "算了。她们往王宫去了。我们也该走了。"

# game/a3/9two_princess.rpy:207
translate english two_princess2_e8214d2b:

    # mc "Погоди, мам."
    mc "等等，妈妈。"

# game/a3/9two_princess.rpy:209
translate english two_princess2_a48d86f6:

    # mc "Еще два пива."
    mc "再来两杯啤酒。"

# game/a3/9two_princess.rpy:210
translate english two_princess2_339f73d4:

    # mom "[mename], что ты делаешь?"
    mom "[mename]，你在干嘛？"

# game/a3/9two_princess.rpy:211
translate english two_princess2_24f6921c:

    # mc "А разве не понятно? Наслаждаюсь последними днями холостой жизни."
    mc "这还不明显吗？享受我最后的单身时光啊。"

# game/a3/9two_princess.rpy:212
translate english two_princess2_29754e3b:

    # mom "А я бы сказала что набираешься храбрости."
    mom "我倒觉得你是在给自己壮胆。"

# game/a3/9two_princess.rpy:213
translate english two_princess2_8ce8953a:

    # mc "Храбрости, зачем?"
    mc "壮胆？我需要壮什么胆？"

# game/a3/9two_princess.rpy:214
translate english two_princess2_54707e5f:

    # mom "Две девушки...обе красавицы. На одной из них тебе нужно жениться. И прямо сейчас они ждут тебя во дворце."
    mom "两个姑娘……都是美人。你必须娶其中一个。而此刻，她们就在王宫里等着你。"

# game/a3/9two_princess.rpy:215
translate english two_princess2_46531f54:

    # mc "Пфф...мне вообще плевать. Ну не плевать полностью, конечно...все таки они обе...и....я хочу выпить не поэтому, ясно?"
    mc "啧……我根本不在乎。好吧，也不是完全不在乎……毕竟她们俩都……而且……反正我不是因为这个才想喝酒的，明白吗？"

# game/a3/9two_princess.rpy:216
translate english two_princess2_ccf54794:

    # mom "Ага. Конечно. Только не..."
    mom "嗯。当然。你只要别……"

# game/a3/9two_princess.rpy:218
translate english two_princess2_167db2e6:

    # mom "...напейся."
    mom "……喝醉了。"

# game/a3/9two_princess.rpy:219
translate english two_princess2_508bf125:

    # mc "ЕЩЕ ДВЕ!"
    mc "再来两杯！"

# game/a3/9two_princess.rpy:220
translate english two_princess2_9d51e5d1:

    # mom "[mename], хватит."
    mom "[mename]，够了。"

# game/a3/9two_princess.rpy:221
translate english two_princess2_f6669b54:

    # mc "Я не напился, мам..."
    mc "我没醉，妈妈……"

# game/a3/9two_princess.rpy:222
translate english two_princess2_e0c2cc8a:

    # mom "Я уже напилась."
    mom "我醉了。"

# game/a3/9two_princess.rpy:223
translate english two_princess2_1b97211a:

