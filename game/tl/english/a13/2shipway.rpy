    # cass "А ты..."
    cass "那你..."

# game/a13/2shipway.rpy:695
translate english shipway_cass_ad02f53a:

    # me "Что?"
    me "什么？"

# game/a13/2shipway.rpy:696
translate english shipway_cass_8a994a55:

    # cass "...да так."
    cass "...算了。"

# game/a13/2shipway.rpy:697
translate english shipway_cass_88742244:

    # me "Спрашивай что хотела, [cass]."
    me "想问什么就问，[cass]。"

