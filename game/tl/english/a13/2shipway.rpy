    # me "Уже уходишь?"
    me "你这就走了？"

# game/a13/2shipway.rpy:675
translate english shipway_cass_a78c32a1:

    # cass "Да. Я получила, что хотела, пора уходить."
    cass "对。我得到了想要的，是时候走了。"

# game/a13/2shipway.rpy:677
translate english shipway_cass_5f935ea4:

    # cass "Так и есть. Ты моя личная шлюшка-братик."
    cass "正是如此。你是我的私人小婊子弟弟。"

# game/a13/2shipway.rpy:678
translate english shipway_cass_3820771a_28:

    # me "..."
    me "..."

# game/a13/2shipway.rpy:680
translate english shipway_cass_e65c3809:

    # me "Получил."
    me "明白了。"

# game/a13/2shipway.rpy:682
translate english shipway_cass_5da8dccd:

    # me "А твоя морская болезнь? Она то хоть настоящей была?"
    me "那你的晕船呢？那到底是不是真的？"

# game/a13/2shipway.rpy:683
translate english shipway_cass_a6aa2f71:

    # cass "Естественно."
    cass "当然是真的。"

# game/a13/2shipway.rpy:684
