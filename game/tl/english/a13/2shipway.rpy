    me "啊哈。当然。"

# game/a13/2shipway.rpy:364
translate english shipway_cass_9e4f678f:

    # cass "Неужели у меня такая плохая репутация?"
    cass "我的名声就这么差吗？"

# game/a13/2shipway.rpy:365
translate english shipway_cass_a4c0a420:

    # me "Тебе сказать правду или солгать?"
    me "你想听真话还是假话？"

# game/a13/2shipway.rpy:366
translate english shipway_cass_ced2ea51:

    # cass "Солги."
    cass "说假话。"

# game/a13/2shipway.rpy:367
translate english shipway_cass_5d2a1b2c:

    # me "...Эм..."
    me "...呃..."

# game/a13/2shipway.rpy:368
translate english shipway_cass_ab3a03bb:

    # cass "Ну?"
    cass "嗯？"

# game/a13/2shipway.rpy:369
translate english shipway_cass_30dfcba5:

