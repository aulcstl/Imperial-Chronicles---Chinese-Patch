translate english shipway5_99a10868:

    # matros "{size=+4}Русалкин муж!{/size}"
    matros "{size=+4}是美人鱼的老公！{/size}"

# game/a13/2shipway.rpy:728
translate english shipway5_2bc9690e:

    # me "Русалкин муж?"
    me "美人鱼的老公？"

# game/a13/2shipway.rpy:729
translate english shipway5_91625b88:

    # captain "Значит труп."
    captain "那就是尸体了。"

# game/a13/2shipway.rpy:731
translate english shipway5_3d3f5a60:

    # me "А что труп делает на острове? Корабль разбило о скалы или рифы?"
    me "尸体怎么会在岛上？船在岩石或暗礁上撞碎了？"

# game/a13/2shipway.rpy:732
translate english shipway5_67aa9979:

    # captain "Были бы следы корабля. Скорее всего маронинг, наш или восточный."
    captain "有船难的话，应该有船的残骸。更像是放逐，我们那儿的，或者东方的。"

# game/a13/2shipway.rpy:733
translate english shipway5_f711f9da:

    # me "Маронинг?"
    me "放逐？"

# game/a13/2shipway.rpy:735
translate english shipway5_81710770:

    # me "Восточный?"
    me "东方的？"

# game/a13/2shipway.rpy:736
translate english shipway5_5f86d009:

    # captain "Проще будет показать. Хотите я отправлю своего парня с вами на лодке, он вам все покажет."
    captain "亲眼看看更简单。您想让我派个伙计陪您坐小船过去吗？他会给您解释一切。"

# game/a13/2shipway.rpy:737
translate english shipway5_9f99ca7e:

    # me "А мы можем задержаться?"
    me "我们可以耽搁一下吗？"

# game/a13/2shipway.rpy:739
translate english shipway5_71d3b8c8:

    # me "Хорошо."
    me "好。"

# game/a13/2shipway.rpy:741
translate english shipway5_5948a82b:

    # victor "Я Виктор. Можешь звать Вик."
    victor "我叫维克多。可以叫我维克。"

# game/a13/2shipway.rpy:742
translate english shipway5_12b384b7:

    # me "Я [mename]. Можешь звать мой принц."
    me "我是[mename]。可以叫我的王子殿下。"

# game/a13/2shipway.rpy:743
translate english shipway5_581946b5:

    # victor "А [mename]? А [mename] могу называть?"
    victor "那[mename]呢？可以叫你[mename]吗？"

# game/a13/2shipway.rpy:744
translate english shipway5_fe792b65:

    # me "Если расскажешь что за маронинг."
    me "如果你告诉我什么是'放逐'的话。"

# game/a13/2shipway.rpy:745
translate english shipway5_ed5bc04d:

    # victor "Наказание. Но у нас не практикуется уже давно. Иногда пираты таким балуются, но не здесь."
    victor "一种惩罚。但我们这儿早就不这么干了。有时候海盗会玩玩，但不会在这儿。"

# game/a13/2shipway.rpy:746
translate english shipway5_1fe7cd27:

    # me "Так..."
    me "那么..."

# game/a13/2shipway.rpy:748
translate english shipway5_e7c6ceb0:

    # me "Они такое практикуют?"
    me "他们这么干？"

# game/a13/2shipway.rpy:749
translate english shipway5_febbf8d5:

    # victor "Вроде того."
    victor "差不多。"

# game/a13/2shipway.rpy:750
translate english shipway5_b5a090d8:

    # me "Вроде?"
    me "差不多？"

# game/a13/2shipway.rpy:752
translate english shipway5_d482b05c:

    # victor "У них это наказание не для моряков."
    victor "在他们那儿，这不是针对水手的惩罚。"

# game/a13/2shipway.rpy:753
translate english shipway5_7273c1b4:

    # me "Не для моряков? А как же он здесь оказался?"
    me "不是针对水手？那他是怎么到这儿来的？"

# game/a13/2shipway.rpy:754
translate english shipway5_37d9ee7a:

    # victor "Привезли на корабле."
    victor "用船运过来的。"

# game/a13/2shipway.rpy:755
translate english shipway5_3820771a:

    # me "..."
    me "..."

# game/a13/2shipway.rpy:756
translate english shipway5_5c659bdd:

    # victor "..."
    victor "..."

# game/a13/2shipway.rpy:757
translate english shipway5_2b5a412f:

    # me "Ничего не понимаю."
    me "我完全搞不懂了。"

# game/a13/2shipway.rpy:758
translate english shipway5_a3dea656:

    # victor "Я объясню, идемте."
    victor "我来解释，走吧。"

# game/a13/2shipway.rpy:761
translate english shipway5_5ac38cf1:

    # me "Почему?"
    me "为什么？"

# game/a13/2shipway.rpy:763
translate english shipway5_602e43dc:

    # me "Так... за что его тут оставили?"
    me "那么...他是为什么被留在这儿的？"

# game/a13/2shipway.rpy:764
translate english shipway5_8d3bc730:

    # victor "На Востоке есть что-то вроде непростительных преступлений."
    victor "在东方，有那么几种不可饶恕的罪行。"

# game/a13/2shipway.rpy:766
translate english shipway5_3f0dc64b:

    # victor "Всех не знаю, но нарушение клятвы одно из них. Вроде еще отцеубийство и разрушение храма. Могу ошибаться, хрен их разберешь."
    victor "我不知道全部，但违背誓言是其中之一。好像还有弑父和毁坏神庙。我可能记错，鬼才搞得懂他们。"

# game/a13/2shipway.rpy:767
translate english shipway5_f95c9fc9:

    # me "И?"
    me "然后呢？"

# game/a13/2shipway.rpy:768
translate english shipway5_7a4d1124:

    # victor "За эти преступления предусмотрена не смерть, а изгнание."
    victor "对这些罪行的惩罚不是死刑，而是放逐。"

# game/a13/2shipway.rpy:769
translate english shipway5_3c0ff6e4:

    # me "За непростительное преступление изгнание, а не смерть?"
    me "犯下不可饶恕的罪，惩罚是放逐而不是死刑？"

# game/a13/2shipway.rpy:770
translate english shipway5_5268d947:

    # victor "У них... особая культура. Позор для них хуже смерти. По крайней мере для знати. Умереть не на родной земле - величайший позор."
    victor "他们...有特殊的文化。对他们来说，耻辱比死亡更可怕。至少对贵族是这样的。客死异乡是最大的耻辱。"

# game/a13/2shipway.rpy:771
translate english shipway5_6b77f5c5:

    # me "Так их привозят сюда специально?"
    me "所以他们是特意被带到这儿来的？"

# game/a13/2shipway.rpy:773
translate english shipway5_375d791b:

    # victor "Да. Они хитрят. Наказание не предусматривает смерть."
    victor "是的。他们很狡猾。惩罚本身不包括处死。"

# game/a13/2shipway.rpy:774
translate english shipway5_6140895f:

    # me "Но если оставить на таком островке..."
    me "但如果被扔在这样的小岛上..."

# game/a13/2shipway.rpy:775
translate english shipway5_a151f38e:

    # victor "Да. Сам сдохнет через пару дней. Этот умер недавно."
    victor "没错。过几天自己就死了。这个刚死不久。"

# game/a13/2shipway.rpy:776
translate english shipway5_9cef29fa:

    # me "Как ты понял?"
    me "你怎么看出来的？"

# game/a13/2shipway.rpy:777
translate english shipway5_6725d795:

    # victor "Птицы только глаза выклевать успели."
    victor "鸟儿只来得及啄掉眼睛。"

# game/a13/2shipway.rpy:778
translate english shipway5_db94e305:

    # me "Выглядит старым."
    me "看起来年纪很大。"

# game/a13/2shipway.rpy:779
translate english shipway5_eff2cb0b:

    # victor "Да. Наверное какой-то дворянин."
    victor "是啊。大概是某个贵族。"

# game/a13/2shipway.rpy:780
translate english shipway5_64f8201f:

    # me "А это ты как понял? На Востоке до старости доживают только дворяне?"
    me "这你又是怎么知道的？在东方，只有贵族才能活到老吗？"

# game/a13/2shipway.rpy:781
translate english shipway5_830105d8:

    # victor "По мечу."
    victor "凭这把剑。"

# game/a13/2shipway.rpy:784
translate english shipway5_0e17afce:

    # victor "Так и есть. Они острые как бритва."
    victor "没错。它们像剃刀一样锋利。"

# game/a13/2shipway.rpy:785
translate english shipway5_492737b4:

    # me "Может забрать его?"
    me "也许把它带走？"

# game/a13/2shipway.rpy:786
translate english shipway5_39fb54b2:

    # victor "Не надо! Это плохая примета. Этих людей проклинают, когда отправляют умирать вне родины, возьмем его вещь и перенесем проклятия на корабль."
    victor "不要！这是不祥之兆。这些人被送来客死他乡时是被诅咒了的，我们要是拿了他的东西，会把诅咒带到船上去。"

# game/a13/2shipway.rpy:787
translate english shipway5_63f42833:

    # me "Я не верю в приметы."
    me "我不信这些兆头。"

# game/a13/2shipway.rpy:788
translate english shipway5_53f12829:

    # victor "Не стоит..."
    victor "还是别拿..."

# game/a13/2shipway.rpy:789
translate english shipway5_eedef105:

    # me "Ну ладно-ладно. У меня есть свой меч. Просто впечатляет красота этого."
    me "那好吧，好吧。我自己也有剑。只是这把剑的工艺太美了，令人印象深刻。"

# game/a13/2shipway.rpy:790
translate english shipway5_489ba546:

    # victor "Дворянский."
    victor "贵族用的。"

# game/a13/2shipway.rpy:791
translate english shipway5_48d412b8:

    # me "Зачем те, кто его оставили, дали ему меч? Еще и такой хороший. Чтобы он мог убить себя?"
    me "为什么把他扔在这儿的人，会给他剑？而且还是这么好的一把。让他能自杀吗？"

# game/a13/2shipway.rpy:792
translate english shipway5_becb7a9a:

    # victor "Нет. Он попросил."
    victor "不。是他自己要的。"

# game/a13/2shipway.rpy:793
translate english shipway5_ede7d3ab:

    # me "Попросил?"
    me "自己要的？"

# game/a13/2shipway.rpy:794
translate english shipway5_1493c845:

    # victor "Им разрешают взять одну свою вещь."
    victor "他们被允许带走一件属于自己的东西。"

# game/a13/2shipway.rpy:795
translate english shipway5_1fed9b53:

    # me "Что же никто не возьмет лодку?"
    me "怎么没人要条船？"

# game/a13/2shipway.rpy:796
translate english shipway5_b2cd67dc:

    # victor "Обмануть не получится. Попросишь лодку - дадут. Но снимут весла."
    victor "耍不了花招。你要船，他们会给。但会把桨拿走。"

# game/a13/2shipway.rpy:797
translate english shipway5_6cc1e037:

    # me "Выходит это все-таки казнь."
    me "这么说来，这终究还是死刑。"

# game/a13/2shipway.rpy:798
translate english shipway5_5f1de946:

    # victor "Выходит что так."
    victor "看来是这么回事。"

# game/a13/2shipway.rpy:800
translate english shipway5_9b2decdf:

    # me "Голый он по этой же причине?"
    me "他赤身裸体也是这个原因？"

# game/a13/2shipway.rpy:801
translate english shipway5_4893ed44:

    # victor "Наверняка. Был бы одет теплее, его мог бы подобрать другой корабль."
    victor "很可能。要是穿得暖和点，可能会被别的船救起来。"

# game/a13/2shipway.rpy:802
translate english shipway5_f1ffd6c7:

    # me "Так он... тут недавно."
    me "这么说他...在这儿还没多久。"

# game/a13/2shipway.rpy:803
translate english shipway5_e6cc191e:

    # victor "Да. Может с утра еще был жив."
    victor "对。也许早上还活着。"

# game/a13/2shipway.rpy:804
translate english shipway5_6fdbe064:

    # me "Могли бы его спасти."
    me "本来是可以救他的。"

# game/a13/2shipway.rpy:805
translate english shipway5_7f389d5f:

    # victor "Только если бы вы приказали."
    victor "除非您下令。"

# game/a13/2shipway.rpy:806
translate english shipway5_5ac38cf1_1:

    # me "Почему?"
    me "为什么？"

# game/a13/2shipway.rpy:807
translate english shipway5_7801ae4a:

    # victor "Тот корабль и капитан, что поможет такому изгнаннику, больше не будет иметь хода в любой порт Востока."
    victor "那条船和船长，要是帮助了这样的放逐者，就再也别想停靠东方的任何一个港口了。"

# game/a13/2shipway.rpy:808
translate english shipway5_90677c02:

    # me "Сначала им нужно об этом узнать."
    me "首先得让他们知道才行。"

# game/a13/2shipway.rpy:809
translate english shipway5_3602fab4:

    # victor "Если бы не узнавали, их бы подбирали чаще."
    victor "如果别人发现不了，他们被救的情况会更频繁。"

# game/a13/2shipway.rpy:810
translate english shipway5_92bc1e4c:

    # me "А как они это делают?"
    me "那他们是怎么做到的？"

# game/a13/2shipway.rpy:811
translate english shipway5_1a29d21f:

    # victor "Понятия не имею. Но как-то узнают. Не всегда конечно, то достаточно часто, чтобы капитаны не рисковали."
    victor "我一点头绪都没有。但反正他们会知道。当然不总是如此，但足够频繁，以至于船长们都不敢冒险。"

# game/a13/2shipway.rpy:812
translate english shipway5_d5c369f2:

    # me "...понятно."
    me "...明白了。"

# game/a13/2shipway.rpy:813
translate english shipway5_28cab54c:

    # victor "Еще вопросы?"
    victor "还有问题吗？"

# game/a13/2shipway.rpy:814
translate english shipway5_90d50911:

    # me "Нет. Поплыли отсюда."
    me "没有了。我们离开这儿吧。"

# game/a13/2shipway.rpy:816
translate english shipway5_59b15fa2:

    # me "Неужели на Востоке нет своих маленьких островов, зачем заплывать так далеко?"
    me "难道东方就没有自己的小岛吗，何必跑这么远？"

# game/a13/2shipway.rpy:817
translate english shipway5_c482f6f9:

    # victor "Мелкие острова у континента наверное считаются частью их родины."
    victor "大陆附近的小岛恐怕也被算作他们故乡的一部分。"

# game/a13/2shipway.rpy:818
translate english shipway5_f1b4e0c8:

    # me "А по пути?"
    me "那沿途呢？"

# game/a13/2shipway.rpy:819
translate english shipway5_ceff5a14:

    # victor "По пути таких бедолаг больше всего."
    victor "沿途这种可怜虫更多。"

# game/a13/2shipway.rpy:820
translate english shipway5_58dddb20:

    # me "Так за что этого отвезли так далеко?"
    me "那这个人又是为什么被送到这么远？"

# game/a13/2shipway.rpy:821
translate english shipway5_cebf356e:

    # victor "Не знаю. Часто мы находили горсти земли у них в одежде, иногда у трупов лежали сразу несколько вещей. А этот...."
    victor "不知道。我们经常在他们衣服里发现一捧土，有时候尸体旁边还有好几件东西。可这个...."

# game/a13/2shipway.rpy:822
translate english shipway5_d0a9e0d5:

    # me "Видимо сильно провинился."
    me "看来是犯了大罪。"

# game/a13/2shipway.rpy:823
translate english shipway5_353b10c7:

    # victor "Ага. Наверное совершил несколько непростительных преступлений сразу. А может жертва каких-нибудь интриг. Кто знает что у них там происходит, моряков дальше портов да базаров не пускают."
    victor "啊。可能一次犯了好几样不可饶恕的罪。也可能是某些阴谋的牺牲品。谁知道他们那儿发生了什么，我们水手最远只被允许走到港口和集市。"

# game/a13/2shipway.rpy:824
translate english shipway5_c8c39ef8:

    # me "Загадка."
    me "真是个迷。"

# game/a13/2shipway.rpy:825
translate english shipway5_99d23ffc:

    # victor "АГа..."
    victor "是啊..."

# game/a13/2shipway.rpy:827
translate english shipway5_32fecaaa:

    # "Два дня спустя."
    "两天以后。"

translate english strings:

    # game/a13/2shipway.rpy:58
    old "Отпустить ее отдохнуть"
    new "让她去休息"

    # game/a13/2shipway.rpy:58
    old "Пойти вместе с ней"
    new "和她一起去"

    # game/a13/2shipway.rpy:433
    old "Оставить ее"
    new "留下她"

    # game/a13/2shipway.rpy:568
    old "Предупредить ее"
    new "警告她"

    # game/a13/2shipway.rpy:568
    old "Не предупреждать"
    new "不警告"

# TODO: Translation updated at 2026-03-15 16:26

# game/a13/2shipway.rpy:24
translate english shipway4_35a6c36e:

    # me "{i}Если конечно содержимое наших трюмов нас не сильно замедлит.{/i}"
    me "{i}当然，如果我们货舱里的东西没怎么拖慢我们的话。{/i}"

# game/a13/2shipway.rpy:45
translate english shipway_aurora_22ca3c8b:

    # me "Угмн. Когда вырос - перешел на вино."
    me "嗯哼。长大以后——就改喝酒了。"

# game/a13/2shipway.rpy:53
translate english shipway_aurora_d2cea9d6:

    # me "Ну.. я немного преувеличиваю свое увлечение вином, это скорее был метод расслабления после всех уроков и тренировок моих учителей."
    me "呃...我稍微夸大了我对酒的喜爱，这更多是我在老师们所有课程和训练之后，用来放松的方法。"

# game/a13/2shipway.rpy:88
translate english shipway_aurora_b2ffbceb:

    # me "Чувствуешь? Все точно так же как и на суше."
    me "感觉到了吗？一切和陆地上完全一样。"

# game/a13/2shipway.rpy:148
translate english shipway_aurora_3e2d73d8:

    # aur "Получается находиться в море необязательно."
    aur "这么说，待在海上也不是必须的。"

# game/a13/2shipway.rpy:213
translate english shipway_aurora_7d75efb3:

    # aur "Звучит как прозвище странствующего рыцаря, а не имя для человека."
    aur "听起来像个流浪骑士的绰号，不像人名。"

# game/a13/2shipway.rpy:218
translate english shipway_aurora_982cd91a:

    # me "Морской краб трупоед, пожиратель кораллов и... ну и собственно трупов."
    me "食尸海蟹，珊瑚吞噬者，还有...嗯，以及尸体吞噬者。"

# game/a13/2shipway.rpy:235
translate english shipway_cass_0b8e9c36:

    # me "Ну съешь еще один."
    me "那就再吃一个。"

# game/a13/2shipway.rpy:236
translate english shipway_cass_9e4e218e:

    # cass "Это тебе не жареную перепелку есть. Я еле-еле один смогла прожевать, а ты мне предлагаешь ими питаться?"
    cass "这可不是吃烤鹌鹑。我连一个都勉强才能嚼碎吞下去，你还要我以它们为食？"

# game/a13/2shipway.rpy:258
translate english shipway_cass_da341b38:

    # me "Неужели тебе вообще не стало легче."
    me "难道你没有觉得哪怕舒服一点点吗？"

# game/a13/2shipway.rpy:265
translate english shipway_cass_547100c1:

    # me "Я думаю это наказание от богов."
    me "我觉得这是来自众神的惩罚。"

# game/a13/2shipway.rpy:269
translate english shipway_cass_bec6254f:

    # me "А мне кажется, чтобы проконтролировать."
    me "我倒觉得，是为了监督。"

# game/a13/2shipway.rpy:340
translate english shipway_cass_b3f31ea5:

    # me "{i}Хотя чему я удивляюсь, это же [cass].{/i}"
    me "{i}不过我惊讶什么呢，这毕竟是[cass]。{/i}"

# game/a13/2shipway.rpy:358
translate english shipway_cass_b07af1a9:

    # me "Я больше не буду участвовать ни в чем... таком."
    me "我再也不会参与任何...那种事了。"

# game/a13/2shipway.rpy:422
translate english shipway_cass_aa21d35f:

    # cass "А я и не говорила, что они будут признавать тебя Королем. Армию пока никак не переправить, но это и не нужно. Пусть они поднимут восстание, а мы поможем несчастному Северу."
    cass "我也没说过他们会承认你是国王。军队暂时无法运过去，但也没这个必要。让他们发动起义，我们去帮助不幸的北方。"

# game/a13/2shipway.rpy:428
translate english shipway_cass_7135eddc:

    # cass "Не волнуйся. Ты действуешь правильно. Сначала посмотрим что к чему, а потом и составим план."
    cass "别担心。你做得对。我们先看看情况，然后再制定计划。"

# game/a13/2shipway.rpy:487
translate english shipway_cass_da3ba9fc:

    # cass "Интеллект и помешательство это вечные соседи. К тому же ты не видел по-настоящему сумасшедших, если называешь меня такой."
    cass "智慧和疯狂是永恒的邻居。再说，你要是把我叫做疯子，那你还没见过真正的疯子长什么样。"

# game/a13/2shipway.rpy:505
translate english shipway_cass_e4a6c5cd:

    # cass "Ну я знаю парочку способов проиграть."
    cass "嗯，我倒知道几种输的办法。"

# game/a13/2shipway.rpy:561
translate english shipway_cass_ce230b31:

    # cass "И что ты сделаешь? Убьешь моего законного супруга?"
    cass "那你打算怎么做？杀掉我的合法配偶？"

# game/a13/2shipway.rpy:576
translate english shipway_cass_87e3f794:

    # cass "Поздновато переспрашивать."
    cass "现在才追问，有点晚了吧。"

# game/a13/2shipway.rpy:600
translate english shipway_cass_a281f768:

    # me "Почему ты дала мне..."
    me "你为什么让我..."

# game/a13/2shipway.rpy:608
translate english shipway_cass_c2487b65_3:

    # cass "Что?"
    cass "什么？"

# game/a13/2shipway.rpy:644
translate english shipway_cass_f35d3275:

    # cass "Успокоится? Ты в меня кончил, ублюдок!"
    cass "冷静下来？是你射在我里面的，混蛋！"

# game/a13/2shipway.rpy:648
translate english shipway_cass_d5537071:

    # cass "{size=+4}Сначала отрублю им твой член.{/size}"
    cass "{size=+4}先用它把你的命根子砍下来。{/size}"

# game/a13/2shipway.rpy:661
translate english shipway_cass_99bb14ee:

    # cass "Ты, по-моему, от страха чуть еще раз не кончил."
    cass "我看你啊，刚才吓得差点又要射一次。"

# game/a13/2shipway.rpy:676
translate english shipway_cass_d23b5bd9:

    # me "Чувствую себя использованным."
    me "感觉被利用了。"

# game/a13/2shipway.rpy:679
translate english shipway_cass_1fff1240:

    # cass "Не делай вид, что не получил удовольствие. Ты в меня пол трюма семени накачал."
    cass "别装得好像你没爽到。你在我里面灌了半舱的种子了。"

# game/a13/2shipway.rpy:681
translate english shipway_cass_2c894e6b:

    # cass "Так что ты еще хотел? Поговорить о погоде? Соленый морской ветер, как и обычно."
    cass "那你到底还想干什么？聊聊天气吗？咸咸的海风，一如既往。"

# game/a13/2shipway.rpy:698
translate english shipway_cass_5fc5dc02:

    # cass "Ты правда почувствовал себя использованным?"
    cass "你真的觉得自己被利用了？"

# game/a13/2shipway.rpy:700
translate english shipway_cass_6792f2ff:

    # cass "Нет. Ничего. Может в следующий раз сам... сымпровизируешь?"
    cass "没有。没什么。也许下次我自己...来'见鸡行事'一下？"

# game/a13/2shipway.rpy:717
translate english shipway5_904ae1dc:

    # captain "Я думал принцу будет интересно узнать, где рифы встречаются чаще всего."
    captain "我以为王子殿下会有兴趣知道，哪里最容易遇到暗礁。"

# game/a13/2shipway.rpy:719
translate english shipway5_ea25b1d2:

    # captain "По опыту или как в книге написано?"
    captain "是凭经验，还是像书上写的那样？"

# game/a13/2shipway.rpy:734
translate english shipway5_fae27227:

    # captain "Когда в наказание оставляют на острове."
    captain "当惩罚是把人留在岛上时的那种。"

# game/a13/2shipway.rpy:738
translate english shipway5_f2458328:

    # captain "Мы определили два других корабля на полдня. Можем не торопится."
    captain "我们发现另外两艘船要领先我们半天。我们可以不用那么赶。"

# game/a13/2shipway.rpy:747
translate english shipway5_dd7475b4:

    # victor "Почти уверен что это с восточного корабля."
    victor "几乎可以肯定是东方的船。"

# game/a13/2shipway.rpy:760
translate english shipway5_54a72714:

    # victor "Мы таких называем морской таверной."
    victor "我们管这种叫'海上酒馆'。"

# game/a13/2shipway.rpy:762
translate english shipway5_1cd7d384:

    # victor "Потому что птицы жрут их месяцами. Да. Конкретно этот точно с Востока."
    victor "因为鸟会吃上好几个月。对。这个肯定是东方的。"

# game/a13/2shipway.rpy:765
translate english shipway5_e473fa2f:

    # me "Например?"
    me "比如？"

# game/a13/2shipway.rpy:783
translate english shipway5_70cb3419:

    # me "Выглядит... искусным."
    me "看起来...工艺精湛。"

