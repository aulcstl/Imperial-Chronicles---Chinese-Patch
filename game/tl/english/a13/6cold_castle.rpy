# game/a13/6cold_castle.rpy:4
translate english cold_castle_0f476a5d:

    # "Чуть позже."
    "过了一会。"
    
# game/a13/6cold_castle.rpy:5
translate english cold_castle_070a94de:

    # cath "Принц, [mename]. Рада вас видеть. Как вам охота?"
    cath "王子殿下，[mename]。很高兴见到您。您觉得狩猎怎么样？"

# game/a13/6cold_castle.rpy:6
translate english cold_castle_107a0703:

    # eva "Да, как вам охота, принц [mename]?"
    eva "是啊，您觉得狩猎怎么样，[mename]王子？"

# game/a13/6cold_castle.rpy:7
translate english cold_castle_99759e83:

    # me "Неплохо, как ты успела..."
    me "还不错，你怎么这么快就……"

# game/a13/6cold_castle.rpy:8
translate english cold_castle_b16172de:

    # cath "Вы раньше не охотились?"
    cath "您以前没打过猎吗？"

# game/a13/6cold_castle.rpy:9
translate english cold_castle_6db4e820:

    # eva "Да, вы раньше не охотились, [mename]?"
    eva "对啊，您以前没打过猎吗，[mename]？"

# game/a13/6cold_castle.rpy:10
translate english cold_castle_bd806191:

    # me "Нет. Но обязательно схожу на собственную охоту, по возвращению домой."
    me "没有。但等我回家后，一定要亲自去打一次猎。"

# game/a13/6cold_castle.rpy:11
translate english cold_castle_7656096d:

    # cath "Здорово."
    cath "太棒了。"

# game/a13/6cold_castle.rpy:12
translate english cold_castle_e5e78303:

    # eva "Что вам понравилось на охоте больше всего?"
    eva "您最喜欢狩猎的哪一点？"

# game/a13/6cold_castle.rpy:13
translate english cold_castle_ede2d3d2:

    # me "...Эм... прогулка по лесу и жареный олень."
    me "……呃……在森林里散步，还有烤鹿肉。"

# game/a13/6cold_castle.rpy:14
translate english cold_castle_b09e5fc5:

    # cath "Тогда вы будете рады сегодняшнему обеду. На кухне приготовили много мяса."
    cath "那您一定会喜欢今天的午餐。厨房准备了很多肉。"

# game/a13/6cold_castle.rpy:15
translate english cold_castle_deb904fd:

    # eva "Да. Мне не терпится попробовать."
    eva "是啊。我迫不及待想尝尝了。"

# game/a13/6cold_castle.rpy:16
translate english cold_castle_db55f6ff:

    # me "Любите мяса, принцесса Ева?"
    me "您喜欢肉食吗，Eva公主？"

# game/a13/6cold_castle.rpy:17
translate english cold_castle_2a17e3d8:

    # eva "Обожаю. Рада, что вы с отцом подстрелили оленя."
    eva "喜欢极了。很高兴您和父亲射中了那头鹿。"

# game/a13/6cold_castle.rpy:18
translate english cold_castle_3820771a:

    # me "..."
    me "..."

# game/a13/6cold_castle.rpy:19
translate english cold_castle_0243ab40:

    # cath "Не может быть. Вы были на охоте в первый раз и уже стреляли из лука в оленя?"
    cath "不会吧。您是第一次打猎，就用弓箭射鹿了？"

# game/a13/6cold_castle.rpy:20
translate english cold_castle_c571587f:

    # eva "Да, расскажите нам."
    eva "是啊，给我们讲讲。"

# game/a13/6cold_castle.rpy:22
translate english cold_castle_a744586c:

    # dubov "Ева, прекрати вести себя, будто тебя там не было."
    dubov "Eva，别装得好像你不在场一样。"

# game/a13/6cold_castle.rpy:23
translate english cold_castle_cb68da62:

    # cath "Она была с вами на охоте?"
    cath "她也和你们一起去打猎了？"

# game/a13/6cold_castle.rpy:24
translate english cold_castle_6441fc71:

    # eva "Может и была..."
    eva "也许去了吧……"

# game/a13/6cold_castle.rpy:25
translate english cold_castle_0d339852:

    # dubov "Не может, а была."
    dubov "不是也许，她就是去了。"

# game/a13/6cold_castle.rpy:26
translate english cold_castle_ee6a9949:

    # cath "О боже."
    cath "哦，天哪。"

# game/a13/6cold_castle.rpy:27
translate english cold_castle_e8711117:

    # eva "Какая у меня любящая и заботливая матушка. Даже не заметила, что меня не было в замке."
    eva "我有一位多么爱我、关心我的母亲啊。她甚至都没注意到我不在城堡里。"

# game/a13/6cold_castle.rpy:28
translate english cold_castle_fd792e19:

    # cath "Я думала она в башне. Отбывает наказание."
    cath "我以为她在塔楼里。在受罚呢。"

# game/a13/6cold_castle.rpy:29
translate english cold_castle_4b1e9bae:

    # dubov "Она там скоро окажется. Я так понимаю никакого прощения она у тебя не просила?"
    dubov "她很快就会去那了。我猜她根本没请求你的原谅吧？"

# game/a13/6cold_castle.rpy:30
translate english cold_castle_5c332c81:

    # cath "У меня?"
    cath "我的？"

# game/a13/6cold_castle.rpy:31
translate english cold_castle_9f933767:

    # eva "Я хотела попросить, но не смогла найти матушку в замке."
    eva "我是想请求原谅的，但我没能在城堡里找到母亲。"

# game/a13/6cold_castle.rpy:32
translate english cold_castle_7c43a77a:

    # dubov "Так ты опять солгала. После обеда..."
    dubov "这么说你又撒谎了。午餐之后……"

# game/a13/6cold_castle.rpy:33
translate english cold_castle_f48a31bd:

    # eva "Да-да. Буду в башне."
    eva "是是。我会去塔楼的。"

# game/a13/6cold_castle.rpy:34
translate english cold_castle_36d8243c:

    # dubov "В этот раз я проконтролирую. Приставлю к тебе не слугу, а стражника."
    dubov "这次我会监督的。我不会派仆人看着你，我会派个守卫。"

# game/a13/6cold_castle.rpy:37
translate english cold_castle_fee70913:

    # lisa "Ох... как же хорошо в кругу семьи. Ложь, угрозы, наказания. А ведь обед даже не начался."
    lisa "唉……家庭团聚真好啊。谎言、威胁、惩罚。这午餐都还没开始呢。"

# game/a13/6cold_castle.rpy:38
translate english cold_castle_f981b0ab:

    # aurora "Лиза..."
    aurora "Lisa……"

# game/a13/6cold_castle.rpy:39
translate english cold_castle_7e53bc3b:

    # me "Могу отвезти тебя обратно."
    me "我可以送你回去。"

# game/a13/6cold_castle.rpy:40
translate english cold_castle_37f84f44:

    # lisa "Нет. Что уж тут. Наслаждаемся все вместе."
    lisa "不。就这样吧。我们一起好好'享受'。"

# game/a13/6cold_castle.rpy:41
translate english cold_castle_71042e8a:

    # aurora "Она иронизирует, но я знаю, что ей нравится."
    aurora "她在说反话，但我知道她其实喜欢这样。"

# game/a13/6cold_castle.rpy:42
translate english cold_castle_4b4427ab:

    # cath "...что она сделала?"
    cath "……她做了什么？"

# game/a13/6cold_castle.rpy:43
translate english cold_castle_707aafd8:

    # lisa "Да. Я очень люблю, когда жаренную оленину приправляют семейными скандалами."
    lisa "是啊。我特别喜欢在烤鹿肉里加上家庭争吵作为佐料。"

# game/a13/6cold_castle.rpy:44
translate english cold_castle_fc8fdd62:

    # aurora "И семейной любовью."
    aurora "还有家人的爱。"

# game/a13/6cold_castle.rpy:45
translate english cold_castle_fc951fc9:

    # lisa "Да ну."
    lisa "得了吧。"

# game/a13/6cold_castle.rpy:46
translate english cold_castle_9eb1b081:

    # aurora "Конечно. Люблю тебя, сестренка."
    aurora "当然。我爱你，姐姐。"

# game/a13/6cold_castle.rpy:47
translate english cold_castle_e9da6d54:

    # me "Аврора о таком не врет."
    me "Aurora从不在这种事上撒谎。"

# game/a13/6cold_castle.rpy:48
translate english cold_castle_7f13c7f4:

    # lisa "Да ладно вам, умасливаете меня так, будто я могу встать и уйти."
    lisa "你们得了吧，这么讨好我，好像我能站起来走开似的。"

# game/a13/6cold_castle.rpy:49
translate english cold_castle_d8b9ff2f:

    # eva "...ничего я не делала!"
    eva "……我什么也没做！"

# game/a13/6cold_castle.rpy:50
translate english cold_castle_12c7aa3c:

    # aurora "Не хотелось чтобы ты чувствовала себя неловко. Если что-то нужно..."
    aurora "我不想让你觉得不自在。如果你需要什么……"

# game/a13/6cold_castle.rpy:51
translate english cold_castle_98b7c48d:

    # lisa "Успокойся. Я в порядке. Правда. Ты сегодня решила взять на себя обязанности матери, пока она отчитывает Еву за убийство собаки?"
    lisa "冷静点。我没事。真的。你今天是想在母亲因为Eva杀了狗而训斥她的时候，承担起母亲的责任吗？"

# game/a13/6cold_castle.rpy:52
translate english cold_castle_3d61a44d:

    # eva "...не убивала я никакую собаку!"
    eva "……我没杀任何狗！"

# game/a13/6cold_castle.rpy:53
translate english cold_castle_8371e823:

    # cath "...Борис, расскажи как все было."
    cath "……Boris，说说到底是怎么回事。"

# game/a13/6cold_castle.rpy:54
translate english cold_castle_682cb6b4:

    # aurora "Нет. Просто давно тебя не видела."
    aurora "不。只是很久没见到你了。"

# game/a13/6cold_castle.rpy:55
translate english cold_castle_718ee003:

    # lisa "Мы вчера весь день болтали, пока твой муж и отец были на охоте."
    lisa "我们昨天聊了一整天，就在你丈夫和父亲去打猎的时候。"

# game/a13/6cold_castle.rpy:56
translate english cold_castle_1d94df08:

    # aurora "Мне этого мало. Я не знаю когда мы еще раз здесь будем, так если есть возможность - я хочу тебя видеть."
    aurora "那对我来说不够。我不知道我们何时才能再来这里，所以只要有机会，我就想见到你。"

# game/a13/6cold_castle.rpy:57
translate english cold_castle_cc38c489:

    # lisa "Это мило. Спасибо."
    lisa "这真贴心。谢谢你。"

# game/a13/6cold_castle.rpy:58
translate english cold_castle_aab721a7:

    # eva "...НЕ ДЕЛАЛА Я ЭТОГО!"
    eva "……我没干那事！"

# game/a13/6cold_castle.rpy:61
translate english cold_castle_fee70913_1:

    # lisa "Ох... как же хорошо в кругу семьи. Ложь, угрозы, наказания. А ведь обед даже не начался."
    lisa "唉……家庭团聚真好啊。谎言、威胁、惩罚。这午餐都还没开始呢。"

# game/a13/6cold_castle.rpy:62
translate english cold_castle_7e53bc3b_1:

    # me "Могу отвезти тебя обратно."
    me "我可以送你回去。"

# game/a13/6cold_castle.rpy:63
translate english cold_castle_37f84f44_1:

    # lisa "Нет. Что уж тут. Наслаждаемся все вместе."
    lisa "不。就这样吧。我们一起好好'享受'。"

# game/a13/6cold_castle.rpy:64
translate english cold_castle_4b4427ab_1:

    # cath "...что она сделала?"
    cath "……她做了什么？"

# game/a13/6cold_castle.rpy:65
translate english cold_castle_291bda02:

    # lisa "Я очень люблю, когда жаренную оленину приправляют семейными скандалами."
    lisa "我非常喜欢在烤鹿肉里加上家庭争吵作为佐料。"

# game/a13/6cold_castle.rpy:66
translate english cold_castle_356d00f0:

    # me "Это везде так. Я рос с тремя сестрами. Каждое застолье было точно также."
    me "这在哪儿都一样。我是和三个姐妹一起长大的。每次吃饭都是这样。"

# game/a13/6cold_castle.rpy:67
translate english cold_castle_eb60bee2:

    # lisa "Правда?"
    lisa "真的吗？"

# game/a13/6cold_castle.rpy:68
translate english cold_castle_2d42945b:

    # me "Ага."
    me "是啊。"

# game/a13/6cold_castle.rpy:69
translate english cold_castle_3d61a44d_1:

    # eva "...не убивала я никакую собаку!"
    eva "……我没杀任何狗！"

# game/a13/6cold_castle.rpy:70
translate english cold_castle_5bf6ef58:

    # lisa "Удивительно. Ни в одной книге не написано, что с братьями расти легче, чем с сестрами."
    lisa "真令人惊讶。没有一本书里写过，和兄弟一起长大比和姐妹一起更轻松。"

# game/a13/6cold_castle.rpy:71
translate english cold_castle_750c429b:

    # me "Смотря что имеется в виду. Может криков поменьше, но, уверен, драмы не меньше."
    me "看你怎么理解了。也许尖叫声会少些，但我敢肯定，戏剧性不会少。"

# game/a13/6cold_castle.rpy:72
translate english cold_castle_cdc7f82e:

    # lisa "И драк."
    lisa "还有打架。"

# game/a13/6cold_castle.rpy:73
translate english cold_castle_eb0d474a:

    # me "Верно."
    me "没错。"

# game/a13/6cold_castle.rpy:74
translate english cold_castle_8371e823_1:

    # cath "...Борис, расскажи как все было."
    cath "……Boris，说说到底是怎么回事。"

# game/a13/6cold_castle.rpy:75
translate english cold_castle_219a56b7:

    # lisa "Видимо поэтому среди мальчишек спокойнее. Они выпускают пар набивая друг другу морды."
    lisa "也许这就是为什么男孩堆里更安静些。他们通过互殴来发泄怒气。"

# game/a13/6cold_castle.rpy:76
translate english cold_castle_a3771d22:

    # me "Не пробовала делать то же самое?"
    me "你没试过也这么做吗？"

# game/a13/6cold_castle.rpy:77
translate english cold_castle_0cc4c5cd:

    # lisa "Боюсь не получится, даже если бы хотела... руки слабоваты."
    lisa "恐怕做不到，即使我想……我的手臂太无力了。"

# game/a13/6cold_castle.rpy:78
translate english cold_castle_aab721a7_1:

    # eva "...НЕ ДЕЛАЛА Я ЭТОГО!"
    eva "……我没干那事！"

# game/a13/6cold_castle.rpy:80
translate english cold_castle_697aef82:

    # lisa "А может она подарит псарю щенка?"
    lisa "要不她送只小狗给猎犬管理员吧？"

# game/a13/6cold_castle.rpy:81
translate english cold_castle_299d7b31:

    # cath "Отличная идея."
    cath "好主意。"

# game/a13/6cold_castle.rpy:82
translate english cold_castle_724ecc67:

    # eva "Чего? Не буду я ему ничего дарить!"
    eva "什么？我才不会送他任何东西！"

# game/a13/6cold_castle.rpy:83
translate english cold_castle_3eb373cb:

    # lisa "Почему же? Ему будет приятно, что ты решила заменить ему убитую собаку."
    lisa "为什么不呢？他肯定会很高兴，你决定送他一只狗来代替那只被杀掉的狗。"

# game/a13/6cold_castle.rpy:84
translate english cold_castle_509dae03:

    # eva "Я ее не убивала. Пусть тот, кто убил и дарит ему щенка."
    eva "我没杀它。让那个杀了狗的人去送他小狗吧。"

# game/a13/6cold_castle.rpy:85
translate english cold_castle_f83ecf32:

    # cath "Даже если ты этого не делала, это будет хорошим поступком. Он лишился любимца."
    cath "即使不是你做的，这也是一件好事。他失去了心爱的宠物。"

# game/a13/6cold_castle.rpy:86
translate english cold_castle_54112f34:

    # lisa "Вот именно. Может он даже не будет держать на тебя злость."
    lisa "正是如此。也许他就不会对你心怀怨恨了。"

# game/a13/6cold_castle.rpy:87
translate english cold_castle_07941e35:

    # eva "Да мне плевать. Пусть злится. Я его псину не трогала."
    eva "我才不在乎。让他恨去。我没碰他的狗。"

# game/a13/6cold_castle.rpy:88
translate english cold_castle_0d37f760:

    # cath "Я куплю щенка в Хельвике."
    cath "我会在Helvik买一只小狗。"

# game/a13/6cold_castle.rpy:89
translate english cold_castle_238f6cf5:

    # lisa "Может он поживет первое время у Евы в комнате?"
    lisa "也许头几天可以让它住在Eva的房间里？"

# game/a13/6cold_castle.rpy:90
translate english cold_castle_456566ea:

    # eva "Чего? Может и сам вонючий псарь у меня поживет?"
    eva "什么？那要不要让那个臭烘烘的猎犬管理员也住我房间？"

# game/a13/6cold_castle.rpy:91
translate english cold_castle_b9b2613c:

    # cath "Это необязательно. Их продают уже самостоятельными."
    cath "这没必要。他们出售的小狗已经是能独立生活的了。"

# game/a13/6cold_castle.rpy:92
translate english cold_castle_793d7e65:

    # lisa "Думала это поможет тебе проникнуться симпатией к собакам и ты перестанешь их убивать."
    lisa "我还以为这能帮你对狗产生点好感，你就不会再杀它们了。"

# game/a13/6cold_castle.rpy:93
translate english cold_castle_5ae49e2c:

    # eva "Не проникнусь."
    eva "我不会有好感的。"

# game/a13/6cold_castle.rpy:94
translate english cold_castle_67356659:

    # lisa "И продолжишь убивать их."
    lisa "然后你还会继续杀它们。"

# game/a13/6cold_castle.rpy:95
translate english cold_castle_fe057f9a:

    # eva "И продолжу... чего? Никого я..."
    eva "我还会继续……什么？我没……"

# game/a13/6cold_castle.rpy:96
translate english cold_castle_f4b1a326:

    # lisa "Как ты это сделала? Заколола? Ножом? Покажешь как?"
    lisa "你是怎么做到的？用刀刺死的？用刀子？能演示一下吗？"

# game/a13/6cold_castle.rpy:97
translate english cold_castle_48b39675:

    # eva "Заткнись."
    eva "闭嘴。"

# game/a13/6cold_castle.rpy:99
translate english cold_castle_eb6c0896:

    # dubov "Мы готовы. Ставьте блюда."
    dubov "我们准备好了。上菜吧。"

# game/a13/6cold_castle.rpy:100
translate english cold_castle_77cdd19d:

    # slug "Да, мой король."
    slug "是，我的国王。"

# game/a13/6cold_castle.rpy:101
translate english cold_castle_4f84a225:

    # me "Пахнет рыбой?"
    me "我闻到鱼的味道了？"

# game/a13/6cold_castle.rpy:102
translate english cold_castle_0bff01b9:

    # dubov "Для тех, кто не будет мясо. Моя жена его не особо любит."
    dubov "这是为不吃肉的人准备的。我的妻子不太喜欢肉。"

# game/a13/6cold_castle.rpy:103
translate english cold_castle_b0db6828:

    # cath "Борис так часто ходит на охоту, что я им пресытилась."
    cath "Boris打猎太频繁了，我吃肉都吃腻了。"

# game/a13/6cold_castle.rpy:104
translate english cold_castle_af09c68d:

    # me "Я вот не откажусь."
    me "我可不会拒绝。"

# game/a13/6cold_castle.rpy:105
translate english cold_castle_a7b28cfb:

    # dubov "Если хотите, рыбу унесут, как только моя супруга возьмет себе кусочек."
    dubov "如果您愿意，等我妻子取走她那份后，可以把鱼撤走。"

# game/a13/6cold_castle.rpy:106
translate english cold_castle_3c7685e1:

    # me "Нет. Я привык к запаху."
    me "不。我习惯这味道。"

# game/a13/6cold_castle.rpy:107
translate english cold_castle_9bed940b:

    # dubov "Бригдок?"
    dubov "腌鱼？"

# game/a13/6cold_castle.rpy:108
translate english cold_castle_718401a9:

    # me "Да. Хотя я привык к запаху рыбы намного раньше."
    me "是的。不过我习惯鱼腥味要早得多。"

# game/a13/6cold_castle.rpy:109
translate english cold_castle_0e83cec9:

    # dubov "Кто-то из вашей семьи любит?"
    dubov "您家里有人喜欢吗？"

# game/a13/6cold_castle.rpy:110
translate english cold_castle_530e8f4c:

    # me "Ага. Моя сестра."
    me "是的。我的姐姐。"

# game/a13/6cold_castle.rpy:111
translate english cold_castle_a9cc9983:

    # dubov "Говорят, что женщины, которые любят рыбу, хороши в постели."
    dubov "据说，喜欢鱼的女人在床上都表现很好。"

# game/a13/6cold_castle.rpy:112
translate english cold_castle_71309404:

    # cath "Борис!"
    cath "Boris！"

# game/a13/6cold_castle.rpy:114
translate english cold_castle_33df282d:

    # eva "...Я...НЕ...УБИВАЛА...ЭТУ...ТУПОРЫЛУЮ...ПСИНУ..."
    eva "……我……没……杀……那头……蠢……狗……"

# game/a13/6cold_castle.rpy:115
translate english cold_castle_dad6e3f1:

    # lisa "А ведешь себя так, будто убивала."
    lisa "可你的行为表现得好像是你杀的一样。"

# game/a13/6cold_castle.rpy:116
translate english cold_castle_53352fc0:

    # eva "..."
    eva "..."

# game/a13/6cold_castle.rpy:117
translate english cold_castle_d7d34dbf:

    # lisa "Какая ты злая, сестренка."
    lisa "你真恶毒，我的好妹妹。"

# game/a13/6cold_castle.rpy:118
translate english cold_castle_411c156e:

    # eva "Радуешься так, будто это я тебя от твоей жалкой жизни калеки избавила."
    eva "你这么高兴，好像是我帮你摆脱了你那可怜的残废生活似的。"

# game/a13/6cold_castle.rpy:119
translate english cold_castle_581cd4c1:

    # lisa "А ты можешь? Я не против."
    lisa "你能做到吗？我不介意的。"

# game/a13/6cold_castle.rpy:120
translate english cold_castle_253f2282:

    # eva "Ну что ты, я бы никогда не навредила своей любимой старшей сестре."
    eva "瞧你说的，我怎么会伤害我亲爱的姐姐呢。"

# game/a13/6cold_castle.rpy:121
translate english cold_castle_2b51bf7d:

    # lisa "Жаль, может передумаешь, если я погавкаю?"
    lisa "真可惜，也许我学狗叫几声，你就会改变主意？"

# game/a13/6cold_castle.rpy:122
translate english cold_castle_e14975e8:

    # eva "Попробуй. Подберем тебе кобеля с псарни, раз уж нормальные женихи тебе не светят."
    eva "试试看啊。既然正常的求婚者都不会看上你，我们也许可以在狗舍里给你找个公狗配对。"

# game/a13/6cold_castle.rpy:123
translate english cold_castle_4e08a650:

    # lisa "Уверена твой жених поменяет тебя на меня уже через пару минут общения."
    lisa "我相信你的未婚夫和我聊上几分钟后，就会想用我来代替你。"

# game/a13/6cold_castle.rpy:124
translate english cold_castle_2a99617d:

    # eva "Ага. Особенно если у него сломается колесо в карете."
    eva "是啊。尤其是他马车轮子坏了的时候。"

# game/a13/6cold_castle.rpy:125
translate english cold_castle_d4a9848d:

    # lisa "Думаю самообладание у него сломается раньше."
    lisa "我想他的自制力会更早崩溃。"

# game/a13/6cold_castle.rpy:126
translate english cold_castle_e61afc82:

    # cath "Девочки, хватит. Рыбу поближе ко мне."
    cath "姑娘们，够了。把鱼放得离我近些。"

# game/a13/6cold_castle.rpy:127
translate english cold_castle_5218709f:

    # slug "Да, госпожа."
    slug "是，夫人。"

# game/a13/6cold_castle.rpy:128
translate english cold_castle_fe3a21cf:

    # eva "А это она начала."
    eva "是她先开始的。"

# game/a13/6cold_castle.rpy:129
translate english cold_castle_c0e69f37:

    # lisa "Прости, вовсе не хотела портить тебе аппетит, сестренка."
    lisa "对不起，我一点也不想破坏你的胃口，我的好妹妹。"

# game/a13/6cold_castle.rpy:130
translate english cold_castle_53352fc0_1:

    # eva "..."
    eva "..."

# game/a13/6cold_castle.rpy:131
translate english cold_castle_7db5a02a:

    # lisa "Мир?"
    lisa "讲和？"

# game/a13/6cold_castle.rpy:132
translate english cold_castle_7f12193d:

    # eva "Мира между волком и человеком быть не может."
    eva "狼和人之间不可能有和平。"

# game/a13/6cold_castle.rpy:133
translate english cold_castle_24c09a40:

    # lisa "Это ты волк? Скорее маленькая вредная лисичка."
    lisa "你是狼？更像一只讨厌的小狐狸。"

# game/a13/6cold_castle.rpy:134
translate english cold_castle_023fd5fe:

    # eva "Смотри чтобы это лисичка не обкусала твои веточки."
    eva "小心别让这只小狐狸把你的树枝啃光了。"

# game/a13/6cold_castle.rpy:135
translate english cold_castle_ee6209ac:

    # lisa "Веточки? А, я дерево в лесу. Поняла. Смешно."
    lisa "树枝？哦，我是森林里的树。懂了。真好笑。"

# game/a13/6cold_castle.rpy:136
translate english cold_castle_883db5cd:

    # dubov "Закройте рты и ешьте."
    dubov "闭上嘴，吃饭。"

# game/a13/6cold_castle.rpy:137
translate english cold_castle_9f8a1772:

    # eva "Да, папочка."
    eva "是，爸爸。"

# game/a13/6cold_castle.rpy:138
translate english cold_castle_7fa35a3f:

    # lisa "..."
    lisa "..."

# game/a13/6cold_castle.rpy:140
translate english cold_castle_41b39971:

    # "После обеда."
    "午餐过后。"

# game/a13/6cold_castle.rpy:141
translate english cold_castle_6407a0e3:

    # eva "Принц [mename]. Вы поели?"
    eva "王子[mename]。您吃好了吗？"

# game/a13/6cold_castle.rpy:142
translate english cold_castle_76945fb6:

    # me "Да. Было вкусно."
    me "是的。很好吃。"

# game/a13/6cold_castle.rpy:143
translate english cold_castle_f6384b35:

    # eva "Не проводите меня до башни?"
    eva "您能送我去塔楼吗？"

# game/a13/6cold_castle.rpy:144
translate english cold_castle_55b892b0:

    # me "Конечно...."
    me "当然可以……"

# game/a13/6cold_castle.rpy:145
translate english cold_castle_368bf64c:

    # lisa "И меня тоже."
    lisa "也送送我。"

# game/a13/6cold_castle.rpy:146
translate english cold_castle_5a3c3268:

    # eva "Я первая..."
    eva "我先来的……"

# game/a13/6cold_castle.rpy:147
translate english cold_castle_92b40f01:

    # cath "Я могу позвать слугу."
    cath "我可以叫个仆人来。"

# game/a13/6cold_castle.rpy:148
translate english cold_castle_a726544e:

    # lisa "Нет, я предпочла, чтобы это был принц [mename]."
    lisa "不，我更希望由[mename]王子来送。"

# game/a13/6cold_castle.rpy:149
translate english cold_castle_01822020:

    # me "Ладно."
    me "好吧。"

# game/a13/6cold_castle.rpy:150
translate english cold_castle_b75b3d20:

    # eva "Ты специально?"
    eva "你是故意的吗？"

# game/a13/6cold_castle.rpy:151
translate english cold_castle_da5d393a:

    # lisa "Нам по пути, сестренка, не ругайся. Пойдем вместе."
    lisa "我们顺路，妹妹，别生气。咱们一起走吧。"

# game/a13/6cold_castle.rpy:152
translate english cold_castle_53352fc0_2:

    # eva "..."
    eva "..."

# game/a13/6cold_castle.rpy:153
translate english cold_castle_dd692bc4:

    # me "Так что? Идем?"
    me "那么？我们走吗？"

# game/a13/6cold_castle.rpy:154
translate english cold_castle_6da29439:

    # eva "Идем."
    eva "走吧。"

# game/a13/6cold_castle.rpy:156
translate english cold_castle_9780e222:

    # eva "...твои колеса портят пол. Что за огромные шипы?"
    eva "……你的轮子把地板弄坏了。这些巨大的尖刺是什么？"

# game/a13/6cold_castle.rpy:157
translate english cold_castle_29655aff:

    # lisa "Попросила кузнеца, он и сделал."
    lisa "我让铁匠做的，他就做了。"

# game/a13/6cold_castle.rpy:158
translate english cold_castle_4d9155fb:

    # eva "Ну и зачем?"
    eva "搞这个干嘛？"

# game/a13/6cold_castle.rpy:159
translate english cold_castle_a867428b:

    # lisa "Чтобы портить пол, obviously."
    lisa "显然是为了弄坏地板。"

# game/a13/6cold_castle.rpy:160
translate english cold_castle_53352fc0_3:

    # eva "..."
    eva "..."

# game/a13/6cold_castle.rpy:161
translate english cold_castle_187b55f0:

    # eva "Не зря бог наказал тебя. Ты плохая сестра, да и как человек не очень..."
    eva "难怪上帝惩罚你。你是个坏姐姐，作为人也挺差劲的……"

# game/a13/6cold_castle.rpy:162
translate english cold_castle_a8173371:

    # lisa "Если бы бог наказывал людей за то, что они были плохими сестрами, ты была бы парализована с ног до головы."
    lisa "如果上帝因为人们是坏姐妹而惩罚他们，你早就从头到脚都瘫痪了。"

# game/a13/6cold_castle.rpy:163
translate english cold_castle_b2d41f3f:

    # eva "Н-да?"
    eva "哦，是吗？"

# game/a13/6cold_castle.rpy:164
translate english cold_castle_ce84f531:

    # lisa "Ага. А может и чего похуже."
    lisa "是啊。也许还有更糟的。"

# game/a13/6cold_castle.rpy:165
translate english cold_castle_783aa4c5:

    # eva "И почему же я плохая сестра?"
    eva "我为什么是个坏妹妹？"

# game/a13/6cold_castle.rpy:166
translate english cold_castle_a1524b67:

    # lisa "А почему я плохая сестра?"
    lisa "那我又为什么是个坏姐姐？"

# game/a13/6cold_castle.rpy:167
translate english cold_castle_a4425aa5:

    # eva "Потому что ты обвиняла меня за столом в убийстве этой псины!"
    eva "因为你在餐桌上指责我杀了那条蠢狗！"

# game/a13/6cold_castle.rpy:168
translate english cold_castle_c7987adc:

    # lisa "А зачем ты ее убила?"
    lisa "那你为什么要杀了它？"

# game/a13/6cold_castle.rpy:169
translate english cold_castle_94d3d282:

    # eva "Я ее не убивала."
    eva "我没杀它。"

# game/a13/6cold_castle.rpy:170
translate english cold_castle_dd3f2622:

    # lisa "Ага. Конечно. А я не калека."
    lisa "是啊。当然。就像我不是残废一样。"

# game/a13/6cold_castle.rpy:171
translate english cold_castle_754b7c5e:

    # eva "Вот видишь? Ты плохая сестра, ты услышала какую-то глупость и тут же ее поддержала, потому что эта глупость против меня."
    eva "你看？你是个坏姐姐，你听到一些蠢话，立刻就跟着起哄，因为这些蠢话是针对我的。"

# game/a13/6cold_castle.rpy:172
translate english cold_castle_4927a432:

    # lisa "Я бы не называла убийство 'глупостью', тем более если об этой 'глупости' рассказал наш отец."
    lisa "我不会把'谋杀'称为'蠢话'，尤其是如果这'蠢话'是我们的父亲说的。"

# game/a13/6cold_castle.rpy:173
translate english cold_castle_139df134:

    # eva "Он просто не разобрался в ситуации."
    eva "他只是没搞清楚情况。"

# game/a13/6cold_castle.rpy:174
translate english cold_castle_5f43b73a:

    # lisa "Уверена, он не выпорол тебя прямо на месте, только чтобы не позорить."
    lisa "我相信他没有当场鞭打你，只是为了不丢脸。"

# game/a13/6cold_castle.rpy:176
translate english cold_castle_1c22e696:

    # eva "Видите, как она меня ненавидит, принц [mename]?"
    eva "您看，她多恨我啊，[mename]王子？"

# game/a13/6cold_castle.rpy:177
translate english cold_castle_88a00e28:

    # me "По-моему просто смеется."
    me "在我看来，她只是在开玩笑。"

# game/a13/6cold_castle.rpy:178
translate english cold_castle_d53a114f:

    # lisa "Не скули. А то сама станешь похожей на собаку."
    lisa "别抱怨了。不然你会变得像狗一样。"

# game/a13/6cold_castle.rpy:179
translate english cold_castle_b44c7e05:

    # eva "И оскорбляет. Сравнивает с собакой!"
    eva "她还侮辱我。把我比作狗！"

# game/a13/6cold_castle.rpy:180
translate english cold_castle_ce3ab085:

    # me "Предлагаете защитить вашу честь, принцесса Ева?"
    me "您是在建议我捍卫您的荣誉吗，Eva公主？"

# game/a13/6cold_castle.rpy:181
translate english cold_castle_5ecd743f:

    # lisa "Разрешаю вызвать меня на дуэль."
    lisa "我允许你向我提出决斗。"

# game/a13/6cold_castle.rpy:182
translate english cold_castle_13abfac0:

    # eva "Не смейтесь!"
    eva "别笑了！"

# game/a13/6cold_castle.rpy:183
translate english cold_castle_84a04fcb:

    # me "Какое оружие выбираем?"
    me "我们选什么武器？"

# game/a13/6cold_castle.rpy:184
translate english cold_castle_4fc2d239:

    # lisa "Предлагаю копья. Вы на коне, я на кресле."
    lisa "我建议用长矛。您骑马，我坐轮椅。"

# game/a13/6cold_castle.rpy:185
translate english cold_castle_43f81b9d:

    # eva "Это вовсе не смешно. Я чуть-чуть шучу над ней, а она всегда поддерживает самые грязные слухи обо мне."
    eva "这一点也不好笑。我只是稍稍取笑她一下，但她总是支持关于我的最肮脏的谣言。"

# game/a13/6cold_castle.rpy:186
translate english cold_castle_a98c6978:

    # me "Например какие?"
    me "比如说？"

# game/a13/6cold_castle.rpy:187
translate english cold_castle_4a3555e0:

    # lisa "Ну раз грязные, то видимо слух о том, что она не моется."
    lisa "唔，既然是肮脏的谣言，那大概就是她不洗澡的传闻吧。"

# game/a13/6cold_castle.rpy:188
translate english cold_castle_d7c1b911:

    # eva "Прекратите!"
    eva "够了！"

# game/a13/6cold_castle.rpy:189
translate english cold_castle_348ac362:

    # me "Думаю стоит прекратить. Или вашей матушке придется везти сюда не только щенка, но и нового принца Золотого Королевства и принцессу Севера."
    me "我想我们该停下了。否则您的母亲不仅要带小狗来，还得带一位新的黄金王国王子和一位北方公主回去了。"

# game/a13/6cold_castle.rpy:190
translate english cold_castle_0f20de60:

    # lisa "Думаете новой принцессе матушка сломает ноги для аутентичности?"
    lisa "您觉得母亲会为了追求'原汁原味'而打断新公主的腿吗？"

# game/a13/6cold_castle.rpy:191
translate english cold_castle_336ec7a2:

    # eva "Вы... пф..."
    eva "你……噗……"

# game/a13/6cold_castle.rpy:192
translate english cold_castle_99ef555b:

    # me "Мы шутим, расслабься."
    me "我们在开玩笑，放松点。"

# game/a13/6cold_castle.rpy:193
translate english cold_castle_279b368c:

    # lisa "Шутим? Я была абсолютно серьезна."
    lisa "开玩笑？我可是非常认真的。"

# game/a13/6cold_castle.rpy:194
translate english cold_castle_9a7d860f:

    # eva "Ах так?"
    eva "哦，是吗？"

# game/a13/6cold_castle.rpy:196
translate english cold_castle_110175b4:

    # lisa "Степан."
    lisa "Stepan。"

# game/a13/6cold_castle.rpy:197
translate english cold_castle_2aaab9cf:

    # stepan "Думал, где вы были, госпожа."
    stepan "我还想您去哪儿了呢，小姐。"

# game/a13/6cold_castle.rpy:198
translate english cold_castle_0c900c00:

    # lisa "На прекрасном ужине с семьей."
    lisa "和家人们享受了一顿美妙的晚餐。"

# game/a13/6cold_castle.rpy:199
translate english cold_castle_859fe0a7:

    # stepan "Принц [mename]. Мой брат сопровождал Аврору к вам в столицу."
    stepan "王子[mename]。我的哥哥曾护送Aurora去您的首都。"

# game/a13/6cold_castle.rpy:200
translate english cold_castle_bb646705:

    # me "А я все думал, где я вас раньше видел."
    me "我一直觉得以前在哪儿见过您。"

# game/a13/6cold_castle.rpy:201
translate english cold_castle_8cc2c7c3:

    # stepan "Хех. Мы близнецы."
    stepan "呵，我们是孪生兄弟。"

# game/a13/6cold_castle.rpy:202
translate english cold_castle_aa19b101:

    # lisa "Отвезешь меня в библиотеку?"
    lisa "你能送我去图书馆吗？"

# game/a13/6cold_castle.rpy:203
translate english cold_castle_73c3f6da:

    # stepan "Конечно."
    stepan "当然可以。"

# game/a13/6cold_castle.rpy:204
translate english cold_castle_1b2d2702:

    # eva "Отлично. Думала придется терпеть тебя до самого конца пути."
    eva "太好了。我还以为得一直忍受你到最后呢。"

# game/a13/6cold_castle.rpy:205
translate english cold_castle_b7adc718:

    # lisa "Можешь передавать бразды правления."
    lisa "你可以移交缰绳了。"

# game/a13/6cold_castle.rpy:206
translate english cold_castle_fd9fba8b:

    # eva "Расставайся с ней побыстрее. Не жди."
    eva "快点离开她。别等了。"

# game/a13/6cold_castle.rpy:207
translate english cold_castle_722c82ca:

    # lisa "Не забудь, что ей в башню, а не в ее покои."
    lisa "别忘了，她是要去塔楼，不是回她自己的房间。"

# game/a13/6cold_castle.rpy:208
translate english cold_castle_cc3142d0:

    # eva "Я ему напомню, не волнуйся, сестра."
    eva "我会提醒他的，别担心，姐姐。"

# game/a13/6cold_castle.rpy:221
translate english cold_castle_eva_32b938f6:

    # eva "На чем мы остановились?"
    eva "我们说到哪儿了？"

# game/a13/6cold_castle.rpy:222
translate english cold_castle_eva_7b3cb7f2:

    # me "На том, что тебя нужно проводить в башню."
    me "说到该送你去塔楼了。"

# game/a13/6cold_castle.rpy:223
translate english cold_castle_eva_671b7ad2:

    # eva "В мои покои."
    eva "去我的房间。"

# game/a13/6cold_castle.rpy:224
translate english cold_castle_eva_443fae1e:

    # me "В башню."
    me "去塔楼。"

# game/a13/6cold_castle.rpy:225
translate english cold_castle_eva_53352fc0:

    # eva "..."
    eva "..."

# game/a13/6cold_castle.rpy:226
translate english cold_castle_eva_443fae1e_1:

    # me "В башню."
    me "去塔楼。"

# game/a13/6cold_castle.rpy:227
translate english cold_castle_eva_8fa8e500:

    # eva "Если бы вы провели меня в мои покои, я бы потом могла сказать, что вы забылись."
    eva "如果您送我回房间，我之后就能说是您记错了。"

# game/a13/6cold_castle.rpy:228
translate english cold_castle_eva_25b1152b:

    # me "Ты хочешь снять с себя наказание переложив ответственность на меня?"
    me "你想把责任推到我身上，来逃避惩罚？"

# game/a13/6cold_castle.rpy:229
translate english cold_castle_eva_162f86a1:

    # eva "По-моему очень рациональное желание - подставить другого, а самой не страдать."
    eva "我觉得这是个非常理性的愿望——让别人顶罪，自己不受苦。"

# game/a13/6cold_castle.rpy:230
translate english cold_castle_eva_3820771a:

    # me "..."
    me "..."

# game/a13/6cold_castle.rpy:231
translate english cold_castle_eva_0100b07e:

    # eva "Что?"
    eva "什么？"

# game/a13/6cold_castle.rpy:232
translate english cold_castle_eva_3240ad63:

    # me "Теперь я точно не хочу помогать."
    me "现在我更不想帮你了。"

# game/a13/6cold_castle.rpy:233
translate english cold_castle_eva_d478c6a7:

    # eva "А за поцелуй?"
    eva "那用一个吻换呢？"

# game/a13/6cold_castle.rpy:234
translate english cold_castle_eva_fc98612f:

    # me "Даже за два."
    me "两个也不行。"

# game/a13/6cold_castle.rpy:235
translate english cold_castle_eva_22ab8585:

    # eva "Три?"
    eva "三个？"

# game/a13/6cold_castle.rpy:236
translate english cold_castle_eva_3820771a_1:

    # me "..."
    me "..."

# game/a13/6cold_castle.rpy:237
translate english cold_castle_eva_c7886a17:

    # eva "Четыре?"
    eva "四个？"

# game/a13/6cold_castle.rpy:238
translate english cold_castle_eva_3820771a_2:

    # me "..."
    me "..."

# game/a13/6cold_castle.rpy:239
translate english cold_castle_eva_ca806df8:

    # eva "Сто двадцать шесть с половиной."
    eva "一百二十六个半。"

# game/a13/6cold_castle.rpy:240
translate english cold_castle_eva_8399c344:

    # me "Где ты училась торговаться?"
    me "你是从哪里学会讨价还价的？"

# game/a13/6cold_castle.rpy:241
translate english cold_castle_eva_2430ae94:

    # eva "Я аристократка, я не торгуюсь."
    eva "我是贵族，不讨价还价。"

# game/a13/6cold_castle.rpy:242
translate english cold_castle_eva_2d46ebcf:

    # me "А аристократы принимают наказание или стараются от него ускользнуть? Что выберет аристократ, честность или обман?"
    me "那贵族是接受惩罚，还是设法逃避呢？贵族会选择诚实，还是欺骗？"

# game/a13/6cold_castle.rpy:243
translate english cold_castle_eva_44b52eaf:

    # eva "Конечно второе, но раз даже сто двадцать шесть с половиной поцелуев не сработали... Идем."
    eva "当然是后者。但既然连一百二十六个半吻都没用……我们走吧。"

# game/a13/6cold_castle.rpy:245
translate english cold_castle_eva_d7da5cde:

    # me "И часто ты так?"
    me "你经常这样吗？"

# game/a13/6cold_castle.rpy:246
translate english cold_castle_eva_dc839df0:

    # eva "Что именно?"
    eva "怎样？"

# game/a13/6cold_castle.rpy:247
translate english cold_castle_eva_09b1e55f:

    # me "Попадаешь в башню?"
    me "被关进塔楼？"

# game/a13/6cold_castle.rpy:248
translate english cold_castle_eva_722d4d13:

    # eva "Справедливо или несправедливо?"
    eva "你问是公正地还是不公正地？"

# game/a13/6cold_castle.rpy:249
translate english cold_castle_eva_53363519:

    # me "И так и так."
    me "两者都算吧。"

# game/a13/6cold_castle.rpy:250
translate english cold_castle_eva_d703f569:

    # eva "Справедливо никогда."
    eva "公正地？从来没有过。"

# game/a13/6cold_castle.rpy:251
translate english cold_castle_eva_63e2d8fe:

    # me "А несправедливо?"
    me "那不公正地呢？"

# game/a13/6cold_castle.rpy:252
translate english cold_castle_eva_ceacd553:

    # eva "Постоянно."
    eva "家常便饭。"

# game/a13/6cold_castle.rpy:253
translate english cold_castle_eva_4d00bc1c:

    # me "Ну естественно."
    me "那是自然。"

# game/a13/6cold_castle.rpy:254
translate english cold_castle_eva_ac3ee6db:

    # eva "Вообще-то это жестоко и бесчеловечно. Пытка одиночеством одна из самых страшных."
    eva "其实这很残酷，不人道。孤独折磨是最可怕的惩罚之一。"

# game/a13/6cold_castle.rpy:255
translate english cold_castle_eva_153400a2:

    # me "Для тебя уж точно."
    me "对你来说肯定是。"

# game/a13/6cold_castle.rpy:256
translate english cold_castle_eva_67fbd165:

    # eva "А для вас нет?"
    eva "对您来说不是吗？"

# game/a13/6cold_castle.rpy:257
translate english cold_castle_eva_eb669f3d:

    # me "Иногда побыть одному не так плохо."
    me "有时候能一个人待着也不坏。"

# game/a13/6cold_castle.rpy:258
translate english cold_castle_eva_411b208b:

    # eva "Меня держат там годами."
    eva "他们把我关在那里好多年。"

# game/a13/6cold_castle.rpy:259
translate english cold_castle_eva_3820771a_3:

    # me "..."
    me "..."

# game/a13/6cold_castle.rpy:260
translate english cold_castle_eva_57ac82a1:

    # eva "Ну может не годами... месяцами..."
    eva "唔，也许不是好多年……好几个月吧……"

# game/a13/6cold_castle.rpy:261
translate english cold_castle_eva_b4d5ad48:

    # me "Ева."
    me "Eva。"

# game/a13/6cold_castle.rpy:262
translate english cold_castle_eva_7a9d0651:

    # eva "Даже за несколько дней можно с ума сойти!"
    eva "就算几天也能把人逼疯！"

# game/a13/6cold_castle.rpy:264
translate english cold_castle_eva_3e962818:

    # me "И что представляет собой эта башня?"
    me "那塔楼是什么样的？"

# game/a13/6cold_castle.rpy:265
translate english cold_castle_eva_7ab37c97:

    # eva "Башню. Что же еще?"
    eva "就是座塔楼。还能是什么？"

# game/a13/6cold_castle.rpy:266
translate english cold_castle_eva_5d0bdff8:

    # me "Я имею в виду там же есть что-то внутри?"
    me "我是说，里面总该有点什么吧？"

# game/a13/6cold_castle.rpy:267
translate english cold_castle_eva_4c495867:

    # eva "Ничего. Пустой зал."
    eva "什么都没有。就是一个空荡荡的大厅。"

# game/a13/6cold_castle.rpy:268
translate english cold_castle_eva_9ec0401e:

    # me "Не верю."
    me "我不信。"

# game/a13/6cold_castle.rpy:269
translate english cold_castle_eva_3e1061df:

    # eva "Придется поверить."
    eva "你不得不信。"

# game/a13/6cold_castle.rpy:270
translate english cold_castle_eva_f4bc54f5:

    # me "И что же ты делаешь в пустом зале?"
    me "那你在空荡荡的大厅里做什么？"

# game/a13/6cold_castle.rpy:271
translate english cold_castle_eva_219c8fe6:

    # eva "К сожалению читаю."
    eva "很遗憾，读书。"

# game/a13/6cold_castle.rpy:272
translate english cold_castle_eva_a7fe097a:

    # me "К сожалению?"
    me "很遗憾？"

# game/a13/6cold_castle.rpy:273
translate english cold_castle_eva_53814170:

    # eva "Все книги из библиотеки такой мусор. Понятия не имею как Лиза это читает. Ни любовных романов, ни приключений. Какие-то трактаты о медицине и история домов. Скука."
    eva "图书馆里所有的书都是垃圾。真不知道Lisa是怎么读下去的。没有爱情小说，也没有冒险故事。全是些医学论文和家族史。无聊透顶。"

# game/a13/6cold_castle.rpy:274
translate english cold_castle_eva_66e40d2e:

    # me "Там хоть стулья то есть?"
    me "那里面至少有椅子吧？"

# game/a13/6cold_castle.rpy:275
translate english cold_castle_eva_b7a72ee5:

    # eva "Где? В башне? Нет."
    eva "哪里？塔楼里？没有。"

# game/a13/6cold_castle.rpy:276
translate english cold_castle_eva_8c163a93:

    # me "Быть того не может."
    me "不可能。"

# game/a13/6cold_castle.rpy:277
translate english cold_castle_eva_67960bdf:

    # eva "Они есть в комнате. Там и кровать есть."
    eva "房间里有的。那里还有张床。"

# game/a13/6cold_castle.rpy:278
translate english cold_castle_eva_1e9acb89:

    # me "Комнате? Ты сказала там ничего нет."
    me "房间？你说过那里什么都没有。"

# game/a13/6cold_castle.rpy:279
translate english cold_castle_eva_7bf55894:

    # eva "Ничего нет в самой башне. Кроме комнат. А вот в комнате уже что-то есть."
    eva "塔楼本身是空的。除了房间。而房间里总算有点东西了。"

# game/a13/6cold_castle.rpy:280
translate english cold_castle_eva_3820771a_4:

    # me "..."
    me "..."

# game/a13/6cold_castle.rpy:281
translate english cold_castle_eva_0100b07e_1:

    # eva "Что?"
    eva "什么东西？"

# game/a13/6cold_castle.rpy:282
translate english cold_castle_eva_3c5e2cfc:

    # me "Да нет, ничего."
    me "不，没什么。"

# game/a13/6cold_castle.rpy:283
translate english cold_castle_eva_783d33c5:

    # eva "Знаешь что, раз уже меня наказали ни за что. Надо хотя бы перед наказанием пошалить."
    eva "你知道吗，既然我已经无缘无故被罚了，那在受罚前至少得调皮一下。"

# game/a13/6cold_castle.rpy:284
translate english cold_castle_eva_ec26e47d:

    # me "Каким образом?"
    me "怎么调皮？"

# game/a13/6cold_castle.rpy:285
translate english cold_castle_eva_6bdea92b:

    # eva "Ну мы почти пришли, впереди одни коридоры и лестницы, так что вариантов не очень много."
    eva "嗯，我们快到了，前面只剩下走廊和楼梯了，所以选择不太多。"

# game/a13/6cold_castle.rpy:287
translate english cold_castle_eva_82c9d0c8:

    # eva "Догоняй!"
    eva "来追我！"

# game/a13/6cold_castle.rpy:288
translate english cold_castle_eva_67c5f2d1:

    # me "Чего?"
    me "什么？"

# game/a13/6cold_castle.rpy:289
translate english cold_castle_eva_546a44ee:

    # eva "Ну не стой столбом!"
    eva "别傻站着！"

# game/a13/6cold_castle.rpy:290
translate english cold_castle_eva_672a5a4c:

    # me "Ты серьезно?"
    me "你是认真的吗？"

# game/a13/6cold_castle.rpy:291
translate english cold_castle_eva_d883e8f3:

    # eva "Кто последний тот мокрая дохлая вонючая полусгнившая крыса!"
    eva "最后一个到的是又湿又臭又烂的死老鼠！"

# game/a13/6cold_castle.rpy:292
translate english cold_castle_eva_23266dc8:

    # me "Я не побегу."
    me "我不会跑的。"

# game/a13/6cold_castle.rpy:293
translate english cold_castle_eva_0124f67c:

    # eva "Мокрая крыса!"
    eva "湿老鼠！"

# game/a13/6cold_castle.rpy:295
translate english cold_castle_eva_6853f766:

    # me "Какого хрена я делаю?"
    me "我到底在干什么？"

# game/a13/6cold_castle.rpy:296
translate english cold_castle_eva_ac99a511:

    # eva "Веселишься."
    eva "找乐子。"

# game/a13/6cold_castle.rpy:297
translate english cold_castle_eva_73d4f025:

    # me "Не уверен."
    me "我不这么觉得。"

# game/a13/6cold_castle.rpy:298
translate english cold_castle_eva_d4e16150:

    # eva "Не уверен? Почему?"
    eva "不觉得？为什么？"

# game/a13/6cold_castle.rpy:299
translate english cold_castle_eva_01f10f9d:

    # me "Мы же просто бежим."
    me "我们只是在跑。"

# game/a13/6cold_castle.rpy:300
translate english cold_castle_eva_5c132882:

    # eva "И тебе не весело?"
    eva "你不觉得有趣吗？"

# game/a13/6cold_castle.rpy:302
translate english cold_castle_eva_997c151d:

    # me "Не особо."
    me "不怎么觉得。"

# game/a13/6cold_castle.rpy:303
translate english cold_castle_eva_fd6e8f49:

    # eva "Ну это пока что."
    eva "现在是还没到时候。"

# game/a13/6cold_castle.rpy:304
translate english cold_castle_eva_889467f8:

    # me "Пока что не весело?"
    me "还没到觉得有趣的时候？"

# game/a13/6cold_castle.rpy:305
translate english cold_castle_eva_c68ba327:

    # eva "Пока что просто бежим."
    eva "还没到只是跑步的时候。"

# game/a13/6cold_castle.rpy:306
translate english cold_castle_eva_149b3064:

    # me "В каком смысле?"
    me "什么意思？"

# game/a13/6cold_castle.rpy:307
translate english cold_castle_eva_503ebe0f:

    # eva "Сейчас будет этаж со слугами!"
    eva "马上就到仆人们住的那层楼了！"

# game/a13/6cold_castle.rpy:310
translate english cold_castle_eva_5e06f480:

    # eva "Аккуратней!"
    eva "小心点！"

# game/a13/6cold_castle.rpy:311
translate english cold_castle_eva_663902cc:

    # slug "Ой!"
    slug "哎呀！"

# game/a13/6cold_castle.rpy:312
translate english cold_castle_eva_d3fed71e:

    # eva "Не стой на пути!"
    eva "别挡路！"

# game/a13/6cold_castle.rpy:313
translate english cold_castle_eva_ee6a35d9:

    # slug "Рыба! Нет! Только не на пол."
    slug "鱼！不！别掉地上！"

# game/a13/6cold_castle.rpy:314
translate english cold_castle_eva_f39022fe:

    # eva "Не забудь отмыть!"
    eva "别忘了擦干净！"

# game/a13/6cold_castle.rpy:317
translate english cold_castle_eva_72971efa:

    # ice_guard "ВО ИМЯ БЕЗЫМЯННЫХ БОГОВ!"
    ice_guard "以无名诸神之名！"

# game/a13/6cold_castle.rpy:318
translate english cold_castle_eva_60e5f37d:

    # me "Прошу меня простить!"
    me "请原谅我！"

# game/a13/6cold_castle.rpy:319
translate english cold_castle_eva_cb40af5a:

    # ice_guard "Что происходит? "
    ice_guard "发生什么了？"

# game/a13/6cold_castle.rpy:320
translate english cold_castle_eva_c1c6c4f6:

    # me "Все нормально. Просто нужно кое-куда срочно добежать!"
    me "没事。只是得赶紧跑到某个地方！"

# game/a13/6cold_castle.rpy:321
translate english cold_castle_eva_c3aadec3:

    # ice_guard "С ума посходили!"
    ice_guard "都疯了！"

# game/a13/6cold_castle.rpy:323
translate english cold_castle_eva_c6dd4736:

    # me "Стой!"
    me "停下！"

# game/a13/6cold_castle.rpy:324
translate english cold_castle_eva_d93c267c:

    # eva "Не остановлюсь. Догоняй."
    eva "我不会停的。来追啊。"

# game/a13/6cold_castle.rpy:325
translate english cold_castle_eva_d4a1c02c:

    # me "Мы куда бежим?"
    me "我们跑哪儿去？"

# game/a13/6cold_castle.rpy:326
translate english cold_castle_eva_3e97ff44:

    # eva "В башню. Пару лестниц вверх. Догонишь - дам поцеловать."
    eva "去塔楼。再上几段楼梯。追上了——让你亲一下。"

# game/a13/6cold_castle.rpy:327
translate english cold_castle_eva_3820771a_5:

    # me "..."
    me "..."

# game/a13/6cold_castle.rpy:328
translate english cold_castle_eva_56b39423:

    # eva "Я серьезно! А если нет - сожрешь крысу, идет?"
    eva "我是认真的！要是没追上——你就吃老鼠，怎么样？"

# game/a13/6cold_castle.rpy:331
translate english cold_castle_eva_b44de435:

    # eva "ОЙ!"
    eva "哎呀！"

# game/a13/6cold_castle.rpy:332
translate english cold_castle_eva_a5982414:

    # me "Поймал!"
    me "抓住你了！"

# game/a13/6cold_castle.rpy:333
translate english cold_castle_eva_45d76976:

    # eva "Нечестно! Тут все двери закрыты. Больше некуда бежать."
    eva "不公平！这里的门都锁着。无处可跑了。"

# game/a13/6cold_castle.rpy:334
translate english cold_castle_eva_1a1fe843:

    # me "А вот это явно не моя проблема."
    me "这显然不是我的问题。"

# game/a13/6cold_castle.rpy:335
translate english cold_castle_eva_c8ab6fc4:

    # eva "Ладно, можешь не есть крысу."
    eva "好吧，你可以不吃老鼠了。"

# game/a13/6cold_castle.rpy:336
translate english cold_castle_eva_97c63883:

    # me "И не собирался."
    me "我也没打算吃。"

# game/a13/6cold_castle.rpy:337
translate english cold_castle_eva_dd638832:

    # eva "Отпусти."
    eva "放开我。"

# game/a13/6cold_castle.rpy:338
translate english cold_castle_eva_da04afb2:

    # me "Не пущу"
    me "不放。"

# game/a13/6cold_castle.rpy:341
translate english cold_castle_eva_33a9721b:

    # eva "Ай. Ты чего делаешь?"
    eva "哎哟。你干嘛？"

# game/a13/6cold_castle.rpy:342
translate english cold_castle_eva_25c24972:

    # me "Хочу убедится, что ты не вырвешься."
    me "我想确保你不会挣脱。"

# game/a13/6cold_castle.rpy:343
translate english cold_castle_eva_1a364108:

    # eva "Не вырвусь. Тут некуда бежать."
    eva "我不会挣脱的。这里无路可逃。"

# game/a13/6cold_castle.rpy:344
translate english cold_castle_eva_f7da35be:

    # me "Мы башне? Лестниц выше нет. Мы в башне."
    me "我们到塔楼了吗？上面没有楼梯了。我们在塔楼了。"

# game/a13/6cold_castle.rpy:345
translate english cold_castle_eva_a7062d72:

    # eva "Не держи меня."
    eva "别抓着我。"

# game/a13/6cold_castle.rpy:346
translate english cold_castle_eva_f4ddb348:

    # me "Хочу и держу."
    me "我想抓就抓。"

# game/a13/6cold_castle.rpy:347
translate english cold_castle_eva_53352fc0_1:

    # eva "..."
    eva "..."

# game/a13/6cold_castle.rpy:348
translate english cold_castle_eva_9ac7f315:

    # me "Ты покраснела."
    me "你脸红了。"

# game/a13/6cold_castle.rpy:349
translate english cold_castle_eva_e9306c55:

    # eva "Идиот."
    eva "白痴。"

# game/a13/6cold_castle.rpy:350
translate english cold_castle_eva_788e1953:

    # me "Куда же делась вся твоя игривость."
    me "你刚才那调皮劲儿去哪儿了？"

# game/a13/6cold_castle.rpy:352
translate english cold_castle_eva_b5d600f9:

    # eva "Принц [mename]..."
    eva "[mename]王子……"

# game/a13/6cold_castle.rpy:353
translate english cold_castle_eva_8f292d86:

    # me "Ага. Вот и она."
    me "啊哈。这才像话。"

# game/a13/6cold_castle.rpy:354
translate english cold_castle_eva_34f2b367:

    # eva "А я знаю, зачем ты меня держишь."
    eva "我知道您为什么抓着我。"

# game/a13/6cold_castle.rpy:355
translate english cold_castle_eva_6c6a6d69:

    # me "И зачем же?"
    me "为什么？"

# game/a13/6cold_castle.rpy:356
translate english cold_castle_eva_45afd9a8:

    # eva "Хотите стребовать поцелуй за победу?"
    eva "您想索取胜利的亲吻？"

# game/a13/6cold_castle.rpy:357
translate english cold_castle_eva_3927811f:

    # me "Стребовать? Ты сама мне его пообещала."
    me "索取？是你自己答应我的。"

# game/a13/6cold_castle.rpy:358
translate english cold_castle_eva_5ed20526:

    # eva "Я пошутила."
    eva "我开玩笑的。"

# game/a13/6cold_castle.rpy:359
translate english cold_castle_eva_287fc2da:

    # me "Пошутила..."
    me "开玩笑……"

# game/a13/6cold_castle.rpy:360
translate english cold_castle_eva_4b77f6f7:

    # eva "Вы же не думали, что я правда вас поцелую."
    eva "您不会真的以为我会亲您吧。"

# game/a13/6cold_castle.rpy:361
translate english cold_castle_eva_05d7d63b:

    # me "Именно так и думал."
    me "我就是这么想的。"

# game/a13/6cold_castle.rpy:362
translate english cold_castle_eva_f7d265c2:

    # eva "Фу. Это было бы в крайней мере неприлично. Вы женаты."
    eva "呸。这实在是太不合礼数了。您是已婚男士。"

# game/a13/6cold_castle.rpy:363
translate english cold_castle_eva_3daaab58:

    # me "А ты пока нет."
    me "而你还是未婚。"

# game/a13/6cold_castle.rpy:364
translate english cold_castle_eva_3545af80:

    # eva "И что, это дает тебе право меня целовать?"
    eva "那又怎样，这就给了您亲吻我的权利？"

# game/a13/6cold_castle.rpy:365
translate english cold_castle_eva_7de2d902:

    # me "Право тебя целовать ты дала мне сама. Я победил."
    me "亲吻你的权利是你自己给我的。我赢了。"

# game/a13/6cold_castle.rpy:367
translate english cold_castle_eva_a9aa22d8:

    # eva "Принц [mename]... Это было бы очень и очень... неправильно."
    eva "[mename]王子……这会是件非常非常……不对的事。"

# game/a13/6cold_castle.rpy:368
translate english cold_castle_eva_82b170d1:

    # me "Еще как."
    me "确实。"

# game/a13/6cold_castle.rpy:370
translate english cold_castle_eva_7c34f2cb:

    # eva "Авроре бы это не понравилось."
    eva "Aurora不会喜欢的。"

# game/a13/6cold_castle.rpy:371
translate english cold_castle_eva_bd371ee7:

    # me "Наверняка она была бы в шоке."
    me "她肯定会大吃一惊。"

# game/a13/6cold_castle.rpy:372
translate english cold_castle_eva_53352fc0_2:

    # eva "..."
    eva "..."

# game/a13/6cold_castle.rpy:373
translate english cold_castle_eva_3820771a_6:

    # me "..."
    me "..."

# game/a13/6cold_castle.rpy:374
translate english cold_castle_eva_7159e386:

    # eva "Ну?"
    eva "那么？"

# game/a13/6cold_castle.rpy:375
translate english cold_castle_eva_ad02f53a:

    # me "Что?"
    me "什么？"

# game/a13/6cold_castle.rpy:376
translate english cold_castle_eva_e65cd2c2:

    # eva "Ты собираешься исполнять свою угрозу, принц?"
    eva "您打算执行您的威胁了吗，王子？"

# game/a13/6cold_castle.rpy:377
translate english cold_castle_eva_29000e64:

    # me "Нет. Я передумал. Это действительно было бы неправильно."
    me "不。我改主意了。这确实不对。"

# game/a13/6cold_castle.rpy:378
translate english cold_castle_eva_3809b822:

    # eva "Ты лжешь."
    eva "您在撒谎。"

# game/a13/6cold_castle.rpy:379
translate english cold_castle_eva_6d9ec4ca:

    # me "Я серьезно. Тем более если ты пошутила... если уговора не было..."
    me "我是认真的。尤其如果你是在开玩笑……如果协议不存在……"

# game/a13/6cold_castle.rpy:380
translate english cold_castle_eva_53352fc0_3:

    # eva "..."
    eva "..."

# game/a13/6cold_castle.rpy:381
translate english cold_castle_eva_97da1426:

    # me "Наверное мне пора."
    me "可能我该走了。"

# game/a13/6cold_castle.rpy:382
translate english cold_castle_eva_b98d332e:

    # eva "Ладно, уговор был."
    eva "好吧，协议是存在的。"

# game/a13/6cold_castle.rpy:383
translate english cold_castle_eva_23d5fd25:

    # me "И какой же?"
    me "什么样的协议？"

# game/a13/6cold_castle.rpy:384
translate english cold_castle_eva_90268ef6:

    # eva "Я дам себя поцеловать, если ты меня поймешь."
    eva "如果你抓住我，我就让你亲。"

# game/a13/6cold_castle.rpy:385
translate english cold_castle_eva_dcc52db4:

    # me "Я поймал?"
    me "我抓住了吗？"

# game/a13/6cold_castle.rpy:386
translate english cold_castle_eva_abb88013:

    # eva "Поймал."
    eva "抓住了。"

# game/a13/6cold_castle.rpy:387
translate english cold_castle_eva_3820771a_7:

    # me "..."
    me "..."

# game/a13/6cold_castle.rpy:388
translate english cold_castle_eva_9f16755a:

    # eva "Целуй уже, хватит меня мучить."
    eva "要亲就快点，别再折磨我了。"

# game/a13/6cold_castle.rpy:390
translate english cold_castle_eva_740239e0:

    # me "{i}Мне определенно не стоит этого делать.{/i}"
    me "{i}我绝对不该这么做。{/i}"

# game/a13/6cold_castle.rpy:391
translate english cold_castle_eva_4a0f2045:

    # me "{i}Но все же я это делаю.{/i}"
    me "{i}但我还是这么做了。{/i}"

# game/a13/6cold_castle.rpy:392
translate english cold_castle_eva_cf90fe93:

    # me "{i}Она сама предложила...{/i}"
    me "{i}是她自己提议的……{/i}"

# game/a13/6cold_castle.rpy:393
translate english cold_castle_eva_c815a973:

    # me "{i}Нет... я не буду перекладывать ответственность на избалованную девчонку.{/i}"
    me "{i}不……我不会把责任推给一个被宠坏的女孩。{/i}"

# game/a13/6cold_castle.rpy:394
translate english cold_castle_eva_5657733f:

    # me "{i}Даже если она сама этого хочет, я должен быть сильней.{/i}"
    me "{i}即使是她自愿的，我也应该更坚强。{/i}"

# game/a13/6cold_castle.rpy:395
translate english cold_castle_eva_d92186a1:

    # me "{i}Так какого хрена я ее целую?{/i}"
    me "{i}那我他妈为什么在亲她？{/i}"

# game/a13/6cold_castle.rpy:397
translate english cold_castle_eva_77146afd:

    # me "{i}Я сошел с ума. Я сошел с ума.{/i}"
    me "{i}我疯了。我疯了。{/i}"

# game/a13/6cold_castle.rpy:398
translate english cold_castle_eva_fcb96f53:

    # me "{i}Если бы ее отец это увидел...{/i}"
    me "{i}如果她父亲看见了……{/i}"

# game/a13/6cold_castle.rpy:399
translate english cold_castle_eva_b4372422:

    # me "{i}Это была бы проблема.{/i}"
    me "{i}那会是个大麻烦。{/i}"

# game/a13/6cold_castle.rpy:400
translate english cold_castle_eva_7fc2623d:

    # me "{i}Боюсь мой дипломатический вояж пришлось бы окончить... преждевременно.{/i}"
    me "{i}恐怕我的外交之旅就得……提前结束了。{/i}"

# game/a13/6cold_castle.rpy:401
translate english cold_castle_eva_4ab49e10:

    # me "{i}А может даже и моя жизнь закончилась.{/i}"
    me "{i}也许我的小命也会结束。{/i}"

# game/a13/6cold_castle.rpy:402
translate english cold_castle_eva_c95396e6:

    # me "{i}Хотя я просто целую ее...{/i}"
    me "{i}虽然我只是在亲她……{/i}"

# game/a13/6cold_castle.rpy:403
translate english cold_castle_eva_f93855bb:

    # me "{i}Я ведь не обесчестил ее?{/i}"
    me "{i}我并没有玷污她的名誉，不是吗？{/i}"

# game/a13/6cold_castle.rpy:404
translate english cold_castle_eva_5c76dbe7:

    # me "{i}...{/i}"
    me "{i}...{/i}"

# game/a13/6cold_castle.rpy:406
translate english cold_castle_eva_192f417c:

    # me "{i}Кого я обманываю?{/i}"
    me "{i}我在骗谁呢？{/i}"

# game/a13/6cold_castle.rpy:407
translate english cold_castle_eva_0dbfcf54:

    # me "{i}У себя в голове я уже давно сделал это.{/i}"
    me "{i}在我脑子里，我早就这么做了。{/i}"

# game/a13/6cold_castle.rpy:408
translate english cold_castle_eva_7389706a:

    # me "{i}В ту самую секунду, когда ее увидел.{/i}"
    me "{i}在我看见她的那一秒，就已经做了。{/i}"

# game/a13/6cold_castle.rpy:409
translate english cold_castle_eva_eec87469:

    # me "{i}...красивые девушки иногда манят меня сильнее короны.{/i}"
    me "{i}……美丽的姑娘有时比王冠更吸引我。{/i}"

# game/a13/6cold_castle.rpy:410
translate english cold_castle_eva_6258ecbd:

    # me "{i}Так и должно быть или я дерьмовый принц и буду дерьмовым императором?{/i}"
    me "{i}这是理所当然的，还是说我是个糟糕的王子，将来也会是个糟糕的皇帝？{/i}"

# game/a13/6cold_castle.rpy:411
translate english cold_castle_eva_78b347ad:

    # me "{i}Я определенно не должен этого делать...{/i}"
    me "{i}我绝对不该这么做……{/i}"

# game/a13/6cold_castle.rpy:412
translate english cold_castle_eva_dd3fa15e:

    # me "{i}Но ее губы...{/i}"
    me "{i}但是她的嘴唇……{/i}"

# game/a13/6cold_castle.rpy:414
translate english cold_castle_eva_d679da63:

    # slug "О, боже!"
    slug "哦，天哪！"

# game/a13/6cold_castle.rpy:416
translate english cold_castle_eva_917ddaaf:

    # eva "Я..."
    eva "我……"

# game/a13/6cold_castle.rpy:417
translate english cold_castle_eva_193c62d4:

    # me "Блядь!"
    me "该死！"

# game/a13/6cold_castle.rpy:418
translate english cold_castle_eva_5b30a3fb:

    # slug "Извините! Я не хотела помешать!"
    slug "对不起！我不是故意打扰的！"

# game/a13/6cold_castle.rpy:419
translate english cold_castle_eva_123d35f3:

    # eva "Ты не помешала!"
    eva "你没有打扰！"

# game/a13/6cold_castle.rpy:420
translate english cold_castle_eva_220d2b82:

    # me "Мы ничего и не делали."
    me "我们什么都没做。"

# game/a13/6cold_castle.rpy:421
translate english cold_castle_eva_5e15926a:

    # slug "Да! Да!"
    slug "是的！是的！"

# game/a13/6cold_castle.rpy:422
translate english cold_castle_eva_53352fc0_4:

    # eva "..."
    eva "..."

# game/a13/6cold_castle.rpy:423
translate english cold_castle_eva_3820771a_8:

    # me "..."
    me "..."

# game/a13/6cold_castle.rpy:424
translate english cold_castle_eva_347a08bb:

    # slug "Я пойду."
    slug "我先走了。"

# game/a13/6cold_castle.rpy:426
translate english cold_castle_eva_bf589d57:

    # eva "Стой! Ты что вообще здесь делаешь? Ты шпионила?"
    eva "等等！你到底在这里干什么？你一直在监视？"

# game/a13/6cold_castle.rpy:427
translate english cold_castle_eva_4c9ef222:

    # slug "Нет! Клянусь!"
    slug "没有！我发誓！"

# game/a13/6cold_castle.rpy:428
translate english cold_castle_eva_fa81a552:

    # eva "Тогда почему ты вошла сюда?"
    eva "那你为什么进来？"

# game/a13/6cold_castle.rpy:429
translate english cold_castle_eva_66692d00:

    # slug "Ваш отец приказал."
    slug "您的父亲命令的。"

# game/a13/6cold_castle.rpy:430
translate english cold_castle_eva_64835e47:

    # eva "Мой отец?"
    eva "我的父亲？"

# game/a13/6cold_castle.rpy:431
translate english cold_castle_eva_224a9ff8:

    # slug "Ваше наказание в башне, я должна была проследить. Я буду за дверью!"
    slug "您被罚关在塔楼，我必须监督。我在门外守着！"

# game/a13/6cold_castle.rpy:432
translate english cold_castle_eva_bc4b0443:

    # eva "Почему ты? Он сказал это будет стражник!"
    eva "为什么是你？他说会是守卫！"

# game/a13/6cold_castle.rpy:433
translate english cold_castle_eva_3a376628:

    # slug "Извините! Наверное он поменял решение."
    slug "对不起！可能他改变主意了。"

# game/a13/6cold_castle.rpy:434
translate english cold_castle_eva_3111d128:

    # eva "То что ты увидела..."
    eva "你看到的……"

# game/a13/6cold_castle.rpy:435
translate english cold_castle_eva_915415d3:

    # slug "Я ничего не видела! Клянусь!"
    slug "我什么都没看见！我发誓！"

# game/a13/6cold_castle.rpy:436
translate english cold_castle_eva_14d6c7ce:

    # eva "Принц [mename] просто обнял меня перед прощанием, верно?"
    eva "[mename]王子只是临别前抱了我一下，对吧？"

# game/a13/6cold_castle.rpy:437
translate english cold_castle_eva_eb0d474a:

    # me "Верно."
    me "对。"

# game/a13/6cold_castle.rpy:438
translate english cold_castle_eva_2e2b2c4f:

    # slug "Да. Конечно!"
    slug "是的。当然！"

# game/a13/6cold_castle.rpy:439
translate english cold_castle_eva_57f64409:

    # eva "Если кто-нибудь..."
    eva "如果有人……"

# game/a13/6cold_castle.rpy:440
translate english cold_castle_eva_3bf9de6e:

    # slug "Никогда! Простите, госпожа! Я ничего не видела. Я пойду."
    slug "绝对不会说！对不起，小姐！我什么都没看见。我走了。"

# game/a13/6cold_castle.rpy:442
translate english cold_castle_eva_0e24ff7f:

    # eva "О боже..."
    eva "哦，天哪……"

# game/a13/6cold_castle.rpy:443
translate english cold_castle_eva_fde92496:

    # me "Успокойся. Она так напугалась, я уверен, что она никому не скажет."
    me "冷静点。她被吓坏了，我肯定她不会告诉任何人的。"

# game/a13/6cold_castle.rpy:444
translate english cold_castle_eva_0c0d9e0d:

    # eva "Хорошо бы. А иначе нас обоих четвертуют."
    eva "那就好。否则我们俩都会被四马分尸的。"

# game/a13/6cold_castle.rpy:445
translate english cold_castle_eva_28a395d7:

    # me "За объятия?"
    me "就为了一个拥抱？"

# game/a13/6cold_castle.rpy:446
translate english cold_castle_eva_29a03f1f:

    # eva "За поцелуй."
    eva "为了一个吻。"

# game/a13/6cold_castle.rpy:447
translate english cold_castle_eva_3a88566c:

    # me "А его и не было."
    me "根本就没吻。"

# game/a13/6cold_castle.rpy:448
translate english cold_castle_eva_530ee096:

    # eva "Что ты несешь?"
    eva "你在说什么？"

# game/a13/6cold_castle.rpy:449
translate english cold_castle_eva_bddab046:

    # me "Мы просто обнялись на прощание и все."
    me "我们只是在告别时拥抱了一下，仅此而已。"

# game/a13/6cold_castle.rpy:450
translate english cold_castle_eva_8a7fb80e:

    # eva "...да. Просто обнялись."
    eva "……对。只是拥抱了一下。"

# game/a13/6cold_castle.rpy:451
translate english cold_castle_eva_72ba0a39:

    # me "Не нервничай. Нас же не в постели застали."
    me "别紧张。我们又没被捉奸在床。"

# game/a13/6cold_castle.rpy:452
translate english cold_castle_eva_135ce236:

    # eva "А если она расскажет?"
    eva "要是她说出去了呢？"

# game/a13/6cold_castle.rpy:453
translate english cold_castle_eva_26b236ca:

    # me "Кому? Твоему отцу? Она не станет рисковать, не зная ее возможной реакции."
    me "跟谁说？你父亲吗？她不敢冒险，因为她不知道你父亲会有什么反应。"

# game/a13/6cold_castle.rpy:454
translate english cold_castle_eva_2f1a9940:

    # eva "А другим слугам? Что если она расскажет им?"
    eva "那其他仆人呢？要是她告诉他们了呢？"

# game/a13/6cold_castle.rpy:455
translate english cold_castle_eva_213d91a8:

    # me "Успокойся, она ничего не расскажет. А если и расскажет - ее слово против наших двух. Она это знает и не будет рисковать."
    me "冷静点，她什么都不会说的。即使说了，也只是她一个人的话对我们的两个人的话。她知道这点，不会冒险的。"

# game/a13/6cold_castle.rpy:456
translate english cold_castle_eva_aa0961cd:

    # eva "...ладно. Сегодня она будет дежурить у моих покоев в башне, я с ней побеседую..."
    eva "……好吧。今晚她会在塔楼我的房间外值班，我跟她谈谈……"

# game/a13/6cold_castle.rpy:457
translate english cold_castle_eva_45cd4bd1:

    # me "Не стоит. Просто делай вид, что ничего и не было."
    me "千万别。就当什么都没发生过。"

# game/a13/6cold_castle.rpy:458
translate english cold_castle_eva_64a6853e:

    # eva "Хорошо."
    eva "好吧。"

# game/a13/6cold_castle.rpy:459
translate english cold_castle_eva_814f9962:

    # me "Вот и отлично. А я лучше пойду."
    me "这就对了。我最好走了。"

# game/a13/6cold_castle.rpy:467
translate english cold_castle_lisa_808b4959:

    # me "Я сопровожу принцессу в библиотеку сам."
    me "我会亲自送公主去图书馆。"

# game/a13/6cold_castle.rpy:468
translate english cold_castle_lisa_0100b07e:

    # eva "Что?"
    eva "什么？"

# game/a13/6cold_castle.rpy:469
translate english cold_castle_lisa_596aa7ab:

    # lisa "Что?"
    lisa "什么？"

# game/a13/6cold_castle.rpy:470
translate english cold_castle_lisa_a863fbd0:

    # me "Степан может помочь принцессе Еве добраться до башни, ее отец как раз хотел, чтобы ее там охранял стражник."
    me "Stepan可以帮助Eva公主去塔楼，她父亲正希望有个守卫在那里看守她。"

# game/a13/6cold_castle.rpy:471
translate english cold_castle_lisa_73c3f6da:

    # stepan "Конечно."
    stepan "当然可以。"

# game/a13/6cold_castle.rpy:472
translate english cold_castle_lisa_8636a1bf:

    # eva "Но...я..."
    eva "但是……我……"

# game/a13/6cold_castle.rpy:473
translate english cold_castle_lisa_b0170ddd:

    # lisa "Вы уверены, принц?"
    lisa "您确定吗，王子？"

# game/a13/6cold_castle.rpy:474
translate english cold_castle_lisa_47e9b604:

    # me "Уверен. У меня как раз книжное настроение."
    me "确定。我正好有读书的心情。"

# game/a13/6cold_castle.rpy:475
translate english cold_castle_lisa_858048e3:

    # lisa "Книжное настроение...а... поняла."
    lisa "读书的心情……啊……懂了。"

# game/a13/6cold_castle.rpy:476
translate english cold_castle_lisa_6670210f:

    # stepan "Пойдемте госпожа."
    stepan "我们走吧，小姐。"

# game/a13/6cold_castle.rpy:477
translate english cold_castle_lisa_5ab084d4:

    # eva "П-пойдемте."
    eva "走……走吧。"

# game/a13/6cold_castle.rpy:478
translate english cold_castle_lisa_956ad573:

    # lisa "Нам налево."
    lisa "我们往左。"

# game/a13/6cold_castle.rpy:479
translate english cold_castle_lisa_2d42945b:

    # me "Ага."
    me "嗯。"

# game/a13/6cold_castle.rpy:481
translate english cold_castle_lisa_fc7d3a18:

    # "Пару минут спустя."
    "几分钟以后。"

# game/a13/6cold_castle.rpy:482
translate english cold_castle_lisa_d0bfd598:

    # lisa "Вот сюда."
    lisa "这边。"

# game/a13/6cold_castle.rpy:483
translate english cold_castle_lisa_6c1651c4:

    # me "Вижу."
    me "看到了。"

# game/a13/6cold_castle.rpy:484
translate english cold_castle_lisa_03892506:

    # lisa "Готова поспорить меньше, чем ваша в Столице."
    lisa "我敢打赌这图书馆比你们首都的小。"

# game/a13/6cold_castle.rpy:485
translate english cold_castle_lisa_3dbd674e:

    # me "Разумеется."
    me "当然。"

# game/a13/6cold_castle.rpy:486
translate english cold_castle_lisa_6b03d5d4:

    # lisa "Хотела бы там побывать."
    lisa "我真想去那儿看看。"

# game/a13/6cold_castle.rpy:487
translate english cold_castle_lisa_eb09d363:

    # me "Так поехали. Заберу вас на обратном пути."
    me "那就一起去吧。我回程时带上你。"

# game/a13/6cold_castle.rpy:488
translate english cold_castle_lisa_aacdc322:

    # lisa "Смешно."
    lisa "真会开玩笑。"

# game/a13/6cold_castle.rpy:489
translate english cold_castle_lisa_15cb29bb:

    # me "Я серьезно."
    me "我是认真的。"

# game/a13/6cold_castle.rpy:490
translate english cold_castle_lisa_93aabf1a:

    # lisa "...туда к столу, пожалуйста."
    lisa "……请到那边的桌子。"

# game/a13/6cold_castle.rpy:492
translate english cold_castle_lisa_1db2a73f:

    # me "Здесь?"
    me "这里吗？"

# game/a13/6cold_castle.rpy:493
translate english cold_castle_lisa_35c81ef2:

    # lisa "Да."
    lisa "对。"

# game/a13/6cold_castle.rpy:494
translate english cold_castle_lisa_108f5a59:

    # me "В вашем замке удивительно много картин."
    me "你们的城堡里画可真多。"

# game/a13/6cold_castle.rpy:495
translate english cold_castle_lisa_52da829b:

    # lisa "Раньше и скульптур было много. Отец зачем-то убрал их в крипту. Видимо чтобы мертвецам было на что поглазеть."
    lisa "以前还有很多雕塑。父亲不知为何把它们都搬到地下墓室去了。大概是让死人有东西可看吧。"

# game/a13/6cold_castle.rpy:496
translate english cold_castle_lisa_517265a9:

    # me "Красивая картина. Это вы?"
    me "这幅画很美。这是你吗？"

# game/a13/6cold_castle.rpy:497
translate english cold_castle_lisa_b91f7bd2:

    # lisa "Похожа?"
    lisa "像吗？"

# game/a13/6cold_castle.rpy:498
translate english cold_castle_lisa_fc30fd2b:

    # me "Да."
    me "像。"

# game/a13/6cold_castle.rpy:499
translate english cold_castle_lisa_5e4f18ab:

    # lisa "Это не я."
    lisa "这不是我。"

# game/a13/6cold_castle.rpy:500
translate english cold_castle_lisa_0d146ab2:

    # me "Ваша мать?"
    me "你的母亲？"

# game/a13/6cold_castle.rpy:501
translate english cold_castle_lisa_0c079ce9:

    # lisa "Нет."
    lisa "不。"

# game/a13/6cold_castle.rpy:502
translate english cold_castle_lisa_e69902c9:

    # me "А кто это?"
    me "那这是谁？"

# game/a13/6cold_castle.rpy:503
translate english cold_castle_lisa_a3068259:

    # lisa "Понятия не имею. Никогда не спрашивала. Меня больше интересуют книги, а не картины. Какая-то красивая северянка."
    lisa "毫无头绪。从没问过。我更感兴趣的是书，而不是画。某个美丽的北方女人。"

# game/a13/6cold_castle.rpy:504
translate english cold_castle_lisa_21bb671a:

    # me "Они все красивые."
    me "她们都很美。"

# game/a13/6cold_castle.rpy:505
translate english cold_castle_lisa_70f54e58:

    # lisa "Какой вы льстец, принц."
    lisa "您可真会奉承人，王子。"

# game/a13/6cold_castle.rpy:506
translate english cold_castle_lisa_b2884594:

    # me "[mename]."
    me "[mename]."

# game/a13/6cold_castle.rpy:507
translate english cold_castle_lisa_17745ffb:

    # lisa "[mename], подайте что-нибудь с полки сзади меня."
    lisa "[mename]，请从我身后的书架上拿点东西。"

# game/a13/6cold_castle.rpy:509
translate english cold_castle_lisa_1324e561:

    # me "С какого ряда?"
    me "哪一排？"

# game/a13/6cold_castle.rpy:510
translate english cold_castle_lisa_641efaf9:

    # lisa "С самого верхнего."
    lisa "最上面那排。"

# game/a13/6cold_castle.rpy:511
translate english cold_castle_lisa_b9336f7e:

    # me "Что-то конкретное?"
    me "指定要哪本吗？"

# game/a13/6cold_castle.rpy:512
translate english cold_castle_lisa_4bc26a8d:

    # lisa "Нет. Я читаю все по очереди."
    lisa "不。我按顺序全部读。"

# game/a13/6cold_castle.rpy:513
translate english cold_castle_lisa_713b4223:

    # me "И много так прочитали?"
    me "这样读了很多吗？"

# game/a13/6cold_castle.rpy:514
translate english cold_castle_lisa_b958d199:

    # lisa "Почти все что тут есть. Жаль больше половины это дрянь полная."
    lisa "这里几乎所有的书我都读过了。可惜一多半都是彻头彻尾的垃圾。"

# game/a13/6cold_castle.rpy:515
translate english cold_castle_lisa_8f6d7f80:

    # me "Больше половины?"
    me "一多半？"

# game/a13/6cold_castle.rpy:516
translate english cold_castle_lisa_4e310bf1:

    # lisa "Ага. Тут только научных трактатов о лечении импотенции книг восемь."
    lisa "是啊。光是关于治疗阳痿的科学论文就有八本。"

# game/a13/6cold_castle.rpy:517
translate english cold_castle_lisa_0ec3946c:

    # me "Где они, говорите, стоят?"
    me "您说，它们放在哪儿？"

# game/a13/6cold_castle.rpy:518
translate english cold_castle_lisa_d552b072:

    # lisa "Шутите?"
    lisa "您开玩笑吧？"

# game/a13/6cold_castle.rpy:519
translate english cold_castle_lisa_231b4084:

    # me "Шучу."
    me "开玩笑的。"

# game/a13/6cold_castle.rpy:521
translate english cold_castle_lisa_082293af:

    # lisa "Рада. Мужчины без члена, как..."
    lisa "真高兴。没有那话儿的男人，就像……"

# game/a13/6cold_castle.rpy:522
translate english cold_castle_lisa_4e3d767c:

    # me "...женщина без ног."
    me "……没有腿的女人。"

# game/a13/6cold_castle.rpy:523
translate english cold_castle_lisa_c8f53cfc:

    # lisa "Ага."
    lisa "对。"

# game/a13/6cold_castle.rpy:524
translate english cold_castle_lisa_6ef429f3:

    # me "Сколько книг взять."
    me "要拿几本书？"

# game/a13/6cold_castle.rpy:525
translate english cold_castle_lisa_58664b49:

    # lisa "Что вместится в руки."
    lisa "能拿多少拿多少。"

# game/a13/6cold_castle.rpy:526
translate english cold_castle_lisa_7c6a3569:

    # me "Вместится много."
    me "那能拿很多。"

# game/a13/6cold_castle.rpy:527
translate english cold_castle_lisa_922be575:

    # lisa "Замечательно. У меня как раз полно свободного времени."
    lisa "太好了。我正好有大把的空闲时间。"

# game/a13/6cold_castle.rpy:529
translate english cold_castle_lisa_57bd8592:

    # lisa "Спасибо. Можете идти."
    lisa "谢谢。您可以走了。"

# game/a13/6cold_castle.rpy:530
translate english cold_castle_lisa_ee2dbdc3:

    # me "Идти."
    me "走？"

# game/a13/6cold_castle.rpy:531
translate english cold_castle_lisa_8bd8c2b9:

    # lisa "Вы мне помогли и шутка удалась."
    lisa "您已经帮了我，而且玩笑也开过了。"

# game/a13/6cold_castle.rpy:532
translate english cold_castle_lisa_e7645a9a:

    # me "Шутка?"
    me "玩笑？"

# game/a13/6cold_castle.rpy:533
translate english cold_castle_lisa_3686d6c5:

    # lisa "Вы хотели позлить Еву у вас наверняка получилось."
    lisa "您想气气Eva，您肯定已经做到了。"

# game/a13/6cold_castle.rpy:534
translate english cold_castle_lisa_f05b128d:

    # me "Я искренне хотел сюда с вами пойти."
    me "我是真心想和你一起来这里的。"

# game/a13/6cold_castle.rpy:535
translate english cold_castle_lisa_e83bb9d0:

    # lisa "...это продолжение шутки?"
    lisa "……这也是玩笑的一部分吗？"

# game/a13/6cold_castle.rpy:536
translate english cold_castle_lisa_dcdad8e2:

    # me "Нет. Я серьезно."
    me "不。我是认真的。"

# game/a13/6cold_castle.rpy:537
translate english cold_castle_lisa_eff68130:

    # lisa "Не понимаю зачем это вам."
    lisa "我不明白您为什么要这么做。"

# game/a13/6cold_castle.rpy:538
translate english cold_castle_lisa_0926c9c8:

    # me "Просто захотелось."
    me "只是想来而已。"

# game/a13/6cold_castle.rpy:539
translate english cold_castle_lisa_8e972307:

    # lisa "Вы ведь понимаете что я парализована?"
    lisa "您知道我瘫痪了吧？"

# game/a13/6cold_castle.rpy:540
translate english cold_castle_lisa_fc30fd2b_1:

    # me "Да."
    me "知道。"

# game/a13/6cold_castle.rpy:541
translate english cold_castle_lisa_c1fb5feb:

    # lisa "Я не стану вам любовницей, даже если бы хотела."
    lisa "我不会成为您的情妇，即使我想也不行。"

# game/a13/6cold_castle.rpy:542
translate english cold_castle_lisa_068b7a82:

    # me "Я знаю."
    me "我知道。"

# game/a13/6cold_castle.rpy:543
translate english cold_castle_lisa_b17eeb5d:

    # lisa "Я не жената и у меня нет никакого влияния на отца."
    lisa "我未婚，对父亲也没有任何影响力。"

# game/a13/6cold_castle.rpy:544
translate english cold_castle_lisa_068b7a82_1:

    # me "Я знаю."
    me "我知道。"

# game/a13/6cold_castle.rpy:545
translate english cold_castle_lisa_7863e5a3:

    # lisa "Я понятия не имею о его планах."
    lisa "我对他的计划一无所知。"

# game/a13/6cold_castle.rpy:546
translate english cold_castle_lisa_587c63b8:

    # me "Угумн."
    me "嗯哼。"

# game/a13/6cold_castle.rpy:547
translate english cold_castle_lisa_d60eace8:

    # lisa "И вы все еще планируете остаться?"
    lisa "您还是打算留下来？"

# game/a13/6cold_castle.rpy:548
translate english cold_castle_lisa_fc30fd2b_2:

    # me "Да."
    me "是的。"

# game/a13/6cold_castle.rpy:549
translate english cold_castle_lisa_594df83c:

    # lisa "Вы странный."
    lisa "您真是个怪人。"

# game/a13/6cold_castle.rpy:550
translate english cold_castle_lisa_316f6919:

    # me "Может я просто люблю читать."
    me "也许我只是喜欢读书。"

# game/a13/6cold_castle.rpy:552
translate english cold_castle_lisa_79e0ab33:

    # lisa "Это удивительно. Вы первый дворянин с членом на моей памяти, которому интересна библиотека, а не бордель в городке у замка."
    lisa "真令人惊讶。您是我记忆中，第一个对图书馆感兴趣，而不是对城堡外小镇上妓院感兴趣的有'那话儿'的贵族。"

# game/a13/6cold_castle.rpy:553
translate english cold_castle_lisa_eb73e2d2:

    # me "С членом?"
    me "有'那话儿'？"

# game/a13/6cold_castle.rpy:554
translate english cold_castle_lisa_4ebd06fb:

    # lisa "Иногда они привозят с собой жён и они скучают здесь перебирая книги в поисках любовного романа, чтобы хоть на страницах книги насладится отношениями, которых у них никогда не будет."
    lisa "有时候他们会带着妻子来，那些妻子们就在这儿打发时间，翻遍所有的书寻找爱情小说，只为了在书页里享受一下她们永远不会拥有的爱情关系。"

# game/a13/6cold_castle.rpy:555
translate english cold_castle_lisa_977bce99:

    # me "А потом возвращаются их мужья и вы снова остаетесь одна."
    me "然后她们的丈夫回来了，你又变成独自一人。"

# game/a13/6cold_castle.rpy:556
translate english cold_castle_lisa_b1099174:

    # lisa "Это самые счастливые моменты моей жизни. Нет существ тупее и скучнее, чем скучающие аристократки."
    lisa "这是我生命中最幸福的时刻。没有比无聊的贵族妇女更愚蠢、更无趣的人了。"

# game/a13/6cold_castle.rpy:557
translate english cold_castle_lisa_c4781a4c:

    # me "Вы тоже в какой-то мере скучающая аристократка."
    me "从某种程度上说，你也是个无聊的贵族妇女。"

# game/a13/6cold_castle.rpy:558
translate english cold_castle_lisa_17a2a084:

    # lisa "К сожалению."
    lisa "很不幸。"

# game/a13/6cold_castle.rpy:559
translate english cold_castle_lisa_a7fe097a:

    # me "К сожалению?"
    me "不幸？"

# game/a13/6cold_castle.rpy:560
translate english cold_castle_lisa_7a8a90b6:

    # lisa "Будь я крестьянкой меня бы уже оставили в лесу."
    lisa "如果我是农妇，我早就被丢在森林里了。"

# game/a13/6cold_castle.rpy:561
translate english cold_castle_lisa_4c7d378a:

    # me "Вы хотите умереть?"
    me "你想死？"

# game/a13/6cold_castle.rpy:562
translate english cold_castle_lisa_b8ca0c70:

    # lisa "Если бы не хотела, то не оказалась бы в кресле."
    lisa "如果不想死，我就不会坐在轮椅上了。"

# game/a13/6cold_castle.rpy:563
translate english cold_castle_lisa_995a109a:

    # me "Так вы пытались покончить с собой?"
    me "所以你曾试图自杀？"

# game/a13/6cold_castle.rpy:564
translate english cold_castle_lisa_c8f53cfc_1:

    # lisa "Ага."
    lisa "是的。"

# game/a13/6cold_castle.rpy:565
translate english cold_castle_lisa_46abb150:

    # me "Почему не повторили попытку?"
    me "为什么没有再试一次？"

# game/a13/6cold_castle.rpy:566
translate english cold_castle_lisa_3d22dfbc:

    # lisa "Потому что для еще одного прыжка нет рабочих ног, нож не вариант потому что я боюсь крови и потеряю сознание прежде чем умру, а для яда я слишком брезглива."
    lisa "因为再跳一次，我没有能用的腿；用刀子不行，因为我怕血，会在死前就晕过去；至于毒药，我又太挑剔了。"

# game/a13/6cold_castle.rpy:567
translate english cold_castle_lisa_3820771a:

    # me "..."
    me "..."

# game/a13/6cold_castle.rpy:568
translate english cold_castle_lisa_e48b820f:

    # lisa "Я шучу. Просто хотела посмотреть на ваше лицо, обычно оно искажается в притворном сожалении и обеспокоенности или в искреннем непонимании. Но вы как будто собрались мне помочь."
    lisa "我开玩笑的。只是想看看您脸上的表情，通常会扭曲成虚伪的遗憾和关切，或者真诚的困惑。但您看起来好像打算帮我似的。"

# game/a13/6cold_castle.rpy:570
translate english cold_castle_lisa_84ab31b8:

    # lisa "Ой!"
    lisa "哎哟！"

# game/a13/6cold_castle.rpy:571
translate english cold_castle_lisa_a95c103d:

    # me "Я помогу."
    me "我会帮你的。"

# game/a13/6cold_castle.rpy:572
translate english cold_castle_lisa_199bf60b:

    # lisa "Я шутила-шутила. Не надо меня сбрасывать со стены."
    lisa "我开玩笑的！开玩笑的！别把我从城墙上扔下去。"

# game/a13/6cold_castle.rpy:573
translate english cold_castle_lisa_3f35de58:

    # me "А нож?"
    me "那刀子呢？"

# game/a13/6cold_castle.rpy:574
translate english cold_castle_lisa_1f49ba7e:

    # lisa "Тоже не стоит."
    lisa "也别用。"

# game/a13/6cold_castle.rpy:575
translate english cold_castle_lisa_65850c1f:

    # me "Наверное я все-таки вам помогу. Просто по-другому."
    me "也许我终究会帮你的。只是换个方式。"

# game/a13/6cold_castle.rpy:576
translate english cold_castle_lisa_88bdff05:

    # lisa "Не надо мне...помогать."
    lisa "我不需要……帮助。"

# game/a13/6cold_castle.rpy:577
translate english cold_castle_lisa_bad07e75:

    # me "Я очень хочу."
    me "我非常想帮你。"

# game/a13/6cold_castle.rpy:578
translate english cold_castle_lisa_0f5a334c:

    # lisa "[mename]?"
    lisa "[mename]?"

# game/a13/6cold_castle.rpy:579
translate english cold_castle_lisa_3fc0fb20:

    # me "Вам наверняка очень неудобно."
    me "你现在肯定很不舒服。"

# game/a13/6cold_castle.rpy:580
translate english cold_castle_lisa_879dd9c0:

    # lisa "В крипте будет явно неудобнее."
    lisa "在地下墓室肯定会更不舒服。"

# game/a13/6cold_castle.rpy:582
translate english cold_castle_lisa_f8010867:

    # me "А на диване?"
    me "那在沙发上呢？"

# game/a13/6cold_castle.rpy:583
translate english cold_castle_lisa_a6cae77f:

    # lisa "В этом заключалась помощь?"
    lisa "这就是您所谓的帮助？"

# game/a13/6cold_castle.rpy:584
translate english cold_castle_lisa_23f0a33f:

    # me "Ну да. А вы что подумали, Лиза?"
    me "嗯，是啊。不然你以为是什么，Lisa？"

# game/a13/6cold_castle.rpy:585
translate english cold_castle_lisa_e2ba557c:

    # lisa "Да так... вы меня проверяли, да?"
    lisa "没……您是在试探我吗，对吧？"

# game/a13/6cold_castle.rpy:586
translate english cold_castle_lisa_904f8ce4:

    # me "Хотел понять шутили ли вы."
    me "我想知道你刚才是不是在开玩笑。"

# game/a13/6cold_castle.rpy:587
translate english cold_castle_lisa_cc258281:

    # lisa "Я же прямым текстом сказала, что шутила."
    lisa "我明确说了我是在开玩笑。"

# game/a13/6cold_castle.rpy:588
translate english cold_castle_lisa_097acf75:

    # me "Прости, после общения с вашей сестрой, я привык не доверять словам."
    me "抱歉，跟你妹妹打过交道后，我习惯了不轻信别人的话。"

# game/a13/6cold_castle.rpy:589
translate english cold_castle_lisa_e4456ad7:

    # lisa "Моим можешь доверять. Мне забавляться и флиртовать с тобой незачем."
    lisa "你可以相信我的话。我没有理由和你调情取乐。"

# game/a13/6cold_castle.rpy:590
translate english cold_castle_lisa_f376df28:

    # me "Прям совсем незачем?"
    me "真的一点理由都没有吗？"

# game/a13/6cold_castle.rpy:591
translate english cold_castle_lisa_aa6ea821:

    # lisa "Ничего не чувствую тем местом, из которого выходит женская потребность хихикать и нести чушь в присутствии мужчин."
    lisa "我用来发出'吃吃傻笑和当着男人的面说胡话'这种女性需求的部位，完全没有感觉。"

# game/a13/6cold_castle.rpy:592
translate english cold_castle_lisa_dad0da23:

    # me "Простите за мое любопытство, но ничего это прямо 'ничего'?"
    me "请原谅我的好奇心，但'没有'是彻底的'毫无感觉'吗？"

# game/a13/6cold_castle.rpy:593
translate english cold_castle_lisa_bf047668:

    # lisa "Да. Вообще ничего. Могу убрать руку и проверишь."
    lisa "是的。完全没感觉。我可以把手拿开，你自己验证一下。"

# game/a13/6cold_castle.rpy:595
translate english cold_castle_lisa_2b9306d5:

    # lisa "Видишь?"
    lisa "看到了吗？"

# game/a13/6cold_castle.rpy:596
translate english cold_castle_lisa_04bda702:

    # me "Ты не сможешь подняться?"
    me "你自己起不来？"

# game/a13/6cold_castle.rpy:597
translate english cold_castle_lisa_686aa15e:

    # lisa "Разве что помогая руками."
    lisa "除非用手帮忙。"

# game/a13/6cold_castle.rpy:598
translate english cold_castle_lisa_451a1a37:

    # me "И что прям... ни боли, ни удовольствия?"
    me "那么直截了当说……既不痛，也不舒服？"

# game/a13/6cold_castle.rpy:599
translate english cold_castle_lisa_0a8265d9:

    # lisa "На юге знают значение слова 'ничего'?"
    lisa "南方人知道'毫无'这个词是什么意思吗？"

# game/a13/6cold_castle.rpy:600
translate english cold_castle_lisa_de570995:

    # me "Я не с Юга."
    me "我不是南方人。"

# game/a13/6cold_castle.rpy:601
translate english cold_castle_lisa_642a2e7e:

    # lisa "Мы на Севере. Для нас все остальные в мире на юге."
    lisa "我们是在北方。对我们来说，世界上其他所有人都在南方。"

# game/a13/6cold_castle.rpy:602
translate english cold_castle_lisa_3f1d699f:

    # me "Кроме дворфов."
    me "除了矮人。"

# game/a13/6cold_castle.rpy:603
translate english cold_castle_lisa_f06bb137:

    # lisa "Кроме дворфов."
    lisa "除了矮人。"

# game/a13/6cold_castle.rpy:604
translate english cold_castle_lisa_471c5eca:

    # me "А где кончаются.... ощущения?"
    me "那感觉的边界在哪里……？"

# game/a13/6cold_castle.rpy:606
translate english cold_castle_lisa_5bfc0ae9:

    # lisa "Здесь."
    lisa "这里。"

# game/a13/6cold_castle.rpy:607
translate english cold_castle_lisa_74841d07:

    # me "На пупке?"
    me "在肚脐上？"

# game/a13/6cold_castle.rpy:608
translate english cold_castle_lisa_3b623508:

    # lisa "Чуть ниже."
    lisa "稍微下面一点。"

# game/a13/6cold_castle.rpy:609
translate english cold_castle_lisa_1535d2fc:

    # me "И как ощущается этот переход, от неживого к живому?"
    me "这种从'无生命'到'有生命'的过渡，感觉是怎样的？"

# game/a13/6cold_castle.rpy:610
translate english cold_castle_lisa_0510a0f1:

    # lisa "Как если бы ты прибил доски себе к ступне и ходил на них. Чувствуешь что это часть тела. Она что-то весит. Но изнутри никаких ощущений."
    lisa "就像你往自己脚底钉了块木板，然后踩在上面走路。你感觉到它是身体的一部分。它有一定的重量。但内部没有任何感觉。"

# game/a13/6cold_castle.rpy:611
translate english cold_castle_lisa_f93972f6:

    # me "Можно нескромный вопрос?"
    me "可以问个冒昧的问题吗？"

# game/a13/6cold_castle.rpy:612
translate english cold_castle_lisa_cb162446:

    # lisa "Ты интересный человек, [mename]. Ты держишь меня на коленях, бесцеремонно лапаешь за живот, но пытаешься соблюдать приличия в беседе."
    lisa "你是个有趣的人，[mename]。你抱着我坐在你腿上，放肆地摸我的肚子，却又试图在谈话中保持礼貌。"

# game/a13/6cold_castle.rpy:613
translate english cold_castle_lisa_3820771a_1:

    # me "..."
    me "..."

# game/a13/6cold_castle.rpy:614
translate english cold_castle_lisa_24bc989c:

    # lisa "Задавай свой вопрос."
    lisa "问吧。"

# game/a13/6cold_castle.rpy:615
translate english cold_castle_lisa_99c3a341:

    # me "Ты контролируешь мочу?"
    me "你能控制小便吗？"

# game/a13/6cold_castle.rpy:616
translate english cold_castle_lisa_4448be9b:

    # lisa "Ну ты даешь. Контролирую. Но много воды не пью."
    lisa "你可真行。能控制。但我不多喝水。"

# game/a13/6cold_castle.rpy:617
translate english cold_castle_lisa_5ac38cf1:

    # me "Почему?"
    me "为什么？"

# game/a13/6cold_castle.rpy:618
translate english cold_castle_lisa_fbd06ac7:

    # lisa "Догадайся, умник."
    lisa "猜猜看，聪明人。"

# game/a13/6cold_castle.rpy:620
translate english cold_castle_lisa_9bf1d05f:

    # me "А что насчет других ощущений?"
    me "那其他感觉呢？"

# game/a13/6cold_castle.rpy:621
translate english cold_castle_lisa_2737dac9:

    # lisa "Какие еще 'ощущений'?"
    lisa "什么'其他感觉'？"

# game/a13/6cold_castle.rpy:622
translate english cold_castle_lisa_54015fab:

    # me "Неужели все действительно зарождается здесь?"
    me "难道一切真的都起源于这里？"

# game/a13/6cold_castle.rpy:623
translate english cold_castle_lisa_81512e93:

    # lisa "А где еще?"
    lisa "还能在哪里？"

# game/a13/6cold_castle.rpy:624
translate english cold_castle_lisa_9035c021:

    # me "В голове."
    me "在头脑里。"

# game/a13/6cold_castle.rpy:625
translate english cold_castle_lisa_612c74ba:

    # lisa "В голове? Похоть? Что ж люди не бьются лбами, когда их тянет на блуд?"
    lisa "在头脑里？情欲吗？那人们被情欲驱使时，怎么不互相撞头呢？"

# game/a13/6cold_castle.rpy:626
translate english cold_castle_lisa_d4d5a298:

    # me "Ну ты вы во всяком случае покраснела."
    me "但无论如何你脸红了。"

# game/a13/6cold_castle.rpy:627
translate english cold_castle_lisa_0d73b04a:

    # lisa "Потому что ты ведешь себя нагло."
    lisa "那是因为你行为太放肆了。"

# game/a13/6cold_castle.rpy:628
translate english cold_castle_lisa_c3eb3d15:

    # me "А. Так это гнев, стыд или...."
    me "啊。所以这是愤怒、羞耻还是……"

# game/a13/6cold_castle.rpy:629
translate english cold_castle_lisa_f3426399:

    # lisa "Достаточно экскурсий по моему телу. Встань, пожалуйста."
    lisa "对我身体的'参观'到此为止。请起来。"

# game/a13/6cold_castle.rpy:630
translate english cold_castle_lisa_d14f24c4:

    # me "Прости, если обидел. Мне правда было интересно."
    me "抱歉，如果我冒犯了你。我是真的好奇。"

# game/a13/6cold_castle.rpy:631
translate english cold_castle_lisa_4cee317a:

    # lisa "Не обидел. Просто уйди. И подай мне какую-нибудь книгу."
    lisa "没冒犯。只是请离开。帮我拿本书。"

# game/a13/6cold_castle.rpy:632
translate english cold_castle_lisa_01822020:

    # me "Ладно."
    me "好吧。"

# game/a13/6cold_castle.rpy:634
translate english cold_castle_lisa_3dc8d62d:

    # me "Интересно, таких людей как ты, можно использовать как живую библиотеку?"
    me "真有意思，像你这样的人，能不能被用作'活体图书馆'？"

# game/a13/6cold_castle.rpy:635
translate english cold_castle_lisa_440d405f:

    # lisa "Чего?"
    lisa "什么？"

# game/a13/6cold_castle.rpy:636
translate english cold_castle_lisa_5b2d1b6c:

    # me "Ну ты наверняка многое помнишь, из того, что прочитала."
    me "嗯，你肯定记得很多你读过的东西。"

# game/a13/6cold_castle.rpy:637
translate english cold_castle_lisa_a9045979:

    # lisa "Допустим и что?"
    lisa "就算是，然后呢？"

# game/a13/6cold_castle.rpy:638
translate english cold_castle_lisa_b5ce91c3:

    # me "Можно брать тебя с собой и спрашивать о чем-нибудь, если понадобится."
    me "可以带上你一起，需要时就问问你什么。"

# game/a13/6cold_castle.rpy:639
translate english cold_castle_lisa_91da0851:

    # lisa "Отличная идея."
    lisa "绝妙的主意。"

# game/a13/6cold_castle.rpy:640
translate english cold_castle_lisa_489a247d:

    # me "Правда?"
    me "真的吗？"

# game/a13/6cold_castle.rpy:641
translate english cold_castle_lisa_ceb28332:

    # lisa "Нет. Половина этих знаний противоречит друг другу, а вторая написана престарелыми кретинами. Я уж не говорю о том, что все рецепты не запомнить, а все истории либо выдуман ны, либо приукрашены."
    lisa "假的。这些知识一半相互矛盾，另一半是老糊涂的笨蛋写的。更别提药方根本记不住，所有的故事不是编造的就是添油加醋的。"

# game/a13/6cold_castle.rpy:643
translate english cold_castle_lisa_87fd71b8:

    # me "Так твои знания бесполезны?"
    me "所以你的知识是无用的？"

# game/a13/6cold_castle.rpy:644
translate english cold_castle_lisa_2e3da099:

    # lisa "Может быть."
    lisa "也许吧。"

# game/a13/6cold_castle.rpy:647
translate english cold_castle_lisa_5a846db4:

    # me "Я думаю это все от того, что ты читаешь не те книги."
    me "我觉得这都是因为你读错了书。"

# game/a13/6cold_castle.rpy:649
translate english cold_castle_lisa_440d405f_1:

    # lisa "Чего?"
    lisa "什么？"

# game/a13/6cold_castle.rpy:650
translate english cold_castle_lisa_5ab8363a:

    # me "Выбираешь некачественную литературу. Тратишь на нее свои силы и время."
    me "你选择了质量低劣的文学作品。把你的精力和时间浪费在上面了。"

# game/a13/6cold_castle.rpy:651
translate english cold_castle_lisa_83304d64:

    # lisa "Каким образом я могу знать заранее, паршивая ли будет книга?"
    lisa "我怎么能提前知道一本书是好是坏？"

# game/a13/6cold_castle.rpy:652
translate english cold_castle_lisa_a19e2cf3:

    # me "Никак."
    me "没办法。"

# game/a13/6cold_castle.rpy:653
translate english cold_castle_lisa_b134ba83:

    # lisa "Ну и в чем тогда суть претензии?"
    lisa "那你指责的意义何在？"

# game/a13/6cold_castle.rpy:654
translate english cold_castle_lisa_3ef85797:

    # me "Ты могла бы спросить у тех, кто уже эти книги читал."
    me "你可以问问那些读过这些书的人。"

# game/a13/6cold_castle.rpy:655
translate english cold_castle_lisa_fef31c05:

    # lisa "В этом замке таких людей нет."
    lisa "在这座城堡里没有这样的人。"

# game/a13/6cold_castle.rpy:656
translate english cold_castle_lisa_dee3c461:

    # me "Ну может не в этом замке."
    me "嗯，也许不在这座城堡里。"

# game/a13/6cold_castle.rpy:657
translate english cold_castle_lisa_312c736a:

    # lisa "Так случилось, что посещать другие для меня затруднительно."
    lisa "偏巧了，去别的城堡拜访对我来说很困难。"

# game/a13/6cold_castle.rpy:658
translate english cold_castle_lisa_b8880cff:

    # me "Понимаю. Но у тебя есть я."
    me "理解。但你还有我。"

# game/a13/6cold_castle.rpy:659
translate english cold_castle_lisa_4cf3cb64:

    # lisa "Ты?"
    lisa "你？"

# game/a13/6cold_castle.rpy:660
translate english cold_castle_lisa_0dd4ac53:

    # me "Да. Я. Я прочитал столько же книг, сколько и ты. А может и больше. Посоветовать тебе что-нибудь?"
    me "是的。我。我读过的书和你一样多。也许更多。要我给你推荐几本吗？"

# game/a13/6cold_castle.rpy:661
translate english cold_castle_lisa_3ac77ea7:

    # lisa "Попробуй."
    lisa "试试看。"

# game/a13/6cold_castle.rpy:663
translate english cold_castle_lisa_ede9fec5:

    # me "Гномья бухгалтерия, советы от мастеров гор."
    me "《矮人会计学:山岭大师的建议》。"

# game/a13/6cold_castle.rpy:664
translate english cold_castle_lisa_5d082c96:

    # lisa "Мгм."
    lisa "嗯。"

# game/a13/6cold_castle.rpy:665
translate english cold_castle_lisa_a2f9724d:

    # me "Полная хронология болотной войны и флора Долины Розы Палмс."
    me "《沼泽战争全史》和《帕姆斯玫瑰谷植物志》。"

# game/a13/6cold_castle.rpy:666
translate english cold_castle_lisa_7fa35a3f:

    # lisa "..."
    lisa "..."

# game/a13/6cold_castle.rpy:667
translate english cold_castle_lisa_7c3445e6:

    # me "История добычи меди на острове меди. Автора не помню."
    me "《铜岛铜矿开采史》。作者不记得了。"

# game/a13/6cold_castle.rpy:668
translate english cold_castle_lisa_c8970128:

    # lisa "Так..."
    lisa "嗯……"

# game/a13/6cold_castle.rpy:669
translate english cold_castle_lisa_59c621f2:

    # me "Подробное руководство по чистке доспехов Флина Уотерса."
    me "弗林·沃特斯的《盔甲清洁详细指南》。"

# game/a13/6cold_castle.rpy:670
translate english cold_castle_lisa_57145e0f:

    # lisa "Доспехи..."
    lisa "盔甲……"

# game/a13/6cold_castle.rpy:671
translate english cold_castle_lisa_8653f5bc:

    # me "Великий Трактат об Имперских формах и законах..."
    me "《帝国形式与法律伟大论纲》……"

# game/a13/6cold_castle.rpy:673
translate english cold_castle_lisa_8c26506a:

    # me "Ауч."
    me "哎哟。"

# game/a13/6cold_castle.rpy:674
translate english cold_castle_lisa_c2de3f37:

    # lisa "Хватит."
    lisa "够了。"

# game/a13/6cold_castle.rpy:675
translate english cold_castle_lisa_4d3626f1:

    # me "Больно!"
    me "好痛！"

# game/a13/6cold_castle.rpy:676
translate english cold_castle_lisa_866e7889:

    # lisa "Я поняла-поняла."
    lisa "我明白了明白了。"

# game/a13/6cold_castle.rpy:678
translate english cold_castle_lisa_d3084dfa:

    # lisa "Сначала думала, что ты шутишь, но потом поняла, что ты хвастаешься."
    lisa "一开始我以为你在开玩笑，但后来我明白你是在炫耀。"

# game/a13/6cold_castle.rpy:679
translate english cold_castle_lisa_d02ac46e:

    # me "Хвастаюсь?"
    me "炫耀？"

# game/a13/6cold_castle.rpy:680
translate english cold_castle_lisa_e8352bb4:

    # lisa "Ты эти книги не выдумал, а значит ты действительно читал эту чушь, как и я."
    lisa "这些书你不是编出来的，这意味着你真的读过这些垃圾，就像我一样。"

# game/a13/6cold_castle.rpy:681
translate english cold_castle_lisa_ae1c086f:

    # me "Ты тоже это читала?"
    me "这些你也都读过？"

# game/a13/6cold_castle.rpy:682
translate english cold_castle_lisa_fd837487:

    # lisa "Ну кроме доспехов."
    lisa "嗯，除了盔甲那本。"

# game/a13/6cold_castle.rpy:683
translate english cold_castle_lisa_902fc5c3:

    # me "Пробелы в знаниях. "
    me "知识空白。"

# game/a13/6cold_castle.rpy:684
translate english cold_castle_lisa_729d8e8f:

    # lisa "Обязательно поищу здесь."
    lisa "我一定在这儿找找。"

# game/a13/6cold_castle.rpy:685
translate english cold_castle_lisa_a0f0828d:

    # me "Если не найдешь я привезу тебе."
    me "如果你找不到，我给你带来。"

# game/a13/6cold_castle.rpy:686
translate english cold_castle_lisa_27827cd6:

    # lisa "Ты уж постарайся. Без тебя я так и останусь набитой дурой."
    lisa "那你得努力了。没有你，我只会一直是个自认为聪明其实无知的傻瓜。"

# game/a13/6cold_castle.rpy:687
translate english cold_castle_lisa_a667c167:

    # me "Жди меня. Я вернусь с полным трюмом этой... качественной литературы."
    me "等着我。我会带满满一船舱这种……'高质量文学'回来。"

# game/a13/6cold_castle.rpy:688
translate english cold_castle_lisa_5176ca37:

    # lisa "Ты ведь не читал Великий Трактат об имперских формах в действительности."
    lisa "你其实没有真的读过《帝国形式与法律伟大论纲》。"

# game/a13/6cold_castle.rpy:689
translate english cold_castle_lisa_512b642e:

    # me "Читал."
    me "读过。"

# game/a13/6cold_castle.rpy:690
translate english cold_castle_lisa_1af9197a:

    # lisa "Врешь."
    lisa "撒谎。"

# game/a13/6cold_castle.rpy:691
translate english cold_castle_lisa_3820771a_2:

    # me "..."
    me "..."

# game/a13/6cold_castle.rpy:692
translate english cold_castle_lisa_7fa35a3f_1:

    # lisa "..."
    lisa "..."

# game/a13/6cold_castle.rpy:693
translate english cold_castle_lisa_c9f94a92:

    # me "Использование формулировки 'своими словами'...."
    me "'用自己的话'这种说法……"

# game/a13/6cold_castle.rpy:695
translate english cold_castle_lisa_e4837ba4:

    # lisa "...строго запрещено."
    lisa "……是被严格禁止的。"

# game/a13/6cold_castle.rpy:696
translate english cold_castle_lisa_1e785529:

    # me "Да, это было перед каждым примером."
    me "没错，每个例子前都有这句话。"

# game/a13/6cold_castle.rpy:697
translate english cold_castle_lisa_035e3d6a:

    # lisa "Ты действительно читал этот бред."
    lisa "你真的读过这堆废话。"

# game/a13/6cold_castle.rpy:698
translate english cold_castle_lisa_5d22012a:

    # me "Ты тоже."
    me "你也是。"

# game/a13/6cold_castle.rpy:699
translate english cold_castle_lisa_3594629a:

    # lisa "...запрещается торговля рабами, севернее зоны установленной Имперскими столбами с печатью."
    lisa "……禁止在帝国界碑封印所划定的区域以北进行奴隶贸易。"

# game/a13/6cold_castle.rpy:700
translate english cold_castle_lisa_4b17aec0:

    # me "...запрещено возить с собой столбы, напоминающие столбы для установления разграничения между Югом и другими провинциями."
    me "……禁止携带类似划定南方与其他行省边界的柱子。"

# game/a13/6cold_castle.rpy:701
translate english cold_castle_lisa_46fca2a4:

    # lisa "...запрещено перемещать эти столбы."
    lisa "……禁止移动这些界柱。"

# game/a13/6cold_castle.rpy:702
translate english cold_castle_lisa_c9a7358f:

    # me "А что насчет казней эльфов?"
    me "那关于处决精灵的规定呢？"

# game/a13/6cold_castle.rpy:703
translate english cold_castle_lisa_c6202a88:

    # lisa "Запрещено без суда. Если только это не была самооборона."
    lisa "禁止未经审判处决。除非是自我防卫。"

# game/a13/6cold_castle.rpy:704
translate english cold_castle_lisa_2f88e503:

    # me "Нужно доказать это показаниями как минимум двух свидетелей."
    me "必须通过至少两名证人的证词来证明。"

# game/a13/6cold_castle.rpy:705
translate english cold_castle_lisa_5ce3b345:

    # lisa "Они не должны быть родственниками, подданными совершившего убийство, должниками или..."
    lisa "他们不能是行凶者的亲属、臣属、债务人或者……"

# game/a13/6cold_castle.rpy:706
translate english cold_castle_lisa_1c2d42d1:

    # me "...или эльфами."
    me "……或者精灵。"

# game/a13/6cold_castle.rpy:707
translate english cold_castle_lisa_54de9523:

    # lisa "АХхаха. Да. Хорошая все же книга."
    lisa "哈哈哈。是啊。这书其实还不错。"

# game/a13/6cold_castle.rpy:708
translate english cold_castle_lisa_0a55b4bf:

    # me "Смешная."
    me "挺逗的。"

# game/a13/6cold_castle.rpy:711
translate english cold_castle_lisa_fbe622b9:

    # me "Так может займешься чем-нибудь другим?"
    me "或者你可以试着干点别的？"

# game/a13/6cold_castle.rpy:712
translate english cold_castle_lisa_abb60ddc:

    # lisa "Например? Охота?"
    lisa "比如说？打猎吗？"

# game/a13/6cold_castle.rpy:713
translate english cold_castle_lisa_e85d73e3:

    # me "Ну... это может быть проблематичным."
    me "嗯……这可能有点困难。"

# game/a13/6cold_castle.rpy:714
translate english cold_castle_lisa_9e1145e8:

    # lisa "Да ну. Зато если зверь вцепится мне в ногу я даже не закричу."
    lisa "是啊。但如果野兽咬住我的腿，我甚至都不会尖叫。"

# game/a13/6cold_castle.rpy:715
translate english cold_castle_lisa_06f2bab9:

    # me "Может готовка?"
    me "烹饪怎么样？"

# game/a13/6cold_castle.rpy:716
translate english cold_castle_lisa_b2b976eb:

    # lisa "Готовка? Ты сейчас серьезно?"
    lisa "烹饪？你是认真的吗？"

# game/a13/6cold_castle.rpy:717
translate english cold_castle_lisa_8a0b9502:

    # me "А что?"
    me "怎么？"

# game/a13/6cold_castle.rpy:718
translate english cold_castle_lisa_506ed268:

    # lisa "По-твоему готовка интереснее, чем чтение?"
    lisa "你觉得烹饪比读书更有趣？"

# game/a13/6cold_castle.rpy:719
translate english cold_castle_lisa_87e53fa8:

    # me "Понятия не имею. Не занимался ни тем ни тем уже кучу лет."
    me "不知道。我已经好多年没干过这两件事了。"

# game/a13/6cold_castle.rpy:720
translate english cold_castle_lisa_973d1a49:

    # lisa "Ты не читаешь книги?"
    lisa "你不读书？"

# game/a13/6cold_castle.rpy:721
translate english cold_castle_lisa_7b3cbc51:

    # me "Ну... не особо."
    me "嗯……不太读。"

# game/a13/6cold_castle.rpy:722
translate english cold_castle_lisa_c5e818d9:

    # lisa "Одна книга в неделю или в год? К чему ближе?"
    lisa "一周一本还是一年一本？更接近哪个？"

# game/a13/6cold_castle.rpy:723
translate english cold_castle_lisa_91268e84:

    # me "В год."
    me "一年一本。"

# game/a13/6cold_castle.rpy:724
translate english cold_castle_lisa_7c404d28:

    # lisa "Печально."
    lisa "真可悲。"

# game/a13/6cold_castle.rpy:725
translate english cold_castle_lisa_dac948a0:

    # me "Да вроде нормально. Не испытываю особых душевных мук по этому поводу."
    me "倒觉得还行。我不会因为这个感到特别痛苦。"

# game/a13/6cold_castle.rpy:726
translate english cold_castle_lisa_b7b96590:

    # lisa "Я про твоих подданных. У них будет король, который читает по книге в год."
    lisa "我是替你的臣民感到可悲。他们将有一位一年只读一本书的国王。"

# game/a13/6cold_castle.rpy:727
translate english cold_castle_lisa_56ce70f9:

    # me "Император."
    me "是皇帝。"

# game/a13/6cold_castle.rpy:728
translate english cold_castle_lisa_2231a56e:

    # lisa "Еще лучше."
    lisa "那更好了。"

# game/a13/6cold_castle.rpy:729
translate english cold_castle_lisa_8a4ee182:

    # me "Почитаешь мне что-нибудь?"
    me "你能读点什么给我听吗？"

# game/a13/6cold_castle.rpy:730
translate english cold_castle_lisa_e84d5249:

    # lisa "А сам?"
    lisa "你自己不能读吗？"

# game/a13/6cold_castle.rpy:732
translate english cold_castle_lisa_698855fd:

    # me "Я доверюсь тебе."
    me "我信任你的选择。"

# game/a13/6cold_castle.rpy:733
translate english cold_castle_lisa_d73e7b50:

    # lisa "А ты будешь слушать?"
    lisa "你会听吗？"

# game/a13/6cold_castle.rpy:734
translate english cold_castle_lisa_c0476866:

    # me "Буду."
    me "会的。"

# game/a13/6cold_castle.rpy:735
translate english cold_castle_lisa_c29d4cdb:

    # lisa "Ладно. Тогда что-нибудь для правителя или для общего кругозора?"
    lisa "好吧。那读点对统治者有用的，还是开阔眼界的？"

# game/a13/6cold_castle.rpy:736
translate english cold_castle_lisa_3a3855e8:

    # me "Эм... а что есть для правителя?"
    me "呃……对统治者有用的是什么？"

# game/a13/6cold_castle.rpy:737
translate english cold_castle_lisa_ce6d5395:

    # lisa "Из того что ты достал с полки подходит только одна книга."
    lisa "你从书架上拿下来的书里，只有一本符合条件。"

# game/a13/6cold_castle.rpy:738
translate english cold_castle_lisa_23f5eb78:

    # me "Какая?"
    me "哪本？"

# game/a13/6cold_castle.rpy:739
translate english cold_castle_lisa_fe42a8df:

    # lisa "История дома Аран."
    lisa "《阿兰家族史》。"

# game/a13/6cold_castle.rpy:740
translate english cold_castle_lisa_9c45e563:

    # me "О. Это вассалы моего отца."
    me "哦。他们是我父亲的封臣。"

# game/a13/6cold_castle.rpy:741
translate english cold_castle_lisa_dadc35db:

    # lisa "Это все что ты о них знаешь."
    lisa "你就知道这些？"

# game/a13/6cold_castle.rpy:742
translate english cold_castle_lisa_4345c325:

    # me "Нет. Еще они делают прекрасное вино. Аранское золотое."
    me "不。他们还酿造极好的葡萄酒。阿兰黄金酒。"

# game/a13/6cold_castle.rpy:743
translate english cold_castle_lisa_d52aaa49:

    # lisa "Потрясающе. Может тут даже будет про это глава."
    lisa "太棒了。也许书里还会有一章专门讲这个。"

# game/a13/6cold_castle.rpy:745
translate english cold_castle_lisa_c5e61e12:

    # me "Наверняка будет. Это их основной доход."
    me "肯定会有。这是他们的主要收入来源。"

# game/a13/6cold_castle.rpy:746
translate english cold_castle_lisa_ae5e6d90:

    # lisa "Судя по твоим восторженным комментариям ты их основной покупатель."
    lisa "从你这热情的评论来看，你是他们的主要买家。"

# game/a13/6cold_castle.rpy:747
translate english cold_castle_lisa_62afba49:

    # me "Все верно."
    me "没错。"

# game/a13/6cold_castle.rpy:748
translate english cold_castle_lisa_4ed15b11:

    # lisa "Ладно, слушай. Основатель дома - Варриан Аран."
    lisa "好吧，听着。家族的创始人是——瓦里安·阿兰。"

# game/a13/6cold_castle.rpy:749
translate english cold_castle_lisa_7406da60:

    # me "Что-то слышал."
    me "好像听说过。"

# game/a13/6cold_castle.rpy:750
translate english cold_castle_lisa_2712520f:

    # lisa "Еще бы. Ступил на этот континент вместе с твоим предком."
    lisa "当然听说过。他和你的祖先一起踏上了这片大陆。"

# game/a13/6cold_castle.rpy:751
translate english cold_castle_lisa_6dc275dd:

    # me "С Лотриком?"
    me "和Lotric吗？"

# game/a13/6cold_castle.rpy:752
translate english cold_castle_lisa_b996ea3b:

    # lisa "С ним самым. Бился храбро. Особенно отличился в битве при Белой Роще. Пронзил копьем шесть эльфийских всадников."
    lisa "就是他。作战英勇。尤其在白林之战中表现突出。用长矛刺穿了六个精灵骑兵。"

# game/a13/6cold_castle.rpy:753
translate english cold_castle_lisa_83f8d64d:

    # me "Думаешь их и было шесть?"
    me "你觉得真的有六个那么多吗？"

# game/a13/6cold_castle.rpy:754
translate english cold_castle_lisa_8fc03b79:

    # lisa "В каком смысле?"
    lisa "什么意思？"

# game/a13/6cold_castle.rpy:755
translate english cold_castle_lisa_920af03b:

    # me "Наверняка одного уложил или двух. Остальных уже придумали позже."
    me "肯定只干掉了一两个。其他的是后来杜撰的。"

# game/a13/6cold_castle.rpy:756
translate english cold_castle_lisa_408859e8:

    # lisa "Может быть. Я просто читаю что написано."
    lisa "有可能。我只是照着书念。"

# game/a13/6cold_castle.rpy:757
translate english cold_castle_lisa_ea7b35f5:

    # me "Ладно-ладно. Давай дальше."
    me "好吧好吧。继续。"

# game/a13/6cold_castle.rpy:758
translate english cold_castle_lisa_1042af84:

    # lisa "Бился в легендарной битве на звездном поле. Взял часть звезды для наконечника своего копья."
    lisa "参加过传奇的星落原之战。取下了一部分陨星碎片用作矛尖。"

# game/a13/6cold_castle.rpy:759
translate english cold_castle_lisa_75a6e0f6:

    # me "Теперь ясно почему Лотрику хватило только на корону."
    me "现在我知道为什么Lotric只够用来做王冠了。"

# game/a13/6cold_castle.rpy:760
translate english cold_castle_lisa_6d564d1c:

    # lisa "Ты так и будешь перебивать?"
    lisa "你打算一直这样打断我吗？"

# game/a13/6cold_castle.rpy:761
translate english cold_castle_lisa_435423ea:

    # me "Прости, продолжай. Просто мне... действительно интересно."
    me "抱歉，继续。只是我……真的很感兴趣。"

# game/a13/6cold_castle.rpy:769
translate english cold_castle_away_50524f75:

    # me "Степан, проводите принцессу Еву в башню, после того, как закончите с Лизой."
    me "Stepan，送完Lisa后，把Eva公主送到塔楼去。"

# game/a13/6cold_castle.rpy:770
translate english cold_castle_away_73c3f6da:

    # stepan "Конечно."
    stepan "遵命。"

# game/a13/6cold_castle.rpy:771
translate english cold_castle_away_659d9d72:

    # eva "Но, я... мы же..."
    eva "但是，我……我们不是说好了……"

# game/a13/6cold_castle.rpy:772
translate english cold_castle_away_85d5184b:

    # me "Я бы помог, но у меня болит голова."
    me "我很想帮忙，但我头疼。"

# game/a13/6cold_castle.rpy:773
translate english cold_castle_away_61fa7176:

    # lisa "О. Ничего удивительного."
    lisa "哦。一点也不奇怪。"

# game/a13/6cold_castle.rpy:774
translate english cold_castle_away_6ef061d1:

    # eva "Голова. Ну конечно."
    eva "头疼。当然啦。"

# game/a13/6cold_castle.rpy:775
translate english cold_castle_away_7f15e2ae:

    # me "Не забудьте, что она должна быть в башне, а не в своих покоях."
    me "别忘了，她必须去塔楼，而不是她自己的房间。"

# game/a13/6cold_castle.rpy:776
translate english cold_castle_away_0fd35c09:

    # lisa "Я напомню, не волнуйтесь."
    lisa "我会提醒他的，别担心。"

# game/a13/6cold_castle.rpy:777
translate english cold_castle_away_f87e0af1:

    # eva "Я была о вас лучшего мнения."
    eva "我之前真是高估你了。"

# game/a13/6cold_castle.rpy:778
translate english cold_castle_away_b5e51e1c:

    # me "Ага. Удачи."
    me "嗯。祝你好运。"

# game/a13/6cold_castle.rpy:779
translate english cold_castle_away_ca8bb0c0:

    # lisa "И вам, принц."
    lisa "也祝您，王子殿下。"

# game/a13/6cold_castle.rpy:783
translate english cold_castle_away_80a75a49:

    # me "Ух..."
    me "呃……"

# game/a13/6cold_castle.rpy:784
translate english cold_castle_away_95b7487d:

    # aurora "Устал?"
    aurora "累了吗？"

# game/a13/6cold_castle.rpy:785
translate english cold_castle_away_ee48ac59:

    # me "Немного."
    me "有一点。"

# game/a13/6cold_castle.rpy:786
translate english cold_castle_away_9be78398:

    # aurora "От моей семьи?"
    aurora "因为我的家人？"

# game/a13/6cold_castle.rpy:787
translate english cold_castle_away_322b6407:

    # me "Что...нет."
    me "什么……不。"

# game/a13/6cold_castle.rpy:788
translate english cold_castle_away_d9f5b50c:

    # aurora "Да ладно тебе, я понимаю. Иногда они могут быть утомительными."
    aurora "得了，我理解。有时候他们确实会让人疲惫。"

# game/a13/6cold_castle.rpy:789
translate english cold_castle_away_f8ece910:

    # me "Ну раз уж ты понимаешь... то да. От твоей младшей сестры у меня болит голова."
    me "好吧，既然你明白……是的。你的妹妹让我头疼。"

# game/a13/6cold_castle.rpy:790
translate english cold_castle_away_235d0e36:

    # aurora "Ее характер сильно испортился. Боюсь жених ей необходим."
    aurora "她的性格变得很坏。恐怕她迫切需要个丈夫了。"

# game/a13/6cold_castle.rpy:791
translate english cold_castle_away_3820771a:

    # me "..."
    me "..."

# game/a13/6cold_castle.rpy:792
translate english cold_castle_away_60747eac:

    # aurora "Ну... не в этом смысле."
    aurora "呃……不是那个意思。"

# game/a13/6cold_castle.rpy:793
translate english cold_castle_away_eee819cf:

    # me "Я понял."
    me "我明白了。"

# game/a13/6cold_castle.rpy:795
translate english cold_castle_away_c558e6b1:

    # me "Я планирую продолжить свой...дипломатический вояж через пару дней."
    me "我计划过几天继续我的……外交之旅。"

# game/a13/6cold_castle.rpy:796
translate english cold_castle_away_8c07e979:

    # aurora "Понятно."
    aurora "明白了。"

# game/a13/6cold_castle.rpy:797
translate english cold_castle_away_17c5456c:

    # me "Если хочешь - можешь поехать со мной. Но лучше останься здесь."
    me "如果你想，可以跟我一起走。不过最好还是留在这里。"

# game/a13/6cold_castle.rpy:798
translate english cold_castle_away_874a145e:

    # aurora "Это будет опасно?"
    aurora "会有危险吗？"

# game/a13/6cold_castle.rpy:799
translate english cold_castle_away_eae9d4c3:

    # me "Необязательно. Но это точно будет... изматывающе."
    me "不一定。但肯定会……让人筋疲力尽。"

# game/a13/6cold_castle.rpy:800
translate english cold_castle_away_98b75e98:

    # aurora "Если только я не нужна тебе в дороге."
    aurora "除非你在路上需要我。"

# game/a13/6cold_castle.rpy:801
translate english cold_castle_away_d94bf30d:

    # me "А чем ты можешь помочь?"
    me "你能帮上什么忙？"

# game/a13/6cold_castle.rpy:802
translate english cold_castle_away_8a031035:

    # aurora "Именем."
    aurora "以我名字的名义。"

# game/a13/6cold_castle.rpy:803
translate english cold_castle_away_85b3f62e:

    # me "Лорды и так знают, что ты моя жена. Твое присутствие никак этот факт не усилит. А даже если и не знают - твой отец написал мне сопроводительную грамоту."
    me "领主们已经知道你是我的妻子。你的出现不会加强这个事实。即使他们不知道，你父亲也给我写了同行文书。"

# game/a13/6cold_castle.rpy:804
translate english cold_castle_away_04fbb480:

    # aurora "Так ты не против, если я останусь?"
    aurora "那么你不介意我留下？"

# game/a13/6cold_castle.rpy:805
translate english cold_castle_away_6d31443f:

    # me "Не вижу смысла таскать тебя всюду с собой."
    me "我看不出带着你到处跑有什么意义。"

# game/a13/6cold_castle.rpy:807
translate english cold_castle_away_e98c048a:

    # aurora "Я твоя жена."
    aurora "我是你的妻子。"

# game/a13/6cold_castle.rpy:808
translate english cold_castle_away_0584105f:

    # me "Именно поэтому я и не хочу терзать тебя долгой дорогой. Это тебе не недельная качка в личной каюте. Путь будет грязным и осенне-дождливым."
    me "正因为如此，我才不想让你受长途跋涉的苦。这可不是在私人船舱里摇晃一周那么轻松。路途会泥泞不堪，秋雨绵绵。"

# game/a13/6cold_castle.rpy:809
translate english cold_castle_away_dca42ca2:

    # aurora "Ты справишься до зимы?"
    aurora "你能在冬天前赶回来吗？"

# game/a13/6cold_castle.rpy:810
translate english cold_castle_away_c0e4d137:

    # me "Надеюсь на это. Не в моих планах задерживаться без причины, но если причина все же найдется..."
    me "希望如此。我可没计划无故耽搁，但如果真有原因……"

# game/a13/6cold_castle.rpy:811
translate english cold_castle_away_f29955b7:

    # aurora "Понимаю."
    aurora "明白了。"

# game/a13/6cold_castle.rpy:812
translate english cold_castle_away_96e4d231:

    # me "Тебе не нужно мое дозволение, чтобы вернуться. Корабли стоят в Хельвике. Один из них вернет тебя домой по первому требованию."
    me "你不需要我的允许才能回去。船就停在Helvik。其中一艘随时可以送你回家。"

# game/a13/6cold_castle.rpy:813
translate english cold_castle_away_5eab5a6e:

    # aurora "Домой... я все же дождусь тебя здесь."
    aurora "家……我还是在这里等你吧。"

# game/a13/6cold_castle.rpy:814
translate english cold_castle_away_9b2efd15:

    # me "В этом нет необходимости. Ему ты нужна гораздо больше."
    me "没必要。他更需要你。"

# game/a13/6cold_castle.rpy:815
translate english cold_castle_away_647d504b:

    # aurora "Ты правда даешь мне эту возможность?"
    aurora "你真的给我这个机会？"

# game/a13/6cold_castle.rpy:816
translate english cold_castle_away_806d8e34:

    # me "А почему нет? Ты моя жена, ты должна быть с моими детьми. Мы оказали необходимое уважение, а ты пообщалась с близкими. В твоем прибывании здесь теперь меньше необходимости чем в Золотой Столице."
    me "为什么不呢？你是我的妻子，你应该和我的孩子们在一起。我们已经表示了必要的尊重，你也和亲人们团聚了。现在你留在黄金首都的必要性已经没那么大了。"

# game/a13/6cold_castle.rpy:817
translate english cold_castle_away_179b625a:

    # aurora "Спасибо, [mename]."
    aurora "谢谢你，[mename]。"

# game/a13/6cold_castle.rpy:818
translate english cold_castle_away_f310d975:

    # me "Не надо меня за это благодарить."
    me "不必为此谢我。"

# game/a13/6cold_castle.rpy:820
translate english cold_castle_away_cdb914e8:

    # aurora "Я дождусь смены ветров. Вдруг ты успеешь."
    aurora "我会等到风向转变。说不定你能及时赶回来。"

# game/a13/6cold_castle.rpy:821
translate english cold_castle_away_82b96222:

    # me "Это вряд ли."
    me "这不太可能。"

# game/a13/6cold_castle.rpy:822
translate english cold_castle_away_ed062664:

    # aurora "И все же. Это будет достаточным уважением к тебе и твоему пути."
    aurora "即便如此。这是对你和你的旅程的充分尊重。"

# game/a13/6cold_castle.rpy:823
translate english cold_castle_away_e86af725:

    # me "Как скажешь, разве я могу спорить с решением моей красавицы-жены."
    me "就听你的吧，我怎么能反对我的美丽妻子的决定呢。"

# game/a13/6cold_castle.rpy:824
translate english cold_castle_away_fd81fa0b:

    # aurora "Красавицы?"
    aurora "美丽？"

# game/a13/6cold_castle.rpy:825
translate english cold_castle_away_b5227b1b:

    # me "Красивое белье. Ты взяла его с собой?"
    me "漂亮的内衣。你自己带来的吗？"

# game/a13/6cold_castle.rpy:826
translate english cold_castle_away_17a844cf:

    # aurora "Признаться честно - это моя мама дала мне его. Попросила портного сшить."
    aurora "说实话，这是我母亲给我的。她让裁缝做的。"

# game/a13/6cold_castle.rpy:827
translate english cold_castle_away_add5f000:

    # me "Мама?"
    me "妈妈？"

# game/a13/6cold_castle.rpy:828
translate english cold_castle_away_b46aabc1:

    # aurora "Я так понимаю ее предложение сделать больше детей было серьезным."
    aurora "我猜她想让我们多生几个孩子的提议是认真的。"

# game/a13/6cold_castle.rpy:829
translate english cold_castle_away_229e3a1d:

    # me "Похоже на то. Она говорит, что жена должна ублажать мужа как можно чаще и как можно... старательнее."
    me "看起来是这样。她说妻子应该尽可能频繁、尽可能……卖力地取悦丈夫。"

# game/a13/6cold_castle.rpy:830
translate english cold_castle_away_2374417d:

    # aurora "Мудрая женщина. Ты с ней согласна? Нужно ублажать мужа как можно чаще?"
    aurora "聪明的女人。你同意她吗？应该尽可能频繁地取悦丈夫？"

# game/a13/6cold_castle.rpy:832
translate english cold_castle_away_041c8f99:

    # aurora "Ну... если он сам хочет?"
    aurora "这个……如果他想要的话？"

# game/a13/6cold_castle.rpy:833
translate english cold_castle_away_06e38c91:

    # me "Почему же он может этого не хотеть?"
    me "他怎么会不想要呢？"

# game/a13/6cold_castle.rpy:834
translate english cold_castle_away_5fdd99a8:

    # aurora "Не знаю, а ты хочешь?"
    aurora "不知道，你想要吗？"

# game/a13/6cold_castle.rpy:835
translate english cold_castle_away_8f9071f9:

    # me "Конечно."
    me "当然。"

# game/a13/6cold_castle.rpy:836
translate english cold_castle_away_a587cb76:

    # aurora "Некоторые мужья теряют интерес к женам, когда те рождают им детей..."
    aurora "有些丈夫在妻子生下孩子后就对他们失去兴趣了……"

# game/a13/6cold_castle.rpy:837
translate english cold_castle_away_2cd334db:

    # me "Это точно не про меня."
    me "我绝对不是那种人。"

# game/a13/6cold_castle.rpy:838
translate english cold_castle_away_f9f9595c:

    # aurora "Уверен?"
    aurora "你确定吗？"

# game/a13/6cold_castle.rpy:839
translate english cold_castle_away_d7fceca4:

    # me "А ты не чувствуешь?"
    me "你感觉不到吗？"

# game/a13/6cold_castle.rpy:840
translate english cold_castle_away_bbe84473:

    # aurora "...чувствую."
    aurora "……感觉到了。"

# game/a13/6cold_castle.rpy:841
translate english cold_castle_away_88d4afd9:

    # me "Так иди ко мне."
    me "那就到我身边来。"

# game/a13/6cold_castle.rpy:843
translate english cold_castle_away_6b0d6d8f:

    # me "{i}Ее неуверенность меня поражает.{/i}"
    me "{i}她的不自信让我惊讶。{/i}"

# game/a13/6cold_castle.rpy:844
translate english cold_castle_away_6145053f:

    # me "{i}Мы год в браке и даже завели ребенка. Он все еще не уверена нравится ли мне.{/i}"
    me "{i}我们结婚一年了，甚至有了孩子。她还是不确定我喜不喜欢她。{/i}"

# game/a13/6cold_castle.rpy:845
translate english cold_castle_away_81d73d9d:

    # me "{i}...разве, что это не игра?{/i}"
    me "{i}……难道这是种游戏？{/i}"

# game/a13/6cold_castle.rpy:846
translate english cold_castle_away_755440a8:

    # me "{i}Я никогда не думал об этом с этой стороны.{/i}"
    me "{i}我从来没从这个角度想过。{/i}"

# game/a13/6cold_castle.rpy:847
translate english cold_castle_away_52b42ed8:

    # me "{i}Ее мать кажется опытной женщиной.{/i}"
    me "{i}她母亲看起来是个有经验的女人。{/i}"

# game/a13/6cold_castle.rpy:848
translate english cold_castle_away_cab05be8:

    # me "{i}Быть может это она советует вести себя так...{/i}"
    me "{i}也许就是她建议这么做的……{/i}"

# game/a13/6cold_castle.rpy:849
translate english cold_castle_away_c993f28b:

    # me "{i}Может эта слабость просто игра?{/i}"
    me "{i}也许这种柔弱只是伪装？{/i}"

# game/a13/6cold_castle.rpy:850
translate english cold_castle_away_ce977040:

    # me "{i}Мужчинам просто нравится чувствовать себя защитниками и спасителями и она дарует мне эту роль?{/i}"
    me "{i}男人喜欢感觉自己像个保护者和拯救者，她是在赐予我这个角色吗？{/i}"

# game/a13/6cold_castle.rpy:852
translate english cold_castle_away_5c76dbe7:

    # me "{i}...{/i}"
    me "{i}...{/i}"

# game/a13/6cold_castle.rpy:853
translate english cold_castle_away_2d6d819d:

    # me "{i}В нашу первую ночь она точно не притворялась.{/i}"
    me "{i}在我们新婚之夜，她肯定不是装的。{/i}"

# game/a13/6cold_castle.rpy:854
translate english cold_castle_away_39676adc:

    # me "{i}А сейчас?{/i}"
    me "{i}那现在呢？{/i}"

# game/a13/6cold_castle.rpy:855
translate english cold_castle_away_d544f76d:

    # me "{i}Это белье она надела явно не для сна.{/i}"
    me "{i}她穿这身内衣显然不是为了睡觉。{/i}"

# game/a13/6cold_castle.rpy:856
translate english cold_castle_away_db9d8a08:

    # me "{i}Так может я прав? Она просто играет в кроткую и скромную жену?{/i}"
    me "{i}也许我是对的？她只是在扮演一个温顺谦逊的妻子？{/i}"

# game/a13/6cold_castle.rpy:857
translate english cold_castle_away_8d996427:

    # me "{i}Хотя как мне узнать? Как понять это воспитание или игра?{/i}"
    me "{i}但我怎么才能知道？怎么区分这是教养还是演戏？{/i}"

# game/a13/6cold_castle.rpy:858
translate english cold_castle_away_8fc8dc35:

    # me "{i}Хотя нет, нет... я схожу с ума.{/i}"
    me "{i}不对，不对……我疯了。{/i}"

# game/a13/6cold_castle.rpy:859
translate english cold_castle_away_89df14d8:

    # me "{i}Никто в здравом уме не стал играть бы так долго и держаться в роли, даже если я жажду иного.{/i}"
    me "{i}神志正常的人不会演这么久还保持角色，即使我渴望不一样的东西。{/i}"

# game/a13/6cold_castle.rpy:861
translate english cold_castle_away_8d4a6d08:

    # aurora "О чем думаешь?"
    aurora "在想什么？"

# game/a13/6cold_castle.rpy:862
translate english cold_castle_away_5006fdce:

    # me "О ком."
    me "想谁。"

# game/a13/6cold_castle.rpy:863
translate english cold_castle_away_fac5e64e:

    # aurora "О ком думаешь?"
    aurora "在想谁？"

# game/a13/6cold_castle.rpy:864
translate english cold_castle_away_1705924a:

    # me "О твоей матери."
    me "在想你的母亲。"

# game/a13/6cold_castle.rpy:865
translate english cold_castle_away_b78a3b18:

    # aurora "[mename]?"
    aurora "[mename]?"

# game/a13/6cold_castle.rpy:866
translate english cold_castle_away_da40e839:

    # me "Не в этом смысле. Просто думал, насколько ее советы глубоко уходят корнями в твое поведение."
    me "不是那个意思。我只是在想，她的建议对你行为的影响有多么根深蒂固。"

# game/a13/6cold_castle.rpy:868
translate english cold_castle_away_22b591b2:

    # aurora "Настолько глубоко, насколько это возможно."
    aurora "要多深有多深。"

# game/a13/6cold_castle.rpy:869
translate english cold_castle_away_489a247d:

    # me "Правда?"
    me "真的？"

# game/a13/6cold_castle.rpy:870
translate english cold_castle_away_0dcaab62:

    # aurora "Конечно. А как ты думал? О таком не пишут книг. Есть конечно те, что рассказывают о том что должно, но нет тех, что рассказывают о том как будет на самом деле."
    aurora "当然。不然你以为呢？这种事没有书教你。当然，有些书会告诉你应该怎样，但没有书告诉你实际上会是怎样。"

# game/a13/6cold_castle.rpy:871
translate english cold_castle_away_3820771a_1:

    # me "..."
    me "..."

# game/a13/6cold_castle.rpy:872
translate english cold_castle_away_b8725b6e:

    # aurora "А моя мать в браке больше, чем я живу на свете. Я доверяю ее опыту."
    aurora "而我母亲的婚龄比我活的年头都长。我相信她的经验。"

# game/a13/6cold_castle.rpy:873
translate english cold_castle_away_d1fa3f50:

    # me "И многое она тебе рассказывала?"
    me "她跟你说了很多吗？"

# game/a13/6cold_castle.rpy:874
translate english cold_castle_away_6d9c832d:

    # aurora "Многое. В конце концов это ее обязанность."
    aurora "很多。毕竟这是她的责任。"

# game/a13/6cold_castle.rpy:875
translate english cold_castle_away_8859d175:

    # me "Мой отец со мной никогда не говорил на эту тему."
    me "我父亲从未和我谈过这个话题。"

# game/a13/6cold_castle.rpy:876
translate english cold_castle_away_607c7391:

    # aurora "Благородные мужчины не нуждаются в советах, их опыт начинается задолго до свадьбы."
    aurora "高贵的男人不需要建议，他们的经验早在婚礼前就开始了。"

# game/a13/6cold_castle.rpy:877
translate english cold_castle_away_c97fadc0:

    # me "Ну..."
    me "呃……"

# game/a13/6cold_castle.rpy:878
translate english cold_castle_away_050a53ac:

    # aurora "Можешь не отрицать. Я знаю, что я не первая девушка, что ты познал."
    aurora "不用否认。我知道我不是你认识的第一个女孩。"

# game/a13/6cold_castle.rpy:879
translate english cold_castle_away_3820771a_2:

    # me "..."
    me "..."

# game/a13/6cold_castle.rpy:880
translate english cold_castle_away_11fe778a:

    # aurora "У благородных девушек такого опыта быть не может. Значит премудростями с ними делиться должны их матери."
    aurora "高贵的女孩不可能有这样的经验。所以这方面的智慧必须由她们的母亲传授。"

# game/a13/6cold_castle.rpy:881
translate english cold_castle_away_68acc0ee:

    # me "И о чем последнем вы говорили? Об этом белье?"
    me "那你们最后谈的是什么？关于这件内衣？"

# game/a13/6cold_castle.rpy:883
translate english cold_castle_away_5d3c485f:

    # aurora "Может быть. Нравится?"
    aurora "也许吧。喜欢吗？"

# game/a13/6cold_castle.rpy:884
translate english cold_castle_away_1c922167:

    # me "Нравится."
    me "喜欢。"

# game/a13/6cold_castle.rpy:885
translate english cold_castle_away_c7dbf634:

    # aurora "В таком случае советы хорошие, не находишь?"
    aurora "这样的话，这建议不错，你不觉得吗？"

# game/a13/6cold_castle.rpy:886
translate english cold_castle_away_f7eb52bc:

    # me "Пожалуй."
    me "或许吧。"

# game/a13/6cold_castle.rpy:887
translate english cold_castle_away_bdabd545:

    # aurora "Могу я попросить кое о чем?"
    aurora "我能请求一件事吗？"

# game/a13/6cold_castle.rpy:888
translate english cold_castle_away_8f9071f9_1:

    # me "Конечно."
    me "当然。"

# game/a13/6cold_castle.rpy:889
translate english cold_castle_away_cb18d230:

    # aurora "Можем не говорить о наших родителях, пока занимаемся любовью?"
    aurora "我们在亲热的时候，能不能别谈我们的父母了？"

# game/a13/6cold_castle.rpy:890
translate english cold_castle_away_6572953e:

    # me "Разумеется. Прости. Просто действительно стало любопытно."
    me "当然。对不起。只是真的有点好奇。"

# game/a13/6cold_castle.rpy:891
translate english cold_castle_away_f29955b7_1:

    # aurora "Понимаю."
    aurora "理解。"

# game/a13/6cold_castle.rpy:894
translate english cold_castle_away_489998a1:

    # me "Что ты делаешь?"
    me "你在做什么？"

# game/a13/6cold_castle.rpy:895
translate english cold_castle_away_5d9bc142:

    # aurora "Не знаю. Мне прекратить?"
    aurora "不知道。要我停下吗？"

# game/a13/6cold_castle.rpy:896
translate english cold_castle_away_0f44b538:

    # me "Ни в коем случае."
    me "千万别。"

# game/a13/6cold_castle.rpy:897
translate english cold_castle_away_76de37ae:

    # aurora "Нравится?"
    aurora "喜欢吗？"

# game/a13/6cold_castle.rpy:898
translate english cold_castle_away_c97fadc0_1:

    # me "Ну..."
    me "呃……"

# game/a13/6cold_castle.rpy:900
translate english cold_castle_away_b6da4f86:

    # aurora "А вот так?"
    aurora "那这样呢？"

# game/a13/6cold_castle.rpy:901
translate english cold_castle_away_d02570dc:

    # me "Это что-то новенькое."
    me "这还真新鲜。"

# game/a13/6cold_castle.rpy:902
translate english cold_castle_away_2b71bc54:

    # aurora "..."
    aurora "..."

# game/a13/6cold_castle.rpy:903
translate english cold_castle_away_870171d0:

    # me "Я обязан спросить..."
    me "我必须问一下……"

# game/a13/6cold_castle.rpy:904
translate english cold_castle_away_0131985d:

    # aurora "Нет, это не мама мне посоветовала."
    aurora "不，这不是妈妈教我的。"

# game/a13/6cold_castle.rpy:905
translate english cold_castle_away_12ac55f5:

    # me "...тогда кто?"
    me "……那是谁教的？"

# game/a13/6cold_castle.rpy:906
translate english cold_castle_away_1fa1261c:

    # aurora "Прочитала в книге."
    aurora "在书里读到的。"

# game/a13/6cold_castle.rpy:907
translate english cold_castle_away_317ea190:

    # me "Ты сказала таких книг нет."
    me "你说过没有这种书。"

# game/a13/6cold_castle.rpy:908
translate english cold_castle_away_c22e6df9:

    # aurora "Это книга не об отношениях. А... ну ты понимаешь..."
    aurora "这不是关于两性关系的书。是……嗯，你懂的……"

# game/a13/6cold_castle.rpy:909
translate english cold_castle_away_b8b88d2d:

    # me "Не совсем."
    me "不太懂。"

# game/a13/6cold_castle.rpy:910
translate english cold_castle_away_54193f7b:

    # aurora "Любовный роман. Один из тех, для которых существуют закрытые полки в библиотеках."
    aurora "爱情小说。那种图书馆里有封闭书架的书。"

# game/a13/6cold_castle.rpy:911
translate english cold_castle_away_a2c8b41e:

    # me "Так мне благодарить Лизу?"
    me "那我得感谢Lisa了？"

