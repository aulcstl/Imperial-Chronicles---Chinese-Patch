# game/a13/7recure.rpy:759
translate english recure2_a56afc87:

    # cath "Приобретать друзей иногда выгодней, чем землю на которой они живут. Однажды вы это поймете, хотя думаю уже поняли."
    cath "结交朋友，有时比他们居住的土地更有利可图。总有一天您会明白的，但我想您现在已经懂了。"

# game/a13/7recure.rpy:760
translate english recure2_33fa92b0:

    # me "До встречи, леди Катерина."
    me "再见，Katerina夫人。"

# game/a13/7recure.rpy:761
translate english recure2_90185341:

    # cath "До встречи, [mename]."
    cath "再见，[mename]。"

# game/a13/7recure.rpy:765
translate english recure2_c9228cba_1:

    # me "Ну... вообще-то подобные просьбы предполагают услугу."
    me "嗯...一般来说，提出这种请求是意味着要回报的。"

# game/a13/7recure.rpy:766
translate english recure2_ddbe28af:

    # cath "Бартер..."
    cath "交易..."

# game/a13/7recure.rpy:767
translate english recure2_38c39b7c:

    # me "Вроде того."
    me "差不多吧。"

# game/a13/7recure.rpy:769
translate english recure2_e1c00fe1:

    # cath "Я так и думала. Похоже вы скорее человек рынка, а не человек чести."
    cath "我想也是。看来您更像是个商人，而不是什么有荣誉感的人。"

# game/a13/7recure.rpy:770
translate english recure2_8e2d023f:

    # me "Это так ужасно?"
    me "这很糟糕吗？"

# game/a13/7recure.rpy:771
translate english recure2_87f1258b:

    # cath "Вообще-то да."
    cath "说实话，是的。"

# game/a13/7recure.rpy:772
translate english recure2_3e2a9871:

    # me "Ну что же. Вы сами с этого начали."
    me "那好吧。这可是您先开的头。"

# game/a13/7recure.rpy:773
translate english recure2_d3c37d19:

    # cath "Я?"
    cath "我？"

# game/a13/7recure.rpy:774
translate english recure2_b413aaa3:

    # me "Вы решили узнать цену моей чести. Сами решайте высока она или нет."
    me "是您决定要给我的荣誉估价。您自己判断它高还是不高吧。"

# game/a13/7recure.rpy:775
translate english recure2_dd2d1d95_4:

    # cath "..."
    cath "..."

# game/a13/7recure.rpy:776
translate english recure2_3820771a_6:

    # me "..."
    me "..."

# game/a13/7recure.rpy:777
translate english recure2_fef2fa0f:

    # cath "И чего вы хотите? Сразу говорю, я не стану вредить моему мужу или моей семье."
    cath "那您想要什么？我先说好，我不会做损害我丈夫或家族的事。"

# game/a13/7recure.rpy:778
translate english recure2_32dd3bdb:

    # me "Я ничего такого и не требовал."
    me "我根本没要求那种东西。"

# game/a13/7recure.rpy:779
translate english recure2_abefb07d:

    # cath "Так... что же вам нужно?"
    cath "那...您到底想要什么？"

# game/a13/7recure.rpy:780
translate english recure2_aebb8859:

    # me "Ничего такого. Мы же на рынке. Вы покупаете мою услугу и я теперь вам что-то должен. Когда вы убедитесь, что услуга вас... удовлетворяет я просто хочу услугу взамен."
    me "没什么大不了的。我们既然是在做交易。您购买我的服务，那我现在欠您了。等您确信，我的服务...令您满意后，我只想要一个回报的服务。"

# game/a13/7recure.rpy:781
translate english recure2_ad435328:

    # cath "Вы хотите чтобы я была вам должна."
    cath "您是想让我欠您一个人情。"

# game/a13/7recure.rpy:782
translate english recure2_443048ff:

    # me "Это так много?"
    me "这要求过分吗？"

# game/a13/7recure.rpy:783
translate english recure2_7e958d63:

    # cath "Это... я могу себе позволить. И все же..."
    cath "这...我还能接受。不过..."

# game/a13/7recure.rpy:784
translate english recure2_108be4eb:

    # me "Помню-помню. Дополнительные условия. Не волнуйтесь, леди Катерина. Чтобы я не попросил - ваша семья, ваш муж и даже его положение не пострадают."
    me "我记得，我记得。附加条件。别担心，Katerina夫人。无论我求什么——您的家族、您的丈夫、甚至他的地位，都不会受到伤害。"

# game/a13/7recure.rpy:785
translate english recure2_dd2d1d95_5:

    # cath "..."
    cath "..."

# game/a13/7recure.rpy:786
translate english recure2_3aad8b66:

    # me "Мы договорились?"
    me "那我们说定了？"

# game/a13/7recure.rpy:787
translate english recure2_34444dd8:

    # cath "Договорились. Удачи вас в завтрашней дороге, [mename]."
    cath "说定了。祝您明天的旅途顺利，[mename]。"

# game/a13/7recure.rpy:788
translate english recure2_3066598f:

    # me "Спасибо."
    me "谢谢。"

# game/a13/7recure.rpy:792
translate english recure2_b7344260_3:

    # me "Вы меня с кем-то спутали. Я бы никогда ничего подобного не сделал."
    me "您把我和谁搞混了。我绝对做不出那种事。"

# game/a13/7recure.rpy:793
translate english recure2_d12ef797_3:

    # cath "Простите... я..."
    cath "对不起...我..."

# game/a13/7recure.rpy:794
translate english recure2_cc9cc335:

    # me "Но я понимаю ваше беспокойство. Я конечно-же не слепой."
    me "但我理解您的担忧。我当然不是瞎子。"

# game/a13/7recure.rpy:795
translate english recure2_4e3df824_3:

    # me "И раз уж вы объяснили мне причины ее поведения - я конечно же дам обещание не пользоваться этой ситуацией."
    me "既然您向我解释了她行为的原因，我当然会保证，不利用这种情况。"

# game/a13/7recure.rpy:796
translate english recure2_01049091_3:

    # cath "Спасибо, [mename], вы не представляете как облегчили мои переживания."
    cath "谢谢您，[mename]，您无法想象这让我心里的一块大石头落了地。"

# game/a13/7recure.rpy:797
translate english recure2_98a16e12_3:

    # me "Я бы никогда..."
    me "我绝不会..."

# game/a13/7recure.rpy:798
translate english recure2_0f2f680d_3:

    # cath "Простите. Конечно. Я не должна была сомневаться в вашей добродетели. Но..."
    cath "对不起。当然。我不该怀疑您的德行。但是..."

# game/a13/7recure.rpy:799
translate english recure2_d880fb2a_2:

    # me "Но вы мать."
    me "但您是一个母亲。"

# game/a13/7recure.rpy:800
translate english recure2_2bb5cf20_3:

    # cath "Да."
    cath "是的。"

# game/a13/7recure.rpy:801
translate english recure2_ad4e9c95_2:

    # me "Я вас понимаю."
    me "我理解您。"

# game/a13/7recure.rpy:802
translate english recure2_dd2d1d95_6:

    # cath "..."
    cath "..."

# game/a13/7recure.rpy:804
translate english recure2_63851221_1:

    # me "Я поговорю с ней."
    me "我会和她谈谈。"

# game/a13/7recure.rpy:805
translate english recure2_873f6dde_1:

    # cath "[mename]..."
    cath "[mename]..."

# game/a13/7recure.rpy:806
translate english recure2_4699106d_1:

    # me "Нужно осадить ее. Сказать, чтобы даже не думала, что между нами что-то возможно."
    me "得让她收敛点。告诉她别痴心妄想我们之间会有什么可能。"

# game/a13/7recure.rpy:807
translate english recure2_44056ed8_1:

    # cath "Вы уверены?"
    cath "您确定要这么做？"

# game/a13/7recure.rpy:808
translate english recure2_777ee1f7_1:

    # me "Да. Лучше сделать это сейчас."
    me "对。最好现在就做。"

# game/a13/7recure.rpy:809
translate english recure2_fb2aea4c_1:

    # cath "Наверное вы правы. Спасибо."
    cath "也许您是对的。谢谢。"

# game/a13/7recure.rpy:810
translate english recure2_6c33ecd1:

    # me "Где ее искать?"
    me "上哪儿找她？"

# game/a13/7recure.rpy:811
translate english recure2_2c5b82fb:

    # cath "Она в восточной башне."
    cath "她在东塔。"

# game/a13/7recure.rpy:812
translate english recure2_74b56832:

    # me "Не волнуйтесь. Я охлажу ее пыл."
    me "别担心。我会泼醒她的。"

# game/a13/7recure.rpy:813
translate english recure2_f785af30:

    # cath "Спасибо..."
    cath "谢谢..."

# game/a13/7recure.rpy:819
translate english recure_eva2_49b4291c:

    # me "Эдрик, леди Катерина проводит тебя до твоих покоев."
    me "埃德里克，Katerina夫人会送你去你的房间。"

# game/a13/7recure.rpy:820
translate english recure_eva2_ff01f4c7:

    # eva "А мы еще не пообщались, как следует, да, Эдрик?"
    eva "我们还没好好聊聊呢，对吧，埃德里克？"

# game/a13/7recure.rpy:821
translate english recure_eva2_8a5a232e:

    # edric "Да. Мы только нашли общий язык."
    edric "是啊。我们才刚找到共同语言。"

# game/a13/7recure.rpy:822
translate english recure_eva2_14341519:

    # me "Леди Катерина хочет с тобой кое-что обсудить."
    me "Katerina夫人想跟你谈点事。"

# game/a13/7recure.rpy:823
translate english recure_eva2_b94890a7:

    # eva "Что это?"
    eva "什么事？"

# game/a13/7recure.rpy:824
translate english recure_eva2_c7c85f55:

    # me "Тебя это не касается."
    me "这不关你事。"

# game/a13/7recure.rpy:825
translate english recure_eva2_d54a0ce0:

    # eva "Осторожнее с выражениями, мой муж из рыцарского дома."
    eva "注意你的措辞，我的未婚夫可是骑士家族出身。"

# game/a13/7recure.rpy:826
translate english recure_eva2_7f1c3f40:

    # me "Он еще не твой муж."
    me "他还不是你丈夫。"

# game/a13/7recure.rpy:827
translate english recure_eva2_bc98aa6d:

    # eva "Скоро будет, да, Эдрик?"
    eva "很快就走了，对吧，埃德里克？"

# game/a13/7recure.rpy:828
translate english recure_eva2_28e7f011:

    # edric "Ну да..."
    edric "呃...是的..."

# game/a13/7recure.rpy:829
translate english recure_eva2_c7f2c491:

    # me "Эдрик, тебе пора."
    me "埃德里克，你该走了。"

# game/a13/7recure.rpy:830
translate english recure_eva2_4677cf92:

    # eva "Эдрик, сиди."
    eva "埃德里克，坐好。"

# game/a13/7recure.rpy:831
translate english recure_eva2_3d6d4531:

    # edric "Эм...я..."
    edric "呃...我..."

# game/a13/7recure.rpy:832
translate english recure_eva2_8a4226e2:

    # me "Эдрик, твой дом не просто так называется рыцарским, верно? Было бы странно, если бы его представитель ослушался своего монарха."
    me "埃德里克，你的家族之所以叫骑士家族，不是没原因的吧？如果它的代表违抗了自己的君主，那就太奇怪了。"

# game/a13/7recure.rpy:833
translate english recure_eva2_3af2bb6e:

    # eva "А ты принц, а не Император."
    eva "你只是个王子，又不是皇帝。"

# game/a13/7recure.rpy:834
translate english recure_eva2_cb039e46:

    # me "Эдрик."
    me "埃德里克。"

# game/a13/7recure.rpy:835
translate english recure_eva2_66aab5b9:

    # eva "Эдрик, не вздумай."
    eva "埃德里克，千万别动。"

# game/a13/7recure.rpy:836
translate english recure_eva2_734feeca:

    # edric "Мне...мне пора Ева. Встретимся за ужином, да?"
    edric "我...我该走了，Eva。晚饭时见，好吗？"

# game/a13/7recure.rpy:837
translate english recure_eva2_910e42b7:

    # eva "Иди уже, рыцарь тоже мне."
    eva "快走吧，就你也配叫骑士。"

# game/a13/7recure.rpy:838
translate english recure_eva2_90a1801c:

    # eva "И ты тоже проваливай."
    eva "你也给我滚。"

# game/a13/7recure.rpy:841
translate english recure_eva2_fc7d3a18:

    # "Пару минут спустя."
    "几分钟以后。"

# game/a13/7recure.rpy:842
translate english recure_eva2_08179a6a:

    # me "Вот ты где."
    me "原来你在这儿。"

# game/a13/7recure.rpy:843
translate english recure_eva2_aa4dc86f:

    # eva "Пришел подчищать следы?"
    eva "来销毁证据吗？"

# game/a13/7recure.rpy:844
translate english recure_eva2_dfa39bbc:

    # me "Смешно. А ты что здесь делаешь?"
    me "真好笑。你在这儿做什么？"

# game/a13/7recure.rpy:845
translate english recure_eva2_c2d98b77:

    # eva "Да так... тебе какая разница?"
    eva "没什么...关你什么事？"

# game/a13/7recure.rpy:846
translate english recure_eva2_3820771a:

    # me "..."
    me "..."

# game/a13/7recure.rpy:847
translate english recure_eva2_0154ade9:

    # eva "...ну?"
    eva "...然后呢？"

# game/a13/7recure.rpy:848
translate english recure_eva2_7578f46d:

    # me "Мне уйти?"
    me "要我走吗？"

# game/a13/7recure.rpy:849
translate english recure_eva2_9ac3c607:

    # eva "Я тобой не командую. Делай что хочешь."
    eva "我又没命令你。想做什么随你便。"

# game/a13/7recure.rpy:850
translate english recure_eva2_2ec41e21:

    # me "А ты чего хочешь?"
    me "那你想做什么？"

# game/a13/7recure.rpy:851
translate english recure_eva2_0248c525:

    # eva "Повторяю - какая тебе разница?"
    eva "再说一遍——关你什么事？"

# game/a13/7recure.rpy:852
translate english recure_eva2_bc226766:

    # me "Грубо."
    me "真粗鲁。"

# game/a13/7recure.rpy:853
translate english recure_eva2_ae59190c:

    # eva "Общаюсь с людьми так, как они того заслуживают."
    eva "别人怎么对我，我就怎么对别人。"

# game/a13/7recure.rpy:854
translate english recure_eva2_03221c22:

    # me "А когда они с тобой так?"
    me "那别人也这么对你的时候呢？"

# game/a13/7recure.rpy:855
translate english recure_eva2_0c2444d4:

    # eva "Ты чего пришел?"
    eva "你来干什么？"

# game/a13/7recure.rpy:856
translate english recure_eva2_403fcd3b:

    # me "Да так..."
    me "没什么..."

# game/a13/7recure.rpy:857
translate english recure_eva2_c1e0bd90:

    # eva "Знаешь я передумала, я хочу тобой командовать - проваливай."
    eva "知道吗，我改主意了，我现在很想命令你——给我滚。"

# game/a13/7recure.rpy:858
translate english recure_eva2_0fa7e23d:

    # me "Как скажешь."
    me "随你怎么说。"

# game/a13/7recure.rpy:860
translate english recure_eva2_7fc81cf7:

    # eva "Стой. Куда ты?"
    eva "站住。你去哪儿？"

# game/a13/7recure.rpy:861
translate english recure_eva2_3ba7b3eb:

    # me "Ухожу."
    me "离开。"

# game/a13/7recure.rpy:862
translate english recure_eva2_65c948e5:

    # eva "Куда?"
    eva "去哪儿？"

# game/a13/7recure.rpy:863
translate english recure_eva2_6dd878b4:

    # me "Куда угодно отсюда. Ты сама мне сказала."
    me "除了这儿，哪儿都行。是你让我走的。"

# game/a13/7recure.rpy:864
translate english recure_eva2_8f0a5eff:

    # eva "Я же пошутила, идиот."
    eva "我开玩笑的，白痴。"

# game/a13/7recure.rpy:865
translate english recure_eva2_287fc2da:

    # me "Пошутила..."
    me "开玩笑..."

# game/a13/7recure.rpy:866
translate english recure_eva2_164769e1:

    # eva "Ну да. Пошутила. Ты шуток не понимаешь?"
    eva "对啊。开玩笑。你听不出玩笑话吗？"

# game/a13/7recure.rpy:867
translate english recure_eva2_e5f36ec9:

    # me "Понимаю. Смешная была шутка с картиной."
    me "听得出来。那幅画的玩笑就很好笑。"

# game/a13/7recure.rpy:868
translate english recure_eva2_ac27bfd9:

    # eva "Вот. Видишь?"
    eva "看吧。这不就懂了吗？"

# game/a13/7recure.rpy:869
translate english recure_eva2_eb4bf4b0:

    # me "И с одеждой забавная."
    me "还有那件衣服的玩笑也挺有趣。"

# game/a13/7recure.rpy:870
translate english recure_eva2_f556b95c:

    # eva "С картиной все-таки получше. Одежда слишком хорошо тебе подошла."
    eva "那幅画还是更棒。衣服对你来说太合身了。"

# game/a13/7recure.rpy:871
translate english recure_eva2_272b9a65:

    # me "Ну и конечно же сказать, что все это придумала твоя мать. Это действительно уморительно."
    me "然后当然，再说这一切都是你母亲出的主意。那真是太好笑了。"

# game/a13/7recure.rpy:872
translate english recure_eva2_f4e78ce8:

    # eva "Знаешь, ты, как и любой типичный южанин, очень тупоголовый, но я рада, что ты все-таки рассмотрел мой талант, хотя бы через время."
    eva "知道吗，你就像所有典型的南方人一样，脑袋里全是浆糊，但我很高兴，你最终还是识破了我的才华，虽然过了一阵子。"

# game/a13/7recure.rpy:873
translate english recure_eva2_44456ade:

    # me "И убийство собаки было смешным."
    me "杀狗的玩笑也很好笑。"

# game/a13/7recure.rpy:875
translate english recure_eva2_42f6ad5f:

    # eva "Никакую собаку я не убивала."
    eva "我可没杀什么狗。"

# game/a13/7recure.rpy:876
translate english recure_eva2_7a0be8e7:

    # me "А кто убил? Неведомый бог?"
    me "那是谁杀的？无名之神吗？"

# game/a13/7recure.rpy:877
translate english recure_eva2_ff4236ea:

    # eva "А что? Нужно же ему хоть чем-то заниматься."
    eva "怎么啦？他总得找点事做吧。"

# game/a13/7recure.rpy:878
translate english recure_eva2_ee9b15b2:

    # me "А мне кажется, что это ты собаку убила."
    me "我倒觉得是你杀了那条狗。"

# game/a13/7recure.rpy:879
translate english recure_eva2_4980c518:

    # eva "Тебе кажется."
    eva "那是你觉得。"

# game/a13/7recure.rpy:880
translate english recure_eva2_3ee4f18c:

    # me "Тебя взбесило, что Влад специально промазал и ты решила ему отомстить."
    me "Vlad故意射偏，让你暴跳如雷，所以你决定报复他。"

# game/a13/7recure.rpy:881
translate english recure_eva2_30312bd5:

    # eva "Ооо, так теперь ты признаешь, что он специально промазал."
    eva "哦——，现在你倒承认他是故意射偏的了。"

# game/a13/7recure.rpy:882
translate english recure_eva2_ff5c0f7e:

    # me "И это был повод убить его собаку?"
    me "这就成了你杀他狗的理由？"

# game/a13/7recure.rpy:883
translate english recure_eva2_9bf848e9:

    # eva "Я этого не делала."
    eva "我没那么做。"

# game/a13/7recure.rpy:884
translate english recure_eva2_46909844:

    # me "А ночью ты писать вставала."
    me "而且你夜里还起来上厕所了。"

# game/a13/7recure.rpy:885
translate english recure_eva2_3f03e150:

    # eva "Ага. Молока напилась вечером."
    eva "对。晚上牛奶喝多了。"

# game/a13/7recure.rpy:886
translate english recure_eva2_1c8c5c2b:

    # me "И ведь догадалась засунуть черноплод в мясо. Не побрезговала, все ради того, чтобы убить собаку."
    me "还真想得到把黑果塞进肉里。也不嫌脏，就为了弄死条狗。"

# game/a13/7recure.rpy:887
translate english recure_eva2_3d30184d:

    # eva "Не понимаю о чем ты."
    eva "不知道你在说什么。"

# game/a13/7recure.rpy:888
translate english recure_eva2_563f026b:

    # me "А служанку ты зачем убила? Она же никому ничего не говорила."
    me "那你为什么杀了那个女仆？她可没告诉任何人。"

# game/a13/7recure.rpy:890
translate english recure_eva2_d983e8aa:

    # eva "Я ее не убивала?"
    eva "我没杀她。"

# game/a13/7recure.rpy:891
translate english recure_eva2_69646d86:

    # me "Ну да. Конечно."
    me "嗯对。当然了。"

# game/a13/7recure.rpy:892
translate english recure_eva2_8627c68e:

    # eva "Придурок, я под замком сидела все это время."
    eva "大白痴，那段时间我一直被关着。"

# game/a13/7recure.rpy:893
translate english recure_eva2_a653e38f:

    # me "И кто это может подтвердить?"
    me "谁能证明？"

# game/a13/7recure.rpy:894
translate english recure_eva2_63cc992f:

    # eva "Ната."
    eva "娜塔。"

# game/a13/7recure.rpy:895
translate english recure_eva2_c5e491dc:

    # me "Ната... ну да."
    me "娜塔...嗯，是啊。"

# game/a13/7recure.rpy:896
translate english recure_eva2_4450f2ae:

    # eva "Что? Она убивает вместе со мной? Мы злобная команда убийц?"
    eva "怎么？她跟我合谋杀的吗？我们是邪恶杀人小队？"

# game/a13/7recure.rpy:897
translate english recure_eva2_08a7d595:

    # me "Зачем ты пытаешься меня обмануть? Я же знаю правду."
    me "你为什么还想骗我？我知道真相。"

# game/a13/7recure.rpy:898
translate english recure_eva2_31df1fd2:

    # eva "Какую правду, кретин? Я ее не убивала."
    eva "什么真相，蠢货？我没杀她。"

# game/a13/7recure.rpy:899
translate english recure_eva2_45fa44d0:

    # me "И кто же ее убил?"
    me "那谁杀的？"

# game/a13/7recure.rpy:900
translate english recure_eva2_330e9457:

    # eva "Понятия не имею. Может она сама упала."
    eva "完全没头绪。也许她自己摔下去的。"

# game/a13/7recure.rpy:901
translate english recure_eva2_ea97f834:

    # me "Ага... служанка, что видела наш поцелуй просто взяла и чудесным образом упала с башни."
    me "是啊...一个撞见我们接吻的女仆，就这么凭空自己从塔上摔下去了。"

# game/a13/7recure.rpy:902
translate english recure_eva2_93cd2016:

    # eva "Совпадение. Такое бывает."
    eva "巧合。这种事常有。"

# game/a13/7recure.rpy:903
translate english recure_eva2_a8e1f4af:

    # me "Ты звучишь неубедительно."
    me "你的话一点说服力都没有。"

# game/a13/7recure.rpy:904
translate english recure_eva2_0d46267c:

    # eva "А мне и не надо тебя убежать. Я знаю, что я ее не убивала..."
    eva "我也不需要说服你。我知道我没杀她..."

# game/a13/7recure.rpy:907
translate english recure_eva2_e0b287f8:

    # me "Заткнись."
    me "闭嘴。"

# game/a13/7recure.rpy:908
translate english recure_eva2_1a3334f6:

    # eva "Ты...чего ты..."
    eva "你...你干什么..."

# game/a13/7recure.rpy:909
translate english recure_eva2_04d78874:

    # me "Закрой свою пасть. Я больше не могу это слушать."
    me "闭上你的臭嘴。我再也听不下去了。"

# game/a13/7recure.rpy:910
translate english recure_eva2_451192b5:

    # eva "Отпусти..."
    eva "放开..."

# game/a13/7recure.rpy:911
translate english recure_eva2_4b65ce53:

    # me "Я не верю ни единому твоему слову. Я знаю, что это была ты, даже если не могу доказать."
    me "我一个字都不信。我知道就是你干的，哪怕我没法证明。"

# game/a13/7recure.rpy:912
translate english recure_eva2_54607146:

    # eva "Хватит..."
    eva "住手..."

# game/a13/7recure.rpy:913
translate english recure_eva2_3546750e:

    # me "С картинами, с собакой и со служанкой. Это всегда была ты."
    me "那些画、那只狗、还有那个女仆。一直是你。"

# game/a13/7recure.rpy:914
translate english recure_eva2_38ed152c:

    # eva "Горло..."
    eva "喉咙..."

# game/a13/7recure.rpy:915
translate english recure_eva2_67f51647:

    # me "Может и призраком из шкафа была не ты?"
    me "也许连柜子里的幽灵也不是你吧？"

# game/a13/7recure.rpy:916
translate english recure_eva2_01d4976d:

    # eva "Я...я..."
    eva "我...我..."

# game/a13/7recure.rpy:917
translate english recure_eva2_ae37bbff:

    # me "О... ну надо же. Признания вылетают из тебя куда охотнее, когда твое горло сдавлено, удивительно."
    me "哦...瞧瞧啊。原来捏住你的喉咙，你招供得就这么痛快，真是意外。"

# game/a13/7recure.rpy:918
translate english recure_eva2_f9e665c5:

    # eva "Убери руки..."
    eva "把手拿开..."

# game/a13/7recure.rpy:919
translate english recure_eva2_f1c4f358:

    # me "Или что? Может я просто убью тебя, а потом скажу, что не делал этого?"
    me "不然呢？也许我干脆杀了你，然后说我没做过？"

# game/a13/7recure.rpy:920
translate english recure_eva2_a82aa883:

    # eva "...не надо..."
    eva "...不要..."

# game/a13/7recure.rpy:921
translate english recure_eva2_3443989c:

    # me "О? Не надо? Тогда просто признайся."
    me "哦？不要？那就老实承认。"

# game/a13/7recure.rpy:923
translate english recure_eva2_bbe74771:

    # me "Признайся, сука больная... что это ты сделала. Все ты."
    me "承认吧，你这疯婆子...就是你干的。全是你。"

# game/a13/7recure.rpy:924
translate english recure_eva2_14d6591c:

    # eva "[mename]..."
    eva "[mename]..."

# game/a13/7recure.rpy:925
translate english recure_eva2_bc2c3379:

    # me "Или я сломаю твою сраную шею, клянусь. Признайся..."
    me "不然我就扭断你这该死的脖子，我发誓。承认..."

# game/a13/7recure.rpy:926
translate english recure_eva2_53352fc0:

    # eva "..."
    eva "..."

# game/a13/7recure.rpy:927
translate english recure_eva2_6f4d4c2c:

    # me "Ты убила собаку?"
    me "你杀了那条狗吗？"

# game/a13/7recure.rpy:928
translate english recure_eva2_104ec449:

    # eva "Я. Я убила."
    eva "是我。是我杀的。"

# game/a13/7recure.rpy:929
translate english recure_eva2_c0656fa2:

    # me "Конечно ты. Кто еще? Ты запихала черноплод в мясо и скормила этой псине?"
    me "当然是你。还能有谁？是你把黑果塞进肉里，喂给那条畜生的吗？"

# game/a13/7recure.rpy:930
translate english recure_eva2_802b271f:

    # eva "Да."
    eva "是。"

# game/a13/7recure.rpy:931
translate english recure_eva2_22646461:

    # me "А служанка? Ее ты тоже убила."
    me "那女仆呢？她也是你杀的。"

# game/a13/7recure.rpy:932
translate english recure_eva2_51b73d8b:

    # eva "Нет."
    eva "不是。"

# game/a13/7recure.rpy:933
translate english recure_eva2_88b51173:

    # me "Не лги мне."
    me "别对我撒谎。"

# game/a13/7recure.rpy:934
translate english recure_eva2_63965cd8:

    # eva "Я не лгу. Я ее не трогала."
    eva "我没撒谎。我没动她。"

# game/a13/7recure.rpy:935
translate english recure_eva2_05817463:

    # me "Ты же понимаешь, что я убью тебя? Прямо сейчас? Никто и никогда не узнает, что это был я. ПРИЗНАЙСЯ ИЛИ Я УБЬЮ ТЕБЯ, ЛЖИВАЯ СУКА."
    me "你明白我会杀了你吗？现在，马上。没人会知道是我干的。承认，不然我宰了你，你这满口谎言的婊子。"

# game/a13/7recure.rpy:936
translate english recure_eva2_9bf848e9_1:

    # eva "Я этого не делала."
    eva "我没做。"

# game/a13/7recure.rpy:937
translate english recure_eva2_ef185957:

    # me "Знаешь, твоя мать говорила со мной. Просила чтобы я тобой не пользовался."
    me "知道吗，你母亲跟我谈过了。求我不要碰你。"

# game/a13/7recure.rpy:938
translate english recure_eva2_7b7aaffb:

    # eva "Моя мама?"
    eva "我妈妈？"

# game/a13/7recure.rpy:939
translate english recure_eva2_9ce9ea76:

    # me "Ага. Я сказал, что не стану тебя портить. Поклялся ей. И знаешь что? Я могу солгать ей..."
    me "啊。我告诉她不会糟蹋你。我向她发誓了。你知道吗？我可以对她撒谎..."

# game/a13/7recure.rpy:940
translate english recure_eva2_c7f54c45:

    # eva "Что ты собираешься делать?"
    eva "你想干什么？"

# game/a13/7recure.rpy:941
translate english recure_eva2_2f8558a0:

    # me "Я? Ничего. Я знаю, кто ты на самом деле. Так что я не буду угрожать тебе что-то с тобой сделать. Я буду угрожать тебе с тобой ничего не сделать."
    me "我？什么也不干。我知道你的真面目。所以我不会威胁要对“你”做什么。我会威胁，不对“你”做什么。"

# game/a13/7recure.rpy:942
translate english recure_eva2_0e5223a4:

    # eva "Не понимаю..."
    eva "不明白..."

# game/a13/7recure.rpy:943
translate english recure_eva2_8c439709:

    # me "Понимаешь. Я собираюсь солгать твоей матери. Но только при одном условии... если ты скажешь правду. Хотя бы раз в жизни."
    me "你明白。我打算对你母亲撒谎。但有一个条件...你说实话。哪怕这辈子就这么一次。"

# game/a13/7recure.rpy:944
translate english recure_eva2_53352fc0_1:

    # eva "..."
    eva "..."

# game/a13/7recure.rpy:945
translate english recure_eva2_ec12e024:

    # me "Считаю до трех."
    me "我数到三。"

# game/a13/7recure.rpy:946
translate english recure_eva2_9bf848e9_2:

    # eva "Я этого не делала."
    eva "我没做过。"

# game/a13/7recure.rpy:947
translate english recure_eva2_9dec903d:

    # me "Один."
    me "一。"

# game/a13/7recure.rpy:948
translate english recure_eva2_9c77eb08:

    # eva "[mename]."
    eva "[mename]."

# game/a13/7recure.rpy:949
translate english recure_eva2_0627e1f1:

    # me "Два..."
    me "二..."

# game/a13/7recure.rpy:950
translate english recure_eva2_fd4f7249:

    # eva "Отпусти меня... я этого НЕ ДЕЛАЛА!"
    eva "放开我...我，没做过！"

# game/a13/7recure.rpy:951
translate english recure_eva2_6529b1cd:

    # me "Отпускаю. Три."
    me "我放手。三。"

# game/a13/7recure.rpy:954
translate english recure_eva2_e1a642c7:

    # eva "Ладно. Я это сделала. Я столкнула эту тупорылую суку вниз. Она испортила нам приятный момент, так что она это заслужила."
    eva "好吧。是我干的。我把那个蠢脸婊子推下去的。她破坏了我们的美妙时刻，所以她活该。"

# game/a13/7recure.rpy:955
translate english recure_eva2_3528755d:

    # me "Да неужели. Это еще что?"
    me "还真是你啊。这又是什么？"

# game/a13/7recure.rpy:956
translate english recure_eva2_53806215:

    # eva "Ключик от башни. Забрала у нее, прежде чем она полетела вниз."
    eva "塔楼的钥匙。在她掉下去之前，我从她那儿拿走的。"

# game/a13/7recure.rpy:957
translate english recure_eva2_3a54e117:

    # me "Как ты это сделала?"
    me "你是怎么做到的？"

# game/a13/7recure.rpy:958
translate english recure_eva2_0c9c936e:

    # eva "Толкнула ее из-за всех сил, когда она повернулась спиной, как еще?"
    eva "趁她转过身，用尽全身力气推了她一把，还能怎么着？"

# game/a13/7recure.rpy:959
translate english recure_eva2_a7e097a1:

    # me "Я не про это, как ты выбралась из своей башни и попала в эту?"
    me "我不是问这个。你怎么从你的塔里出来，进到那个塔里的？"

# game/a13/7recure.rpy:960
translate english recure_eva2_241468ed:

    # eva "У девочек должны быть свои маленькие секреты."
    eva "女孩子总得有点自己的小秘密吧。"

# game/a13/7recure.rpy:961
translate english recure_eva2_3820771a_1:

    # me "..."
    me "..."

# game/a13/7recure.rpy:962
translate english recure_eva2_c93dfbca:

    # eva "Я пробралась мимо служанки."
    eva "我偷偷绕过女仆溜出去的。"

# game/a13/7recure.rpy:963
translate english recure_eva2_c8a78a06:

    # me "Ты была закрыта на замок."
    me "你被锁在房间里。"

# game/a13/7recure.rpy:964
translate english recure_eva2_b6a184d2:

    # eva "Вот именно. Она закрыла меня на замок, а сама легла спать в соседних покоях."
    eva "对呀。她把我锁在里面，自己就在隔壁房间睡着了。"

# game/a13/7recure.rpy:965
translate english recure_eva2_cc0d8fd9:

    # me "Я все еще не понял."
    me "我还是没懂。"

# game/a13/7recure.rpy:966
translate english recure_eva2_50637e32:

    # eva "Ну... в помещениях бывают не только двери, но и окна. В башне множество покоев. Окна рядом друг с другом."
    eva "嗯...房间可不光有门，还有窗户。塔里有很多房间。窗户都挨得很近。"

# game/a13/7recure.rpy:967
translate english recure_eva2_7e075db8:

    # me "Ты ползала ночью из окна в окно, рискуя сорваться, чтобы убить служанку? Да ты правда больная."
    me "你夜里在窗户间爬来爬去，冒着摔死的危险，就为了杀一个女仆？你真是病得不轻。"

# game/a13/7recure.rpy:968
translate english recure_eva2_ea930f9f:

    # eva "Зато получилось отличное алиби. Ты так и будешь меня расспрашивать или выполнишь свою угрозу?"
    eva "但这样就有了完美的不在场证明。你到底是要继续审问我，还是兑现你的威胁？"

# game/a13/7recure.rpy:969
translate english recure_eva2_785e7aed:

    # me "Угроза была ничего не сделать."
    me "威胁就是什么都不做。"

# game/a13/7recure.rpy:970
translate english recure_eva2_1a5866f1:

    # eva "Ты понял о чем. Солги моей матери. Вот он ключик. Закрой дверь и..."
    eva "你知道我指什么。对我母亲撒谎。给你钥匙。锁上门然后..."

# game/a13/7recure.rpy:972
translate english recure_eva2_3820771a_2:

    # me "..."
    me "..."

# game/a13/7recure.rpy:973
translate english recure_eva2_53352fc0_2:

    # eva "..."
    eva "..."

# game/a13/7recure.rpy:975
translate english recure_eva2_e8f5c8d0:

    # me "Признайся в чем-то еще разок - ты именно этого и хотела."
    me "再承认点别的——这不就是你想要的吗。"

# game/a13/7recure.rpy:976
translate english recure_eva2_2b81a925:

    # eva "Признайся тоже. ТЫ именно этого и хотел. "
    eva "你也承认好了。这不也正是你想要的。"

# game/a13/7recure.rpy:977
translate english recure_eva2_a3a52aa9:

    # me "О. Я не привык себе лгать."
    me "噢。我不习惯对自己撒谎。"

# game/a13/7recure.rpy:978
translate english recure_eva2_cd26fab8:

    # eva "Я тоже. Только другим."
    eva "我也是。只对别人撒谎。"

# game/a13/7recure.rpy:979
translate english recure_eva2_71ba2c27:

    # me "Если лгать так часто, люди перестанут тебе верить."
    me "要是谎话说得太多，人们就不会再相信你了。"

# game/a13/7recure.rpy:980
translate english recure_eva2_831300e1:

    # eva "Если специально лгать плохо - люди начнут думать, что понимают когда ты лжешь."
    eva "要是故意把谎话说得很烂，人们就会以为能看穿你什么时候在撒谎。"

# game/a13/7recure.rpy:981
translate english recure_eva2_c9988de3:

    # me "Все поняли, что ты убила собаку."
    me "大家都看出来你杀了狗。"

# game/a13/7recure.rpy:982
translate english recure_eva2_955b9707:

    # eva "Да, но никто даже не подумал, что это я убила служанку."
    eva "没错，但根本没人想到是我杀了那个女仆。"

# game/a13/7recure.rpy:983
translate english recure_eva2_eee819cf:

    # me "Я понял."
    me "我看出来了。"

# game/a13/7recure.rpy:984
translate english recure_eva2_6ab39e3c:

    # eva "Это не считается. Ты знал мой мотив. Да и признайся - ты хоть на секундочку да задумался, действительно ли это я сделала?"
    eva "这不算。你知道我的动机。而且，说实话——你真的一秒钟都没想过，到底是不是我干的？"

# game/a13/7recure.rpy:985
translate english recure_eva2_3820771a_3:

    # me "..."
    me "..."

# game/a13/7recure.rpy:986
translate english recure_eva2_0dbf5209:

    # eva "Хм... красноречивое молчание."
    eva "哼...你的沉默真有说服力。"

# game/a13/7recure.rpy:987
translate english recure_eva2_3820771a_4:

    # me "..."
    me "..."

# game/a13/7recure.rpy:988
translate english recure_eva2_17783b09:

    # eva "Если признаешься, что поверил мне, позволю тебе меня вылизать."
    eva "只要承认你相信了我，我就允许你舔我。"

# game/a13/7recure.rpy:992
translate english recure_eva2_3820771a_5:

    # me "..."
    me "..."

# game/a13/7recure.rpy:993
translate english recure_eva2_38c9a485:

    # eva "Я ценю твою честность."
    eva "我真欣赏你的诚实。"

# game/a13/7recure.rpy:994
translate english recure_eva2_235b2e7a:

    # me "Не каждый может найти в себе силы признаться, что его обманула девчонка."
    me "能鼓起勇气承认自己被一个小丫头骗了，可不是人人都能做到的。"

# game/a13/7recure.rpy:995
translate english recure_eva2_08aa5134:

    # eva "Я обманывала людей и поопытней тебя."
    eva "我骗过比你更老练的人。"

# game/a13/7recure.rpy:996
translate english recure_eva2_3475d6e7:

    # me "Своего отца например."
    me "比如我父亲。"

# game/a13/7recure.rpy:997
translate english recure_eva2_052037c9:

    # eva "Например. А что? Тебе его никогда не обмануть."
    eva "比方说。怎么？你永远都骗不了他。"

# game/a13/7recure.rpy:998
translate english recure_eva2_3820771a_6:

    # me "..."
    me "..."

# game/a13/7recure.rpy:999
translate english recure_eva2_3158da3d:

    # eva "Ты когда-нибудь это делал?"
    eva "你舔过吗？"

# game/a13/7recure.rpy:1000
translate english recure_eva2_88b61fc1:

    # me "А что? Боишься что я что-нибудь тебе сломаю?"
    me "怎么？怕我给你咬下来？"

# game/a13/7recure.rpy:1001
translate english recure_eva2_f23fe2a9:

    # eva "Не хочу чтобы это делали грязным ртом."
    eva "只是不想你用脏嘴来做。"

# game/a13/7recure.rpy:1002
translate english recure_eva2_b3a08695:

    # me "По-твоему, я ни разу не чистил рот с тех пор?"
    me "你觉得我从那以后就没漱过口？"

# game/a13/7recure.rpy:1003
translate english recure_eva2_17c725b5:

    # eva "Так ты все-таки это делал. Кому? Жене?"
    eva "所以你还是舔过。对谁？你的妻子？"

# game/a13/7recure.rpy:1004
translate english recure_eva2_f13902b8:

    # me "Какая тебе разница? "
    me "关你什么事？"

# game/a13/7recure.rpy:1005
translate english recure_eva2_9f0cb091:

    # eva "Мне? Да насрать мне. Лижи."
    eva "我？我才不在乎。舔吧。"

# game/a13/7recure.rpy:1007
translate english recure_eva2_3820771a_7:

    # me "..."
    me "..."

# game/a13/7recure.rpy:1008
translate english recure_eva2_8f0dec4d:

    # eva "Ух.. что ты... что ты нахрен делаешь?"
    eva "呃...你...你到底在干啥？"

# game/a13/7recure.rpy:1009
translate english recure_eva2_e97dd81f:

    # me "Тебе не нравится?"
    me "不喜欢吗？"

# game/a13/7recure.rpy:1010
translate english recure_eva2_baa7086c:

    # eva "Не знаю... просто... так и должно быть... скользко?"
    eva "不知道...只是...本来就该这么...滑溜溜的？"

# game/a13/7recure.rpy:1011
translate english recure_eva2_8f9071f9:

    # me "Конечно."
    me "当然。"

# game/a13/7recure.rpy:1012
translate english recure_eva2_e3c2f254:

    # eva "Фу. Там, что, твоя слюна?"
    eva "呃。那是你的口水吗？"

# game/a13/7recure.rpy:1013
translate english recure_eva2_58237f2e:

    # me "Это твои соки, дура."
    me "这是你自己的汁水，蠢货。"

# game/a13/7recure.rpy:1014
translate english recure_eva2_126f65e6:

    # eva "Не ври, ты напускал в меня слюней, отвратительно."
    eva "骗人，你往我里面吐了口水，恶心死了。"

# game/a13/7recure.rpy:1016
translate english recure_eva2_3820771a_8:

    # me "..."
    me "..."

# game/a13/7recure.rpy:1017
translate english recure_eva2_7379e937:

    # eva "Ох... какая гадость... какой же ты ублюдок... господи..."
    eva "噢...真恶心...你真是个混蛋...天哪..."

# game/a13/7recure.rpy:1018
translate english recure_eva2_9dbec9b0:

    # me "Ты можешь заткнуться?"
    me "你能闭嘴吗？"

# game/a13/7recure.rpy:1019
translate english recure_eva2_559d0b67:

    # eva "Это ты должен заткнуться и лизать меня... без слюней!"
    eva "该闭嘴的是你，好好舔我...别用口水！"

# game/a13/7recure.rpy:1020
translate english recure_eva2_3820771a_9:

    # me "..."
    me "..."

# game/a13/7recure.rpy:1021
translate english recure_eva2_b00c66d7:

    # eva "Что? Я тебя не заставляла."
    eva "什么？我又没逼你。"

# game/a13/7recure.rpy:1022
translate english recure_eva2_3820771a_10:

    # me "..."
    me "..."

# game/a13/7recure.rpy:1023
translate english recure_eva2_f9f4628c:

    # eva "Ох... я бы знаешь... сделала это на обеденном столе."
    eva "唉...你知道吗...我真想在餐桌上做这事。"

# game/a13/7recure.rpy:1024
translate english recure_eva2_3820771a_11:

    # me "..."
    me "..."

# game/a13/7recure.rpy:1025
translate english recure_eva2_7df77c94:

    # eva "Вместо самого обеда? Знаешь... все если бы, а ты бы пускал меня свои слюни, больной ты урод."
    eva "代替晚餐吗？你知道...全是假如，而你会对我吐口水，你这发疯的怪物。"

# game/a13/7recure.rpy:1026
translate english recure_eva2_205c00e9:

    # me "Это ты больная, сука."
    me "你才是疯子，婊子。"

# game/a13/7recure.rpy:1027
translate english recure_eva2_70081d00:

    # eva "Ты еще и тупой. Я смогла тебя обмануть. Стыдно?"
    eva "你还很蠢。我能骗过你。丢脸吗？"

# game/a13/7recure.rpy:1028
translate english recure_eva2_5a7a7577:

    # me "Нет."
    me "不。"

# game/a13/7recure.rpy:1029
translate english recure_eva2_a8949172:

    # eva "А должно... быть... ты чего делаешь?"
    eva "你应该...感到...你在干什么？"

# game/a13/7recure.rpy:1030
translate english recure_eva2_3820771a_12:

    # me "..."
    me "..."

# game/a13/7recure.rpy:1031
translate english recure_eva2_14d6591c_1:

    # eva "[mename]..."
    eva "[mename]..."

# game/a13/7recure.rpy:1032
translate english recure_eva2_3820771a_13:

    # me "..."
    me "..."

# game/a13/7recure.rpy:1033
translate english recure_eva2_62704326:

    # eva "Принц, [mename]."
    eva "[mename]王子。"

# game/a13/7recure.rpy:1034
translate english recure_eva2_3820771a_14:

    # me "..."
    me "..."

# game/a13/7recure.rpy:1035
translate english recure_eva2_aa906b3f:

    # eva "Погоди немного... не трогай мой... пестик..."
    eva "等一下...别碰我的...花蕊..."

# game/a13/7recure.rpy:1036
translate english recure_eva2_1c8a1a11:

    # me "Это называется клитор, дура."
    me "那玩意叫阴蒂，蠢货。"

# game/a13/7recure.rpy:1037
translate english recure_eva2_3eae7786:

    # eva "Я не использую таких похабных слов, ты, грязный дегенерат."
    eva "我才不用那种下流词，你这肮脏的贱胚。"

# game/a13/7recure.rpy:1038
translate english recure_eva2_3820771a_15:

    # me "..."
    me "..."

# game/a13/7recure.rpy:1039
translate english recure_eva2_3295ffd9:

    # eva "И вообще... погоди немного..."
    eva "而且...等一下..."

# game/a13/7recure.rpy:1040
translate english recure_eva2_3820771a_16:

    # me "..."
    me "..."

# game/a13/7recure.rpy:1041
translate english recure_eva2_093a3b39:

    # eva "Ой..."
    eva "哦..."

# game/a13/7recure.rpy:1043
translate english recure_eva2_9046875f:

    # eva "О... ты..."
    eva "噢...你..."

# game/a13/7recure.rpy:1044
translate english recure_eva2_c3e351e0:

    # me "Спасибо скажешь? Справился за пару минут."
    me "该说谢谢吗？几分钟就搞定了。"

# game/a13/7recure.rpy:1045
translate english recure_eva2_98c3358e:

    # eva "Это.. приятней, чем пальцами."
    eva "这...比用手指舒服。"

# game/a13/7recure.rpy:1046
translate english recure_eva2_ac88bccb:

    # me "Еще бы."
    me "那还用说。"

# game/a13/7recure.rpy:1047
translate english recure_eva2_a8534d1d:

    # eva "Я бы могла к этому привыкнуть."
    eva "我大概能习惯这个。"

# game/a13/7recure.rpy:1048
translate english recure_eva2_1f795cb0:

    # me "Раскатала губу. Это был исключительный случай."
    me "别做梦了。这是例外的一次。"

# game/a13/7recure.rpy:1049
translate english recure_eva2_4cc6d634:

    # eva "За то, что я тебя обманула."
    eva "就因为我骗了你。"

# game/a13/7recure.rpy:1050
translate english recure_eva2_3aa199f4:

    # me "Этого больше никогда не повторится."
    me "再也不会有了。"

# game/a13/7recure.rpy:1051
translate english recure_eva2_07b57c0c:

    # eva "Ты такой идиот, ты же мог просто соврать... сказать, что не поверил мне..."
    eva "你真是个白痴，你大可以撒谎...说你没相信我..."

# game/a13/7recure.rpy:1052
translate english recure_eva2_3820771a_17:

    # me "..."
    me "..."

# game/a13/7recure.rpy:1053
translate english recure_eva2_5923394c:

    # eva "Если только...."
    eva "除非..."

# game/a13/7recure.rpy:1054
translate english recure_eva2_e0b287f8_1:

    # me "Заткнись."
    me "闭嘴。"

# game/a13/7recure.rpy:1055
translate english recure_eva2_7fe95767:

    # eva "Сам не захотел..."
    eva "是你自己不想..."

# game/a13/7recure.rpy:1058
translate english recure_eva2_15b187a9:

    # me "Заткни пасть. Я не верил тебе ни секунды."
    me "闭上你的嘴。我一秒钟都没信过你。"

# game/a13/7recure.rpy:1059
translate english recure_eva2_7bef9684:

    # eva "Поэтому ты мне и понравился."
    eva "这就是为什么我喜欢你。"

# game/a13/7recure.rpy:1061
translate english recure_eva2_d5eee931:

    # me "Ну что? Готова?"
    me "怎么样？准备好了？"

# game/a13/7recure.rpy:1062
translate english recure_eva2_9563f942:

    # eva "Это твой член?"
    eva "这是你的老二？"

# game/a13/7recure.rpy:1063
translate english recure_eva2_45722eb3:

    # me "Нет, третья нога."
    me "不，是我的第三条腿。"

# game/a13/7recure.rpy:1064
translate english recure_eva2_e9ba480d:

    # eva "Маловат для третьей ноги."
    eva "当第三条腿可有点小。"

# game/a13/7recure.rpy:1065
translate english recure_eva2_128e07e5:

    # me "Видала больше?"
    me "你见过更大的？"

# game/a13/7recure.rpy:1066
translate english recure_eva2_51b73d8b_1:

    # eva "Нет."
    eva "没有。"

# game/a13/7recure.rpy:1067
translate english recure_eva2_7e0aad70:

    # me "Так в чем претензия."
    me "那你有什么不满的。"

# game/a13/7recure.rpy:1068
translate english recure_eva2_5448a4a4:

    # eva "Что у тебя с тестикулами?"
    eva "你的蛋蛋是怎么回事？"

# game/a13/7recure.rpy:1069
translate english recure_eva2_0d1b5463:

    # me "С ними все нормально."
    me "它们好得很。"

# game/a13/7recure.rpy:1070
translate english recure_eva2_b680f6ac:

    # eva "Какие-то они огромные. Ты случайно не болеешь?"
    eva "真是巨大。你不会是得什么病了吧？"

# game/a13/7recure.rpy:1071
translate english recure_eva2_76cc5127:

    # me "Чем? Большеяицевостью?"
    me "什么病？巨蛋症？"

# game/a13/7recure.rpy:1072
translate english recure_eva2_24a05be3:

    # eva "Понятия не имею. Выглядит... странно. И ты что... не сбриваешь волосы на лобке?"
    eva "完全不懂。看着...好奇怪。还有，你...不剃下面的毛？"

# game/a13/7recure.rpy:1073
translate english recure_eva2_7f6114ec:

    # me "Зачем."
    me "为什么要剃。"

# game/a13/7recure.rpy:1074
translate english recure_eva2_eee55c64:

    # eva "Для гигиены, кретин. Они же воняют. На них могут поселиться лобковые вши. Это в конце концов не эстетично."
    eva "为了卫生，蠢货。它们会变臭的。还会长阴虱。说到底，这不雅观。"

# game/a13/7recure.rpy:1075
translate english recure_eva2_5a6bc7a1:

    # me "Ты как-то многовато рассуждаешь об эстетике гениталий для девственница."
    me "你一个处女，对生殖器的审美倒挺有研究。"

# game/a13/7recure.rpy:1076
translate english recure_eva2_9aa9e7c9:

    # eva "Я аристократка. Хочу чтобы первый раз был с достойным меня человеком, а не с грязной свиньей."
    eva "我是贵族。我希望第一次是跟一个配得上我的人，而不是一头肮脏的猪。"

# game/a13/7recure.rpy:1077
translate english recure_eva2_c3ffddbe:

    # me "...я начинаю."
    me "...我开始了。"

# game/a13/7recure.rpy:1078
translate english recure_eva2_88ca7924:

    # eva "Стой."
    eva "等等。"

# game/a13/7recure.rpy:1079
translate english recure_eva2_20875dc2:

    # me "Ну что опять?"
    me "又怎么了？"

# game/a13/7recure.rpy:1080
translate english recure_eva2_34b6f855:

    # eva "Не в этой позе."
    eva "别用这个姿势。"

# game/a13/7recure.rpy:1081
translate english recure_eva2_b850b57f:

    # me "А в какой."
    me "那用什么姿势。"

# game/a13/7recure.rpy:1083
translate english recure_eva2_0ceba8d6:

    # eva "В этой. И не в ту дырку. Хочу в задницу."
    eva "用这个。还有，别捅错洞。我要你进后面。"

# game/a13/7recure.rpy:1084
translate english recure_eva2_67c5f2d1:

    # me "Чего?"
    me "什么？"

# game/a13/7recure.rpy:1085
translate english recure_eva2_c4cce84e:

    # eva "В задницу. У тебя она тоже есть. Ты знаешь что это такое."
    eva "进后面。你也有那地方。你知道是什么的。"

# game/a13/7recure.rpy:1086
translate english recure_eva2_60358084:

    # me "Эм..."
    me "呃..."

# game/a13/7recure.rpy:1087
translate english recure_eva2_82a8be71:

    # eva "Она чистая. Я ее мою."
    eva "是干净的。我洗过了。"

# game/a13/7recure.rpy:1088
translate english recure_eva2_9697c4bc:

    # me "Дело не в этом. Это будет больно."
    me "问题不在这儿。会很痛的。"

# game/a13/7recure.rpy:1089
translate english recure_eva2_802941a1:

    # eva "Я знаю."
    eva "我知道。"

# game/a13/7recure.rpy:1090
translate english recure_eva2_32041af0:

    # me "Очень больно."
    me "非常非常痛。"

# game/a13/7recure.rpy:1091
translate english recure_eva2_802941a1_1:

    # eva "Я знаю."
    eva "我知道。"

# game/a13/7recure.rpy:1092
translate english recure_eva2_ffbd4237:

    # me "У тебя может пойти кровь."
    me "你可能会流血。"

# game/a13/7recure.rpy:1093
translate english recure_eva2_802941a1_2:

    # eva "Я знаю."
    eva "我知道。"

# game/a13/7recure.rpy:1094
translate english recure_eva2_839702fb:

    # me "...ты действительно больная на голову."
    me "...你真是脑子有病。"

# game/a13/7recure.rpy:1095
translate english recure_eva2_2173aff2:

    # eva "Я подготовилась."
    eva "我准备好了。"

# game/a13/7recure.rpy:1096
translate english recure_eva2_5fb623f5:

    # me "Как? Помылась."
    me "怎么准备的？洗干净了。"

# game/a13/7recure.rpy:1097
translate english recure_eva2_846253e4:

    # eva "В другом смысле. Я растягивала анус пальцами."
    eva "别的方面。我用手指扩张过肛门了。"

# game/a13/7recure.rpy:1098
translate english recure_eva2_9cabfc4a:

    # me "Очень аристократично."
    me "真够贵族风范的。"

# game/a13/7recure.rpy:1099
translate english recure_eva2_28bc45c9:

    # eva "Заткнись и засунь член в мне в задницу."
    eva "闭嘴，把你的东西插进我后面。"

# game/a13/7recure.rpy:1101
translate english recure_eva2_dded6892:

    # eva "Ай! Не так резко, спятил?"
    eva "哎哟！别这么猛，疯了吗？"

# game/a13/7recure.rpy:1102
translate english recure_eva2_a3a0534a:

    # me "Это еще не член."
    me "这还不是那东西。"

# game/a13/7recure.rpy:1103
translate english recure_eva2_c5d6f7bd:

    # eva "А что это?"
    eva "那是什么？"

# game/a13/7recure.rpy:1104
translate english recure_eva2_862809db:

    # me "Это мой палец. Один."
    me "是我的手指。一根。"

# game/a13/7recure.rpy:1105
translate english recure_eva2_507ac14e:

    # eva "У тебя какие-то толстые пальцы. Ты точно принц? Пальцы скоре как у рыбака."
    eva "你的手指真粗。你真是王子？手指倒像个渔夫。"

# game/a13/7recure.rpy:1106
translate english recure_eva2_1d2e085c:

