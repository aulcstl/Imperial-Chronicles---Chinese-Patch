# game/a13/7recure.rpy:445
translate english recure2_5e1b12c5:

    # eva "Да. Я не только убийца собак, но еще и лгунья."
    eva "是呀。我不光是个杀狗犯，还是个骗子。"

# game/a13/7recure.rpy:446
translate english recure2_0ae095cc:

    # cath "Ева, хватит."
    cath "Eva，够了。"

# game/a13/7recure.rpy:447
translate english recure2_27b7220d:

    # eva "Эдрик, простите, если вы хотите жениться на мне, вам придется жить со мной в башне, потому что я похоже никогда не отбуду родительское наказание."
    eva "埃德里克，抱歉，如果您想娶我，您就得跟我住在那塔楼里，因为我父母的惩罚看样子永远都不会结束。"

# game/a13/7recure.rpy:448
translate english recure2_0796b8e0:

    # cath "Эдрик не слушайте ее, нигде вам жить не придется."
    cath "埃德里克，别听她胡说，根本不用你住在哪儿。"

# game/a13/7recure.rpy:449
translate english recure2_f297efd5:

    # edric "Я... эм..."
    edric "我...呃..."

# game/a13/7recure.rpy:450
translate english recure2_c7ef9478:

    # eva "У вас в замке есть башня? Вам придется регулярно меня наказывать."
    eva "你们的城堡里有塔楼吗？您以后得定期惩罚我了。"

# game/a13/7recure.rpy:451
translate english recure2_f4eef25a:

    # cath "Ева!"
    cath "Eva！"

# game/a13/7recure.rpy:452
translate english recure2_c1de9fb4:

    # edric "Я... не думаю, что мне придется."
    edric "我...我觉得没这个必要。"

# game/a13/7recure.rpy:453
translate english recure2_9ea12cc6:

    # eva "Почти наверняка придется. Я очень к этому привыкла. Либо это, либо телесные наказания."
    eva "几乎肯定有。我都习惯了。不是关塔楼，就是体罚。"

# game/a13/7recure.rpy:454
translate english recure2_d05bf769:

    # edric "Телесные?"
    edric "体罚？"

# game/a13/7recure.rpy:455
translate english recure2_7d9b7031:

    # eva "Ну да. Вы бы смогли меня ударить?"
    eva "对呀。您下得了手打我吗？"

# game/a13/7recure.rpy:456
translate english recure2_e8a00aea:

    # edric "Я...эм..."
    edric "我...呃..."

# game/a13/7recure.rpy:457
translate english recure2_64dcf53a:

    # cath "Если ты не прекратишь..."
    cath "你再不住口..."

# game/a13/7recure.rpy:458
translate english recure2_66c1627f:

    # eva "Эдрик, вам не кажется, что моя матушка немного мешает нам найти общий язык?"
    eva "埃德里克，您不觉得我母亲有点妨碍我们俩互相了解吗？"

# game/a13/7recure.rpy:459
translate english recure2_1171f2df:

    # edric "Ева, я..."
    edric "Eva，我..."

# game/a13/7recure.rpy:460
translate english recure2_86da24fb:

    # eva "Вы будто напуганы, надеюсь это не из-за меня? Я бы очень хотела вам понравится!"
    eva "您好像吓到了，希望不是因为我吧？我真的很想讨您喜欢！"

# game/a13/7recure.rpy:461
translate english recure2_73a62d08:

    # edric "Вы мне нравитесь."
    edric "我喜欢您。"

# game/a13/7recure.rpy:462
translate english recure2_de32a075:

    # eva "Здорово! Я рада. Я слышала вы младший сын в семье."
    eva "太好了！真高兴。我听说您是家里的小儿子。"

# game/a13/7recure.rpy:463
translate english recure2_d713558f:

    # edric "Да."
    edric "是的。"

# game/a13/7recure.rpy:464
translate english recure2_ada22d40:

    # eva "Как думаете..."
    eva "那您觉得..."

# game/a13/7recure.rpy:465
translate english recure2_c93a7309_3:

    # cath "Ева..."
    cath "Eva..."

# game/a13/7recure.rpy:466
translate english recure2_bc2ff153:

    # eva "...я смогла бы соблазнить вашего старшего брата? Он унаследует привилегий и земель явно больше вас. А может я вообще займусь вашим отцом? Как он? Любит девочек помоложе?"
    eva "...我能不能勾引一下您的大哥？他继承的特权和土地肯定比您多得多。或者，我干脆去搞定您父亲？他怎么样？喜欢年轻姑娘吗？"

# game/a13/7recure.rpy:467
translate english recure2_b8ca3775_2:

    # edric "..."
    edric "..."

# game/a13/7recure.rpy:468
translate english recure2_4b66e57a:

    # cath "Еще одна издевка, и за тобой буду следить не я, а отец."
    cath "再敢说一句风凉话，看着你的就不是我，而是你父亲了。"

# game/a13/7recure.rpy:471
translate english recure2_a0aff477:

    # eva "Отец занят. Расследует... убийство."
    eva "父亲忙着呢。他在调查...谋杀案。"

# game/a13/7recure.rpy:472
translate english recure2_c747ac44:

    # edric "О боги, кого-то убили?"
    edric "噢，天哪，有人被杀了？"

# game/a13/7recure.rpy:473
translate english recure2_e3666184:

    # cath "Не волнуйтесь, Эдрик. Кто-то из стражников убил служанку из ревности."
    cath "别紧张，埃德里克。某个卫兵出于嫉妒杀了个女仆。"

# game/a13/7recure.rpy:474
translate english recure2_3c693645:

    # edric "Из ревности?"
    edric "嫉妒？"

# game/a13/7recure.rpy:475
translate english recure2_5b5ffab6:

    # eva "Мы этого не знаем. Убийцей может оказаться кто угодно. Да, принц [mename]."
    eva "这我们可不知道。凶手可能是任何人。对吧，[mename]王子。"

# game/a13/7recure.rpy:476
translate english recure2_4acd789c:

    # me "Например кто?"
    me "比如谁呢？"

# game/a13/7recure.rpy:477
translate english recure2_1375ec1d:

    # cath "Давайте не будем сейчас об этом говорить. Мой муж закончит расследование и виновные будут наказаны."
    cath "我们现在还是别谈这个了。我丈夫会完成调查，有罪的人会受到惩罚。"

# game/a13/7recure.rpy:478
translate english recure2_8f3dd405:

    # eva "А я бы обсудила"
    eva "我倒想聊聊。"

# game/a13/7recure.rpy:479
translate english recure2_dbc15020:

    # cath "Это не предложение."
    cath "这不是建议。"

# game/a13/7recure.rpy:480
translate english recure2_080d9682:

    # eva "Простите, Эдрик, я бы рассказала еще чего-нибудь, но матушка против."
    eva "抱歉，埃德里克，我本来还想再说点，但我母亲不准。"

# game/a13/7recure.rpy:481
translate english recure2_defae85c:

    # edric "Все нормально, она права. Если расследование не окончено..."
    edric "没关系，她是对的。如果调查还没结束..."

# game/a13/7recure.rpy:482
translate english recure2_9f4b0e89:

    # eva "Просто мне кажется версия с ревностью какая-то слишком простая."
    eva "只是我觉得那个嫉妒的说法有点太简单了。"

# game/a13/7recure.rpy:483
translate english recure2_34ccefed:

    # cath "В каком это смысле?"
    cath "这话什么意思？"

# game/a13/7recure.rpy:484
translate english recure2_b82cc09f:

    # eva "Стражники ходят в борделе в городке у замка, зачем кому-то сдалась какая-то служанка. Я видела их всех, Эдрик, там ни одна не стоит ревности."
    eva "卫兵们都去城堡附近镇上的妓院，谁会稀罕一个普通女仆？我见过她们所有人，埃德里克，里面没哪个值得人嫉妒发狂的。"

# game/a13/7recure.rpy:485
translate english recure2_61bb5289:

    # edric "Ну... любовь иногда толкает на необдуманные поступки."
    edric "嗯...爱情有时会让人做出不理智的事。"

# game/a13/7recure.rpy:486
translate english recure2_f483c313:

    # eva "Так ее убили из любви?"
    eva "所以她是因为爱情被杀的？"

# game/a13/7recure.rpy:487
translate english recure2_8f1e8691:

    # cath "Ева...."
    cath "Eva..."

# game/a13/7recure.rpy:488
translate english recure2_7d9498fc:

    # edric "Может тот кто ее убил, ее сильно любил, а она ему изменила."
    edric "也许杀她的人非常爱她，她却背叛了他。"

# game/a13/7recure.rpy:489
translate english recure2_84f7972f:

    # eva "Если бы мы женились и я вам изменила, вы бы убили меня, Эдрик?"
    eva "要是我们结婚了，我背叛了您，您会杀了我吗，埃德里克？"

# game/a13/7recure.rpy:490
translate english recure2_8b57f7b0:

    # cath "Ева, клянусь богом..."
    cath "Eva，我对天发誓..."

# game/a13/7recure.rpy:491
translate english recure2_ba2a6c17:

    # edric "Все нормально, Леди Катерина. Мы же просто общаемся."
    edric "没关系，Katerina夫人。我们不过是闲聊。"

# game/a13/7recure.rpy:492
translate english recure2_f09dfc63:

    # eva "Вот именно, Леди Катерина, мы просто общаемся."
    eva "就是说啊，Katerina夫人，我们只是闲聊。"

# game/a13/7recure.rpy:493
translate english recure2_dd2d1d95_1:

    # cath "..."
    cath "..."

# game/a13/7recure.rpy:494
translate english recure2_57b34d37:

    # edric "Я... не уверен. Если бы я действительно искренне вас любил, я бы убил вашего любовника, но вас, наверное, я не смог бы убить."
    edric "我...不确定。如果我真的发自内心爱您，我大概会杀了您的情人，但您，我可能下不了手。"

# game/a13/7recure.rpy:495
translate english recure2_15d98569:

    # eva "Что вы имеете в виду под 'если бы любил', Эдрик, разве вы меня не любите?"
    eva "“如果爱”是什么意思，埃德里克，难道您不爱我吗？"

# game/a13/7recure.rpy:496
translate english recure2_7903ad9f:

    # edric "Я....эм... не в этом смысле. Я люблю вас, конечно же. Просто..."
    edric "我...呃...不是那个意思。我当然爱您。不过是..."

# game/a13/7recure.rpy:497
translate english recure2_c5a52fbe:

    # cath "Тебе доставляет это удовольствие? Вести себя так?"
    cath "你这样很开心是吗？故意这么闹？"

# game/a13/7recure.rpy:498
translate english recure2_5ed4f03c:

    # eva "Не понимаю о чем ты, матушка. Мы просто обсуждали убийство."
    eva "不明白你在说什么，母亲。我们只是在讨论这桩谋杀案。"

# game/a13/7recure.rpy:500
translate english recure2_ec510692:

    # cath "Мы обсуждали твою свадьбу, а не убийство."
    cath "我们讨论的是你的婚事，不是什么谋杀。"

# game/a13/7recure.rpy:501
translate english recure2_05b22f52:

    # eva "С моей свадьбой все решено, а убийство еще не расследовано. Оно будоражит кровь, верно, [mename]?"
    eva "我的婚事已经是板上钉钉了，可谋杀案还没查清。这让人兴奋，对吧，[mename]？"

# game/a13/7recure.rpy:502
translate english recure2_6be4e6cc:

    # cath "При чем тут вообще принц [mename]."
    cath "这跟[mename]王子有什么关系。"

# game/a13/7recure.rpy:503
translate english recure2_1684475a:

    # eva "Может это он ее убил."
    eva "也许就是他杀的。"

# game/a13/7recure.rpy:504
translate english recure2_8c11a588:

    # cath "Ева."
    cath "Eva。"

# game/a13/7recure.rpy:505
translate english recure2_e13f3e80:

    # me "Я ее не убивал. Это могут подтвердить слуги."
    me "我没杀她。仆人能作证。"

# game/a13/7recure.rpy:506
translate english recure2_0f534439:

    # eva "Я была под замком. Значит и я ее не убивала. Эдрик, вы ведь прибыли в замок позже?"
    eva "我那时被锁着。所以也不可能是我。埃德里克，您到城堡比较晚吧？"

# game/a13/7recure.rpy:507
translate english recure2_b8e32241:

    # edric "Ну...да."
    edric "嗯...是的。"

# game/a13/7recure.rpy:508
translate english recure2_6d38e7b2:

    # cath "К чему это сейчас?"
    cath "说这些现在有什么意义？"

# game/a13/7recure.rpy:509
translate english recure2_31a21dad:

    # eva "Из нас четверых только ты могла это сделать?"
    eva "我们四个人里，只有你可能做出这事了？"

# game/a13/7recure.rpy:510
translate english recure2_2b48ec4d:

    # cath "Это смешно, по-твоему?"
    cath "你觉得这很好笑吗？"

# game/a13/7recure.rpy:511
translate english recure2_b54d7fb0:

    # eva "Это не смешно. Это просто интересное наблюдение. Я ведь тебя не обвиняю."
    eva "不好笑。只是个有趣的观察。我又没指控你。"

# game/a13/7recure.rpy:512
translate english recure2_23267b1d:

    # cath "Еще бы ты меня обвиняла."
    cath "你还想指控我。"

# game/a13/7recure.rpy:513
translate english recure2_c3b1eeff:

    # eva "Отец мог бы быть убийцей. Как думаете, Эдрик?"
    eva "父亲倒可能是凶手。您觉得呢，埃德里克？"

# game/a13/7recure.rpy:514
translate english recure2_ccea5cc0:

    # edric "Что? Нет... я не думаю. Зачем ему это?"
    edric "什么？不...我不认为。他为什么要这么做？"

# game/a13/7recure.rpy:515
translate english recure2_03075293:

    # cath "Ева. Закрой рот."
    cath "Eva。闭上你的嘴。"

# game/a13/7recure.rpy:516
translate english recure2_8bd50eb1:

    # eva "Я его не обвиняю. Просто рассуждаю. Отец прямо сейчас делает то же самое. В чем проблема? Он ведь рассматривает все версии и мы тоже можем. Какая версия у вас, принц?"
    eva "我又没指控他。只是推理。父亲此刻不也正在这样做吗？有什么问题？他考虑所有的可能性，我们也可以啊。您有什么看法，王子？"

# game/a13/7recure.rpy:517
translate english recure2_fadd83e1:

    # me "Понятия не имею. Может она случайно упала."
    me "毫无头绪。也许她是不小心掉下去的。"

# game/a13/7recure.rpy:518
translate english recure2_3e189fe0:

    # eva "Случайно? Фу. Это было бы очень скучным, правда, Эдрик?"
    eva "不小心？呸。那也太无聊了，对吧，埃德里克？"

# game/a13/7recure.rpy:519
translate english recure2_dcd8f696:

    # cath "Не впутывай в это своего жениха и принца."
    cath "别把你的未婚夫和王子卷进来。"

# game/a13/7recure.rpy:520
translate english recure2_c40d5310:

    # edric "Нет... все нормально. Я думаю вариант принца наиболее вероятен."
    edric "不...没事的。我觉得王子的推测最靠谱。"

# game/a13/7recure.rpy:521
translate english recure2_d5e20bbc:

    # eva "А вы, принц [mename], вы могли бы убить за измену?"
    eva "那您呢，[mename]王子，您会因为背叛而杀人吗？"

# game/a13/7recure.rpy:522
translate english recure2_ccc5c2b4:

    # me "Понятия не имею, мне не изменяли."
    me "毫无头绪，没人背叛过我。"

# game/a13/7recure.rpy:523
translate english recure2_f7eb0dcb:

    # eva "А вы?"
    eva "那您呢？"

# game/a13/7recure.rpy:524
translate english recure2_df3b5a43:

    # cath "Ева... это уже не смешно. Я серьезно."
    cath "Eva...这真的不好笑了。我是认真的。"

# game/a13/7recure.rpy:525
translate english recure2_cacda236:

    # eva "Эдрик. Вы ведь верны принцу?"
    eva "埃德里克。您是忠于王子的吧？"

# game/a13/7recure.rpy:526
translate english recure2_8ce2f7e2:

    # edric "Разумеется."
    edric "当然。"

# game/a13/7recure.rpy:527
translate english recure2_443db170:

    # eva "А если бы... Чисто в теории. Вы сказали, что смогли бы убить моего любовника, но не уверены, что смогли бы убить меня..."
    eva "那假如...纯理论地说。您刚才说，您会杀了我的情人，但不确定能不能杀我..."

# game/a13/7recure.rpy:528
translate english recure2_3c10aba3:

    # cath "ЕВА..."
    cath "Eva......"

# game/a13/7recure.rpy:529
translate english recure2_d4419399:

    # eva "Если бы я изменила вас с принцем, вы бы смогли убить его или хотя бы меня?"
    eva "要是我背叛您，和王子好上了，您能杀了他，或者至少杀了我吗？"

# game/a13/7recure.rpy:530
translate english recure2_1025c8f4:

    # edric "Я..."
    edric "我..."

# game/a13/7recure.rpy:532
translate english recure2_ca75f898:

    # cath "Принц [mename], можно вас на минутку?"
    cath "[mename]王子，能借一步说话吗？"

# game/a13/7recure.rpy:533
translate english recure2_93218c32:

    # eva "Мы же просто разговариваем!"
    eva "我们就是随便聊聊！"

# game/a13/7recure.rpy:534
translate english recure2_f26acbc2:

    # me "На минутку?"
    me "就一会儿？"

# game/a13/7recure.rpy:535
translate english recure2_352c3c67:

    # cath "Надо поговорить кое о чем."
    cath "有点事要谈谈。"

# game/a13/7recure.rpy:536
translate english recure2_67506c92:

    # me "Понял. Ладно."
    me "明白。好吧。"

# game/a13/7recure.rpy:537
translate english recure2_7cb11a01:

    # eva "Принц, вы вовсе не обязаны ее слушаться, вы в гостях у моего отца, а не у нее."
    eva "王子，您完全没必要听她的，您是我父亲的客人，不是她的。"

# game/a13/7recure.rpy:538
translate english recure2_705d9eac:

    # cath "Ева. Закрой. Свой. Рот."
    cath "Eva。给。我。闭嘴。"

# game/a13/7recure.rpy:539
translate english recure2_c41cfeea:

    # eva "Ты ведешь себя странно, матушка."
    eva "你的行为真奇怪，母亲。"

# game/a13/7recure.rpy:540
translate english recure2_c12af1c6:

    # cath "Я веду себя странно? [mename], вы идете или нет?"
    cath "我奇怪？[mename]，您走还是不走？"

# game/a13/7recure.rpy:541
translate english recure2_84bb8e65:

    # me "Иду."
    me "走。"

# game/a13/7recure.rpy:543
translate english recure2_7d482285:

    # cath "Ох..."
    cath "唉..."

# game/a13/7recure.rpy:544
translate english recure2_3820771a_3:

    # me "..."
    me "..."

# game/a13/7recure.rpy:545
translate english recure2_caee2377:

    # cath "Клянусь, это девчонка сведет меня в могилу."
    cath "我发誓，这丫头迟早把我气得进坟墓。"

# game/a13/7recure.rpy:546
translate english recure2_b914b7ea:

    # me "Я думал вы уже привыкли."
    me "我以为您已经习惯了。"

# game/a13/7recure.rpy:547
translate english recure2_997e1ba9:

    # cath "Разве к этому можно привыкнуть?"
    cath "这也能习惯吗？"

# game/a13/7recure.rpy:548
translate english recure2_62cc42d6:

    # me "Не знаю. К радости."
    me "不知道。像这种快乐可没法习惯。"

# game/a13/7recure.rpy:549
translate english recure2_2224180c:

    # cath "Пообещайте, что когда у вас будут дети, вы будете чаще их бить."
    cath "答应我，等您有了孩子，要更常打他们。"

# game/a13/7recure.rpy:550
translate english recure2_ea809ac5:

    # me "У меня уже есть ребенок. Предлагаете бить младенца?"
    me "我已经有个孩子了。您建议我去打那个婴儿吗？"

# game/a13/7recure.rpy:551
translate english recure2_050b3cf7:

    # cath "Нет... простите. Просто это так... ты никогда не замечаешь, когда они перестают быть детьми и становятся слишком поздно."
    cath "不...对不起。只是这真是...你从来都注意不到，他们从什么时候起不再是孩子，等发现时已经太晚了。"

# game/a13/7recure.rpy:552
translate english recure2_52de7f6f:

    # me "Поздно, для того чтобы их бить?"
    me "太晚到不能打他们了？"

# game/a13/7recure.rpy:553
translate english recure2_f597b47f:

    # cath "В том числе. Ты умиляешься и радуешься им, пропускаешь все тревожные звоночки, думаешь 'она еще слишком мала, как можно ее наказывать'. А потом - бах, и все."
    cath "也包括这个。你宠爱他们，为他们高兴，忽略了所有警示的信号，想着“她还太小了，怎么能惩罚她”。然后——啪，一切都变了。"

# game/a13/7recure.rpy:554
translate english recure2_5ddc1b08:

    # me "Вы меня про воспитание вывели поговорить?"
    me "您拉我出来就是为了谈育儿经吗？"

# game/a13/7recure.rpy:555
translate english recure2_c42ab2cb:

    # cath "Ох, [mename], к сожалению нет."
    cath "噢，[mename]，可惜不是。"

# game/a13/7recure.rpy:557
translate english recure2_6143c8e0:

    # cath "Вы ведь понимаете, что происходит?"
    cath "您明白在发生什么吧？"

# game/a13/7recure.rpy:558
translate english recure2_f3a55b8c:

    # me "Ну... мы знакомим их. Что-то вроде того."
    me "嗯...我们在介绍他们认识。差不多是这样。"

# game/a13/7recure.rpy:559
translate english recure2_4397db92:

    # cath "Я не про это. Я про то что происходит с Евой."
    cath "我不是说这个。我是指Eva身上发生的事。"

# game/a13/7recure.rpy:560
translate english recure2_0dd59ca7:

    # me "Опять про воспитание."
    me "又回到育儿经了。"

# game/a13/7recure.rpy:561
translate english recure2_5d1daa41:

    # cath "Да нет же. Вы, конечно, молоды, но не настолько же. Вы же видите, что она в вас влюблена."
    cath "不是。您虽然年轻，但也不至于那么迟钝。您看得出来她爱上您了。"

# game/a13/7recure.rpy:562
translate english recure2_921d0c62:

    # me "Влюблена?"
    me "爱上我了？"

# game/a13/7recure.rpy:563
translate english recure2_f0293a62:

    # cath "Да. Это не искренняя любовь. Так. Баловство. Она долго была одна, созрела как женщина, и тут приезжаете вы. Это... телесная потребность. Я сама была девочкой, я понимаю о чем говорю."
    cath "是的。这算不上什么真爱。只是胡闹。她孤独太久了，身心成熟了，然后您出现了。这是一种...身体上的需求。我自己也当过女孩，我知道自己在说什么。"

# game/a13/7recure.rpy:564
translate english recure2_713c1391:

    # me "Эмм..."
    me "呃..."

# game/a13/7recure.rpy:565
translate english recure2_73c97ee4:

    # cath "Она специально ведет себя так. Ева, конечно, и раньше была невыносима, но сейчас она просто...отвратительна. И ведет она себя так для вас."
    cath "她是故意这么做的。Eva以前当然也很惹人厌，但现在她简直是...令人作呕。而她这样做是为了给您看。"

# game/a13/7recure.rpy:566
translate english recure2_eaa6b899:

    # me "Для меня?"
    me "给我看？"

# game/a13/7recure.rpy:567
translate english recure2_5f6eeb10:

    # cath "Ну конечно."
    cath "当然是。"

# game/a13/7recure.rpy:568
translate english recure2_77c28c06:

    # me "Допустим это так."
    me "就算真是这样吧。"

# game/a13/7recure.rpy:569
translate english recure2_c408d2dd:

    # cath "Это так."
    cath "就是这样。"

# game/a13/7recure.rpy:570
translate english recure2_933230cd:

    # me "Хорошо. Это так. Я то тут при чем? Я вообще завтра уезжаю."
    me "好吧。就算是这样。那跟我有什么关系？我明天就走了。"

# game/a13/7recure.rpy:571
translate english recure2_57a185e9:

    # cath "Но вы ведь вернетесь. Вы повезете ее в Золотое Королевство."
    cath "可您还会回来的。您要带她去黄金王国。"

# game/a13/7recure.rpy:572
translate english recure2_2325fa76:

    # me "И что?"
    me "那又怎样？"

# game/a13/7recure.rpy:573
translate english recure2_4b99a9d6:

    # cath "И то. Она не остановится. Она будет только все сильнее и сильнее вас... провоцировать. Она сейчас себя не контролирует. Думает, что в вас нашла свою любовь, или родственную душу или еще бог знает что."
    cath "就这样。她不会停下来的。她只会越来越卖力地...挑逗您。她现在控制不住自己。她以为在您身上找到了真爱，或是灵魂伴侣，或是天知道什么东西。"

# game/a13/7recure.rpy:574
translate english recure2_a68f8445:

    # me "Я все еще не услышал, что вы от меня хотите, леди Катерина."
    me "我还是没听到您到底想让我做什么，Katerina夫人。"

# game/a13/7recure.rpy:575
translate english recure2_6e5fbe22:

    # cath "Прошу вас. Дайте мне обещание. Что вы не станете ей...отвечать. В любой форме. Забудьте про нее. Игнорируйте тот короткий миг что остался до отбытия и после того как вернетесь. Не губите ее."
    cath "我请求您。向我保证。您不会对她...作出任何回应。任何形式的。忘了她吧。在您出发前这短暂的一刻，以及在您回来之后，都无视她。别毁了她。"

# game/a13/7recure.rpy:576
translate english recure2_0da8fd00:

    # cath "Я знаю, мужчины у власти относятся к этому очень несерьезно. А я прошу - пообещайте, что не воспользуетесь ее глупостью."
    cath "我知道，当权的男人对这种事都很不严肃。但我恳求您——请保证，您不会利用她的愚蠢。"

# game/a13/7recure.rpy:581
translate english recure2_b7344260:

    # me "Вы меня с кем-то спутали. Я бы никогда ничего подобного не сделал."
    me "您把我和谁搞混了。我绝对做不出那种事。"

# game/a13/7recure.rpy:582
translate english recure2_d12ef797:

    # cath "Простите... я..."
    cath "对不起...我..."

# game/a13/7recure.rpy:583
translate english recure2_b72a53dd:

    # me "Но я понимаю ваше беспокойство. Я конечно же не слепой. "
    me "但我理解您的担忧。我当然不是瞎子。"

# game/a13/7recure.rpy:584
translate english recure2_4e3df824:

    # me "И раз уж вы объяснили мне причины ее поведения - я конечно же дам обещание не пользоваться этой ситуацией."
    me "既然您向我解释了她行为的原因，我当然会保证，不利用这种情况。"

# game/a13/7recure.rpy:585
translate english recure2_01049091:

    # cath "Спасибо, [mename], вы не представляете как облегчили мои переживания."
    cath "谢谢您，[mename]，您无法想象这让我心里的一块大石头落了地。"

# game/a13/7recure.rpy:586
translate english recure2_98a16e12:

    # me "Я бы никогда..."
    me "我绝不会..."

# game/a13/7recure.rpy:587
translate english recure2_0f2f680d:

    # cath "Простите. Конечно. Я не должна была сомневаться в вашей добродетели. Но..."
    cath "对不起。当然。我不该怀疑您的德行。但是..."

# game/a13/7recure.rpy:588
translate english recure2_d880fb2a:

    # me "Но вы мать."
    me "但您是一个母亲。"

# game/a13/7recure.rpy:589
translate english recure2_2bb5cf20:

    # cath "Да."
    cath "是的。"

# game/a13/7recure.rpy:590
translate english recure2_ad4e9c95:

    # me "Я вас понимаю."
    me "我理解您。"

# game/a13/7recure.rpy:591
translate english recure2_ff637ffc:

    # cath "Раз уж мы пришли к соглашению... давайте оставим наедине Еву и Эдрика."
    cath "既然我们达成了共识...就让Eva和埃德里克单独待一会儿吧。"

# game/a13/7recure.rpy:592
translate english recure2_8f9071f9_1:

    # me "Конечно."
    me "当然。"

# game/a13/7recure.rpy:594
translate english recure2_e43dfe26:

    # cath "Не знаю, когда это пройдет..."
    cath "不知道这阶段什么时候会过去..."

# game/a13/7recure.rpy:595
translate english recure2_b4e39c68:

    # me "Вы о Еве?"
    me "您是指Eva？"

# game/a13/7recure.rpy:596
translate english recure2_9ff35aeb:

    # cath "Да. Думаю Эдрику сейчас будет тяжело."
    cath "是的。我想埃德里克现在日子会很难过。"

# game/a13/7recure.rpy:597
translate english recure2_a6b31745:

    # me "Он справится."
    me "他能应付。"

# game/a13/7recure.rpy:598
translate english recure2_435c45a3:

    # cath "Надеюсь."
    cath "希望如此。"

# game/a13/7recure.rpy:599
translate english recure2_fc8b1cc5:

    # me "Вы говорили, что испытывали что-то подобное."
    me "您说过您也经历过类似的事。"

# game/a13/7recure.rpy:600
translate english recure2_edef9841:

    # cath "Да. Но все это всегда происходит по-разному. Такие влюбленности очень непостоянны. Могут длиться и очень долго."
    cath "是的。但这种事总是因人而异。这种迷恋非常反复无常。也可能持续很久。"

# game/a13/7recure.rpy:601
translate english recure2_ff479a24:

    # me "Вы долго испытывали это?"
    me "您持续了很长时间吗？"

# game/a13/7recure.rpy:602
translate english recure2_7e046a02:

    # cath "Нет. Мне повезло. Я думаю что Еве тоже станет легче, как только..."
    cath "没有。我很幸运。我想Eva也会轻松些，只要..."

# game/a13/7recure.rpy:603
translate english recure2_22b5d127:

    # me "Как только я отсюда уберусь."
    me "只要我从这儿消失。"

# game/a13/7recure.rpy:604
translate english recure2_a36d0374:

    # cath "Простите."
    cath "请原谅。"

# game/a13/7recure.rpy:605
translate english recure2_db7b0804:

    # me "Все нормально. Я понимаю."
    me "没关系。我理解。"

# game/a13/7recure.rpy:606
translate english recure2_ab531fa5:

    # cath "Она... кхм... наверняка будет страдать первое время. Но... чем больше времени пройдет, тем ей будет легче.."
    cath "她...咳...头一段时间肯定会痛苦。但是...时间越长，她就越轻松..."

# game/a13/7recure.rpy:607
translate english recure2_84c15d81:

    # me "Вы сейчас о чем-то вспоминаете?"
    me "您现在是在回忆什么吗？"

# game/a13/7recure.rpy:608
translate english recure2_d15b847a:

    # cath "Как вы поняли?"
    cath "您怎么看出来的？"

# game/a13/7recure.rpy:610
translate english recure2_117b4cf6:

    # cath "Ох... это все глупости. Когда ты так юн, ты вообще не понимаешь концепции брака. Тебе кажется чудовищным насилием, что мужа тебе выбирает отец."
    cath "唉...都是些傻事。当你那么年轻时，你完全不懂婚姻的概念。你会觉得，由父亲为你选择丈夫是种骇人听闻的暴力。"

# game/a13/7recure.rpy:611
translate english recure2_b35dbbfb:

    # me "Вы любили кого-то до Бориса?"
    me "您在Boris之前爱过别人吗？"

# game/a13/7recure.rpy:612
translate english recure2_a4af392d:

    # cath "Нет. Это нельзя назвать любовью. Любовь строится. Долго и муторно. Куется в браке. А влюбленность... нет. Это совсем другое."
    cath "没有。那称不上是爱。爱是建立起来的。漫长又繁琐。是在婚姻中锻造出来的。而迷恋...不。那完全是另一回事。"

# game/a13/7recure.rpy:613
translate english recure2_3820771a_4:

    # me "..."
    me "..."

# game/a13/7recure.rpy:614
translate english recure2_7b603519:

    # cath "Тяжело объяснить. Это можно только почувствовать. Но разница колоссальная."
    cath "很难解释。只能亲自体会。但差别是天壤之别。"

# game/a13/7recure.rpy:615
translate english recure2_5f1f76a8:

    # me "Я думаю, я понимаю."
    me "我想我明白了。"

# game/a13/7recure.rpy:616
translate english recure2_55d25d55:

    # cath "Правда?"
    cath "真的吗？"

# game/a13/7recure.rpy:617
translate english recure2_fc30fd2b:

    # me "Да."
    me "是的。"

# game/a13/7recure.rpy:618
translate english recure2_02fc255e:

    # cath "Когда-то Борис казался мне... навязанным мне долгом. Другой человек любил меня, а я его. Подумать только, мы даже думали сбежать."
    cath "曾几何时，Boris对我来说...像是强加给我的义务。另一个人爱着我，而我也爱着他。想想看，我们甚至想过私奔。"

# game/a13/7recure.rpy:619
translate english recure2_c2e764e0:

    # me "Ого."
    me "哇哦。"

# game/a13/7recure.rpy:620
translate english recure2_84675fff:

    # cath "Да. Но прошли года и я благодарю безымянного бога, что я не встала на тот путь..."
    cath "是啊。但多年过去，我感谢无名的神，我没有走上那条路..."

# game/a13/7recure.rpy:621
translate english recure2_5ac38cf1:

    # me "Почему?"
    me "为什么？"

# game/a13/7recure.rpy:622
translate english recure2_7cf991c5:

    # cath "Это длинная история. Но когда-нибудь я вам ее расскажу."
    cath "说来话长。但总有一天我会告诉您的。"

# game/a13/7recure.rpy:623
translate english recure2_97983ce5:

    # me "Обязательно послушаю."
    me "我一定洗耳恭听。"

# game/a13/7recure.rpy:628
translate english recure2_c9228cba:

    # me "Ну... вообще-то подобные просьбы предполагают услугу."
    me "嗯...一般来说，提出这种请求是意味着要回报的。"

# game/a13/7recure.rpy:629
translate english recure2_27846d0b:

    # cath "Услугу?"
    cath "回报？"

# game/a13/7recure.rpy:630
translate english recure2_fb59c06f:

    # me "Ну да. Услугу. Это бартер. Вы чего-то хотите от меня. Значит должны что-то предложить."
    me "对。回报。这是交易。您想从我这里得到点什么。那您也得付出些什么。"

# game/a13/7recure.rpy:632
translate english recure2_9fba0e9a:

    # me "Ауч! Какого хрена?"
    me "哎哟！搞什么鬼？"

# game/a13/7recure.rpy:633
translate english recure2_8783f9e6:

    # cath "Я не мясом на рынке торгую, это моя дочь!"
    cath "我可不是在市场卖肉的，那是我女儿！"

# game/a13/7recure.rpy:634
translate english recure2_6ec0009b:

    # me "Вы зачем меня ударили?"
    me "您为什么打我？"

# game/a13/7recure.rpy:635
translate english recure2_d2e91de9:

    # cath "Вы... вы вообще знаете что-нибудь о чести?"
    cath "您...您到底知不知道什么是荣誉？"

# game/a13/7recure.rpy:637
translate english recure2_5b870722:

    # me "Знаю, что после такого я вам точно ничем не обязан."
    me "我只知道，在您这么做之后，我绝对什么都不欠您的了。"

# game/a13/7recure.rpy:638
translate english recure2_a803ba46:

    # cath "Стойте!"
    cath "站住！"

# game/a13/7recure.rpy:639
translate english recure2_e386ee7c:

    # me "И не подумаю. Мы не рынке? Что же вы торгуетесь моей честью? Я не обязан стелиться под каждую дурновоспитанную девку!"
    me "我才不。这不是市场吗？您凭什么用我的荣誉来讨价还价？我没义务对每一个缺乏教养的黄毛丫头卑躬屈膝！"

# game/a13/7recure.rpy:640
translate english recure2_78b4c593:

    # cath "Принц [mename], простите!"
    cath "[mename]王子，请原谅！"

# game/a13/7recure.rpy:641
translate english recure2_0ad1a6e2:

    # me "Прощаю. Но ничего обещать вам не собираюсь."
    me "我原谅您。但我什么都不打算向您保证。"

# game/a13/7recure.rpy:642
translate english recure2_f599df1f:

    # cath "Я просто..."
    cath "我只是..."

# game/a13/7recure.rpy:643
translate english recure2_3271d9f8:

    # me "...просто плохо воспитала дочь и перекладываю ответственность на других."
    me "...只是自己没教好女儿，却把责任推给别人。"

# game/a13/7recure.rpy:644
translate english recure2_152cadb8:

    # cath "Я согласна!"
    cath "我同意！"

# game/a13/7recure.rpy:646
translate english recure2_84b0ee1a:

    # cath "Что вы хотите?"
    cath "您想要什么？"

# game/a13/7recure.rpy:647
translate english recure2_cb7a70e2:

    # me "Уже и не знаю... после того что было..."
    me "现在我也不知道了...在刚才那件事之后..."

