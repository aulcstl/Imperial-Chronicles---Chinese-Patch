# game/a13/7recure.rpy:4
translate english recure_c1d8b998:

    # "На следующее утро."
    "第二天早上。"

# game/a13/7recure.rpy:6
translate english recure_a35602ab:

    # me "{i}...ох... моя голова...{/i}"
    me "{i}...哎哟...我的头...{/i}"

# game/a13/7recure.rpy:7
translate english recure_fa0fdd2c:

    # me "{i}Ее будто железом залили.{/i}"
    me "{i}感觉像灌了铅一样。{/i}"

# game/a13/7recure.rpy:8
translate english recure_5c76dbe7:

    # me "{i}...{/i}"
    me "{i}...{/i}"

# game/a13/7recure.rpy:9
translate english recure_27487dd1:

    # me "{i}Это был сон или...{/i}"
    me "{i}那是个梦，还是...{/i}"

# game/a13/7recure.rpy:10
translate english recure_8ce062e0:

    # me "{i}Буду надеяться, что сон. Хотя что-то мне подсказывает все эти видения реальны.{/i}"
    me "{i}希望只是个梦吧。不过直觉告诉我，那些幻觉都是真的。{/i}"

# game/a13/7recure.rpy:11
translate english recure_1b7d41b0:

    # me "{i}Впрочем, что размышлять - проверю, когда вернусь.{/i}"
    me "{i}算了，想那么多干嘛——等我回去就清楚了。{/i}"

# game/a13/7recure.rpy:13
translate english recure_84cffc65:

    # me "{i}Ух... как же хорошо мне здесь спится.{/i}"
    me "{i}唔...在这儿睡得可真香。{/i}"

# game/a13/7recure.rpy:14
translate english recure_9ecf34f5:

    # me "{i}Этот дипломатический вояж мне явно на пользу.{/i}"
    me "{i}这次外交旅行对我确实有好处。{/i}"

# game/a13/7recure.rpy:15
translate english recure_69e000e3:

    # me "{i}Даже жаль, что скоро мне снова будет пора отправляться в дорогу.{/i}"
    me "{i}都有点可惜了，我很快就又要上路。{/i}"

# game/a13/7recure.rpy:16
translate english recure_c433f804:

    # me "{i}...может еще пару часов поспать?{/i}"
    me "{i}...也许能再睡几个小时？{/i}"

# game/a13/7recure.rpy:17
translate english recure_f6a45cd8:

    # me "{i}Нет... нет... или да? Нет.{/i}"
    me "{i}不...不行...还是...行？不行。{/i}"

# game/a13/7recure.rpy:19
translate english recure_818a51a7:

    # me "{i}Пора вставать.{/i}"
    me "{i}该起床了。{/i}"

# game/a13/7recure.rpy:22
translate english recure_0f476a5d:

    # "Чуть позже."
    "过了一会。"

# game/a13/7recure.rpy:23
translate english recure_26fb4764:

    # cass "Все наши люди уже в замке - я отправляюсь сегодня."
    cass "我们的人都已经到城堡了——我今天就出发。"

# game/a13/7recure.rpy:24
translate english recure_9fe0f573:

    # me "Отлично. Последую за тобой завтра же. Мы определились с маршрутом?"
    me "很好。我明天就跟着你走。路线定好了吗？"

# game/a13/7recure.rpy:25
translate english recure_037dd93c:

    # cass "Тут одна дорога, не ошибешься."
    cass "就一条路，走不岔的。"

# game/a13/7recure.rpy:26
translate english recure_f8473367:

    # me "Пока что одна."
    me "目前只有一条。"

# game/a13/7recure.rpy:27
translate english recure_7a671f6c:

    # cass "Я буду встречать тебя в каждом замке по пути и говорить куда отправляюсь в следующий раз."
    cass "我会在沿途每个城堡等你，然后告诉你我接下来去哪儿。"

# game/a13/7recure.rpy:28
translate english recure_a9e89568:

    # me "Ага. И так я снова твой хвост."
    me "啊哈。这么说我又成了你的小跟班。"

# game/a13/7recure.rpy:29
translate english recure_26b99aa9:

    # cass "Не начинай. Я же не говорю тебе, что делать."
    cass "别又来这套。我又没指挥你做事。"

# game/a13/7recure.rpy:30
translate english recure_b645034b:

    # me "Ну да. Просто едешь впереди."
    me "嗯，没错。你只是走在前头而已。"

# game/a13/7recure.rpy:31
translate english recure_365a2f01:

    # cass "Я не собираюсь вести переговоры с этими напыщенными ублюдками, не волнуйся, оставлю это удовольствие тебе."
    cass "我可没打算跟那群傲慢的混蛋谈判，别担心，这份“乐趣”留给你。"

# game/a13/7recure.rpy:32
translate english recure_4c74c8d3:

    # me "В чем же тогда смысл?"
    me "那这有什么意义？"

# game/a13/7recure.rpy:33
translate english recure_582c80f8:

    # cass "Смысл в том, чтобы заранее искать болевые точки, на которые ты будешь нажимать."
    cass "意义在于，提前找到那些你能施压的痛处。"

# game/a13/7recure.rpy:34
translate english recure_1c5d39f3:

    # me "А... понимаю. Всегда приятнее вести переговоры, когда знаешь... О ЧЕМ надо говорить."
    me "啊...我明白了。谈判的时候，要是知道...该“聊”些什么，总是更愉快的。"

# game/a13/7recure.rpy:35
translate english recure_a63dc8e7:

    # cass "Умница. Рада, что хотя бы сейчас тебе не пришлось разжевывать. Еще чуть-чуть и мы станем полноценной командой."
    cass "聪明。很高兴这次总算不用我给你嚼碎了喂。再这么下去，我们很快就成一支完美的团队了。"

# game/a13/7recure.rpy:36
translate english recure_dbf7e171:

    # me "Равноценной командой."
    me "——一支旗鼓相当的团队。"

# game/a13/7recure.rpy:37
translate english recure_a7e62985:

    # cass "Типо того."
    cass "差不多吧。"

# game/a13/7recure.rpy:39
translate english recure_d311db43:

    # aurora "[cass]!"
    aurora "[cass]!"

# game/a13/7recure.rpy:40
translate english recure_78968d99:

    # cass "Аврора. Рада тебя видеть."
    cass "Aurora。很高兴见到你。"

# game/a13/7recure.rpy:41
translate english recure_4535c45f:

    # aurora "Я тоже. Жаль это не так часто происходит."
    aurora "我也是。可惜这样的机会不多。"

# game/a13/7recure.rpy:42
translate english recure_d46940d0:

    # cass "Ну как же... а сейчас?"
    cass "怎么会...现在不就是吗？"

# game/a13/7recure.rpy:43
translate english recure_cbea1ac9:

    # aurora "Да, но... мой отец приглашал тебя к нам за стол. Ты ни разу не пришла."
    aurora "是，可是...我父亲邀请过你来我们家一起用餐，你一次都没来过。"

# game/a13/7recure.rpy:44
translate english recure_ac5ae1b0:

    # cass "Прости, с детства не люблю семейные застолья."
    cass "抱歉，我从小就讨厌家庭聚餐。"

# game/a13/7recure.rpy:45
translate english recure_c2c34c46:

    # aurora "Очень жаль это слышать. Надеюсь ты не отказываешься, потому что думаешь, что тебе там не место. Мы были бы рады тебя видеть, да [mename]?"
    aurora "听你这么说真遗憾。希望你不是因为觉得那儿没你的位置才拒绝的。我们会很高兴见到你，对吧，[mename]？"

# game/a13/7recure.rpy:46
translate english recure_e77d71b4:

    # me "Именно."
    me "正是。"

# game/a13/7recure.rpy:47
translate english recure_0ab0f583:

    # cass "Приятно это слышать, Аврора. Но я, правда, больше люблю есть в одиночку."
    cass "听你这么说很欣慰，Aurora。但我确实更喜欢独自用餐。"

# game/a13/7recure.rpy:48
translate english recure_f20921e6:

    # aurora "Но ты и в замке почти не появляешься."
    aurora "但你几乎都不在城堡里露面。"

# game/a13/7recure.rpy:49
translate english recure_16be0ce4:

    # cass "У вас такие красивые виды, было бы кощунством проводить все время зажатой в крепостные стены."
    cass "你们这儿的景色太美了，要是整天困在城墙里，那简直是种亵渎。"

# game/a13/7recure.rpy:50
translate english recure_4e8e47e1:

    # aurora "Оу... ну я рада, что тебе нравится."
    aurora "哦...好吧，很高兴你喜欢。"

# game/a13/7recure.rpy:51
translate english recure_99bd063f:

    # cass "Конечно, нравится."
    cass "我当然喜欢。"

# game/a13/7recure.rpy:52
translate english recure_b7093a0a:

    # aurora "Может хотя бы сегодня с нами поужинаешь."
    aurora "那至少今晚跟我们一起吃晚饭吧？"

# game/a13/7recure.rpy:53
translate english recure_8e4e99b3:

    # cass "Боюсь я прямо сейчас уезжаю."
    cass "恐怕我马上就得走了。"

# game/a13/7recure.rpy:54
translate english recure_fef247f4:

    # aurora "Обратно в Золотую Столицу?"
    aurora "回黄金都城去？"

# game/a13/7recure.rpy:55
translate english recure_290d7713:

    # cass "Не совсем. Буду помогать твоему мужу в путешествии."
    cass "不完全是。我会在旅途中帮助你的丈夫。"

# game/a13/7recure.rpy:56
translate english recure_8c07e979:

    # aurora "Понятно."
    aurora "明白了。"

# game/a13/7recure.rpy:57
translate english recure_15f3ea55:

    # cass "Еще увидимся."
    cass "回头见。"

# game/a13/7recure.rpy:60
translate english recure_ad994ed0:

    # slug "{size=+5}О, БОЖЕ!{/size}"
    slug "{size=+5}噢，天哪！{/size}"

# game/a13/7recure.rpy:61
translate english recure_57274eea:

    # aurora "Слышали?"
    aurora "听到了吗？"

# game/a13/7recure.rpy:62
translate english recure_6a18f3cb:

    # cass "Ага."
    cass "嗯。"

# game/a13/7recure.rpy:63
translate english recure_eb655f0d:

    # me "[cass]?"
    me "[cass]?"

# game/a13/7recure.rpy:64
translate english recure_c6ae7b6a:

    # cass "Я к этому, что бы это ни было, отношения не имею, клянусь."
    cass "不管这是什么，我发誓跟我没关系。"

# game/a13/7recure.rpy:65
translate english recure_f6e9a1db:

    # aurora "Нужно пойти проверить."
    aurora "得去看看。"

# game/a13/7recure.rpy:66
translate english recure_4a663527:

    # cass "Сами справитесь?"
    cass "你们自己行吗？"

# game/a13/7recure.rpy:67
translate english recure_6f29a469:

    # me "Справимся."
    me "没问题。"

# game/a13/7recure.rpy:68
translate english recure_57171702:

    # aurora "Может позвать стражу?"
    aurora "要不要叫卫兵？"

# game/a13/7recure.rpy:69
translate english recure_893d96a4:

    # cass "По-моему она уже там."
    cass "我看他们已经在那边了。"

# game/a13/7recure.rpy:70
translate english recure_e47914f8:

    # me "Тогда пойдем и посмотрим."
    me "那我们就去看看。"

# game/a13/7recure.rpy:76
translate english recure_6828450f:

    # me "{i}Все остальные с корабля прибудут сегодня.{/i}"
    me "{i}船上的其他人今天就会到。{/i}"

# game/a13/7recure.rpy:77
translate english recure_dce3edc9:

    # me "{i}Можно начинать готовится к отбытию.{/i}"
    me "{i}可以开始准备出发了。{/i}"

# game/a13/7recure.rpy:78
translate english recure_2103e2ef:

    # me "{i}Да уж... не думал, что так задержусь.{/i}"
    me "{i}唉...真没想到会耽搁这么久。{/i}"

# game/a13/7recure.rpy:79
translate english recure_70e261be:

    # me "{i}Впрочем чего я ожидал? Это явно не могло быть легкой прогулкой.{/i}"
    me "{i}不过我又能指望什么呢？这显然不可能是一次轻松的散步。{/i}"

# game/a13/7recure.rpy:81
translate english recure_6c13b6a9:

    # aurora "[mename]!"
    aurora "[mename]!"

# game/a13/7recure.rpy:82
translate english recure_1ccac3f2:

    # me "Аврора."
    me "Aurora。"

# game/a13/7recure.rpy:83
translate english recure_1ca1a252:

    # aurora "Отцу доложили, что караван движется в сторону замка."
    aurora "有人向父亲禀报，说商队正朝城堡来。"

# game/a13/7recure.rpy:84
translate english recure_73bb439f:

    # me "Да. Я уже в курсе."
    me "嗯。我已经知道了。"

# game/a13/7recure.rpy:85
translate english recure_5fcaeb1a:

    # aurora "Это значит ты скоро отправишься в путь?"
    aurora "这意味着你很快就要上路了吧？"

# game/a13/7recure.rpy:86
translate english recure_0195cae4:

    # me "Думаю завтра утром."
    me "我想是明天早上。"

# game/a13/7recure.rpy:87
translate english recure_1bd1dcf7:

    # aurora "Ты ведь согласился на предложение отца о сопровождении?"
    aurora "你答应了父亲派人护送的建议吗？"

# game/a13/7recure.rpy:88
translate english recure_45240418:

    # me "Пусть отправляет вслед. Я поеду налегке. Небольшого отряда хватит."
    me "让他们随后跟来吧。我轻装上路。一支小队就够了。"

# game/a13/7recure.rpy:89
translate english recure_f9f9595c:

    # aurora "Уверен?"
    aurora "你确定？"

# game/a13/7recure.rpy:90
translate english recure_4a6ee51e:

    # me "Уверен. Или я до зимы точно не справлюсь."
    me "确定。不然到下雪前我肯定完不成任务。"

# game/a13/7recure.rpy:91
translate english recure_a3f5b98b:

    # aurora "...может хотя бы..."
    aurora "...那至少..."

# game/a13/7recure.rpy:92
translate english recure_5fab84f5:

    # me "Не волнуйся, Аврора. Я буду в порядке. Я просто поеду по единственной дороге от замка к замку. Обещаю не влезать в неприятности."
    me "别担心，Aurora。我会没事的。我会沿着唯一的路，从一座城堡到另一座城堡。我保证不惹麻烦。"

# game/a13/7recure.rpy:93
translate english recure_19c6e8a9:

    # aurora "Хорошо, [mename], я тебе верю."
    aurora "好的，[mename]，我相信你。"

# game/a13/7recure.rpy:96
translate english recure_ad994ed0_1:

    # slug "{size=+5}О, БОЖЕ!{/size}"
    slug "{size=+5}噢，天哪！{/size}"

# game/a13/7recure.rpy:97
translate english recure_fcd0adde:

    # me "Это еще что?"
    me "这又是什么声音？"

# game/a13/7recure.rpy:98
translate english recure_26422bd8:

    # aurora "Не знаю."
    aurora "不知道。"

# game/a13/7recure.rpy:99
translate english recure_82965915:

    # me "Посмотрим?"
    me "去看看？"

# game/a13/7recure.rpy:100
translate english recure_cf8b39b3:

    # aurora "Не уверена. Может позовем стражу?"
    aurora "我不太确定。要不要叫卫兵？"

# game/a13/7recure.rpy:101
translate english recure_bdade29f:

    # me "Они уже и так там."
    me "他们已经在那儿了。"

# game/a13/7recure.rpy:102
translate english recure_9deddb2c:

    # aurora "Ладно... тогда давай проверим."
    aurora "好吧...那我们去看看。"

# game/a13/7recure.rpy:108
translate english recure_6828450f_1:

    # me "{i}Все остальные с корабля прибудут сегодня.{/i}"
    me "{i}船上的其他人今天就会到。{/i}"

# game/a13/7recure.rpy:109
translate english recure_dce3edc9_1:

    # me "{i}Можно начинать готовится к отбытию.{/i}"
    me "{i}可以开始准备出发了。{/i}"

# game/a13/7recure.rpy:110
translate english recure_2103e2ef_1:

    # me "{i}Да уж... не думал, что так задержусь.{/i}"
    me "{i}唉...真没想到会耽搁这么久。{/i}"

# game/a13/7recure.rpy:111
translate english recure_70e261be_1:

    # me "{i}Впрочем чего я ожидал? Это явно не могло быть легкой прогулкой.{/i}"
    me "{i}不过我又能指望什么呢？这显然不可能是一次轻松的散步。{/i}"

# game/a13/7recure.rpy:114
translate english recure_ad994ed0_2:

    # slug "{size=+5}О, БОЖЕ!{/size}"
    slug "{size=+5}噢，天哪！{/size}"

# game/a13/7recure.rpy:115
translate english recure_b95d10f4:

    # me "{i}Это еще что?{/i}"
    me "{i}这又是什么情况？{/i}"

# game/a13/7recure.rpy:116
translate english recure_8423e007:

    # me "{i}Женский крик. И стража там.{/i}"
    me "{i}女人的尖叫声。卫兵也在那边。{/i}"

# game/a13/7recure.rpy:117
translate english recure_f8e87340:

    # me "{i}Надеюсь не случилось ничего, что вдруг помешает моим планам в последний момент?{/i}"
    me "{i}希望别在最后关头出什么岔子，打乱我的计划。{/i}"

# game/a13/7recure.rpy:118
translate english recure_2b20f34b:

    # me "{i}Пойду проверю.{/i}"
    me "{i}我去看看。{/i}"

# game/a13/7recure.rpy:122
translate english recure_26c9acfa:

    # me "{i}Надо собирать вещи...{/i}"
    me "{i}得收拾行李了...{/i}"

# game/a13/7recure.rpy:123
translate english recure_4e9a24a4:

    # me "{i}Хотя зачем это делать мне? Я и забыл, что я принц.{/i}"
    me "{i}不过，这干嘛要我做？我都忘了我还是个王子。{/i}"

# game/a13/7recure.rpy:124
translate english recure_65a00d28:

    # me "{i}Надо отдать приказ собирать вещи.{/i}"
    me "{i}该下令让他们给我收拾行李。{/i}"

# game/a13/7recure.rpy:128
translate english recure_eva1_8820ee16:

    # slug "О, неведомый, защити меня, идущую по твоим путям..."
    slug "哦，无名之神，请保佑我，行走在你道路上的仆人..."

# game/a13/7recure.rpy:129
translate english recure_eva1_ac598c40:

    # strazh "Что произошло?"
    strazh "发生什么事了？"

# game/a13/7recure.rpy:130
translate english recure_eva1_b5d1a93e:

    # slug "Я обещаю быть верной тебе, следовать за твоим голосом, как за своим..."
    slug "我发誓忠于您，追随您的声音，如同追随我心..."

# game/a13/7recure.rpy:131
translate english recure_eva1_85cc40fe:

    # strazh "Прекрати лопотать, говори со мной."
    strazh "别念叨了，跟我说话。"

# game/a13/7recure.rpy:132
translate english recure_eva1_0f25da26:

    # slug "Пути неведомого бога бесчисленны..."
    slug "无名之神的道路数不胜数..."

# game/a13/7recure.rpy:133
translate english recure_eva1_2d07537f:

    # strazh "Я выбью тебе зубы, если ты не начнешь говорить со мной, вместо твоего бога."
    strazh "你再不跟我说话，只顾着跟你神叨叨，我就打掉你的牙。"

# game/a13/7recure.rpy:134
translate english recure_eva1_e6d62fa3:

    # slug "Я шла.. и..."
    slug "我走...走着...然后..."

# game/a13/7recure.rpy:135
translate english recure_eva1_4ba1b80d:

    # strazh "И?"
    strazh "然后？"

# game/a13/7recure.rpy:136
translate english recure_eva1_5456a7ae:

    # slug "И увидела ее. Я испугалась. Потрогала ее, а она холодная."
    slug "就看到她了。我吓坏了。我碰了碰她，她是冷的。"

# game/a13/7recure.rpy:137
translate english recure_eva1_7df8ef4c:

    # strazh "Ясно."
    strazh "明白了。"

# game/a13/7recure.rpy:140
translate english recure_eva1_fee863bd:

    # aurora "О, неведомый, какой ужас!"
    aurora "哦，无名之神，太可怕了！"

# game/a13/7recure.rpy:141
translate english recure_eva1_63b11793:

    # slug "Пути неведомого бога бесчисленны...Пути неведомого бога бесчисленны..."
    slug "无名之神的道路数不胜数... 无名之神的道路数不胜数..."

# game/a13/7recure.rpy:142
translate english recure_eva1_ee592b74:

    # strazh "Хватит."
    strazh "够了。"

# game/a13/7recure.rpy:143
translate english recure_eva1_81182b06:

    # aurora "Как это произошло?"
    aurora "这是怎么发生的？"

# game/a13/7recure.rpy:144
translate english recure_eva1_13c19dcf:

    # me "Ну и дела."
    me "这下可好。"

# game/a13/7recure.rpy:145
translate english recure_eva1_b09cc74c:

    # slug "Ее убили?"
    slug "她是被杀的吗？"

# game/a13/7recure.rpy:146
translate english recure_eva1_0f548489:

    # strazh "Понятия не имею."
    strazh "完全没头绪。"

# game/a13/7recure.rpy:147
translate english recure_eva1_95929ad6:

    # aurora "Нужно.. нужно позвать моего отца."
    aurora "得...得去叫我父亲。"

# game/a13/7recure.rpy:148
translate english recure_eva1_423043a6:

    # me "Да..."
    me "是啊..."

# game/a13/7recure.rpy:149
translate english recure_eva1_1e2db102:

    # strazh "Уже позвали, моя принцесса."
    strazh "已经去叫了，我的公主。"

# game/a13/7recure.rpy:150
translate english recure_eva1_c1293d3d:

    # aurora "Какой кошмар... Она... ее ноги..."
    aurora "太可怕了...她的...她的腿..."

# game/a13/7recure.rpy:151
translate english recure_eva1_507992a5:

    # me "Похоже на перелом. Кто мог такое сделать?"
    me "看起来像是骨折了。谁会做出这种事？"

# game/a13/7recure.rpy:152
translate english recure_eva1_4bcb0ef9:

    # slug "Может быть духи гор?"
    slug "也许是山中的精怪？"

# game/a13/7recure.rpy:153
translate english recure_eva1_4a717395:

    # strazh "Не лепи чепуху, ты пугаешь принцессу."
    strazh "别说胡话，你吓到公主了。"

# game/a13/7recure.rpy:154
translate english recure_eva1_4c8df7c1:

    # me "Где ее ботинок?"
    me "她的鞋去哪儿了？"

# game/a13/7recure.rpy:157
translate english recure_eva1_85a8b9d0:

    # me "Ух ты..."
    me "嚯..."

# game/a13/7recure.rpy:158
translate english recure_eva1_d4172704:

    # strazh "Принц [mename], вам необязательно на это смотреть."
    strazh "[mename]王子，您不必看这个。"

# game/a13/7recure.rpy:159
translate english recure_eva1_115a4691:

    # me "Все нормально, я уже видел трупы в своей жизни."
    me "没关系，我这辈子又不是没见过尸体。"

# game/a13/7recure.rpy:160
translate english recure_eva1_9358a1db:

    # slug "Какой ужас...Пути неведомого бога бесчисленны, а значит каждый...."
    slug "太可怕了...无名之神的道路数不胜数，也就是说，每个人..."

# game/a13/7recure.rpy:161
translate english recure_eva1_adf64c7b:

    # strazh "Хватит. Бог не поможет, она уже мертва."
    strazh "够了。神帮不了她，她已经死了。"

# game/a13/7recure.rpy:162
translate english recure_eva1_225bffff:

    # me "Ее ноги... похоже у нее вывих или перелом."
    me "她的腿...似乎是脱臼或是骨折了。"

# game/a13/7recure.rpy:163
translate english recure_eva1_0ef7f270:

    # slug "У нее ботинка нет."
    slug "她少了一只鞋。"

# game/a13/7recure.rpy:164
translate english recure_eva1_a9a2fb5a:

    # strazh "Действительно."
    strazh "确实。"

# game/a13/7recure.rpy:165
translate english recure_eva1_03f41cc0:

    # me "Кто мог такое сделать? Кто-то явно большой."
    me "谁能干出这种事？肯定是个大家伙。"

# game/a13/7recure.rpy:166
translate english recure_eva1_4a717395_1:

    # slug "Если это вообще был человек!"
    slug "如果那玩意是人的话！"

# game/a13/7recure.rpy:167
translate english recure_eva1_4089d21a:

    # strazh "Заткнись, говорю. "
    strazh "我说了，闭嘴。"

# game/a13/7recure.rpy:168
translate english recure_eva1_d0ea5d9d:

    # slug "Могу я уйти?"
    slug "我能走了吗？"

# game/a13/7recure.rpy:169
translate english recure_eva1_92387ca7:

    # strazh "Нет, мы ждем Лорда Дубовицкого."
    strazh "不行，等Dubovitsky领主来了再说。"

# game/a13/7recure.rpy:171
translate english recure_eva1_94b14de2:

    # dubov "Что здесь такое?"
    dubov "这儿发生什么事了？"

# game/a13/7recure.rpy:172
translate english recure_eva1_605a4aae:

    # strazh "Труп, мой король."
    strazh "一具尸体，我的国王。"

# game/a13/7recure.rpy:173
translate english recure_eva1_9e9507dd:

    # dubov "Я вижу, что труп. Кто это сделал?"
    dubov "我看得见是尸体。是谁干的？"

# game/a13/7recure.rpy:174
translate english recure_eva1_5a8741fb:

    # strazh "Не знаю, мой лорд. Утренняя прислуга нашла его. Вон стоит."
    strazh "我不知道，大人。是早班的仆从发现的。她就在那边站着。"

# game/a13/7recure.rpy:175
translate english recure_eva1_c515b926:

    # slug "Я шла на кухню, а она... она мертвая лежит. Холодная. Давно значит."
    slug "我正要去厨房，就看到她...她躺在那儿，死了。身子冰冷。说明死了很久了。"

# game/a13/7recure.rpy:176
translate english recure_eva1_651d6c49:

    # dubov "Может и не давно. Ночи уже холодные. Она бы и за час остыла."
    dubov "也许不是很久。夜里已经很冷了。她可能一个小时内就凉了。"

# game/a13/7recure.rpy:177
translate english recure_eva1_2d66709e:

    # strazh "Караулы проверяют друг друга каждые два часа, мой король."
    strazh "巡逻的卫兵每两小时换岗一次，我的国王。"

# game/a13/7recure.rpy:178
translate english recure_eva1_e590d3cc:

    # dubov "И сколько до следующего?"
    dubov "距离下一次换岗还有多久？"

# game/a13/7recure.rpy:179
translate english recure_eva1_d9d8dfab:

    # strazh "Полчаса, не больше."
    strazh "最多半小时。"

# game/a13/7recure.rpy:180
translate english recure_eva1_fa9abc6b:

    # dubov "А принц?"
    dubov "那王子呢？"

# game/a13/7recure.rpy:181
translate english recure_eva1_6909824e:

    # me "Я только что проснулся, меня видели слуги."
    me "我刚睡醒，仆人们可以作证。"

# game/a13/7recure.rpy:182
translate english recure_eva1_5d87cb20:

    # strazh "Он говорит правду, мой король."
    strazh "他说的是实话，我的国王。"

# game/a13/7recure.rpy:183
translate english recure_eva1_ed8c3953:

    # dubov "Ох... неведомый. Ладно, мне кажется тут загадка не сильно сложная."
    dubov "唉...无名之神。好了，依我看，这谜题不算太难。"

# game/a13/7recure.rpy:185
translate english recure_eva1_a94bb9b7:

    # dubov "Она упала вон оттуда. С восточной башни."
    dubov "她是从那上面掉下来的。从东塔。"

# game/a13/7recure.rpy:186
translate english recure_eva1_20a41173:

    # slug "Упала?"
    slug "掉下来？"

# game/a13/7recure.rpy:187
translate english recure_eva1_28e9a77c:

    # dubov "Или ей помогли упасть."
    dubov "或者是有人帮她“掉”下来的。"

# game/a13/7recure.rpy:188
translate english recure_eva1_4f73b905:

    # strazh "Как вы поняли, мой король?"
    strazh "您是怎么看出来的，我的国王？"

# game/a13/7recure.rpy:189
translate english recure_eva1_85b08ed2:

    # dubov "Следов борьбы не видно, крови почти нет. Только на лице и затылке немного. Неестественная поза."
    dubov "没有挣扎的痕迹，几乎没有血迹。只有脸和后脑勺有一点。姿势很不自然。"

# game/a13/7recure.rpy:190
translate english recure_eva1_84851a5f:

    # strazh "Может ее ударили по затылку?"
    strazh "会不会是有人打了她的后脑勺？"

# game/a13/7recure.rpy:191
translate english recure_eva1_f758e6ef:

    # dubov "Выражение лица странное. Видимо испугалась перед смертью. Да и ботинок отлетел - такое часто бывает при падении."
    dubov "脸上的表情很奇怪。看来死前受了惊吓。而且鞋子也掉了——摔下来时经常这样。"

# game/a13/7recure.rpy:192
translate english recure_eva1_0f10eb14:

    # strazh "Что она там делала?"
    strazh "她在那里做什么？"

# game/a13/7recure.rpy:193
translate english recure_eva1_b957fa99:

    # slug "Это Ольга. Она должна была следить за Евой по вашему приказу."
    slug "这是奥尔加。按您的命令，她本应看守着Eva。"

# game/a13/7recure.rpy:194
translate english recure_eva1_58ef6c10:

    # dubov "Пошли людей."
    dubov "派人去查看。"

# game/a13/7recure.rpy:195
translate english recure_eva1_d1e22f93:

    # strazh "Да, мой лорд."
    strazh "是，大人。"

# game/a13/7recure.rpy:196
translate english recure_eva1_222981c2:

    # dubov "И что значит 'должна была'?"
    dubov "还有，“本应”是什么意思？"

# game/a13/7recure.rpy:197
translate english recure_eva1_cd84a5ab:

    # slug "Она поменялась с другой девушкой."
    slug "她和另一个女孩换了班。"

# game/a13/7recure.rpy:198
translate english recure_eva1_1e7e46f5:

    # dubov "Почему?"
    dubov "为什么？"

# game/a13/7recure.rpy:199
translate english recure_eva1_8f3d09fa:

    # slug "Я не знаю. Просто вернулась и поменялась."
    slug "我不知道。她只是回到住处，然后就跟人换了。"

# game/a13/7recure.rpy:200
translate english recure_eva1_0790399d:

    # dubov "Разве слугам решать, кто именно будет выполнять мой приказ? "
    dubov "什么时候轮到仆人来决定由谁执行我的命令了？"

# game/a13/7recure.rpy:201
translate english recure_eva1_c941a832:

    # slug "Простите, мой король, я не знаю. Я так не делаю. Она вчера пришла и сильно попросила поменяться с одной из девушек. С Натой, кажется."
    slug "对不起，国王陛下，我不知道。我不会这么做的。她昨天回来，苦苦哀求跟一个女孩换班。好像是跟娜塔换的。"

# game/a13/7recure.rpy:202
translate english recure_eva1_b4831566:

    # dubov "А что должна была делать Ната?"
    dubov "那娜塔本来该做什么？"

# game/a13/7recure.rpy:203
translate english recure_eva1_bd6acfda:

    # slug "Убираться в восточной башне."
    slug "清扫东塔。"

# game/a13/7recure.rpy:204
translate english recure_eva1_d77de88a:

    # dubov "Восточной? Видимо уборка пошла не по плану."
    dubov "东塔？看来清扫工作没按计划进行啊。"

# game/a13/7recure.rpy:206
translate english recure_eva1_80a99db9:

    # strazh "Все в порядке, мой король. Ваша дочь и слуга, что ее охраняла живы и здоровы. Мы на всякий случай вывели их из башни."
    strazh "一切正常，我的国王。您的女儿和护卫她的仆人安然无恙。为以防万一，我们已经把她们带离了塔楼。"

# game/a13/7recure.rpy:207
translate english recure_eva1_1ffafd5a:

    # dubov "Хорошо. Проверьте восточную башню тоже, мы используем ее для переговоров, не хотелось бы неприятных сюрпризов. Да и вообще, прочешите весь замок. Ищите чужаков."
    dubov "很好。也检查一下东塔，我们要用它来进行谈判，我可不想有任何不愉快的意外。对了，彻底搜查整座城堡。寻找陌生人。"

# game/a13/7recure.rpy:208
translate english recure_eva1_d1e22f93_1:

    # strazh "Да, мой лорд."
    strazh "是，大人。"

# game/a13/7recure.rpy:209
translate english recure_eva1_d59aa776:

    # slug "О, боже.. О боже..."
    slug "哦，天哪...哦，天哪..."

# game/a13/7recure.rpy:210
translate english recure_eva1_f374f838:

    # me "{i}Что-то мне подсказывает, что я знаю, кто за этим стоит.{/i}"
    me "{i}直觉告诉我，我知道这是谁干的。{/i}"

# game/a13/7recure.rpy:211
translate english recure_eva1_e6edd943:

    # me "{i}Зачем ей это? Поменялись... должна была следить за Евой... стойте... это же та слуга, что застала нас за... непотребством..{/i}"
    me "{i}她为什么要这么做？换班...本应看守Eva...等等...这不就是那个撞见我们...不成体统的仆人吗...{/i}"

# game/a13/7recure.rpy:212
translate english recure_eva1_f32d2351:

    # me "{i}Она убила ее за это? С ума сойти. Я ожидал от нее чего угодно, но это...{/i}"
    me "{i}她为此杀了她？真是疯了。我料到她会做出任何事，但这...{/i}"

# game/a13/7recure.rpy:213
translate english recure_eva1_b61fc94e:

    # dubov "Вы что-нибудь знаете об этом, принц?"
    dubov "您对此事知道些什么吗，王子？"

# game/a13/7recure.rpy:214
translate english recure_eva1_76104d0f:

    # me "Я только что проснулся, меня видели слуги."
    me "我刚睡醒，仆人们可以作证。"

# game/a13/7recure.rpy:215
translate english recure_eva1_cbb3c831:

    # dubov "Я вас не обвиняю. Просто спрашиваю."
    dubov "我不是在指责您。只是问问。"

# game/a13/7recure.rpy:216
translate english recure_eva1_397fbe41:

    # me "Нет, я ничего не знаю."
    me "不，我不知道。"

# game/a13/7recure.rpy:217
translate english recure_eva1_2915b928:

    # me "{i}Я почти уверен, что это она.{/i}"
    me "{i}我几乎可以肯定就是她干的。{/i}"

# game/a13/7recure.rpy:218
translate english recure_eva1_ba9661a3:

    # strazh "В восточной башне все чисто."
    strazh "东塔一切正常。"

# game/a13/7recure.rpy:219
translate english recure_eva1_442acb0b:

    # dubov "Хм..."
    dubov "唔..."

# game/a13/7recure.rpy:220
translate english recure_eva1_dfd802ef:

    # me "{i}Она ведь была под замком всю ночь... как она это сделала?{/i}"
    me "{i}她可是被锁了一整晚...她是怎么做到的？{/i}"

# game/a13/7recure.rpy:221
translate english recure_eva1_9bd4a0e2:

    # me "{i}Но это она... это должна быть она.{/i}"
    me "{i}但就是她...一定是她。{/i}"

# game/a13/7recure.rpy:222
translate english recure_eva1_da575ae8:

    # strazh "Я не понимаю, зачем кому-то убивать слугу?"
    strazh "我不明白，谁会想杀一个仆人？"

# game/a13/7recure.rpy:223
translate english recure_eva1_e00272dd:

    # dubov "Может приревновал кто-нибудь? Какой-нибудь стражник, увидел что его любимая уединилась в башне с другим? Подождал и под утро отомстил."
    dubov "也许是有人吃醋了？某个卫兵，看见他心爱的人在塔里和别人幽会？于是等到凌晨，然后报复。"

# game/a13/7recure.rpy:224
translate english recure_eva1_e25535d1:

    # strazh "Мой король..."
    strazh "我的国王..."

# game/a13/7recure.rpy:225
translate english recure_eva1_4a94838b:

    # dubov "Да ладно, не делай из меня идиота."
    dubov "行了，别把我当傻瓜。"

# game/a13/7recure.rpy:226
translate english recure_eva1_09db7a7e:

    # strazh "Вы запрещаете..."
    strazh "您禁止..."

# game/a13/7recure.rpy:227
translate english recure_eva1_473404ca:

    # dubov "То что я запрещаю, еще не значит, что вы этого не делаете. Зачем ей меняться с другой слугой? Хотелось остаться в башне наедине с кем-то?"
    dubov "我禁止的事，不代表你们就不会去做。她为什么要和别的仆人换班？是想单独和谁留在塔里吗？"

# game/a13/7recure.rpy:228
translate english recure_eva1_c55dc37a:

    # me "{i}А может... нет, это не может быть совпадением. Она видит нас, целующихся и вот, меньше чем через день, она мертва.{/i}"
    me "{i}难道说...不，这不可能是巧合。她看到我们在接吻，然后不到一天，她就死了。{/i}"

# game/a13/7recure.rpy:229
translate english recure_eva1_e9318137:

    # dubov "Выкладывай, что знаешь."
    dubov "说吧，把你知道的都说出来。"

# game/a13/7recure.rpy:230
translate english recure_eva1_65227938:

    # me "{i}Я?{/i}"
    me "{i}我？{/i}"

# game/a13/7recure.rpy:231
translate english recure_eva1_e25535d1_1:

    # strazh "Мой король..."
    strazh "我的国王..."

# game/a13/7recure.rpy:232
translate english recure_eva1_0b1a307a:

    # dubov "И я хочу поговорить со всем стражниками и слугами в замке. Любой, у кого кончится дежурство и он минует мой кабинет считается убийцей, ясно?"
    dubov "我还要跟城堡里所有的卫兵和仆人谈谈。任何人，值勤结束后若绕过我的书房，一律视为凶手，明白吗？"

# game/a13/7recure.rpy:233
translate english recure_eva1_d1e22f93_2:

    # strazh "Да, мой лорд."
    strazh "是，大人。"

# game/a13/7recure.rpy:234
translate english recure_eva1_1957bbec:

    # dubov "Вы можете идти, принц."
    dubov "您可以走了，王子。"

# game/a13/7recure.rpy:238
translate english recure2_7dac0600:

    # "Пару часов спустя."
    "几个小时以后。"

# game/a13/7recure.rpy:239
translate english recure2_c8e4a2dc:

    # me "{i}Удивительно, этот замок выглядит гораздо меньше снаружи.{/i}"
    me "{i}真奇怪，这城堡从外面看起来要小得多。{/i}"

# game/a13/7recure.rpy:240
translate english recure2_ebf4cf8b:

    # me "{i}Оно все еще меньше, чем дворец и замок в Золотой Столице, но все равно впечатляет.{/i}"
    me "{i}虽然还是比黄金都城的王宫和城堡小，但依旧令人印象深刻。{/i}"

# game/a13/7recure.rpy:241
translate english recure2_a40c213f:

    # me "{i}Я уж точно не думал, что Север удивит меня своим богатством.{/i}"
    me "{i}我确实没想到北方能用它的财富让我惊讶。{/i}"

# game/a13/7recure.rpy:242
translate english recure2_4b0065f0:

    # me "{i}Хотя... это же замок Дубовицких. Может другие лорды живут поскромнее?{/i}"
    me "{i}不过...这是Dubovitsky家的城堡。也许其他领主住得要简朴些？{/i}"

# game/a13/7recure.rpy:243
translate english recure2_05bd32a8:

    # me "{i}Потому что если нет, я точно изменю свою позицию по тому, какой регион в Империи был главным.{/i}"
    me "{i}因为如果不是这样，我绝对要改变我对帝国哪个地区才是主导的看法了。{/i}"

# game/a13/7recure.rpy:244
translate english recure2_5c76dbe7:

    # me "{i}...{/i}"
    me "{i}...{/i}"

# game/a13/7recure.rpy:245
translate english recure2_0b3facb2:

    # me "{i}Интересно, как меня встретят?{/i}"
    me "{i}不知道他们会怎样迎接我？{/i}"

# game/a13/7recure.rpy:246
translate english recure2_37aed8bd:

    # me "{i}Будет неловко, если нигде не пропустят дальше ворот.{/i}"
    me "{i}要是走到哪儿都被人挡在门外，那就尴尬了。{/i}"

# game/a13/7recure.rpy:247
translate english recure2_4651e902:

    # me "{i}С другой стороны у меня есть грамота от Короля Севера.{/i}"
    me "{i}但话说回来，我手里有北方之王的文书。{/i}"

# game/a13/7recure.rpy:248
translate english recure2_ed4d847a:

    # me "{i}Надеюсь это также значимо, как и звучит.{/i}"
    me "{i}希望这东西的作用和它听起来一样大。{/i}"

# game/a13/7recure.rpy:249
translate english recure2_d045133d:

    # me "{i}Больше всего боюсь увязнуть тут до зимы.{/i}"
    me "{i}最怕的是在这儿耽搁到冬天。{/i}"

# game/a13/7recure.rpy:250
translate english recure2_a86ed96f:

    # me "{i}Не хочется проверять на себе, действительно ли так суровы северные морозы.{/i}"
    me "{i}我可不想亲身体验北方的严寒到底有多严酷。{/i}"

# game/a13/7recure.rpy:253
translate english recure2_66eb2145:

    # lisa "[mename], когда покидаете нас?"
    lisa "[mename]，您什么时候离开我们？"

# game/a13/7recure.rpy:254
translate english recure2_3cae327a:

    # me "Завтра с утра."
    me "明天一早。"

# game/a13/7recure.rpy:255
translate english recure2_9685470d:

    # lisa "Ох... так быстро. Жаль."
    lisa "哦...这么快。真遗憾。"

# game/a13/7recure.rpy:256
translate english recure2_f44b8229:

    # me "Жаль? Я думал вам нравится одиночество."
    me "遗憾？我还以为您喜欢独处呢。"

# game/a13/7recure.rpy:257
translate english recure2_fe70ab76:

    # lisa "Я бы могла съязвить, но в этом нет необходимости. Ваша компания мне действительно по душе."
    lisa "我本可以挖苦您几句，但没这个必要。有您做伴，我确实很愉快。"

# game/a13/7recure.rpy:258
translate english recure2_68bfc636:

    # me "Приятно это слышать. Ваша компания мне тоже нравится."
    me "听您这么说真高兴。跟您做伴，我也很愉快。"

# game/a13/7recure.rpy:259
translate english recure2_3917856a:

    # lisa "Ну это вряд ли. Иначе вы взяли бы меня с собой."
    lisa "这我可不信。不然您就带上我了。"

# game/a13/7recure.rpy:260
translate english recure2_3820771a:

    # me "..."
    me "..."

# game/a13/7recure.rpy:261
translate english recure2_34246a48:

    # lisa "Шучу. Вы бы не хотели увидеть меня на лошади, уверяю."
    lisa "开个玩笑。我向您保证，您不会想看到我骑马的样子。"

# game/a13/7recure.rpy:262
translate english recure2_2d868fe2:

    # me "Теперь я не смогу думать ни о чем другом. Вас бы наверняка пришлось привязывать к седлу."
    me "这下我可没法想别的事了。恐怕得把您绑在马鞍上才行。"

# game/a13/7recure.rpy:263
translate english recure2_3daa573b:

    # lisa "Либо приделывать колеса лошади."
    lisa "或者给马安上轮子。"

# game/a13/7recure.rpy:264
translate english recure2_bc961638:

    # me "Хех. Ну да. Вы пришли попрощаться."
    me "呵。说得是。您是来道别的吗？"

# game/a13/7recure.rpy:265
translate english recure2_1e51409f:

    # lisa "Ну не совсем пришла. Но да. Если вдруг нам не удастся увидеться завтра с утра, хотела пожелать вам удачной дороги."
    lisa "不算特意过来，不过是的。要是明天早上咱们见不着面，我想祝您一路顺风。"

# game/a13/7recure.rpy:266
translate english recure2_51180497:

    # me "Спасибо, Лиза."
    me "谢谢，Lisa。"

# game/a13/7recure.rpy:267
translate english recure2_46477ea4:

    # lisa "И постарайтесь не умереть, пока будете решать проблему с горцами для моего отца."
    lisa "还有，替我父亲解决山民问题时，尽量别死掉。"

# game/a13/7recure.rpy:269
translate english recure2_5919a5f1:

    # me "Как ты... По-моему, ваш отец все-таки делится с вами информацией, Лиза."
    me "你怎么...在我看来，您父亲还是跟您分享了情报，Lisa。"

# game/a13/7recure.rpy:270
translate english recure2_57b3caf2:

    # lisa "Вовсе нет. Я просто сопоставила пару фактов и догадалась сама."
    lisa "才不是。我只是把几件事联系起来，自己猜到的。"

# game/a13/7recure.rpy:271
translate english recure2_8cd6ebdc:

    # me "А говорили, что большая часть книг бесполезна."
    me "您之前还说大部分书都没用呢。"

# game/a13/7recure.rpy:272
translate english recure2_b76fbe79:

    # lisa "Большая часть. Но не все."
    lisa "是大部分，但不是全部。"

# game/a13/7recure.rpy:273
translate english recure2_e3034758:

    # me "Удивительно. Библиотека на колесах."
    me "真是令人赞叹。一座带轮子的图书馆。"

# game/a13/7recure.rpy:274
translate english recure2_09c49eb8:

    # lisa "Спасибо. Дать пару советов?"
    lisa "谢谢。想听听我的建议吗？"

# game/a13/7recure.rpy:275
translate english recure2_74c20ff1:

    # me "О чем?"
    me "关于什么？"

# game/a13/7recure.rpy:276
translate english recure2_63efb552:

    # lisa "О ком. О горцах."
    lisa "关于谁。关于山民。"

# game/a13/7recure.rpy:277
translate english recure2_3dbd674e:

    # me "Разумеется."
    me "当然想听。"

# game/a13/7recure.rpy:278
translate english recure2_f16c823a:

    # lisa "Не пытайтесь победить их силой."
    lisa "别试图用武力战胜他们。"

# game/a13/7recure.rpy:279
translate english recure2_11d48bdc:

    # me "Они настолько хороши?"
    me "他们这么厉害？"

# game/a13/7recure.rpy:280
translate english recure2_b3fd5ba4:

    # lisa "Они очень злопамятны. Хранят обиды долго. Убьете их и решите проблему на года три, создавая кризис на столетия."
    lisa "他们非常记仇。怨恨会持续很久。杀了他们，能解决三年的问题，却会制造延续几个世纪的危机。"

# game/a13/7recure.rpy:281
translate english recure2_3691dc81:

    # me "И что же мне сделать?"
    me "那我该怎么做？"

# game/a13/7recure.rpy:282
translate english recure2_06960361:

    # lisa "Обманите их."
    lisa "骗骗他们。"

# game/a13/7recure.rpy:283
translate english recure2_018e5aca:

    # me "Как же?"
    me "怎么骗？"

# game/a13/7recure.rpy:284
translate english recure2_22d1cf6e:

    # lisa "Они жадные, как и все люди. Предложите им что-то получше двух кусков каменистой земли и они с радостью согласятся."
    lisa "他们和所有人一样贪婪。您给他们点比两块石头地更好的东西，他们会很高兴地同意的。"

# game/a13/7recure.rpy:285
translate english recure2_44e7b075:

    # me "Проблема только в том, что у меня и двух кусков каменистой земли нет."
    me "问题在于，我连两块石头地都没有。"

# game/a13/7recure.rpy:286
translate english recure2_09e7a136:

    # lisa "Ну...у вас может быть что-то получше. В теории..."
    lisa "嗯...您也许有更好的东西。理论上..."

# game/a13/7recure.rpy:287
translate english recure2_59256d58:

    # me "Не говорите загадками, Лиза."
    me "别打哑谜了，Lisa。"

# game/a13/7recure.rpy:288
translate english recure2_c7c0030e:

    # lisa "Люди, что назвали свою родину Рубиновым Ущельем за пару камней, найденных там сто лет назад, довольно алчны и горделивы, вы так не думаете?"
    lisa "一群因为一百年前在那儿找到过几块石头，就把家乡命名为“红宝石峡谷”的人，想必相当贪婪又自傲，您不觉得吗？"

# game/a13/7recure.rpy:289
translate english recure2_3820771a_1:

    # me "..."
    me "..."

# game/a13/7recure.rpy:290
translate english recure2_20337d68:

    # me "Убийство создаст кризис, а обман нет?"
    me "杀戮会制造危机，欺骗就不会吗？"

# game/a13/7recure.rpy:291
translate english recure2_e90a0d31:

    # lisa "Может быть и создаст. Но нарушить слово - значит опозориться. А это единственное, чего они боятся."
    lisa "也许会。但违背诺言意味着丢脸。而这是他们唯一害怕的事。"

# game/a13/7recure.rpy:292
translate english recure2_c02cee3a:

    # me "...спасибо."
    me "...谢谢。"

# game/a13/7recure.rpy:293
translate english recure2_a6972d11:

    # lisa "Надеюсь у вас все получится. До встречи."
    lisa "希望您一切顺利。再见。"

# game/a13/7recure.rpy:294
translate english recure2_ae3c9629:

    # me "До встречи, Лиза."
    me "再见，Lisa。"

# game/a13/7recure.rpy:297
translate english recure2_78f51e5a:

    # strazh "Рамона и Эдрик Вингхэды."
    strazh "拉莫娜和埃德里克·温赫德。"

# game/a13/7recure.rpy:298
translate english recure2_a3fa75b0:

    # me "Ну наконец-то."
    me "终于来了。"

# game/a13/7recure.rpy:299
translate english recure2_11fab6fa:

    # me "{i}Надо было сразу взять их с собой. Может выиграл бы себе еще пару дней.{/i}"
    me "{i}真该一开始就带他们一起来。说不定能多争取到几天时间。{/i}"

# game/a13/7recure.rpy:300
translate english recure2_a0a1792f:

    # me "{i}Хотя привозить их сюда, прежде разговора с Дубовицким тоже могло быть опрометчиво.{/i}"
    me "{i}不过，在和Dubovitsky谈过之前就把他们带到这里来，也可能太草率了。{/i}"

# game/a13/7recure.rpy:301
translate english recure2_2b7ee997:

    # me "{i}Надеюсь он сдержит слово.{/i}"
    me "{i}希望他能信守诺言。{/i}"

# game/a13/7recure.rpy:302
translate english recure2_94abe52c:

    # me "{i}А дальше уже дело за Эдриком.{/i}"
    me "{i}剩下的事就看埃德里克的了。{/i}"

# game/a13/7recure.rpy:303
translate english recure2_f738130e:

    # me "{i}Сможет ли он справится с Евой.{/i}"
    me "{i}他能搞得定Eva吗。{/i}"

# game/a13/7recure.rpy:304
translate english recure2_06508fe7:

    # me "{i}Что-то мне подсказывает, что нет.{/i}"
    me "{i}总觉得有点悬。{/i}"

# game/a13/7recure.rpy:306
translate english recure2_22507e3d:

    # ramona "Принц [mename]."
    ramona "[mename]王子。"

# game/a13/7recure.rpy:307
translate english recure2_92153ffe:

    # edric "Принц [mename]."
    edric "[mename]王子。"

# game/a13/7recure.rpy:308
translate english recure2_c33e78ac:

    # me "Эдрик, Рамона. Как путь?"
    me "埃德里克，拉莫娜。一路可好？"

# game/a13/7recure.rpy:309
translate english recure2_7d32ea70:

    # edric "Все прошло быстро и спокойно. Спасибо, что поинтересовались."
    edric "一路又快又太平。谢谢您的关心。"

# game/a13/7recure.rpy:310
translate english recure2_c2d0649a:

    # me "Надеюсь вы не против, что вас не встречали с фанфарами. Похоже они все достались мне."
    me "希望你们别介意没有人吹着喇叭迎接你们。看来那些排场全用在我身上了。"

# game/a13/7recure.rpy:311
translate english recure2_b9171849:

    # edric "Мы здесь не для формальностей, верно?"
    edric "我们不是为这些排场来的，对吧？"

# game/a13/7recure.rpy:312
translate english recure2_857b86ad:

    # me "Верно. Все остальные тоже с вами?"
    me "对。其他人也和你们一起到了吗？"

# game/a13/7recure.rpy:313
translate english recure2_a1e018ed:

    # edric "Да. В Хельвике остались только корабли и их команды. Груз с нами."
    edric "是的。Helvik那边只剩下船和船员。货物跟我们一起到了。"

# game/a13/7recure.rpy:314
translate english recure2_62e55a26:

    # me "Наняли лошадей?"
    me "租马匹了吗？"

# game/a13/7recure.rpy:315
translate english recure2_137d4e8b:

    # edric "Даже пару быков."
    edric "还租了几头牛。"

# game/a13/7recure.rpy:316
translate english recure2_9d2d5bef:

    # me "Хорошо. Тогда не придется брать припасы в дорогу у хозяев. Кстати насчет их, вы уже виделись?"
    me "很好。那就不必向主人家借路上的补给了。对了，说到主人家，你们见过面了吗？"

# game/a13/7recure.rpy:317
translate english recure2_850fbb14:

    # edric "Нет. Только приехали."
    edric "还没有。我们才刚到。"

# game/a13/7recure.rpy:318
translate english recure2_772267a1:

    # me "Хорошо. Я организую встречу."
    me "好的。我来安排会面。"

# game/a13/7recure.rpy:319
translate english recure2_6fd3efcc:

    # edric "Спасибо, мой принц."
    edric "谢谢您，我的王子。"

# game/a13/7recure.rpy:320
translate english recure2_72b04b86:

    # me "Ну что ты, это и в моих интересах тоже."
    me "别客气，这也是为我自己着想。"

# game/a13/7recure.rpy:322
translate english recure2_3358b1e1:

    # me "Устали?"
    me "累了吧？"

# game/a13/7recure.rpy:323
translate english recure2_e911a8e7:

    # ramona "Немного."
    ramona "有一点。"

# game/a13/7recure.rpy:324
translate english recure2_9db2b447:

    # edric "Но если от нас требуется..."
    edric "但如果需要我们做什么..."

# game/a13/7recure.rpy:325
translate english recure2_3936c265:

    # me "Пока ничего не требуется. Разве что помыться, у тебя встреча с невестой."
    me "暂时不需要做什么。不过去洗洗干净，你要去见你的未婚妻了。"

# game/a13/7recure.rpy:326
translate english recure2_3fe8a805:

    # edric "Конечно. Буду чистым через мгновение!"
    edric "当然。我马上就去洗干净！"

# game/a13/7recure.rpy:327
translate english recure2_4d29b0ac:

    # me "Замечательно."
    me "太好了。"

# game/a13/7recure.rpy:328
translate english recure2_21314a57:

    # ramona "А я?"
    ramona "那我呢？"

# game/a13/7recure.rpy:329
translate english recure2_f5592c1f:

    # me "Боюсь твой принц в другом замке. У лорда Дубовицкого нет сыновей."
    me "恐怕你的王子在另一座城堡里。Dubovitsky领主没有儿子。"

# game/a13/7recure.rpy:330
translate english recure2_eff38af8:

    # edric "Она это знает. Просто надеялась, что женихи сами будут к ней ехать."
    edric "她知道这个。只是希望求婚者能自己来找她。"

# game/a13/7recure.rpy:331
translate english recure2_5d5a0ec2:

    # ramona "Эдрик!"
    ramona "埃德里克！"

# game/a13/7recure.rpy:332
translate english recure2_494db918:

    # me "Не переживай. Мы подберем тебе лучшую партию."
    me "别担心。我们会给你找个最好的归宿。"

# game/a13/7recure.rpy:333
translate english recure2_f9b9785a:

    # edric "Лучшую для Империи, разумеется?"
    edric "当然是对帝国最有利的，对吗？"

# game/a13/7recure.rpy:334
translate english recure2_bb686f7a:

    # me "Ну да."
