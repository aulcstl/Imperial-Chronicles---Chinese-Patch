# game/a13/8northroad.rpy:4
translate english northroad_580a3638:

    # "Ранним утром"
    "一大早。"

# game/a13/8northroad.rpy:6
translate english northroad_0693ba1f:

    # me "...ну как лошади?"
    me "...马匹怎么样？"

# game/a13/8northroad.rpy:7
translate english northroad_ec25762a:

    # harold "Хорошие, мой принц, лорд Дубовицкий не поскупился."
    harold "很不错，我的王子。Dubovitsky大人没有吝啬。"

# game/a13/8northroad.rpy:8
translate english northroad_9395b404:

    # me "Отлично. Остальные ребята готовы?"
    me "太好了。其他人准备好了吗？"

# game/a13/8northroad.rpy:9
translate english northroad_d965280e:

    # harold "Да, мой принц. Уверены что четверых хватит?"
    harold "准备好了，我的王子。你确定四个人就够了吗？"

# game/a13/8northroad.rpy:10
translate english northroad_46724dde:

    # me "Уверен. Чем меньше нас будет, тем быстрее будем двигаться."
    me "我确定。我们人越少，行动就能越快。"

# game/a13/8northroad.rpy:11
translate english northroad_2f9d6383:

    # harold "Хорошо. А обоз?"
    harold "好的。那辎重车队呢？"

# game/a13/8northroad.rpy:12
translate english northroad_7af28cf1:

    # me "А что с ним?"
    me "车队怎么了？"

# game/a13/8northroad.rpy:13
translate english northroad_dfc7f618:

    # harold "Они будут отставать от нас. Чем дальше, тем сильнее."
    harold "他们会落后于我们，而且会越落越远。"

# game/a13/8northroad.rpy:14
translate english northroad_711e04d8:

    # me "Будут нагонять нас, пока мы будем гостить в замках северных лордов. Тем более здесь одна дорога, не заплутают."
    me "等我们在北方领主的城堡里做客停留时，他们会赶上来的。再说这里只有一条路，他们不会迷路的。"

# game/a13/8northroad.rpy:15
translate english northroad_83be4cca:

    # harold "Конечно, мой принц."
    harold "当然，我的王子。"

# game/a13/8northroad.rpy:16
translate english northroad_ef2d6434:

    # me "Ну так как?"
    me "那么...怎么样了？"

# game/a13/8northroad.rpy:17
translate english northroad_4479b1f6:

    # harold "Мы все готовы. Ждем вашего приказа."
    harold "我们都准备好了。等待您的命令。"

# game/a13/8northroad.rpy:20
translate english northroad_6ebcc452:

    # me "Ну... ты слышала."
    me "嗯...你听到了。"

# game/a13/8northroad.rpy:21
translate english northroad_35940de8:

    # aurora "Ты уверен, что тебе не нужно больше охраны?"
    aurora "你确定你不需要更多护卫吗？"

# game/a13/8northroad.rpy:22
translate english northroad_3fac7c3e:

    # me "Уверен."
    me "我确定。"

# game/a13/8northroad.rpy:23
translate english northroad_1b8fa1b6:

    # aurora "А если... ну не знаю... на вас нападут?"
    aurora "那要是...万一...你们遇到袭击呢？"

# game/a13/8northroad.rpy:24
translate english northroad_2c263999:

    # me "Кто? Разве Север славится разбойниками? Для них тут холодновато."
    me "谁会袭击？难道北方以盛产强盗闻名吗？对他们来说这里太冷了。"

# game/a13/8northroad.rpy:25
translate english northroad_fb9c38f2:

    # aurora "А эльфы?"
    aurora "那精灵呢？"

# game/a13/8northroad.rpy:26
translate english northroad_17ed722c:

    # me "Эльфы на Севере, это не эльфы в Долине или на Западе. Здесь они в основном воруют. Поверь мне, я знаю, о чем говорю."
    me "北方的精灵，可不是谷地或西部的精灵。这里的精灵主要是偷东西。相信我，我在说什么我心里有数。"

# game/a13/8northroad.rpy:27
translate english northroad_d03a1223:

    # aurora "И все же..."
    aurora "可我总觉得..."

# game/a13/8northroad.rpy:28
translate english northroad_f1bd53f1:

    # me "Даже если на нас вдруг выйдет из леса армия эльфов, даю слово я развернусь и поскачу назад."
    me "就算突然有一支精灵大军从林子里杀出来袭击我们，我发誓我会立刻掉头就跑。"

# game/a13/8northroad.rpy:29
translate english northroad_2b71bc54:

    # aurora "..."
    aurora "..."

# game/a13/8northroad.rpy:30
translate english northroad_0c0b687a:

    # me "Успокойся. У нас нет обоза, у нас нечего украсть. К тому же никто в здравом уме не нападает на вооруженных всадников."
    me "放心吧。我们没有车队，没什么好偷的。再说，任何神志清醒的人都不会去攻击一队全副武装的骑兵。"

# game/a13/8northroad.rpy:31
translate english northroad_aa4750d4:

    # aurora "Они могут напасть на тебя."
    aurora "他们可能会冲你来。"

# game/a13/8northroad.rpy:32
translate english northroad_de579618:

    # me "Меня здесь никто не знает. Успокойся, Аврора."
    me "这儿没人认识我。放心吧，Aurora。"

# game/a13/8northroad.rpy:33
translate english northroad_0dc06d46:

    # aurora "Хорошо..."
    aurora "好吧..."

# game/a13/8northroad.rpy:34
translate english northroad_09aef151:

    # me "Ну... Пора прощаться."
    me "嗯...该道别了。"

# game/a13/8northroad.rpy:36
translate english northroad_aea9d68e:

    # aurora "Возвращайся скорее."
    aurora "早点回来。"

# game/a13/8northroad.rpy:37
translate english northroad_1fd80160:

    # me "Вернусь как только смогу."
    me "我会尽快赶回来。"

# game/a13/8northroad.rpy:38
translate english northroad_4e83ac80:

    # aurora "Зимы на Севере суровые."
    aurora "北方的冬天很严酷。"

# game/a13/8northroad.rpy:39
translate english northroad_d19ee3d9:

    # me "Я успею до первого снега. Я почти в этом уверен."
    me "我会在第一场雪前赶回来。我几乎可以确定。"

# game/a13/8northroad.rpy:40
translate english northroad_1f253c40:

    # aurora "Береги себя. Я и твой сын будем тебя ждать."
    aurora "保重自己。我和你的儿子会等着你。"

# game/a13/8northroad.rpy:41
translate english northroad_66549616:

    # me "Я буду об этом помнить холодными ночами и это будет греть мне сердце, Аврора."
    me "在寒冷的夜里我会记着这话，它会温暖我的心，Aurora。"

# game/a13/8northroad.rpy:42
translate english northroad_77cc71a4:

    # aurora "...я люблю тебя."
    aurora "...我爱你。"

# game/a13/8northroad.rpy:43
translate english northroad_2723316e:

    # me "И я тебя."
    me "我也爱你。"

# game/a13/8northroad.rpy:44
translate english northroad_b78a3b18:

    # aurora "[mename]?"
    aurora "[mename]?"

# game/a13/8northroad.rpy:45
translate english northroad_dfcceeac:

    # me "М?"
    me "嗯？"

# game/a13/8northroad.rpy:46
translate english northroad_e99429c8:

    # aurora "Помни, что ты еще молод. Не обязательно пытаться завладеть всем миром, до того как твой сын научится ходить."
    aurora "记住，你还年轻。不一定非得在你儿子学会走路之前就征服整个世界。"

# game/a13/8northroad.rpy:47
translate english northroad_71d3b8c8:

    # me "Хорошо."
    me "好的。"

# game/a13/8northroad.rpy:48
translate english northroad_2b71bc54_1:

    # aurora "..."
    aurora "..."

# game/a13/8northroad.rpy:49
translate english northroad_83a6f5e3:

    # me "Аврора?"
    me "Aurora？"

# game/a13/8northroad.rpy:50
translate english northroad_eef4168d:

    # aurora "М?"
    aurora "嗯？"

# game/a13/8northroad.rpy:51
translate english northroad_dd2ea153:

    # me "Мне пора."
    me "我该走了。"

# game/a13/8northroad.rpy:52
translate english northroad_8d5faff1:

    # aurora "Да... конечно. Еще пару секундочек..."
    aurora "是的...当然。再等几秒钟就好..."

# game/a13/8northroad.rpy:55
translate english northroad_6ebcc452_1:

    # me "Ну... ты слышала."
    me "嗯...你听到了。"

# game/a13/8northroad.rpy:56
translate english northroad_6cb9b314:

    # ramona "Я поеду в обозе?"
    ramona "我要跟着车队走吗？"

# game/a13/8northroad.rpy:57
translate english northroad_50a6ecc9:

    # me "Нет. Ты отправишься часа через два, когда рассветет. Ты умеешь ездить верхом?"
    me "不。你大概两个小时之后，天亮时再出发。你会骑马吗？"

# game/a13/8northroad.rpy:58
translate english northroad_963384e3:

    # ramona "Ну... немного. Боком."
    ramona "嗯...一点点。侧着坐。"

# game/a13/8northroad.rpy:59
translate english northroad_9800177f:

    # me "Отлично. Большего и не надо. Будешь ехать с кем-нибудь из наших людей."
    me "太好了。这已经足够了。你会和我们的人合骑一匹马。"

# game/a13/8northroad.rpy:60
translate english northroad_d5b97ee8:

    # ramona "Я... я думала, я поеду в карете."
    ramona "我...我还以为我会坐马车。"

# game/a13/8northroad.rpy:61
translate english northroad_ff81bc01:

    # me "Я решил, что это будет слишком медленно, если я буду задерживаться в каждом замке по пути, ожидая тебя."
    me "我考虑了一下，如果每到一个城堡都要停下来等你，那就太慢了。"

# game/a13/8northroad.rpy:62
translate english northroad_5c028e2f:

    # ramona "Понятно."
    ramona "我明白了。"

# game/a13/8northroad.rpy:63
translate english northroad_9e2eab4d:

    # me "Не волнуйся. Я дал приказ быть с тобой осторожным, как с вазой из горного хрусталя."
    me "别担心。我已经下令要他们把你当成水晶花瓶一样小心照顾。"

# game/a13/8northroad.rpy:64
translate english northroad_0d32f7a8:

    # ramona "..."
    ramona "..."

# game/a13/8northroad.rpy:65
translate english northroad_a9caeef6:

    # me "И если ты захочешь остановиться - стоит тебе только сказать и все, кто тебя сопровождают остановятся."
    me "如果你想停下来休息，只要说一声，所有随从都会停下。"

# game/a13/8northroad.rpy:66
translate english northroad_9e30d0ee:

    # ramona "...спасибо."
    ramona "...谢谢。"

# game/a13/8northroad.rpy:67
translate english northroad_779d93ab:

    # me "Между замками не больше двух-трех дней пути. Сильно не вымотаешься."
    me "城堡之间不过两三天的路程。你不会太疲惫的。"

# game/a13/8northroad.rpy:68
translate english northroad_484ca316:

    # ramona "Конечно."
    ramona "好的。"

# game/a13/8northroad.rpy:70
translate english northroad_c8fa5366:

    # me "Прости за это."
    me "对此我很抱歉。"

# game/a13/8northroad.rpy:71
translate english northroad_bbcab479:

    # ramona "Вам не за что извиняться, мой принц."
    ramona "您不必道歉，我的王子。"

# game/a13/8northroad.rpy:72
translate english northroad_e4d69b28:

    # me "Есть за что. Такая дорога не для молодой девушки."
    me "有必要。这样的旅途不适合一位年轻姑娘。"

# game/a13/8northroad.rpy:73
translate english northroad_38ad4f79:

    # ramona "Это необходимость."
    ramona "这是必须的。"

# game/a13/8northroad.rpy:74
translate english northroad_acf46137:

    # me "Нет. Правильным было бы отправится в путь и начать договариваться без твоего участия. Но тогда пришлось бы делать круг, чтобы забрать тебя и это заняло больше времени."
    me "不。更恰当的做法本该是我独自出发去谈判，你没必要参与。但那样一来，为了接你就得绕路，会花更多时间。"

# game/a13/8northroad.rpy:75
translate english northroad_2a34e755:

    # me "Признаюсь тебе, я делаю это для того, чтобы успеть вернуться назад до снегов и морозов."
    me "我向你坦白，这么做是为了能赶在风雪严寒之前回来。"

# game/a13/8northroad.rpy:76
translate english northroad_b4a391eb:

    # ramona "Я вас понимаю, мой принц."
    ramona "我理解，我的王子。"

# game/a13/8northroad.rpy:77
translate english northroad_4df5d422:

    # me "Ты сильная девушка, спасибо, Рамона. Я отблагодарю тебя за это. Корона возьмет на себя расходы на свадьбу и оплатит приданное."
    me "你是个坚强的姑娘，谢谢你，拉莫娜。我会为此报答你。王室将承担你的婚礼费用和嫁妆。"

# game/a13/8northroad.rpy:78
translate english northroad_5497af0f:

    # ramona "Правда? Отец будет счастлив."
    ramona "真的吗？我父亲会非常高兴的。"

# game/a13/8northroad.rpy:79
translate english northroad_fecf2dde:

    # me "Н-да... А что насчет тебя?"
    me "嗯...那你呢？"

# game/a13/8northroad.rpy:80
translate english northroad_e403d873:

    # ramona "Я благодарна вам за это."
    ramona "我为此感激您。"

# game/a13/8northroad.rpy:81
translate english northroad_0fdf5179:

    # me "Нет. Я о твоих предпочтениях. Если тебе кто-то понравится, скажи. Не обещаю, что твое мнение будет определяющим, но я точно к нему прислушаюсь."
    me "不。我是问你的喜好。如果你喜欢谁，就告诉我。我不能保证你的意见起决定性作用，但我一定会认真考虑。"

# game/a13/8northroad.rpy:82
translate english northroad_3b343e75:

    # ramona "Спасибо, принц [mename]."
    ramona "谢谢您，[mename]王子。"

# game/a13/8northroad.rpy:83
translate english northroad_fbe89712:

    # me "Ладно. Мне пора. Увидимся в первом замке по пути."
    me "好了。我该走了。我们沿路第一个城堡见。"

# game/a13/8northroad.rpy:84
translate english northroad_484ca316_1:

    # ramona "Конечно."
    ramona "好的。"

# game/a13/8northroad.rpy:86
translate english northroad_8283ac89:

    # me "{i}Ну... вот и снова в дорогу.{/i}"
    me "{i}嗯...又要上路了。{/i}"

# game/a13/8northroad.rpy:87
translate english northroad_f15d3fdf:

    # me "{i}Когда я гнил в Бригдоке я мечтал, что когда-нибудь смогу обрести волю и средства, чтобы объездить весь мир.{/i}"
    me "{i}当初在布里格多克腐烂等死时，我还梦想着有朝一日能获得自由和财富，好能周游世界。{/i}"

# game/a13/8northroad.rpy:88
translate english northroad_b2695c02:

    # me "{i}Теперь у меня есть и то и то, да еще и цель, но покидать замок тяжело.{/i}"
    me "{i}现在我两者都有了，甚至还多了个目标，但离开城堡却如此沉重。{/i}"

# game/a13/8northroad.rpy:89
translate english northroad_b3a232ad:

    # me "{i}Приключения манят меня, но теплая кровать манит еще больше.{/i}"
    me "{i}冒险吸引着我，但温暖的床铺更吸引我。{/i}"

# game/a13/8northroad.rpy:90
translate english northroad_67136aa8:

    # me "{i}Впрочем от замка к замку спать в лесу или поле придется не больше одного-двух раз. Чего я переживаю?{/i}"
    me "{i}不过，从一个城堡到另一个城堡，最多在林子里或野地里睡一两个晚上。我在瞎担心什么？{/i}"

# game/a13/8northroad.rpy:91
translate english northroad_5c76dbe7:

    # me "{i}...{/i}"
    me "{i}...{/i}"

# game/a13/8northroad.rpy:92
translate english northroad_5bef5c09:

    # me "{i}Если только кто-то вдруг решит меня не впускать...{/i}"
    me "{i}除非有人突然决定不让我进门...{/i}"

# game/a13/8northroad.rpy:93
translate english northroad_c5d88dd0:

    # me "{i}Кхм... Уверен этого не случится.{/i}"
    me "{i}咳...我相信这不会发生。{/i}"

# game/a13/8northroad.rpy:98
translate english northroad_0d59103e:

    # eva "Эх... обязательно было будить меня так рано?"
    eva "唉...非得这么早就叫醒我吗？"

# game/a13/8northroad.rpy:99
translate english northroad_4339b764:

    # cath "Обязательно. Наш гость уезжает."
    cath "非这样不可。我们的客人要走了。"

# game/a13/8northroad.rpy:100
translate english northroad_c89c2245:

    # eva "И что? Стражники не смогут открыть ворота без нас?"
    eva "那又怎样？守卫没我们就不会开门了吗？"

# game/a13/8northroad.rpy:101
translate english northroad_58f87999:

    # cath "Во что ты одета?"
    cath "你穿的是什么？"

# game/a13/8northroad.rpy:102
translate english northroad_fc737d9c:

    # eva "А во что я должна быть одета утром?"
    eva "那我早上应该穿什么？"

# game/a13/8northroad.rpy:103
translate english northroad_0cee4244:

    # lisa "Скажи спасибо, что на ней хоть что-то есть, мам."
    lisa "妈，你得庆幸她至少还穿了点东西。"

# game/a13/8northroad.rpy:104
translate english northroad_560f4b55:

    # cath "Ты будешь сидеть в башне до самого возвращения принца, обещаю."
    cath "我保证，在王子回来之前，你会一直待在塔楼里。"

# game/a13/8northroad.rpy:105
translate english northroad_195ed02d:

    # eva "Ну чего ты начинаешь, мам, я же пришла."
    eva "妈，你又来了，我不是来了嘛。"

# game/a13/8northroad.rpy:106
translate english northroad_2c8d9432:

    # lisa "Действительно пришла. Даже ни одной собаки по пути не убила. Наверное."
    lisa "她确实是来了。路上估计都没打死过一条狗。大概吧。"

# game/a13/8northroad.rpy:107
translate english northroad_5d1fba6d:

    # cath "Лиза..."
    cath "Lisa..."

# game/a13/8northroad.rpy:108
translate english northroad_bd2885bf:

    # lisa "Что? Меня можешь башней не пугать, мам."
    lisa "怎么？妈，你不用拿塔楼来吓唬我。"

# game/a13/8northroad.rpy:109
translate english northroad_95ef36e3:

    # eva "И долго мы так стоять будем? Я спать хочу."
    eva "我们还要这样站多久？我想睡觉。"

# game/a13/8northroad.rpy:110
translate english northroad_6042d8d0:

    # cath "Будем стоять столько, сколько потребуется."
    cath "需要站多久就站多久。"

# game/a13/8northroad.rpy:111
translate english northroad_2bd8ca95:

    # eva "Можно я хоть к Лизе на кресло присяду?"
    eva "我能不能至少去Lisa的椅子上坐会儿？"

# game/a13/8northroad.rpy:112
translate english northroad_42ee4bd6:

    # lisa "Обойдешься, сначала стань калекой, а потом пользуйся такой замечательной возможностью сидеть, когда захочешь. И когда нет тоже."
    lisa "你想得美，除非你也变成残废，才能享受到随便想坐就坐的绝妙特权。当然也包括你不想坐的时候。"

# game/a13/8northroad.rpy:113
translate english northroad_054f5bb9:

    # eva "А без этого никак?"
    eva "就没别的办法了吗？"

# game/a13/8northroad.rpy:114
translate english northroad_e9729b26:

    # lisa "Если тебе так скучно, можешь убить какую-нибудь лошадь. "
    lisa "你要是觉得无聊，可以去杀匹马玩玩。"

# game/a13/8northroad.rpy:115
translate english northroad_3c13aa28:

    # lisa "Да, тебя тут же накажут и отправят в башню, зато не придется присутствовать на скучных церемониальных провожаниях в путь."
    lisa "是啊，这样你会立刻受罚被关进塔楼，但好处是不用在这无聊的送行仪式上待着了。"

# game/a13/8northroad.rpy:116
translate english northroad_aa8fdd31:

    # cath "А можно я не буду краснеть за вас сейчас? Подождите пять минут, прежде чем принц уедет, а потом несите свою чушь хоть целый день."
    cath "我现在能不能别替你们害臊？等五分钟，等王子走了以后，你们想怎么胡说八道都行，整天都可以。"

# game/a13/8northroad.rpy:118
translate english northroad_7785e7bb:

    # cath "Прости, милая."
    cath "对不起，亲爱的。"

# game/a13/8northroad.rpy:119
translate english northroad_b3da181b:

    # aurora "Все нормально, мам."
    aurora "没事的，妈。"

# game/a13/8northroad.rpy:120
translate english northroad_bef0c1b9:

    # cath "Уверена?"
    cath "你确定？"

# game/a13/8northroad.rpy:121
translate english northroad_d986d97d:

    # aurora "Уверена. Если девочки хотят, могут идти."
    aurora "我确定。如果姑娘们想走，可以走。"

# game/a13/8northroad.rpy:122
translate english northroad_048fb74e:

    # lisa "Прости, Аврора."
    lisa "对不起，Aurora。"

# game/a13/8northroad.rpy:123
translate english northroad_70060c33:

    # eva "А вот я готова уйти, если Аврора разрешает."
    eva "要是Aurora允许，我倒是非常乐意走。"

# game/a13/8northroad.rpy:124
translate english northroad_c93a7309:

    # cath "Ева..."
    cath "Eva..."

# game/a13/8northroad.rpy:125
translate english northroad_f02463d0:

    # dubov "Должен вернуться через месяц-два..."
    dubov "他应该一两个月后就回来了..."

# game/a13/8northroad.rpy:126
translate english northroad_29950fc8:

    # cath "Принц [mename]? Если застанет зиму, порт в Хельвике может замерзнуть, как в прошлом году. Возможно придется перезимовать у нас."
    cath "[mename]王子？要是他赶上冬天，Helvik的港口可能会像去年一样封冻。他也许得在我们这儿过冬了。"

# game/a13/8northroad.rpy:129
translate english northroad_27d656f3:

    # eva "О, это было бы хорошо."
    eva "哦，那就太好了。"

# game/a13/8northroad.rpy:130
translate english northroad_e8c45adb:

    # cath "Что же в этом хорошего?"
    cath "这有什么好的？"

# game/a13/8northroad.rpy:131
translate english northroad_f3a69677:

    # eva "Ну как же? Можно укрепить связи с наследником Империи. Стать ему... друзьями."
    eva "怎么不好？能和帝国继承人加深联系。成为他的...朋友。"

# game/a13/8northroad.rpy:132
translate english northroad_b2d7becc:

    # cath "Да что ты."
    cath "说的倒轻巧。"

# game/a13/8northroad.rpy:133
translate english northroad_b8d9852c:

    # eva "Ну да. Разве плохо?"
    eva "是啊。不好吗？"

# game/a13/8northroad.rpy:134
translate english northroad_530529c9:

    # cath "...принц [mename] говорил с тобой вчера?"
    cath "...[mename]王子昨天跟你谈话了？"

# game/a13/8northroad.rpy:135
translate english northroad_2ee248ad:

    # eva "Говорил."
    eva "谈了。"

# game/a13/8northroad.rpy:136
translate english northroad_51eea18b:

    # cath "И что?"
    cath "然后呢？"

# game/a13/8northroad.rpy:137
translate english northroad_c934f708:

    # eva "Разговор мне не понравился."
    eva "我不喜欢那场谈话。"

# game/a13/8northroad.rpy:138
translate english northroad_c3f1cfbe:

    # cath "Меня это радует."
    cath "这让我很高兴。"

# game/a13/8northroad.rpy:139
translate english northroad_e4b36949:

    # eva "Ты его попросила?"
    eva "是你求他说的？"

# game/a13/8northroad.rpy:140
translate english northroad_5f662a3a:

    # cath "А не стоило? Твое поведение позорило всю нашу семью."
    cath "难道不该吗？你的行为让我们全家蒙羞。"

# game/a13/8northroad.rpy:141
translate english northroad_3b4845b2:

    # eva "Он был... груб."
    eva "他...很粗暴。"

# game/a13/8northroad.rpy:142
translate english northroad_a4ec8abd:

    # cath "Вот и хорошо. По-другому ты не понимаешь."
    cath "那就对了。不这样你不长记性。"

# game/a13/8northroad.rpy:143
translate english northroad_e694d2c9:

    # eva "Он ругался и даже сделал мне больно."
    eva "他责骂了我，甚至伤了我。"

# game/a13/8northroad.rpy:144
translate english northroad_d32017f6:

    # cath "Не выдумывай."
    cath "别胡说八道。"

# game/a13/8northroad.rpy:145
translate english northroad_fe3c4ef3:

    # eva "Ну... в душевном плане."
    eva "嗯...我说的是精神层面上。"

# game/a13/8northroad.rpy:146
translate english northroad_904691f1:

    # cath "И почему же у тебя тогда улыбка не слазит с лица?"
    cath "那你脸上为什么还挂着笑容？"

# game/a13/8northroad.rpy:147
translate english northroad_fcfedeee:

    # eva "Уверена, принц еще... прислушается ко мне. Вдруг не успеет к зиме. У меня будет столько времени, чтобы его переубедить..."
    eva "我相信，王子他还是会...再次听我说话的。万一他冬天前赶不回来呢。我会有很多时间来说服他改变主意..."

# game/a13/8northroad.rpy:148
translate english northroad_c93a7309_1:

    # cath "Ева..."
    cath "Eva..."

# game/a13/8northroad.rpy:149
translate english northroad_edb9313d:

    # eva "М?"
    eva "嗯？"

# game/a13/8northroad.rpy:150
translate english northroad_a6f3bbb8:

    # cath "Даже не смей..."
    cath "你休想..."

# game/a13/8northroad.rpy:151
translate english northroad_44865975:

    # eva "О чем ты, матушка?"
    eva "你在说什么呀，母亲大人？"

# game/a13/8northroad.rpy:152
translate english northroad_ec6e4b78:

    # cath "Поговорим позже."
    cath "晚些时候我们再谈。"

# game/a13/8northroad.rpy:153
translate english northroad_1f9b02ee:

    # eva "Как скажешь."
    eva "随你怎么说。"

# game/a13/8northroad.rpy:156
translate english northroad_70fd1edd:

    # lisa "О. Это было не так плохо."
    lisa "哦。还不算太糟。"

# game/a13/8northroad.rpy:157
translate english northroad_e9df7f1e:

    # cath "Почему же?"
    cath "为什么？"

# game/a13/8northroad.rpy:158
translate english northroad_7fe77092:

    # lisa "Если с кем и коротать время в зиму, то с такими людьми."
    lisa "要是得找人一起消磨冬天时光，至少是和这样的人。"

# game/a13/8northroad.rpy:159
translate english northroad_0cd5c1db:

    # cath "С какими 'такими'?"
    cath "哪样的人？"

# game/a13/8northroad.rpy:160
translate english northroad_5fba2d1c:

    # lisa "С интересными."
    lisa "有趣的人。"

# game/a13/8northroad.rpy:161
translate english northroad_353c9472:

    # cath "Принц показался тебе интересным?"
    cath "你觉得王子很有趣？"

# game/a13/8northroad.rpy:162
translate english northroad_e4cb39b0:

    # lisa "А что? Это какая-то проблема? Звучишь так, будто подозреваешь меня в чем-то, матушка."
    lisa "怎么了？有什么问题吗？母亲大人，你说话的口气，就像是在怀疑我什么似的。"

# game/a13/8northroad.rpy:163
translate english northroad_dd2d1d95:

    # cath "..."
    cath "..."

# game/a13/8northroad.rpy:164
translate english northroad_d89133bb:

    # lisa "Ладно, я признаюсь, мы полюбили друг друга и собираемся сбежать к дворфам в горы."
    lisa "好吧，我承认，我们相爱了，打算私奔去山里的矮人那儿。"

# game/a13/8northroad.rpy:165
translate english northroad_74ed6b6e:

    # cath "Лиза."
    cath "Lisa。"

# game/a13/8northroad.rpy:166
translate english northroad_a22a93a1:

    # lisa "Что? Это ты меня допрашиваешь, хотя я просто сказала, что он интересный."
    lisa "怎么了？是你先盘问我的，我只不过说他有趣而已。"

# game/a13/8northroad.rpy:167
translate english northroad_e9137ef9:

    # cath "Он был здесь не больше недели, я даже не знала, что вы проводили вместе время."
    cath "他在这儿待了不到一周，我都不知道你们还一起待过。"

# game/a13/8northroad.rpy:168
translate english northroad_48818f2a:

    # lisa "Читали разок вместе в библиотеке."
    lisa "在图书馆一起读过一次书。"

# game/a13/8northroad.rpy:169
translate english northroad_4afb168d:

    # cath "Это... вежливо с его стороны."
    cath "那...他可真是有礼数。"

# game/a13/8northroad.rpy:170
translate english northroad_65d7d842:

    # lisa "Нет. В том то и дело. Наверное поэтому он мне и понравился. Это первый наш гость, который провел со мной время, не потому что ему меня жалко."
    lisa "不。问题就在这儿。大概就因为这样我才喜欢他。他是第一个和我待着却没带着怜悯心的客人。"

# game/a13/8northroad.rpy:171
translate english northroad_95dde132:

    # cath "Все гости, что проводили с тобой время...."
    cath "所有和你待过的客人..."

# game/a13/8northroad.rpy:172
translate english northroad_e1ecdb96:

    # lisa "Да. Все."
    lisa "是。全部都是。"

# game/a13/8northroad.rpy:173
translate english northroad_2dcbb33c:

    # cath "А почему же тогда принц [mename] провел с тобой время?"
    cath "那为什么[mename]王子愿意和你待在一起？"

# game/a13/8northroad.rpy:174
translate english northroad_234512a6:

    # lisa "Не знаю, может потому что ему нравится живой ум, даже если он присоединен к мертвым ногам?"
    lisa "不知道，也许是因为他欣赏活跃的头脑，哪怕它连在了一双残废的腿上？"

# game/a13/8northroad.rpy:175
translate english northroad_cc99da22:

    # cath "...ладно. Я рада, что вы подружились."
    cath "...好吧。我很高兴你们成了朋友。"

# game/a13/8northroad.rpy:176
translate english northroad_5853b158:

    # lisa "Я тоже."
    lisa "我也是。"

# game/a13/8northroad.rpy:179
translate english northroad_f788fabe:

    # cath "Впрочем это было бы не так уж и плохо."
    cath "说起来，这也不是什么坏事。"

# game/a13/8northroad.rpy:180
translate english northroad_5f90c3af:

    # dubov "Почему это?"
    dubov "为什么这么说？"

# game/a13/8northroad.rpy:181
translate english northroad_b760d256:

    # cath "Он человек чести."
    cath "他是个有荣誉感的人。"

# game/a13/8northroad.rpy:182
translate english northroad_505ef0ba:

    # dubov "Да ну?"
    dubov "是吗？"

# game/a13/8northroad.rpy:183
translate english northroad_9638a87f:

    # cath "Да, Борис. Я знаю ты будешь его проверять, но мою маленькую проверку он уже прошел."
    cath "是的，Boris。我知道你会去考验他，但他已经通过了我的小小考验。"

# game/a13/8northroad.rpy:184
translate english northroad_338901d5:

    # dubov "..."
    dubov "..."

# game/a13/8northroad.rpy:185
translate english northroad_a673d2f1:

    # cath "Прости, не могу сказать, что именно он сделал, но это поступок достойного мужчины."
    cath "抱歉，我不能说具体他做了什么，但那是一个正直男人该做的事。"

# game/a13/8northroad.rpy:186
translate english northroad_df5a8bdd:

    # dubov "Уверена?"
    dubov "你确定？"

# game/a13/8northroad.rpy:187
translate english northroad_bcd73530:

    # cath "По крайней мере пока что."
    cath "至少目前是。"

# game/a13/8northroad.rpy:188
translate english northroad_e81d7ade:

    # dubov "Пока что?"
    dubov "目前？"

# game/a13/8northroad.rpy:189
translate english northroad_dfae63e2:

    # cath "Он дал слово. И он его держит."
    cath "他给出了承诺，而且他在遵守它。"

# game/a13/8northroad.rpy:190
translate english northroad_3eef6699:

    # dubov "Мне он тоже дал слово."
    dubov "他也给了我承诺。"

# game/a13/8northroad.rpy:191
translate english northroad_72d5bbaa:

    # cath "Уверена, он сдержит оба."
    cath "我相信他会遵守两个承诺的。"

# game/a13/8northroad.rpy:192
translate english northroad_7669724b:

    # dubov "Красный Император тоже был человеком слова..."
    dubov "红帝也是个信守承诺的人..."

# game/a13/8northroad.rpy:193
translate english northroad_f3925fb7:

    # cath "Уверена, принц [mename], не такой."
    cath "我相信，[mename]王子跟他不一样。"

# game/a13/8northroad.rpy:194
translate english northroad_41915f38:

    # dubov "Пока что не такой."
    dubov "至少目前不一样。"

# game/a13/8northroad.rpy:195
translate english northroad_28dbddf5:

    # cath "Верно. Но что-то мне подсказывает... что он будет другим."
    cath "没错。但我有种预感...他会不同的。"

# game/a13/8northroad.rpy:196
translate english northroad_104686a1:

    # dubov "Надеюсь на это."
    dubov "希望如此。"

# game/a13/8northroad.rpy:198
translate english northroad_dfb4f122:

    # me "{i}Надеюсь то, что мы отправляемся не через главные ворота да еще и на рассвете сыграет роль.{/i}"
    me "{i}希望我们不从正门出发，而且还选在拂晓时分这一点能起些作用。{/i}"

# game/a13/8northroad.rpy:199
translate english northroad_db2bba6c:

    # me "{i}Вряд ли кто-то следит. Но все же... а вдруг?{/i}"
    me "{i}大概没人会在监视吧。但万一呢...？{/i}"

# game/a13/8northroad.rpy:200
translate english northroad_1794ea03:

    # me "{i}Нет, нет. Я зря параною. Мы просто прошвырнемся по всем замкам по пути налегке и прибудем в Рубиновое Ущелье.{/i}"
    me "{i}不，不。我是在瞎想。我们就轻装简行地一路拜访所有城堡，然后抵达红宝石峡谷。{/i}"

# game/a13/8northroad.rpy:201
translate english northroad_99b6ad93:

    # me "{i}Успеем до зимы. Я уверен.{/i}"
    me "{i}冬天前能赶到。我确定。{/i}"

# game/a13/8northroad.rpy:202
translate english northroad_5c76dbe7_1:

    # me "{i}...{/i}"
    me "{i}...{/i}"

# game/a13/8northroad.rpy:203
translate english northroad_bb411881:

    # me "{i}Ладно... сейчас думать об этом смысла нет.{/i}"
    me "{i}好了...现在想这些也没用。{/i}"

# game/a13/8northroad.rpy:204
translate english northroad_0ba216c1:

    # me "{i}Я и так выбрал самый быстрый способ. Если что-то пойдет не так...{/i}"
    me "{i}我已经选了最快的办法。如果真出了什么岔子...{/i}"

# game/a13/8northroad.rpy:205
translate english northroad_16249dcc:

    # me "{i}Нет, все будет нормально.{/i}"
    me "{i}不会有事的。{/i}"

# game/a13/8northroad.rpy:206
translate english northroad_7dfb2784:

    # me "{i}Но если что-то пойдет не так... буду думать тогда, когда это случится. Сейчас нужно отправляться в путь.{/i}"
    me "{i}但如果真出问题...那就等发生时再想吧。现在，我得出发了。{/i}"

# game/a13/8northroad.rpy:207
translate english northroad_24abcc5d:

    # harold "Едем, мой принц?"
    harold "出发吗，我的王子？"

# game/a13/8northroad.rpy:208
translate english northroad_f6039ac6:

    # me "Едем."
    me "出发。"

# game/a13/8northroad.rpy:210
translate english northroad_3f73e3d1:

    # harold "Они не зажигали факелы в замке?"
    harold "城堡里没点火把吗？"

# game/a13/8northroad.rpy:211
translate english northroad_4d940d60:

    # me "Я попросил. Не хотел, чтобы лишняя активность выдала наше отправление."
    me "是我吩咐的。我不想不必要的动静暴露我们的行踪。"

# game/a13/8northroad.rpy:212
translate english northroad_4ea217a9:

    # harold "Нам есть чего бояться, мой принц?"
    harold "我们需要害怕什么吗，我的王子？"

# game/a13/8northroad.rpy:213
translate english northroad_4896090f:

    # me "Нет, но предосторожность лишней не будет, верно?"
    me "不需要，但谨慎些总没坏处，对吧？"

# game/a13/8northroad.rpy:214
translate english northroad_c0713d8a:

    # harold "Верно, мой принц. За пределами этого замка начинается Север."
    harold "说得对，我的王子。出了这座城堡，就是真正的北方了。"

# game/a13/8northroad.rpy:215
translate english northroad_d300edea:

    # me "А до этого, где мы были?"
    me "那这之前我们在哪儿？"

# game/a13/8northroad.rpy:216
translate english northroad_fcc4963a:

    # harold "Хельвик и замок Дубовицких это его врата. Дальше настоящий Север."
    harold "Helvik和Dubovitsky的城堡是北方的大门。再往前就是真正的北方了。"

# game/a13/8northroad.rpy:217
translate english northroad_3820771a:

    # me "..."
    me "..."

# game/a13/8northroad.rpy:218
translate english northroad_c6c6fbb0:

    # harold "Не пугайтесь, мой принц. Мы здесь все будем биться за вас насмерть, что бы ни случилось."
    harold "别紧张，我的王子。在这里，无论发生什么，我们都会为您死战到底。"

# game/a13/8northroad.rpy:219
translate english northroad_0967c0ba:

    # me "Я вовсе не напуган, думаю кто у нас первый на пути. Ховрины?"
    me "我不是害怕，是在想我们路上第一个要去的是谁。霍夫林家？"

# game/a13/8northroad.rpy:220
translate english northroad_7e804931:

    # harold "Они вымерли, мой принц."
    harold "那一族已经死绝了，我的王子。"

# game/a13/8northroad.rpy:221
translate english northroad_151489dd:

    # me "Ах, точно. Украдские?"
    me "啊，没错。乌克兰斯基家？"

# game/a13/8northroad.rpy:222
translate english northroad_27f4df59:

    # harold "Они через один замок, мой принц. Первый на пути лорд Корвин."
    harold "他们还要再过一个城堡，我的王子。路上第一个是科温大人。"

# game/a13/8northroad.rpy:224
translate english northroad_90998495:

    # "Восемь часов спустя."
    "八个小时以后。"

# game/a13/8northroad.rpy:225
translate english northroad_bb37c4c0:

    # me "Здесь осень так сильно не ощущается, верно?"
    me "这里的秋意还不算浓，对吧？"

# game/a13/8northroad.rpy:226
translate english northroad_e7f45afe:

    # harold "Хвойные деревья, мой принц, они не желтеют."
    harold "针叶林，我的王子，它们不会变黄。"

# game/a13/8northroad.rpy:227
translate english northroad_6d5e24d0:

    # me "Здесь и трава еще зеленая."
    me "连草都还绿着呢。"

# game/a13/8northroad.rpy:228
translate english northroad_20f6fa62:

    # harold "Верно."
    harold "是啊。"

# game/a13/8northroad.rpy:229
translate english northroad_5f479c97:

    # me "Может и успеем до первых морозов."
    me "也许真能赶在第一场霜冻之前。"

# game/a13/8northroad.rpy:230
translate english northroad_702e0146:

    # harold "Может быть, мой принц."
    harold "也许吧，我的王子。"

# game/a13/8northroad.rpy:232
translate english northroad_937a6a28:

    # "Еще пять часов спустя."
    "又过了五个小时。"

# game/a13/8northroad.rpy:233
translate english northroad_801b1ff5:

    # harold "Темнеет, мой принц. И лошади устали."
    harold "天要黑了，我的王子。马也累了。"

# game/a13/8northroad.rpy:234
translate english northroad_f38af065:

    # me "Может еще часик?"
    me "要不再走一小时？"

# game/a13/8northroad.rpy:235
translate english northroad_c91deb77:

    # harold "Если лошади выбьются из сил то завтра мы пройдем намного меньше."
    harold "要是马累坏了，明天我们能走的路就更少了。"

# game/a13/8northroad.rpy:236
translate english northroad_0db11aa9:

    # me "Хорошо. Остановимся."
    me "好吧。停下休息。"

# game/a13/8northroad.rpy:237
translate english northroad_74c01b5a:

    # harold "Лучше съехать с дороги."
    harold "最好离开大路。"

# game/a13/8northroad.rpy:238
translate english northroad_c897429b:

    # me "Согласен. Тогда привал. Отправимся в дорогу на рассвете."
    me "同意。那就扎营。拂晓再上路。"

# game/a13/8northroad.rpy:240
translate english northroad_7dac0600:

    # "Пару часов спустя."
    "几个小时以后。"

# game/a13/8northroad.rpy:241
translate english northroad_8fa1fbfd:

    # me "{i}Лорд Корвин...{/i}"
    me "{i}科温大人...{/i}"

# game/a13/8northroad.rpy:242
translate english northroad_2ff49138:

    # me "{i}Стоило пораспрашивать побольше о всех, кто встретится на пути.{/i}"
    me "{i}真应该多打听打听路上会遇到的每一个人。{/i}"

# game/a13/8northroad.rpy:243
translate english northroad_1985b672:

    # me "{i}Так... что я записал? Он вдовец и он довольно нелюдим.{/i}"
    me "{i}看看...我都记了什么？他丧偶独居，性格孤僻。{/i}"

# game/a13/8northroad.rpy:244
translate english northroad_9396eaec:

    # me "{i}Надеюсь не настолько, чтобы не впускать нас внутрь.{/i}"
    me "{i}希望没孤僻到不愿意让我们进去的程度。{/i}"

# game/a13/8northroad.rpy:246
translate english northroad_9adc8205:

    # me "{i}Леди Катерина говорила, что у него есть сын. Жена умерла уже довольно давно.{/i}"
    me "{i}Katerina夫人说，他有个儿子，妻子已经去世很久了。{/i}"

# game/a13/8northroad.rpy:247
translate english northroad_0fefd253:

    # me "{i}Сам лорд не очень стар. Странно. Почему он не женился второй раз?{/i}"
    me "{i}他本人并不算老。奇怪，为什么他没有续弦？{/i}"

# game/a13/8northroad.rpy:248
translate english northroad_24474854:

    # me "{i}Сильно любил свою жену? Или не нашел подходящую кандидатку?{/i}"
    me "{i}太深爱自己的妻子？还是没找到合适的人选？{/i}"

# game/a13/8northroad.rpy:250
translate english northroad_e2844a2b:

    # me "{i}Его сын может быть потенциальным женихом для Рамоны. Близко к Хельвику, этот союз может быть выгоден.{/i}"
    me "{i}他的儿子也许是拉莫娜的潜在丈夫人选。离Helvik很近，这桩联姻可能有利可图。{/i}"

# game/a13/8northroad.rpy:251
translate english northroad_596bb8f6:

    # me "{i}Лорд Дубовицкий говорил, что лорд Корвин любит искусство, значит он должен быть богат.{/i}"
    me "{i}Dubovitsky大人说，科温大人热爱艺术，那他一定很富有。{/i}"

# game/a13/8northroad.rpy:252
translate english northroad_861b85c6:

    # me "{i}Во всяком случае бедный лорд многого себе бы позволить не смог.{/i}"
    me "{i}至少一个贫穷的领主是供不起太多爱好的。{/i}"

# game/a13/8northroad.rpy:253
translate english northroad_a6ce7469:

    # me "{i}Рощи да леса вокруг. Интересно откуда он заработал себе состояние.{/i}"
    me "{i}周围都是小树林和森林，真想知道他是怎么赚下这份家业的。{/i}"

# game/a13/8northroad.rpy:255
translate english northroad_f9842007:

    # harold "Мой принц, мы развели костер, готовим еду. Там тепло. Идите к нам."
    harold "我的王子，我们点好了篝火，在准备食物。那边暖和，过来吧。"

# game/a13/8northroad.rpy:256
translate english northroad_e0c12944:

    # me "Спасибо, мне и здесь неплохо."
    me "谢谢，我在这里也挺好的。"

# game/a13/8northroad.rpy:257
translate english northroad_64164bf0:

    # harold "Уверены? Ночью будет еще холоднее."
    harold "您确定吗？夜里会更冷的。"

# game/a13/8northroad.rpy:258
translate english northroad_07b13f5b:

    # me "Уверен. Если станет совсем невмоготу я приду."
    me "确定。要是实在受不了了，我会过去的。"

# game/a13/8northroad.rpy:259
translate english northroad_2c22f83e:

    # harold "Хорошо, мой принц."
    harold "好的，我的王子。"

# game/a13/8northroad.rpy:260
translate english northroad_8c6faf77:

    # me "Караул выставили?"
    me "安排岗哨了吗？"

# game/a13/8northroad.rpy:261
translate english northroad_98ae93bd:

    # harold "Да. Сначала я и Рональд, потом поменяемся."
    harold "安排了。先是我和Ronald，然后换班。"

# game/a13/8northroad.rpy:262
translate english northroad_71d3b8c8_1:

    # me "Хорошо."
    me "好。"

# game/a13/8northroad.rpy:263
translate english northroad_cd2a5aa5:

    # harold "Уверены, что не хотите к нам? Может хоть принесу вам поесть?"
    harold "您确定不过来吗？至少让我给您送点吃的过来？"

# game/a13/8northroad.rpy:264
translate english northroad_ac59c86c:

    # me "Спасибо, я наелся сушеного мяса, пока мы ехали. Иди."
    me "谢谢，路上我吃了不少肉干。你去吧。"

# game/a13/8northroad.rpy:265
translate english northroad_cad701fd:

    # harold "Да, мой принц."
    harold "是，我的王子。"

# game/a13/8northroad.rpy:267
translate english northroad_343b06a0:

    # me "{i}Ладно. Больше я о лорде Корвине ничего не записывал. Разберемся на месте.{/i}"
    me "{i}好吧。关于科温大人，我就记了这么多。到了那儿再见机行事吧。{/i}"

# game/a13/8northroad.rpy:268
translate english northroad_ac3b5be2:

    # me "{i}Тем более я хочу спать.{/i}"
    me "{i}再说我也想睡了。{/i}"

# game/a13/8northroad.rpy:269
translate english northroad_371f3b4c:

    # me "{i}Если будем идти в том же темпе, то завтра, возможно, даже не придется морозить задницу на холодной земле.{/i}"
    me "{i}如果保持这个速度，明天也许就不用在这冰冷的地上冻屁股了。{/i}"

# game/a13/8northroad.rpy:270
translate english northroad_5adf1eba:

    # me "{i}Я слышал это довольно вредно. Так можно и ограничиться только одним наследником...{/i}"
    me "{i}我听说那样挺伤身的。搞不好就只能有一个继承人了...{/i}"

# game/a13/8northroad.rpy:271
translate english northroad_490b42b2:

    # me "{i}Ладно. Пока еще терпимо, если что - пойду спать к костру.{/i}"
    me "{i}算了。现在还能忍，要是真撑不住了，就去篝火旁睡。{/i}"

# game/a13/8northroad.rpy:272
translate english northroad_99c866f9:

    # me "{i}А пока...{/i}"
    me "{i}至于现在...{/i}"

# game/a13/8northroad.rpy:273
translate english northroad_e246db31:

    # me "{i}...посплю здесь.{/i}"
    me "{i}...就在这儿睡吧。{/i}"

# game/a13/8northroad.rpy:275
translate english northroad_760d42f4:

    # me "{i}Как много лордов дадут мне людей?{/i}"
    me "{i}会有多少领主给我人马呢？{/i}"

# game/a13/8northroad.rpy:276
translate english northroad_ec027aad:

    # me "{i}Все? Вряд ли. Получить бы хотя бы сотню людей.{/i}"
    me "{i}全部？不太可能。哪怕能有百来个人也行。{/i}"

# game/a13/8northroad.rpy:277
translate english northroad_62c3cb0e:

    # me "{i}Если с горцами придется воевать - не хотелось бы делать это только с моим отрядом.{/i}"
    me "{i}如果真得和山民开战——我可不想只靠我自己的队伍去打。{/i}"

# game/a13/8northroad.rpy:278
translate english northroad_2ebe1633:

    # me "{i}Боюсь даже если я буду полезен, мое участие будет не слишком заметным.{/i}"
    me "{i}恐怕就算我帮上忙，我的那点贡献也会显得微不足道。{/i}"

# game/a13/8northroad.rpy:279
translate english northroad_739def73:

    # me "{i}Посчитает ли тогда лорд Дубовицкий наш уговор действительным?{/i}"
    me "{i}那样的话，Dubovitsky大人还会不会承认我们的约定？{/i}"

# game/a13/8northroad.rpy:280
translate english northroad_0752e3b3:

    # me "{i}Не уверен...{/i}"
    me "{i}我不太确定...{/i}"

# game/a13/8northroad.rpy:281
translate english northroad_ef78bcc3:

    # me "{i}...впрочем нужно ли мне вообще соблюдать этот договор?{/i}"
    me "{i}...话说回来，我到底需不需要遵守这个约定？{/i}"

# game/a13/8northroad.rpy:282
translate english northroad_a58abd30:

    # me "{i}В конце концов это враг моей семьи.{/i}"
    me "{i}毕竟，他可是我家族的敌人。{/i}"

# game/a13/8northroad.rpy:283
translate english northroad_13b9217f:

    # me "{i}Когда-то точно им был...{/i}"
    me "{i}至少曾经是...{/i}"

# game/a13/8northroad.rpy:284
translate english northroad_4c378183:

    # me "{i}Хотя когда-то его родители укрывали моего деда.{/i}"
    me "{i}虽然他的父母也曾经庇护过我的祖父。{/i}"

# game/a13/8northroad.rpy:285
translate english northroad_5c76dbe7_2:

    # me "{i}...{/i}"
    me "{i}...{/i}"

# game/a13/8northroad.rpy:287
translate english northroad_a691f599:

    # redp "Родители будут тебя искать."
    redp "你父母会找你的。"

# game/a13/8northroad.rpy:288
translate english northroad_d886e0f8:

    # yulie "Отец не встает с постели. Ты же знаешь."
    yulie "父亲已经下不了床了。你是知道的。"

# game/a13/8northroad.rpy:289
translate english northroad_654b1065:

    # redp "А твоя мать? Наверняка просит слуг за мной следить. Она явно недовольна тем, сколько мы проводим времени вместе. "
    redp "那你的母亲呢？她肯定派仆人在盯我的梢。她明显很不满我们总待在一起。"

# game/a13/8northroad.rpy:290
translate english northroad_ed1d8fbf:

    # yulie "А ты?"
    yulie "那你呢？"

# game/a13/8northroad.rpy:291
translate english northroad_37b149ce:

    # redp "А что я?"
    redp "我怎么了？"

# game/a13/8northroad.rpy:292
translate english northroad_d85f7fac:

    # yulie "Ты доволен? Или мне уйти?"
    yulie "你满意吗？还是说，我该离开？"

# game/a13/8northroad.rpy:293
translate english northroad_eb745950:

    # redp "Ты знаешь ответ."
    redp "你知道答案的。"

# game/a13/8northroad.rpy:294
translate english northroad_2f5a4902:

    # yulie "Знаю. Но хочу чтобы ты сказал вслух."
    yulie "是知道。但我要你亲口说出来。"

# game/a13/8northroad.rpy:295
translate english northroad_87365f9a:

    # redp "Хочу чтобы ты осталась."
    redp "我要你留下来。"

# game/a13/8northroad.rpy:296
translate english northroad_63609961:

    # yulie "... ты же знаешь, что твой племянник осадил замок Дубовицких?"
    yulie "...你知道你的侄子把Dubovitsky的城堡围了吗？"

# game/a13/8northroad.rpy:297
translate english northroad_0117f054:

    # redp "Марвин? Пусть впускают его. Меня ведь там нет."
    redp "Marvin吗？让他们进来好了，反正我又不在那儿。"

# game/a13/8northroad.rpy:298
translate english northroad_074fb28d:

    # yulie "..."
    yulie "..."

# game/a13/8northroad.rpy:299
translate english northroad_d1aef959:

    # yulie "Думаешь в этот раз твой отец все-таки умрет?"
    yulie "你觉得这回你父亲真会死吗？"

# game/a13/8northroad.rpy:300
translate english northroad_7c7ebfd9:

    # redp "Похоже на то. Хотя помнится лет десять назад он кашлял кровью и все хоронили его уже тогда."
    redp "看起来像是。不过话说回来，大概十年前他也咳血，那时候大家就都等着埋他了。"

# game/a13/8northroad.rpy:301
translate english northroad_bfc8747a:

    # yulie "Так..."
    yulie "所以..."

# game/a13/8northroad.rpy:302
translate english northroad_e8b3b412:

    # redp "Нет. Думаю в этот раз он умрет. Если уже не умер."
    redp "不。我觉得这回他是真的要死了。也许已经死了。"

# game/a13/8northroad.rpy:303
translate english northroad_25f4cfc3:

    # yulie "Разве некому за тебя заступиться в столице? Ты же законный наследник."
    yulie "难道首都就没人能为你说话吗？你可是合法的继承人啊。"

# game/a13/8northroad.rpy:304
translate english northroad_678302bf:

    # redp "Мой брат озаботился тем, чтобы запихнуть меня как можно дальше, прежде чем умрет. А друзей в Столице теряют точно также быстро, как и находят."
    redp "我的好哥哥在临死前，费尽心机把我支得远远的。至于首都里的朋友，找到得快，丢得也快。"

# game/a13/8northroad.rpy:305
translate english northroad_671fac12:

    # yulie "И что же, они так и будут искать тебя?"
    yulie "那，他们会一直找你吗？"

# game/a13/8northroad.rpy:306
translate english northroad_5f9d038c:

    # redp "Нет. Когда отец умрет, каждый из моих племянников захочет оказаться поближе к трону. Там много работы, нужно подкупить городской трибунал и запугать имперский совет."
    redp "不会。一旦父亲去世，我的每个侄子都会争着接近王座。那边够他们忙的，得贿赂城市裁判庭，还得恐吓帝国议会。"

# game/a13/8northroad.rpy:307
translate english northroad_be14b553:

    # redp "Тот, кто будет далеко - ничего не получит. Я начну собирать армию, как только Марвин уйдет отсюда."
    redp "谁离得远，谁就什么都得不到。等Marvin一离开这里，我就开始招募军队。"

# game/a13/8northroad.rpy:308
translate english northroad_abc4fda6:

    # yulie "А если не уйдет?"
    yulie "他要是不走呢？"

# game/a13/8northroad.rpy:309
translate english northroad_5b8bd127:

    # redp "Уйдет. Хотел бы он искать меня по-настоящему, остановился бы на самом первом замке по пути?"
    redp "他会走的。要是真想抓我，他会在第一座城堡就停下来吗？"

# game/a13/8northroad.rpy:310
translate english northroad_a88921cc:

    # yulie "...ты ведь вернешься?"
    yulie "...你一定会回来的，对吧？"

# game/a13/8northroad.rpy:312
translate english northroad_d1b4bc76:

    # redp "В столицу? Конечно. Корона моя. Таков Золотой Порядок и так решил мой отец, когда я говорил с ним в последний раз."
    redp "回首都？当然。那是我的王冠。这是黄金秩序决定的，也是我父亲最后一次同我谈话时的决定。"

# game/a13/8northroad.rpy:313
translate english northroad_1a95d021:

    # yulie "Почему же он просто не объявил тебя принцем-регентом?"
    yulie "那他为什么不直接任命你为摄政王子？"

# game/a13/8northroad.rpy:314
translate english northroad_7f75bc51:

    # redp "Чтобы меня убили прямо там, на месте?"
    redp "好让我当场被他们杀掉吗？"

# game/a13/8northroad.rpy:315
translate english northroad_f15bb95f:

    # yulie "Прости. Я не сведуща в дворцовых интригах."
    yulie "抱歉。我对宫廷阴谋一窍不通。"

# game/a13/8northroad.rpy:316
translate english northroad_9c059c2d:

    # redp "Это никакие не интриги, просто кровавая бойня за власть. Я не мог действовать, пока с десяток мечей моих племянников были слишком близко к моему горлу."
    redp "这哪是什么阴谋，就是一场权力争夺的血腥混战。当时我十几个侄子的刀剑都离我的喉咙太近了，我没法行动。"

# game/a13/8northroad.rpy:317
translate english northroad_ede8d3bc:

    # yulie "А сюда ты вернешься?"
    yulie "那你还会回这里来吗？"

# game/a13/8northroad.rpy:318
translate english northroad_d27c7bf8:

    # redp "Когда выиграю, обязательно вернусь. Я должен отблагодарить тех, кто мне помогал."
    redp "等我赢了，一定会回来。我必须报答那些帮助过我的人。"

# game/a13/8northroad.rpy:319
translate english northroad_18253b58:

    # yulie "Возьмешь моего брата в оруженосцы?"
    yulie "你会收我弟弟当侍从吗？"

# game/a13/8northroad.rpy:320
translate english northroad_50788971:

    # redp "Он уже служит у Дубовицких."
    redp "他已经为Dubovitsky家效力了。"

# game/a13/8northroad.rpy:321
translate english northroad_7555c8c8:

    # yulie "А будет служить у Императора."
    yulie "那他将为皇帝效力。"

# game/a13/8northroad.rpy:322
translate english northroad_02b74ffc:

    # redp "Если он пожелает. Твоя семья мне очень помогла, это меньшее, что я могу сделать."
    redp "如果他愿意的话。你的家族帮助了我很多，这是我起码能做的。"

# game/a13/8northroad.rpy:323
translate english northroad_2d8e3dfe:

    # yulie "Здорово. А что насчет меня?"
    yulie "太好了。那我呢？"

# game/a13/8northroad.rpy:324
translate english northroad_0f8e2b7d:

    # redp "Я уже говорил тебе. Я связан клятвой."
    redp "我已经告诉过你了。我受誓言约束。"

# game/a13/8northroad.rpy:325
translate english northroad_f76f86a1:

    # yulie "Ты выбрал жену не по любви. Это не считается."
    yulie "你这桩婚姻不是出于爱情。这不算数。"

# game/a13/8northroad.rpy:326
translate english northroad_a9dc3236:

    # redp "Я выбрал ее сам."
    redp "是我自己选的妻子。"

# game/a13/8northroad.rpy:327
translate english northroad_d27f7fbe:

    # yulie "Да. Но для союза. Ты был вынужден."
    yulie "是。但那是为了结盟。你是被迫的。"

# game/a13/8northroad.rpy:328
translate english northroad_ea512a78:

    # redp "Клятва есть клятва. К тому же я консумировал брак, у меня есть сын."
    redp "誓言就是誓言。再说，我已经圆了房，也有了儿子。"

# game/a13/8northroad.rpy:329
translate english northroad_1a9d7c16:

    # yulie "Но ведь наша...связь для тебя что-то значит?"
    yulie "但我们之间的...这段感情，对你来说有意义吧？"

# game/a13/8northroad.rpy:330
translate english northroad_abbe4307:

    # redp "Ну конечно."
    redp "当然有。"

# game/a13/8northroad.rpy:331
translate english northroad_e8c23dc2:

    # yulie "Хорошо. И я..."
    yulie "很好。那我..."

# game/a13/8northroad.rpy:332
translate english northroad_7ea1cde4:

    # redp "Не надо."
    redp "别说了。"

# game/a13/8northroad.rpy:333
translate english northroad_7de96f3b:

    # yulie "Я тебя люблю. А ты меня?"
    yulie "我爱你。你呢？"

# game/a13/8northroad.rpy:334
translate english northroad_d368daf5:

    # redp "Я тоже тебя люблю. Но должна понимать..."
    redp "我也爱你。但你要明白..."

# game/a13/8northroad.rpy:335
translate english northroad_fc9a1e57:

    # yulie "Я все понимаю."
    yulie "我都明白。"

# game/a13/8northroad.rpy:336
translate english northroad_eb1f3a12:

    # redp "Я в этом не уверен."
    redp "我不太确定。"

# game/a13/8northroad.rpy:337
translate english northroad_dabe554d:

    # yulie "Лотрик."
    yulie "Lotric。"

# game/a13/8northroad.rpy:338
translate english northroad_46b4bf4e:

    # redp "М?"
    redp "嗯？"

# game/a13/8northroad.rpy:340
translate english northroad_7a65bcc5:

    # yulie "Я тут подумала, если ты скоро уедешь... мы ведь долго не увидимся?"
    yulie "我刚刚在想，既然你很快就要走了...我们会有很久见不到面，对吧？"

# game/a13/8northroad.rpy:341
translate english northroad_e9484f34:

    # redp "Ну да."
    redp "是啊。"

# game/a13/8northroad.rpy:342
translate english northroad_7614f386:

    # yulie "Может ты бы мог полюбить меня... по-настоящему?"
    yulie "或许...你可以真正地爱我一次？"

# game/a13/8northroad.rpy:343
translate english northroad_cbd4f9de:

    # redp "Не сходи с ума. Того, что между нами было и так быть не должно. А ты просишь..."
    redp "别发疯了。我们之间发生的事本来就不该发生。你居然还要..."

# game/a13/8northroad.rpy:344
translate english northroad_de785de5:

    # yulie "Вот именною. Я ведь сама прошу об этом."
    yulie "就是这句话。是我自己求你的。"

# game/a13/8northroad.rpy:345
translate english northroad_b11cf833:

    # redp "Я не стану тебя портить."
    redp "我不会玷污你。"

# game/a13/8northroad.rpy:346
translate english northroad_143181c5:

    # yulie "Ты меня не испортишь. Как тот, кого я люблю, может меня испортить?"
    yulie "你玷污不了我。我爱的人，怎么可能玷污我？"

# game/a13/8northroad.rpy:347
translate english northroad_243960f0:

    # redp "Ты знаешь как, ты будешь непригодна для брака."
    redp "你知道怎么玷污，你会变得不适合出嫁。"

# game/a13/8northroad.rpy:348
translate english northroad_37a6d5f0:

    # yulie "Для брака со всеми, кроме тебя."
    yulie "除了嫁给你以外，谁都不适合了。"

# game/a13/8northroad.rpy:349
translate english northroad_86d26e4c:

    # redp "Вот именно. Кроме меня. А я уже женат."
    redp "就是这样。除了我。可我已经结婚了。"

# game/a13/8northroad.rpy:350
translate english northroad_d4202e27:

    # yulie "Женат... а что если с твоей женой что-то случится?"
    yulie "结婚了...那如果你妻子出了什么事呢？"

# game/a13/8northroad.rpy:351
translate english northroad_467ac3f0:

    # redp "Например?"
    redp "比如说？"

# game/a13/8northroad.rpy:352
translate english northroad_4630e3fe:

    # yulie "Что угодно. Я буду ждать тебя. Ты сможешь жениться на мне."
    yulie "什么都好。我会等着你。到时候你就可以娶我了。"

# game/a13/8northroad.rpy:353
translate english northroad_4a1f3eab:

    # redp "Ты будешь ждать, пока моя жена умрет, чтобы стать моей новой женой?"
    redp "你要等着我妻子死去，好成为我的新妻子？"

# game/a13/8northroad.rpy:354
translate english northroad_a25a14ed:

    # yulie "Ну да."
    yulie "嗯，对啊。"

# game/a13/8northroad.rpy:355
translate english northroad_4b907004:

    # redp "Это безумие. Она может умереть через двадцать лет. А может вообще умереть позже меня."
    redp "这太疯狂了。她可能还要活二十年，甚至可能活得比我还长。"

# game/a13/8northroad.rpy:356
translate english northroad_6e59ebec:

    # yulie "Это не безумие. Это любовь. Я готова ждать сколько угодно. Лишь бы ты подарил мне причину не сомневаться в твоей любви."
    yulie "这不是疯狂，这是爱情。我已经准备一直等下去。只要能给我个理由，让我不再怀疑你的爱就好。"

# game/a13/8northroad.rpy:357
translate english northroad_456c2449:

    # redp "Моя любовь настоящая. Именно поэтому я не желаю тебе такой жизни. И не желаю портить тебя для твоего мужа."
    redp "我的爱是真的。正因为是真的，我才不愿你过那样的日子，也不愿让你为了你未来的丈夫，败坏了身子。"

# game/a13/8northroad.rpy:358
translate english northroad_c02a27e0:

    # yulie "А я не хочу другой жизни. Я хочу чтобы моим мужем был ты."
    yulie "可我不想要别的生活。我只想让你成为我的丈夫。"

# game/a13/8northroad.rpy:359
translate english northroad_24d3297e:

    # redp "Ты не понимаешь, что ты говоришь."
    redp "你根本不知道自己在说什么。"

# game/a13/8northroad.rpy:360
translate english northroad_e202da4a:

    # yulie "Ты не понимаешь, насколько я тебя люблю, Лотрик. Я никогда не встречала никого, такого же смелого, умного, справедливого, честного..."
    yulie "你不知道我有多爱你，Lotric。我从没见过像你这样勇敢、聪明、公正、诚实的人..."

# game/a13/8northroad.rpy:361
translate english northroad_74d07dd5:

    # redp "Вот именно. Честного. Я честно тебе говорю - ты просто погубишь себя."
    redp "正是这样。诚实。我诚实地告诉你——你这样做只会毁了自己。"

# game/a13/8northroad.rpy:362
translate english northroad_fdc194b8:

    # yulie "Значит так оно и будет."
    yulie "那这就是我的命。"

# game/a13/8northroad.rpy:363
translate english northroad_7503419c:

    # redp "Прошу, не нужно этого делать."
    redp "求你了，别这样。"

# game/a13/8northroad.rpy:364
translate english northroad_a787d829:

    # yulie "Но ведь ты тоже меня любишь."
    yulie "可你也爱我啊。"

# game/a13/8northroad.rpy:365
translate english northroad_44bc2445:

    # redp "Я будущий Император. А любовь... любовь это смерть долга."
    redp "我是未来的皇帝。而爱...爱是责任的大敌。"

# game/a13/8northroad.rpy:366
translate english northroad_1715e0f2:

    # yulie "Я не желаю видеть своим мужем никого, кроме тебя."
    yulie "除了你，我不愿嫁给任何人做丈夫。"

# game/a13/8northroad.rpy:367
translate english northroad_28057899:

    # redp "Я надеюсь твой разум прояснится."
    redp "我希望你能清醒过来。"

# game/a13/8northroad.rpy:368
translate english northroad_fb245ecc:

    # yulie "Проверишь это сам когда вернешься ко мне. Ты ведь вернешься? Хотя бы прост проведать?"
    yulie "等你回到我身边时，亲自验证吧。你会回来的，对吧？就算只是来看看？"

# game/a13/8northroad.rpy:369
translate english northroad_446bb984:

    # redp "Вернусь."
    redp "我会回来的。"

# game/a13/8northroad.rpy:370
translate english northroad_2378df05:

    # yulie "Обещаешь?"
    yulie "你保证？"

# game/a13/8northroad.rpy:371
translate english northroad_4cc59ce3:

    # redp "Обещаю."
    redp "我保证。"

# game/a13/8northroad.rpy:373
translate english northroad_5c76dbe7_3:

    # me "{i}...{/i}"
    me "{i}...{/i}"

# game/a13/8northroad.rpy:374
translate english northroad_6947697b:

    # me "{i}Ну и сны...{/i}"
    me "{i}这都是些什么梦啊...{/i}"

# game/a13/8northroad.rpy:375
translate english northroad_6ea43c1c:

    # me "{i}Это был мой дед?{/i}"
    me "{i}那是我的祖父？{/i}"

# game/a13/8northroad.rpy:376
translate english northroad_19192ec5:

    # me "{i}Да. Это определенно был он.{/i}"
    me "{i}是。那肯定是他。{/i}"

# game/a13/8northroad.rpy:377
translate english northroad_653b48a9:

    # me "{i}Он сидел на этом же месте?{/i}"
    me "{i}他也坐在这同一个地方吗？{/i}"

# game/a13/8northroad.rpy:378
translate english northroad_052e7739:

    # me "{i}Нет... мне просто так приснилось. Потому что я заснул здесь.{/i}"
    me "{i}不...只是我梦见了，因为我在这儿睡着了。{/i}"

# game/a13/8northroad.rpy:379
translate english northroad_5c76dbe7_4:

    # me "{i}...{/i}"
    me "{i}...{/i}"

# game/a13/8northroad.rpy:380
translate english northroad_f304d157:

    # me "{i}Хотя... те руины по пути... Мокрый Холм должен быть неподалеку... Может это он и есть?{/i}"
    me "{i}不过...路上那片废墟...湿丘应该就在不远处...也许就是这儿？{/i}"

# game/a13/8northroad.rpy:382
translate english northroad_6a69d1db:

    # me "{i}Совсем рядом. Если Лотрик сидел здесь с этой девушкой... наверное это и есть замок Ховриных.{/i}"
    me "{i}非常近了。如果Lotric是和那个姑娘一起坐在这儿...那这大概就是霍夫林家的城堡。{/i}"

# game/a13/8northroad.rpy:383
translate english northroad_bb6a7da0:

    # me "{i}Какой еще заброшенный замок может быть по пути?{/i}"
    me "{i}路上还能有什么别的废弃城堡？{/i}"

# game/a13/8northroad.rpy:384
translate english northroad_5c76dbe7_5:

    # me "{i}...{/i}"
    me "{i}...{/i}"

# game/a13/8northroad.rpy:385
translate english northroad_bb7ab448:

    # me "{i}Но ведь тогда это не просто сон...{/i}"
    me "{i}但要是那样，这就不仅仅是个梦了...{/i}"

# game/a13/8northroad.rpy:386
translate english northroad_cfa24a76:

    # me "{i}Опять видения?{/i}"
    me "{i}又是幻象？{/i}"

# game/a13/8northroad.rpy:387
translate english northroad_5f94ac0d:

    # me "{i}Нет... нет... это просто сон.{/i}"
    me "{i}不...不...这只是个梦而已。{/i}"

# game/a13/8northroad.rpy:388
translate english northroad_58c2591f:

    # me "{i}Я не буду проверять. Да и как я это сделаю?{/i}"
    me "{i}我不会去查证的。再说我要怎么查证？{/i}"

# game/a13/8northroad.rpy:389
translate english northroad_a3b8d2ad:

    # me "{i}...твою мать. Что со мной не так?{/i}"
    me "{i}...可恶。我到底怎么了？{/i}"

# game/a13/8northroad.rpy:391
translate english northroad_8ed30a09:

    # me "{i}Да. Выглядит заброшенным много лет.{/i}"
    me "{i}是。看起来确实荒废多年了。{/i}"

# game/a13/8northroad.rpy:392
translate english northroad_5fb85806:

    # me "{i}Неужели никто не поселился здесь за много лет?{/i}"
    me "{i}这么多年来，难道就没人住进来吗？{/i}"

# game/a13/8northroad.rpy:393
translate english northroad_3035a672:

    # me "{i}Или законы Севера запрещают селиться в заброшенных замках?{/i}"
    me "{i}还是说北方的法律禁止占据废弃的城堡？{/i}"

# game/a13/8northroad.rpy:394
translate english northroad_0126d197:

    # me "{i}Впрочем эльфам и прочим бродягам на такие законы обычно все равно.{/i}"
    me "{i}不过，精灵和其他流浪汉通常可不在乎这种法律。{/i}"

# game/a13/8northroad.rpy:395
translate english northroad_fa8515ee:

    # me "{i}Воздух какой-то... спертый.{/i}"
    me "{i}空气有点...闷。{/i}"

# game/a13/8northroad.rpy:396
translate english northroad_5ed0ebc4:

    # me "{i}Наверняка полно пыли.{/i}"
    me "{i}肯定全是灰尘。{/i}"

# game/a13/8northroad.rpy:398
translate english northroad_bd536825:

    # me "{i}Что я вообще здесь ищу?{/i}"
    me "{i}我到底在这里找什么？{/i}"

# game/a13/8northroad.rpy:399
translate english northroad_7cb8065b:

    # me "{i}Даже если это замок Ховриных, что с того?{/i}"
    me "{i}就算这是霍夫林家的城堡，又怎么样？{/i}"

# game/a13/8northroad.rpy:400
translate english northroad_bc2ecef3:

    # me "{i}Даже если мой сон был видением прошлого, какая разница?{/i}"
    me "{i}就算我的梦是过去的景象，又有什么分别？{/i}"

# game/a13/8northroad.rpy:401
translate english northroad_892c9d06:

    # me "{i}Зачем я сюда пришел?{/i}"
    me "{i}我为什么来了这儿？{/i}"

# game/a13/8northroad.rpy:402
translate english northroad_85f9b352:

    # me "{i}...словно меня что-то манит сюда.{/i}"
    me "{i}...就好像有什么东西在吸引我。{/i}"

# game/a13/8northroad.rpy:403
translate english northroad_b054e333:

    # me "{i}Будто я должен.{/i}"
    me "{i}好像我有义务来。{/i}"

# game/a13/8northroad.rpy:404
translate english northroad_ad476801:

    # me "{i}Но зачем?{/i}"
    me "{i}但到底为什么？{/i}"

# game/a13/8northroad.rpy:405
translate english northroad_94ba6d10:

    # me "{i}Лучше повернуть обратно.{/i}"
    me "{i}还是掉头回去的好。{/i}"

# game/a13/8northroad.rpy:407
translate english northroad_1d2d3e1b:

    # me "Кто здесь?"
    me "谁在那里？"

# game/a13/8northroad.rpy:408
translate english northroad_ab515016:

    # me "{i}Похоже бродяги здесь все же живут.{/i}"
    me "{i}看来流浪汉确实住在这儿。{/i}"

# game/a13/8northroad.rpy:409
translate english northroad_53352481:

    # me "{i}А может и что похуже.{/i}"
    me "{i}又或者，是更糟糕的东西。{/i}"

# game/a13/8northroad.rpy:410
translate english northroad_57cdaffd:

    # me "{i}Зачем я вообще сюда поперся? Больше не буду слушать внутренний голос. Никогда.{/i}"
    me "{i}我到底是为什么要跑进来？再也不听内心那个声音了。绝不会了。{/i}"

# game/a13/8northroad.rpy:411
translate english northroad_5c76dbe7_6:

    # me "{i}...{/i}"
    me "{i}...{/i}"

# game/a13/8northroad.rpy:412
translate english northroad_28905316:

    # me "Эй! Выходи, я тебя не трону."
    me "嘿！出来吧，我不会伤害你的。"

# game/a13/8northroad.rpy:413
translate english northroad_7743325f:

    # me "{i}С кем я говорю? Если здесь что-то и прячется, оно явно не станет выходить ко мне по первому зову.{/i}"
    me "{i}我在跟谁说话？就算真有东西藏在这里，它也不会听我一叫就出来。{/i}"

# game/a13/8northroad.rpy:414
translate english northroad_8605c7eb:

    # me "{i}Ладно. Лучше просто уйти. Да. Так и сделаю.{/i}"
    me "{i}算了。最好还是离开。对，就这么办。{/i}"

# game/a13/8northroad.rpy:417
translate english northroad_c123a7aa:

    # girl "Ты вернулся."
    girl "你回来了。"

# game/a13/8northroad.rpy:418
translate english northroad_cd3ac828:

    # me "{size=+5}КТО ЗДЕСЬ?{/size}"
    me "{size=+5}谁在那儿？{/size}"

# game/a13/8northroad.rpy:419
translate english northroad_7ed2af4d:

    # girl "Прости, я не хотела тебя напугать."
    girl "对不起，我没想吓你。"

# game/a13/8northroad.rpy:420
translate english northroad_93b3e572:

    # me "Кто ты? Покажись!"
    me "你是谁？现身！"

# game/a13/8northroad.rpy:422
translate english northroad_1802ac28:

    # girl "Я уже показалась. По ночам здесь маловато света. Прости. Свечи нынче дорогие. А с тех пор как умер отец, мы едва сводим концы с концами."
    girl "我已经现出来了。这里晚上光线不太好。抱歉。现在蜡烛很贵。父亲死后，我们只能勉强糊口。"

# game/a13/8northroad.rpy:423
translate english northroad_5fd96d65:

    # girl "Но я очень рада тебя снова видеть!"
    girl "但我真的很高兴再见到你！"

# game/a13/8northroad.rpy:424
translate english northroad_3c912647:

    # me "Меня?"
    me "我？"

# game/a13/8northroad.rpy:425
translate english northroad_188bcb0a:

    # girl "Ну да. Ты все-таки сдержал обещание."
    girl "是啊。你毕竟还是遵守了诺言。"

# game/a13/8northroad.rpy:426
translate english northroad_e581ea13:

    # me "Прости. Я ничего не обещал."
    me "对不起。我什么也没答应过。"

# game/a13/8northroad.rpy:427
translate english northroad_8d6da31a:

    # girl "Разве? Ни разу за жизнь?"
    girl "是吗？这辈子都没有？"

# game/a13/8northroad.rpy:428
translate english northroad_a65dc055:

    # me "Тебе? Ну думаю."
    me "对你？应该没有吧。"

# game/a13/8northroad.rpy:429
translate english northroad_acac006a:

    # girl "Мне. Ты мне обещал."
    girl "对我。你答应过我。"

# game/a13/8northroad.rpy:430
translate english northroad_0b34c373:

    # me "Кто ты?"
    me "你是谁？"

# game/a13/8northroad.rpy:431
translate english northroad_861d0547:

    # girl "Понимаю. Прошло так много времени. Ты и не помнишь."
    girl "我明白。过了这么长时间，你也不记得了。"

# game/a13/8northroad.rpy:432
translate english northroad_6fbb4a44:

    # me "Ты меня с кем-то перепутала. Я здесь впервые."
    me "你认错人了。我是第一次来这里。"

# game/a13/8northroad.rpy:433
translate english northroad_76970b29:

    # girl "Ну как же... нет. Ты определенно он. Пахнешь как он. Двигаешься как он. Ходишь как он. Разве что постарел. Седина тронула волосы."
    girl "怎么可能...不。你肯定就是他。你的气味像他，动作像他，走路也像他。只是更老了，头发都花白了。"

# game/a13/8northroad.rpy:434
translate english northroad_b0e01d81:

    # girl "Но оно и не удивительно. Столько времени прошло."
    girl "但这也不奇怪吧。过了这么久了。"

# game/a13/8northroad.rpy:436
translate english northroad_60e9a310:

    # girl "Но я все это время ждала тебя. Видишь? У меня все готово. И платье и капеллан, знаю у вас так не принято, но раз уж мы на Севере, то поклясться лучше перед безымянным богом."
    girl "但我一直在等你。看到了吗？我都准备好了。连衣裙和随行神父。我知道你们那边风俗不一样，但既然我们在北方，最好还是向无名之神起誓。"

# game/a13/8northroad.rpy:437
translate english northroad_71b3e1ec:

    # me "Готов для чего?"
    me "准备好什么？"

# game/a13/8northroad.rpy:438
translate english northroad_542f5673:

    # girl "Для свадьбы конечно."
    girl "当然是结婚啊。"

# game/a13/8northroad.rpy:439
translate english northroad_3876c021:

    # me "Свадьбы?"
    me "结婚？"

# game/a13/8northroad.rpy:440
translate english northroad_294729c3:

    # girl "Но ты ведь для этого вернулся. Ты наконец-то свободен от уз долга."
    girl "可你就是为这个回来的啊。你终于摆脱了责任的束缚。"

# game/a13/8northroad.rpy:441
translate english northroad_583774ee:

    # me "Теперь я понимаю с кем ты меня перепутала."
    me "现在我明白你把我当成谁了。"

# game/a13/8northroad.rpy:442
translate english northroad_3e51cf6f:

    # girl "Перепутала. Да нет же. Ты он и есть. Может быть это ты меня не узнаешь, Лотрик."
    girl "认错人了。不，没有。你就是他。也许，是你没认出我来，Lotric。"

# game/a13/8northroad.rpy:443
translate english northroad_1dbfddab:

    # me "...это невозможно."
    me "...这不可能。"

# game/a13/8northroad.rpy:444
translate english northroad_e89212f1:

    # girl "Что именно?"
    girl "什么不可能？"

# game/a13/8northroad.rpy:445
translate english northroad_67313ae8:

    # me "Прошло столько времени..."
    me "这么久过去了..."

# game/a13/8northroad.rpy:446
translate english northroad_728adfb0:

    # girl "Много. Но я бы ждала тебя еще столько же."
    girl "是很久了。但哪怕再等这么久，我也愿意。"

# game/a13/8northroad.rpy:448
translate english northroad_a2d33c30:

    # girl "Возьми меня за руку."
    girl "握住我的手吧。"

# game/a13/8northroad.rpy:449
translate english northroad_e9b181e4:

    # me "А... ну ественно. Это не по-настоящему, да?"
    me "啊...那当然了。这不是真的，对吧？"

# game/a13/8northroad.rpy:450
translate english northroad_35c64ca0:

    # girl "О чем ты?"
    girl "你在说什么？"

# game/a13/8northroad.rpy:451
translate english northroad_148095bb:

    # me "Я на секунду подумал, что ты ждала все это время, но теперь уверен, что все еще сплю."
    me "我刚刚还在想，难道你真的等了这么久，但现在我确定，我还还在睡梦中。"

# game/a13/8northroad.rpy:452
translate english northroad_b9de7305:

    # girl "О чем, ты, Лотрик?"
    girl "你到底在说什么呀，Lotric？"

# game/a13/8northroad.rpy:453
translate english northroad_f7d2f6bb:

    # me "Замок давно заброшен. Ты бы не продержалась столько."
    me "这座城堡早就废弃了。你不可能撑这么久。"

# game/a13/8northroad.rpy:454
translate english northroad_543434aa:

    # girl "Замок в плохом состоянии, знаю. С тех пор как умер отец дела совсем плохи. Я думала брат поможет нам, но он так и не вернулся из Столицы."
    girl "城堡是年久失修了，我知道。自从父亲死后，境况就每况愈下。我原以为哥哥会帮我们，可他去了首都后就再没回来。"

# game/a13/8northroad.rpy:455
translate english northroad_cfbeb1f7:

    # me "Не вернулся? Почему?"
    me "没回来？为什么？"

# game/a13/8northroad.rpy:456
translate english northroad_7447d5ff:

    # girl "Ну ты ведь знаешь. Он все неправильно понял. Он думал, что я отказываюсь от всех предложений замужества, потому что ты меня опозорил."
    girl "你肯定知道啊。他全都误会了。他以为我拒绝所有求婚，是因为你玷污了我的名誉。"

# game/a13/8northroad.rpy:457
translate english northroad_3820771a_1:

    # me "..."
    me "..."

# game/a13/8northroad.rpy:458
translate english northroad_dfc6b342:

    # girl "Я плакала. Клялась, что это не так. Говорила что жду тебя, потому что люблю. Но он не поверил. Вы ведь поговорили? Он стал твоим оруженосцем?"
    girl "我哭过，发过誓说不是那样。我说我等你，是因为我爱你。但他不信。你们谈过了吗？他成了你的侍从吗？"

# game/a13/8northroad.rpy:459
translate english northroad_f3c4991a:

    # me "Не знаю... похоже он стал одним из вам."
    me "不知道...好像他成了你们中一员。"

# game/a13/8northroad.rpy:460
translate english northroad_35c64ca0_1:

    # girl "О чем ты?"
    girl "你在说什么呢？"

# game/a13/8northroad.rpy:461
translate english northroad_3820771a_2:

    # me "..."
    me "..."

# game/a13/8northroad.rpy:462
translate english northroad_75853f7f:

    # girl "Ты возьмешь меня за руку?"
    girl "你愿意握住我的手吗？"

# game/a13/8northroad.rpy:464
translate english northroad_7efdf658:

    # girl "Ох... я так давно этого не чувствовала. Ничего не чувствовала. Я так скучала, Лотрик."
    girl "哦...我太久没有这种感觉了。什么感觉都没了。我太想念你了，Lotric。"

# game/a13/8northroad.rpy:465
translate english northroad_6fa499d9:

    # me "Прости..."
    me "对不起..."

# game/a13/8northroad.rpy:466
translate english northroad_fb88d4b8:

    # girl "Тебе не за что извиняться. Я знаю, ты руководствовался долгом. Ты обязан был жить так, как жил. Ты не виноват, что женился прежде, чем встретил меня."
    girl "你不必道歉。我知道你是出于责任。你过那样的生活是身不由己。你不过是爱我之前先结了婚，这不是你的错。"

# game/a13/8northroad.rpy:467
translate english northroad_3820771a_3:

    # me "..."
    me "..."

# game/a13/8northroad.rpy:468
translate english northroad_dced9a4f:

    # girl "Ты ведь помнишь, как мы гуляли и собирали грибы по вечерам?"
    girl "你还记得我们傍晚散步、采蘑菇吗？"

# game/a13/8northroad.rpy:469
translate english northroad_3820771a_4:

    # me "..."
    me "..."

# game/a13/8northroad.rpy:470
translate english northroad_47210ba9:

    # girl "А как убегали из замка в деревню и веселились с простолюдинами, напиваясь и поя песни до утра?"
    girl "还有我们溜出城堡，跑去村子里和老百姓一起瞎闹，喝得醉醺醺的，唱歌到天亮？"

# game/a13/8northroad.rpy:471
translate english northroad_3820771a_5:

    # me "..."
    me "..."

# game/a13/8northroad.rpy:472
translate english northroad_2ea891f6:

    # girl "А как читали одну и ту же книгу? Я читала быстрее и ты постоянно просил дать тебе еще время. Клал свою руку на мою, не давая пролистывать?"
    girl "还有我们共读同一本书？我读得比你快，你总是求我等等你。还把你的手压在我手上，不让我翻页？"

# game/a13/8northroad.rpy:473
translate english northroad_3820771a_6:

    # me "..."
    me "..."

# game/a13/8northroad.rpy:474
translate english northroad_0141331a:

    # girl "А наш поцелуй? Я помню это, будто это было вчера. Была ночь, темная, как эта. Мы смотрели на звезды и я пела тебе песню. Про горного козленка, помнишь? Ты еще так посмотрел на меня, грустно, будто никогда не вернешься. Но вернулся."
    girl "还有我们的吻？我记得它，就像是昨天发生的一样。那是个夜晚，和今晚一样黑。我们看星星，我给你唱了首歌。是那首关于山间小羊的歌，记得吗？那时，你那么悲伤地看着我，好像再也不会回来了。但你还是回来了。"

# game/a13/8northroad.rpy:475
translate english northroad_a30f3d44:

    # me "Прости, но я не Лотрик."
    me "对不起，但我不是Lotric。"

# game/a13/8northroad.rpy:477
translate english northroad_d258c609:

    # girl "Но как же. Ты такой же, как и в тот день, когда уехал. Пару шрамов и седина. Но все остальное почти такое же."
    girl "怎么会。你和你离开那天一模一样。就是多了几道疤，添了些白发。除此之外，几乎没变。"

# game/a13/8northroad.rpy:478
translate english northroad_8b0123e0:

    # me "Я не он."
    me "我不是他。"

# game/a13/8northroad.rpy:479
translate english northroad_f107998d:

    # girl "Не шути так, Лотрик. Я почти поверила. Но я твои глаза не спутаю ни с какими другими на свете. Голубые, как море у Хельвика."
    girl "别开这种玩笑，Lotric。我差点就信了。但你的眼睛，我在这世上绝不会认错。蓝得像Helvik的海。"

# game/a13/8northroad.rpy:480
translate english northroad_4f7b6c0f:

    # me "Я не Лотрик. Я его внук."
    me "我不是Lotric。我是他的孙子。"

# game/a13/8northroad.rpy:481
translate english northroad_ecff9eaa:

    # girl "Внук? Какая глупость. Много времени прошло. Но не настолько же."
    girl "孙子？胡说什么。是过了很长一段时间，但也没到那种程度吧。"

# game/a13/8northroad.rpy:482
translate english northroad_6970d445:

    # me "Настолько. Ты... кем бы ты ни была, ты перепутала меня именно поэтому. Я его внук. Во мне кровь Красного Императора."
    me "就是到了。你...不管你是什么，你认错人就是因为这个。我是他孙子。我体内流着红帝的血。"

# game/a13/8northroad.rpy:483
translate english northroad_a2722520:

    # girl "Красного Императора? Это мы в с тобой придумали. Ты рассказал мне про комету и я придумала называть тебя красный принц. Но теперь ты конечно уже Император."
    girl "红帝？那是我们一起想出来的名号。你跟我提了那颗彗星，我就想出叫你红王子。现在，你当然已经是皇帝了。"

# game/a13/8northroad.rpy:484
translate english northroad_96c82728:

    # me "Лотрик мертв. Давно."
    me "Lotric死了。很久以前。"

# game/a13/8northroad.rpy:485
translate english northroad_4444d2ab:

    # girl "Не может такого быть. Он стоит передо мной."
    girl "不可能。他就站在我面前。"

# game/a13/8northroad.rpy:486
translate english northroad_1c4edefd:

    # me "Я не Лотрик."
    me "我不是Lotric。"

# game/a13/8northroad.rpy:487
translate english northroad_b05a5edb:

    # girl "Я знаю только один способ узнать."
    girl "我只知道一种方法来辨别。"

# game/a13/8northroad.rpy:488
translate english northroad_4e7dfaf3:

    # me "Какой?"
    me "什么方法？"

# game/a13/8northroad.rpy:490
translate english northroad_00574b6f:

    # girl "{i}Вспомнить тот самый поцелуй.{/i}"
    girl "{i}回忆起那个吻。{/i}"

# game/a13/8northroad.rpy:491
translate english northroad_4e1ea170:

    # me "{i}Я не Лотрик.{/i}"
    me "{i}我不是Lotric。{/i}"

# game/a13/8northroad.rpy:492
translate english northroad_53d88f69:

    # girl "{i}Постой... это правда.{/i}"
    girl "{i}等等...是真的。{/i}"

# game/a13/8northroad.rpy:493
translate english northroad_5c76dbe7_7:

    # me "{i}...{/i}"
    me "{i}...{/i}"

# game/a13/8northroad.rpy:494
translate english northroad_b31a5e2f:

    # girl "{i}Ты действительно не Лотрик. Неужели ты не лгал?{/i}"
    girl "{i}你真的不是Lotric。难道你没有说谎？{/i}"

# game/a13/8northroad.rpy:495
translate english northroad_0ff8f9b1:

    # me "{i}Мне жаль.{/i}"
    me "{i}我很难过。{/i}"

# game/a13/8northroad.rpy:496
translate english northroad_b416b8b2:

    # girl "{i}Этого не может быть.{/i}"
    girl "{i}这不可能。{/i}"

# game/a13/8northroad.rpy:497
translate english northroad_5abfd917:

    # me "{i}Может.{/i}"
    me "{i}可能的。{/i}"

# game/a13/8northroad.rpy:498
translate english northroad_f011deac:

    # girl "{i}Но... он обещал вернуться!{/i}"
    girl "{i}但是...他答应过会回来的！{/i}"

# game/a13/8northroad.rpy:499
translate english northroad_20c9d23f:

    # me "{i}Прости.{/i}"
    me "{i}对不起。{/i}"

# game/a13/8northroad.rpy:500
translate english northroad_b4ddd461:

    # girl "{i}Нет.. нет... нет... Ты Лотрик. Я просто что-то забыла. Момент размылся в памяти.{/i}"
    girl "{i}不..不...不...你是Lotric。我肯定忘了什么。那一刻在记忆里模糊了。{/i}"

# game/a13/8northroad.rpy:502
translate english northroad_9ab50ae8:

    # me "{i}Я принц [mename] Стархэд. Наследую Лотрику через его старшего сына.{/i}"
    me "{i}我是[mename]·Starhead王子，是Lotric的长子一脉。{/i}"

# game/a13/8northroad.rpy:503
translate english northroad_56e7b5b4:

    # girl "{i}...{/i}"
    girl "{i}...{/i}"

# game/a13/8northroad.rpy:504
translate english northroad_4e1ea170_1:

    # me "{i}Я не Лотрик.{/i}"
    me "{i}我不是Lotric。{/i}"

# game/a13/8northroad.rpy:505
translate english northroad_d096e4f8:

    # girl "{i}Да... ты не Лотрик.{/i}"
    girl "{i}是...你不是Lotric。{/i}"

# game/a13/8northroad.rpy:508
translate english northroad_b5842b1f:

    # girl "{i}Ты намного хуже.{/i}"
    girl "{i}你比他差远了。{/i}"

# game/a13/8northroad.rpy:509
translate english northroad_6718189f:

    # me "{i}{size=+2}Что... ЧТО ПРОИСХОДИТ?{/size}{/i}"
    me "{i}{size=+2}什么...发生了什么事？{/size}{/i}"

# game/a13/8northroad.rpy:510
translate english northroad_8264dec0:

    # girl "{i}Лотрик был человеком чести.{/i}"
    girl "{i}Lotric是个重荣誉的人。{/i}"

# game/a13/8northroad.rpy:511
translate english northroad_894362ea:

    # me "{i}{size=+4}ОТПУСТИ МЕНЯ.{/size}{/i}"
    me "{i}{size=+4}放开我。{/size}{/i}"

# game/a13/8northroad.rpy:512
translate english northroad_e5147fcd:

    # girl "{i}А ты... женское достоинство для тебя ничего не значит.{/i}"
    girl "{i}至于你...女性的尊严对你来说一文不值。{/i}"

# game/a13/8northroad.rpy:513
translate english northroad_4abee006:

    # me "{i}{size=+6}НЕ МОГУ ПОШЕВЕЛИТСЯ.{/size}{/i}"
    me "{i}{size=+6}我动弹不得。{/size}{/i}"

# game/a13/8northroad.rpy:514
translate english northroad_09d8f398:

    # girl "{i}Лотрик не пришел. Не вернулся. Но пришел ты. Неужели на его место сел ты? Ты отвратителен.{/i}"
    girl "{i}Lotric没来，没回来。但来了你。难道你取代了他？你让人厌恶。{/i}"

# game/a13/8northroad.rpy:515
translate english northroad_7a5f0476:

    # me "{i}{size=+8}ХОЛОДНО.{/size}{/i}"
    me "{i}{size=+8}好冷。{/size}{/i}"

# game/a13/8northroad.rpy:516
translate english northroad_58a759ac:

    # girl "{i}как можешь ты носить его фамилию, как кровь, что бежит в тебе, не выворачивает тебя наизнанку?{/i}"
    girl "{i}冠着他的姓氏，血脉在你体内流淌，怎么没让你五脏俱焚？{/i}"

# game/a13/8northroad.rpy:517
translate english northroad_604f7ca4:

    # me "{i}{size=+10}ОТПУСТИ. УМОЛЯЮ.{/size}{/i}"
    me "{i}{size=+10}放开我，求求你。{/size}{/i}"

# game/a13/8northroad.rpy:518
translate english northroad_9c324062:

    # girl "{i}Принц [mename]? У меня для тебя новое прозвище...{/i}"
    girl "{i}[mename]王子？我给你想了个新绰号...{/i}"

# game/a13/8northroad.rpy:519
translate english northroad_ebcb460b:

    # me "{i}{size=+12}ПРОШУ. ДАЙ МНЕ УЙТИ.{/size}{/i}"
    me "{i}{size=+12}求你了。让我走。{/size}{/i}"

# game/a13/8northroad.rpy:520
translate english northroad_93949137:

    # girl "{i}Проклятый принц.{/i}"
    girl "{i}被诅咒的王子。{/i}"

# game/a13/8northroad.rpy:521
translate english northroad_1b921cd3:

    # me "{i}{size=+14}ХВАТИТ!{/size}{/i}"
    me "{i}{size=+14}够了！{/size}{/i}"

# game/a13/8northroad.rpy:523
translate english northroad_3aa2c9ec:

    # me "{i}Твою мать...{/i}"
    me "{i}该死...{/i}"

# game/a13/8northroad.rpy:524
translate english northroad_35a4c92e:

    # me "{i}Какой ужас. У меня сердце колотится...{/i}"
    me "{i}太恐怖了。我的心还在狂跳...{/i}"

# game/a13/8northroad.rpy:525
translate english northroad_e368e2f6:

    # me "{i}Это был реально... а может это и было реально?{/i}"
    me "{i}这是真的...或者说，这也许是真的？{/i}"

# game/a13/8northroad.rpy:526
translate english northroad_03e64f73:

    # me "{i}Ее голос звучал у меня во всем теле. Даже в костях отдавался.{/i}"
    me "{i}她的声音响彻我的全身。甚至在我骨头里回荡。{/i}"

# game/a13/8northroad.rpy:527
translate english northroad_45369657:

    # me "{i}Нет... это точно не просто сон.{/i}"
    me "{i}不...这绝对不只是一个梦。{/i}"

# game/a13/8northroad.rpy:528
translate english northroad_c05532a7:

    # me "{i}Ева не врала, когда притворялась призраком замка Ховриных? Он реален?{/i}"
    me "{i}Eva假扮湿丘鬼魂时并没有撒谎？那鬼魂是真的？{/i}"

# game/a13/8northroad.rpy:529
translate english northroad_1f768093:

    # me "{i}По-моему я больше не усну.{/i}"
    me "{i}我觉得我再也睡不着了。{/i}"

# game/a13/8northroad.rpy:533
translate english northroad_ef065b08:

    # girl "{i}Но ты очень на него похож.{/i}"
    girl "{i}但你真的很像他。{/i}"

# game/a13/8northroad.rpy:534
translate english northroad_0f4c922e:

    # me "{i}Чем?{/i}"
    me "{i}哪方面？{/i}"

# game/a13/8northroad.rpy:535
translate english northroad_a95a2dd8:

    # girl "{i}Много чем. По крайней мере женское достоинство для тебя не пустой звук. Ты и правду его наследник.{/i}"
    girl "{i}很多方面。至少女性的尊严对你来说并非空谈。你确实是他的继承人。{/i}"

# game/a13/8northroad.rpy:536
translate english northroad_0da11e61:

    # me "{i}Где мы?{/i}"
    me "{i}我们在哪里？{/i}"

# game/a13/8northroad.rpy:537
translate english northroad_40775ad9:

    # girl "{i}То самое место. Мы расстелили одеяло и лежали здесь часов шесть не меньше. Мы ели яблоки, смеялись и разговаривали. Потом наступила ночь и ты поцеловал меня.{/i}"
    girl "{i}就在那个地方。我们一起铺上毯子，在这儿至少躺了六个小时。我们吃苹果，欢笑，聊天。然后夜幕降临，你吻了我。{/i}"

# game/a13/8northroad.rpy:538
translate english northroad_81d64eb5:

    # me "{i}Это был не я...{/i}"
    me "{i}那不是我...{/i}"

# game/a13/8northroad.rpy:539
translate english northroad_b7b46b0e:

    # girl "{i}Это был не ты. Но ты вернулся. В другом облике. Дал мне почувствовать это снова.{/i}"
    girl "{i}那不是你。但你回来了。以另一种模样。让我又感觉到了这一切。{/i}"

# game/a13/8northroad.rpy:540
translate english northroad_afddfcba:

    # me "{i}Юлия... тебя ведь так зовут?{/i}"
    me "{i}尤莉娅...你是叫这个名字吗？{/i}"

# game/a13/8northroad.rpy:541
translate english northroad_780c45cb:

    # yulie "{i}Да, принц [mename], наследник Лотрика.{/i}"
    yulie "{i}是的，[mename]王子，Lotric的继承人。{/i}"

# game/a13/8northroad.rpy:542
translate english northroad_c3bb5cd8:

    # me "{i}Мне нужно тебе кое-что сказать.{/i}"
    me "{i}我有件事得告诉你。{/i}"

# game/a13/8northroad.rpy:544
translate english northroad_5e0dfd5f:

    # me "Боюсь ты мертва."
    me "恐怕你已经死了。"

# game/a13/8northroad.rpy:545
translate english northroad_197d2659:

    # yulie "Мертва?"
    yulie "死了？"

# game/a13/8northroad.rpy:546
translate english northroad_37f20346:

    # me "Да. И похоже, что очень давно."
    me "是的。而且看起来，已经死了很久了。"

# game/a13/8northroad.rpy:547
translate english northroad_5eef660d:

    # yulie "Как ты понял?"
    yulie "你怎么知道的？"

# game/a13/8northroad.rpy:548
translate english northroad_5108b416:

    # me "Не знаю. Я думаю, что все еще сплю. Но если нет - ты бы никогда не прожила столько лет."
    me "不知道。我想，我还在梦里吧。但如果不是——你绝不可能活那么多年。"

# game/a13/8northroad.rpy:549
translate english northroad_ac43b39d:

    # yulie "Любовь способна на многое."
    yulie "爱情能做很多事。"

# game/a13/8northroad.rpy:550
translate english northroad_98ef9955:

    # me "Но не на это."
    me "但不包括这个。"

# game/a13/8northroad.rpy:551
translate english northroad_94f399bb:

    # yulie "Она единственная бессмертна. Даже безымянные боги над ней не властны. Любовь самых первых людей течет в наших венах и бьется в наших сердцах."
    yulie "唯独爱是永恒不灭的。即便是无名之神也无法支配它。那来自远古人类祖先的爱，在我们的血管里流淌，在我们心中跳动。"

# game/a13/8northroad.rpy:552
translate english northroad_9a8339fe:

    # me "Твое сердце давно не бьется."
    me "你的心，早就停止跳动了。"

# game/a13/8northroad.rpy:553
translate english northroad_eaf20bd5:

    # yulie "Ну и пусть. Зато бьется твое. Тот кого я любила, жив в тебе."
    yulie "那又如何。但你的心还在跳。我爱过的人，在你身上活着。"

# game/a13/8northroad.rpy:554
translate english northroad_dc2e71a7:

    # me "Но не жива ты. И не жива ни в ком из ныне живущих."
    me "可你并不活着。你在任何活着的人身上都不存在。"

# game/a13/8northroad.rpy:555
translate english northroad_9ea11811:

    # yulie "Может быть. А может быть и жива. Может часть моей любви это часть Лотрика, а значит и часть тебя."
    yulie "也许吧。但也可能我还活着。也许我的一部分爱，就是Lotric的一部分，因此也是你的一部分。"

# game/a13/8northroad.rpy:556
translate english northroad_d19f4260:

    # me "Ты никогда с ним не была. Ты умерла и не продолжила род ни с ним, ни с кем-либо еще."
    me "你从未和他结合。你死了，没有和他、也没有和其他任何人留下子嗣。"

# game/a13/8northroad.rpy:557
translate english northroad_abfcc04a:

    # yulie "Любовь не только порождает жизнь, но и дает повод для нее продолжаться. Я полюбила Лотрика и хоть и ненадолго, но сделала его и себя счастливыми."
    yulie "爱情不只孕育生命，也赋予人活下去的理由。我爱过Lotric，虽只短短一瞬，但至少让他和我都感到了幸福。"

# game/a13/8northroad.rpy:558
translate english northroad_3820771a_7:

    # me "..."
    me "..."

# game/a13/8northroad.rpy:559
translate english northroad_9cbcf98a:

    # yulie "Прощай, принц [mename], наследник Лотрика. Ждать мне больше некого. Я присоединяюсь к безымянному богу."
    yulie "再见了，[mename]王子，Lotric的继承人。我已无人可等。我这就去跟从无名之神了。"

# game/a13/8northroad.rpy:560
translate english northroad_a925faa9:

    # me "Прощай."
    me "再见了。"

# game/a13/8northroad.rpy:562
translate english northroad_3040977c:

    # me "{i}Ох... это действительно был сон.{/i}"
    me "{i}唉...这真的只是个梦啊。{/i}"

# game/a13/8northroad.rpy:563
translate english northroad_9b2b8542:

    # me "{i}А может и нет.{/i}"
    me "{i}也许不是。{/i}"

# game/a13/8northroad.rpy:564
translate english northroad_0488c87e:

    # me "{i}Этот поцелуй... и ее голос. Я будто слышу ее и сейчас.{/i}"
    me "{i}那个吻...还有她的声音。我仿佛到现在还能听到。{/i}"

# game/a13/8northroad.rpy:565
translate english northroad_2d2e77a5:

    # me "{i}Похоже призрак из Мокрого Холма это не выдумка.{/i}"
    me "{i}看来，湿丘的幽灵并不只是传说。{/i}"

# game/a13/8northroad.rpy:566
translate english northroad_5c76dbe7_8:

    # me "{i}...{/i}"
    me "{i}...{/i}"

# game/a13/8northroad.rpy:567
translate english northroad_67a1b917:

    # me "{i}Это точно был не просто сон.{/i}"
    me "{i}这绝对不是个普通的梦。{/i}"

# game/a13/8northroad.rpy:568
translate english northroad_22c07660:

    # me "{i}Я должен проверить.{/i}"
    me "{i}我必须去核实一下。{/i}"

# game/a13/8northroad.rpy:571
translate english northroad_2ba6709f:

    # harold "Мой принц? Я услышал шум."
    harold "我的王子？我听到有动静。"

# game/a13/8northroad.rpy:572
translate english northroad_f61e94c9:

    # me "Все нормально. Мне просто приснился сон."
    me "没事。我只是做了个梦。"

# game/a13/8northroad.rpy:573
translate english northroad_7e9764e9:

    # harold "Кошмар?"
    harold "噩梦吗？"

# game/a13/8northroad.rpy:575
translate english northroad_5a7a7577:

    # me "Нет."
    me "不是。"

# game/a13/8northroad.rpy:577
translate english northroad_fc30fd2b:

    # me "Да."
    me "是。"

# game/a13/8northroad.rpy:578
translate english northroad_d82da62e:

    # me "Видели развалины рядом?"
    me "你们看到旁边那些废墟了吗？"

# game/a13/8northroad.rpy:579
translate english northroad_b09b2bc9:

    # harold "Только хотел предложить переждать там дождь."
    harold "我正想建议去那儿避雨呢。"

# game/a13/8northroad.rpy:580
translate english northroad_5a7a7577_1:

    # me "Нет."
    me "不行。"

# game/a13/8northroad.rpy:581
translate english northroad_dee9c5d3:

    # harold "Нет? Почему?"
    harold "不行？为什么？"

# game/a13/8northroad.rpy:582
translate english northroad_77b69d4d:

    # me "Сначала дождемся утра."
    me "先等天亮再说。"

# game/a13/8northroad.rpy:583
translate english northroad_cfcc9cfd:

    # harold "Уверены?"
    harold "您确定吗？"

# game/a13/8northroad.rpy:584
translate english northroad_ed706450:

    # me "Да. Поверь мне. Лучше вымокнуть. Дождемся утра и проверим."
    me "确定。相信我。宁可淋湿。等天亮了，我们再去查看。"

# game/a13/8northroad.rpy:585
translate english northroad_c95781ac:

    # harold "Могу я спросить? Это как-то связано со сном?"
    harold "我能问问吗？这和您的梦有关吗？"

# game/a13/8northroad.rpy:586
translate english northroad_dd69c3a1:

    # me "Можно и так сказать."
    me "可以这么说吧。"

# game/a13/8northroad.rpy:588
translate english northroad_9f2a99fe:

    # "Утром."
    "早上。"

# game/a13/8northroad.rpy:589
translate english northroad_c8ac2cad:

    # me "Аккуратнее. Ничего не трогайте."
    me "小心点。什么也别碰。"

# game/a13/8northroad.rpy:590
translate english northroad_950fbd04:

    # harold "Будьте наготове."
    harold "你们都要准备好了。"

# game/a13/8northroad.rpy:591
translate english northroad_50f8f46e:

    # me "Не думаю, что это понадобится."
    me "我觉得没必要。"

# game/a13/8northroad.rpy:592
translate english northroad_0820c233:

    # guard "Вроде никого нет. Поднимемся наверх?"
    guard "看来这儿没人。上楼看看吗？"

# game/a13/8northroad.rpy:593
translate english northroad_e210d121:

    # me "Нет. Нам нужен этот зал."
    me "不。我们需要检查这个大厅。"

# game/a13/8northroad.rpy:594
translate english northroad_728bb702:

    # harold "Мы ищем что-то конкретное?"
    harold "我们在找具体什么东西吗？"

# game/a13/8northroad.rpy:595
translate english northroad_963f0a57:

    # me "Кого-то. Ищите тело. Или человека. Но скорее всего тело."
    me "在找一个人。找一具遗体。或者活人。但更可能是遗体。"

# game/a13/8northroad.rpy:596
translate english northroad_abd5892d:

    # harold "Кого именно мы ищем?"
    harold "到底在找谁？"

# game/a13/8northroad.rpy:597
translate english northroad_544b3893:

    # me "Трудно объяснить."
    me "这很难解释。"

# game/a13/8northroad.rpy:598
translate english northroad_64d7036a:

    # guard "Вижу! Сюда."
    guard "看见了！这里。"

# game/a13/8northroad.rpy:600
translate english northroad_5e7d39e8:

    # me "А вот и она."
    me "啊，是她了。"

# game/a13/8northroad.rpy:601
translate english northroad_e46776d7:

    # harold "Она? Вы были знакомы?"
    harold "她？您认识她？"

# game/a13/8northroad.rpy:602
translate english northroad_7b670fef:

    # me "В каком-то роде."
    me "某种意义上吧。"

# game/a13/8northroad.rpy:603
translate english northroad_0e83b481:

    # harold "Я думал вы первый раз не Севере."
    harold "我以为您是第一次来北方。"

# game/a13/8northroad.rpy:604
translate english northroad_3af3cc24:

    # me "Наше знакомство... это правда сложно объяснить."
    me "我们的相识...这真的很难解释。"

# game/a13/8northroad.rpy:605
translate english northroad_a8e56791:

    # harold "Не буду мучить вас расспросами, мой принц."
    harold "我不会追问了，我的王子。"

# game/a13/8northroad.rpy:606
translate english northroad_ce45f9d6:

    # me "Вот и хорошо."
    me "嗯，很好。"

# game/a13/8northroad.rpy:607
translate english northroad_4ef26ce6:

    # harold "Странно. Почему она не в склепе? Кто-то положил тело в главный зал и забыл его тут?"
    harold "真奇怪。她为什么不在墓窖里？谁把遗体放在主大厅里，然后就把她给忘了？"

# game/a13/8northroad.rpy:608
translate english northroad_8613242c:

    # me "Угу."
    me "嗯。"

# game/a13/8northroad.rpy:609
translate english northroad_9fefa1b8:

    # harold "Неужели слуги ее не похоронили?"
    harold "难道仆人们都没埋葬她吗？"

# game/a13/8northroad.rpy:610
translate english northroad_265de910:

    # me "Может к моменту ее смерти никаких слуг и не было."
    me "也许她死的时候，已经没有仆人了。"

# game/a13/8northroad.rpy:611
translate english northroad_d4e75e0c:

    # harold "Да ну. Она последний обитатель замка?"
    harold "怎么会。她是这个城堡的最后一个人？"

# game/a13/8northroad.rpy:612
translate english northroad_d17731ef:

    # me "Может и так. А может она и попросила себя так оставить."
    me "有可能。又或许，是她自己要求这样留下的。"

# game/a13/8northroad.rpy:613
translate english northroad_8ae45f32:

    # harold "О ком мы говорим?"
    harold "我们说的是谁？"

# game/a13/8northroad.rpy:615
translate english northroad_19f56933:

    # me "Юлия Ховрина."
    me "尤莉娅·霍夫林娜。"

# game/a13/8northroad.rpy:616
translate english northroad_874dea08:

    # harold "Да ну... она ведь умерла целую вечность назад."
    harold "怎么会...她已经死了不知多少年了。"

# game/a13/8northroad.rpy:617
translate english northroad_fc30fd2b_1:

    # me "Да."
    me "是的。"

# game/a13/8northroad.rpy:618
translate english northroad_5314bab1:

    # harold "Как вы могли быть с ней знакомы?"
    harold "您怎么可能认识她？"

# game/a13/8northroad.rpy:619
translate english northroad_8d295e66:

    # me "Не спрашивай."
    me "别问了。"

# game/a13/8northroad.rpy:620
translate english northroad_153bdaea:

    # harold "Странно, за все это время тело не тронули животные и люди, хотя дверь сломана."
    harold "真奇怪，门都坏了，但这么久以来，遗体居然没被动物的也没被人碰过。"

# game/a13/8northroad.rpy:621
translate english northroad_549dee0c:

    # me "А вот этому я как раз не удивлен."
    me "对这个我倒是不惊讶。"

# game/a13/8northroad.rpy:622
translate english northroad_af15e885:

    # harold "Даже не буду спрашивать."
    harold "我甚至都不想问了。"

# game/a13/8northroad.rpy:623
translate english northroad_5f55cd7a:

    # me "И не надо. Заберите тело. Сожжём его в саду."
    me "也别问。把遗体带走。我们到花园里火化她。"

# game/a13/8northroad.rpy:624
translate english northroad_81beb214:

    # harold "Зачем?"
    harold "为什么？"

# game/a13/8northroad.rpy:625
translate english northroad_bc74a08e:

    # me "Ты сказал спрашивать не будешь."
    me "你说过你不问了。"

# game/a13/8northroad.rpy:626
translate english northroad_8279a93f:

    # harold "..."
    harold "..."

# game/a13/8northroad.rpy:627
translate english northroad_0b5390ad:

    # me "Такая здесь традиция."
    me "这是这里的传统。"

# game/a13/8northroad.rpy:628
translate english northroad_102b5351:

    # harold "Здесь и закапывают тоже."
    harold "这儿的人也都是土葬的。"

# game/a13/8northroad.rpy:629
translate english northroad_b2a8fd72:

    # me "Ее надо сжечь."
    me "她必须火化。"

# game/a13/8northroad.rpy:630
translate english northroad_2c1332ab:

    # harold "Конечно, мой принц. Рональд, Спайк, помогите."
    harold "当然，我的王子。Ronald，斯派克，搭把手。"

# game/a13/8northroad.rpy:631
translate english northroad_fe1f5074:

    # me "Только аккуратнее. Это не мешок с мусором. Эту девушку когда-то любил Красный Император."
    me "但是要小心。这不是一袋垃圾。这位姑娘，曾是红帝爱过的人。"

# game/a13/8northroad.rpy:633
translate english northroad_396c128f:

    # "Час спустя."
    "一个小时以后。"

# game/a13/8northroad.rpy:634
translate english northroad_b0fb816b:

    # harold "Трудно было найти сухую древесину после дождя."
    harold "雨后很难找到干柴。"

# game/a13/8northroad.rpy:635
translate english northroad_24a74c1b:

    # me "Рад, что вы справились."
    me "很高兴你们办到了。"

# game/a13/8northroad.rpy:636
translate english northroad_113468bb:

    # harold "Взяли немного из замка. Пришлось разбить пару старинных стульев и столов."
    harold "从城堡里拿了点。不得不劈了几把古董椅子和桌子。"

# game/a13/8northroad.rpy:637
translate english northroad_78102d7b:

    # me "Их тоже не тронули?"
    me "那些也没人碰过？"

# game/a13/8northroad.rpy:638
translate english northroad_7a822112:

    # harold "Нет. Похоже местные верят в призрака."
    harold "没有。看来当地人都相信有幽灵。"

# game/a13/8northroad.rpy:639
translate english northroad_27bcfec9:

    # me "А ты нет?"
    me "那您不信？"

# game/a13/8northroad.rpy:640
translate english northroad_e027d76c:

    # harold "Теперь тоже верю. Раз уже вы верите."
    harold "现在也信了。既然您信了。"

# game/a13/8northroad.rpy:641
translate english northroad_a72edbf1:

    # me "А с чего ты взял, что я верю?"
    me "你又怎么知道我信了？"

# game/a13/8northroad.rpy:642
translate english northroad_e93583af:

    # harold "Вам что-то приснилось, а потом вы велели найти тело в заброшенном замке, и оно там действительно было. Ну и теперь вот погребальный костер... явно неспроста."
    harold "您做了个梦，然后就让我们在废弃的城堡里找一具尸体，结果还真找到了。现在又举行火葬...显然不是无缘无故的。"

# game/a13/8northroad.rpy:643
translate english northroad_fdd96432:

    # me "...ты умнее, чем кажешься."
    me "...你比看起来要聪明。"

# game/a13/8northroad.rpy:644
translate english northroad_ebbd9c2a:

    # harold "Поэтому и командую остальными."
    harold "所以我才指挥其他人。"

# game/a13/8northroad.rpy:645
translate english northroad_3820771a_8:

    # me "..."
    me "..."

# game/a13/8northroad.rpy:646
translate english northroad_86a28344:

    # harold "Думаете это поможет?"
    harold "您觉得这样有用吗？"

# game/a13/8northroad.rpy:647
translate english northroad_8158fa35:

    # me "Что именно? Сожжение?"
    me "什么有用？火化？"

# game/a13/8northroad.rpy:648
translate english northroad_9a6b7afc:

    # harold "Ну да. После этого ее душа расствориться в безымянных богах?"
    harold "嗯。之后她的灵魂会融入无名之神吗？"

# game/a13/8northroad.rpy:651
translate english northroad_d51a331e:

    # me "Наверняка. Я думаю она обрела свой первый покой. Осталось только забыть ее имя."
    me "肯定会的。我想她已经得到了最初的安宁。就剩下忘记她的名字了。"

# game/a13/8northroad.rpy:652
translate english northroad_76df36d5:

    # harold "Что же ее раньше никто не сжег?"
    harold "为什么以前没人火化她呢？"

# game/a13/8northroad.rpy:653
translate english northroad_b295ad0a:

    # me "Может это судьба? Это должен был сделать я?"
    me "也许这就是命运？这必须由我来做？"

# game/a13/8northroad.rpy:654
translate english northroad_af19b1e3:

    # harold "В каком смысле?"
    harold "什么意思？"

# game/a13/8northroad.rpy:655
translate english northroad_535c5128:

    # me "Я наследник Красного Императора. А они когда-то любили друг друга."
    me "我是红帝的继承人。而他们曾经相爱。"

# game/a13/8northroad.rpy:656
translate english northroad_6400712d:

    # harold "Может так оно и есть."
    harold "也许真是这样吧。"

# game/a13/8northroad.rpy:657
translate english northroad_21dacee5:

    # me "Я почти уверен, что так и есть. Нет. Я абсолютно уверен, что так и должно было случится."
    me "我几乎确定就是如此。不，我百分之百确定，事情就该是这样。"

# game/a13/8northroad.rpy:658
translate english northroad_e93d25d3:

    # harold "У этой уверенности есть причины, мой принц."
    harold "我的王子，您的这份确信是有原因的。"

# game/a13/8northroad.rpy:659
translate english northroad_f75e0134:

    # me "Да. Есть."
    me "对。有原因。"

# game/a13/8northroad.rpy:660
translate english northroad_68cb1f07:

    # harold "Спрашивать?"
    harold "要问吗？"

# game/a13/8northroad.rpy:661
translate english northroad_d448162f:

    # me "Не стоит."
    me "别问了。"

# game/a13/8northroad.rpy:664
translate english northroad_7c48b339:

    # me "Не знаю. Но кто-то должен был это сделать."
    me "不知道。但总得有人来做这件事。"

# game/a13/8northroad.rpy:665
translate english northroad_3413d4d9:

    # harold "Почему мы? Не думайте, что я оспариваю ваши приказы, мой принц, просто интересно, что вы такого увидели во сне, что решились на это."
    harold "为什么是我们？我可不是质疑您的命令，我的王子，只是好奇，您在梦里到底看到了什么，才会决定这么做。"

# game/a13/8northroad.rpy:666
translate english northroad_237e6ffe:

    # me "Ничего хорошего..."
    me "不是什么好事..."

# game/a13/8northroad.rpy:667
translate english northroad_8279a93f_1:

    # harold "..."
    harold "..."

# game/a13/8northroad.rpy:668
translate english northroad_3820771a_9:

    # me "..."
    me "..."

# game/a13/8northroad.rpy:669
translate english northroad_f3627371:

    # harold "Вы говорили ее любил Красный Император."
    harold "您说过红帝爱过她。"

# game/a13/8northroad.rpy:670
translate english northroad_5664ae92:

    # me "Она его тоже любила."
    me "她也爱他。"

# game/a13/8northroad.rpy:671
translate english northroad_38a53cdc:

    # harold "Думаете ваш дед..."
    harold "您觉得您的祖父..."

# game/a13/8northroad.rpy:672
translate english northroad_92c2f9ca:

    # me "Нет. Вряд ли. Тут все гораздо хуже. Несчастная любовь и семейная драма. Теперь я думаю, обесчесть он ее или возьми с собой, как любовницу..."
    me "不。不太可能。事情远比这糟糕得多。不幸的爱情和家庭悲剧。现在我想，要是他当初玷污了她，或是把她带在身边做情妇..."

# game/a13/8northroad.rpy:673
translate english northroad_966aefd0:

    # me "Может для нее все кончилось бы лучше."
    me "也许她的结局会好得多。"

# game/a13/8northroad.rpy:675
translate english northroad_c1581d9f:

    # me "С этой историей мы закончили."
    me "这段往事，就到此为止了。"

# game/a13/8northroad.rpy:676
translate english northroad_d8cb8bcc:

    # me "Так что по коням, господа."
    me "那么，上马吧，先生们。"

# game/a13/8northroad.rpy:677
translate english northroad_40378a98:

    # me "Нас ждет долгий путь."
    me "我们还有很长的路要走。"

# game/a13/8northroad.rpy:678
translate english northroad_d6ab5eef:

    # me "Путь из замка в замок."
    me "从一个城堡到另一个城堡的路。"

# game/a13/8northroad.rpy:679
translate english northroad_f3564c44:

    # me "Путь на настоящий Север."
    me "通向真正北方的路。"

# TODO: Translation updated at 2026-03-31 04:47

# game/a13/8northroad.rpy:375
translate english northroad_a3011f82:

    # yulie "Проверишь это сам когда вернешься ко мне. Ты ведь вернешься? Хотя бы просто проведать?"
    yulie "等你回到我身边时，亲自验证吧。你会回来的，对吧？就算只是来看看？"

translate english strings:

    old "Вы отправились на Север."
    new "你已动身前往北方。"

    old "Вы провели некоторое время в окружении семьи короля Севера. Он предложил вам необычную сделку."
    new "你在北方国王的家人身边度过了一段时光。他向你提出了一桩不同寻常的交易。"

    old "На пути к Рубиновому Ущелью вам приснился странный сон."
    new "在前往红宝石峡谷的途中，你做了一个奇怪的梦。"

    old "На пути к Рубиновому Ущелью вам приснился кошмар."
    new "在前往红宝石峡谷的途中，你做了一个噩梦。"


