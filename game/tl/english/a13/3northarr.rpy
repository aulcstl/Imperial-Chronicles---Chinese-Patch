# game/a13/3northarr.rpy:3
translate english northarr_d26ff157:

    # me "Прибыли?"
    me "到了？"

# game/a13/3northarr.rpy:4
translate english northarr_9b34be3e:

    # captain "Да, мой принц. Хельвик. Первый и единственный порт Севера на восточном побережье."
    captain "是的，我的王子。Helvik。北方东海岸第一个也是唯一的港口。"

# game/a13/3northarr.rpy:5
translate english northarr_7c12b0a5:

    # me "Через сколько будем в замке Дубовицких?"
    me "我们多久能到Dubovitsky家族的城堡？"

# game/a13/3northarr.rpy:6
translate english northarr_4af8475e:

    # captain "Сначала нужно пришвартоваться, разгрузить трюмы, нанять тягловых лошадей."
    captain "首先得靠岸，卸下货舱，雇佣拉车的马匹。"

# game/a13/3northarr.rpy:7
translate english northarr_3820771a:

    # me "..."
    me "..."

# game/a13/3northarr.rpy:8
translate english northarr_12216c06:

    # captain "Можете ехать в авангарде, мой принц. Вам решать."
    captain "您可以先走一步，我的王子。由您决定。"

# game/a13/3northarr.rpy:9
translate english northarr_cf9c9143:

    # me "Отличная идея."
    me "好主意。"

# game/a13/3northarr.rpy:11
translate english northarr_7dac0600:

    # "Пару часов спустя."
    "几个小时以后。"

# game/a13/3northarr.rpy:12
translate english northarr_1a3fb5d3:

    # me "Вы взяли что-нибудь?"
    me "您带了什么吗？"

# game/a13/3northarr.rpy:13
translate english northarr_e95ae8ea:

    # guard "Немного фруктов, все что успели достать, мой принц. "
    guard "一些水果，都是我们来得及弄到的，我的王子。"

# game/a13/3northarr.rpy:14
translate english northarr_71d3b8c8:

    # me "Хорошо."
    me "很好。"

# game/a13/3northarr.rpy:15
translate english northarr_f5358cf5:

    # guard "Можем подождать основной конвой, если..."
    guard "我们可以等主力车队，如果..."

# game/a13/3northarr.rpy:16
translate english northarr_cd8b2091:

    # me "Нет. Все нормально. Главное не с пустыми руками. На Севере это считается неуважение к хозяину."
    me "不。没关系。关键是不能空手而来。在北方，这会被视为对主人的不敬。"

# game/a13/3northarr.rpy:17
translate english northarr_b6e7d347:

    # guard "Ну... если пару ящиков винограда и яблок достаточно..."
    guard "嗯...如果几箱葡萄和苹果就足够的话..."

# game/a13/3northarr.rpy:18
translate english northarr_c00c556b:

    # me "Достаточно."
    me "够了。"

# game/a13/3northarr.rpy:19
translate english northarr_3bb3a09f:

    # guard "В таком случае если поторопимся то даже ничего не сгниет по дороге."
    guard "这样的话，如果我们快点，路上甚至不会有什么东西烂掉。"

# game/a13/3northarr.rpy:20
translate english northarr_aee9b288:

    # me "Сколько нам ехать?"
    me "我们要走多久？"

# game/a13/3northarr.rpy:21
translate english northarr_9fb0c76b:

    # guard "День. Не больше."
    guard "一天。不会更久。"

# game/a13/3northarr.rpy:23
translate english northarr_2a6bb006:

    # me "День?"
    me "一天？"

# game/a13/3northarr.rpy:24
translate english northarr_bd2ddebf:

    # guard "К ночи управимся."
    guard "入夜前就能赶到。"

# game/a13/3northarr.rpy:25
translate english northarr_08184009:

    # me "Тогда разобьем привал."
    me "那我们中途歇一下。"

# game/a13/3northarr.rpy:26
translate english northarr_0ab768b7:

    # guard "Мой принц?"
    guard "我的王子？"

# game/a13/3northarr.rpy:27
translate english northarr_e7251463:

    # me "Ночью являются только враги."
    me "夜里来的只有敌人。"

# game/a13/3northarr.rpy:28
translate english northarr_45fcc158:

    # guard "Тоже северная примета?"
    guard "也是北方的说法吗？"

# game/a13/3northarr.rpy:29
translate english northarr_47033197:

    # me "Нет. Это актуально везде."
    me "不。这在哪儿都适用。"

# game/a13/3northarr.rpy:30
translate english northarr_eaefa1c4:

    # guard "Как скажете, принц."
    guard "听您的，王子。"

# game/a13/3northarr.rpy:31
translate english northarr_28109679:

    # me "Здесь... прохладно."
    me "这里...有点冷。"

# game/a13/3northarr.rpy:32
translate english northarr_377c699b:

    # guard "Осень. На Севере она холоднее."
    guard "秋天了。在北方，秋天更冷。"

# game/a13/3northarr.rpy:34
translate english northarr_b77e7e84:

    # me "Да. Я понял по желтым листьям и траве. Думаешь успеем обратно до первых морозов?"
    me "是啊。我从黄叶和枯草看出来了。你觉得我们能在初霜前赶回去吗？"

# game/a13/3northarr.rpy:35
translate english northarr_5d861108:

    # guard "Не знаю, мой принц, смотря на сколько вы планируете задержаться."
    guard "不知道，我的王子，这取决于您打算停留多久。"

# game/a13/3northarr.rpy:36
translate english northarr_778b3ed3:

    # me "Этого я пока не знаю."
    me "这个我现在还不清楚。"

# game/a13/3northarr.rpy:37
translate english northarr_68418b5b:

    # guard "Ну... в таком случае может и застанете."
    guard "嗯...这样的话，您可能会赶上。"

# game/a13/3northarr.rpy:38
translate english northarr_ffc51265:

    # me "Понятно."
    me "明白了。"

# game/a13/3northarr.rpy:39
translate english northarr_f8d33252:

    # guard "Знаете как говорят на Севере? Первый снег всегда настигает в неожиданный момент. Можно днями думать о том, как он скоро пойдет, но он правда пойдет только когда эта мысль ускользнет их головы."
    guard "您知道北方人怎么说吗？第一场雪总是在意想不到的时候来临。你可以整天想着它很快就要下了，但它真的只会在你忘了这念头时才落下。"

# game/a13/3northarr.rpy:40
translate english northarr_aaa43ef3:

    # me "Ты как-то много знаешь о Севере."
    me "你对北方知道得挺多啊。"

# game/a13/3northarr.rpy:41
translate english northarr_a5a32e99:

    # guard "Мой отец отсюда. Кстати как вам вон то место на холме?"
    guard "我父亲是这里人。对了，您觉得那边山丘上的地方怎么样？"

# game/a13/3northarr.rpy:42
translate english northarr_d6ad11ac:

    # me "Да. Подойдет. Командую остановиться."
    me "好。那里可以。传令停下。"

# game/a13/3northarr.rpy:43
translate english northarr_abb29409:

    # guard "Да, мой принц."
    guard "是，我的王子。"

# game/a13/3northarr.rpy:45
translate english northarr_591eb588:

    # "Ночью."
    "晚上。"

# game/a13/3northarr.rpy:46
translate english northarr_c97dda4a:

    # me "{i}Забавно. Когда я жил в вольных городах, всегда думал что оказаться на настоящем Севере у меня больше шансов, чем вернуться домой.{/i}"
    me "{i}真有意思。当我住在自由城邦时，总觉得自己来到真正北方的机会比回家的机会要大。{/i}"

# game/a13/3northarr.rpy:47
translate english northarr_e43843d9:

    # me "{i}Но домой я вернулся. И на Север все равно попал.{/i}"
    me "{i}但我回家了。结果还是来到了北方。{/i}"

# game/a13/3northarr.rpy:48
translate english northarr_219e43af:

    # me "{i}Перипетии судьбы удивительны. Никогда не знаешь наверняка, где окажешься завтра, у гномьего разлома или на невольничьем рынке на Юге.{/i}"
    me "{i}命运的波折真是奇妙。你永远无法确知明天会身在何处，是在矮人的裂谷旁，还是在南方的奴隶市场。{/i}"

# game/a13/3northarr.rpy:49
translate english northarr_5c76dbe7:

    # me "{i}...{/i}"
    me "{i}...{/i}"

# game/a13/3northarr.rpy:50
translate english northarr_4a6ebe43:

    # me "{i}Главное не оказаться в могиле.{/i}"
    me "{i}关键是别进了坟墓。{/i}"

# game/a13/3northarr.rpy:51
translate english northarr_b33ead5c:

    # me "{i}Хотя оказаться там у всех у нас шансов больше всего.{/i}"
    me "{i}虽然对我们所有人来说，进坟墓的可能性最大。{/i}"

# game/a13/3northarr.rpy:52
translate english northarr_304e5938:

    # me "{i}С каждым вздохом все ближе и ближе.{/i}"
    me "{i}每一次呼吸，都离它更近一步。{/i}"

# game/a13/3northarr.rpy:53
translate english northarr_4f2ab14d:

    # me "{i}Почему я вообще об этом думаю? Наверное это безжизненный пейзаж навеял на меня меланхолию.{/i}"
    me "{i}我怎么会想到这个？大概是这片毫无生气的景色让我心生忧郁了吧。{/i}"

# game/a13/3northarr.rpy:54
translate english northarr_1fa5d311:

    # me "Почему-то это место кажется знакомым, хотя я никогда здесь не был."
    me "为什么这个地方感觉有点眼熟，尽管我从未来过这里。"

# game/a13/3northarr.rpy:57
translate english northarr_ff37bc3e:

    # aurora "Наверное читал в книгах."
    aurora "可能是在书里读到过。"

# game/a13/3northarr.rpy:58
translate english northarr_90d94a91:

    # me "О горах? Читал. Не думал что все книги описывают именно эти горы."
    me "关于这些山？读过。没想到所有的书描写的都是这些山。"

# game/a13/3northarr.rpy:59
translate english northarr_6c911f08:

    # aurora "Это не просто горы и не просто плато."
    aurora "这不只是普通的山，也不只是普通的高原。"

# game/a13/3northarr.rpy:60
translate english northarr_3820771a_1:

    # me "..."
    me "..."

# game/a13/3northarr.rpy:61
translate english northarr_c7a60c8b:

    # aurora "Ну же."
    aurora "快说吧。"

# game/a13/3northarr.rpy:62
translate english northarr_ac9cb8bc:

    # me "Понятия не имею."
    me "我完全没概念。"

# game/a13/3northarr.rpy:63
translate english northarr_4aea4a50:

    # aurora "Ну тебе это место кажется знакомым?"
    aurora "你觉得这地方眼熟吗？"

# game/a13/3northarr.rpy:64
translate english northarr_fc30fd2b:

    # me "Да."
    me "是的。"

# game/a13/3northarr.rpy:65
translate english northarr_2814aefb:

    # aurora "Но ты здесь никогда не был."
    aurora "但你从未来过这里。"

# game/a13/3northarr.rpy:66
translate english northarr_1a101c51:

    # me "Не был."
    me "没来过。"

# game/a13/3northarr.rpy:67
translate english northarr_a82e332d:

    # aurora "Тогда ты мог только прочитать об этом месте или увидеть картину."
    aurora "那你只可能是读到过这地方，或者看到过一幅画。"

# game/a13/3northarr.rpy:68
translate english northarr_5a342f90:

    # me "Картину о куске безжизненной земли и горах вокруг?"
    me "一幅关于一片荒地和周围群山的画？"

# game/a13/3northarr.rpy:69
translate english northarr_a019cfc5:

    # aurora "Думаю на картине было что-то еще."
    aurora "我觉得画上应该还有别的。"

# game/a13/3northarr.rpy:70
translate english northarr_e214e134:

    # me "Постой... это же не..."
    me "等等...这该不会是..."

# game/a13/3northarr.rpy:72
translate english northarr_0d66247b:

    # aurora "Да."
    aurora "是的。"

# game/a13/3northarr.rpy:73
translate english northarr_f7e7764a:

    # me "Стоило сразу догадаться. Ты дала даже больше подсказок, чем нужно."
    me "早该猜到的。你给的提示都绰绰有余了。"

# game/a13/3northarr.rpy:74
translate english northarr_50527702:

    # aurora "Ты просто устал."
    aurora "你只是累了。"

# game/a13/3northarr.rpy:75
translate english northarr_23d735ca:

    # me "Это то самое место, где дворфы проводили свой легендарный пир."
    me "这就是矮人们举办他们那场传奇盛宴的地方。"

# game/a13/3northarr.rpy:76
translate english northarr_700a457f:

    # aurora "[mename], ты серьезно?"
    aurora "[mename]，你说真的？"

# game/a13/3northarr.rpy:77
translate english northarr_15903e9b:

    # me "Шучу. Я уже понял, что это место битвы у Синих Гор."
    me "开玩笑的。我已经明白了，这是蓝山战役的遗址。"

# game/a13/3northarr.rpy:78
translate english northarr_18243f09:

    # aurora "Оно самое."
    aurora "正是这里。"

# game/a13/3northarr.rpy:79
translate english northarr_1f5bf5fc:

    # me "Как будто в мире много известных пустошей у гор."
    me "好像世界上有很多著名的山边荒原似的。"

# game/a13/3northarr.rpy:80
translate english northarr_ea36dcf1:

    # aurora "Не будь к себе строг. Это место ничем себя не выдает."
    aurora "别对自己太苛刻。这地方没什么明显的标志。"

# game/a13/3northarr.rpy:82
translate english northarr_f2bafd0a:

    # aurora "Говорят до битвы здесь было полно деревьев и травы."
    aurora "据说战前这里满是树木和青草。"

# game/a13/3northarr.rpy:83
translate english northarr_b3adfb7c:

    # me "Ну... это место действительно выглядит необычно безжизненным, даже для Севера."
    me "嗯...这地方确实显得异常荒芜，即使对北方来说也是如此。"

# game/a13/3northarr.rpy:84
translate english northarr_498d628e:

    # aurora "Да. Это удивительно. Будто сама природа пострадала в этой битве."
    aurora "是啊。真令人惊讶。仿佛大自然本身也在这场战役中受到了伤害。"

# game/a13/3northarr.rpy:85
translate english northarr_ed0ab2f5:

    # me "У этого есть какое-то другое объяснение?"
    me "这有什么别的解释吗？"

# game/a13/3northarr.rpy:86
translate english northarr_4197fe97:

    # aurora "Все деревья срубили для поминальных костров."
    aurora "所有的树都被砍去做葬礼的柴堆了。"

# game/a13/3northarr.rpy:87
translate english northarr_45e62e4e:

    # me "И ни одно не проросло за все это время?"
    me "这么长时间过去了，一棵都没再长出来？"

# game/a13/3northarr.rpy:88
translate english northarr_616acbfd:

    # aurora "Не знаю... может пепел отравил землю?"
    aurora "不知道...也许灰烬毒害了土地？"

# game/a13/3northarr.rpy:89
translate english northarr_a4b3f3be:

    # me "Пепел это удобрения."
    me "灰烬是肥料。"

# game/a13/3northarr.rpy:90
translate english northarr_8a266b10:

    # aurora "Не знаю. Может здесь вообще никогда и не было никаких деревьев. По крайней мере пней я не вижу."
    aurora "不知道。也许这里从来就没有过树。至少我没看到树桩。"

# game/a13/3northarr.rpy:91
translate english northarr_563d35e9:

    # me "Их выкорчевали?"
    me "被连根拔起了？"

# game/a13/3northarr.rpy:93
translate english northarr_c73b2406:

    # aurora "Для поминального костра? Вряд ли."
    aurora "为了葬礼柴堆？不太可能。"

# game/a13/3northarr.rpy:94
translate english northarr_73ad3170:

    # me "Ты никогда не спрашивала об этом отца?"
    me "你从来没问过你父亲这件事？"

# game/a13/3northarr.rpy:95
translate english northarr_e23cbd16:

    # aurora "Но он об этом вспоминать не любит."
    aurora "但他不喜欢回忆这个。"

# game/a13/3northarr.rpy:96
translate english northarr_e4f1d0c6:

    # me "Почему? Он же победил."
    me "为什么？他赢了啊。"

# game/a13/3northarr.rpy:97
translate english northarr_607ed6d9:

    # aurora "Оба его сына умерли в той битве."
    aurora "他的两个儿子都死在那场战役里了。"

# game/a13/3northarr.rpy:98
translate english northarr_87990306:

    # me "Оу... прости."
    me "哦...抱歉。"

# game/a13/3northarr.rpy:99
translate english northarr_722853ad:

    # aurora "Не извиняйся. Я никогда их не знала, они умерли до моего рождения."
    aurora "不用道歉。我从没见过他们，他们在我出生前就去世了。"

# game/a13/3northarr.rpy:100
translate english northarr_7b558e93:

    # me "Ну да, точно... А может это место посыпали солью? Я что-то читал о таком."
    me "嗯，也对...也许这地方被撒了盐？我好像读到过这种事。"

# game/a13/3northarr.rpy:101
translate english northarr_bc1b30fe:

    # aurora "Так делают только южане. Мы бы не стали уничтожать землю просто так, еще и на родине."
    aurora "只有南方人才那么做。我们不会无缘无故毁掉土地，更何况是在自己的家乡。"

# game/a13/3northarr.rpy:102
translate english northarr_2da4094f:

    # me "...тогда это действительно загадка."
    me "...那这真是个谜了。"

# game/a13/3northarr.rpy:103
translate english northarr_68b343b2:

    # aurora "Почва здесь довольно каменистая. Мы взобрались на холм, так что это скорее всего молодая гора."
    aurora "这里的土壤挺多石头的。我们爬上了山丘，所以这很可能是座年轻的山。"

# game/a13/3northarr.rpy:104
translate english northarr_c625b3c0:

    # me "Видимо твой отец приказал отбиваться на возвышении."
    me "看来你父亲当时命令在高处防守。"

# game/a13/3northarr.rpy:105
translate english northarr_9ff0e71e:

    # aurora "Скорее всего."
    aurora "很可能。"

# game/a13/3northarr.rpy:106
translate english northarr_05fcf5a0:

    # me "Так деревьев здесь никогда и не было."
    me "所以这里从来就没有过树。"

# game/a13/3northarr.rpy:107
translate english northarr_fd55407d:

    # aurora "Похоже на то. Видимо крестьянские байки."
    aurora "看来是这样。大概是农民们的无稽之谈。"

# game/a13/3northarr.rpy:108
translate english northarr_3820771a_2:

    # me "..."
    me "..."

# game/a13/3northarr.rpy:109
translate english northarr_2b71bc54:

    # aurora "..."
    aurora "..."

# game/a13/3northarr.rpy:110
translate english northarr_c5278095:

    # me "У нас собой пару шкур. Поспим здесь вместе прямо под звездным небом?"
    me "我们带了几张毛皮。一起在这儿睡吧，就在星空下？"

# game/a13/3northarr.rpy:111
translate english northarr_66ea3013:

    # aurora "С удовольствием."
    aurora "非常乐意。"

# game/a13/3northarr.rpy:115
translate english northarr_f13efdfe:

    # cass "Ты не рассказывал, что бывал так далеко."
    cass "你没说过你来过这么远的地方。"

# game/a13/3northarr.rpy:116
translate english northarr_62eb1399:

    # me "Я же говорю - я здесь не был."
    me "我说了——我没来过这里。"

# game/a13/3northarr.rpy:117
translate english northarr_bad79398:

    # cass "Видимо был слишком пьян, чтобы запомнить."
    cass "看来你当时醉得太厉害，不记得了。"

# game/a13/3northarr.rpy:118
translate english northarr_baeae7c4:

    # me "Да не был я здесь."
    me "我真没来过这里。"

# game/a13/3northarr.rpy:119
translate english northarr_e31d865d:

    # cass "С чего вдруг тогда это место кажется тебе знакомым?"
    cass "那为什么你会觉得这地方眼熟呢？"

# game/a13/3northarr.rpy:120
translate english northarr_ac9cb8bc_1:

    # me "Понятия не имею."
    me "我完全没概念。"

# game/a13/3northarr.rpy:121
translate english northarr_651ccc28:

    # cass "..."
    cass "..."

# game/a13/3northarr.rpy:122
translate english northarr_d49ed0ad:

    # me "Что? У тебя никогда не было чувства, что тебе что-то знакомо, хотя ты видишь это в первый раз?"
    me "怎么？你就从来没有过这种感觉吗？明明是第一次见到某样东西，却觉得它很熟悉？"

# game/a13/3northarr.rpy:123
translate english northarr_aa83f103:

    # cass "Было. Это называется я увидела похожее место или предмет и это похоже на то, что я видела раньше."
    cass "有过。那是因为我看到了一个相似的地方或物品，它和我以前见过的东西很像。"

# game/a13/3northarr.rpy:124
translate english northarr_5a7a7577:

    # me "Нет."
    me "不是这样。"

# game/a13/3northarr.rpy:125
translate english northarr_2ba7690d:

    # cass "Нет?"
    cass "不是？"

# game/a13/3northarr.rpy:126
translate english northarr_7782137a:

    # me "Ты не поняла."
    me "你没理解。"

# game/a13/3northarr.rpy:128
translate english northarr_7674ce95:

    # cass "Ну объясни мне, философ."
    cass "那给我解释解释，哲学家。"

# game/a13/3northarr.rpy:129
translate english northarr_8e2cf8c5:

    # me "Это не объяснить, только прочувствовать."
    me "这没法解释，只能去感受。"

# game/a13/3northarr.rpy:130
translate english northarr_ccbeb2af:

    # cass "Угум. Понятно."
    cass "嗯哼。明白了。"

# game/a13/3northarr.rpy:131
translate english northarr_d405e53f:

    # me "Я... правда не знаю как выразить это словами. У тебя бывало такое, что тебе казалось будто ты уже проживала этот момент?"
    me "我...真的不知道该怎么用言语表达。你有没有过这种感觉，好像自己已经经历过这个时刻？"

# game/a13/3northarr.rpy:132
translate english northarr_ad050d3b:

    # cass "Опять. Просто похожее событие."
    cass "又来了。只是相似的事件罢了。"

# game/a13/3northarr.rpy:133
translate english northarr_0e3a1b6d:

    # me "Нет. Момент уникален. Его точно никогда не было раньше. Но он почему-то кажется тебе знакомым."
    me "不。那个时刻是独一无二的。它以前绝对没发生过。但你却莫名其妙地觉得它很熟悉。"

# game/a13/3northarr.rpy:134
translate english northarr_651ccc28_1:

    # cass "..."
    cass "..."

# game/a13/3northarr.rpy:135
translate english northarr_d9caceac:

    # me "Ну вот мы были здесь когда-нибудь раньше?"
    me "那我们以前来过这里吗？"

# game/a13/3northarr.rpy:136
translate english northarr_2ba4c3a3:

    # cass "Нет."
    cass "没有。"

# game/a13/3northarr.rpy:137
translate english northarr_138a89a3:

    # me "Представь будто ты почувствовала, будто этот момент уже был."
    me "想象一下，你感觉到这个时刻好像已经发生过了。"

# game/a13/3northarr.rpy:138
translate english northarr_77c4c910:

    # cass "Будто мы уже стояли в каких-то руинах посреди каменного холма и смотрели на горы?"
    cass "好像我们已经站在某处石头山丘顶的废墟中，望着群山？"

# game/a13/3northarr.rpy:139
translate english northarr_fc30fd2b_1:

    # me "Да."
    me "对。"

# game/a13/3northarr.rpy:140
translate english northarr_7e24be6a:

    # cass "Каждый момент из нашего детства в эльфийских развалинах."
    cass "我们童年时在精灵废墟里的每一刻都是这样。"

# game/a13/3northarr.rpy:141
translate english northarr_518bc90f:

    # me "Нет. Ты опять не поняла. Момент должен быть уникален."
    me "不。你又没理解。那个时刻必须是独一无二的。"

# game/a13/3northarr.rpy:143
translate english northarr_d2eebad9:

    # me "Да...но... ты меня запутала."
    me "是...的...你把我搞糊涂了。"

# game/a13/3northarr.rpy:144
translate english northarr_20368504:

    # cass "По-моему ты сам запутался."
    cass "我觉得是你自己把自己搞糊涂了。"

# game/a13/3northarr.rpy:145
translate english northarr_e5f12004:

    # me "Поверить не могу, что ты никогда не попадала в ситуации кажущиеся тебя без причины знакомыми."
    me "真不敢相信你从未遇到过那种毫无缘由就觉得熟悉的场景。"

# game/a13/3northarr.rpy:146
translate english northarr_651ccc28_2:

    # cass "..."
    cass "..."

# game/a13/3northarr.rpy:147
translate english northarr_6dfe2a9c:

    # me "Что прям ни разу?"
    me "真的一次都没有？"

# game/a13/3northarr.rpy:148
translate english northarr_58e48e60:

    # cass "Может пару раз и было, но что именно тебе кажется знакомым в этой безжизненной холодной пустыне?"
    cass "也许有过一两次，但在这片毫无生气的寒冷荒原上，你究竟觉得什么熟悉呢？"

# game/a13/3northarr.rpy:149
translate english northarr_ef0fc2d3:

    # me "Вот именно, что я не знаю. Просто кажется это место знакомым и все."
    me "问题就在这儿，我不知道。就是觉得这地方眼熟，仅此而已。"

# game/a13/3northarr.rpy:150
translate english northarr_651ccc28_3:

    # cass "..."
    cass "..."

# game/a13/3northarr.rpy:151
translate english northarr_eeda369f:

    # me "Может я жил или скорее умер здесь в прошлой жизни."
    me "也许我前世在这里生活过，或者死在这里。"

# game/a13/3northarr.rpy:152
translate english northarr_60b172a3:

    # cass "В прошлой жизни? И как ты что-то запомнил если она прошлая?"
    cass "前世？既然是前世的，你怎么可能还记得什么？"

# game/a13/3northarr.rpy:153
translate english northarr_2004c444:

    # me "Не знаю. Как-то запомнил."
    me "不知道。反正就是记得了。"

# game/a13/3northarr.rpy:154
translate english northarr_715646bd:

    # cass "Моя версия с тем, что ты был здесь пьяным звучит более реалистично."
    cass "我觉得我的说法——你喝醉了来过这里——听起来更靠谱。"

# game/a13/3northarr.rpy:156
translate english northarr_301f52e9:

    # me "...о боги."
    me "...哦，诸神啊。"

# game/a13/3northarr.rpy:157
translate english northarr_c2487b65:

    # cass "Что?"
    cass "怎么了？"

# game/a13/3northarr.rpy:158
translate english northarr_618dacce:

    # me "Теперь мне и сам момент кажется знакомым."
    me "现在连这个时刻本身我都觉得熟悉了。"

# game/a13/3northarr.rpy:159
translate english northarr_00f2033a:

    # cass "Чего?"
    cass "什么？"

# game/a13/3northarr.rpy:160
translate english northarr_584b3916:

    # me "Будто это уже было. Я сидел здесь и не мог вспомнить откуда я знаю это место."
    me "好像这已经发生过了。我坐在这里，想不起来我怎么会知道这个地方。"

# game/a13/3northarr.rpy:161
translate english northarr_ee16a318:

    # cass "Уверенна я точно также считала, что аранское золотое разъело тебе голову."
    cass "我敢肯定我当时也是一样，觉得是阿兰黄金烧坏了你的脑子。"

# game/a13/3northarr.rpy:162
translate english northarr_150cb3ce:

    # me "Нет... тебя не было."
    me "不...你不在那里。"

# game/a13/3northarr.rpy:163
translate english northarr_401fbd4d:

    # cass "Не было?"
    cass "不在？"

# game/a13/3northarr.rpy:164
translate english northarr_090978dd:

    # me "Не было. Рядом стоял кто-то другой."
    me "不在。当时站在旁边的是另一个人。"

# game/a13/3northarr.rpy:165
translate english northarr_dec3c1dd:

    # cass "Ты меня пугаешь."
    cass "你吓到我了。"

# game/a13/3northarr.rpy:166
translate english northarr_22eb9bf5:

    # me "Мне самому страшно."
    me "我自己也害怕。"

# game/a13/3northarr.rpy:167
translate english northarr_63cbcced:

    # cass "[mename]?"
    cass "[mename]?"

# game/a13/3northarr.rpy:168
translate english northarr_76406f9c:

    # me "...это место битвы у голубых гор..."
    me "...这是苍山战役的遗址..."

# game/a13/3northarr.rpy:169
translate english northarr_c2487b65_1:

    # cass "Что?"
    cass "什么？"

# game/a13/3northarr.rpy:170
translate english northarr_4e1b0d50:

    # me "Ничего. Просто... Забудь."
    me "没什么。只是...忘了吧。"

# game/a13/3northarr.rpy:171
translate english northarr_d3a59836:

    # cass "Может вернемся в лагерь?"
    cass "要不我们回营地吧？"

# game/a13/3northarr.rpy:172
translate english northarr_c00bb072:

    # me "Да. Ты права."
    me "好。你说得对。"

# game/a13/3northarr.rpy:176
translate english northarr_68442983:

    # guard "Это место битвы у Синих Гор, мой принц."
    guard "这是蓝山战役的遗址，我的王子。"

# game/a13/3northarr.rpy:177
translate english northarr_672a5a4c:

    # me "Ты серьезно?"
    me "你说真的？"

# game/a13/3northarr.rpy:178
translate english northarr_3e76f9f5:

    # guard "Да. Каменное плато недалеко от Хельвика. Это место идеально подходит под описание."
    guard "是的。Helvik附近的一片石质高原。这地方和描述完全吻合。"

# game/a13/3northarr.rpy:179
translate english northarr_4d5c2e81:

    # me "Да. Ты прав."
    me "是的。你说得对。"

# game/a13/3northarr.rpy:180
translate english northarr_a619c084:

    # guard "Дорога в Вольные Города была по пути. Это точно место битвы."
    guard "去自由城邦的路是顺路的。这绝对是那个战场。"

# game/a13/3northarr.rpy:181
translate english northarr_8b4aab32:

    # me "Но... как я... не понимаю. Это место кажется мне знакомым."
    me "但是...我怎么...不明白。这地方我觉得很眼熟。"

# game/a13/3northarr.rpy:182
translate english northarr_48b2abb1:

    # guard "Наверное читали о нем или видели картины, мой принц."
    guard "您可能读到过或者看到过相关的图画，我的王子。"

# game/a13/3northarr.rpy:183
translate english northarr_b9100f77:

    # me "Это пустошь и горы вокруг. На Севере полно таких мест."
    me "这就是一片荒原和周围的群山。北方到处都是这样的地方。"

# game/a13/3northarr.rpy:185
translate english northarr_d8cc3374:

    # me "Может память крови?"
    me "会不会是血之记忆？"

# game/a13/3northarr.rpy:186
translate english northarr_284d0690:

    # guard "Память крови, мой принц?"
    guard "血之记忆，我的王子？"

# game/a13/3northarr.rpy:187
translate english northarr_4ec0935d:

    # me "Мой дед бился здесь. И отец."
    me "我的祖父曾在这里战斗。还有我的父亲。"

# game/a13/3northarr.rpy:188
translate english northarr_53d0bdfa:

    # guard "Боюсь будущий Император Регис был в это время в Столице, мой принц."
    guard "恐怕未来的皇帝Regis那时正在首都，我的王子。"

# game/a13/3northarr.rpy:189
translate english northarr_03b14f96:

    # me "Ну да... точно."
    me "嗯，是...的确。"

# game/a13/3northarr.rpy:190
translate english northarr_afda0aab:

    # guard "Так что вы не могли унаследовать память об этом. Если я конечно понимаю, как это работает."
    guard "所以您不可能遗传到关于此的记忆。当然，前提是我理解那东西是怎么运作的。"

# game/a13/3northarr.rpy:191
translate english northarr_c5b1370a:

    # me "Если это вообще существует..."
    me "如果这东西真的存在的话..."

# game/a13/3northarr.rpy:192
translate english northarr_5233a746:

    # guard "..."
    guard "..."

# game/a13/3northarr.rpy:193
translate english northarr_3820771a_3:

    # me "..."
    me "..."

# game/a13/3northarr.rpy:195
translate english northarr_0ca45935:

    # me "Здесь ни памятников ни алтарей, а ведь северянам дорого далась эта победа."
    me "这里没有纪念碑，也没有祭坛，可这场胜利对北方人来说代价沉重。"

# game/a13/3northarr.rpy:196
translate english northarr_9437a07a:

    # guard "Верно, мой принц. Полагаю это место слишком безжизненное, чтобы что-то здесь строить."
    guard "没错，我的王子。我想是这地方太过荒芜，不适合在这里建任何东西。"

# game/a13/3northarr.rpy:197
translate english northarr_8d53f16f:

    # me "...и все же. Вообще ничего."
    me "...即便如此。什么都没有。"

# game/a13/3northarr.rpy:198
translate english northarr_826314f2:

    # guard "Множество мест великих битв напитались кровью, заросли травой и деревьями и забыты всеми."
    guard "许多伟大战役的遗址都被鲜血浸透，长满了青草和树木，然后被所有人遗忘。"

# game/a13/3northarr.rpy:199
translate english northarr_96eaadd9:

    # me "Да. На этом месте вершилась судьба Империи почти на весь континент, а теперь это просто пустошь."
    me "是啊。在这里，决定了帝国几乎整个大陆的命运，而如今只是片荒原。"

# game/a13/3northarr.rpy:200
translate english northarr_cca2c254:

    # guard "Такова воля безымянных богов. Все будет забыто."
    guard "这是无名诸神的意志。万物皆会被遗忘。"

# game/a13/3northarr.rpy:201
translate english northarr_c1ec750b:

    # guard "Сначала места великих битв, потом имена тех кто дрался, потом имена тех, кто вел в бой."
    guard "先是伟大战役的遗址，然后是参战者的名字，接着是那些领导他们的人的名字。"

# game/a13/3northarr.rpy:202
translate english northarr_b8ea39d2:

    # guard "Даже книги с записями об этом истлеют, а люди, что могут рассказать их содержимое умрут и истлеют сами."
    guard "即使是记载此事的书籍也会腐朽，而能够讲述其内容的人也会死去，自身化为尘土。"

# game/a13/3northarr.rpy:203
translate english northarr_8fd027fa:

    # guard "Все мы однажды присоединимся к безымянным богам."
    guard "终有一天，我们都会加入无名诸神的行列。"

# game/a13/3northarr.rpy:204
translate english northarr_3820771a_4:

    # me "..."
    me "..."

# game/a13/3northarr.rpy:205
translate english northarr_51e45b3c:

    # me "Пора возвращаться в лагерь."
    me "该回营地了。"

# game/a13/3northarr.rpy:209
translate english northarr2_9f2a99fe:

    # "Утром."
    "早上。"

# game/a13/3northarr.rpy:210
translate english northarr2_4c255fbf:

    # me "Вот и он. Выглядит не слишком защищено. Интересно почему мой дед не пошел сразу сюда."
    me "那就是了。看起来防备不是太森严。真好奇为什么我祖父当时没直接来这里。"

# game/a13/3northarr.rpy:211
translate english northarr2_debe8aae:

    # guard "Это замок для проживания и встреч, мой принц. В случае войн, северяне прячутся в свои цитадели в горах."
    guard "这是一座用于居住和会面的城堡，我的王子。发生战争时，北方人会躲进他们在山里的要塞。"

# game/a13/3northarr.rpy:212
translate english northarr2_36df8747:

    # me "Которые им помогали строить дворфы?"
    me "那些矮人帮他们建造的要塞？"

# game/a13/3northarr.rpy:213
translate english northarr2_cec6995e:

    # guard "По слухам."
    guard "据传闻是这样的。"

# game/a13/3northarr.rpy:214
translate english northarr2_3e8d9c7e:

    # me "И насколько эти слухи правдивы?"
    me "这些传闻有多真实？"

# game/a13/3northarr.rpy:215
translate english northarr2_51658345:

    # guard "Не знаю, мой принц, никогда там не был. Туда не пускают чужаков."
    guard "不知道，我的王子，我从没去过那里。那里不许外人进入。"

# game/a13/3northarr.rpy:216
translate english northarr2_ffc51265:

    # me "Понятно."
    me "明白了。"

# game/a13/3northarr.rpy:217
translate english northarr2_963021b5:

    # me "Я так понимаю пышной встречи нам не ожидать?"
    me "我估计，我们是别指望有什么盛大的欢迎仪式了？"

# game/a13/3northarr.rpy:218
translate english northarr2_82f82685:

    # guard "Это северяне, скажите спасибо, что нам не пришлось самим открывать ворота."
    guard "他们是北方人，我们该庆幸不用自己动手开门。"

# game/a13/3northarr.rpy:220
translate english northarr2_51ce1b32:

    # me "Ну хоть фанфары."
    me "至少还有号角声。"

# game/a13/3northarr.rpy:221
translate english northarr2_369ad9f8:

    # guard "Да. И в нас не стреляют арбалетчики со стен. Пока что это самое радушное приветствие на Севере которое я видел."
    guard "是啊。而且城墙上的弩手也没朝我们射击。到目前为止，这是我在北方见过的最热情的欢迎了。"

# game/a13/3northarr.rpy:222
translate english northarr2_e4698ae3:

    # me "Не преувеличивай."
    me "别夸张了。"

# game/a13/3northarr.rpy:223
translate english northarr2_aca05286:

    # guard "Я шучу конечно, мой принц, но..."
    guard "我当然是在开玩笑，我的王子，但是..."

# game/a13/3northarr.rpy:224
translate english northarr2_511310db:

    # me "Но?"
    me "但是？"

# game/a13/3northarr.rpy:225
translate english northarr2_a7d4b0a2:

    # guard "Не забывайте, их радушие это радушие к гостю. Если мы попытаемся..."
    guard "别忘了，他们的热情是对待客人的热情。如果我们试图..."

# game/a13/3northarr.rpy:226
translate english northarr2_bc811cae:

    # me "А мы ничего и не пытаемся. Пока что мы просто гости."
    me "我们什么也没试图。目前，我们只是客人。"

# game/a13/3northarr.rpy:227
translate english northarr2_7a324ba6:

    # guard "Конечно, мой принц."
    guard "当然，我的王子。"

# game/a13/3northarr.rpy:229
translate english northarr2_7ba2c60d:

    # eva "Что-то их не особо много. Заплутали на единственной дороге по пути?"
    eva "他们人好像不多啊。是在唯一的一条路上迷路了？"

# game/a13/3northarr.rpy:230
translate english northarr2_3dbaf6be:

    # cath "Наверное авангард."
    cath "可能是先头部队。"

# game/a13/3northarr.rpy:231
translate english northarr2_3bfc8ca2:

    # eva "Авангард? Они нас атакуют или что-то вроде того? Может закроем ворота?"
    eva "先头部队？他们要攻击我们还是怎么着？要不要关上城门？"

# game/a13/3northarr.rpy:232
translate english northarr2_623bd07a:

    # cath "Не ерничай, Ева, ты поняла о чем я."
    cath "别贫嘴了，Eva，你明白我的意思。"

# game/a13/3northarr.rpy:233
translate english northarr2_d368516e:

    # eva "А среди них принц то есть? Или я зря час кричала на слугу, пока она завязывала мне корсет?"
    eva "那里面有王子吗？还是说我冲着仆人吼了整整一小时让她给我系紧胸衣是白费力气？"

# game/a13/3northarr.rpy:234
translate english northarr2_fae4b71a:

    # cath "Мне кажется, я его вижу."
    cath "我好像看到他了。"

# game/a13/3northarr.rpy:235
translate english northarr2_f4686315:

    # eva "Это лошадь."
    eva "那是匹马。"

# game/a13/3northarr.rpy:236
translate english northarr2_8b445925:

    # cath "Прекрати, Ева."
    cath "别闹了，Eva。"

# game/a13/3northarr.rpy:237
translate english northarr2_1b987dcb:

    # eva "Они воняют? После такой долгой дороги наверняка воняют. Можно я буду закрывать нос, пока мы будем их приветствовать?"
    eva "他们臭吗？走了这么远的路，肯定臭烘烘的。我们欢迎他们的时候我能捂着鼻子吗？"

# game/a13/3northarr.rpy:238
translate english northarr2_9b45d829:

    # cath "У них обоз."
    cath "他们有行李车队。"

# game/a13/3northarr.rpy:239
translate english northarr2_96ba0c92:

    # eva "Подарки с Юга. Болотная чума и белокровие."
    eva "从南方来的礼物。沼泽瘟疫和白血病。"

# game/a13/3northarr.rpy:240
translate english northarr2_fa359855:

    # cath "Надо распорядиться и позвать дополнительных слуг."
    cath "得吩咐下去，多叫些仆人来。"

# game/a13/3northarr.rpy:241
translate english northarr2_2470e07a:

    # eva "Я бы сожгла содержимое. На всякий случай. Это может быть какая-то военная хитрость. Внутри карлики в доспехах или что-то такое."
    eva "要是我，就把里面的东西都烧了。以防万一。这可能是某种军事诡计。里面可能藏着穿铠甲的矮人什么的。"

# game/a13/3northarr.rpy:242
translate english northarr2_1d504899:

    # cath "Может спустимся, Борис?"
    cath "我们下去吧，Boris？"

# game/a13/3northarr.rpy:243
translate english northarr2_a5d4c3d1:

    # eva "Может сразу упадем на колени и поцелуем им руки?"
    eva "要不要现在就跪下亲吻他们的手？"

# game/a13/3northarr.rpy:245
translate english northarr2_f147f715:

    # cath "Ева! Прекрати вести себя как несносная, невоспитанная девчонка!"
    cath "Eva！别再像个讨厌的、没教养的丫头片子那样了！"

# game/a13/3northarr.rpy:246
translate english northarr2_8434f26e:

    # eva "О чем ты, мамочка?"
    eva "你在说什么呀，妈妈？"

# game/a13/3northarr.rpy:247
translate english northarr2_a9d6fd99:

    # cath "Ты знаешь о чем я!"
    cath "你清楚我在说什么！"

# game/a13/3northarr.rpy:248
translate english northarr2_50a2a057:

    # eva "Понятия не имею."
    eva "我完全没概念。"

# game/a13/3northarr.rpy:249
translate english northarr2_61ddea4c:

    # cath "Не дай бог ты будешь нести свою чушь перед гостями!"
    cath "千万别在客人面前胡说八道！"

# game/a13/3northarr.rpy:250
translate english northarr2_6dbca920:

    # eva "Я просто слежу за тем, чтобы наша честь не была попрана."
    eva "我只是在确保我们的荣誉不受践踏。"

# game/a13/3northarr.rpy:251
translate english northarr2_0c4766f1:

    # dubov "Эх..."
    dubov "唉..."

# game/a13/3northarr.rpy:252
translate english northarr2_6e9c146b:

    # cath "Ты позоришь нас прямо сейчас."
    cath "你现在就在给我们丢脸。"

# game/a13/3northarr.rpy:253
translate english northarr2_e78ef18c:

    # eva "Это не я предложила спуститься к ним, будто это мы гости."
    eva "先提出要下去迎接他们的可不是我，好像我们是客人似的。"

# game/a13/3northarr.rpy:254
translate english northarr2_71309404:

    # cath "Борис!"
    cath "Boris！"

# game/a13/3northarr.rpy:255
translate english northarr2_4f3a1b57:

    # eva "Отец со мной согласен, да, папочка?"
    eva "父亲同意我的看法，对吧，爸爸？"

# game/a13/3northarr.rpy:256
translate english northarr2_1873bc6a:

    # dubov "Если я услышу от тебя хоть одно оскорбительное слово или глупую ремарку в сторону наших гостей, ты отправишься под арест в башню."
    dubov "要是我从你嘴里听到哪怕一句侮辱的话或愚蠢的评论针对我们的客人，你就给我去塔楼禁闭。"

# game/a13/3northarr.rpy:257
translate english northarr2_9fc8971a:

    # cath "Слышала отца?"
    cath "听到父亲的话了？"

# game/a13/3northarr.rpy:258
translate english northarr2_9f8a1772:

    # eva "Да, папочка."
    eva "听到了，爸爸。"

# game/a13/3northarr.rpy:259
translate english northarr2_ddf86026:

    # dubov "Мы дождемся их здесь."
    dubov "我们就在这里等他们。"

# game/a13/3northarr.rpy:260
translate english northarr2_eae32da0:

    # cath "Ни слова!"
    cath "一个字也不许说！"

# game/a13/3northarr.rpy:261
translate english northarr2_f71bda30:

    # eva "Мне молчать? Принц должен думать у папы две дочери - инвалиды?"
    eva "我该沉默吗？让王子以为爸爸有两个残疾女儿？"

# game/a13/3northarr.rpy:262
translate english northarr2_d65ed473:

    # cath "Ты прекрасно знаешь, как вести себя нормально."
    cath "你很清楚怎么正常地表现。"

# game/a13/3northarr.rpy:263
translate english northarr2_bc6199c1:

    # eva "Ну ладно-ладно. Я буду хорошей девочкой."
    eva "好吧好吧。我会当个乖女孩的。"

# game/a13/3northarr.rpy:266
translate english northarr2_4d0618e7:

    # dubov "Принц-регент [mename] из Золотой Империи."
    dubov "黄金帝国的摄政王[mename]王子。"

# game/a13/3northarr.rpy:267
translate english northarr2_2f539c2a:

    # me "Лорд Дубовицкий. Король Севера. Я больше не регент. Моему отцу гораздо лучше, он способен править самостоятельно."
    me "Dubovitsky领主。北境之王。我不再是摄政王了。我父亲身体好多了，已经能独立执政了。"

# game/a13/3northarr.rpy:268
translate english northarr2_3cd13a25:

    # dubov "Рад это слышать. И рад, что вы доехали до наших краев в целости и сохранности."
    dubov "很高兴听到这个。也很高兴你们平安到达我们这里。"

# game/a13/3northarr.rpy:269
translate english northarr2_f1d60976:

    # me "Доплыл."
    me "是航行到的。"

# game/a13/3northarr.rpy:270
translate english northarr2_bba17cb3:

    # dubov "Ну кончено. Доплыли. Разумно миновать эпидемию. Справа от меня моя жена Катерина."
    dubov "嗯，当然。航行到的。绕开瘟疫，很明智。我右边是我的妻子Katerina。"

# game/a13/3northarr.rpy:271
translate english northarr2_279bbbfc:

    # cath "Принц [mename]."
    cath "[mename]王子。"

# game/a13/3northarr.rpy:272
translate english northarr2_ffe68702:

    # dubov "Слева от меня моя младшая дочь - Ева."
    dubov "我左边是我的小女儿——Eva。"

# game/a13/3northarr.rpy:273
translate english northarr2_80fd8555:

    # eva "Принц [mename]."
    eva "[mename]王子。"

# game/a13/3northarr.rpy:274
translate english northarr2_639444ec:

    # me "Приятно видеть вашу семью в добром здравии."
    me "很高兴看到您家人安康。"

# game/a13/3northarr.rpy:275
translate english northarr2_eabf3a14:

    # dubov "Полагаю это не все гости."
    dubov "我想这不是全部的客人吧。"

# game/a13/3northarr.rpy:276
translate english northarr2_ce2f0621:

    # me "Нет. Остальные прибудут через пару дней. Нас немного, хватит и 2-3 покоев. Остальные могут жить за стенами."
    me "不是。其余的过几天到。我们人不多，两三间房就够了。其他人可以住在城墙外。"

# game/a13/3northarr.rpy:277
translate english northarr2_8fcf6e53:

    # dubov "Ну что вы. У нас найдется место для всех."
    dubov "您这是说的什么话。我们这儿有足够的地方容纳所有人。"

# game/a13/3northarr.rpy:278
translate english northarr2_ce761074:

    # me "Рад это слышать."
    me "很高兴听到这个。"

# game/a13/3northarr.rpy:279
translate english northarr2_4abc1181:

    # dubov "Вы с грузом?"
    dubov "您带行李了？"

# game/a13/3northarr.rpy:280
translate english northarr2_f618bebb:

    # me "Конечно. Я бы не посетил вас без подарков. Пусть слуги отнесут ящики на кухню. Могу я..."
    me "当然。我不会不带礼物就来拜访您的。让仆人把箱子送到厨房去。我能..."

# game/a13/3northarr.rpy:281
translate english northarr2_9a3e52ae:

    # dubov "Прошу, принц, поднимайтесь, не делайте этот разговор таким формальным."
    dubov "请吧，王子，上来吧，别让这谈话变得如此拘谨。"

# game/a13/3northarr.rpy:284
translate english northarr2_4d0618e7_1:

    # dubov "Принц-регент [mename] из Золотой Империи."
