translate english northarr2_80fd8555_1:

    # eva "Принц [mename]."
    eva "[mename]王子。"

# game/a13/3northarr.rpy:292
translate english northarr2_639444ec_1:

    # me "Приятно видеть вашу семью в добром здравии."
    me "很高兴看到您家人安康。"

# game/a13/3northarr.rpy:293
translate english northarr2_bff51c26:

    # dubov "Аналогично. Приятно видеть мою дочь и ее мужа в добром здравии."
    dubov "彼此彼此。很高兴看到我女儿和她丈夫都安康。"

# game/a13/3northarr.rpy:294
translate english northarr2_859077a4:

    # aurora "Здравствуй, отец."
    aurora "你好，父亲。"

# game/a13/3northarr.rpy:295
translate english northarr2_ef408351:

    # dubov "Здравствуй, Аврора. Полагаю это не все гости."
    dubov "你好，Aurora。我想这不是全部的客人吧。"

