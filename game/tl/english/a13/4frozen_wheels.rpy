translate english frozen_wheels2_eb4a9e12:

    # me "Вроде нет. Но было бы неплохо, может на груди выросло побольше волос."
    me "好像没有。但那样也不坏，也许胸口能多长些毛。"

# game/a13/4frozen_wheels.rpy:519
translate english frozen_wheels2_25d68376:

    # me "Так мы идем?"
    me "那我们走吗？"

# game/a13/4frozen_wheels.rpy:521
translate english frozen_wheels2_9da95031:

    # dubov "Прежде вам нужно переодеться."
    dubov "首先您得换衣服。"

# game/a13/4frozen_wheels.rpy:522
translate english frozen_wheels2_83573e9a:

    # me "Мне довольно удобно и в этом."
    me "我这样也挺舒服。"

# game/a13/4frozen_wheels.rpy:523
translate english frozen_wheels2_dd4c9b3f:

    # dubov "Не сомневаюсь. Но ночью станет холоднее."
    dubov "我不怀疑。但夜里会更冷。"

# game/a13/4frozen_wheels.rpy:524
translate english frozen_wheels2_ef8f0041:

    # me "Я ничего..."
    me "我什么都没……"

# game/a13/4frozen_wheels.rpy:525
translate english frozen_wheels2_ac22173f:

    # dubov "Я все подготовил."
    dubov "我都准备好了。"

# game/a13/4frozen_wheels.rpy:527
translate english frozen_wheels2_4573ad07:

    # me "Вроде по размеру..."
    me "看着像合身的……"

# game/a13/4frozen_wheels.rpy:528
translate english frozen_wheels2_418e9761:

    # dubov "Ты чего здесь делаешь?"
    dubov "你在这儿做什么？"

# game/a13/4frozen_wheels.rpy:529
translate english frozen_wheels2_ab71d907:

    # eva "Собралась на охоту."
    eva "我准备去打猎。"

# game/a13/4frozen_wheels.rpy:530
translate english frozen_wheels2_5429fcb0:

    # dubov "Какую еще охоту? Я тебя не звал."
    dubov "打什么猎？我没叫你。"

# game/a13/4frozen_wheels.rpy:531
translate english frozen_wheels2_95d5afa6:

    # eva "Но пап!"
    eva "可是，爸！"

# game/a13/4frozen_wheels.rpy:532
translate english frozen_wheels2_b8a49de1:

    # dubov "Что, 'пап'?"
    dubov "“爸”什么？"

# game/a13/4frozen_wheels.rpy:533
translate english frozen_wheels2_c3b9ce39:

    # eva "Ты же брал меня с собой!"
    eva "你以前带我去过！"

# game/a13/4frozen_wheels.rpy:534
translate english frozen_wheels2_a53e5400:

    # dubov "И что?"
    dubov "那又怎样？"

# game/a13/4frozen_wheels.rpy:535
translate english frozen_wheels2_d976a8d2:

    # eva "Почему не возьмешь сейчас?"
    eva "为什么这次不带？"

# game/a13/4frozen_wheels.rpy:536
translate english frozen_wheels2_032fad44:

    # dubov "Потому что ты наказана."
    dubov "因为你被惩罚了。"

# game/a13/4frozen_wheels.rpy:537
translate english frozen_wheels2_8d561203:

    # eva "Я целые сутки просидела одна-одинешенька в холодной башне, голодая."
    eva "我整整一天一个人待在寒冷的塔楼里，挨着饿。"

# game/a13/4frozen_wheels.rpy:538
translate english frozen_wheels2_494d33f8:

    # dubov "Тебя кормили."
    dubov "你被喂过了。"

# game/a13/4frozen_wheels.rpy:539
translate english frozen_wheels2_11403e36:

    # eva "Я специально не ела, что наказание было суровей!"
    eva "我是故意不吃的，好让惩罚更严厉！"

# game/a13/4frozen_wheels.rpy:541
translate english frozen_wheels2_21dffe77:

    # dubov "Возвращайся обратно, Ева."
    dubov "回塔楼去，Eva。"

# game/a13/4frozen_wheels.rpy:542
translate english frozen_wheels2_f792f760:

    # eva "Ну пап!"
    eva "爸！"

# game/a13/4frozen_wheels.rpy:543
translate english frozen_wheels2_39dc22f8:

    # dubov "Прекрати, Ева."
    dubov "别闹，Eva。"

# game/a13/4frozen_wheels.rpy:544
translate english frozen_wheels2_43afcbce:

    # eva "Я ведь уже и так серьезно пострадала!"
    eva "我已经受了很多苦了！"

# game/a13/4frozen_wheels.rpy:545
translate english frozen_wheels2_1a874ea1:

    # dubov "Один день в башне это едва ли можно назвать серьезным наказанием."
    dubov "在塔楼待一天可算不上严厉的惩罚。"

# game/a13/4frozen_wheels.rpy:546
translate english frozen_wheels2_85399640:

    # eva "Целый день взаперти!"
    eva "整整一天被关着！"

# game/a13/4frozen_wheels.rpy:547
translate english frozen_wheels2_67977491:

    # dubov "Будет еще больше, если ты не уйдешь."
    dubov "如果你不走，还会有更多天。"

# game/a13/4frozen_wheels.rpy:548
translate english frozen_wheels2_002e7d37:

    # eva "Я ведь извинилась, а принцу моя шутка понравилась!"
    eva "我道歉了，而且王子喜欢我的玩笑！"

# game/a13/4frozen_wheels.rpy:549
translate english frozen_wheels2_224a85f8:

    # dubov "Как это отменяет факт непослушания?"
    dubov "这怎么就能抹掉你不听话的事实？"

# game/a13/4frozen_wheels.rpy:550
translate english frozen_wheels2_5bd60f48:

    # eva "Не отменяет. Я виновата. Ты прав."
    eva "不抹掉。我有错。你是对的。"

# game/a13/4frozen_wheels.rpy:551
translate english frozen_wheels2_43cafb5b:

    # dubov "В таком случе ты знаешь куда идти."
    dubov "那样的话，你知道该去哪儿。"

# game/a13/4frozen_wheels.rpy:552
translate english frozen_wheels2_6dfaa272:

    # eva "Прости. Я просто думала... я хотела провести с тобой больше времени... хотела еще раз извинится перед принцем."
    eva "对不起。我只是想……我想多和你待一会儿……想再向王子道一次歉。"

# game/a13/4frozen_wheels.rpy:553
translate english frozen_wheels2_d19f6f58:

    # dubov "Прекрати."
    dubov "别这样。"

# game/a13/4frozen_wheels.rpy:554
translate english frozen_wheels2_158d236c:

    # eva "Мама наругала меня и ты, и целый день в башне без посетителей... и я ведь извинилась перед принцем, а он даже не расстроился, я думала что наказана сполна..."
    eva "妈妈骂了我，你也骂了，又整天独自关在塔楼里……而且我向王子道了歉，他甚至都没生气，我以为我受够惩罚了……"

# game/a13/4frozen_wheels.rpy:555
translate english frozen_wheels2_0c4766f1:

    # dubov "Эх..."
    dubov "唉……"

# game/a13/4frozen_wheels.rpy:557
translate english frozen_wheels2_1f099caf:

    # eva "И я даже подготовилась к охоте, видишь? Мне не надо переодеваться."
    eva "而且我连打猎都准备好了，你看？我不用换衣服。"

# game/a13/4frozen_wheels.rpy:558
translate english frozen_wheels2_1a9333e6:

    # dubov "Угу..."
    dubov "嗯……"

# game/a13/4frozen_wheels.rpy:559
translate english frozen_wheels2_77c5a60e:

    # eva "Ты ведь сам говорил, что я такая наглая потому что не испытывала трудностей в жизни."
    eva "你自己也说过，我这么放肆是因为没经历过生活的艰辛。"

# game/a13/4frozen_wheels.rpy:560
translate english frozen_wheels2_a53e5400_1:

    # dubov "И что?"
    dubov "那又怎样？"

# game/a13/4frozen_wheels.rpy:561
translate english frozen_wheels2_8e002a2e:

    # eva "Разве охота это не трудно? Минимум день ходьбы без передышки, сон у костра, грубая пища - разве это не хорошая воспитательная практика?"
    eva "打猎难道不艰苦吗？至少走一天路不休息，睡篝火旁，吃粗糙食物——这不是很好的教育实践吗？"

# game/a13/4frozen_wheels.rpy:562
translate english frozen_wheels2_338901d5:

    # dubov "..."
    dubov "..."

# game/a13/4frozen_wheels.rpy:563
translate english frozen_wheels2_0042b306:

    # eva "Я и перед мамой извинилась. Она заставила меня вымыть всю посуду вместо слуг после завтрака. Я унизилась ради нее и она меня простила!"
    eva "我也向妈妈道歉了。她罚我早餐后替仆人们洗所有的盘子。我为她降低了身份，她原谅了我！"

# game/a13/4frozen_wheels.rpy:564
translate english frozen_wheels2_cc1469a6:

    # dubov "Ева..."
    dubov "Eva……"

# game/a13/4frozen_wheels.rpy:565
translate english frozen_wheels2_e67c65da:

    # eva "Я буду хорошей девочкой, обещаю."
    eva "我会做个好女孩，我保证。"

# game/a13/4frozen_wheels.rpy:567
translate english frozen_wheels2_61305b83:

    # me "Так мы идем или нет?"
    me "那我们到底走不走？"

# game/a13/4frozen_wheels.rpy:568
translate english frozen_wheels2_ea571898:

    # dubov "Сначала мне нужно отвести дочь обратно в замок."
    dubov "我得先把女儿送回城堡。"

# game/a13/4frozen_wheels.rpy:569
translate english frozen_wheels2_06eea7d9:

    # eva "Пап!"
    eva "爸！"

# game/a13/4frozen_wheels.rpy:570
translate english frozen_wheels2_9824f48f:

    # dubov "Если только..."
    dubov "除非……"

# game/a13/4frozen_wheels.rpy:571
translate english frozen_wheels2_b4a677c1:

    # me "Я не против. Я уже в третий раз говорю, что меня та ситуация позабавила."
    me "我不反对。我已经说过第三次了，那次事让我觉得有趣。"

# game/a13/4frozen_wheels.rpy:572
translate english frozen_wheels2_4f977c5e:

    # eva "Видишь? Даже принц не против."
    eva "看到了吧？连王子都不反对。"

# game/a13/4frozen_wheels.rpy:573
translate english frozen_wheels2_34874408:

    # dubov "Эх... только потому что вернуть тебя доставит больше хлопот, чем взять с собой."
    dubov "唉……只是因为送你回去比带去更麻烦。"

# game/a13/4frozen_wheels.rpy:574
translate english frozen_wheels2_60943f46:

    # eva "Спасибо, папочка! Спасибо, принц [mename]."
    eva "谢谢你，爸爸！谢谢你，王子[mename]。"

# game/a13/4frozen_wheels.rpy:575
translate english frozen_wheels2_9428adba:

    # me "А мне за что?"
    me "又谢我什么？"

# game/a13/4frozen_wheels.rpy:576
translate english frozen_wheels2_b5e1f107:

    # eva "Что не стали обижаться на невинную шутку."
    eva "因为您没有为一个无伤大雅的玩笑生气。"

# game/a13/4frozen_wheels.rpy:577
translate english frozen_wheels2_de5f71df:

    # dubov "Если продолжишь делать вид, что эта выходка была чем-то нормальным, я все-таки верну тебя в замок."
    dubov "如果你继续表现得好像那出闹剧很正常，我还是会把你送回城堡。"

# game/a13/4frozen_wheels.rpy:578
translate english frozen_wheels2_dfe08074:

    # eva "Я все поняла. Простите!"
    eva "我明白了。对不起！"

# game/a13/4frozen_wheels.rpy:579
translate english frozen_wheels2_d6bfed3a:

    # dubov "Влад."
    dubov "Vlad。"

# game/a13/4frozen_wheels.rpy:581
translate english frozen_wheels2_7a57e29b:

    # vlad "Я посмотрю за ней. Если отстанет - Марен присмотрит."
    vlad "我会看着她。如果她掉队——马琳会照看。"

# game/a13/4frozen_wheels.rpy:582
translate english frozen_wheels2_d42e0637:

    # eva "Я не отстану."
    eva "我不会掉队。"

# game/a13/4frozen_wheels.rpy:583
translate english frozen_wheels2_16ecda5b:

    # dubov "Если понадобиться..."
    dubov "如果必要……"

# game/a13/4frozen_wheels.rpy:584
translate english frozen_wheels2_c5fdb701:

    # vlad "Я отведу ее в замок."
    vlad "我会带她回城堡。"

# game/a13/4frozen_wheels.rpy:585
translate english frozen_wheels2_c25685a4:

    # eva "Не понадобиться! Обещаю!"
    eva "没必要！我保证！"

# game/a13/4frozen_wheels.rpy:586
translate english frozen_wheels2_047e065b:

    # dubov "Ловлю на слово, Ева."
    dubov "我相信你的话，Eva。"

# game/a13/4frozen_wheels.rpy:587
translate english frozen_wheels2_fb57cb40:

    # eva "Я буду хорошей принцессой!"
    eva "我会做个好公主！"

# game/a13/4frozen_wheels.rpy:588
translate english frozen_wheels2_452fab22:

    # dubov "Угум..."
    dubov "嗯嗯……"

# game/a13/4frozen_wheels.rpy:590
translate english frozen_wheels2_83749a03:

    # "Полчаса спустя."
    "半个小时以后。"

# game/a13/4frozen_wheels.rpy:591
translate english frozen_wheels2_a8c49241:

    # dubov "...мой отец не любил охотиться. Мать приучила меня. Отец запрещал, но ей было все равно."
    dubov "……我父亲不喜欢打猎。是母亲教会我的。父亲禁止，但她不在乎。"

# game/a13/4frozen_wheels.rpy:592
translate english frozen_wheels2_db9ea9ff:

    # me "Ваша мать шла наперекор вашему отцу? Удивительно."
    me "您的母亲违抗您的父亲？真令人惊讶。"

# game/a13/4frozen_wheels.rpy:593
translate english frozen_wheels2_8e0db329:

    # dubov "На самом деле нет. Если дать женщинам волю они быстро подомнут своих мужей. Не все конечно. Но некоторые северянки гораздо... тверже своих мужей."
    dubov "实际上不奇怪。如果给女人自由，她们很快就会支配自己的丈夫。当然不是所有。但有些北方女人远比她们的丈夫……强硬。"

# game/a13/4frozen_wheels.rpy:594
translate english frozen_wheels2_a4479736:

    # dubov "Вы это еще увидите, когда отправитесь путешествовать дальше."
    dubov "当您继续北行时，您还会看到。"

# game/a13/4frozen_wheels.rpy:595
translate english frozen_wheels2_82b1c682:

    # me "Почему именно северянки?"
    me "为什么偏偏是北方女人？"

# game/a13/4frozen_wheels.rpy:596
translate english frozen_wheels2_79d915c2:

    # dubov "Может и не только северянки, но я в своей жизни знал только их."
    dubov "也许不单是北方女人，但我一生只认识她们。"

# game/a13/4frozen_wheels.rpy:597
translate english frozen_wheels2_1c325586:

    # me "А как же восстания, которые вы подавляли вместе с моим дедом?"
    me "那您和我祖父一起镇压的那些叛乱呢？"

# game/a13/4frozen_wheels.rpy:598
translate english frozen_wheels2_3619dd06:

    # dubov "Думаете мне тогда было дело до женщин? К тому же я тогда уже был женат."
    dubov "您以为那时候我还有心思关注女人？何况那时我已经结婚了。"

# game/a13/4frozen_wheels.rpy:599
translate english frozen_wheels2_e88aee27:

    # me "Моя бабушка северянка."
    me "我的祖母是北方人。"

# game/a13/4frozen_wheels.rpy:600
translate english frozen_wheels2_09539c09:

    # dubov "Верно."
    dubov "没错。"

# game/a13/4frozen_wheels.rpy:601
translate english frozen_wheels2_a7d7ad23:

    # me "Всегда думал как это вышло. Но мой учитель ограничивался тем, что он уже приехал с Севера с женой."
    me "我总在想这是怎么发生的。但我的老师仅限于告诉我，他带着妻子从北方来。"

# game/a13/4frozen_wheels.rpy:602
translate english frozen_wheels2_b0caa64d:

    # me "Хотя для меня всегда было удивительно, что он вообще здесь жил."
    me "尽管我总是奇怪，他怎么会住在这里。"

# game/a13/4frozen_wheels.rpy:603
translate english frozen_wheels2_5e5d4636:

    # dubov "На Севере? Ничего удивительного. Вы ведь знаете как он получил власть?"
    dubov "在北方？一点也不奇怪。您知道他是怎么获得权力的吗？"

# game/a13/4frozen_wheels.rpy:604
translate english frozen_wheels2_e5800bbc:

    # me "Он был пятым сыном."
    me "他是第五个儿子。"

# game/a13/4frozen_wheels.rpy:605
translate english frozen_wheels2_b57b138a:

    # dubov "Верно. Шанс на его наследование был минимален. Но Старый Император умирать не желал. Подумать только, даже я застал его правление."
    dubov "正确。他继承的机会微乎其微。但老皇帝不愿死去。想想看，甚至我都经历了他统治的时期。"

# game/a13/4frozen_wheels.rpy:606
translate english frozen_wheels2_c4ffead4:

    # me "А когда все же умер...1"
    me "而当他终于去世时……"

# game/a13/4frozen_wheels.rpy:607
translate english frozen_wheels2_e67eae9a:

    # dubov "Да. Живых сыновей у него не осталось. Кроме самого младшего."
    dubov "对。他没了活着的儿子。除了最小的那个。"

# game/a13/4frozen_wheels.rpy:608
translate english frozen_wheels2_2bd005ff:

    # me "Это не объясняет, что он тут делал."
    me "这解释不了他在这里做什么。"

# game/a13/4frozen_wheels.rpy:610
translate english frozen_wheels2_f1ce3071:

    # eva "Прятался. Разве не ясно?"
    eva "在躲藏。难道不明显吗？"

# game/a13/4frozen_wheels.rpy:611
translate english frozen_wheels2_0a80b303:

    # me "Прятался?"
    me "躲藏？"

# game/a13/4frozen_wheels.rpy:612
translate english frozen_wheels2_48310a5e:

    # dubov "Быть единственным живым сыном не очень безопасно, учитывая армию из внуков других сыновей."
    dubov "做唯一活着的儿子并不安全，鉴于其他儿子们的孙辈有一支军队。"

# game/a13/4frozen_wheels.rpy:613
translate english frozen_wheels2_6115b32e:

    # me "Они его искали?"
    me "他们找他了吗？"

# game/a13/4frozen_wheels.rpy:614
translate english frozen_wheels2_d0b3eab4:

    # dubov "Искали. Но когда Старый Император умер, в столице вашего деда не было, поэтому внуки начали резать друг друга, думая что это они друг другу конкуренты."
    dubov "找了。但当老皇帝死时，您祖父不在首都，所以孙辈们开始互相残杀，以为彼此才是竞争对手。"

# game/a13/4frozen_wheels.rpy:615
translate english frozen_wheels2_1b8661ac:

    # eva "И все умерли?"
    eva "而所有人都死了？"

# game/a13/4frozen_wheels.rpy:616
translate english frozen_wheels2_35b8984e:

    # dubov "Не все. Но когда Красный Император вьехал с армией лоялистов в столицу было поздно объединять усилия."
    dubov "不是所有人。但当红色皇帝带着效忠军进入首都时，再联合力量已为时太晚。"

# game/a13/4frozen_wheels.rpy:617
translate english frozen_wheels2_217614c0:

    # eva "Он всех повесил."
    eva "他把所有人都吊死了。"

# game/a13/4frozen_wheels.rpy:618
translate english frozen_wheels2_99c732f4:

    # me "Почему я никогда об этом не слышал?"
    me "为什么我从没听说过这些？"

# game/a13/4frozen_wheels.rpy:619
translate english frozen_wheels2_3c51f683:

    # dubov "Все помнят о безумствах Красного Императора, мало кто вспоминает времена, когда он был справедлив и мудр."
    dubov "所有人都记得红色皇帝的疯狂，很少有人回忆他还是公正明智之时的岁月。"

# game/a13/4frozen_wheels.rpy:620
translate english frozen_wheels2_048d0ac0:

    # eva "Так он убил оставшихся внуков Старого Императора или нет?"
    eva "所以他到底杀没杀老皇帝剩下的孙辈？"

# game/a13/4frozen_wheels.rpy:621
translate english frozen_wheels2_4c1aed42:

    # dubov "Убил только тех, что не склонили колени."
    dubov "只杀了那些不肯屈膝的。"

# game/a13/4frozen_wheels.rpy:622
translate english frozen_wheels2_b2bbbb40:

    # me "Странно. Я ничего не слышал о других Стархэдах по линии Старого Императора."
    me "奇怪。老皇帝这一支，我没听说过还有其他的Starhead。"

# game/a13/4frozen_wheels.rpy:623
translate english frozen_wheels2_11b7cbab:

    # eva "Наверное остальных он убил, когда сошел с ума."
    eva "大概他在发疯后杀了其余的。"

# game/a13/4frozen_wheels.rpy:624
translate english frozen_wheels2_09539c09_1:

    # dubov "Верно."
    dubov "正确。"

# game/a13/4frozen_wheels.rpy:625
translate english frozen_wheels2_91eba28d:

    # me "А это армия лоялистов... он собрал ее на Севере?"
    me "那支效忠军……他是在北方组建的吗？"

# game/a13/4frozen_wheels.rpy:626
translate english frozen_wheels2_029429e8_1:

    # dubov "Да."
    dubov "是的。"

# game/a13/4frozen_wheels.rpy:627
translate english frozen_wheels2_f53683c5:

    # me "Выходит, вы привели его к власти."
    me "那么，是您把他推上权力宝座的。"

# game/a13/4frozen_wheels.rpy:628
translate english frozen_wheels2_b631248a:

    # dubov "Я тогда еще был ребенком. Моя мать и отец были его сторонниками. Они укрывали его, когда слухи о том что Старый Император вот-вот умрет добрались до Севера."
    dubov "那时候我还是个孩子。我母亲和父亲是他的支持者。当老皇帝即将死去的传闻抵达北方时，他们庇护了他。"

# game/a13/4frozen_wheels.rpy:629
translate english frozen_wheels2_29796910:

    # eva "Он жил у нас в замке? Красный Император?"
    eva "他住在我们的城堡里？红色皇帝？"

# game/a13/4frozen_wheels.rpy:630
translate english frozen_wheels2_49f1a43e:

    # dubov "Нет. Это было бы слишком очевидно. Он жил у наших вассалов в замке Мокрый Холм."
    dubov "不。那太明显了。他住在我们封臣的湿丘城堡。"

# game/a13/4frozen_wheels.rpy:631
translate english frozen_wheels2_72ae5e62:

    # eva "Ховрины. Они уже вымерли."
    eva "霍夫林家族。他们已经绝嗣了。"

# game/a13/4frozen_wheels.rpy:632
translate english frozen_wheels2_bceff03e:

    # me "Вымерли?"
    me "绝嗣了？"

# game/a13/4frozen_wheels.rpy:633
translate english frozen_wheels2_59d794b1:

    # dubov "Род прервался, а замок пришел в запустение."
    dubov "血脉断绝，城堡荒废了。"

# game/a13/4frozen_wheels.rpy:634
translate english frozen_wheels2_d5c369f2:

    # me "...понятно."
    me "……明白。"

# game/a13/4frozen_wheels.rpy:636
translate english frozen_wheels2_83749a03_1:

    # "Полчаса спустя."
    "半个小时以后。"

# game/a13/4frozen_wheels.rpy:637
translate english frozen_wheels2_4663f9cc:

    # me "Ева отстала."
    me "Eva落后了。"

# game/a13/4frozen_wheels.rpy:638
translate english frozen_wheels2_022dd408:

    # dubov "Я заметил."
    dubov "我注意到了。"

# game/a13/4frozen_wheels.rpy:639
translate english frozen_wheels2_3820771a_1:

    # me "..."
    me "..."

# game/a13/4frozen_wheels.rpy:640
translate english frozen_wheels2_2206c246:

    # dubov "По поводу горских князей."
    dubov "关于山区王公的事。"

# game/a13/4frozen_wheels.rpy:641
translate english frozen_wheels2_6fe39c0f:

    # me "Да. Есть советы?"
    me "是。有什么建议吗？"

# game/a13/4frozen_wheels.rpy:642
translate english frozen_wheels2_ae1a169d:

    # dubov "Есть парочку. Это не советы... скорее полезная информация."
    dubov "有几个。这不是建议……更像是些有用的信息。"

# game/a13/4frozen_wheels.rpy:643
translate english frozen_wheels2_dd708c23:

    # me "Я готов слушать."
    me "我洗耳恭听。"

# game/a13/4frozen_wheels.rpy:644
translate english frozen_wheels2_b62250d8:

    # dubov "Те земли, что они захватили. Они когда-то были их. Но они пролили кровь без надобности и эти земли отобрали."
    dubov "他们占领的那些土地。曾经是他们的。但他们无故流血，就被剥夺了。"

# game/a13/4frozen_wheels.rpy:645
translate english frozen_wheels2_76f53e06:

    # dubov "С тех пор прошла почти сотня лет. Один из горских князей женил сестру на лорде Скаладане. Но брак был расторгнут."
    dubov "从那以后过了将近一百年。一位山区王公把妹妹嫁给了斯卡拉丹领主。但婚姻被解除了。"

# game/a13/4frozen_wheels.rpy:647
translate english frozen_wheels2_5ac38cf1:

    # me "Почему?"
    me "为什么？"

# game/a13/4frozen_wheels.rpy:648
translate english frozen_wheels2_5fda42a5:

    # dubov "Это мне неизвестно. Но горцы посчитали себя оскорбленными. Они говорят, что раз Скаладан не держит слово, они могут не держать свое."
    dubov "这我不知道。但山区人觉得受了侮辱。他们说，既然斯卡拉丹不守信，他们也就不必守信。"

# game/a13/4frozen_wheels.rpy:649
translate english frozen_wheels2_f0315fc2:

    # me "Неужели вы не спрашивали о причинах расторжения брака?"
    me "难道您没问过解除婚姻的原因吗？"

# game/a13/4frozen_wheels.rpy:650
translate english frozen_wheels2_e217bfb2:

    # dubov "Боюсь обе стороны посчитали, что я не смогу решить эту проблему, еще до того, как я в ней разобрался. Требуют принять их сторону и все."
    dubov "恐怕双方都认为我无法解决这个问题，甚至在我弄清楚之前。他们要求我支持各自一方，仅此而已。"

# game/a13/4frozen_wheels.rpy:651
translate english frozen_wheels2_b9eac2ab:

    # me "Звучит как-то странно..."
    me "这听起来有点奇怪……"

# game/a13/4frozen_wheels.rpy:652
translate english frozen_wheels2_f410fd61:

    # dubov "Скорее всего они обе стороны хитрят и что-то недоговаривают."
    dubov "很可能双方都在耍花招，有所隐瞒。"

# game/a13/4frozen_wheels.rpy:653
translate english frozen_wheels2_149b3064:

    # me "В каком смысле?"
    me "什么意思？"

# game/a13/4frozen_wheels.rpy:654
translate english frozen_wheels2_5869a25b:

    # dubov "Они бы созвали вече, если бы считали себя однозначно правыми. Видимо это не так."
    dubov "要是他们觉得自己百分之百占理，早就召集民众大会了。看来并不是这样。"

# game/a13/4frozen_wheels.rpy:655
translate english frozen_wheels2_cadda22a:

    # me "Не совсем понимаю, как обе стороны могут быть неправы?"
    me "我不太理解，双方怎么都可能不对？"

# game/a13/4frozen_wheels.rpy:656
translate english frozen_wheels2_faa12c8f:

    # dubov "Разрыв брака не предполагает разрыв договора горцев перед всем Севером. Их нежелание честного суда понятно. Но Скаладан тоже не чист, раз собирает солдат и думает что война лучше, чем суд, где могут вскрыться его преступления."
    dubov "婚姻破裂并不意味着山区人对整个北方的誓约破裂。他们不愿接受公正审判可以理解。但斯卡拉丹也不干净，因为他集结士兵，认为战争比审判更好，在审判中他的罪行可能会暴露。"

# game/a13/4frozen_wheels.rpy:657
translate english frozen_wheels2_adc36abc:

    # me "Какие например?"
    me "比如什么？"

# game/a13/4frozen_wheels.rpy:658
translate english frozen_wheels2_0f646ffc:

    # dubov "Может он взял свою невесту, а позже отказался от нее. К тому же разводы в консумированом браке запрещены безымянным богом. Даже если с невестой все в порядке и брак не был консумирован могут быть другие причины."
    dubov "也许他接来了新娘，后来又拒绝了她。而且，对于已完婚的婚姻，无名之神禁止离婚。即使新娘没问题，婚姻未完婚，也可能有其他原因。"

# game/a13/4frozen_wheels.rpy:659
translate english frozen_wheels2_d4c16b87:

    # me "Могу я опять спросить какие?"
    me "我可以再问是什么原因吗？"

# game/a13/4frozen_wheels.rpy:660
translate english frozen_wheels2_d58cf149:

    # dubov "Нет смысла выдумывать и предполагать - это ты выяснишь сам."
    dubov "没有意义去编造和假设——这些你自己去弄清楚。"

# game/a13/4frozen_wheels.rpy:661
translate english frozen_wheels2_23d7ec4b:

    # me "Понятно. Но вы ведь сказали, что лордов два."
    me "明白了。但您说过有两位领主。"

# game/a13/4frozen_wheels.rpy:662
translate english frozen_wheels2_6c663160:

    # dubov "Второй это лорд Войцех. Его земля по соседствую. Он принял сторону Скаладана и пострадал так сказать 'за компанию'. Если бы не он, я бы вообще об этом не узнал."
    dubov "第二位是沃伊切赫领主。他的领地相邻。他站在斯卡拉丹一边，可以说是“受牵连”。如果不是他，我根本不会知道这事。"

# game/a13/4frozen_wheels.rpy:663
translate english frozen_wheels2_443feffe:

    # dubov "А когда попытался разобраться - столкнулся с таким сопротивлением, что диву даешься, даже захотелось дать им друг друга перебить."
    dubov "而当我试图弄清楚时——遭遇了难以置信的阻力，甚至想让他们互相残杀算了。"

# game/a13/4frozen_wheels.rpy:664
translate english frozen_wheels2_3066598f_1:

    # me "Спасибо."
    me "谢谢。"

# game/a13/4frozen_wheels.rpy:665
translate english frozen_wheels2_e8886597:

    # dubov "Не за что. Главное помни - горцы непредсказуемы. Лучше их не провоцировать, если не уверен, что сила за тобой. Если ты кончено не хочешь умереть."
    dubov "不用谢。关键是记住——山区人不可预测。如果你不确定力量在你一边，最好别挑衅他们。当然，除非你想死。"

# game/a13/4frozen_wheels.rpy:666
translate english frozen_wheels2_8eb22bc8:

    # me "Я это запомню."
    me "我会记住的。"

# game/a13/4frozen_wheels.rpy:668
translate english frozen_wheels2_b456edfe:

    # eva "{size=-4}Пап! Стойте.{/size}"
    eva "{size=-4}爸！停下。{/size}"

# game/a13/4frozen_wheels.rpy:669
translate english frozen_wheels2_b64133bf:

    # maren "{size=-4}Мой король, она отказывается дальше идти!{/size}"
    maren "{size=-4}陛下，她拒绝继续走了！{/size}"

# game/a13/4frozen_wheels.rpy:670
translate english frozen_wheels2_9d0e66ee:

    # dubov "Ну и что случилось?"
    dubov "又怎么了？"

# game/a13/4frozen_wheels.rpy:671
translate english frozen_wheels2_5faa866f:

    # maren "{size=-4}Говорит камни.{/size}"
    maren "{size=-4}她说有石头。{/size}"

# game/a13/4frozen_wheels.rpy:672
translate english frozen_wheels2_77246b0f:

    # eva "{size=-4}У меня камни набились в сапог!{/size}"
    eva "{size=-4}我靴子里进了石头！{/size}"

# game/a13/4frozen_wheels.rpy:673
translate english frozen_wheels2_101c6caf:

    # dubov "Ну так достань."
    dubov "那就拿出来。"

# game/a13/4frozen_wheels.rpy:674
translate english frozen_wheels2_7dd4c677:

    # maren "{size=-4}Я ей также сказал!{/size}"
    maren "{size=-4}我也这么告诉她！{/size}"

# game/a13/4frozen_wheels.rpy:675
translate english frozen_wheels2_9e35c151:

    # eva "{size=-4}Я не могу сама! Сапоги очень большие и неудобные.{/size}"
    eva "{size=-4}我自己不行！靴子太大，很不方便。{/size}"

# game/a13/4frozen_wheels.rpy:676
translate english frozen_wheels2_8019e74d:

    # dubov "Ты серьезно?"
    dubov "你认真的吗？"

# game/a13/4frozen_wheels.rpy:677
translate english frozen_wheels2_7373b85f:

    # maren "{size=-4}Я предложил помочь.{/size}"
    maren "{size=-4}我提议帮忙。{/size}"

# game/a13/4frozen_wheels.rpy:678
translate english frozen_wheels2_e03ede01:

    # eva "{size=-4}Я не дам трогать себя какому-то простолюдину.{/size}"
    eva "{size=-4}我不会让一个平民碰我。{/size}"

# game/a13/4frozen_wheels.rpy:679
translate english frozen_wheels2_99add484:

    # dubov "И?"
    dubov "那么？"

# game/a13/4frozen_wheels.rpy:680
translate english frozen_wheels2_536578aa:

    # eva "{size=-4}Пусть это сделает кто-то другой.{/size}"
    eva "{size=-4}让其他人来做。{/size}"

# game/a13/4frozen_wheels.rpy:681
translate english frozen_wheels2_a5f768b6:

    # dubov "Например?"
    dubov "比如说？"

# game/a13/4frozen_wheels.rpy:682
translate english frozen_wheels2_8dfe899e:

    # eva "{size=-4}Ты. Или принц [mename]. {/size}"
    eva "{size=-4}你。或者王子[mename]。 {/size}"

# game/a13/4frozen_wheels.rpy:683
translate english frozen_wheels2_7fbd29c7:

    # maren "{size=-4}Я бы мог...{/size}"
    maren "{size=-4}我可以……{/size}"

# game/a13/4frozen_wheels.rpy:684
translate english frozen_wheels2_72b14930:

    # eva "{size=-4}Я не дам этой похотливой свинье меня трогать! Ты бы видел как он на меня смотрит, пап! Как на кусок мяса.{/size}"
    eva "{size=-4}我不会让这头好色的猪碰我！您真该看看他怎么看我的，爸爸！像看块肉。{/size}"

# game/a13/4frozen_wheels.rpy:685
translate english frozen_wheels2_df0768df:

    # maren "{size=-4}Мой король, клянусь это неправда!{/size}"
    maren "{size=-4}陛下，我发誓那不是真的！{/size}"

# game/a13/4frozen_wheels.rpy:686
translate english frozen_wheels2_4a51f4ee:

    # eva "{size=-4}Мне кто-нибудь поможет или нет?{/size}"
    eva "{size=-4}到底有没有人帮我？{/size}"

# game/a13/4frozen_wheels.rpy:687
translate english frozen_wheels2_108575c0:

    # dubov "О, боже...."
    dubov "哦，天哪……"

# game/a13/4frozen_wheels.rpy:688
translate english frozen_wheels2_a95c103d:

    # me "Я помогу."
    me "我来帮。"

# game/a13/4frozen_wheels.rpy:689
translate english frozen_wheels2_9f722822:

    # dubov "Благодарю, [mename]."
    dubov "谢谢，[mename]。"

# game/a13/4frozen_wheels.rpy:691
translate english frozen_wheels2_0bb1bf3f:

    # eva "Спасибо, что пришли на помощь девушке в беде, принц [mename]."
    eva "谢谢您来帮遇险的少女，王子[mename]。"

# game/a13/4frozen_wheels.rpy:692
translate english frozen_wheels2_5ae39da8:

    # me "Угум. В чем дело?"
    me "嗯。怎么了？"

# game/a13/4frozen_wheels.rpy:693
translate english frozen_wheels2_a3d23f40:

    # eva "Я же говорю - камень."
    eva "我说了——石头。"

# game/a13/4frozen_wheels.rpy:694
translate english frozen_wheels2_1d49b48f:

    # me "Камень."
    me "石头。"

# game/a13/4frozen_wheels.rpy:695
translate english frozen_wheels2_97f43a40:

    # eva "Угу."
    eva "嗯。"

# game/a13/4frozen_wheels.rpy:696
translate english frozen_wheels2_ea7f8842:

    # me "И как он попал в такой высокий сапог?"
    me "它怎么进这么高的靴子里？"

# game/a13/4frozen_wheels.rpy:697
translate english frozen_wheels2_e17788ee:

    # eva "Наверное залетел между завязками."
    eva "大概是顺着系带掉进去的。"

# game/a13/4frozen_wheels.rpy:698
translate english frozen_wheels2_3820771a_2:

    # me "..."
    me "..."

# game/a13/4frozen_wheels.rpy:699
translate english frozen_wheels2_53352fc0:

    # eva "..."
    eva "..."

# game/a13/4frozen_wheels.rpy:700
translate english frozen_wheels2_01822020:

    # me "Ладно."
    me "好吧。"

# game/a13/4frozen_wheels.rpy:702
translate english frozen_wheels2_8b1f9d6b:

    # me "И в какой ноге?"
    me "哪只脚？"

# game/a13/4frozen_wheels.rpy:703
translate english frozen_wheels2_439d3064:

    # eva "В правой."
    eva "右脚。"

# game/a13/4frozen_wheels.rpy:704
translate english frozen_wheels2_654d9da7:

    # me "Мне помочь тебе снять его?"
    me "要我帮你脱靴子吗？"

# game/a13/4frozen_wheels.rpy:705
translate english frozen_wheels2_6ed83434:

    # eva "Нет. С ума сошел? Это же очень долго."
    eva "不。你疯了吗？那太费时间了。"

# game/a13/4frozen_wheels.rpy:706
translate english frozen_wheels2_e97c3069:

    # me "И каким же образом мне тогда тебе помочь?"
    me "那我怎么帮你呢？"

# game/a13/4frozen_wheels.rpy:707
translate english frozen_wheels2_d1947afa:

    # eva "Ну..."
    eva "嗯……"

# game/a13/4frozen_wheels.rpy:708
translate english frozen_wheels2_4d012c4a:

    # me "Придется снимать."
    me "只能脱了。"

# game/a13/4frozen_wheels.rpy:709
translate english frozen_wheels2_98cc10f4:

    # eva "Нет... я и не уверена, что это камень."
    eva "不……而且我不确定是不是石头。"

# game/a13/4frozen_wheels.rpy:710
translate english frozen_wheels2_2d42945b:

    # me "Ага."
    me "哦。"

