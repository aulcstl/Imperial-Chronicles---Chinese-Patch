# TODO: Translation updated at 2026-03-19 16:03

# game/a13/4frozen_wheels.rpy:3
translate english frozen_wheels_0f476a5d:

    # "Чуть позже."
    "过了一会。"

# game/a13/4frozen_wheels.rpy:4
translate english frozen_wheels_72a1feb5:

    # me "{i}Так... в библиотеке ее нет.{/i}"
    me "{i}那么……图书馆里没有她。{/i}"

# game/a13/4frozen_wheels.rpy:5
translate english frozen_wheels_7e169cfc:

    # me "{i}Значит она в саду.{/i}"
    me "{i}那她就是在花园里。{/i}"

# game/a13/4frozen_wheels.rpy:6
translate english frozen_wheels_c43cdb22:

    # me "{i}Знать бы где здесь сад...{/i}"
    me "{i}要是知道花园在哪儿就好了……{/i}"

# game/a13/4frozen_wheels.rpy:7
translate english frozen_wheels_ddc6606b:

    # slug "Вам помочь, принц?"
    slug "需要帮助吗，王子？"

# game/a13/4frozen_wheels.rpy:8
translate english frozen_wheels_fd134636:

    # me "Где здесь замковый сад?"
    me "这里的城堡花园在哪儿？"

# game/a13/4frozen_wheels.rpy:9
translate english frozen_wheels_180b6dac:

    # slug "Их тут несколько."
    slug "这儿有好几个。"

# game/a13/4frozen_wheels.rpy:10
translate english frozen_wheels_c8b98c1d:

    # me "Меня интересует тот, в котором отдыхает дочь твоего короля."
    me "我感兴趣的是你们国王女儿休息的那个花园。"

# game/a13/4frozen_wheels.rpy:11
translate english frozen_wheels_1580a351:

    # slug "Лиза?"
    slug "Lisa？"

# game/a13/4frozen_wheels.rpy:12
translate english frozen_wheels_8c275c00:

    # me "Да. Она самая."
    me "对，就是她。"

# game/a13/4frozen_wheels.rpy:13
translate english frozen_wheels_85efa29d:

    # slug "Я проведу вас."
    slug "我带您去。"

# game/a13/4frozen_wheels.rpy:14
translate english frozen_wheels_3066598f:

    # me "Спасибо."
    me "谢谢。"

# game/a13/4frozen_wheels.rpy:16
translate english frozen_wheels_8f676dcc:

    # me "{i}Ага. Вот и она.{/i}"
    me "{i}啊哈。她就在那儿。{/i}"

# game/a13/4frozen_wheels.rpy:17
translate english frozen_wheels_b6f6122f:

    # me "{i}Надо же... похожа на Аврору гораздо больше, чем на Еву.{/i}"
    me "{i}真是……她长得更像Aurora，而不是Eva。{/i}"

# game/a13/4frozen_wheels.rpy:18
translate english frozen_wheels_bfea69ce:

    # me "{i}В кресле с колесами. Интересный механизм.{/i}"
    me "{i}坐在轮椅上。有趣的装置。{/i}"

# game/a13/4frozen_wheels.rpy:19
translate english frozen_wheels_9cc9f75b:

    # me "{i}Родись она крестьянкой никто не стал бы заморачиваться с методом ее передвижения.{/i}"
    me "{i}如果她生为农妇，没人会费心考虑她的移动方式。{/i}"

# game/a13/4frozen_wheels.rpy:20
translate english frozen_wheels_6c99d59d:

    # me "{i}Хотя не будь она дворянкой, скорее всего уже была бы мертва.{/i}"
    me "{i}不过如果她不是贵族，很可能早就死了。{/i}"

# game/a13/4frozen_wheels.rpy:21
translate english frozen_wheels_c7ac6a68:

    # me "{i}Простолюдины детей с такими проблемами оставляют в лесу. Взрослые вынуждены работать теми частями тела, что у них еще не сломаны.{/i}"
    me "{i}平民会把有这种问题的孩子留在森林里。成年人得用他们尚未损坏的身体部位工作。{/i}"

# game/a13/4frozen_wheels.rpy:22
translate english frozen_wheels_e0be43db:

    # me "{i}Так что можно сказать ей еще повезло.{/i}"
    me "{i}所以可以说她还算幸运。{/i}"

# game/a13/4frozen_wheels.rpy:23
translate english frozen_wheels_7dfbcafd:

    # me "{i}Если это конечно вообще можно назвать везением.{/i}"
    me "{i}当然，如果这也能称得上幸运的话。{/i}"

# game/a13/4frozen_wheels.rpy:24
translate english frozen_wheels_77973413:

    # me "{i}Ладно. Пора поздороваться и представиться.{/i}"
    me "{i}好吧。该打招呼并自我介绍了。{/i}"

# game/a13/4frozen_wheels.rpy:26
translate english frozen_wheels_3872d073:

    # me "Пр..."
    me "您……"

# game/a13/4frozen_wheels.rpy:27
translate english frozen_wheels_6680d6f8:

    # lisa "Рано."
    lisa "太早了。"

# game/a13/4frozen_wheels.rpy:28
translate english frozen_wheels_b6626098:

    # me "А?"
    me "啊？"

# game/a13/4frozen_wheels.rpy:29
translate english frozen_wheels_d5fb7cad:

    # lisa "Рано. Я еще не дочитала, что хотела. Подойди через час."
    lisa "太早了。我还没读完想读的部分。过一小时再来。"

# game/a13/4frozen_wheels.rpy:30
translate english frozen_wheels_c2306c6b:

    # me "Вы меня с кем-то перепутали."
    me "您把我和谁搞混了。"

# game/a13/4frozen_wheels.rpy:31
translate english frozen_wheels_7d28e415:

    # lisa "Ох... прошу прощения. Я думала это слуга захотел затащить меня обратно в замок."
    lisa "哦……请原谅。我以为又是仆人想把我拖回城堡。"

# game/a13/4frozen_wheels.rpy:32
translate english frozen_wheels_680fd3d6:

    # me "Я не слуга."
    me "我不是仆人。"

# game/a13/4frozen_wheels.rpy:33
translate english frozen_wheels_2de441a5:

    # lisa "Я уже поняла."
    lisa "我已经明白了。"

# game/a13/4frozen_wheels.rpy:34
translate english frozen_wheels_e05490a1:

    # me "Меня зовут..."
    me "我叫……"

# game/a13/4frozen_wheels.rpy:35
translate english frozen_wheels_42cd521f:

    # lisa "Постойте. Не говорите."
    lisa "等等。别说。"

# game/a13/4frozen_wheels.rpy:36
translate english frozen_wheels_b6626098_1:

    # me "А?"
    me "啊？"

# game/a13/4frozen_wheels.rpy:37
translate english frozen_wheels_96d7d90a:

    # lisa "Позвольте мне небольшое развлечение. Хочу угадать."
    lisa "请让我稍微娱乐一下。我想猜一猜。"

# game/a13/4frozen_wheels.rpy:38
translate english frozen_wheels_8f9071f9:

    # me "Конечно."
    me "当然。"

# game/a13/4frozen_wheels.rpy:40
translate english frozen_wheels_30f90a43:

    # lisa "Судя по волосам и ушам вы гибрид. Полуэльф."
    lisa "从您的头发和耳朵来看，您是混血儿。半精灵。"

# game/a13/4frozen_wheels.rpy:41
translate english frozen_wheels_eb0d474a:

    # me "Верно."
    me "没错。"

# game/a13/4frozen_wheels.rpy:42
translate english frozen_wheels_b1dbe19c:

    # lisa "Вы знатных кровей или по крайней мере богаты."
    lisa "您出身贵族，或者至少富有。"

# game/a13/4frozen_wheels.rpy:43
translate english frozen_wheels_d2af3887:

    # me "С чего вы взяли?"
    me "您为什么这么想？"

# game/a13/4frozen_wheels.rpy:44
translate english frozen_wheels_9581edee:

    # lisa "Вы хотели представиться, значит у вас есть имя которое что-то значит."
    lisa "您想自我介绍，说明您有一个有份量的名字。"

# game/a13/4frozen_wheels.rpy:45
translate english frozen_wheels_f8a27582:

    # me "Только у знати и богачей могут быть имена достойные быть услышанными."
    me "只有贵族和富人才有值得被听到的名字。"

# game/a13/4frozen_wheels.rpy:46
translate english frozen_wheels_eb7228c6:

    # lisa "Почти всегда да. Иногда у врачей, художников и музыкантов."
    lisa "几乎总是这样。有时医生、艺术家和音乐家也有。"

# game/a13/4frozen_wheels.rpy:47
translate english frozen_wheels_e6755e95:

    # me "Может я художник."
    me "也许我是个艺术家。"

# game/a13/4frozen_wheels.rpy:48
translate english frozen_wheels_33dd952d:

    # lisa "Да ну. И где ваши кисти и мольберт? К тому же для художника у вас слишком чистые руки."
    lisa "得了吧。您的画笔和画架在哪儿？而且，作为艺术家，您的手太干净了。"

# game/a13/4frozen_wheels.rpy:49
translate english frozen_wheels_e281b9b6:

    # me "Врач."
    me "医生。"

# game/a13/4frozen_wheels.rpy:50
translate english frozen_wheels_9f3e5ed1:

    # lisa "Вы слишком молоды для врача."
    lisa "您太年轻了，当不了医生。"

# game/a13/4frozen_wheels.rpy:51
translate english frozen_wheels_79bab281:

    # me "Я учусь."
    me "我在学习。"

# game/a13/4frozen_wheels.rpy:52
translate english frozen_wheels_d8b866d0:

    # lisa "Тогда вы бы были со своим мастером."
    lisa "那您应该和您的老师在一起。"

# game/a13/4frozen_wheels.rpy:53
translate english frozen_wheels_54c6469a:

    # me "Ладно. Допустим вы пока на правильном пути."
    me "好吧。暂时假设您走对了路。"

# game/a13/4frozen_wheels.rpy:54
translate english frozen_wheels_d585767c:

    # lisa "Вы не с Севера."
    lisa "您不是北方人。"

# game/a13/4frozen_wheels.rpy:55
translate english frozen_wheels_5ac38cf1:

    # me "Почему?"
    me "为什么？"

# game/a13/4frozen_wheels.rpy:56
translate english frozen_wheels_480f385d:

    # lisa "Дворяне с Севера общаются с моим отцом и уезжают, никто из них не стал бы посещать меня тем более один."
    lisa "北方的贵族们与我父亲交谈后就离开了，他们中没人会来拜访我，更不会独自一人。"

# game/a13/4frozen_wheels.rpy:58
translate english frozen_wheels_b3e7f9ea:

    # lisa "Вы принц-регент [mename] из Золотой Столицы."
    lisa "您是来自黄金之都的摄政王[mename]。"

# game/a13/4frozen_wheels.rpy:59
translate english frozen_wheels_fda8b26c:

    # me "...верно."
    me "……没错。"

# game/a13/4frozen_wheels.rpy:60
translate english frozen_wheels_e6109e18:

    # lisa "Игра была неинтересной. Слишком просто."
    lisa "这个游戏没意思。太简单了。"

# game/a13/4frozen_wheels.rpy:61
translate english frozen_wheels_dacad09d:

    # me "Потому что ваш собирался со мной встретится?"
    me "是因为您父亲打算和我见面吗？"

# game/a13/4frozen_wheels.rpy:62
translate english frozen_wheels_a84131e5:

    # lisa "Отец не посвящает меня в свои планы и встречи. Это было легко, потому что на континенте не так много полуэльфов-дворян."
    lisa "父亲不会让我参与他的计划和会面。这很简单，因为大陆上没有几个半精灵贵族。"

# game/a13/4frozen_wheels.rpy:63
translate english frozen_wheels_ab96ee34:

    # me "Книги помогли вам меня узнать?"
    me "是书本帮助您认出我的吗？"

# game/a13/4frozen_wheels.rpy:64
translate english frozen_wheels_34abc2f1:

    # lisa "Вы слишком молоды и слишком живы, чтобы о вас писали книги. Даже если бы такие и были они попали бы в нашу библиотеку лет через сто."
    lisa "您太年轻，也太活生生，还没有关于您的书。即使有，也要过一百年才会进入我们的图书馆。"

# game/a13/4frozen_wheels.rpy:65
translate english frozen_wheels_026e35a2:

    # me "Но вы обо мне знаете."
    me "但您知道我的事。"

# game/a13/4frozen_wheels.rpy:66
translate english frozen_wheels_1541016a:

    # lisa "Это слишком доступная информация. Я не могу ходить, а не разговаривать и слушать. Естественно я знаю, кто правит соседними королевствами."
    lisa "这是太容易获取的信息。我不能走路，但能说话和倾听。我当然知道谁统治着邻近的王国。"

# game/a13/4frozen_wheels.rpy:67
translate english frozen_wheels_8c53d918:

    # me "Я не правлю. Регентство больше не требуется."
    me "我不统治。摄政已经不再需要了。"

# game/a13/4frozen_wheels.rpy:68
translate english frozen_wheels_4ab35362:

    # lisa "Ваш отец выздоровел?"
    lisa "您的父亲康复了吗？"

# game/a13/4frozen_wheels.rpy:69
translate english frozen_wheels_fb5c1d2f:

    # me "Можно и так сказать. Мыслит он уже довольно ясно."
    me "可以这么说。他的思维现在已经相当清晰了。"

# game/a13/4frozen_wheels.rpy:70
translate english frozen_wheels_c56593bb:

    # lisa "Ясно. Видимо в положении не сильно лучше моего."
    lisa "明白了。看来他的状况并不比我的好多少。"

# game/a13/4frozen_wheels.rpy:73
translate english frozen_wheels_497ac9ee:

    # me "Я тоже могу о вас кое-что сказать. Эту книгу вы читали уже много раз."
    me "我也可以说说您的一点事。这本书您已经读过很多遍了。"

# game/a13/4frozen_wheels.rpy:74
translate english frozen_wheels_1c1b76d7:

    # lisa "С чего вы взяли?"
    lisa "为什么这么想？"

# game/a13/4frozen_wheels.rpy:75
translate english frozen_wheels_78939830:

    # me "Отбеленная бумага, при этом страницы не пожелтели от старости, но страницы довольно затерты. Значит книга довольно новая, но ее уже много раз читали."
    me "纸张漂白过，而且书页没有因年代而变黄，但页面却被磨损得相当厉害。所以这本书相当新，但已经被阅读了很多次。"

# game/a13/4frozen_wheels.rpy:76
translate english frozen_wheels_8b630143:

    # lisa "Может ее читала не только я."
    lisa "也许不是我一个人读过。"

# game/a13/4frozen_wheels.rpy:77
translate english frozen_wheels_756e3908:

    # me "Может быть. Но есть и другие признаки. Вы быстро бегаете глазами по странице и перелистываете их, хотя ведете разговор во время чтения."
    me "可能。但还有其他迹象。您的目光在书页上移动得很快，翻页也很快，尽管您一边谈话一边阅读。"

# game/a13/4frozen_wheels.rpy:78
translate english frozen_wheels_76f77068:

    # lisa "Может я просто изображаю. Многие используют книгу как атрибут для своей публичной персоны - демонстрируют что они заняты чем-то... умным."
    lisa "也许我只是在装样子。很多人把书当作公众形象的道具——展示他们在忙一些……聪明事。"

# game/a13/4frozen_wheels.rpy:79
translate english frozen_wheels_7afb6087:

    # me "Такое бывает, но вы читали эту книгу и до моего прихода. Сомневаюсь, что кто-то хвастается чтением наедине с самим собой."
    me "有这种情况，但在我到来之前您就已经在读了。我怀疑有人会在独处时炫耀阅读。"

# game/a13/4frozen_wheels.rpy:80
translate english frozen_wheels_9fd82ce0:

    # lisa "Ну... это все равно не доказывает, что я уже читала эту книгу. Может я просто быстро это делаю."
    lisa "嗯……这仍然不能证明我已经读过这本书。也许我只是读得很快。"

# game/a13/4frozen_wheels.rpy:81
translate english frozen_wheels_0fdb47b0:

    # me "Быстро читаете?"
    me "您读得很快？"

# game/a13/4frozen_wheels.rpy:82
translate english frozen_wheels_061bfce4:

    # lisa "Ну да."
    lisa "嗯，是的。"

# game/a13/4frozen_wheels.rpy:83
translate english frozen_wheels_438a9d48:

    # me "Хорошо. Тогда последний аргумент в пользу моей теории."
    me "好吧。那么，我最后一个支持我理论的论据。"

# game/a13/4frozen_wheels.rpy:84
translate english frozen_wheels_62af32ca:

    # lisa "Давайте."
    lisa "请说。"

# game/a13/4frozen_wheels.rpy:85
translate english frozen_wheels_bb1951b6:

    # me "Вы читали эту книгу много раз и вам жаль что она приходит в негодность, поэтому вы надели перчатку, чтобы перелистывать страницы в ней."
    me "您读过这本书很多次，您心疼它被损坏，所以戴上手套来翻页。"

# game/a13/4frozen_wheels.rpy:86
translate english frozen_wheels_7fa35a3f:

    # lisa "..."
    lisa "..."

# game/a13/4frozen_wheels.rpy:87
translate english frozen_wheels_7418365e:

    # me "Ну? Я угадал или нет?"
    me "怎么样？我猜对了吗？"

# game/a13/4frozen_wheels.rpy:88
translate english frozen_wheels_c5e435c3:

    # lisa "Мне жаль почти все книги."
    lisa "我心疼几乎所有的书。"

# game/a13/4frozen_wheels.rpy:89
translate english frozen_wheels_80a112b4:

    # me "Выходит я ошибся."
    me "看来我错了。"

# game/a13/4frozen_wheels.rpy:90
translate english frozen_wheels_bed2af15:

    # lisa "Нет. Вы были правы. Я уже читала эту книгу, хотя почти все ваши рассуждения были мимо."
    lisa "不。您是对的。我已经读过这本书，尽管您几乎所有的推理都不对路。"

# game/a13/4frozen_wheels.rpy:91
translate english frozen_wheels_26561f4f:

    # me "Эх..."
    me "唉……"

# game/a13/4frozen_wheels.rpy:92
translate english frozen_wheels_6ce5826a:

    # lisa "Но мне они понравились. Так рассуждать может только тот, кто сам любит читать."
    lisa "但我喜欢它们。只有自己爱读书的人才会这样推理。"

# game/a13/4frozen_wheels.rpy:94
translate english frozen_wheels_09e052df:

    # eva "Что делаете, голубки?"
    eva "在做什么呢，小鸽子们？"

# game/a13/4frozen_wheels.rpy:95
translate english frozen_wheels_698b2d34:

    # lisa "Ева."
    lisa "Eva。"

# game/a13/4frozen_wheels.rpy:96
translate english frozen_wheels_c7d493bb:

    # me "Разве ты не должна быть в башне?"
    me "你不是该在塔楼里吗？"

# game/a13/4frozen_wheels.rpy:97
translate english frozen_wheels_c20cdb42:

    # eva "Окна моей башни как выходят на этот сад."
    eva "我的塔楼窗户正好对着这个花园。"

# game/a13/4frozen_wheels.rpy:98
translate english frozen_wheels_ddbc2562:

    # lisa "Я так понимаю ее снова наказали за что-то."
    lisa "我看她又被为某事惩罚了。"

# game/a13/4frozen_wheels.rpy:99
translate english frozen_wheels_38c39b7c:

    # me "Вроде того."
    me "差不多吧。"

# game/a13/4frozen_wheels.rpy:100
translate english frozen_wheels_d739daed:

    # lisa "И что же тогда ты тут делаешь?"
    lisa "那你在这儿做什么？"

# game/a13/4frozen_wheels.rpy:101
translate english frozen_wheels_7b0cecb7:

    # eva "Вышла подышать свежим воздухом. Не могу же я вечно сидеть взаперти."
    eva "出来呼吸新鲜空气。我可不能永远被关着。"

# game/a13/4frozen_wheels.rpy:102
translate english frozen_wheels_6be1392a:

    # lisa "В этом и смысл наказания."
    lisa "惩罚的意义就在于此。"

# game/a13/4frozen_wheels.rpy:103
translate english frozen_wheels_6a5cc7ee:

    # eva "А я все еще наказана. Просто сказала слуге, что от стен башни мне дурно. Он отпустил меня на пару минут."
    eva "可我还是在受罚。只是对仆人说塔楼的墙壁让我难受。他就放我出来几分钟。"

# game/a13/4frozen_wheels.rpy:104
translate english frozen_wheels_ffc51265:

    # me "Понятно."
    me "明白了。"

# game/a13/4frozen_wheels.rpy:105
translate english frozen_wheels_3d3cfb67:

    # eva "Что? Я вам помешала?"
    eva "怎么？我打扰你们了吗？"

# game/a13/4frozen_wheels.rpy:106
translate english frozen_wheels_fe65cdbb:

    # lisa "Можешь не спрашивать о таком, мешать и раздражать это твое постоянное свойство."
    lisa "你就不用问这种问题了，打扰和惹人烦是你一贯的特性。"

# game/a13/4frozen_wheels.rpy:107
translate english frozen_wheels_a893bae2:

    # eva "Я могу уйти."
    eva "我可以走。"

# game/a13/4frozen_wheels.rpy:108
translate english frozen_wheels_921f30d6:

    # lisa "Но не уйдешь."
    lisa "但你不会走。"

# game/a13/4frozen_wheels.rpy:109
translate english frozen_wheels_0e087194:

    # eva "Только если кто-то из вас пожалуется отцу."
    eva "除非你们谁去向父亲告状。"

# game/a13/4frozen_wheels.rpy:110
translate english frozen_wheels_7fa35a3f_1:

    # lisa "..."
    lisa "..."

# game/a13/4frozen_wheels.rpy:111
translate english frozen_wheels_3820771a:

    # me "..."
    me "..."

# game/a13/4frozen_wheels.rpy:112
translate english frozen_wheels_c86b1bbd:

    # eva "Вот и отлично."
    eva "那太好了。"

# game/a13/4frozen_wheels.rpy:113
translate english frozen_wheels_f6191274:

    # lisa "Он все равно узнает."
    lisa "他反正也会知道。"

# game/a13/4frozen_wheels.rpy:114
translate english frozen_wheels_feb25bd2:

    # eva "Да он и не хотел отправлять меня сюда, принц [mename] вовсе на меня не злится, верно?"
    eva "他本来就不想送我去那儿，王子[mename]一点也不生我的气，对吧？"

# game/a13/4frozen_wheels.rpy:115
translate english frozen_wheels_5a7a7577:

    # me "Нет."
    me "对。"

# game/a13/4frozen_wheels.rpy:116
translate english frozen_wheels_d5732d65:

    # lisa "И что она сделала?"
    lisa "她做了什么？"

# game/a13/4frozen_wheels.rpy:117
translate english frozen_wheels_e44d537c:

    # me "Да так... небольшая шутка с гардеробом и изобразительным искусством."
    me "就是……一个关于衣柜和绘画艺术的小玩笑。"

# game/a13/4frozen_wheels.rpy:118
translate english frozen_wheels_0c6f3a69:

    # eva "Понравилось?"
    eva "您喜欢吗？"

# game/a13/4frozen_wheels.rpy:119
translate english frozen_wheels_9a93aa34:

    # lisa "Лучше не говорите ей да."
    lisa "最好别对她说喜欢。"

# game/a13/4frozen_wheels.rpy:120
translate english frozen_wheels_5ac38cf1_1:

    # me "Почему?"
    me "为什么？"

# game/a13/4frozen_wheels.rpy:121
translate english frozen_wheels_ea33d3f3:

    # lisa "Она примет это как вызов и утром вы проснетесь от улья пчел под одеялом."
    lisa "她会把这当成挑战，然后早上您会在被窝里发现一窝蜜蜂。"

# game/a13/4frozen_wheels.rpy:122
translate english frozen_wheels_38024186:

    # eva "Не слушайте ее, принц [mename], она скучная, потому что калека."
    eva "别听她的，王子[mename]，她很无聊，因为她是残废。"

# game/a13/4frozen_wheels.rpy:123
translate english frozen_wheels_ffbed5a6:

    # me "Кхм-кхм."
    me "咳咳。"

# game/a13/4frozen_wheels.rpy:125
translate english frozen_wheels_eaae9e89:

    # eva "О чем вы тут щебетали?"
    eva "你们刚才在叽叽喳喳说什么？"

# game/a13/4frozen_wheels.rpy:126
translate english frozen_wheels_97c95162:

    # lisa "Ни о чем. Мы только познакомились."
    lisa "没说什么。我们刚认识。"

# game/a13/4frozen_wheels.rpy:127
translate english frozen_wheels_69928b9d:

    # eva "И?"
    eva "然后呢？"

# game/a13/4frozen_wheels.rpy:128
translate english frozen_wheels_be32b5f7:

    # lisa "Что 'и'?"
    lisa "什么“然后”？"

# game/a13/4frozen_wheels.rpy:129
translate english frozen_wheels_7b319aef:

    # eva "Вы понравились друг другу? Была искра?"
    eva "你们互相喜欢吗？有火花吗？"

# game/a13/4frozen_wheels.rpy:130
translate english frozen_wheels_829693b6:

    # lisa "Во что ты одета?"
    lisa "你穿的这是什么？"

# game/a13/4frozen_wheels.rpy:131
translate english frozen_wheels_157ce539:

    # eva "Не меняй тему разговора."
    eva "别转移话题。"

# game/a13/4frozen_wheels.rpy:132
translate english frozen_wheels_6eb0e603:

    # lisa "Отец выпорет тебя, если увидит в этом."
    lisa "父亲要是看见你穿这个，会抽你鞭子的。"

# game/a13/4frozen_wheels.rpy:133
translate english frozen_wheels_9629eb62:

    # eva "Он такой уставший в последнее время, может меня накажет принц?"
    eva "他最近那么疲惫，也许王子会惩罚我？"

# game/a13/4frozen_wheels.rpy:134
translate english frozen_wheels_6446c03d:

    # me "Почему-то у меня ощущение, что ты и не была ни в какой башне."
    me "不知道为什么，我感觉你根本就没被关在塔楼里。"

# game/a13/4frozen_wheels.rpy:135
translate english frozen_wheels_897073ab:

    # lisa "Ощущение? Если бы слуги ее увидели в этом, тут же доложили бы отцу или матери. Не было ее ни в какой башне."
    lisa "感觉？如果仆人们看到她穿成这样，立刻就会报告给父亲或母亲。她根本没在塔楼。"

# game/a13/4frozen_wheels.rpy:136
translate english frozen_wheels_0b90a3b3:

    # eva "Мне надо было забрать пару вещей по пути."
    eva "我在路上得拿几样东西。"

# game/a13/4frozen_wheels.rpy:137
translate english frozen_wheels_9ca417da:

    # lisa "Судя по длине твоей юбки это были ножницы."
    lisa "从你裙子的长度来看，那些东西是剪刀。"

# game/a13/4frozen_wheels.rpy:138
translate english frozen_wheels_8e8186c8:

    # eva "Мне нравится подчеркивать красоту моих ног. Они у меня такие длинные и... я могу ходить на них куда захочу, понимаешь? Ой... Прости. Совсем забыла, что у тебя не так."
    eva "我喜欢突出我双腿的美。它们这么长，而且……我能用它们走到任何我想去的地方，明白吗？哎呀……对不起。完全忘了你不这样。"

# game/a13/4frozen_wheels.rpy:139
translate english frozen_wheels_5d082c96:

    # lisa "Мгм."
    lisa "嗯。"

# game/a13/4frozen_wheels.rpy:140
translate english frozen_wheels_6a1c9fd0:

    # eva "Я вовсе не хотела тебя обидеть."
    eva "我根本没想伤害你。"

# game/a13/4frozen_wheels.rpy:141
translate english frozen_wheels_470a5096:

    # lisa "Ну разумеется."
    lisa "当然啦。"

# game/a13/4frozen_wheels.rpy:143
translate english frozen_wheels_e9a97fca:

    # eva "Что читаешь?"
    eva "你在读什么？"

# game/a13/4frozen_wheels.rpy:144
translate english frozen_wheels_9c21cce7:

    # lisa "Не твоего ума дело."
    lisa "这不关你的事。"

# game/a13/4frozen_wheels.rpy:145
translate english frozen_wheels_421bcc3b:

    # eva "Ты обиделась из-за того что я напомнила тебе, что ты калека?"
    eva "你生气是因为我提醒你你是残废吗？"

# game/a13/4frozen_wheels.rpy:146
translate english frozen_wheels_9c65f2d6:

    # lisa "Нет. Просто сомневаюсь что ты умеешь читать."
    lisa "不。我只是怀疑你会不会阅读。"

# game/a13/4frozen_wheels.rpy:147
translate english frozen_wheels_b77a237e:

    # eva "Зря ты так. Я может и немного книг прочитала, но все интересные."
    eva "你这就错了。我可能读的书不多，但都很有趣。"

# game/a13/4frozen_wheels.rpy:148
translate english frozen_wheels_0b71a361:

    # lisa "Какие книги ты читала? Самоучитель по несносному поведению? Или научный трактат 'как эффективно позориться при гостях'?"
    lisa "你读过哪些书？《让人无法忍受的行为自学手册》？还是科学论文《如何在客人面前有效出丑》？"

# game/a13/4frozen_wheels.rpy:149
translate english frozen_wheels_69f5723f:

    # eva "Нет. Всякие девчачьи книжки. Ну там про прекрасных принцев, свадьбы, путешествия. Ну знаешь... все что ждет полноценную принцессу, способную выйти замуж."
    eva "不是。各种女孩子读的书。就是关于英俊王子、婚礼、旅行那种。你知道的……所有那些等待着能够出嫁的健全公主的一切。"

# game/a13/4frozen_wheels.rpy:150
translate english frozen_wheels_186b83b5:

    # lisa "Удачи в путешествии, надеюсь оно будет как можно быстрее и на как можно дольше."
    lisa "祝你旅途愉快，但愿它越快越好，越久越好。"

# game/a13/4frozen_wheels.rpy:151
translate english frozen_wheels_7cb65cba:

    # eva "Ты будешь скучать по мне больше всех, когда какой-нибудь прекрасный принц заберет меня к себе."
    eva "你会比任何人都想念我，当某个英俊的王子把我带走的时候。"

# game/a13/4frozen_wheels.rpy:152
translate english frozen_wheels_20930613:

    # lisa "Ни один прекрасный принц никогда не станет с тобой жить, тебя нужно женить на горном тролле. И то, я не уверена, что через месяц он не принесет тебя обратно."
    lisa "任何英俊的王子都不会愿意和你一起生活，你得嫁给山妖。而且，我都不敢保证一个月后他不会把你送回来。"

# game/a13/4frozen_wheels.rpy:153
translate english frozen_wheels_acf5a5a9:

    # eva "Принесет? Я могу сама прийти. У меня же..."
    eva "送回来？我可以自己走回来。要知道我……"

# game/a13/4frozen_wheels.rpy:154
translate english frozen_wheels_2a71caf6:

    # lisa "...ноги ходят. Да. Да. Месяц много. Даю троллю неделю."
    lisa "……有腿能走。对。对。一个月太长了。我给那山妖一周。"

# game/a13/4frozen_wheels.rpy:156
translate english frozen_wheels_814c89af:

    # me "Я смотрю у вас воистинну сестринские отношения."
    me "我看你们这真是姐妹情深。"

# game/a13/4frozen_wheels.rpy:157
translate english frozen_wheels_cf195ad3:

    # eva "На самом деле она меня любит."
    eva "其实她是爱我的。"

# game/a13/4frozen_wheels.rpy:158
translate english frozen_wheels_4f0e6bbd:

    # lisa "Обожаю."
    lisa "我爱极了。"

# game/a13/4frozen_wheels.rpy:159
translate english frozen_wheels_f8f71c84:

    # eva "И я ее! Искренне! Она совершенно меня не ценит."
    eva "我也是！真诚地！她完全不珍惜我。"

# game/a13/4frozen_wheels.rpy:160
translate english frozen_wheels_2317b2a1:

    # me "Есть за что?"
    me "有值得珍惜的地方吗？"

# game/a13/4frozen_wheels.rpy:161
translate english frozen_wheels_ed5cf190:

    # eva "Конечно. Ее никто не любит за то что она калека. И по правде говоря... характер у нее скверный."
    eva "当然。没人喜欢她，因为她是残废。而且说实话……她的性格很糟糕。"

# game/a13/4frozen_wheels.rpy:162
translate english frozen_wheels_7fa35a3f_2:

    # lisa "..."
    lisa "..."

# game/a13/4frozen_wheels.rpy:163
translate english frozen_wheels_6758dc3b:

    # me "Да ну..."
    me "得了吧……"

# game/a13/4frozen_wheels.rpy:164
translate english frozen_wheels_38c2e35d:

    # eva "Да. С ней никто не хочет общаться, поэтому она и сидит тут одна целыми днями."
    eva "是的。没人想和她交往，所以她整天一个人坐在这儿。"

# game/a13/4frozen_wheels.rpy:165
translate english frozen_wheels_080a9f11:

    # lisa "К сожалению не одна. Меня очень часто... слишком часто навещает любимая сестра."
    lisa "可惜不是一个人。我亲爱的姐姐非常经常……过于经常地来探望我。"

# game/a13/4frozen_wheels.rpy:166
translate english frozen_wheels_019c12ce:

    # eva "Аврора здесь больше не живет, можешь на нее не ругаться."
    eva "Aurora不住这儿了，你可以不骂她了。"

# game/a13/4frozen_wheels.rpy:167
translate english frozen_wheels_7fa35a3f_3:

    # lisa "..."
    lisa "..."

# game/a13/4frozen_wheels.rpy:168
translate english frozen_wheels_4b9fac89:

    # eva "Лизе она почему-то не нравится."
    eva "Lisa不知为什么不喜欢她。"

# game/a13/4frozen_wheels.rpy:171
translate english frozen_wheels_0e614352:

    # eva "Знаешь, я только сейчас поняла, что если бы ты не была калекой, то была бы женой принца вместо Авроры."
    eva "你知道吗，我刚刚才想到，如果你不是残废，你就会代替Aurora成为王子的妻子。"

# game/a13/4frozen_wheels.rpy:172
translate english frozen_wheels_eb384cdc:

    # lisa "Потрясающе. И что?"
    lisa "真了不起。那又怎样？"

# game/a13/4frozen_wheels.rpy:173
translate english frozen_wheels_68dbce94:

    # eva "Просто забавно да? Ты бы сейчас была его женой, у вас был бы ребенок."
    eva "只是很有趣，对吧？你现在就是他的妻子，你们会有个孩子。"

# game/a13/4frozen_wheels.rpy:174
translate english frozen_wheels_a65b6abd:

    # lisa "Хватит болтать чепуху."
    lisa "别胡说八道了。"

# game/a13/4frozen_wheels.rpy:175
translate english frozen_wheels_b4632080:

    # eva "А что? Ты старшая дочь. Именно так бы и было. Или ты думаешь принц отказался бы на тебе женится?"
    eva "怎么？你是长女。本来就会是这样。还是你觉得王子会拒绝娶你？"

# game/a13/4frozen_wheels.rpy:176
translate english frozen_wheels_5eb29a97:

    # lisa "Понятия не имею."
    lisa "我没概念。"

# game/a13/4frozen_wheels.rpy:177
translate english frozen_wheels_c86633a8:

    # eva "Думаешь ты слишком старая или уродливая для него?"
    eva "你认为你对他来说太老或太丑？"

# game/a13/4frozen_wheels.rpy:178
translate english frozen_wheels_b8e3cb1d:

    # lisa "Заткнись."
    lisa "闭嘴。"

# game/a13/4frozen_wheels.rpy:179
translate english frozen_wheels_12aeb698:

    # eva "Да ладно тебе, Аврора тоже не красавица, думаю он выбрал ее не за это."
    eva "得了，Aurora也不是美人，我想他选她不是为了这个。"

# game/a13/4frozen_wheels.rpy:180
translate english frozen_wheels_20dcdfd4:

    # lisa "Ты прекратишь или нет?"
    lisa "你停不停？"

# game/a13/4frozen_wheels.rpy:181
translate english frozen_wheels_f61b1165:

    # eva "Точно, можешь спросить у него. Принц, [mename], если бы моя сестра не была калекой, вы бы взяли ее в жены, сделали ей ребеночка?"
    eva "对了，你可以问他。王子，[mename]，如果我姐姐不是残废，您会娶她为妻，给她一个孩子吗？"

# game/a13/4frozen_wheels.rpy:182
translate english frozen_wheels_6c48c770:

    # lisa "Ева..."
    lisa "Eva……"

# game/a13/4frozen_wheels.rpy:183
translate english frozen_wheels_51ede3d9:

    # me "Кстати насчет твоего наказания в башне..."
    me "顺便，关于你的塔楼惩罚……"

# game/a13/4frozen_wheels.rpy:184
translate english frozen_wheels_04d53bf3:

    # eva "Согласна. Глупая тема. Забудем."
    eva "我同意。愚蠢的话题。我们把它忘了吧。"

# game/a13/4frozen_wheels.rpy:185
translate english frozen_wheels_7fa35a3f_4:

    # lisa "..."
    lisa "..."

# game/a13/4frozen_wheels.rpy:187
translate english frozen_wheels_41a8cedd:

    # eva "Вы к нам надолго?"
    eva "您在这儿要待很久吗？"

# game/a13/4frozen_wheels.rpy:188
translate english frozen_wheels_f5bc88ca:

    # me "На пару дней точно."
    me "肯定要待几天。"

# game/a13/4frozen_wheels.rpy:189
translate english frozen_wheels_0d61a43a:

    # eva "Почему так мало?"
    eva "为什么这么短？"

# game/a13/4frozen_wheels.rpy:190
translate english frozen_wheels_248c1a76:

    # lisa "Удивительно что он еще тут, после знакомства с тобой."
    lisa "认识你之后，他竟然还能待在这儿，真是不可思议。"

# game/a13/4frozen_wheels.rpy:191
translate english frozen_wheels_10e49c52:

    # me "У меня есть... дела на Севере."
    me "我在……北方有事。"

# game/a13/4frozen_wheels.rpy:192
translate english frozen_wheels_e83967b7:

    # eva "Мы прямо сейчас на Севере."
    eva "我们现在就是在北方。"

# game/a13/4frozen_wheels.rpy:193
translate english frozen_wheels_3b0d6a62:

    # me "На другом Севере."
    me "另一个北方。"

# game/a13/4frozen_wheels.rpy:194
translate english frozen_wheels_1e9c6bc6:

    # eva "С другими лордами? Вы затеваете бунт против моего отца, принц [mename]?"
    eva "和别的领主？您要密谋反对我父亲吗，王子[mename]？"

# game/a13/4frozen_wheels.rpy:195
translate english frozen_wheels_0dce5b59:

    # lisa "О, боже, Ева, закрой рот."
    lisa "哦，天哪，Eva，闭嘴。"

# game/a13/4frozen_wheels.rpy:196
translate english frozen_wheels_dceaf9a5:

    # me "Нет. Скорее наоборот."
    me "不。更可能是相反。"

# game/a13/4frozen_wheels.rpy:197
translate english frozen_wheels_3415ee99:

    # eva "Это как?"
    eva "这怎么说？"

# game/a13/4frozen_wheels.rpy:198
translate english frozen_wheels_e9f3f765:

    # me "Долго объяснять."
    me "解释起来就长了。"

# game/a13/4frozen_wheels.rpy:199
translate english frozen_wheels_c8431de2:

    # eva "Так вы ему будете помогать?"
    eva "所以您是要帮助他？"

# game/a13/4frozen_wheels.rpy:200
translate english frozen_wheels_d08241f0:

    # lisa "Вы можете ей не отвечать."
    lisa "您不必回答她。"

# game/a13/4frozen_wheels.rpy:201
translate english frozen_wheels_b1b0208c:

    # me "Я расскажу когда вернусь."
    me "我回来后会告诉你们。"

# game/a13/4frozen_wheels.rpy:202
translate english frozen_wheels_59017ae1:

    # eva "Очень интересно. Возьмете меня с собой?"
    eva "很有趣。您会带上我吗？"

# game/a13/4frozen_wheels.rpy:203
translate english frozen_wheels_58f0b5e4:

    # lisa "О, это отличная идея. Никто не будет задавать вопросов, если она потеряется по пути, уверяю вас."
    lisa "哦，这真是个好主意。我向您保证，如果她在路上走丢了，没有人会有疑问。"

# game/a13/4frozen_wheels.rpy:204
translate english frozen_wheels_2d9ad498:

    # me "Не могу. Это поездка не для принцессы."
    me "不行。这不是适合公主的旅行。"

# game/a13/4frozen_wheels.rpy:205
translate english frozen_wheels_ccabdfb1:

    # eva "А хотели бы?"
    eva "那您会想带上我吗？"

# game/a13/4frozen_wheels.rpy:206
translate english frozen_wheels_7200aeda:

    # lisa "Боже, Ева..."
    lisa "天哪，Eva……"

# game/a13/4frozen_wheels.rpy:208
translate english frozen_wheels_8044f440:

    # eva "Я бы могла помочь вам."
    eva "我可以帮助您。"

# game/a13/4frozen_wheels.rpy:209
translate english frozen_wheels_4b307147:

    # me "Мне? Помочь с чем?"
    me "我？帮什么？"

# game/a13/4frozen_wheels.rpy:210
translate english frozen_wheels_c4222a2f:

    # eva "Оказать дипломатическое давление."
    eva "施加外交压力。"

# game/a13/4frozen_wheels.rpy:211
translate english frozen_wheels_dd7074ce:

    # me "На кого?"
    me "对谁？"

# game/a13/4frozen_wheels.rpy:212
translate english frozen_wheels_24f0aa66:

    # eva "На кого угодно. Я дочь короля Севера."
    eva "对谁都行。我是北方国王的女儿。"

# game/a13/4frozen_wheels.rpy:213
translate english frozen_wheels_64d1d537:

    # me "Боюсь самому королю Севера эта идея не понравится."
    me "恐怕北方国王本人不会喜欢这个主意。"

# game/a13/4frozen_wheels.rpy:214
translate english frozen_wheels_b7e96b1f:

    # eva "А вам?"
    eva "那您呢？"

# game/a13/4frozen_wheels.rpy:215
translate english frozen_wheels_887889bb:

    # me "Мне?"
    me "我？"

# game/a13/4frozen_wheels.rpy:216
translate english frozen_wheels_2d2f6fbf:

    # eva "Ну да. Вы бы взяли меня с собой? Если бы отец был не против?"
    eva "嗯，对。如果我父亲不反对，您会带上我吗？"

# game/a13/4frozen_wheels.rpy:217
translate english frozen_wheels_ab5edf7a:

    # me "А зачем мне с собой сумасбродная принцесса?"
    me "我要一个疯癫的公主干什么？"

# game/a13/4frozen_wheels.rpy:218
translate english frozen_wheels_ba4255aa:

    # eva "Ну, во-первых, я очень красива!"
    eva "嗯，首先，我很漂亮！"

# game/a13/4frozen_wheels.rpy:219
translate english frozen_wheels_36690370:

    # me "Для длительного перехода это скорее минус."
    me "对于长途跋涉来说，这更是个缺点。"

# game/a13/4frozen_wheels.rpy:220
translate english frozen_wheels_a96632b9:

    # eva "Почему? Вы боитесь, что не сможете держать себя в руках, принц?"
    eva "为什么？您怕您会控制不住自己吗，王子？"

# game/a13/4frozen_wheels.rpy:221
translate english frozen_wheels_ccf76a33:

    # me "На караваны с молодыми женщинами нападают куда чаще. А с принцессами, за которых можно стребовать выкуп и подавно."
    me "带着年轻女子的商队更容易被袭击。而带着可以勒索赎金的公主，更是如此。"

# game/a13/4frozen_wheels.rpy:222
translate english frozen_wheels_52534ba4:

    # eva "Ох, жаль. Я очень давно хотела с кем-нибудь попутешествовать. Принц для этого идеальная кандидатура."
    eva "哦，真遗憾。我很早就想和什么人一起旅行了。王子是完美的候选人。"

# game/a13/4frozen_wheels.rpy:223
translate english frozen_wheels_d041e90b:

    # lisa "Чем больше вы будете ей отвечать, тем больше она будет нести чушь."
    lisa "您越是回答她，她就越会说胡话。"

# game/a13/4frozen_wheels.rpy:224
translate english frozen_wheels_9c80feda:

    # eva "Это моя мечта с самого детства. Я и принц с далекого королевства. Вместе. Путешествуем. Вместе спим в одном шатре..."
    eva "这是我从小的梦想。我和来自遥远王国的王子。一起。旅行。一起睡在同一个帐篷里……"

# game/a13/4frozen_wheels.rpy:226
translate english frozen_wheels_56d38bf9:

    # eva "Вместе преодолеваем все дорожные трудности. Вместе радуемся первому снегу. Целуемся."
    eva "一起克服路途上的所有困难。一起为初雪欢喜。接吻。"

# game/a13/4frozen_wheels.rpy:227
translate english frozen_wheels_60358084:

    # me "Эм..."
    me "呃……"

# game/a13/4frozen_wheels.rpy:228
translate english frozen_wheels_de89e00a:

    # eva "Простите, принц, замечталась, забыла что вы уже женаты."
    eva "对不起，王子，我做起梦来，忘了您已经结婚了。"

# game/a13/4frozen_wheels.rpy:229
translate english frozen_wheels_3820771a_1:

    # me "..."
    me "..."

# game/a13/4frozen_wheels.rpy:230
translate english frozen_wheels_8d274fc5:

    # eva "Хотя у королей и принцев часто бывают любовницы, верно?"
    eva "虽然国王和王子们经常有情人，对吧？"

# game/a13/4frozen_wheels.rpy:231
translate english frozen_wheels_f9e15667:

    # me "Любовницы."
    me "情人。"

# game/a13/4frozen_wheels.rpy:232
translate english frozen_wheels_89e51d83:

    # eva "Ну да. Я бы подошла на роль любовницы? Мне кажется, что подошла бы. Я умею хранить секреты плюс я очень красивая."
    eva "嗯，对啊。我会适合做情人吗？我觉得我会适合。我会保守秘密，而且我很漂亮。"

# game/a13/4frozen_wheels.rpy:233
translate english frozen_wheels_4d892136:

    # me "Даже спорить не буду."
    me "我甚至不想争论。"

# game/a13/4frozen_wheels.rpy:234
translate english frozen_wheels_c60df0cc:

    # eva "Я бы не очень хотела. Быть официальной женой гораздо лучше."
    eva "我可不太愿意。做正妻要好得多。"

# game/a13/4frozen_wheels.rpy:235
translate english frozen_wheels_3dbd674e:

    # me "Разумеется."
    me "当然。"

# game/a13/4frozen_wheels.rpy:236
translate english frozen_wheels_6b908046:

    # eva "Может мне пока подождать? Вдруг место освободится?"
    eva "也许我该等一等？万一位置空出来呢？"

# game/a13/4frozen_wheels.rpy:237
translate english frozen_wheels_e826e36e:

    # lisa "Я разрешаю вам ее ударить."
    lisa "我允许您打她。"

# game/a13/4frozen_wheels.rpy:240
translate english frozen_wheels_46dd4f78:

    # aurora "Вот вы где."
    aurora "你们在这儿啊。"

# game/a13/4frozen_wheels.rpy:241
translate english frozen_wheels_11cf1ba6:

    # eva "А вот и жена!"
    eva "啊，妻子来了！"

# game/a13/4frozen_wheels.rpy:242
translate english frozen_wheels_1637c255:

    # aurora "Простите, заговорились с матушкой."
    aurora "对不起，和母亲谈久了。"

# game/a13/4frozen_wheels.rpy:243
translate english frozen_wheels_313678dd:

    # me "Все нормально. Мы тут пока общались."
    me "没关系。我们刚才在聊天。"

# game/a13/4frozen_wheels.rpy:244
translate english frozen_wheels_72f2a925:

    # eva "Ага. И без тебя было весело."
    eva "嗯。你不在也挺开心的。"

# game/a13/4frozen_wheels.rpy:245
translate english frozen_wheels_5d92b9fe:

    # lisa "Аврора."
    lisa "Aurora。"

# game/a13/4frozen_wheels.rpy:246
translate english frozen_wheels_a2f8f1ae:

    # aurora "Лиза!"
    aurora "Lisa！"

# game/a13/4frozen_wheels.rpy:248
translate english frozen_wheels_d7aa55d7:

    # aurora "Рада снова видеть тебя, сестренка."
    aurora "很高兴再次见到你，妹妹。"

# game/a13/4frozen_wheels.rpy:249
translate english frozen_wheels_83d0ecb5:

    # lisa "И я."
    lisa "我也是。"

# game/a13/4frozen_wheels.rpy:250
translate english frozen_wheels_5054148c:

    # eva "Какие они милые да?"
    eva "她们多可爱啊，是不是？"

# game/a13/4frozen_wheels.rpy:251
translate english frozen_wheels_8613242c:

    # me "Угу."
    me "嗯。"

# game/a13/4frozen_wheels.rpy:252
translate english frozen_wheels_3baa7ce1:

    # eva "Жаль они обе не калеки, тогда это было бы еще трогательней..."
    eva "可惜她们俩不都是残废，不然就更感人了……"

# game/a13/4frozen_wheels.rpy:253
translate english frozen_wheels_e036a3ca:

    # lisa "Как ты?"
    lisa "你怎么样？"

# game/a13/4frozen_wheels.rpy:254
translate english frozen_wheels_3ffc3b78:

    # aurora "Я в порядке. Как ты?"
    aurora "我很好。你呢？"

# game/a13/4frozen_wheels.rpy:255
translate english frozen_wheels_e7a15114:

    # lisa "Как обычно. Все еще живу лучшую жизнь."
    lisa "和往常一样。仍然过着最棒的生活。"

# game/a13/4frozen_wheels.rpy:256
translate english frozen_wheels_3e849480:

    # aurora "Я привезла тебе книг."
    aurora "我给你带了些书。"

# game/a13/4frozen_wheels.rpy:257
translate english frozen_wheels_14bc5aa4:

    # lisa "Спасибо."
    lisa "谢谢。"

# game/a13/4frozen_wheels.rpy:258
translate english frozen_wheels_4a6371bd:

    # eva "Лучше бы привезла ей новые ноги."
    eva "还不如给她带双新腿。"

# game/a13/4frozen_wheels.rpy:259
translate english frozen_wheels_ed5eb339:

    # aurora "Ева..."
    aurora "Eva……"

# game/a13/4frozen_wheels.rpy:260
translate english frozen_wheels_0100b07e:

    # eva "Что?"
    eva "怎么？"

# game/a13/4frozen_wheels.rpy:262
translate english frozen_wheels_cbb4c8cb:

    # aurora "Что на тебе надето?"
    aurora "你穿的这是什么？"

# game/a13/4frozen_wheels.rpy:263
translate english frozen_wheels_bb3f8c0b:

    # eva "Нравится?"
    eva "喜欢吗？"

# game/a13/4frozen_wheels.rpy:264
translate english frozen_wheels_271acf3d:

    # aurora "Ну..."
    aurora "嗯……"

# game/a13/4frozen_wheels.rpy:265
translate english frozen_wheels_ae670872:

    # eva "Юбку укорачивала и подшивала сама."
    eva "裙子是我自己裁短缝边的。"

# game/a13/4frozen_wheels.rpy:266
translate english frozen_wheels_66cc1496:

    # aurora "В этом я как раз не сомневаюсь."
    aurora "这个我毫不怀疑。"

# game/a13/4frozen_wheels.rpy:267
translate english frozen_wheels_dd9d8b9a:

    # eva "Подчеркивает мои длинные ноги."
    eva "突显我的长腿。"

# game/a13/4frozen_wheels.rpy:268
translate english frozen_wheels_16288f62:

    # aurora "Если мать или отец тебя в этом увидят?"
    aurora "如果母亲或父亲看到你这样穿呢？"

# game/a13/4frozen_wheels.rpy:269
translate english frozen_wheels_752166a4:

    # eva "Я не буду попадаться им на глаза."
    eva "我不会让他们看见的。"

# game/a13/4frozen_wheels.rpy:270
translate english frozen_wheels_5ba36b6c:

    # aurora "А слуги?"
    aurora "那仆人们呢？"

# game/a13/4frozen_wheels.rpy:271
translate english frozen_wheels_c72ac948:

    # eva "Это только для вас. Вернусь в башню и переоденусь."
    eva "这只是为你们穿的。我回塔楼就换掉。"

# game/a13/4frozen_wheels.rpy:272
translate english frozen_wheels_6218e9c8:

    # aurora "Лучше поторопись."
    aurora "你最好快点。"

# game/a13/4frozen_wheels.rpy:273
translate english frozen_wheels_ca1b7b0b:

    # eva "Что? Совсем не нравится?"
    eva "怎么？完全不喜欢吗？"

# game/a13/4frozen_wheels.rpy:274
translate english frozen_wheels_b8024155:

    # aurora "Нравится... но это слишком откровенно."
    aurora "喜欢……但太暴露了。"

# game/a13/4frozen_wheels.rpy:276
translate english frozen_wheels_d26fd500:

    # eva "А твоему мужу понравилось."
    eva "可你丈夫喜欢。"

# game/a13/4frozen_wheels.rpy:277
translate english frozen_wheels_d2e5535d:

    # aurora "Правда?"
    aurora "真的吗？"

# game/a13/4frozen_wheels.rpy:278
translate english frozen_wheels_77d2745c:

    # me "Я этого не говорил."
    me "我可没这么说。"

# game/a13/4frozen_wheels.rpy:279
translate english frozen_wheels_e58dab30:

    # eva "Словами не говорил, но глаза от моих ног не отрывал."
    eva "嘴里是没说，但眼睛一直没离开我的腿。"

# game/a13/4frozen_wheels.rpy:280
translate english frozen_wheels_bcc3ecd9:

    # aurora "Эм..."
    aurora "呃……"

# game/a13/4frozen_wheels.rpy:281
translate english frozen_wheels_c9b3650d:

    # me "Понятия не имею о чем она говорит."
    me "我完全不知道她在说什么。"

# game/a13/4frozen_wheels.rpy:282
translate english frozen_wheels_ee1b3541:

    # eva "Смотрел-смотрел, правда-правда!"
    eva "他看了，一直看着，真的真的！"

# game/a13/4frozen_wheels.rpy:283
translate english frozen_wheels_855ec402:

    # lisa "Никуда он не смотрел. Не слушай ее чушь."
    lisa "他哪儿也没看。别听她胡说。"

# game/a13/4frozen_wheels.rpy:284
translate english frozen_wheels_6808df08:

    # aurora "Разве ты не должна быть в башне?"
    aurora "你不是该在塔楼里吗？"

# game/a13/4frozen_wheels.rpy:285
translate english frozen_wheels_42c298b8:

    # me "Должна."
    me "是该在。"

# game/a13/4frozen_wheels.rpy:286
translate english frozen_wheels_f323ac41:

    # eva "Вы меня выгоняете?"
    eva "你们在赶我走吗？"

# game/a13/4frozen_wheels.rpy:287
translate english frozen_wheels_0f8c69f1:

    # aurora "Она здесь давно с вами?"
    aurora "她跟你们在这儿很久了？"

# game/a13/4frozen_wheels.rpy:288
translate english frozen_wheels_36bd7def:

    # me "Почти с самого начала."
    me "几乎从一开始就在。"

# game/a13/4frozen_wheels.rpy:289
translate english frozen_wheels_52b89f52:

    # eva "Вау. Он такой твердый. Столько мышц. Его так приятно обнимать, сестренка, я тебе завидую!"
    eva "哇。他好结实。这么多肌肉。抱着他真舒服，姐姐，我羡慕你！"

# game/a13/4frozen_wheels.rpy:290
translate english frozen_wheels_6f1f10d2:

    # aurora "[mename]..."
    aurora "[mename]..."

# game/a13/4frozen_wheels.rpy:291
translate english frozen_wheels_1c5115d3:

    # me "Пойду отдохну."
    me "我要去休息了。"

# game/a13/4frozen_wheels.rpy:292
translate english frozen_wheels_cd617d3f:

    # eva "Стойте! Давайте еще поговорим! Можешь обнять меня, если хочешь!"
    eva "等等！我们再聊聊！你想的话可以抱抱我！"

# game/a13/4frozen_wheels.rpy:294
translate english frozen_wheels_cf14e261:

    # aurora "Ева. Не провоцируй меня и моего мужа."
    aurora "Eva。别挑衅我和我丈夫。"

# game/a13/4frozen_wheels.rpy:295
translate english frozen_wheels_2d0c35e7:

    # eva "Я просто пытаюсь быть дружелюбной!"
    eva "我只是想表示友好！"

# game/a13/4frozen_wheels.rpy:296
translate english frozen_wheels_2ca15575:

    # lisa "Она стала гораздо хуже с твоего отъезда, Аврора."
    lisa "Aurora，你离开后她变得更糟了。"

# game/a13/4frozen_wheels.rpy:297
translate english frozen_wheels_7d2f2ef0:

    # aurora "Просто не делай так, ладно?"
    aurora "只是别这样，好吗？"

# game/a13/4frozen_wheels.rpy:298
translate english frozen_wheels_3791439a:

    # eva "Я просто проверяю его и все."
    eva "我只是在考验他罢了。"

# game/a13/4frozen_wheels.rpy:299
translate english frozen_wheels_ef04069e:

    # aurora "Проверяешь?"
    aurora "考验？"

# game/a13/4frozen_wheels.rpy:300
translate english frozen_wheels_e028c47f:

    # eva "Ну... верен он тебе или нет! Он и вправду никуда не смотрел. Значит ценит семью и любовь к тебе."
    eva "嗯……考验他对你是否忠诚！他真的哪儿也没看。说明他珍惜家庭和对你的爱。"

# game/a13/4frozen_wheels.rpy:301
translate english frozen_wheels_3ce8f0eb:

    # aurora "Не надо ничего... проверять. Веди себя нормально."
    aurora "不用……考验什么。表现得正常点。"

# game/a13/4frozen_wheels.rpy:302
translate english frozen_wheels_196d2ac8:

    # eva "Ну ладно. Как будто я сделала что-то ужасное. Подумаешь надела короткую юбку."
    eva "好吧。好像我做了什么可怕的事。只不过穿了条短裙。"

# game/a13/4frozen_wheels.rpy:303
translate english frozen_wheels_ce744693:

    # lisa "Ух... не могу это слушать."
    lisa "呃……我听不下去了。"

# game/a13/4frozen_wheels.rpy:304
translate english frozen_wheels_ed5eb339_1:

    # aurora "Ева..."
    aurora "Eva……"

# game/a13/4frozen_wheels.rpy:305
translate english frozen_wheels_92ff2560:

    # eva "Это ты жена принца и путешествуешь по королевствам. Мне тут скучно. Что такого что я немного забавляюсь?"
    eva "你是王子之妻，在王国间旅行。我在这儿无聊。我稍微找点乐子又怎么了？"

# game/a13/4frozen_wheels.rpy:306
translate english frozen_wheels_1e22d3c1:

    # aurora "Немного ты уже позабавилась. Картин и нарядов было достаточно, ясно?"
    aurora "你已稍微找了不少乐子。画和衣服已经够多了，清楚吗？"

# game/a13/4frozen_wheels.rpy:307
translate english frozen_wheels_19b9287d:

    # eva "Ясно, ясно."
    eva "清楚，清楚。"

# game/a13/4frozen_wheels.rpy:308
translate english frozen_wheels_178cb2f9:

    # aurora "Пообещай вести себя нормально."
    aurora "保证你会正常点。"

# game/a13/4frozen_wheels.rpy:309
translate english frozen_wheels_0791a254:

    # eva "Обещаю."
    eva "我保证。"

# game/a13/4frozen_wheels.rpy:310
translate english frozen_wheels_a57903e8:

    # lisa "Она забудет об этом через пять минут."
    lisa "她五分钟后就会忘掉。"

# game/a13/4frozen_wheels.rpy:311
translate english frozen_wheels_6382af61:

    # aurora "Я сильно расстроюсь, если ты не сдержишь слово."
    aurora "如果你食言，我会非常伤心。"

# game/a13/4frozen_wheels.rpy:312
translate english frozen_wheels_08736020:

    # eva "Я очень сильно постараюсь."
    eva "我会非常努力。"

# game/a13/4frozen_wheels.rpy:315
translate english frozen_wheels_dd2ea153:

    # me "Мне пора."
    me "我得走了。"

# game/a13/4frozen_wheels.rpy:316
translate english frozen_wheels_84806b45:

    # eva "Принц, постойте, не уходите."
    eva "王子，等等，别走。"

# game/a13/4frozen_wheels.rpy:317
translate english frozen_wheels_7be323ad:

    # lisa "Давно было пора."
    lisa "早该走了。"

# game/a13/4frozen_wheels.rpy:319
translate english frozen_wheels_2b31428a:

    # eva "Это из-за тебя."
    eva "这都因为你。"

# game/a13/4frozen_wheels.rpy:320
translate english frozen_wheels_b22210c1:

    # lisa "Из-за меня?"
    lisa "因为我？"

# game/a13/4frozen_wheels.rpy:321
translate english frozen_wheels_cdc710c3:

    # eva "Да. Сидишь тут, стреляешь глазками. Флиртуешь."
    eva "是啊。坐在这儿，乱抛媚眼。在调情。"

# game/a13/4frozen_wheels.rpy:322
translate english frozen_wheels_9ad4b818:

    # lisa "Я флиртую?"
    lisa "我在调情？"

# game/a13/4frozen_wheels.rpy:323
translate english frozen_wheels_e07c054c:

    # eva "Ну да. Он женат, а ты калека, смирись, он не будет твоим."
    eva "嗯，对。他已经结婚了，而你是残废，认命吧，他不会成为你的。"

# game/a13/4frozen_wheels.rpy:324
translate english frozen_wheels_5840b5dd:

    # lisa "Что ты... что за чушь ты вечно мелешь?"
    lisa "你在说什么……你总是在胡扯些什么？"

# game/a13/4frozen_wheels.rpy:325
translate english frozen_wheels_4fd8e36b:

    # eva "Ой, не делай вид, что не понимаешь о чем. У тебя живот видно, шлюха. Можно подумать ты обнажалась не чтобы его подразнить."
    eva "噢，别装听不懂。你的肚子都露出来了，荡妇。好像你露肉不是为了勾引他似的。"

# game/a13/4frozen_wheels.rpy:326
translate english frozen_wheels_7fa35a3f_5:

    # lisa "..."
    lisa "..."

# game/a13/4frozen_wheels.rpy:327
translate english frozen_wheels_e7495238:

    # lisa "В такие моменты я действительно жалею, что я калека. Очень хотелось бы встать, ударить тебя, и уйти."
    lisa "这种时候我真的遗憾自己是残废。真想站起来，给你一拳，然后走开。"

# game/a13/4frozen_wheels.rpy:328
translate english frozen_wheels_383d0da1:

    # eva "Я шучу просто так. Расслабься."
    eva "我只是开玩笑。放松。"

# game/a13/4frozen_wheels.rpy:329
translate english frozen_wheels_cd492f2d:

    # lisa "Смешно. Каждый раз. День за днем, месяц за месяцем и год за годом. Жить с тобой в одном замке одно удовольствие."
    lisa "真好笑。每次都是。日复一日，月复一月，年复一年。和你同住一个城堡真是享受。"

# game/a13/4frozen_wheels.rpy:330
translate english frozen_wheels_d9269caf:

    # eva "Как думаешь, если бы послали не Аврору, а меня, он бы взял меня в жены?"
    eva "你觉得，如果当初派去联姻的不是Aurora，而是我，他会娶我吗？"

# game/a13/4frozen_wheels.rpy:331
translate english frozen_wheels_114be554:

    # lisa "Жаль так не произошло. Ты бы избавила нас от своего присутствия, а он бы задушил тебя через две недели брака."
    lisa "真可惜没这样。那样你就能让我们摆脱你，而他也只会在婚后两周把你掐死。"

# game/a13/4frozen_wheels.rpy:332
translate english frozen_wheels_55136a07:

    # eva "Две недели? В два раза больше, чем у горного троля."
    eva "两周？比山妖多了一倍。"

# game/a13/4frozen_wheels.rpy:333
translate english frozen_wheels_6234fa2b:

    # lisa "Он показался мне терпеливым к твоим выходкам, но я уверена это потому что ты не показала ему и половины твоих прекрасных сторон."
    lisa "他看起来对你的胡闹很有耐心，但我确信那是因为你还没向他展示你美好的一半。"

# game/a13/4frozen_wheels.rpy:334
translate english frozen_wheels_f6a8de11:

    # eva "Хех..."
    eva "嘿……"

# game/a13/4frozen_wheels.rpy:335
translate english frozen_wheels_5b01d0db:

    # lisa "Позови слугу."
    lisa "叫个仆人来。"

# game/a13/4frozen_wheels.rpy:336
translate english frozen_wheels_4631466c:

    # eva "Я могу довезти тебя и сама, сестренка."
    eva "我可以自己推你回去，姐姐。"

# game/a13/4frozen_wheels.rpy:337
translate english frozen_wheels_3a3059b2:

    # lisa "Нет, спасибо, не хочу упасть со стены еще раз."
    lisa "不，谢谢，不想再从墙上摔下去。"

# game/a13/4frozen_wheels.rpy:341
translate english frozen_wheels2_ad5efb6c:

    # "На следующий день."
    "第二天。"

# game/a13/4frozen_wheels.rpy:342
translate english frozen_wheels2_aa8753c7:

    # me "{i}Обеденный сон был ошибкой. Теперь у меня голова болит.{/i}"
    me "{i}午睡是个错误。现在我头疼。{/i}"

# game/a13/4frozen_wheels.rpy:343
translate english frozen_wheels2_44a9aedf:

    # me "{i}И ночью я не усну. А что делать ночью в замке?{/i}"
    me "{i}而且晚上我也睡不着。在城堡里晚上能做什么？{/i}"

# game/a13/4frozen_wheels.rpy:344
translate english frozen_wheels2_d170ef7b:

    # me "{i}Разве что читать книги. Интересно будет ли Лиза в это время в библиотеке?{/i}"
    me "{i}也许只能读书。不知道Lisa这个时候会不会在图书馆？{/i}"

# game/a13/4frozen_wheels.rpy:345
translate english frozen_wheels2_d8a31190:

    # me "{i}Надеюсь они не закрывают кухню на ночь.{/i}"
    me "{i}希望他们晚上不关厨房。{/i}"

# game/a13/4frozen_wheels.rpy:346
translate english frozen_wheels2_02a810a5:

    # me "{i}Хотя... строгий режим сна мне сейчас ни к чему. Через пару дней все равно нужно будет отправляться в путь.{/i}"
    me "{i}不过……现在我也不需要严格的睡眠作息。过几天就得出发上路了。{/i}"

# game/a13/4frozen_wheels.rpy:347
translate english frozen_wheels2_c1030943:

    # me "{i}Еще и шея затекла...{/i}"
    me "{i}脖子也僵了……{/i}"

# game/a13/4frozen_wheels.rpy:350
translate english frozen_wheels2_3d9ac205:

    # cass "Ну ты долго еще будешь приходить в себя?"
    cass "你还要清醒多久？"

# game/a13/4frozen_wheels.rpy:351
translate english frozen_wheels2_8060495e:

    # me "Ты и так меня разбудила, дай хоть пару минут позевать и размять кости."
    me "你已经把我吵醒了，至少给我几分钟打哈欠、舒展下骨头。"

# game/a13/4frozen_wheels.rpy:352
translate english frozen_wheels2_82bcab77:

    # cass "Разомни кость в языке и достаточно, я пришла просто поговорить."
    cass "舒展下你骨子里的舌头就够了，我来只是说说话。"

# game/a13/4frozen_wheels.rpy:353
translate english frozen_wheels2_74c20ff1:

    # me "О чем?"
    me "谈什么？"

# game/a13/4frozen_wheels.rpy:354
translate english frozen_wheels2_38ec854d:

    # cass "Ты мне скажи о чем. Ты говорил с Дубовицким?"
    cass "你该告诉我谈什么。你和Dubovitsky谈过了？"

# game/a13/4frozen_wheels.rpy:355
translate english frozen_wheels2_9615e2e7:

    # me "Говорил."
    me "谈过了。"

# game/a13/4frozen_wheels.rpy:356
translate english frozen_wheels2_00c05ea5:

    # cass "Ну и?"
    cass "那么？"

# game/a13/4frozen_wheels.rpy:357
translate english frozen_wheels2_bd81661a:

    # me "У него ко мне предложение. Он хочет чтобы я разрешил проблему с горцами. Они заняли земли двух лордов. Это такой тест на достойного правителя."
    me "他向我提了个建议。他想让我解决山区人的问题。他们占领了两个领主的土地。这是对一位合格统治者的考验。"

# game/a13/4frozen_wheels.rpy:358
translate english frozen_wheels2_9cd64045:

    # cass "И что будет если ты его пройдешь?"
    cass "如果你通过了呢？"

# game/a13/4frozen_wheels.rpy:359
translate english frozen_wheels2_4efef15b:

    # me "Он согласен на широкую автономию в составе Империи."
    me "他同意在帝国内享有广泛自治。"

# game/a13/4frozen_wheels.rpy:360
translate english frozen_wheels2_df5f3cdb:

    # cass "Он давал тебе какие-то гарантии?"
    cass "他给了你什么保证吗？"

# game/a13/4frozen_wheels.rpy:361
translate english frozen_wheels2_9bf9679c:

    # me "А какие он мог дать гарантии? Он просто пообещал."
    me "他能给什么保证？他只是答应了。"

# game/a13/4frozen_wheels.rpy:362
translate english frozen_wheels2_4d90f10e:

    # cass "Ясно."
    cass "明白了。"

# game/a13/4frozen_wheels.rpy:363
translate english frozen_wheels2_903c4f2d:

    # me "Думаешь он дурит меня?"
    me "你觉得他在耍我吗？"

# game/a13/4frozen_wheels.rpy:364
translate english frozen_wheels2_8004c545:

    # cass "Не знаю. Но его власть здесь несомненна. Я обошла замок, мои люди побродили по Хельвику."
    cass "不知道。但他在这里的权力是毋庸置疑的。我巡视了城堡，我的人在Helvik附近转了转。"

# game/a13/4frozen_wheels.rpy:365
translate english frozen_wheels2_f95c9fc9:

    # me "И?"
    me "然后呢？"

# game/a13/4frozen_wheels.rpy:366
translate english frozen_wheels2_dc1897f5:

    # cass "Здесь нам точно ничего не светит. Так что его предложение это в любом случае хороший вариант."
    cass "这里我们绝对没戏。所以他的提议无论如何都是个好选择。"

# game/a13/4frozen_wheels.rpy:367
translate english frozen_wheels2_0f6941af:

    # me "Среди горцев и недовольных вассалов есть за что зацепиться."
    me "在山区人和不满的封臣之间有可乘之机。"

# game/a13/4frozen_wheels.rpy:368
translate english frozen_wheels2_419c7df2:

    # cass "Ты правильно уловил мысль."
    cass "你抓住了要点。"

# game/a13/4frozen_wheels.rpy:369
translate english frozen_wheels2_e0d20c84:

    # me "Но двух лордов будет маловато."
    me "但两个领主还是太少了。"

# game/a13/4frozen_wheels.rpy:370
translate english frozen_wheels2_5de68ed3:

    # cass "Горцев тоже будет маловато. Мы пока только ищем слабые точки."
    cass "山区人也太少了。我们暂时只是在寻找弱点。"

# game/a13/4frozen_wheels.rpy:371
translate english frozen_wheels2_4ea499aa:

    # me "Пока мы даже не уверены, что хаос нам будем выгоден."
    me "我们甚至还不确定混乱是否对我们有利。"

# game/a13/4frozen_wheels.rpy:372
translate english frozen_wheels2_8fbf9d40:

    # cass "Верно, братишка."
    cass "没错，弟弟。"

# game/a13/4frozen_wheels.rpy:373
translate english frozen_wheels2_1277f62a:

    # me "Выходит нужно отправляться туда."
    me "看来必须去那里。"

# game/a13/4frozen_wheels.rpy:374
translate english frozen_wheels2_28978917:

    # cass "Ты готов?"
    cass "你准备好了？"

# game/a13/4frozen_wheels.rpy:375
translate english frozen_wheels2_8f9071f9:

    # me "Конечно."
    me "当然。"

# game/a13/4frozen_wheels.rpy:376
translate english frozen_wheels2_da2bbf19:

    # cass "Дождись остальных людей с кораблей и отправишься в путь. "
    cass "等船上的其他人到齐，你就出发。"

# game/a13/4frozen_wheels.rpy:377
translate english frozen_wheels2_b78c6e26:

    # me "А ты?"
    me "你呢？"

# game/a13/4frozen_wheels.rpy:378
translate english frozen_wheels2_7a65d2ad:

    # cass "Скажешь когда будешь готов и я опережу тебя на один, разведаю путь. Встретимся у лорда Украдского."
    cass "你准备好后告诉我，我会比你提前一天，去探路。我们在乌克兰德斯基领主那里碰头。"

# game/a13/4frozen_wheels.rpy:379
translate english frozen_wheels2_71d3b8c8:

    # me "Хорошо."
    me "好。"

# game/a13/4frozen_wheels.rpy:381
translate english frozen_wheels2_0ef37c89:

    # cass "Что с семьей короля?"
    cass "国王的家人怎么样？"

# game/a13/4frozen_wheels.rpy:382
translate english frozen_wheels2_79ea49f5:

    # me "А что с ней?"
    me "他们怎么了？"

# game/a13/4frozen_wheels.rpy:383
translate english frozen_wheels2_2623601e:

    # cass "Есть... за что зацепиться?"
    cass "有没有……可以下手的地方？"

# game/a13/4frozen_wheels.rpy:384
translate english frozen_wheels2_eb983e39:

    # me "Нет. Только дочери и жена."
    me "没有。只有女儿们和妻子。"

# game/a13/4frozen_wheels.rpy:385
translate english frozen_wheels2_82151d60:

    # cass "Может соблазнишь кого-то?"
    cass "也许你勾引一个？"

# game/a13/4frozen_wheels.rpy:386
translate english frozen_wheels2_1f8b0e8a:

    # me "И как это поможет?"
    me "那又有什么用？"

# game/a13/4frozen_wheels.rpy:387
translate english frozen_wheels2_1f51db26:

    # cass "Любовницы и любовники это лучшие резервные рычаги влияния."
    cass "情妇和情夫是最好的后备影响力杠杆。"

# game/a13/4frozen_wheels.rpy:388
translate english frozen_wheels2_b4870bca:

    # me "Хорошо, [cass], я посмотрю что можно сделать."
    me "好吧，[cass]，我看看能做什么。"

# game/a13/4frozen_wheels.rpy:389
translate english frozen_wheels2_bd5bd208:

    # cass "Только не сделай никому ребенка, это только усложнит ситуацию."
    cass "只是别让谁怀上孩子，这只会让情况复杂。"

# game/a13/4frozen_wheels.rpy:390
translate english frozen_wheels2_8cc97caa:

    # me "Постараюсь."
    me "我尽量。"

# game/a13/4frozen_wheels.rpy:391
translate english frozen_wheels2_2ae758f7:

    # cass "Тогда до встречи."
    cass "那回头见。"

# game/a13/4frozen_wheels.rpy:392
translate english frozen_wheels2_f6a42382:

    # me "До встречи, [cass]."
    me "回头见，[cass]。"

# game/a13/4frozen_wheels.rpy:394
translate english frozen_wheels2_d17e42a1:

    # "Пять минут спустя."
    "五分钟以后."

# game/a13/4frozen_wheels.rpy:395
translate english frozen_wheels2_3e61168c:

    # me "{i}Хм... а красный мне даже к лицу.{/i}"
    me "{i}嗯……红色还挺适合我的。{/i}"

# game/a13/4frozen_wheels.rpy:396
translate english frozen_wheels2_ad9ec23e:

    # me "{i}Выгляжу как-то... грозно.{/i}"
    me "{i}看起来有点……威严。{/i}"

# game/a13/4frozen_wheels.rpy:397
translate english frozen_wheels2_9d6f262a:

    # me "{i}Да и в этой одежде теплее, чем в рубахе.{/i}"
    me "{i}而且这衣服比衬衫暖和。{/i}"

# game/a13/4frozen_wheels.rpy:398
translate english frozen_wheels2_d4e9d0e6:

    # me "{i}Интересно, Красный Император вообще носил красное?{/i}"
    me "{i}不知道红色皇帝到底穿不穿红色？{/i}"

# game/a13/4frozen_wheels.rpy:399
translate english frozen_wheels2_23fdd587:

    # me "{i}Его так прозвали явно не из-за цвета одежды, что он носил.{/i}"
    me "{i}他被这样称呼显然不是因为他穿的衣服颜色。{/i}"

# game/a13/4frozen_wheels.rpy:400
translate english frozen_wheels2_dd026470:

    # slug "Принц, [mename]?"
    slug "王子，[mename]？"

# game/a13/4frozen_wheels.rpy:401
translate english frozen_wheels2_e79d0fd5:

    # me "Да?"
    me "是？"

# game/a13/4frozen_wheels.rpy:402
translate english frozen_wheels2_ee4e8117:

    # slug "Король зовет вас на охоту."
    slug "国王叫您去狩猎。"

# game/a13/4frozen_wheels.rpy:403
translate english frozen_wheels2_eb9d7995:

    # me "Охоту?"
    me "狩猎？"

# game/a13/4frozen_wheels.rpy:404
translate english frozen_wheels2_ba28f6a3:

    # slug "Он ждет вас в роще у замка."
    slug "他在城堡旁的树林里等您。"

# game/a13/4frozen_wheels.rpy:407
translate english frozen_wheels2_85b51f21:

    # aurora "Ну... ты слышал его."
    aurora "嗯……你听见了。"

# game/a13/4frozen_wheels.rpy:408
translate english frozen_wheels2_8a8fb912:

    # me "Охота?"
    me "狩猎？"

# game/a13/4frozen_wheels.rpy:409
translate english frozen_wheels2_ac448cc3:

    # aurora "Ну да. Ты бывал на охоте?"
    aurora "是啊。你打过猎吗？"

# game/a13/4frozen_wheels.rpy:410
translate english frozen_wheels2_3b75e665:

    # me "Ни разу."
    me "一次也没有。"

# game/a13/4frozen_wheels.rpy:411
translate english frozen_wheels2_e8d25ac8:

    # aurora "Не волнуйся. Мой отец зовет на охоту тех, с кем хочет что-нибудь обсудить."
    aurora "别担心。我父亲叫去打猎的人，都是他想讨论事情的人。"

# game/a13/4frozen_wheels.rpy:412
translate english frozen_wheels2_3e0e0467:

    # me "Так он зовет меня на разговор?"
