translate english little_hunt_ba650982:

    # eva "{size=-2}А я не мой отец. Я тебе приказываю его убить.{/size}"
    eva "{size=-2}我又不是我父亲。我命令你杀了它。{/size}"

# game/a13/5little_hunt.rpy:109
translate english little_hunt_f8fe291b_1:

    # vlad "{size=-2}...{/size}"
    vlad "{size=-2}...{/size}"

# game/a13/5little_hunt.rpy:110
translate english little_hunt_54c56f41_1:

    # eva "{size=-2}Ну?{/size}"
    eva "{size=-2}怎么样？{/size}"

# game/a13/5little_hunt.rpy:111
translate english little_hunt_8a6ec0be:

    # vlad "{size=+2}Как скажете, принцесса.{/size}"
    vlad "{size=+2}遵命，公主殿下。{/size}"

# game/a13/5little_hunt.rpy:113
translate english little_hunt_0cd613d8:

    # eva "Ты спугнул ее!"
    eva "你把母鹿惊跑了！"

# game/a13/5little_hunt.rpy:114
translate english little_hunt_94a9b78c:

    # vlad ".."
    vlad ".."

# game/a13/5little_hunt.rpy:115
translate english little_hunt_a813ccc4:

    # eva "ОН ПОБЕЖАЛ ЗА НЕЙ! СТРЕЛЯЙ!"
    eva "它追那只鹿去了！快放箭！"

# game/a13/5little_hunt.rpy:117
translate english little_hunt_839fcb55:

    # eva "БОЛВАН!"
    eva "你这笨蛋！"

# game/a13/5little_hunt.rpy:118
translate english little_hunt_eb8910e2:

    # vlad "Не вышло."
    vlad "没射中。"

# game/a13/5little_hunt.rpy:119
translate english little_hunt_28582797:

    # eva "ЕЩЕ РАЗ! СТРЕЛЯЙ ЕЩЕ РАЗ!"
    eva "再来一箭！快再放箭！"

# game/a13/5little_hunt.rpy:121
translate english little_hunt_d8c1f71c:

    # vlad "Не выйдет. Они уже среди деревьев."
    vlad "射不到了。它们已经跑到树丛里去了。"

# game/a13/5little_hunt.rpy:122
translate english little_hunt_514222ec:

    # eva "Какой же идиот...."
    eva "真是个白痴……"

# game/a13/5little_hunt.rpy:123
translate english little_hunt_a78549f0:

    # me "А мне понравилось. Никогда не видел волка так близко."
    me "我倒觉得挺有意思。从来没这么近距离看过狼。"

# game/a13/5little_hunt.rpy:124
translate english little_hunt_49e4d975:

    # eva "Понравилось? Мы никого не убили!"
    eva "有意思？我们什么都没猎到！"

# game/a13/5little_hunt.rpy:125
translate english little_hunt_fb74dd70:

    # me "Ну и что? Зато повеселились."
    me "那又怎样？至少玩得开心。"

# game/a13/5little_hunt.rpy:126
translate english little_hunt_085dda8b:

    # vlad "Пойдемте."
    vlad "我们走吧。"

# game/a13/5little_hunt.rpy:127
translate english little_hunt_9399da29:

    # eva "Он... он специально промазал? Ты видел."
    eva "他……他是故意射偏的吧？你看见了。"

# game/a13/5little_hunt.rpy:128
translate english little_hunt_3a470882:

    # me "Он попал довольно рядом."
    me "他射得离目标很近了。"

# game/a13/5little_hunt.rpy:129
translate english little_hunt_29615680:

    # vlad "Мне пришлось целиться в движущуюся цель, вы сами приказали сменить цель в последнюю секунду."
    vlad "我得瞄准一个移动的目标，是您自己在最后一秒让我换目标的。"

# game/a13/5little_hunt.rpy:130
translate english little_hunt_927bd6e8:

    # eva "Ты спугнул олениху голосом, она бы не побежала, если бы не ты!"
    eva "是你用声音惊跑了母鹿，要不是你，它本来不会跑的！"

# game/a13/5little_hunt.rpy:131
translate english little_hunt_f0205872:

    # me "Разве?"
    me "是吗？"

# game/a13/5little_hunt.rpy:132
translate english little_hunt_02e27984:

    # vlad "Я ничего не делал. Идемте."
    vlad "我什么都没做。走吧。"

# game/a13/5little_hunt.rpy:133
translate english little_hunt_54b4367b:

    # eva "Ох... какой же ты идиот. Могли вернуться к отцу с таким трофеем..."
    eva "唉……你真是个白痴。我们本来能带着这么个战利品回去见父亲的……"

# game/a13/5little_hunt.rpy:134
translate english little_hunt_4421a206:

    # me "Ну и ладно. Идем, Ева."
    me "算了算了。走吧，Eva。"

# game/a13/5little_hunt.rpy:136
translate english little_hunt_79d82858_1:

    # "Десять минут спустя."
    "十分钟以后。"

# game/a13/5little_hunt.rpy:137
translate english little_hunt_e75f1aeb:

    # eva "Я тебе этого не забуду."
    eva "这事我跟你没完。"

# game/a13/5little_hunt.rpy:138
translate english little_hunt_1a350e53:

    # vlad "Я выстрелил из лука, как вы и приказали. Я не настолько меткий, чтобы попасть в бегущего ночью волка."
    vlad "我只是照您的命令放了一箭。我没那么准，没法在黑夜里射中奔跑的狼。"

# game/a13/5little_hunt.rpy:139
translate english little_hunt_46505351:

    # eva "Ага. Конечно."
    eva "哼。那当然。"

# game/a13/5little_hunt.rpy:140
translate english little_hunt_9746be61:

    # me "Вижу лагерь."
    me "看到营地了。"

# game/a13/5little_hunt.rpy:141
translate english little_hunt_1d7d4a5e:

    # vlad "Да. Я тоже."
    vlad "嗯。我也看到了。"

# game/a13/5little_hunt.rpy:142
translate english little_hunt_4cf6afac:

    # eva "Принц, вы тоже проигнорируете то, что мой слуга намеренно саботировал охоту?"
    eva "王子殿下，您也要无视我的仆人故意破坏狩猎这事吗？"

# game/a13/5little_hunt.rpy:143
translate english little_hunt_630e9919:

    # me "Я этого не заметил."
    me "我没注意到。"

# game/a13/5little_hunt.rpy:144
translate english little_hunt_9a6864c8:

    # vlad "Я не ваш слуга."
    vlad "我不是您的仆人。"

# game/a13/5little_hunt.rpy:145
translate english little_hunt_2bdc8157:

    # eva "Слуга отца. Как он отреагирует когда узнает, что вы сделали, м?"
    eva "是我父亲的仆人。他要是知道你干了什么，会怎么反应，嗯？"

# game/a13/5little_hunt.rpy:146
translate english little_hunt_87539818:

    # vlad "Ваш отец не убивает волков без надобности."
    vlad "您父亲不会在不必要的情况下杀狼。"

# game/a13/5little_hunt.rpy:147
translate english little_hunt_b1cc4f83:

    # eva "Чего это?"
    eva "这是为什么？"

# game/a13/5little_hunt.rpy:148
translate english little_hunt_bacaffac:

    # vlad "Волки падальщики и санитары леса. Они убивают и едят больных животных."
    vlad "狼是食腐动物，是森林的清道夫。它们会猎杀和吃掉生病的动物。"

# game/a13/5little_hunt.rpy:149
translate english little_hunt_4f0971b5:

    # eva "Звучит как полный бред."
    eva "听着像是鬼扯。"

# game/a13/5little_hunt.rpy:150
translate english little_hunt_76054513:

    # me "Вроде так и есть."
    me "好像还真是这么回事。"

# game/a13/5little_hunt.rpy:151
translate english little_hunt_688626a9:

    # eva "Любитель собак... одомашненных и диких. Ты его не убил потому что он напоминает тебе твою псину."
    eva "爱狗狂……驯化的和野生的都爱。你没杀它，就因为它让你想起你的那条狗。"

# game/a13/5little_hunt.rpy:152
translate english little_hunt_0d9f4c06:

    # me "Лорд Дубовицкий кажется справился."
    me "Dubovitsky大人好像干得不错。"

# game/a13/5little_hunt.rpy:154
translate english little_hunt_7bab5547:

    # dubov "Долго вы."
    dubov "你们可真慢。"

# game/a13/5little_hunt.rpy:155
translate english little_hunt_85131471:

    # eva "Ага. И безрезультатно."
    eva "嗯，还两手空空。"

# game/a13/5little_hunt.rpy:156
translate english little_hunt_477b1281:

    # me "Я так понимаю, приди мы еще на полчаса позже нас бы ждал полноценный ужин?"
    me "我看要是我们再晚来半小时，就能直接吃上大餐了？"

# game/a13/5little_hunt.rpy:157
translate english little_hunt_d135e30e:

    # dubov "Я только начал. Вы шли на дым?"
    dubov "我才刚开始。你们是顺着烟味找来的？"

# game/a13/5little_hunt.rpy:158
translate english little_hunt_687d4609:

    # vlad "Да."
    vlad "是的。"

# game/a13/5little_hunt.rpy:159
translate english little_hunt_fdeb8c63:

    # eva "Мы бы тоже пришли с трофеем, если бы не твой кретин-слуга."
    eva "要不是你那个白痴仆人，我们也能带着战利品回来。"

# game/a13/5little_hunt.rpy:160
translate english little_hunt_57bf8f97:

    # dubov "О чем она?"
    dubov "她在说什么？"

# game/a13/5little_hunt.rpy:161
translate english little_hunt_e27d6b11:

    # me "Долгая история."
    me "说来话长。"

# game/a13/5little_hunt.rpy:162
translate english little_hunt_a2a042e9:

    # vlad "Мы шли по следу самки."
    vlad "我们顺着母鹿的足迹追。"

# game/a13/5little_hunt.rpy:163
translate english little_hunt_99add484:

    # dubov "И?"
    dubov "然后呢？"

# game/a13/5little_hunt.rpy:164
translate english little_hunt_b356def1:

    # vlad "Нашли ее. Принцесса пожелала, чтобы я стрелял в волка."
    vlad "找到了。公主想让我射一头狼。"

# game/a13/5little_hunt.rpy:165
translate english little_hunt_800948f5:

    # eva "Волк трофей гораздо лучше, чем олень, что тут такого?"
    eva "狼比鹿的战利品好得多，这有什么问题？"

# game/a13/5little_hunt.rpy:166
translate english little_hunt_b80aa8f1:

    # dubov "Волк? Ничего себе."
    dubov "狼？不错啊。"

# game/a13/5little_hunt.rpy:167
translate english little_hunt_47aeaaac:

    # eva "Видишь? Если бы мы принесли его тушу, отец был бы рад."
    eva "你看是吧？要是我们把它的尸体带回来，父亲会高兴的。"

# game/a13/5little_hunt.rpy:168
translate english little_hunt_2a99d2b7:

    # me "Олениха его увидела и побежала. Он рванул за ней."
    me "母鹿看见了狼，就跑了。狼追着鹿去了。"

# game/a13/5little_hunt.rpy:169
translate english little_hunt_09ee4057:

    # eva "Влад его спугнул! Специально."
    eva "是Vlad惊跑了狼！故意的。"

# game/a13/5little_hunt.rpy:170
translate english little_hunt_357e41c7:

    # vlad "Я этого не делал."
    vlad "我没有。"

# game/a13/5little_hunt.rpy:171
translate english little_hunt_3e8f8026:

    # eva "Ну конечно."
    eva "哼，当然。"

# game/a13/5little_hunt.rpy:173
translate english little_hunt_df161ad0:

    # dubov "Если ты так хотела его убить, почему же сама не стреляла?"
    dubov "既然你这么想杀它，你自己怎么不射箭？"

# game/a13/5little_hunt.rpy:174
translate english little_hunt_2cf4865c:

    # eva "Я не умею!"
    eva "我不会射箭！"

# game/a13/5little_hunt.rpy:175
translate english little_hunt_2acac660:

    # dubov "Тогда почему ты обвиняешь других в том, в чем сама преуспеть не можешь?"
    dubov "那你自己都不会的事，凭什么指责别人也干不好？"

# game/a13/5little_hunt.rpy:176
translate english little_hunt_7be3c3c8:

    # eva "Я принцесса, а не охотник!"
    eva "我是公主，又不是猎人！"

# game/a13/5little_hunt.rpy:177
translate english little_hunt_6df70ee5:

    # dubov "Так если ты не знаешь как стрелять из лука, с чего ты взяла, что он промахнулся намеренно?"
    dubov "既然如此，你不知道怎么射箭，又凭什么认定他故意射偏了？"

# game/a13/5little_hunt.rpy:178
translate english little_hunt_53352fc0_1:

    # eva "..."
    eva "..."

# game/a13/5little_hunt.rpy:179
translate english little_hunt_574c0c20:

    # dubov "Ну?"
    dubov "嗯？"

# game/a13/5little_hunt.rpy:180
translate english little_hunt_8d0cdaf6:

    # eva "Может он и не специально промахнулся. Но спугнул их специально. Чтобы они побежали и он мог оправдаться, почему промазал."
    eva "也许他不是故意射偏的。但惊跑它们肯定是故意的。好让它们跑起来，他就能为自己射偏找借口。"

# game/a13/5little_hunt.rpy:181
translate english little_hunt_652d8c7a:

    # dubov "И зачем ему это делать?"
    dubov "他为什么要这么做？"

# game/a13/5little_hunt.rpy:182
translate english little_hunt_bf5bf62a:

    # eva "Это не у меня нужно спрашивать! Он сын псаря, спит вместе с собаками и жрет, наверное ему жалко всех, кто ходит на четвереньках, виляет хвостом и у кого воняет из пасти."
    eva "这不该来问我！他是猎犬管理员的儿子，跟狗睡在一起，吃也一样。大概在他眼里，所有四脚走路、摇尾巴、嘴里发臭的东西都值得可怜。"

# game/a13/5little_hunt.rpy:183
translate english little_hunt_06f75bfc:

    # vlad "Я собирался стрелять в самку. Принцесса попросила сменить цель, когда я уже натянул тетиву."
    vlad "我本来要射母鹿。是公主在我拉满弓的时候让换目标的。"

# game/a13/5little_hunt.rpy:184
translate english little_hunt_c86fe556:

    # dubov "Ясно."
    dubov "明白了。"

# game/a13/5little_hunt.rpy:185
translate english little_hunt_f9454570:

    # eva "Он громко ответил. Специально."
    eva "他当时很大声地回答。是故意的。"

# game/a13/5little_hunt.rpy:186
translate english little_hunt_336399a3:

    # dubov "[mename]?"
    dubov "[mename]?"

# game/a13/5little_hunt.rpy:187
translate english little_hunt_235d1677:

    # me "Только меня в это не втягивайте. Мы разговаривали все трое."
    me "别把我扯进去。当时我们三个都在说话。"

# game/a13/5little_hunt.rpy:188
translate english little_hunt_bdfd0780:

    # vlad "Спасибо."
    vlad "谢谢。"

# game/a13/5little_hunt.rpy:189
translate english little_hunt_7660acbe:

    # eva "Да, но он..."
    eva "是，可他……"

# game/a13/5little_hunt.rpy:190
translate english little_hunt_80ad8e6d:

    # dubov "Разговор окончен. Устраивайтесь на ночлег."
    dubov "别说了。准备扎营过夜吧。"

# game/a13/5little_hunt.rpy:192
translate english little_hunt_ee2fb9bc:

    # eva "Я присяду рядом?"
    eva "我坐你旁边行吗？"

# game/a13/5little_hunt.rpy:193
translate english little_hunt_1c50b361:

    # me "Как хочешь."
    me "随你便。"

# game/a13/5little_hunt.rpy:194
translate english little_hunt_d4e11f06:

    # eva "А ты хочешь?"
    eva "你愿意吗？"

# game/a13/5little_hunt.rpy:195
translate english little_hunt_3820771a_2:

    # me "..."
    me "..."

# game/a13/5little_hunt.rpy:196
translate english little_hunt_f2f9195f:

    # eva "Могу уйти."
    eva "我可以走。"

# game/a13/5little_hunt.rpy:197
translate english little_hunt_cd9e76f6:

    # me "Садись уже."
    me "坐下吧。"

# game/a13/5little_hunt.rpy:198
translate english little_hunt_4f547239:

    # eva "Так и знала, что тебе моя компания по душе."
    eva "我就知道你喜欢我陪你。"

# game/a13/5little_hunt.rpy:199
translate english little_hunt_e116cccb:

    # me "Боюсь тут никто кроме меня тебя не выдержит."
    me "恐怕这儿除了我，没人受得了你。"

# game/a13/5little_hunt.rpy:200
translate english little_hunt_1fb946d7:

    # eva "Я не стала бы делить ужин рядом с простолюдинами. Если бы ты отказал, хотя ты бы этого и не сдлела, но вдруг..."
    eva "我才不会和那些平民一起分享晚饭。如果你拒绝了我——虽然你肯定不会那么做，但万一……"

# game/a13/5little_hunt.rpy:201
translate english little_hunt_553c7984:

    # me "Ты бы села с отцом?"
    me "你就会去和你父亲坐？"

# game/a13/5little_hunt.rpy:202
translate english little_hunt_4dc41e58:

    # eva "Я бы села одна."
    eva "我会一个人坐着。"

# game/a13/5little_hunt.rpy:204
translate english little_hunt_3bb17f36:

    # me "Чем же отец заслужил твою немилость?"
    me "父亲又怎么招惹你了，让你这么不待见他？"

# game/a13/5little_hunt.rpy:205
translate english little_hunt_3ad07284:

    # eva "Он не встал на мою сторону."
    eva "他没站在我这边。"

# game/a13/5little_hunt.rpy:206
translate english little_hunt_e8186dd8:

    # me "Я тоже не встал на мою сторону."
    me "我也没站在你这边啊。"

# game/a13/5little_hunt.rpy:207
translate english little_hunt_e7ec1491:

    # eva "Ты просто глупый и ты никогда не был на охоте."
    eva "你就是蠢，而且你以前从没打过猎。"

# game/a13/5little_hunt.rpy:208
translate english little_hunt_3820771a_3:

    # me "..."
    me "..."

# game/a13/5little_hunt.rpy:209
translate english little_hunt_fc6089ef:

    # eva "Он специально повысил голос."
    eva "他故意提高了音量。"

# game/a13/5little_hunt.rpy:210
translate english little_hunt_49dbc767:

    # me "Даже не хочу говорить об этом. Мне действительно все равно."
    me "我压根不想谈这个了。我真的无所谓。"

# game/a13/5little_hunt.rpy:211
translate english little_hunt_f0dd3b77:

    # eva "Ладно. Давай сменим тему. Как тебе Север?"
    eva "好吧。换个话题。你觉得北方怎么样？"

# game/a13/5little_hunt.rpy:212
translate english little_hunt_149b3064:

    # me "В каком смысле?"
    me "什么意思？"

# game/a13/5little_hunt.rpy:213
translate english little_hunt_12f7f58c:

    # eva "В прямом. Как тебе наша природа, еда, женщины?"
    eva "就字面意思。你觉得我们的自然风光，食物，女人怎么样？"

# game/a13/5little_hunt.rpy:214
translate english little_hunt_1deb6b7a:

    # me "Я не был нигде, кроме вашего замка и Хельвика, а в Хельвике я пару часов смотрел на порт, а потом его покинул в авангарде."
    me "除了你们的城堡和Helvik，我哪儿都没去过。在Helvik也就看了几个小时港口，然后就作为先头部队离开了。"

# game/a13/5little_hunt.rpy:215
translate english little_hunt_687d4609_1:

    # me "Так что да. Кроме вашего замка я Севера и не видел."
    me "所以说，除了你们的城堡，我压根没看到北方的样子。"

# game/a13/5little_hunt.rpy:216
translate english little_hunt_a80cd6b8:

    # eva "Этого достаточно. Так что? Как тебе северянки?"
    eva "这也够了。所以呢？北方姑娘怎么样？"

# game/a13/5little_hunt.rpy:217
translate english little_hunt_ccb51a54:

    # me "Я должен ответить сразу про всех или какую-то конкретную?"
    me "我得一次回答所有，还是可以特指某个人？"

# game/a13/5little_hunt.rpy:218
translate english little_hunt_5603dd1b:

    # eva "Можешь про какую-то конкретную, если она тебе особенно запомнилась своей красотой или..."
    eva "你可以说说某个具体的人，如果她因为美貌，或者……"

# game/a13/5little_hunt.rpy:219
translate english little_hunt_49625f2f:

    # me "...или характером."
    me "……或者性格让你印象深刻的话。"

# game/a13/5little_hunt.rpy:220
translate english little_hunt_97f43a40:

    # eva "Угу."
    eva "嗯。"

# game/a13/5little_hunt.rpy:221
translate english little_hunt_ef0876aa:

    # me "Скажем так, красивых девушек полно везде. Но с таким характером..."
    me "这么说吧，漂亮姑娘到处都有。但这样的性格嘛……"

# game/a13/5little_hunt.rpy:222
translate english little_hunt_97699676:

    # eva "Встречаешь впервые?"
    eva "头一回见？"

# game/a13/5little_hunt.rpy:223
translate english little_hunt_68a4bcd5:

    # me "Нет. Но это довольно... уникальный архетип."
    me "那倒不是。但这也确实是种……相当独特的类型。"

# game/a13/5little_hunt.rpy:224
translate english little_hunt_201dd62f:

    # eva "Ну редкость это ведь хорошо? Чем обыкновеннее человек, тем он скучнее."
    eva "嗯，稀罕不就是好事吗？一个人越普通，就越无趣。"

# game/a13/5little_hunt.rpy:225
translate english little_hunt_6ab05865:

    # me "Наверное."
    me "或许吧。"

# game/a13/5little_hunt.rpy:226
translate english little_hunt_f29abfcd:

    # eva "Так и есть. Я рада, что ты признал, что северные девушки гораздо лучше южных."
    eva "就是没错。我很高兴你承认北方姑娘比南方姑娘好得多。"

# game/a13/5little_hunt.rpy:227
translate english little_hunt_df56cc83:

    # me "Я этого не говорил..."
    me "我没这么说……"

# game/a13/5little_hunt.rpy:228
translate english little_hunt_34f1a3b5:

    # eva "Вроде так и сказал."
    eva "你刚才差不多就是这意思。"

# game/a13/5little_hunt.rpy:230
translate english little_hunt_55066ad7:

    # dubov "Вы голодны? Если жаренную, только что убитую дичь?"
    dubov "您饿了吗？想尝尝刚杀好的烤野味吗？"

# game/a13/5little_hunt.rpy:231
translate english little_hunt_3bd73426:

    # me "Нет, но с удовольствием попробую."
    me "不饿，但我很乐意尝一点。"

# game/a13/5little_hunt.rpy:232
translate english little_hunt_915f23a3:

    # dubov "Ева?"
    dubov "Eva？"

# game/a13/5little_hunt.rpy:233
translate english little_hunt_c8dbe194:

    # eva "Фу. Нет."
    eva "呸。不要。"

# game/a13/5little_hunt.rpy:234
translate english little_hunt_5a826f93:

    # dubov "Мы будем здесь до самого утра, а потом еще и дорога назад."
    dubov "我们要在这儿待到明天早上，然后还有回去的路要走呢。"

# game/a13/5little_hunt.rpy:235
translate english little_hunt_4d609f80:

    # eva "Я потерплю."
    eva "我能忍。"

# game/a13/5little_hunt.rpy:236
translate english little_hunt_678023ee:

    # dubov "Как знаешь. Сколько вам кусков, [mename]?"
    dubov "随你。您要几块肉，[mename]？"

# game/a13/5little_hunt.rpy:237
translate english little_hunt_5df52558:

    # me "А сколько можно."
    me "能吃几块？"

# game/a13/5little_hunt.rpy:238
translate english little_hunt_94916c6c:

    # dubov "Можно хоть пол оленя. Чем меньше нести обратно, тем лучше."
    dubov "吃半只鹿都行。带回去的越少越好。"

# game/a13/5little_hunt.rpy:239
translate english little_hunt_949827f3:

    # me "Думаю два куска хватит."
    me "我觉得两块就够了。"

# game/a13/5little_hunt.rpy:240
translate english little_hunt_8b2c33b2:

    # dubov "Хорошо. Найду для тебя куски повкуснее."
    dubov "好的。我给你找两块好吃的。"

# game/a13/5little_hunt.rpy:241
translate english little_hunt_3066598f:

    # me "Спасибо."
    me "谢谢。"

# game/a13/5little_hunt.rpy:242
translate english little_hunt_68c555fa:

    # dubov "Это отдай собакам."
    dubov "这个拿去喂狗。"

# game/a13/5little_hunt.rpy:243
translate english little_hunt_d8b6632b:

    # vlad "Хорошо."
    vlad "好。"

# game/a13/5little_hunt.rpy:245
translate english little_hunt_e94f0961:

    # me "Ты же любишь мясо."
    me "你可是喜欢吃肉的。"

# game/a13/5little_hunt.rpy:246
translate english little_hunt_fea23bb4:

    # eva "Кто? Я?"
    eva "谁？我？"

# game/a13/5little_hunt.rpy:247
translate english little_hunt_bb686f7a:

    # me "Ну да."
    me "对啊。"

# game/a13/5little_hunt.rpy:248
translate english little_hunt_7c00ea36:

    # eva "Кто тебе это сказал? Я люблю фрукты, мясо я ненавижу."
    eva "谁告诉你的？我喜欢水果，肉我最讨厌了。"

# game/a13/5little_hunt.rpy:249
translate english little_hunt_0bbd0755:

    # me "Но...понятно...."
    me "可……明白了……"

# game/a13/5little_hunt.rpy:250
translate english little_hunt_0100b07e:

    # eva "Что?"
    eva "怎么了？"

# game/a13/5little_hunt.rpy:251
translate english little_hunt_e41b5f9e:

    # me "Иногда забываю, что нельзя верить вообще ни единому твоему слову."
    me "有时候我总忘了，你嘴里一个字都不能信。"

# game/a13/5little_hunt.rpy:252
translate english little_hunt_a17d2ac6:

    # eva "О чем ты? Я никогда мясо не любила. Это пища для мужчин и жирногубых свиноматок. Такие аристократки как я, едят только вырезку и то не часто."
    eva "你在说什么？我从没喜欢过肉。那是给男人和那些肥嘴唇的母猪们吃的。像我这样的贵妇人，只吃里脊，还不常吃。"

# game/a13/5little_hunt.rpy:253
translate english little_hunt_3820771a_4:

    # me "..."
    me "..."

# game/a13/5little_hunt.rpy:254
translate english little_hunt_b5e80821:

    # eva "Вон. Видишь? Любители мяса. Даже не жуют, проглатывают целиком от жадности."
    eva "瞧，看到了吗？爱吃肉的家伙。贪婪得连嚼都不嚼，整个儿吞下去。"

# game/a13/5little_hunt.rpy:255
translate english little_hunt_b8e89672:

    # me "Тебя расстраивает собачий этикет."
    me "你连狗的吃相都要看不顺眼。"

# game/a13/5little_hunt.rpy:256
translate english little_hunt_51742f4c:

    # eva "Меня бесят собаки."
    eva "我讨厌狗。"

# game/a13/5little_hunt.rpy:257
translate english little_hunt_5ac38cf1:

    # me "Почему?"
    me "为什么？"

# game/a13/5little_hunt.rpy:258
translate english little_hunt_91891f00:

    # eva "Омерзительные, грязные животные."
    eva "恶心、肮脏的畜生。"

# game/a13/5little_hunt.rpy:259
translate english little_hunt_8a99ba35:

    # me "Зато верные."
    me "但忠诚。"

# game/a13/5little_hunt.rpy:260
translate english little_hunt_899dd882:

    # eva "Верные? Верность это полезное свойство раба или слуги для его хозяина."
    eva "忠诚？那是奴隶或者仆人对他主人有用的品质。"

# game/a13/5little_hunt.rpy:261
translate english little_hunt_3820771a_5:

    # me "..."
    me "..."

# game/a13/5little_hunt.rpy:262
translate english little_hunt_b5af5949:

    # eva "А если слуга или раб ослушивается приказа... их надо наказывать."
    eva "而如果仆人或奴隶不服从命令……就得受到惩罚。"

# game/a13/5little_hunt.rpy:263
translate english little_hunt_6c841341:

    # me "И часто собаки ослушиваются приказов?"
    me "狗经常不服从命令吗？"

# game/a13/5little_hunt.rpy:264
translate english little_hunt_8deaaffe:

    # eva "Я может и не о собаках говорю."
    eva "我说的可能不是狗哦。"

# game/a13/5little_hunt.rpy:265
translate english little_hunt_0355d0cd:

    # vlad "Первые куски готовы."
    vlad "第一批肉好了。"

# game/a13/5little_hunt.rpy:267
translate english little_hunt_2c040d05:

    # eva "Ну как?"
    eva "怎么样？"

# game/a13/5little_hunt.rpy:268
translate english little_hunt_cca6720c:

    # me "Вкусно."
    me "好吃。"

# game/a13/5little_hunt.rpy:269
translate english little_hunt_1d274deb:

    # eva "Ели так когда-нибудь?"
    eva "你以前这样吃过吗？"

# game/a13/5little_hunt.rpy:270
translate english little_hunt_b2b1f860:

    # me "Пару раз."
    me "有过几次。"

# game/a13/5little_hunt.rpy:271
translate english little_hunt_6dc9084e:

    # eva "В Бригдоке."
    eva "在布里格多克。"

# game/a13/5little_hunt.rpy:272
translate english little_hunt_3fd05c5b:

    # me "Не только."
    me "不光是那儿。"

# game/a13/5little_hunt.rpy:273
translate english little_hunt_7bfe837a:

    # eva "Хотя в Бригдоке вы наверное жевали рыбу."
    eva "不过我想在布里格多克，你们大概嚼的是鱼肉。"

# game/a13/5little_hunt.rpy:274
translate english little_hunt_18f2a1c3:

    # me "Это тоже еда для простолюдинов?"
    me "这又是平民吃的玩意儿？"

# game/a13/5little_hunt.rpy:275
translate english little_hunt_40c3a6bb:

    # eva "Разумеется. И чем сильнее воняет, тем с большим удовольствием простолюдины будут это жрать."
    eva "当然。而且越腥臭，那些平民吃得就越香。"

# game/a13/5little_hunt.rpy:276
translate english little_hunt_afedae31:

    # me "И что же едят аристократы, если мясо и рыба им не положена?"
    me "那如果肉和鱼都不适合贵族吃，贵族们吃什么呢？"

# game/a13/5little_hunt.rpy:277
translate english little_hunt_78234677:

    # eva "Сыр. Обожаю его."
    eva "奶酪。我超爱奶酪。"

# game/a13/5little_hunt.rpy:278
translate english little_hunt_c36d17f0:

    # me "Сыр. А как же фрукты?"
    me "奶酪。那水果呢？"

# game/a13/5little_hunt.rpy:279
translate english little_hunt_548ec39b:

    # eva "Фрукты?"
    eva "水果？"

# game/a13/5little_hunt.rpy:280
translate english little_hunt_9af5f20a:

    # me "Дай угадаю. Ты их ненавидишь."
    me "让我猜猜。你讨厌水果。"

# game/a13/5little_hunt.rpy:281
translate english little_hunt_1b2f7995:

    # eva "Верно. Налить молока?"
    eva "没错。要给你倒点牛奶吗？"

# game/a13/5little_hunt.rpy:283
translate english little_hunt_2709ef54:

    # me "Молоко, надеюсь, мне, как аристократу, его можно пить?"
    me "牛奶，我想，作为贵族，我应该是可以喝的吧？"

# game/a13/5little_hunt.rpy:284
translate english little_hunt_0fdb7027:

    # eva "Конечно. Из него ведь делают сыр."
    eva "当然。奶酪不就是用它做的嘛。"

# game/a13/5little_hunt.rpy:285
translate english little_hunt_23e9211b:

    # me "Мне кажется я начинаю понимать аристократическую мысль."
    me "我觉得我开始理解贵族的思维了。"

# game/a13/5little_hunt.rpy:286
translate english little_hunt_bf33e195:

    # eva "Разумеется, вы ведь принц."
    eva "那当然，您可是王子殿下。"

# game/a13/5little_hunt.rpy:287
translate english little_hunt_656f9c6d:

    # me "Мне аристократически кажется что нужно переходить на овощи."
    me "我贵族地觉得，该转向蔬菜了。"

# game/a13/5little_hunt.rpy:288
translate english little_hunt_b4e24d10:

    # eva "Овощи. Да."
    eva "蔬菜。没错。"

# game/a13/5little_hunt.rpy:289
translate english little_hunt_5f9c5fb8:

    # me "Настоящая аристократическая еда."
    me "真正的贵族食物。"

# game/a13/5little_hunt.rpy:290
translate english little_hunt_a03997fd:

    # eva "Мне всегда нравились овощи."
    eva "我一直很喜欢蔬菜。"

# game/a13/5little_hunt.rpy:291
translate english little_hunt_b65cc518:

    # me "А сыр?"
    me "那奶酪呢？"

# game/a13/5little_hunt.rpy:292
translate english little_hunt_3bbb6c6a:

    # eva "Сыр..."
    eva "奶酪……"

# game/a13/5little_hunt.rpy:293
translate english little_hunt_ceb502ff:

    # me "Омерзителен. Воняет и на вкус как стухшее молоко. Всегда его ненавидел."
    me "恶心极了。闻着臭，吃着像馊掉的牛奶。一直讨厌它。"

# game/a13/5little_hunt.rpy:294
translate english little_hunt_a56a4ee4:

    # eva "Да. Я тоже."
    eva "是啊。我也是。"

# game/a13/5little_hunt.rpy:295
translate english little_hunt_3820771a_6:

    # me "..."
    me "..."

# game/a13/5little_hunt.rpy:296
translate english little_hunt_53352fc0_2:

    # eva "..."
    eva "..."

# game/a13/5little_hunt.rpy:298
translate english little_hunt_3d36c154:

    # eva "Вы ведь еще вернетесь к нам?"
    eva "您还会回到我们这儿来的吧？"

# game/a13/5little_hunt.rpy:299
translate english little_hunt_9d119104:

    # me "Вернусь. А что, уже скучаешь по мне?"
    me "会回来的。怎么，已经开始想我了？"

# game/a13/5little_hunt.rpy:300
translate english little_hunt_be20640d:

    # eva "Я? Фу. Нет. Вы мне отвратительны."
    eva "我？呸。没有。您让我觉得恶心。"

# game/a13/5little_hunt.rpy:301
translate english little_hunt_78c722d3:

    # me "Да, ты мне тоже."
    me "是啊，你也一样让我恶心。"

# game/a13/5little_hunt.rpy:302
translate english little_hunt_9860f762:

    # eva "Я рада, что это взаимно."
    eva "真高兴我们是彼此彼此。"

# game/a13/5little_hunt.rpy:303
translate english little_hunt_3820771a_7:

    # me "..."
    me "..."

# game/a13/5little_hunt.rpy:304
translate english little_hunt_140a71c0:

    # eva "...так..."
    eva "……那么……"

# game/a13/5little_hunt.rpy:305
translate english little_hunt_ce095f92:

    # me "Вернусь. Надо сначала решить одно дело."
    me "我会回来的。得先处理一件事。"

# game/a13/5little_hunt.rpy:306
translate english little_hunt_226b5c0c:

    # eva "Я могу помочь."
    eva "也许我能帮忙。"

# game/a13/5little_hunt.rpy:307
translate english little_hunt_f9603b13:

    # me "Сомневаюсь."
    me "我表示怀疑。"

# game/a13/5little_hunt.rpy:308
translate english little_hunt_6608c219:

    # eva "Жаль."
    eva "那真遗憾。"

# game/a13/5little_hunt.rpy:310
translate english little_hunt_83749a03:

    # "Полчаса спустя."
    "半个小时以后。"

# game/a13/5little_hunt.rpy:311
translate english little_hunt_4edeb074:

    # me "{i}Эх... после целого дня на ногах я действительно устал.{/i}"
    me "{i}唉……走了一整天路，我确实累了。{/i}"

# game/a13/5little_hunt.rpy:312
translate english little_hunt_573e7d9b:

    # me "{i}Давно так ноги не болели.{/i}"
    me "{i}好久没这么脚疼过了。{/i}"

# game/a13/5little_hunt.rpy:313
translate english little_hunt_86bf71eb:

    # me "{i}Не хотелось бы спать на сырой земле, но сейчас я бы и в речке уснул.{/i}"
    me "{i}真不想睡在潮湿的地上，但我现在就算在河里都能睡着。{/i}"

# game/a13/5little_hunt.rpy:314
translate english little_hunt_a5113447:

    # me "{i}Хоть костер и чем укрыться есть.{/i}"
    me "{i}好赖还有个篝火和能盖的东西。{/i}"

# game/a13/5little_hunt.rpy:315
translate english little_hunt_00abf68d:

    # me "{i}Не хотелось бы простудиться прямо перед поездкой.{/i}"
    me "{i}可不想就在出发前再着凉了。{/i}"

# game/a13/5little_hunt.rpy:316
translate english little_hunt_5c76dbe7:

    # me "{i}...{/i}"
    me "{i}...{/i}"

# game/a13/5little_hunt.rpy:317
translate english little_hunt_361ec1de:

    # me "{i}Пора спать.{/i}"
    me "{i}该睡了。{/i}"

# game/a13/5little_hunt.rpy:319
translate english little_hunt_684c14a2:

    # eva "Двигайся."
    eva "挪过去点。"

# game/a13/5little_hunt.rpy:320
translate english little_hunt_dfcceeac:

    # me "М?"
    me "嗯？"

# game/a13/5little_hunt.rpy:321
translate english little_hunt_9949869c:

    # eva "Двигайся говорю. Я буду спать рядом."
    eva "我说，挪过去点。我要睡你旁边。"

# game/a13/5little_hunt.rpy:322
translate english little_hunt_60358084:

    # me "Эм..."
    me "呃……"

# game/a13/5little_hunt.rpy:323
translate english little_hunt_481d27e3:

    # eva "Что? Ты хочешь чтобы я мерзла? Это вообще-то очень вредно для молодой женщины."
    eva "怎么？你想让我冻着吗？这对年轻女人可是非常不好的。"

# game/a13/5little_hunt.rpy:324
translate english little_hunt_4afd68af:

    # me "Я не против, но почему я?"
    me "我不反对，但为什么是我？"

# game/a13/5little_hunt.rpy:325
translate english little_hunt_3e8ded82:

    # eva "А кто еще?"
    eva "还能有谁？"

# game/a13/5little_hunt.rpy:326
translate english little_hunt_0aa00e7c:

    # me "Твой отец."
    me "你父亲。"

# game/a13/5little_hunt.rpy:327
translate english little_hunt_d3609019:

    # eva "Он будет еще полночи свежевать тушу. А даже когда закончит от него еще неделю будет пахнуть. Двигайся говорю."
    eva "他还要剥大半夜的鹿皮呢。就算他剥完了，接下来一周他身上都会有味道。我说，你挪过去点。"

# game/a13/5little_hunt.rpy:329
translate english little_hunt_98e020b6:

    # me "Он не против?"
    me "他不反对吗？"

# game/a13/5little_hunt.rpy:330
translate english little_hunt_b8886213:

    # eva "А что? Я же не ложусь голой к тебе в постель. Мы просто в стесненных обстоятельствах. Сомневаюсь, что он хочет чтобы его дочь мерзла."
    eva "那又怎么？我又不是赤身裸体地爬你床上去。我们只是条件有限凑合一下。我怀疑他会想让自己的女儿冻着。"

# game/a13/5little_hunt.rpy:331
translate english little_hunt_2af2cc6c:

    # me "Ты можешь лечь одна."
    me "你可以一个人躺。"

# game/a13/5little_hunt.rpy:332
translate english little_hunt_5f4b19e4:

    # eva "На холодную землю? А что если одна из псин вцепится в меня?"
    eva "躺在冰冷的土地上？万一哪条狗咬我怎么办？"

# game/a13/5little_hunt.rpy:333
translate english little_hunt_1e2638e9:

    # me "С чего бы ей это делать?"
    me "它们干嘛要咬你？"

# game/a13/5little_hunt.rpy:334
translate english little_hunt_0ca0c11b:

    # eva "Мало ли. С мужчиной под боком всяко безопасней."
    eva "说不准嘛。身边有个男人，总归安全些。"

# game/a13/5little_hunt.rpy:335
translate english little_hunt_6ab05865_1:

    # me "Наверное."
    me "也许吧。"

# game/a13/5little_hunt.rpy:336
translate english little_hunt_695262b5:

    # eva "Тем более я оделась немного... ну знаешь."
    eva "再说了，我穿得有点……你懂的。"

# game/a13/5little_hunt.rpy:337
translate english little_hunt_357c431c:

    # me "Да. Запомнил."
    me "嗯。记得。"

# game/a13/5little_hunt.rpy:338
translate english little_hunt_1832f9c3:

    # eva "Не хотелось бы себе там все отморозить. Так что будешь греть и меня и сверху и снизу."
    eva "我可不想把那里冻坏了。所以你要负责给我上下都暖和暖和。"

# game/a13/5little_hunt.rpy:339
translate english little_hunt_1390adfc:

    # me "...ладно."
    me "……好吧。"

# game/a13/5little_hunt.rpy:341
translate english little_hunt_1d90b267:

    # eva "Спасибо, мой принц."
    eva "谢谢，我的王子。"

# game/a13/5little_hunt.rpy:342
translate english little_hunt_155f7bf5:

    # me "Я не твой принц."
    me "我不是你的王子。"

# game/a13/5little_hunt.rpy:343
translate english little_hunt_6572935b:

    # eva "Но ведь так говорят."
    eva "可大家都这么说啊。"

# game/a13/5little_hunt.rpy:344
translate english little_hunt_d821305c:

    # me "Так говорят те, кто мне служит. Все остальные просто упоминают мой титул."
    me "那是服侍我的人才这么说。其余人只是提我的头衔而已。"

# game/a13/5little_hunt.rpy:345
translate english little_hunt_690f9719:

    # eva "Может я хочу тебе служить. Берешь меня на службу?"
    eva "也许我想服侍你呢。你要我为你效劳吗？"

# game/a13/5little_hunt.rpy:346
translate english little_hunt_5967bf81:

    # me "Это не так работает."
    me "事情不是这么办的。"

# game/a13/5little_hunt.rpy:347
translate english little_hunt_53ae69bf:

    # eva "Да ну. А как? А когда ты присоединишь Север, я смогу тебе называть МОЙ принц?"
    eva "切。那要怎么办？等你统一了北方，我就能叫你“我的”王子了吗？"

# game/a13/5little_hunt.rpy:348
translate english little_hunt_c97fadc0:

    # me "Ну..."
    me "呃……"

# game/a13/5little_hunt.rpy:349
translate english little_hunt_bd9b8ef5:

    # eva "Что? Ты сюда явно не охотиться приехал."
    eva "怎么了？你来这儿显然不是为了打猎的。"

# game/a13/5little_hunt.rpy:350
translate english little_hunt_c6127e01:

    # me "Ты..."
    me "你……"

# game/a13/5little_hunt.rpy:351
translate english little_hunt_5718de2b:

    # eva "Удивительно проницательна? Спасибо, я знаю."
    eva "惊人地敏锐？谢谢，我知道。"

# game/a13/5little_hunt.rpy:352
translate english little_hunt_3820771a_8:

    # me "..."
    me "..."

# game/a13/5little_hunt.rpy:353
translate english little_hunt_9476d2e6:

    # eva "Не волнуйся, я никому не расскажу. Хотя я думаю отец и так знает."
    eva "别担心，我不会告诉任何人的。虽然我觉得父亲本来也知道。"

# game/a13/5little_hunt.rpy:354
translate english little_hunt_d71aced8:

    # me "Ты что-то хочешь мне сказать?"
    me "你有什么想对我说的吗？"

# game/a13/5little_hunt.rpy:355
translate english little_hunt_f53988ed:

    # eva "Нет... нет... ничего. Просто хотела пожелать спокойной ночи."
    eva "没有……没有……没什么。只是想祝你晚安。"

# game/a13/5little_hunt.rpy:356
translate english little_hunt_d78fc624:

    # me "Спокойной ночи."
    me "晚安。"

# game/a13/5little_hunt.rpy:358
translate english little_hunt_3df022c6:

    # eva "Ты такой теплый. Рядом с тобой я точно не заболею."
    eva "你好暖和。靠着你我肯定不会生病。"

# game/a13/5little_hunt.rpy:359
translate english little_hunt_66948067_1:

    # me "Мгм."
    me "嗯。"

# game/a13/5little_hunt.rpy:360
translate english little_hunt_69f721f0:

    # eva "И ты тоже не заболеешь. Мы ведь делимся друг с другом теплом."
    eva "你也不会生病的。我们这是共享体温呢。"

# game/a13/5little_hunt.rpy:361
translate english little_hunt_3820771a_9:

    # me "..."
    me "..."

# game/a13/5little_hunt.rpy:362
translate english little_hunt_30e4427e:

    # eva "[mename], ты спишь?"
    eva "[mename]，你睡着了吗？"

# game/a13/5little_hunt.rpy:363
translate english little_hunt_461a2c75:

    # me "Почти."
    me "快了。"

# game/a13/5little_hunt.rpy:364
translate english little_hunt_b766a2d0:

    # eva "Расскажешь историю на ночь?"
    eva "给我讲个睡前故事吧？"

# game/a13/5little_hunt.rpy:365
translate english little_hunt_5a7a7577_1:

    # me "Нет."
    me "不。"

# game/a13/5little_hunt.rpy:366
translate english little_hunt_46170889:

    # eva "Ну и ладно."
    eva "好吧，算了。"

# game/a13/5little_hunt.rpy:367
translate english little_hunt_3820771a_10:

    # me "..."
    me "..."

# game/a13/5little_hunt.rpy:368
translate english little_hunt_e1665042:

    # eva "Знаешь, если ты планируешь какой-то заговор против моего отца лучше скажи сразу. Он тебя повесит и все."
    eva "你知道吗，如果你在计划什么针对我父亲的阴谋，最好现在说清楚。他会把你吊死的，一了百了。"

# game/a13/5little_hunt.rpy:369
translate english little_hunt_3820771a_11:

    # me "..."
    me "..."

# game/a13/5little_hunt.rpy:370
translate english little_hunt_eef361f0:

    # eva "Я бы помогла тебе, но не могу идти против семьи, думаю ты понимаешь. Хотя может и нет. У вас там на юге ни у кого нет чести."
    eva "我倒是想帮你，但我不能背叛家人，我想你能理解。不过也许你不能理解。你们南方那边，一个个都毫无廉耻。"

# game/a13/5little_hunt.rpy:371
translate english little_hunt_3820771a_12:

    # me "..."
    me "..."

# game/a13/5little_hunt.rpy:372
translate english little_hunt_c143123b:

    # eva "Ты наверняка что-то планируешь. Я почти уверена. Мне уже не терпится увидеть, как тебя казнят..."
    eva "你肯定在计划着什么。我几乎可以确定。我都等不及看你被处决了……"

# game/a13/5little_hunt.rpy:373
translate english little_hunt_3820771a_13:

    # me "..."
    me "..."

# game/a13/5little_hunt.rpy:374
translate english little_hunt_53352fc0_3:

    # eva "..."
    eva "..."

# game/a13/5little_hunt.rpy:376
translate english little_hunt_4043ec54:

    # blood "Свет еще не видывал битвы такого масштаба."
    blood "这世间还从未见过如此规模的战役。"

# game/a13/5little_hunt.rpy:377
translate english little_hunt_fd3ba679:

    # blood "Сотня тысяч человек будет завтра убивать друг друга."
    blood "明天，十万人将互相厮杀。"

# game/a13/5little_hunt.rpy:378
translate english little_hunt_f16910da:

    # blood "Земля захлебнется в их крови."
    blood "大地将淹没在他们的血泊中。"

# game/a13/5little_hunt.rpy:379
translate english little_hunt_be0fddc5:

    # blood "Воздух пропитает запах металла."
    blood "空气中将弥漫着金属的腥味。"

# game/a13/5little_hunt.rpy:380
translate english little_hunt_d06aa924:

    # blood "Трупов будет столько, что вороны не смогут ходить, набив брюха."
    blood "尸体将堆积如山，乌鸦吃到撑破肚皮，连走都走不动。"

# game/a13/5little_hunt.rpy:381
translate english little_hunt_3d69508f:

    # blood "А те что выживут - будут завидовать мертвым. Еще десятилетия города будут заполнены калеками этой великой битвы."
    blood "而那些幸存者——会羡慕死者。在未来的几十年里，城市里将充斥着这场伟大战役的残废者。"

# game/a13/5little_hunt.rpy:382
translate english little_hunt_330a1769:

    # blood "Это запомнят на столетия."
    blood "这将被铭记几个世纪。"

# game/a13/5little_hunt.rpy:384
translate english little_hunt_7e0194d4:

    # dubov "Этого все еще можно избежать."
    dubov "这一切仍然可以避免。"

# game/a13/5little_hunt.rpy:385
translate english little_hunt_30709443:

    # blood "Ты согласен сдаться?"
    blood "你同意投降吗？"

# game/a13/5little_hunt.rpy:386
translate english little_hunt_954d1734:

    # dubov "Нет."
    dubov "不。"

# game/a13/5little_hunt.rpy:387
translate english little_hunt_c89c4022:

    # blood "В таком случае этого избежать нельзя."
    blood "既然如此，就无法避免了。"

# game/a13/5little_hunt.rpy:388
translate english little_hunt_fc3606ed:

    # dubov "Я предлагаю тебе то, что предлагал уже неоднократно."
    dubov "我向你提出的，是我反复提议过的东西。"

# game/a13/5little_hunt.rpy:389
translate english little_hunt_bf8bd6de:

    # blood "Нет. Ты смел, что пришел сюда. Ты ведь знаешь, что я могу схватить и убить тебя."
    blood "不。你敢来这里，胆子不小。你清楚我完全可以抓住你，杀了你。"

# game/a13/5little_hunt.rpy:390
translate english little_hunt_6908f19d:

    # dubov "В этом и разница. Я командую моими людьми, но моя жизнь ничего не значит. Если я умру - северяне все равно будут биться. А если умрешь ты - твоя армия повернет назад."
    dubov "这就是区别所在。我指挥我的人，但我的生命无足轻重。如果我死了，北方人依然会战斗。但如果你死了，你的军队就会掉头回去。"

# game/a13/5little_hunt.rpy:391
translate english little_hunt_21e2daf5:

    # ubov "Они не знают, зачем ты ведешь их в бой."
    ubov "他们不知道你为何带领他们奔赴战场。"

# game/a13/5little_hunt.rpy:392
translate english little_hunt_b8668388:

    # blood "Так ты пришел убить меня?"
    blood "所以，你是来杀我的？"

# game/a13/5little_hunt.rpy:393
translate english little_hunt_a6943881:

    # dubov "Я пришел вразумить тебя. Вы не выиграете."
    dubov "我是来让你清醒的。你们赢不了的。"

# game/a13/5little_hunt.rpy:394
translate english little_hunt_dad5471a:

    # blood "Может быть. Но вы тоже не выиграете. Ты собрал тут весь Север, а я лишь один свой легион. Даже если завтра вы победите - я приду снова."
    blood "也许吧。但你们也赢不了。你集结了整个北方，而我仅仅动用了我的一个军团。就算明天你们赢了，我还会卷土重来。"

# game/a13/5little_hunt.rpy:395
translate english little_hunt_dd86485a:

    # blood "Где ты возьмешь еще людей?"
    blood "你去哪里再召集人手？"

# game/a13/5little_hunt.rpy:396
translate english little_hunt_355ac765:

    # dubov "А для тебя жизни твоих подданных не важны? Империя состоит из них, если ты забыл."
    dubov "难道你不在乎你臣民的性命吗？帝国由他们组成，如果你忘了的话。"

# game/a13/5little_hunt.rpy:397
translate english little_hunt_e84825df:

    # blood "Я здесь именно для того, чтобы их спасти. Дело не в Империи. Дело в нашем народе от Юга и до Севера. Либо наш народ будет един, либо мы погибнем, как эльфы."
    blood "我正是为此而来，为了拯救他们。这与帝国无关。这关乎我们从南到北的整个民族。要么我们民族团结统一，要么我们就会像精灵一样消亡。"

# game/a13/5little_hunt.rpy:398
translate english little_hunt_3348ef81:

    # dubov "Эльфы живы."
    dubov "精灵还活着呢。"

# game/a13/5little_hunt.rpy:399
translate english little_hunt_e5b5369f:

    # blood "Их участь хуже смерти. Я не позволю людскому роду гнить в болотах Долины, потому что северянам захотелось свободы."
    blood "他们的命运比死亡更糟。我不会让人类因为北方人想要自由，就烂在峡谷的沼泽地里。"

# game/a13/5little_hunt.rpy:400
translate english little_hunt_2d4657e0:

    # dubov "Твоя жажда власти разъединяет наш народ, а не объединяет его."
    dubov "你对权力的渴望正在分裂我们的民族，而非团结它。"

# game/a13/5little_hunt.rpy:401
translate english little_hunt_a5981b15:

    # blood "Власти? По-твоему, я хочу власти? Я закаляю наш народ в единый клинок, вот и все."
    blood "权力？你觉得我想要权力？我是在把我们民族锤炼成一把统一的利剑，仅此而已。"

# game/a13/5little_hunt.rpy:402
translate english little_hunt_90d00589:

    # dubov "Ты сошел с ума. Или делаешь вид."
    dubov "你疯了。或者是在装疯。"

# game/a13/5little_hunt.rpy:404
translate english little_hunt_e3cdb49b:

    # me "Я просто знаю больше чем ты."
    me "我只是知道的比你多。"

# game/a13/5little_hunt.rpy:405
translate english little_hunt_4da959c5:

    # dubov "Я знаю о пророчестве. Мой род идет от Лотрика так же как и твой."
    dubov "我知道那个预言。我的家族血脉，和你一样，都源自Lotric。"

# game/a13/5little_hunt.rpy:406
translate english little_hunt_c6bef626:

    # me "Тогда чему ты сопротивляешься? Ты не веришь в пророчество?"
    me "那你还在抗拒什么？你不相信这个预言？"

# game/a13/5little_hunt.rpy:407
translate english little_hunt_5b5673d2:

    # dubov "А это не имеет значения."
    dubov "这无关紧要。"

# game/a13/5little_hunt.rpy:408
translate english little_hunt_1b32cfea:

    # me "Как это?"
    me "怎么会无关紧要？"

# game/a13/5little_hunt.rpy:409
translate english little_hunt_ccacc685:

    # dubov "Допустим я верю. Допустим ты делаешь это, чтобы объединить наш народ в единый клинок. С чего ты взял, что должен быть тем, кто держит этот меч за рукоять."
    dubov "就算我相信。就算你做这一切是为了把我们民族团结成一把统一的利剑。你凭什么认为，握着这把剑柄的人非得是你。"

# game/a13/5little_hunt.rpy:410
translate english little_hunt_23806bfa:

    # blood "Это мое право по крови."
    blood "这是我的血统赋予的权力。"

# game/a13/5little_hunt.rpy:411
translate english little_hunt_739287c7:

    # dubov "Слышу в этих словах жажду власти тирана, а не страдания мессии."
    dubov "我听到的这些话，是一个渴望权力的暴君的声音，而不是一个救世主的苦痛。"

# game/a13/5little_hunt.rpy:412
translate english little_hunt_abed65ce:

    # me "А кто это должен быть? Ты?"
    me "那该是谁？你吗？"

# game/a13/5little_hunt.rpy:413
translate english little_hunt_36d3d4c8:

    # dubov "Может и я."
    dubov "也许是我。"

# game/a13/5little_hunt.rpy:414
translate english little_hunt_95b72799:

    # me "Так в этом дело. Ты хочешь быть Императором."
    me "原来如此。你想当皇帝。"

# game/a13/5little_hunt.rpy:415
translate english little_hunt_954d1734_1:

    # dubov "Нет."
    dubov "不。"

# game/a13/5little_hunt.rpy:417
translate english little_hunt_915afc1a:

    # dubov "Пророчество не сбылось. Оно должно было случится при твоей жизни, но ты мёртв. Ты не избранный."
    dubov "预言没有实现。它本该在你活着的时候发生，但你已经死了。你不是那个天选之人。"

# game/a13/5little_hunt.rpy:418
translate english little_hunt_2275f168:

    # blood "Я не мёртв."
    blood "我没死。"

# game/a13/5little_hunt.rpy:419
translate english little_hunt_6e6a665c:

    # dubov "Мёртв. Та комета ничего не значила. Ты зря убивал наш народ."
    dubov "死了。那颗彗星什么意义都没有。你白白屠杀了我们的同胞。"

# game/a13/5little_hunt.rpy:420
translate english little_hunt_3b0b8440:

    # me "Я объединял его."
    me "我是在统一他们。"

# game/a13/5little_hunt.rpy:421
translate english little_hunt_f9fbc4c4:

    # dubov "Правда? Меч, что ты ковал, разбился вдребезги, как только ты перестал дышать."
    dubov "真的吗？你所锻造的剑，在你停止呼吸的那一刻，就碎成了齑粉。"

# game/a13/5little_hunt.rpy:422
translate english little_hunt_95d4ba13:

    # me "Я еще дышу, старик."
    me "我还在呼吸呢，老家伙。"

# game/a13/5little_hunt.rpy:423
translate english little_hunt_19493c4f:

    # dubov "Это уже не ты. Но может это и хорошо."
    dubov "这已经不是你了。但也许这是件好事。"

# game/a13/5little_hunt.rpy:424
translate english little_hunt_e2d4bfa1:

    # me "Что же в этом хорошего?"
    me "这有什么好的？"

# game/a13/5little_hunt.rpy:425
translate english little_hunt_7cc7321a:

    # dubov "Ты никогда не думал, что люди должны объединится сами? Даже если пророчество правда, мы не знаем когда именно оно сбудется."
    dubov "你从没想过，人们应该自己团结起来？就算预言是真的，我们也不知道它究竟何时才能应验。"

# game/a13/5little_hunt.rpy:426
translate english little_hunt_2325fa76_1:

    # me "И что?"
    me "那又怎样？"

# game/a13/5little_hunt.rpy:427
translate english little_hunt_f37ae1ba:

    # dubov "А значит поливать землю кровью вредно. Ты не помогаешь людям объединится. Ты куешь железные куски, соединяя их своей кровью. Но когда ты умрешь, а все мы смертны..."
    dubov "这就是说，用鲜血浇灌大地是有害的。你不是在帮助人们团结。你是在锻造一块块的铁片，用你的血把它们焊在一起。但当你死后，而我们都是凡人……"

# game/a13/5little_hunt.rpy:428
translate english little_hunt_815b8d40:

    # dubov "Когда такой правитель умирает - все что он строил и ковал рассыпается."
    dubov "当这样的统治者死去时，他所建造和锻造的一切都会分崩离析。"

# game/a13/5little_hunt.rpy:429
translate english little_hunt_84cb2c27:

    # me "И что же ты предлагаешь? Ждать смерти, как эльфы? Они тоже верили, что верны свободе, друг другу и своему народу, а когда мы приплыли, они еще год спорили, как воевать, пока мы строили пирамиды их голов."
    me "那你的建议是什么？像精灵一样等待灭亡？他们也曾经相信自由、彼此信任、忠于自己的同胞，然而当我们登陆时，他们还花了一年时间争论该如何作战，而我们则用他们的头颅堆起了金字塔。"

# game/a13/5little_hunt.rpy:430
translate english little_hunt_0eefff44:

    # dubov "Будь достоин."
    dubov "要配得上。"

# game/a13/5little_hunt.rpy:431
translate english little_hunt_c1542da7:

    # me "Достоин?"
    me "配得上？"

# game/a13/5little_hunt.rpy:432
translate english little_hunt_029429e8:

    # dubov "Да."
    dubov "是的。"

# game/a13/5little_hunt.rpy:434
translate english little_hunt_cdf3bc52:

    # blood "Что же это значит?"
    blood "这是什么意思？"

# game/a13/5little_hunt.rpy:435
translate english little_hunt_f3ae5d78:

    # dubov "Кровью не сковать крепкий меч. Север не подчинится тирану. Но достойному правителю не нужно ее проливать без надобности. Люди пойдут за ним и так."
    dubov "用血铸不成利剑。北方不会屈服于暴君。但对于一个配得上的统治者，他不需要无故流血，人们同样会追随他。"

# game/a13/5little_hunt.rpy:436
translate english little_hunt_a5bc9808:

    # me "Люди сами мне подчиняться?"
    me "人们会自愿臣服于我？"

# game/a13/5little_hunt.rpy:437
translate english little_hunt_bfacfe40:

    # dubov "Тому, кто этого достоин."
    dubov "只会臣服于配得上的那个人。"

# game/a13/5little_hunt.rpy:438
translate english little_hunt_ac5a58aa:

    # me "Я достоин."
    me "我配得上。"

# game/a13/5little_hunt.rpy:439
translate english little_hunt_443faf9e:

    # north "Правда?"
    north "真的吗？"

# game/a13/5little_hunt.rpy:440
translate english little_hunt_78d69334:

    # me "Правда. Север будет моим."
    me "真的。北方将属于我。"

# game/a13/5little_hunt.rpy:441
translate english little_hunt_34c0b1bb:

    # north "В твоих словах страх. Ты не правитель, ты испуганный мальчишка, что боится приехать домой без новой короны."
    north "你的话里充满了恐惧。你不是统治者，你只是一个害怕空手回家的、吓破了胆的小男孩。"

# game/a13/5little_hunt.rpy:442
translate english little_hunt_cae14e92:

    # me "Это ложь."
    me "这是谎言。"

# game/a13/5little_hunt.rpy:443
translate english little_hunt_b5d5ce1b:

    # north "Нет... это правда... ты недостоин. Ты и сам это знаешь. Ты понятия не имеешь как вести за собой людей. У тебя нет ничего кроме твоей крови и короны."
    north "不……这是事实……你不配。你自己也清楚这一点。你根本不知道如何带领人民。除了你的血统和王冠，你一无所有。"

# game/a13/5little_hunt.rpy:444
translate english little_hunt_d7d0f447:

    # me "Север будет моим."
    me "北方将属于我。"

# game/a13/5little_hunt.rpy:445
translate english little_hunt_103659c5:

    # north "Твоим? Зачем он тебе, [mename] Стархэд?"
    north "属于你？你要它做什么，[mename]·Starthead？"

# game/a13/5little_hunt.rpy:446
translate english little_hunt_e1a32faf:

    # me "Я должен защитить свой народ."
    me "我必须保护我的人民。"

# game/a13/5little_hunt.rpy:447
translate english little_hunt_9435f212:

    # north "Должен..."
    north "必须……"

# game/a13/5little_hunt.rpy:448
translate english little_hunt_fc30fd2b:

    # me "Да."
    me "是的。"

# game/a13/5little_hunt.rpy:449
translate english little_hunt_4be67922:

    # north "По крайней мере в тебе нет лжи... Но достойный правитель не только честен, но и обладает терпением... сейчас ты не получишь чего хочешь. Но если будешь терпелив..."
    north "至少，你身上没有谎言……但是，一个配得上的统治者，不仅要诚实，还要拥有耐心……现在，你不会得到你想要的。但如果你有耐心……"

# game/a13/5little_hunt.rpy:450
translate english little_hunt_620d02a2:

    # me "То стану достойным?"
    me "我就会变得配得上？"

# game/a13/5little_hunt.rpy:451
translate english little_hunt_03ff9b3b:

    # north "Возможно."
    north "也许吧。"

# game/a13/5little_hunt.rpy:452
translate english little_hunt_5d432dc7:

    # me "А если я захочу забрать то, что мое, сейчас?"
    me "那如果我想现在就夺回属于我的东西呢？"

# game/a13/5little_hunt.rpy:455
translate english little_hunt_86598cdf:

    # north "{size=+5}ПОПРОБУЙ!{/size}"
    north "{size=+5}那你试试看！{/size}"

# game/a13/5little_hunt.rpy:457
translate english little_hunt_b5617c5e:

    # me "Ох..."
    me "啊……"

# game/a13/5little_hunt.rpy:458
translate english little_hunt_e76487db:

    # eva "Ты в порядке?"
    eva "你还好吗？"

# game/a13/5little_hunt.rpy:459
translate english little_hunt_e2f9374e:

    # me "Нет. Кошмар приснился."
    me "不好。做了个噩梦。"

# game/a13/5little_hunt.rpy:460
translate english little_hunt_66f26d0b:

    # eva "Про привидений?"
    eva "梦到鬼怪了？"

# game/a13/5little_hunt.rpy:461
translate english little_hunt_d1ed53cc:

    # me "Можно и так сказать. Про привидений прошлого. Да и настоящего тоже."
    me "可以这么说。梦见了过去的幽灵，还有现在的。"

# game/a13/5little_hunt.rpy:462
translate english little_hunt_64c10f64:

    # eva "Дать молока?"
    eva "要喝点牛奶吗？"

# game/a13/5little_hunt.rpy:463
translate english little_hunt_4ad7cb88:

    # me "Не надо. Ты откуда?"
    me "不用了。你从哪儿过来的？"

# game/a13/5little_hunt.rpy:464
translate english little_hunt_ca6037d9:

    # eva "Я... нужно было отлучиться."
    eva "我……刚才需要离开一下。"

# game/a13/5little_hunt.rpy:465
translate english little_hunt_2dc2da16:

    # me "Отлучиться? Ночью?"
    me "离开？大半夜的？"

# game/a13/5little_hunt.rpy:466
translate english little_hunt_288e0222:

    # eva "Не заставляй меня объяснять, зачем нужно отлучаться ночью."
    eva "别逼我解释为什么需要夜里离开一下。"

# game/a13/5little_hunt.rpy:467
translate english little_hunt_3820771a_14:

    # me "..."
    me "..."

# game/a13/5little_hunt.rpy:468
translate english little_hunt_958caab8:

    # eva "Я писать ходила."
    eva "我去解手了。"

# game/a13/5little_hunt.rpy:469
translate english little_hunt_aead60c4:

    # me "Я понял. Чем пахнет?"
    me "我知道。这是什么味儿？"

# game/a13/5little_hunt.rpy:470
translate english little_hunt_051c38d5:

    # eva "Тут рядом гора из олених кишок, ты как думаешь?"
    eva "旁边就是一堆鹿内脏，你说呢？"

# game/a13/5little_hunt.rpy:471
translate english little_hunt_e159bbcf:

    # me "Ладно. Ложись."
    me "好吧。躺下吧。"

# game/a13/5little_hunt.rpy:473
translate english little_hunt_943138db:

    # eva "Так о чем был сон?"
    eva "那，你梦到什么了？"

# game/a13/5little_hunt.rpy:474
translate english little_hunt_3d9fe6d2:

    # me "Я же говорю - кошмар."
    me "我说了——是噩梦。"

# game/a13/5little_hunt.rpy:475
translate english little_hunt_aba12d46:

    # eva "Ну у кошмаров тоже есть детали. Кто тебя напугал?"
    eva "噩梦也有细节啊。谁吓到你了？"

# game/a13/5little_hunt.rpy:476
translate english little_hunt_670f2070:

    # me "Не поверишь... волк."
    me "说出来你可能不信……是狼。"

# game/a13/5little_hunt.rpy:477
translate english little_hunt_dc04a05d:

    # eva "Которого мы сегодня не подстрелили?"
    eva "我们今天没射中的那只？"

# game/a13/5little_hunt.rpy:478
translate english little_hunt_bc4492ee:

    # me "Не знаю. Тот, во сне, был раз в двадцать больше."
    me "不知道。梦里的那只，要大上二十倍。"

# game/a13/5little_hunt.rpy:479
translate english little_hunt_e70bdb41:

    # eva "Ого. Огромный."
    eva "哇哦。好大。"

# game/a13/5little_hunt.rpy:480
translate english little_hunt_ae18987b:

    # me "Ага. Хотел меня сожрать."
    me "嗯。想把我吃掉。"

# game/a13/5little_hunt.rpy:481
translate english little_hunt_8c8a6ea5:

    # eva "За что?"
    eva "为什么？"

# game/a13/5little_hunt.rpy:482
translate english little_hunt_dfcdbac7:

    # me "За мою дерзость."
    me "因为我太狂妄了。"

# game/a13/5little_hunt.rpy:483
translate english little_hunt_25e069ea:

    # eva "А зачем дерзить такому большому волку?"
    eva "为什么要对那么大一头狼狂妄？"

# game/a13/5little_hunt.rpy:484
translate english little_hunt_ca4033b0:

    # me "По-твоему я контролирую то, что происходит во сне?"
    me "你觉得我能控制梦里发生的事吗？"

# game/a13/5little_hunt.rpy:485
translate english little_hunt_d4dece6a:

    # eva "...что ты ему сказал?"
    eva "……你跟他说什么了？"

# game/a13/5little_hunt.rpy:486
translate english little_hunt_3c41e6b9:

    # me "Что Север мой."
    me "我说北方是我的。"

# game/a13/5little_hunt.rpy:487
translate english little_hunt_38b6133c:

    # eva "Ну значит он правильно тебя сожрал."
    eva "那他把你吃掉是对的。"

# game/a13/5little_hunt.rpy:488
translate english little_hunt_6ab05865_2:

    # me "Наверное."
    me "也许吧。"

# game/a13/5little_hunt.rpy:489
translate english little_hunt_7b24b242:

    # eva "Что-то еще было?"
    eva "还有别的吗？"

# game/a13/5little_hunt.rpy:490
translate english little_hunt_4dcbf5cc:

    # me "Твоей отец встречался с моим дедом перед битвой у Синих Гор?"
    me "你父亲在蓝山战役之前，是不是见过我祖父？"

# game/a13/5little_hunt.rpy:491
translate english little_hunt_88a1a869:

    # eva "Мне, по-твоему, лет пятьдесят?"
    eva "你觉得我像是五十岁吗？"

# game/a13/5little_hunt.rpy:492
translate english little_hunt_259bd19f:

    # me "Может он тебе рассказывал."
    me "也许他跟你说过呢。"

# game/a13/5little_hunt.rpy:493
translate english little_hunt_46fcb87e:

    # eva "Неа. А что? Ты это во сне увидел?"
    eva "没有。怎么了？你在梦里看到的？"

# game/a13/5little_hunt.rpy:494
translate english little_hunt_fc30fd2b_1:

    # me "Да."
    me "对。"

# game/a13/5little_hunt.rpy:495
translate english little_hunt_185d96b7:

    # eva "И что они обсуждали?"
    eva "他们谈了什么？"

# game/a13/5little_hunt.rpy:496
translate english little_hunt_76b6010c:

    # me "Да так... предстоящую битву."
    me "也没什么……就是谈谈即将到来的战斗。"

# game/a13/5little_hunt.rpy:497
translate english little_hunt_1d36568a:

    # eva "Ясно."
    eva "哦。"

# game/a13/5little_hunt.rpy:498
translate english little_hunt_3820771a_15:

    # me "..."
    me "..."

# game/a13/5little_hunt.rpy:499
translate english little_hunt_8bf1a1c9:

    # eva "А..."
    eva "那……"

# game/a13/5little_hunt.rpy:500
translate english little_hunt_79654931:

    # me "Давай спать."
    me "睡吧。"

# game/a13/5little_hunt.rpy:501
translate english little_hunt_cf3a1258:

    # eva "Ладно."
    eva "好。"

# game/a13/5little_hunt.rpy:505
translate english little_hunt2_9f2a99fe:

    # "Утром."
    "早上。"

# game/a13/5little_hunt.rpy:506
translate english little_hunt2_f1b08667:

    # me "{i}Ох... моя поясница.{/i}"
    me "{i}哎哟……我的腰。{/i}"

# game/a13/5little_hunt.rpy:507
translate english little_hunt2_9e6e81e8:

    # me "{i}Не стоило спать в такой позе.{/i}"
    me "{i}不该用那个姿势睡觉的。{/i}"

# game/a13/5little_hunt.rpy:508
translate english little_hunt2_8e668d52:

    # me "{i}Ну хоть было действительно тепло.{/i}"
    me "{i}不过，确实暖和。{/i}"

# game/a13/5little_hunt.rpy:509
translate english little_hunt2_af531ac2:

    # me "{i}Наверное из-за этой живой грелки под боком.{/i}"
    me "{i}大概是身边这个暖呼呼的人形抱枕的功劳。{/i}"

# game/a13/5little_hunt.rpy:511
translate english little_hunt2_17ea7ef4:

    # me "Эхэ..."
    me "唉……"

# game/a13/5little_hunt.rpy:512
translate english little_hunt2_83822737:

    # me "{i}Все уже встали. Неужели ждали пока мы проснемся?{/i}"
    me "{i}大家都起来了。难道是在等我们睡醒？{/i}"

# game/a13/5little_hunt.rpy:513
translate english little_hunt2_2a8b8d94:

    # me "{i}Ну, Борис не отрубил мне голову, так что видимо он действительно был не против, чтобы она спала рядом.{/i}"
    me "{i}嗯，Boris没砍我脑袋，看来他确实不反对她睡我旁边。{/i}"

# game/a13/5little_hunt.rpy:514
translate english little_hunt2_c8a8c2bc:

    # me "{i}Пахнет... росой и кишками оленя.{/i}"
    me "{i}闻起来……有露水和鹿内脏的味道。{/i}"

# game/a13/5little_hunt.rpy:515
translate english little_hunt2_0ddc8ee9:

    # me "{i}Нужно вставать.{/i}"
    me "{i}该起床了。{/i}"

# game/a13/5little_hunt.rpy:516
translate english little_hunt2_d6219c16:

    # me "Ты там как?"
    me "你怎么样？"

# game/a13/5little_hunt.rpy:517
translate english little_hunt2_edb9313d:

    # eva "М?"
    eva "嗯？"

# game/a13/5little_hunt.rpy:518
translate english little_hunt2_3962fe8b:

    # me "Пора вставать."
    me "该起来了。"

# game/a13/5little_hunt.rpy:519
translate english little_hunt2_40af765c:

    # eva "Мгм... еще чуть-чуть, ладно?"
    eva "嗯……再一小会儿，行吗？"

# game/a13/5little_hunt.rpy:520
translate english little_hunt2_c477dbb3:

    # me "Не ладно. У меня все затекло."
    me "不行。我浑身都麻了。"

# game/a13/5little_hunt.rpy:521
translate english little_hunt2_f1dadfc2:

    # eva "А у меня все хорошо..."
    eva "我可舒服着呢……"

# game/a13/5little_hunt.rpy:522
translate english little_hunt2_1150228b:

    # me "Не сомневаюсь."
    me "我不怀疑。"

# game/a13/5little_hunt.rpy:523
translate english little_hunt2_dcef1dd3:

    # vlad "Рагга!"
    vlad "拉加！"

# game/a13/5little_hunt.rpy:525
translate english little_hunt2_8d9376c0:

    # vlad "Рагга, вставай приятель."
    vlad "拉加，伙计，醒醒。"

# game/a13/5little_hunt.rpy:526
translate english little_hunt2_613e9e88:

    # dubov "Что случилось?"
    dubov "怎么了？"

# game/a13/5little_hunt.rpy:527
translate english little_hunt2_902cd045:

    # vlad "Не дышит."
    vlad "没呼吸了。"

# game/a13/5little_hunt.rpy:528
translate english little_hunt2_9cd1f830:

    # dubov "Пульс есть?"
    dubov "有脉搏吗？"

# game/a13/5little_hunt.rpy:529
translate english little_hunt2_71cc2ba0:

    # vlad "Сейчас проверю..."
    vlad "我这就看看……"

# game/a13/5little_hunt.rpy:530
translate english little_hunt2_574c0c20:

    # dubov "Ну?"
    dubov "怎么样？"

# game/a13/5little_hunt.rpy:531
translate english little_hunt2_e1de448e:

    # vlad "Мертв. Сука!"
    vlad "死了。他妈的！"

# game/a13/5little_hunt.rpy:532
translate english little_hunt2_372a81e0:

    # dubov "Как так вышло?"
    dubov "怎么会这样？"

# game/a13/5little_hunt.rpy:533
translate english little_hunt2_41266aa3:

    # vlad "Понятия не имею. Он еще теплый!"
    vlad "我完全不知道。尸体还温着呢！"

# game/a13/5little_hunt.rpy:534
translate english little_hunt2_22b309e8:

    # dubov "Ночью было тихо, не волки же это..."
    dubov "夜里很安静，不可能是狼……"

# game/a13/5little_hunt.rpy:535
translate english little_hunt2_9bb9aae4:

    # vlad "Он не ранен. Крови нет."
    vlad "没有伤口。没有血。"

# game/a13/5little_hunt.rpy:536
translate english little_hunt2_efc31727:

    # dubov "А пасть?"
    dubov "嘴巴呢？"

# game/a13/5little_hunt.rpy:538
translate english little_hunt2_60782264:

    # me "Что случилось?"
    me "出什么事了？"

# game/a13/5little_hunt.rpy:539
translate english little_hunt2_9b84ecb6:

    # dubov "Кто-то сюда приходил?"
    dubov "夜里有人来过吗？"

# game/a13/5little_hunt.rpy:540
translate english little_hunt2_4f6ec6f2:

    # yuka "Нет, мой король. Мы охраняли всю ночь."
    yuka "没有，我的国王。我们守了一整夜。"

# game/a13/5little_hunt.rpy:541
translate english little_hunt2_24e208f6:

    # dubov "И никто даже глаза не прикрыл? На секунду?"
    dubov "连眼皮都没合一下？一秒都没有？"

# game/a13/5little_hunt.rpy:542
translate english little_hunt2_792a9f35:

    # yuka "Мой король..."
    yuka "我的国王……"

# game/a13/5little_hunt.rpy:543
translate english little_hunt2_51992866:

    # dubov "Ладно, что там с пастью?"
    dubov "算了，它嘴巴怎么样了？"

# game/a13/5little_hunt.rpy:544
translate english little_hunt2_4a63bc3e:

    # vlad "Крови нет... хотя..."
    vlad "没血……但……"

# game/a13/5little_hunt.rpy:545
translate english little_hunt2_71e7acd9:

    # dubov "Что?"
    dubov "什么？"

# game/a13/5little_hunt.rpy:546
translate english little_hunt2_8d921a12:

    # me "Его рвало?"
    me "它吐了？"

# game/a13/5little_hunt.rpy:547
translate english little_hunt2_2f65cf0c:

    # yuka "Рядом следы. Вижу рвоту."
    yuka "旁边有痕迹。我看到呕吐物了。"

# game/a13/5little_hunt.rpy:548
translate english little_hunt2_87d04bca:

    # vlad "Пахнет черноплодом... да. Вот шкурки..."
    vlad "闻着有黑浆果的味道……嗯。这里有果皮……"

# game/a13/5little_hunt.rpy:549
translate english little_hunt2_c495e37b:

    # dubov "Наелся ягод выходит."
    dubov "看来是吃浆果了。"

# game/a13/5little_hunt.rpy:550
translate english little_hunt2_0c76be7e:

    # yuka "Черноплод даже лесные звери не трогают, собаки тем более."
    yuka "黑浆果连林中的野兽都不碰，狗就更不会了。"

# game/a13/5little_hunt.rpy:551
translate english little_hunt2_645d2110:

    # vlad "Он умный был, не стал бы есть его просто так."
    vlad "它很聪明，不会无缘无故吃这个的。"

# game/a13/5little_hunt.rpy:552
translate english little_hunt2_aca777d9:

    # dubov "Но его же рвало им. Значит он как-то попал внутрь?"
    dubov "但它就是吐了这个。这说明它不知怎么的，把这东西吃到肚子里去了？"

# game/a13/5little_hunt.rpy:553
translate english little_hunt2_8ea034c3:

    # me "Может случайно съел?"
    me "也许是意外吃到的？"

# game/a13/5little_hunt.rpy:554
translate english little_hunt2_c7ae26d3:

    # yuka "Настолько много? Черноплод отвратительный на вкус."
    yuka "能吃这么多？黑浆果味道糟糕透了。"

# game/a13/5little_hunt.rpy:555
translate english little_hunt2_63df93a6:

    # vlad "Значит он его глотал."
    vlad "那它就是大口吞下去的。"

# game/a13/5little_hunt.rpy:556
translate english little_hunt2_14fc29ec:

    # dubov "Звучит сомнительно."
    dubov "这听着也说不通啊。"

# game/a13/5little_hunt.rpy:558
translate english little_hunt2_4e2ada9c:

    # eva "Эх... какое приятное утро, правда?"
    eva "唉……真是个愉快的早晨，对吧？"

# game/a13/5little_hunt.rpy:559
translate english little_hunt2_8ea0af2e:

    # dubov "Не очень."
    dubov "不觉得。"

# game/a13/5little_hunt.rpy:560
translate english little_hunt2_04cf53db:

    # eva "Почему?"
    eva "为什么？"

# game/a13/5little_hunt.rpy:561
translate english little_hunt2_34c2fd2a:

    # dubov "Случайно не знаешь, почему собака Влада мертва?"
    dubov "你不会碰巧知道，Vlad的狗为什么会死吧？"

# game/a13/5little_hunt.rpy:562
translate english little_hunt2_b01cc7a4:

    # eva "Понятия не имею, я ее хозяйка что ли?"
    eva "我怎么知道，我又不是它的主人，对吧？"

# game/a13/5little_hunt.rpy:563
translate english little_hunt2_3839fd2c:

    # dubov "Она наелась ягод."
    dubov "它吃浆果了。"

# game/a13/5little_hunt.rpy:564
translate english little_hunt2_6798ff41:

    # eva "И что?"
    eva "然后呢？"

# game/a13/5little_hunt.rpy:565
translate english little_hunt2_6c904c91:

    # dubov "Ядовитых. Черноплод."
    dubov "有毒的浆果。黑浆果。"

# game/a13/5little_hunt.rpy:566
translate english little_hunt2_d545dbe5:

    # eva "Какая тупая псина, они же ядовиты."
    eva "多蠢的狗，不知道那东西有毒吗。"

# game/a13/5little_hunt.rpy:567
translate english little_hunt2_fa74781a:

    # dubov "Собака не стала бы их есть."
    dubov "狗是不会吃那东西的。"

# game/a13/5little_hunt.rpy:568
translate english little_hunt2_2f43058d:

    # eva "Но сожрала же. Говорю же - видимо очень тупая псина."
    eva "可它就是吃了。我说了——就是条蠢狗。"

# game/a13/5little_hunt.rpy:569
translate english little_hunt2_cc1469a6:

    # dubov "Ева..."
    dubov "Eva……"

# game/a13/5little_hunt.rpy:571
translate english little_hunt2_685e37ae:

    # vlad "Ты это сделала, да?"
    vlad "是你干的，对不对？"

# game/a13/5little_hunt.rpy:572
translate english little_hunt2_1d1e1591:

    # eva "Я? На кой хрен мне это надо?"
    eva "我？我干嘛要费这劲？"

# game/a13/5little_hunt.rpy:573
translate english little_hunt2_6e62a61b:

    # vlad "Ты не простила меня за то, что я не попал по волку."
    vlad "你没原谅我没射中那头狼的事。"

# game/a13/5little_hunt.rpy:574
translate english little_hunt2_324c89df:

    # eva "Чего? Да мне плевать на этого волка."
    eva "什么？我才不在乎那头狼呢。"

# game/a13/5little_hunt.rpy:575
translate english little_hunt2_d860be3b:

    # vlad "Я еще думал кто там копошится у кишков ночью."
    vlad "我还在想夜里是谁在那堆内脏旁边窸窸窣窣的。"

# game/a13/5little_hunt.rpy:576
translate english little_hunt2_b1ee2ec1:

    # eva "Ну твоя дебильная псина видимо и копошилась. Наверное сожрала пару кишок, а в них были ягоды."
    eva "嗯，大概就是你的蠢狗在那儿窸窣吧。可能吃了几截肠子，那里面有浆果。"

# game/a13/5little_hunt.rpy:577
translate english little_hunt2_c8c08338:

    # vlad "Олени их тоже не едят."
    vlad "鹿也不吃那个。"

# game/a13/5little_hunt.rpy:578
translate english little_hunt2_475464b3:

    # eva "Да ну."
    eva "切。"

# game/a13/5little_hunt.rpy:579
translate english little_hunt2_4b564a8d:

    # vlad "Да. Ты отравила моего пса?"
    vlad "是的。是不是你毒死了我的狗？"

# game/a13/5little_hunt.rpy:580
translate english little_hunt2_ca95a557:

    # eva "Делать мне нечего, травить каких-то убогих псин. Как я вообще, по-твоему, это сделала?"
    eva "我闲得没事干，去毒死一条可怜的破狗？你觉得我是怎么做到的？"

# game/a13/5little_hunt.rpy:581
translate english little_hunt2_d9815258:

    # vlad "Засунула ягод в мясо или еще удобнее - в кишку."
    vlad "把浆果塞进肉里，或者更方便——塞进肠子里。"

# game/a13/5little_hunt.rpy:582
translate english little_hunt2_b603c030:

    # eva "Там этих кишок полная яма. Как я вообще заставила бы сожрать нужный кусок?"
    eva "那儿肠子堆得跟山一样。我怎么能恰好让它吃下那块？"

# game/a13/5little_hunt.rpy:583
translate english little_hunt2_9dd18595:

    # vlad "Наши собаки не подходят к еде без разрешения. Ты дала ему еду с рук."
    vlad "我们的狗没有命令不会靠近食物。你是亲手喂它的。"

# game/a13/5little_hunt.rpy:584
translate english little_hunt2_273195ea:

    # eva "Фу, я бы никогда не прикоснулась к кишкам и тем более к твоей шелудивой псине."
    eva "呸，我才不会碰那些肠子，更别提碰你那条癞皮狗了。"

# game/a13/5little_hunt.rpy:586
translate english little_hunt2_f4615ee1:

    # dubov "Ева!"
    dubov "Eva！"

# game/a13/5little_hunt.rpy:587
translate english little_hunt2_a54a837d:

    # eva "Ну что?"
    eva "干嘛？"

# game/a13/5little_hunt.rpy:588
translate english little_hunt2_0091aa11:

    # dubov "Ты сделала это?"
    dubov "是不是你干的？"

# game/a13/5little_hunt.rpy:589
translate english little_hunt2_61f1f03e:

    # eva "Нет!"
    eva "不是！"

# game/a13/5little_hunt.rpy:590
translate english little_hunt2_0e6492f9:

    # dubov "А кто?"
    dubov "那是谁？"

# game/a13/5little_hunt.rpy:591
translate english little_hunt2_d4a3b9b2:

    # eva "Понятия не имею. И не надо на меня орать."
    eva "我不知道。别冲我吼。"

# game/a13/5little_hunt.rpy:592
translate english little_hunt2_d08586b3:

    # dubov "Это серьезное дело."
    dubov "这很严重。"

# game/a13/5little_hunt.rpy:593
translate english little_hunt2_1b0b6356:

    # eva "Я ничего не делала! Почему вы обвиняете именно меня? Может его Юка отравил?"
    eva "我什么都没做！你们凭什么就怪我？万一是尤卡下的毒呢？"

# game/a13/5little_hunt.rpy:594
translate english little_hunt2_245658d7:

    # yuka "Я? Зачем мне это?"
    yuka "我？我干嘛这么做？"

# game/a13/5little_hunt.rpy:595
translate english little_hunt2_2733fb66:

    # eva "А мне зачем?"
    eva "那我干嘛这么做？"

# game/a13/5little_hunt.rpy:596
translate english little_hunt2_5c89ab97:

    # dubov "Ты вчера повздорила с Владом."
    dubov "你昨天跟Vlad吵架了。"

# game/a13/5little_hunt.rpy:597
translate english little_hunt2_eb34b11e:

    # eva "И что? Я два дня назад я повздорила с тобой, ты меня наказал, если бы в тот день принц [mename] сломал мне руку, ты был бы виноват, пап?"
    eva "那又怎样？前天我还跟你吵架了呢，你也罚我了，如果那天王子[mename]扭断了我的手，你就有嫌疑了吧，是吗，爸爸？"

# game/a13/5little_hunt.rpy:598
translate english little_hunt2_fb77a88a:

    # dubov "Кстати об этом. [mename]."
    dubov "说到这个。[mename]。"

# game/a13/5little_hunt.rpy:600
translate english little_hunt2_7ee4d8a9:

    # me "Я никому руку не ломал."
    me "我没扭断任何人的手。"

# game/a13/5little_hunt.rpy:601
translate english little_hunt2_c57070fd:

    # dubov "Знаю. Ева ведь спала рядом ночью. Может ты что-то видел? Она куда-нибудь отлучалась?"
    dubov "知道。Eva昨晚睡你旁边的。或许你看到什么了？她夜里离开过吗？"

# game/a13/5little_hunt.rpy:605
translate english little_hunt2_097e2780:

    # me "Ну я спал. Она спала рядом."
    me "嗯，我睡着了。她睡我旁边。"

# game/a13/5little_hunt.rpy:606
translate english little_hunt2_866cc7f3:

    # dubov "Все время она была рядом?"
    dubov "她一直待在你身边吗？"

# game/a13/5little_hunt.rpy:607
translate english little_hunt2_73e69bbd:

    # eva "Он же, блин, спал, как он может знать?"
    eva "他妈的，他睡着了啊，他怎么能知道？"

# game/a13/5little_hunt.rpy:608
translate english little_hunt2_bea6f8b9:

    # dubov "Молчи, я не у тебя спрашиваю."
    dubov "闭嘴，我没问你。"

# game/a13/5little_hunt.rpy:609
translate english little_hunt2_c9d8eed9:

    # me "Я могу отвечать только за те моменты, что бодрствовал."
    me "我只能为我自己醒着的那段时间作证。"

# game/a13/5little_hunt.rpy:610
translate english little_hunt2_fa0277fb:

    # dubov "Разумеется."
    dubov "这是自然。"

# game/a13/5little_hunt.rpy:611
translate english little_hunt2_c3d85d55:

    # me "Она всегда была со мной. Я даже просыпался пару раз..."
    me "她一直在我身边。我中间还醒了几次……"

# game/a13/5little_hunt.rpy:612
translate english little_hunt2_8314cdf6:

    # dubov "И..."
    dubov "然后……"

# game/a13/5little_hunt.rpy:613
translate english little_hunt2_9c6eb58b:

    # eva "Я была рядом."
    eva "我在他旁边。"

# game/a13/5little_hunt.rpy:614
translate english little_hunt2_e1e54932:

    # dubov "Замолчи."
    dubov "闭嘴。"

# game/a13/5little_hunt.rpy:615
translate english little_hunt2_381a4905:

    # me "Она была рядом. В той же позе. Голова у меня на груди."
    me "她就在旁边。跟我睡前一样的姿势。头靠在我胸口。"

# game/a13/5little_hunt.rpy:616
translate english little_hunt2_338901d5:

    # dubov "..."
    dubov "..."

# game/a13/5little_hunt.rpy:617
translate english little_hunt2_b5484d8f:

    # eva "Видишь, папочка? Я не убивала собачку твоего псаря."
    eva "看到了吗，爸爸？我没杀你养狗人的狗。"

# game/a13/5little_hunt.rpy:618
translate english little_hunt2_2a2ca95e:

    # dubov "Но кто-то это сделал."
    dubov "但总有人干的。"

# game/a13/5little_hunt.rpy:619
translate english little_hunt2_15692a50:

    # eva "Ищите злодея, я буду первой, кто в него плюнет."
    eva "去找真凶吧，我会是第一个唾弃他的人。"

# game/a13/5little_hunt.rpy:620
translate english little_hunt2_1149dda8:

    # dubov "...собирайте вещи."
    dubov "……收拾东西。"

# game/a13/5little_hunt.rpy:624
translate english little_hunt2_097e2780_1:

    # me "Ну я спал. Она спала рядом."
    me "嗯，我睡着了。她睡我旁边。"

# game/a13/5little_hunt.rpy:625
translate english little_hunt2_866cc7f3_1:

    # dubov "Все время она была рядом?"
    dubov "她一直待在你身边吗？"

# game/a13/5little_hunt.rpy:626
translate english little_hunt2_73e69bbd_1:

    # eva "Он же, блин, спал, как он может знать?"
    eva "他妈的，他睡着了啊，他怎么能知道？"

# game/a13/5little_hunt.rpy:627
translate english little_hunt2_bea6f8b9_1:

    # dubov "Молчи, я не у тебя спрашиваю."
    dubov "闭嘴，我没问你。"

# game/a13/5little_hunt.rpy:628
translate english little_hunt2_c9d8eed9_1:

    # me "Я могу отвечать только за те моменты, что бодрствовал."
    me "我只能为我自己醒着的那段时间作证。"

# game/a13/5little_hunt.rpy:629
translate english little_hunt2_fa0277fb_1:

    # dubov "Разумеется."
    dubov "这是自然。"

# game/a13/5little_hunt.rpy:630
translate english little_hunt2_834549d0:

    # me "Я проснулся разок в середине ночи."
    me "我半夜醒过一回。"

# game/a13/5little_hunt.rpy:631
translate english little_hunt2_99add484:

    # dubov "И?"
    dubov "然后呢？"

# game/a13/5little_hunt.rpy:632
translate english little_hunt2_249065a5:

    # me "Она вернулась откуда-то в этот момент."
    me "那会儿她刚从什么地方回来。"

# game/a13/5little_hunt.rpy:633
translate english little_hunt2_7ea4117d:

    # dubov "Надо же."
    dubov "哦。"

# game/a13/5little_hunt.rpy:634
translate english little_hunt2_042dacc4:

    # eva "Я ходила писать."
    eva "我去解手了。"

# game/a13/5little_hunt.rpy:635
translate english little_hunt2_21a8fac4:

    # me "Больше ничего не было. Она спала рядом все оставшееся время."
    me "除此以外没别的事了。剩下的时间她都睡在我旁边。"

# game/a13/5little_hunt.rpy:636
translate english little_hunt2_338901d5_1:

    # dubov "..."
    dubov "..."

# game/a13/5little_hunt.rpy:637
translate english little_hunt2_e16d7910:

    # eva "Что? Мне надо было терпеть или писать под себя? Если хотите, покажу место куда я писала, особо пытливые могу понюхать и проверить."
    eva "怎么？难道要我憋着，还是尿裤子？要是有谁特别好奇，我可以指给他看我解手的地方，特别有钻研精神的话，还可以凑近了闻闻检查一下。"

# game/a13/5little_hunt.rpy:638
translate english little_hunt2_b6a99b06:

    # dubov "Ни в чем не хочешь признаться?"
    dubov "你真没有什么想承认的吗？"

# game/a13/5little_hunt.rpy:639
translate english little_hunt2_4d98587a:

    # eva "Хочу. Я писаю с самого детства. Привычка такая. Могу писать даже пару раз в день."
    eva "有。我从小就尿尿。这是我的习惯。一天能尿好几次呢。"

# game/a13/5little_hunt.rpy:640
translate english little_hunt2_338901d5_2:

    # dubov "..."
    dubov "..."

# game/a13/5little_hunt.rpy:641
translate english little_hunt2_436b271b:

    # eva "Не смотри на меня так, пап. Я ничего не делала."
    eva "别这样看着我，爸爸。我什么都没做。"

# game/a13/5little_hunt.rpy:642
translate english little_hunt2_1149dda8_1:

    # dubov "...собирайте вещи."
    dubov "……收拾东西。"

# game/a13/5little_hunt.rpy:645
translate english little_hunt2_396c128f:

    # "Час спустя."
    "一个小时以后。"

# game/a13/5little_hunt.rpy:646
translate english little_hunt2_b07e858c:

    # eva "...самого большого оленя подстрелила моя бабушка. Его голова висит в спальне родителей."
    eva "……最大的那头鹿是我祖母射的。它的头还挂在我父母卧室里呢。"

# game/a13/5little_hunt.rpy:647
translate english little_hunt2_4c8a6080:

    # me "Удивительная женщина."
    me "了不起的女人。"

# game/a13/5little_hunt.rpy:648
translate english little_hunt2_16ef21d0:

    # eva "Она еще жива."
    eva "她还活着呢。"

# game/a13/5little_hunt.rpy:649
translate english little_hunt2_489a247d:

    # me "Правда?"
    me "真的？"

# game/a13/5little_hunt.rpy:650
translate english little_hunt2_03875dfd:

    # eva "Но она уже очень старая."
    eva "但已经很老了。"

# game/a13/5little_hunt.rpy:651
translate english little_hunt2_62ff8f1d:

    # me "Я могу ее увидеть?"
    me "我能见见她吗？"

# game/a13/5little_hunt.rpy:652
translate english little_hunt2_2638f175:

    # eva "Вряд ли. Сейчас ей нездоровится."
    eva "恐怕不行。她现在身体不好。"

# game/a13/5little_hunt.rpy:653
translate english little_hunt2_3508e5a0:

    # me "Может на обратном пути."
    me "也许在回去的路上。"

# game/a13/5little_hunt.rpy:654
translate english little_hunt2_6d333001:

    # eva "Она слепая и у нее старческое слабоумие. Зачем тебе ее видеть?"
    eva "她瞎了，而且有老年痴呆。你到底为什么要见她？"

# game/a13/5little_hunt.rpy:655
translate english little_hunt2_567cff54:

    # me "Я лучше убежусь в этом сам."
    me "我最好亲自确认一下。"

# game/a13/5little_hunt.rpy:656
translate english little_hunt2_6907a2e2:

    # eva "Пфф... если тебе хочется общаться со старыми бабками - общайся, мне все равно."
    eva "切……随你便，如果你喜欢跟老太太聊天，就去聊吧，我无所谓。"

# game/a13/5little_hunt.rpy:659
translate english little_hunt2_c9dcbbe1:

    # me "Может поговорим о том, что ты сделала?"
    me "也许我们该谈谈你干的事？"

# game/a13/5little_hunt.rpy:660
translate english little_hunt2_a0f22b95:

    # eva "А что я сделала?"
    eva "我干了什么？"

# game/a13/5little_hunt.rpy:661
translate english little_hunt2_7181146a:

    # me "Ты знаешь что."
    me "你知道是什么。"

# game/a13/5little_hunt.rpy:662
translate english little_hunt2_0a6463e5:

    # eva "И ты туда же. Не убивала я эту сраную собаку."
    eva "你也跟他们一样。我没杀那条该死的狗。"

# game/a13/5little_hunt.rpy:663
translate english little_hunt2_a38a41b6:

    # me "Ага. Как скажешь."
    me "哦。随你怎么说。"

# game/a13/5little_hunt.rpy:664
translate english little_hunt2_df292935:

    # eva "Если уж на то пошло, то это не собака промазала стрелой из лука."
    eva "要真说起来，放箭射偏的可不是那条狗。"

# game/a13/5little_hunt.rpy:665
translate english little_hunt2_7da68b83:

    # me "Промазал ее хозяин. Поэтому ты решила ему отомстить."
    me "是它的主人。所以你就决定报复他。"

# game/a13/5little_hunt.rpy:666
translate english little_hunt2_ee14cd5b:

    # eva "Если бы я захотела, я бы отомстила ему напрямую."
    eva "我要是想报复，会直接报复他本人。"

# game/a13/5little_hunt.rpy:667
translate english little_hunt2_d2b04ecc:

    # me "Как?"
    me "怎么做？"

# game/a13/5little_hunt.rpy:668
translate english little_hunt2_092928aa:

    # eva "Сказала бы отцу, что он меня трогал. Мы много шли с ним наедине."
    eva "我会跟父亲说，他碰我了。我们单独走了那么远。"

# game/a13/5little_hunt.rpy:669
translate english little_hunt2_089efbd3:

    # me "И он бы тебе поверил? Зная твою репутацию."
    me "凭你的名声，他会信你？"

# game/a13/5little_hunt.rpy:670
translate english little_hunt2_97698c3e:

    # eva "Ему пришлось бы. Если понадобилось бы - я бы и кровь себе пустила."
    eva "他必须信。如果必要的话，我甚至可以自己弄点血出来。"

# game/a13/5little_hunt.rpy:671
translate english little_hunt2_e8af13af:

    # me "Звучишь как психопатка."
    me "你听起来像个变态。"

# game/a13/5little_hunt.rpy:672
translate english little_hunt2_45277492:

    # eva "Это для примера. Я бы так не сделала."
    eva "我只是打个比方。我不会那么做的。"

# game/a13/5little_hunt.rpy:673
translate english little_hunt2_056fb4c6:

    # me "Ладно. Допустим я тебе верю. Кто тогда отравил собаку?"
    me "好吧。就算我信你。那又是谁毒死了狗？"

# game/a13/5little_hunt.rpy:674
translate english little_hunt2_41b558ed:

    # eva "С чего вдруг я должна это знать? И вообще, я не хочу с тобой больше говорить. Ведешь себя как кретин."
    eva "我干嘛非得知道这个？而且我不想再跟你说话了。你表现得像个白痴。"

# game/a13/5little_hunt.rpy:675
translate english little_hunt2_1c50b361:

    # me "Как хочешь."
    me "随你便。"

# game/a13/5little_hunt.rpy:678
translate english little_hunt2_8a23f98b:

    # eva "Спасибо, что прикрыл меня."
    eva "谢谢你替我打掩护。"

# game/a13/5little_hunt.rpy:679
translate english little_hunt2_e37fa57b:

    # me "Прикрыл?"
    me "打掩护？"

# game/a13/5little_hunt.rpy:680
translate english little_hunt2_1b5b6849:

    # eva "Ну знаешь, с собакой."
    eva "嗯，你知道的，就是狗的事。"

# game/a13/5little_hunt.rpy:681
translate english little_hunt2_cf15de9f:

    # me "Да не за что. Я просто сказал правду."
    me "不值一提。我只是说了事实。"

# game/a13/5little_hunt.rpy:682
translate english little_hunt2_3ac6df2d:

    # eva "{size=-3}Ну вообще-то ты сказал не всю правду.{/size}"
    eva "{size=-3}嗯，其实你没说出全部事实。{/size}"

# game/a13/5little_hunt.rpy:683
translate english little_hunt2_92237388:

    # me "{size=-3}В смысле?{/size}"
    me "{size=-3}什么意思？{/size}"

# game/a13/5little_hunt.rpy:684
translate english little_hunt2_03ac9012:

    # eva "{size=-3}Я ведь отлучалась ночью.{/size}"
    eva "{size=-3}我夜里确实离开过呀。{/size}"

# game/a13/5little_hunt.rpy:685
translate english little_hunt2_699f949a:

    # me "{size=-3}Ты ходила писать.{/size}"
    me "{size=-3}你去解手了。{/size}"

# game/a13/5little_hunt.rpy:686
translate english little_hunt2_b13ab86f:

    # eva "{size=-3}Ты этого не знаешь. Это я тебе так сказала. К тому же ты проснулся когда я уже возвращалась. Может меня не было гораздо больше времени, чем требует на ночной туалет, м?{/size}"
    eva "{size=-3}你又不知道。是我这么告诉你的。再说了，你醒的时候我已经在往回走了。说不定我离开的时间，比上个厕所要长得多得多，嗯？{/size}"

# game/a13/5little_hunt.rpy:687
translate english little_hunt2_20c3153b:

    # me "{size=-3}Я чего-то не понимаю или ты теперь пытаешься убедить меня, что ты убила собаку?{/size}"
    me "{size=-3}是我不明白情况，还是你现在正试图说服我你杀了那条狗？{/size}"

# game/a13/5little_hunt.rpy:688
translate english little_hunt2_1a28b2f2:

    # eva "{size=-3}А дело не в собаке.{/size}"
    eva "{size=-3}关键不是狗。{/size}"

# game/a13/5little_hunt.rpy:689
translate english little_hunt2_c77da900:

    # me "{size=-3}А в чем же?{/size}"
    me "{size=-3}那是什么？{/size}"

# game/a13/5little_hunt.rpy:690
translate english little_hunt2_a53c003a:

    # eva "{size=-3}В том что ты меня защитил. Соврал ради меня.{/size}"
    eva "{size=-3}关键是你保护了我。你为了我撒谎。{/size}"

# game/a13/5little_hunt.rpy:691
translate english little_hunt2_55928725:

    # me "{size=-3}Я не врал.{/size}"
    me "{size=-3}我没撒谎。{/size}"

# game/a13/5little_hunt.rpy:692
translate english little_hunt2_2d3cb6db:

    # eva "{size=-3}Умолчал.{/size}"
    eva "{size=-3}是隐瞒了。{/size}"

# game/a13/5little_hunt.rpy:693
translate english little_hunt2_eb5a1bc0:

    # me "{size=-3}Ну.. да...{/size}"
    me "{size=-3}呃……是……{/size}"

# game/a13/5little_hunt.rpy:695
translate english little_hunt2_4d2d5bc5:

    # eva "Спасибо."
    eva "谢谢。"

# game/a13/5little_hunt.rpy:696
translate english little_hunt2_9508d41b:

    # me "За что?"
    me "为什么谢我？"

# game/a13/5little_hunt.rpy:697
translate english little_hunt2_b714b94c:

    # eva "Ради меня еще никто не врал."
    eva "从没有人为了我撒过谎。"

# game/a13/5little_hunt.rpy:698
translate english little_hunt2_72c6f7e3:

    # me "Я не..."
    me "我没……"

# game/a13/5little_hunt.rpy:699
translate english little_hunt2_86cbbe20:

    # eva "Ну да-да. Умолчал. Это одно и то же."
    eva "嗯，是啊。是隐瞒了。都一样。"

# game/a13/5little_hunt.rpy:700
translate english little_hunt2_3646592e:

    # me "Я начинаю думать, что это ты убила собаку."
    me "我开始觉得，狗就是你杀的。"

# game/a13/5little_hunt.rpy:701
translate english little_hunt2_934e88a6:

    # eva "А если это я, то что ты сделаешь?"
    eva "如果是我干的，你会怎么办？"

# game/a13/5little_hunt.rpy:702
translate english little_hunt2_0a930ba1:

    # me "А это ты?"
    me "是你干的吗？"

# game/a13/5little_hunt.rpy:703
translate english little_hunt2_91764459:

    # eva "Я первая задала вопрос. Если это я, ты расскажешь это моему отцу?"
    eva "我先问你的。如果是我干的，你会告诉我父亲吗？"

# game/a13/5little_hunt.rpy:704
translate english little_hunt2_691f4ec8:

    # me "...нет."
    me "……不会。"

# game/a13/5little_hunt.rpy:705
translate english little_hunt2_699d9877:

    # me "Теперь мой вопрос. Это ты сделала?"
    me "现在轮到我问了。是你干的吗？"

# game/a13/5little_hunt.rpy:707
translate english little_hunt2_51b73d8b:

    # eva "Нет."
    eva "不是。"

# game/a13/5little_hunt.rpy:708
translate english little_hunt2_72ed7d30:

    # me "Тогда к чему был этот цирк?"
    me "那刚才那么闹一出是为什么？"

# game/a13/5little_hunt.rpy:709
translate english little_hunt2_b0d6707e:

    # eva "Просто немного тебя подразнила."
    eva "逗你玩一下而已。"

# game/a13/5little_hunt.rpy:710
translate english little_hunt2_cf735e39:

    # me "Ну да... конечно... И кто это тогда сделал?"
    me "嗯……当然……那会是谁干的？"

# game/a13/5little_hunt.rpy:711
translate english little_hunt2_9c0d62f3:

    # eva "Юка."
    eva "尤卡。"

# game/a13/5little_hunt.rpy:712
translate english little_hunt2_60d76925:

    # me "Юка?"
    me "尤卡？"

# game/a13/5little_hunt.rpy:713
translate english little_hunt2_d97339d6:

    # eva "Наверное."
    eva "大概吧。"

# game/a13/5little_hunt.rpy:714
translate english little_hunt2_c1ed3f36:

    # me "Зачем ему это?"
    me "他干嘛要这么做？"

# game/a13/5little_hunt.rpy:715
translate english little_hunt2_fcd0db1d:

    # eva "Завидует. Влад бастард моего отца."
    eva "嫉妒呗。Vlad是我父亲的私生子。"

# game/a13/5little_hunt.rpy:716
translate english little_hunt2_ad02f53a:

    # me "Что?"
    me "什么？"

# game/a13/5little_hunt.rpy:717
translate english little_hunt2_67ff261a:

    # eva "Да ладно, ты правда не заметил как они близки?"
    eva "拜托，你真没注意到他们有多亲近吗？"

# game/a13/5little_hunt.rpy:718
translate english little_hunt2_6487059e:

    # me "Он помогает с охотой."
    me "他在帮忙打猎。"

# game/a13/5little_hunt.rpy:719
translate english little_hunt2_ab9fd9a7:

    # eva "Ты хоть раз слышал, как он называет его 'мой король' или хотя бы 'мой лорд'?"
    eva "你听到过他叫我父亲“我的国王”，或者哪怕“我的大人”吗？"

# game/a13/5little_hunt.rpy:720
translate english little_hunt2_bfaba482:

    # me "...ты сейчас серьезно или опять меня разыгрываешь?"
    me "……你现在是认真的，还是在耍我？"

# game/a13/5little_hunt.rpy:721
translate english little_hunt2_640e54ef:

    # eva "Я серьезно."
    eva "我是认真的。"

# game/a13/5little_hunt.rpy:722
translate english little_hunt2_040fa874:

    # me "Но они же не похожи."
    me "但他们长得不像。"

# game/a13/5little_hunt.rpy:723
translate english little_hunt2_8912541e:

    # eva "Он вышел больше в маму. В жену псаря, которую трахнул мой отец."
    eva "他长得更像他妈妈。我的父亲搞了犬舍主人的老婆。"

# game/a13/5little_hunt.rpy:724
translate english little_hunt2_3820771a:

    # me "..."
    me "..."

# game/a13/5little_hunt.rpy:725
translate english little_hunt2_938a2fdb:

    # eva "Не думал, куда делся сам псарь? Мой отец его повесил, когда тот начал открывать рот."
    eva "你没想过犬舍主人哪去了？我父亲把他吊死了，在他开始多嘴的时候。"

# game/a13/5little_hunt.rpy:726
translate english little_hunt2_06c9f11b:

    # me "Ладно. Это чушь какая-то."
    me "好吧。这真是胡扯。"

# game/a13/5little_hunt.rpy:727
translate english little_hunt2_044795ec:

    # eva "Почему же? Это не чушь. Твой отец, твой дед да и ты сам. У вас наверняка десятки бастардов. Это же привилегия знатного мужчины - трахать простолюдинок."
    eva "怎么胡扯了？根本不是胡扯。你的父亲，你的祖父，还有你自己。你们肯定有几十个私生子。这就是贵族的特权——搞平民女人。"

# game/a13/5little_hunt.rpy:728
translate english little_hunt2_c585ba1b:

    # me "Мой отец может быть, а вот Красный Император был верен своей жене."
    me "我父亲也许是这样，但红皇帝对他妻子很忠诚。"

# game/a13/5little_hunt.rpy:729
translate english little_hunt2_32230db8:

    # eva "Кто тебе это сказал?"
    eva "谁告诉你的？"

# game/a13/5little_hunt.rpy:730
translate english little_hunt2_c1c62188:

    # me "Так в книгах написано, так мой отец мне говорил."
    me "书里是这么写的，我父亲也是这么告诉我的。"

# game/a13/5little_hunt.rpy:731
translate english little_hunt2_ff99b401:

    # eva "Пфф... верь больше в эту чушь."
    eva "切……这种鬼话你也信。"

# game/a13/5little_hunt.rpy:732
translate english little_hunt2_42ac88c4:

    # me "Мы сейчас отстанем от группы."
    me "我们要掉队了。"

# game/a13/5little_hunt.rpy:733
translate english little_hunt2_4f425415:

    # eva "Ладно, пойдем."
    eva "好吧，走吧。"

# game/a13/5little_hunt.rpy:735
translate english little_hunt2_7dac0600:

    # "Пару часов спустя."
    "几个小时以后。"

# game/a13/5little_hunt.rpy:736
translate english little_hunt2_766f355c:

    # me "{i}Ну и охота. Была бы в разы скучнее, если бы не Ева.{/i}"
    me "{i}唉，这次打猎。要不是有Eva在，会更无聊。{/i}"

# game/a13/5little_hunt.rpy:737
translate english little_hunt2_9e13aab3:

    # me "{i}Но и собаки были бы целее...{/i}"
    me "{i}但那样狗也许就还活着……{/i}"

# game/a13/5little_hunt.rpy:738
translate english little_hunt2_7bc856f4:

    # me "{i}Она действительно это сделала?{/i}"
    me "{i}真的是她干的吗？{/i}"

# game/a13/5little_hunt.rpy:739
translate english little_hunt2_150a1224:

    # me "{i}Она конечно все отрицает, но кто, если не она?{/i}"
    me "{i}她当然否认一切，可如果不是她，又会是谁呢？{/i}"

# game/a13/5little_hunt.rpy:740
translate english little_hunt2_46a83e20:

    # me "{i}Тем более за эти дни я уже четко уяснил - если она открывает рот, то либо солжет, либо скажет какую-то глупость.{/i}"
    me "{i}更何况这几天我已经彻底明白了——只要她一开口，要么是在撒谎，要么就是讲些蠢话。{/i}"

# game/a13/5little_hunt.rpy:741
translate english little_hunt2_5c76dbe7:

    # me "{i}...{/i}"
    me "{i}...{/i}"

# game/a13/5little_hunt.rpy:742
translate english little_hunt2_2ab9dd85:

    # me "{i}Но вдруг и вправду не она?{/i}"
    me "{i}但万一真不是她呢？{/i}"

# game/a13/5little_hunt.rpy:743
translate english little_hunt2_171ae1ba:

    # me "{i}Пора на обед.{/i}"
    me "{i}该去吃午饭了。{/i}"

# game/a13/5little_hunt.rpy:746
translate english little_hunt2_9253702d:

    # aurora "[mename]! Рада тебя видеть. Как все прошло?"
    aurora "[mename]！很高兴见到你。一切都顺利吗？"

# game/a13/5little_hunt.rpy:747
translate english little_hunt2_e7ce88cd:

    # me "Нормально."
    me "还行。"

# game/a13/5little_hunt.rpy:748
translate english little_hunt2_ff82587f:

    # aurora "Нормально? Ты поговорил с отцом?"
    aurora "还行？你跟我父亲谈过了吗？"

# game/a13/5little_hunt.rpy:749
translate english little_hunt2_9e30bba8:

    # me "Да. Обсудили, что хотели."
    me "谈了。讨论了我们想讨论的事。"

# game/a13/5little_hunt.rpy:750
translate english little_hunt2_df21fa7a:

    # aurora "А сама охота?"
    aurora "那打猎本身呢？"

# game/a13/5little_hunt.rpy:751
translate english little_hunt2_251306de:

    # me "Было весело. Правда большую часть охоты мы просто шли."
    me "挺有意思。不过大部分时间我们就是在走路。"

# game/a13/5little_hunt.rpy:752
translate english little_hunt2_bc8c3351:

    # aurora "Это правда, что Ева напросилась с вами? Она не сильно надоедала?"
    aurora "Eva是主动要求跟你们去的，是真的吗？她没有太烦人吧？"

# game/a13/5little_hunt.rpy:753
translate english little_hunt2_07a39f86:

    # me "Мне? Не особо."
    me "烦我？不太烦。"

# game/a13/5little_hunt.rpy:754
translate english little_hunt2_81a22595:

    # aurora "А остальным?"
    aurora "那烦别人呢？"

# game/a13/5little_hunt.rpy:755
translate english little_hunt2_6bbe2503:

    # me "Остальным поболее."
    me "烦别人可就厉害多了。"

# game/a13/5little_hunt.rpy:756
translate english little_hunt2_ac3d69b7:

    # aurora "Устал? Холодно было спать в лесу?"
    aurora "累了吗？在林子里睡觉冷吗？"

# game/a13/5little_hunt.rpy:757
translate english little_hunt2_aaaef611:

    # me "Нормально. Я привык."
    me "还好。习惯了。"

# game/a13/5little_hunt.rpy:758
translate english little_hunt2_f2a758c1:

    # aurora "Ты идешь на обед? Слуги приготовили оленину."
    aurora "你去吃午饭吗？仆人们准备了鹿肉。"

# game/a13/5little_hunt.rpy:759
translate english little_hunt2_ab4dc7ef:

    # me "Конечно. Иди, я догоню тебя через пару минут."
    me "当然。你先去，我几分钟后赶上你。"

# game/a13/5little_hunt.rpy:761
translate english little_hunt2_fc7d3a18:

    # "Пару минут спустя."
    "几分钟以后。"

# game/a13/5little_hunt.rpy:762
translate english little_hunt2_c340d6ef:

    # me "{i}Горцы... Надо бы что-нибудь почитать о них, прежде чем отправляться в путь.{/i}"
    me "{i}山地人……在动身前，我最好读点关于他们的东西。{/i}"

# game/a13/5little_hunt.rpy:763
translate english little_hunt2_8fc4fc38:

    # me "{i}Если даже великий и ужасный король Севера говорит, что их стоит опасаться...{/i}"
    me "{i}既然连伟大又可怕的北方国王都说要提防他们……{/i}"

# game/a13/5little_hunt.rpy:764
translate english little_hunt2_ce5a76be:

    # me "{i}Пожалуй их стоит опасаться.{/i}"
    me "{i}那我大概确实该提防他们。{/i}"

# game/a13/5little_hunt.rpy:765
translate english little_hunt2_c7687d80:

    # me "{i}С другой стороны как я смогу прогнать их, если буду вести себя как трус?{/i}"
    me "{i}话说回来，如果我表现得像个懦夫，又怎么能赶走他们呢？{/i}"

# game/a13/5little_hunt.rpy:766
translate english little_hunt2_ddf67ed2:

    # me "{i}Но силы, чтобы выгнать их у меня нет.{/i}"
    me "{i}但我又没有兵力赶走他们。{/i}"

# game/a13/5little_hunt.rpy:767
translate english little_hunt2_893c7387:

    # me "{i}Может объединить силы пострадавших лордов? Хотя они наверняка и без меня справятся.{/i}"
    me "{i}也许可以把受害领主们的力量联合起来？虽然他们可能没有我也能应付。{/i}"

# game/a13/5little_hunt.rpy:768
translate english little_hunt2_5ac854a8:

    # me "{i}Я мог бы взять в помощь людей у лордов по пути.{/i}"
    me "{i}我可以沿途向领主们寻求人手帮助。{/i}"

# game/a13/5little_hunt.rpy:769
translate english little_hunt2_e3af43a6:

    # me "{i}Если они конечно согласятся дать их чужаку. Впрочем, у меня теперь есть грамота от короля Севера...{/i}"
    me "{i}当然了，如果他们愿意借给一个外来人的话。不过嘛，我现在有北方国王的手令了……{/i}"

# game/a13/5little_hunt.rpy:772
translate english little_hunt2_143609e7:

    # eva "{size=+5}БУ!{/size}"
    eva "{size=+5}哇！{/size}"

# game/a13/5little_hunt.rpy:773
translate english little_hunt2_20e7f682:

    # eva "{size=+5}СТРАШНО? КОЛОТЯТЬСЯ НОГИ, ТРЯСУТСЯ?{/size}"
    eva "{size=+5}吓坏了吧？腿抖了吗，发抖了吗？{/size}"

# game/a13/5little_hunt.rpy:774
translate english little_hunt2_97d26502:

    # eva "{size=+5}ПРАВИЛЬНО, ВЕДЬ Я ПРИЗРАК НЕВЕСТЫ, Я УБЬЮ ВСЕХ, В КОМ ТЕЧЕТ КРОВЬ ЛОТРИКА!{/size}"
    eva "{size=+5}这就对了，因为我是鬼新娘，我要杀光所有流着Lotric血液的人！{/size}"

# game/a13/5little_hunt.rpy:776
translate english little_hunt2_6a6247c0:

    # eva "Что, не страшно?"
    eva "怎么，不害怕吗？"

# game/a13/5little_hunt.rpy:777
translate english little_hunt2_b423daab:

    # me "Не очень."
    me "不太怕。"

# game/a13/5little_hunt.rpy:778
translate english little_hunt2_22b3bf21:

    # eva "Издеваешься? Я два часа штору зачем портила?"
    eva "你在耍我吗？我花了两小时把窗帘弄坏，是为了什么？"

# game/a13/5little_hunt.rpy:779
translate english little_hunt2_4a693058:

    # me "Понятия не имею. А что за точки на вуали?"
    me "我怎么知道。你面纱上那些点是干嘛的？"

# game/a13/5little_hunt.rpy:780
translate english little_hunt2_750d982d:

    # eva "Это глаза!"
    eva "那是眼睛！"

# game/a13/5little_hunt.rpy:781
translate english little_hunt2_be91886e:

    # me "Так ведь это вуаль, их не должно быть видно."
    me "可这是面纱啊，眼睛不该被看见才对。"

# game/a13/5little_hunt.rpy:782
translate english little_hunt2_53352fc0:

    # eva "..."
    eva "..."

# game/a13/5little_hunt.rpy:783
translate english little_hunt2_3820771a_1:

    # me "..."
    me "..."

# game/a13/5little_hunt.rpy:784
translate english little_hunt2_bf82dd79:

    # eva "Ты самый умный, да?"
    eva "就你最聪明，是吧？"

# game/a13/5little_hunt.rpy:785
translate english little_hunt2_37510074:

    # me "И что это за призрак?"
    me "这又是什么鬼？"

# game/a13/5little_hunt.rpy:786
translate english little_hunt2_4cb7dcc8:

    # eva "Юлия Ховрина. Призрак из замка Мокрый Холм."
    eva "尤利娅·霍夫琳娜。来自湿丘城堡的鬼魂。"

# game/a13/5little_hunt.rpy:787
translate english little_hunt2_197b86a9:

    # me "Первый раз слышу."
    me "第一次听说。"

# game/a13/5little_hunt.rpy:788
translate english little_hunt2_db4fe664:

    # eva "Это из-за твоего деда он там появился."
    eva "就是因为你的祖父，这鬼魂才会在那出现。"

# game/a13/5little_hunt.rpy:789
translate english little_hunt2_5ac38cf1:

    # me "Почему?"
    me "为什么？"

# game/a13/5little_hunt.rpy:790
translate english little_hunt2_a8db29e1:

    # eva "Его прятали там после смерти Старого Императора, а он вместо благодарности обесчестил дочку хозяев. Хотя уже был женат."
    eva "老皇帝死后，你祖父被藏在那里，但他没有感恩，反而玷污了主人的女儿。虽然他已经结婚了。"

# game/a13/5little_hunt.rpy:791
translate english little_hunt2_05260d5a:

    # me "Я про это не слышал."
    me "我没听说过这事。"

# game/a13/5little_hunt.rpy:792
translate english little_hunt2_1c441aca:

    # eva "Про это знает только моя семья."
    eva "这事只有我家族知道。"

# game/a13/5little_hunt.rpy:793
translate english little_hunt2_4d00bc1c:

    # me "Ну естественно."
    me "嗯，那当然。"

# game/a13/5little_hunt.rpy:795
translate english little_hunt2_84972dde:

    # eva "Так и было! И брата ее убил потом!"
    eva "就是这样的！后来他还杀了她兄弟！"

# game/a13/5little_hunt.rpy:796
translate english little_hunt2_3781327e:

    # me "А брата за что?"
    me "为什么要杀她兄弟？"

# game/a13/5little_hunt.rpy:797
translate english little_hunt2_76053169:

    # eva "Он был возмущен, его можно было понять - он поехал требовать справедливости и Лотрик убил его в поединке."
    eva "他感到愤怒，这可以理解——他是去讨公道的，结果Lotric在决斗中杀了他。"

# game/a13/5little_hunt.rpy:798
translate english little_hunt2_cb7b5dda:

    # me "Потрясающе, тебе нужно писать книги."
    me "真了不起，你应该去写书。"

# game/a13/5little_hunt.rpy:799
translate english little_hunt2_f5188cbd:

    # eva "Я это не придумала!"
    eva "这不是我编的！"

# game/a13/5little_hunt.rpy:800
translate english little_hunt2_3a30e832:

    # me "Да-да."
    me "是，是。"

# game/a13/5little_hunt.rpy:801
translate english little_hunt2_23fa8fb0:

    # eva "Придурок! Это правда."
    eva "混蛋！这是真的。"

# game/a13/5little_hunt.rpy:802
translate english little_hunt2_7e33cee3:

    # me "И призрак тоже правда."
    me "那鬼魂也是真的。"

# game/a13/5little_hunt.rpy:803
translate english little_hunt2_9cd36e33:

    # eva "Да! Крестьяне до сих пор обходят замок стороной!"
    eva "当然！农民们到现在还绕着那个城堡走呢！"

# game/a13/5little_hunt.rpy:804
translate english little_hunt2_2720a72b:

    # me "Невероятная история. Как думаешь, призрака утихомирит оленина?"
    me "真是不可思议的故事。那你觉得，给这鬼来点鹿肉，能安抚它吗？"

# game/a13/5little_hunt.rpy:805
translate english little_hunt2_7004a0de:

    # eva "Чего?"
    eva "什么？"

# game/a13/5little_hunt.rpy:806
translate english little_hunt2_b51fe08c:

    # me "Всех зовут на обед. Предлагаю тебе прийти в этом."
    me "叫大家都去吃午饭了。我建议你就穿这身去。"

# game/a13/5little_hunt.rpy:807
translate english little_hunt2_25032196:

    # eva "Обед? О, боги, я переоденусь, подождешь меня?"
    eva "午饭？哦，天啊，我去换衣服，你等我一下好吗？"

# game/a13/5little_hunt.rpy:808
translate english little_hunt2_3c75eb46:

    # me "Ага. Жду."
    me "嗯。等你。"

# game/a13/5little_hunt.rpy:809
translate english little_hunt2_263e5f91:

    # eva "Я быстро!"
    eva "我很快！"

# game/a13/5little_hunt.rpy:811
translate english little_hunt2_89ada321:

    # lisa "Принц [mename]."
    lisa "[mename]王子。"

# game/a13/5little_hunt.rpy:812
translate english little_hunt2_18197316:

    # me "Можно просто [mename]."
    me "叫我[mename]就好。"

# game/a13/5little_hunt.rpy:813
translate english little_hunt2_3c1d46ff:

    # lisa "Вы уже не принц?"
    lisa "您不再是王子了吗？"

# game/a13/5little_hunt.rpy:814
translate english little_hunt2_8cbd167b:

    # me "Вы ведь тоже принцесса, но я ведь не называю вас принцесса Лиза."
    me "您也是公主，但我并没有称呼您为Lisa公主。"

# game/a13/5little_hunt.rpy:815
translate english little_hunt2_d39ba8ea:

    # lisa "А я калека, а не принцесса."
    lisa "我是个残废，不是公主。"

# game/a13/5little_hunt.rpy:816
translate english little_hunt2_36051555:

    # me "Мне называть вас калека Лиза? Или калека? Или все таки лучше Лиза?"
    me "那我该叫您残废Lisa？还是残废？或者，还是叫Lisa更好？"

# game/a13/5little_hunt.rpy:817
translate english little_hunt2_e9bc18c1:

    # lisa "Калека Лиза звучит смешно."
    lisa "残废Lisa听起来很可笑。"

# game/a13/5little_hunt.rpy:818
translate english little_hunt2_489a247d_1:

    # me "Правда?"
    me "是吗？"

# game/a13/5little_hunt.rpy:819
translate english little_hunt2_b00e6180:

    # lisa "Нет. Но хотя бы правдиво."
    lisa "不是可笑。但至少是实话。"

# game/a13/5little_hunt.rpy:820
translate english little_hunt2_364450fc:

    # me "Как насчет поесть в кругу семьи?"
    me "和家人一起吃顿饭怎么样？"

# game/a13/5little_hunt.rpy:821
translate english little_hunt2_4d969502:

    # lisa "Звучит не очень."
    lisa "听着不太妙。"

# game/a13/5little_hunt.rpy:822
translate english little_hunt2_77c8caf7:

    # me "Вы не любите свою семью?"
    me "您不喜欢您的家人吗？"

# game/a13/5little_hunt.rpy:823
translate english little_hunt2_2d632d8d:

    # lisa "Люблю. Именно поэтому не хочу им портить аппетит своим видом."
    lisa "喜欢。正因如此，我才不想用我这副样子坏了他们的胃口。"

# game/a13/5little_hunt.rpy:824
translate english little_hunt2_89a19b42:

    # me "Мне кажется они к вас уже привыкли."
    me "我觉得他们已经习惯您这个样子了。"

# game/a13/5little_hunt.rpy:825
translate english little_hunt2_1f056913:

    # lisa "Я же знаю как это будет выглядеть - мать будет суетиться, будто я ребенок, а не калека, а Ева будет веси себя... ну как Ева."
    lisa "我知道那会是怎样的场景——母亲会忙前忙后，好像我是个孩子，而不是个残废；Eva则会表现得……跟平时一样混蛋。"

# game/a13/5little_hunt.rpy:827
translate english little_hunt2_2037b8bd:

    # me "И все же без вас семейный обед будет неполноценным."
    me "但少了您，这顿家宴就不完整了。"

# game/a13/5little_hunt.rpy:828
translate english little_hunt2_6706154d:

    # lisa "Зря вы это делаете, принц."
    lisa "您不该这么做的，王子殿下。"

# game/a13/5little_hunt.rpy:829
translate english little_hunt2_b2884594:

    # me "[mename]."
    me "[mename]."

# game/a13/5little_hunt.rpy:830
translate english little_hunt2_26d87577:

    # lisa "Зря вы это делаете, [mename]."
    lisa "您不该这么做的，[mename]。"

# game/a13/5little_hunt.rpy:831
translate english little_hunt2_9dcbe78d:

    # me "Уверен сидеть здесь вам уже надоело."
    me "我肯定您已经在这里坐烦了。"

# game/a13/5little_hunt.rpy:832
translate english little_hunt2_5f2694b1:

    # lisa "Там я тоже буду сидеть, если вы не заметили это мое постоянное положение."
    lisa "在那儿我也是坐着，如果您没注意到的话，我永远都是这个状态。"

# game/a13/5little_hunt.rpy:833
translate english little_hunt2_e1024b07:

    # me "Да. Но окружение будет другим."
    me "是的。但周围环境会不一样。"

# game/a13/5little_hunt.rpy:834
translate english little_hunt2_c0d6b334:

    # lisa "Ладно. Но у меня есть условие."
    lisa "好吧。但我有个条件。"

# game/a13/5little_hunt.rpy:835
translate english little_hunt2_2d904da4:

    # me "Какое?"
    me "什么？"

# game/a13/5little_hunt.rpy:836
translate english little_hunt2_d3c7e86c:

    # lisa "Я буду тоже вести себя невыносимо."
    lisa "我也会表现得让人难以忍受。"

# game/a13/5little_hunt.rpy:837
translate english little_hunt2_db83d1f3:

    # me "Тоже?"
    me "也？"

# game/a13/5little_hunt.rpy:838
translate english little_hunt2_7cf587c3:

    # lisa "Тоже, как Ева."
    lisa "也，像Eva那样。"

# game/a13/5little_hunt.rpy:839
translate english little_hunt2_53258dea:

    # me "Разрешаю. Только чур едой не швыряться."
    me "我准了。只是不许乱扔食物。"

# game/a13/5little_hunt.rpy:840
translate english little_hunt2_869ce5df:

    # lisa "И не бегать по обеденному залу, я поняла."
    lisa "也不许在宴会厅里乱跑，我懂了。"

translate english strings:

    # game/a13/5little_hunt.rpy:602
    old "Оправдать ее"
    new "为她辩护。"

    # game/a13/5little_hunt.rpy:602
    old "Сказать правду"
    new "说出真相。"

# TODO: Translation updated at 2026-03-20 20:01

# game/a13/5little_hunt.rpy:215
translate english little_hunt_97b9723a:

    # me "Так что да. Кроме вашего замка я Севера и не видел."
    me "所以说，除了你们的城堡，我压根没看到北方的样子。"

# game/a13/5little_hunt.rpy:230
translate english little_hunt_abc12267:

    # dubov "Вы голодны? Ели когда-нибудь жареную, только что убитую дичь?"
    dubov "您饿了吗？想尝尝刚杀好的烤野味吗？"

# game/a13/5little_hunt.rpy:237
translate english little_hunt_d3163925:

    # me "А сколько можно?"
    me "能吃几块？"

# game/a13/5little_hunt.rpy:255
translate english little_hunt_a2081876:

    # me "Тебя расстраивает собачий этикет?"
    me "你连狗的吃相都要看不顺眼？"

# game/a13/5little_hunt.rpy:411
translate english little_hunt_9ae28b72:

    # dubov "Слышу в этих словах жажду власти безумца, а не страдания мессии."
    dubov "我听到的这些话，是一个渴望权力的疯子的声音，而不是一个救世主的苦痛。"

# game/a13/5little_hunt.rpy:425
translate english little_hunt_8dbc0ec2:

    # north "Ты никогда не думал, что люди должны объединится сами? Даже если пророчество правда, мы не знаем когда именно оно сбудется."
    north "你从没想过，人们应该自己团结起来？就算预言是真的，我们也不知道它究竟何时才能应验。"

# game/a13/5little_hunt.rpy:427
translate english little_hunt_230d47f9:

    # north "А значит поливать землю кровью вредно. Ты не помогаешь людям объединится. Ты куешь железные куски, соединяя их своей кровью. Но когда ты умрешь, а все мы смертны..."
    north "这就是说，用鲜血浇灌大地是有害的。你不是在帮助人们团结。你是在锻造一块块的铁片，用你的血把它们焊在一起。但当你死后，而我们都是凡人……"

# game/a13/5little_hunt.rpy:435
translate english little_hunt_6511f20d:

    # dubov "Кровью не сковать крепкий меч. Север может пасть к ногам тирана, но такая власть рухнет вместе с ним. Достойному правителю не нужно проливать кровь без надобности. Люди пойдут за ним и так."
    dubov "用血铸不成利剑。北方或许会匍匐在暴君的脚下，但这权力将随他一同崩塌。对于一个配得上的统治者，他不需要无故流血，人们同样会追随他。"

# game/a13/5little_hunt.rpy:436
translate english little_hunt_81e409e2:

    # me "Люди сами мне подчинятся?"
    me "人们会自愿臣服于我？"

# game/a13/5little_hunt.rpy:447
translate english little_hunt_19cacb0e:

    # north "Должен... Все вы верите в свою избранность. Ты. Твой дед. Человек, что держит корону сейчас. Все вы лжете, убиваете и заключаете в цепи. Среди вас не достойных."
    north "必须……你们所有人都相信自己是天选之人。你。你祖父。现在戴着王冠的那个人。你们全都撒谎、杀戮、给人套上枷锁。你们之中没有配得上的人。"

# game/a13/5little_hunt.rpy:448
translate english little_hunt_ac5a58aa_1:

    # me "Я достоин."
    me "我配得上。"

# game/a13/5little_hunt.rpy:449
translate english little_hunt_99b89c4f:

    # north "Он тоже так думает... Проверяет тебя. Старый волк смотрит достоин ли молодой лев, умеет ли он кусать и рвать достаточно сильно, чтобы управлять тем, что никогда его и не было."
    north "他也这么认为……他在考验你。这头老狼在看这头年轻的狮子是否配得上，牙齿是否够尖利，力气是否够大，去掌控那从来就不曾属于他的地盘。"

# game/a13/5little_hunt.rpy:450
translate english little_hunt_c52d48e6:

    # me "Разве у меня есть выбор?"
    me "我难道有选择吗？"

# game/a13/5little_hunt.rpy:451
translate english little_hunt_5b8c873b:

    # north "Нету. Но у того, кто по-настоящему достоин есть терпение. Если все выборы прокляты - зачем вообще выбирать?"
    north "没有。但真正配得上的人拥有耐心。如果所有选择都是被诅咒的——那又为何非要选择呢？"

