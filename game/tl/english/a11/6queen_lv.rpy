# TODO: Translation updated at 2025-10-10 00:22

# game/a11/6queen_lv.rpy:3
translate english queen_lv_24b271ca:

    # "Неделю спустя."
    "一周以后。"

# game/a11/6queen_lv.rpy:4
translate english queen_lv_e7527f74:

    # guard "Мой принц."
    guard "我的王子。"

# game/a11/6queen_lv.rpy:5
translate english queen_lv_d108194e:

    # me "Гости уже прибыли?"
    me "宾客们已经来了吗？"

# game/a11/6queen_lv.rpy:6
translate english queen_lv_d31125c1:

    # guard "Вы о вассалах, мой принц?"
    guard "您问的是封臣们吗，我的王子？"

# game/a11/6queen_lv.rpy:7
translate english queen_lv_7d698950:

    # me "Ага. О новых и старых."
    me "嗯。新封臣和旧封臣。"

# game/a11/6queen_lv.rpy:8
translate english queen_lv_9f98b3c3:

    # guard "Еще нет. Там только королева."
    guard "还没。只有王后在那儿。"

# game/a11/6queen_lv.rpy:9
translate english queen_lv_ffc51265:

    # me "Понятно."
    me "明白了。"

# game/a11/6queen_lv.rpy:10
translate english queen_lv_513e07a1:

    # guard "Сообщить им, что вы ждете?"
    guard "需要通知他们您在等候吗？"

# game/a11/6queen_lv.rpy:11
translate english queen_lv_e6051f92:

    # me "Да, сообщи."
    me "好，通知吧。"

# game/a11/6queen_lv.rpy:12
translate english queen_lv_75fc43e4:

    # guard "Будет сделано, мой принц."
    guard "遵命，我的王子。"

# game/a11/6queen_lv.rpy:14
translate english queen_lv_52c93a0f:

    # me "{i}А вот и мама. Уже ждет меня.{/i}"
    me "{i}啊，母亲来了。已经在等我了。{/i}"

# game/a11/6queen_lv.rpy:15
translate english queen_lv_241f740c:

    # me "{i}Наверное хочет о чем-то поговорить, прежде чем я встречусь с вассалами.{/i}"
    me "{i}大概是想在我见封臣之前先谈点什么。{/i}"

# game/a11/6queen_lv.rpy:16
translate english queen_lv_46d80ae2:

    # me "{i}Интересно, долго она тут стоит?{/i}"
    me "{i}不知道她在这儿站了多久了？{/i}"

# game/a11/6queen_lv.rpy:17
translate english queen_lv_066f9a84:

    # me "{i}Одета...официально.{/i}"
    me "{i}穿得……很正式。{/i}"

# game/a11/6queen_lv.rpy:18
translate english queen_lv_75eda696:

    # me "{i}Если не считать босых ног, конечно.{/i}"
    me "{i}当然，赤着的双脚得另当别论。{/i}"

# game/a11/6queen_lv.rpy:20
translate english queen_lv_182ed287:

    # mom "Думаешь он держал звезду прямо в руках?"
    mom "你觉得他真的是直接用手拿着那颗星吗？"

# game/a11/6queen_lv.rpy:21
translate english queen_lv_0ce7a63b:

    # me "Сир Лотрик? Не знаю. По легенде он выковал себе из нее корону прямо на поле битвы, после того как она влетела в ряды войск людей."
    me "Lotric爵士？不知道。据传说，那颗星坠入人类军队阵中后，他直接在战场上用那颗星给自己锻了一顶王冠。"

# game/a11/6queen_lv.rpy:22
translate english queen_lv_7e1d8593:

    # mom "Ну да. Хотя эльфы считают, что звезда упала именно на них. Поэтому та битва и была проиграна."
    mom "是啊。虽然精灵们认为那颗星是落在他们那儿的。所以那场仗才输掉了。"

# game/a11/6queen_lv.rpy:23
translate english queen_lv_39788248:

    # me "Отец считает так же. Кстати как он?"
    me "父亲也这么认为。对了，他现在怎么样？"

# game/a11/6queen_lv.rpy:24
translate english queen_lv_06e0bf9e:

    # mom "Уже лучше."
    mom "已经好些了。"

# game/a11/6queen_lv.rpy:25
translate english queen_lv_489a247d:

    # me "Правда?"
    me "真的吗？"

# game/a11/6queen_lv.rpy:26
translate english queen_lv_d822ed21:

    # mom "Да. Он даже стал немного ходить."
    mom "是的。他甚至能稍微走一走了。"

# game/a11/6queen_lv.rpy:27
translate english queen_lv_9710bb40:

    # me "Ты лечишь его магией?"
    me "你用法术给他治疗了吗？"

# game/a11/6queen_lv.rpy:28
translate english queen_lv_aa36553a:

    # mom "Нет. Это же не рана. Болезнь просто износила его тело, это ничем не вылечить."
    mom "没有。那又不是伤口。疾病已经耗尽了他的身体，这是治不好的。"

# game/a11/6queen_lv.rpy:29
translate english queen_lv_2e4c0db5:

    # me "И все же ему лучше."
    me "但他还是好些了。"

# game/a11/6queen_lv.rpy:30
translate english queen_lv_ae367394:

    # mom "Лучше. Насколько лучше может быть ослабленному старику."
    mom "好些了。对一个衰弱的老者来说，他已经好到不能再好了。"

# game/a11/6queen_lv.rpy:31
translate english queen_lv_ce4f4394:

    # me "...так он пример корону?"
    me "……那他会试戴王冠吗？"

# game/a11/6queen_lv.rpy:33
translate english queen_lv_3b6a47b0:

    # mom "Нет. Я говорила с ним. Он хочет чтобы ты принял ее."
    mom "不。我和他谈过了。他想让你接受王冠。"

# game/a11/6queen_lv.rpy:34
translate english queen_lv_65c9b7a4:

    # me "Как то это..."
    me "这有点……"

# game/a11/6queen_lv.rpy:35
translate english queen_lv_eff8244f:

    # mom "Да. Так неположено. Но сегодня утром он лично объяснял вассалам свое положение."
    mom "是的。这不合规矩。但今天早上，他亲自向封臣们解释了他的状况。"

# game/a11/6queen_lv.rpy:36
translate english queen_lv_dbcf82ef:

    # me "И что они?"
    me "那他们怎么说？"

# game/a11/6queen_lv.rpy:37
translate english queen_lv_3d49dbe7:

    # mom "Предложили перенести коронацию."
    mom "他们提议推迟加冕。"

# game/a11/6queen_lv.rpy:38
translate english queen_lv_f95c9fc9:

    # me "И?"
    me "然后呢？"

# game/a11/6queen_lv.rpy:39
translate english queen_lv_3dad3dfe:

    # mom "Он не согласился. Сказал такое не стоит откладывать."
    mom "他不同意。说这种事不该耽搁。"

# game/a11/6queen_lv.rpy:40
translate english queen_lv_81a0a824:

    # me "Не понимаю... так что мне делать?"
    me "我不明白……那我该做什么？"

# game/a11/6queen_lv.rpy:41
translate english queen_lv_0889d548:

    # mom "Ты примешь корону, от имени отца. Как кронпринц."
    mom "你将代表父王接受王冠。以王储的身份。"

# game/a11/6queen_lv.rpy:42
translate english queen_lv_de3fe2e3:

    # me "Такого еще никто не делал."
    me "以前从没有人这么做过。"

# game/a11/6queen_lv.rpy:43
translate english queen_lv_8a087981:

    # mom "Не делал. Обычно если король впадает в немощь, он отказывается от короны и передает власть."
    mom "是没有。通常如果国王衰弱不堪，他会放弃王位并移交权力。"

# game/a11/6queen_lv.rpy:44
translate english queen_lv_a4fafaa0:

    # me "Но не в этот раз, да?"
    me "但这次不是这样，对吗？"

# game/a11/6queen_lv.rpy:46
translate english queen_lv_35e639c6:

    # mom "Это первый за сотни лет случай, когда кто-то оправлялся от такой серьезной болезни одновременно с приобретением...власти."
    mom "这是几百年来头一回，有人从如此严重的疾病中康复，同时又……获得权力。"

# game/a11/6queen_lv.rpy:47
translate english queen_lv_1466ebcb:

    # me "Выходит мне ужасно повезло. Я беру на себя всю ответственность, но становлюсь не властью, а ее представителем."
    me "这么说我真是幸运极了。我承担起全部责任，却并非掌权，而只是个代表。"

# game/a11/6queen_lv.rpy:48
translate english queen_lv_2813ce85:

    # mom "Выходит так."
    mom "看来是这样。"

# game/a11/6queen_lv.rpy:49
translate english queen_lv_4b53dc59:

    # me "Ну...полагаю выбора у меня нет. А что вассалы?"
    me "嗯……我想我大概没有选择了。封臣们呢？"

# game/a11/6queen_lv.rpy:50
translate english queen_lv_551069b6:

    # mom "Вассалы твоего отца согласились сделать исключение, учитывая обстоятельства."
    mom "你父亲的封臣们同意鉴于情况特殊，下不为例。"

# game/a11/6queen_lv.rpy:51
translate english queen_lv_a67df5ef:

    # me "Ты говорила с ними?"
    me "你跟他们谈过了？"

# game/a11/6queen_lv.rpy:52
translate english queen_lv_61835c7b:

    # mom "Я присутствовала на их разговоре с Королем. А ты уже говорил с ними?"
    mom "他们和国王谈话时，我在场。你呢，你跟他们谈过了吗？"

# game/a11/6queen_lv.rpy:53
translate english queen_lv_6ea7272d:

    # me "Пока еще нет. Мы поговорим здесь."
    me "还没有。我们会在这儿谈。"

# game/a11/6queen_lv.rpy:54
translate english queen_lv_a30e3d36:

    # mom "Хорошо. Если они сообщат что-то, чего я не знаю, ты ведь мне расскажешь?"
    mom "好。如果他们说了什么我不知道的事，你会告诉我的，对吧？"

# game/a11/6queen_lv.rpy:55
translate english queen_lv_5f7e1872:

    # me "А должен?"
    me "我一定要这么做吗？"

# game/a11/6queen_lv.rpy:56
translate english queen_lv_8c7f61c5:

    # mom "[mename], я твоя мать, разве я давала повод сомневаться в своей любви к тебе?"
    mom "[mename]，我是你的母亲，难道我给过你理由怀疑我对你的爱吗？"

# game/a11/6queen_lv.rpy:57
translate english queen_lv_3820771a:

    # me "..."
    me "..."

# game/a11/6queen_lv.rpy:58
translate english queen_lv_b5490cf5:

    # mom "Это обидно, знаешь ли."
    mom "你这么说很伤人，你知道的。"

# game/a11/6queen_lv.rpy:59
translate english queen_lv_a10265e0:

    # me "Я не думаю, что они расскажут мне что-то новое. В конце концов это просто символический жест, не более. Присягу Золотому Порядку давать будут значительно позже, разве не так?"
    me "我不认为他们会告诉我什么新消息。说到底，这不过是个象征性的姿态，仅此而已。向黄金秩序宣誓效忠是很久以后的事了，难道不是吗？"

# game/a11/6queen_lv.rpy:60
translate english queen_lv_1cf6e36d:

    # mom "Так. Ты прав. Все должно быть нормально."
    mom "是的。你说得对。应该一切都会正常的。"

# game/a11/6queen_lv.rpy:61
translate english queen_lv_e5249e1e:

    # me "Так и будет."
    me "一定会的。"

# game/a11/6queen_lv.rpy:63
translate english queen_lv_158dea6f:

    # mom "Кажется они идут."
    mom "好像他们来了。"

# game/a11/6queen_lv.rpy:64
translate english queen_lv_572fd1ef:

    # me "Ты уходишь?"
    me "你要走了吗？"

# game/a11/6queen_lv.rpy:65
translate english queen_lv_4d291459:

    # mom "Я вернусь, когда вы закончите."
    mom "等你们谈完了，我再回来。"

# game/a11/6queen_lv.rpy:66
translate english queen_lv_6b592793:

    # me "Я не против, чтобы ты осталась."
    me "你留下来，我也不介意。"

# game/a11/6queen_lv.rpy:67
translate english queen_lv_acf20de3:

    # mom "Спасибо, милый, но тебе нужно учиться справляться с таким самому."
    mom "谢谢，亲爱的，但你需要学会独自处理这些事。"

# game/a11/6queen_lv.rpy:68
translate english queen_lv_3820771a_1:

    # me "..."
    me "..."

# game/a11/6queen_lv.rpy:69
translate english queen_lv_e75a6988:

    # mom "К тому же не хочу раздражать их своих присутствием больше нужного. Они и так были недовольны, что я слушала их разговор с королем."
    mom "再说，我也不想过多地在这儿刺激他们。我旁听他们和国王的谈话，他们就已经很不高兴了。"

# game/a11/6queen_lv.rpy:70
translate english queen_lv_71d3b8c8:

    # me "Хорошо."
    me "好吧。"

# game/a11/6queen_lv.rpy:71
translate english queen_lv_b09f8e1f:

    # mom "Но ты же... расскажешь мне детали позже?"
    mom "那你……之后会把细节告诉我吗？"

# game/a11/6queen_lv.rpy:72
translate english queen_lv_33d8ccb2:

    # me "Может быть. Если будет что рассказывать. Думаю этот разговор будет просто пересказом событий на Западе и обсуждением коронации."
    me "也许吧。如果有什么可说的。我想这次谈话不过就是复述一下西方的事件，再讨论一下加冕礼。"

# game/a11/6queen_lv.rpy:73
translate english queen_lv_229c2284:

    # mom "Верно. Скорее всего так и будет, но..."
    mom "没错。很可能就是这样，不过……"

# game/a11/6queen_lv.rpy:74
translate english queen_lv_d08c4a97:

    # me "Но если нет - я тебе все расскажу."
    me "不过如果不是这样——我会把一切都告诉你。"

# game/a11/6queen_lv.rpy:75
translate english queen_lv_ae72fade:

    # mom "Вот и славно."
    mom "那太好了。"

# game/a11/6queen_lv.rpy:78
translate english queen_lv_dbc3fd1f:

    # guidon "Надо сказать я ожидал худшего. Но здесь все почти так же, как я запомнил. Да и эльфов не очень много."
    guidon "我得说，我预想过更糟的情况。但这里的一切几乎和我记忆中的一样。精灵也不太多。"

# game/a11/6queen_lv.rpy:79
translate english queen_lv_1cd55990:

    # lagg "Их вообще нет, если не считать...некоторых членов королевской семьи."
    lagg "他们根本就不在，如果不算……某些王室成员的话。"

# game/a11/6queen_lv.rpy:80
translate english queen_lv_ca61842a:

    # guidon "Верно."
    guidon "也对。"

# game/a11/6queen_lv.rpy:81
translate english queen_lv_e1848aff:

    # lagg "Хотя я со временем стал относиться к этому легче."
    lagg "不过，随着时间推移，我对此也渐渐看开了。"

# game/a11/6queen_lv.rpy:82
translate english queen_lv_d3c0e506:

    # guidon "Это еще почему?"
    guidon "这又是为什么？"

# game/a11/6queen_lv.rpy:83
translate english queen_lv_36d60193:

    # lagg "Принц ведь хорошо себя зарекомендовал. Он собирает земли бывшей Империи. Может нам даже не придется вскоре использовать слово 'бывшей'."
    lagg "毕竟王子的表现很不错。他正在收复昔日帝国的疆土。或许我们很快就不用再提“昔日”这个词了。"

# game/a11/6queen_lv.rpy:84
translate english queen_lv_e6617b34:

    # guidon "Меня не нужно убеждать в том, что нас определяют поступки. Но вот поступками руководит кровь."
    guidon "不必向我论证我们是由行为决定的。但引导行为的是血脉。"

# game/a11/6queen_lv.rpy:85
translate english queen_lv_eb2d5216:

    # lagg "Ну значит в принце сильнее его предки люди. А эльфийская кровь даже полезна."
    lagg "那么，说明王子身上的人类祖先更强一些。而精灵血脉甚至是有益的。"

# game/a11/6queen_lv.rpy:86
translate english queen_lv_6ed5f692:

    # guidon "Полезна?"
    guidon "有益？"

# game/a11/6queen_lv.rpy:87
translate english queen_lv_d66a0adb:

    # lagg "Продлевает жизнь. Как много кризисов переживают королевства и империи, когда властитель умирает? Долголетие - лучший спутник стабильных государств."
    lagg "延长寿命。想想看，每当统治者去世，王国和帝国要经历多少危机？长寿是稳定国家的最佳伴侣。"

# game/a11/6queen_lv.rpy:88
translate english queen_lv_aecf9c65:

    # guidon "Может и так."
    guidon "也许是这样吧。"

# game/a11/6queen_lv.rpy:90
translate english queen_lv_ce941a26:

    # me "Вас слышно со всех углов галереи."
    me "你们的声音在廊道的每个角落都听得清清楚楚。"

# game/a11/6queen_lv.rpy:91
translate english queen_lv_fad9d458:

    # lagg "Простите, мой принц, ваше происхождение будоражит ум лорда Гвидона."
    lagg "请原谅，我的王子，是您的出身让吉维登勋爵浮想联翩。"

# game/a11/6queen_lv.rpy:92
translate english queen_lv_351364c7:

    # guidon "Разве я завел об этом разговор?"
    guidon "难道是我提起这个话题的吗？"

# game/a11/6queen_lv.rpy:93
translate english queen_lv_621a8caf:

    # leonard "Мой принц."
    leonard "我的王子。"

# game/a11/6queen_lv.rpy:94
translate english queen_lv_37623a6b:

    # me "Леонард. Гвидон. Лаггариус."
    me "Leonard。吉维登。Laggarius。"

# game/a11/6queen_lv.rpy:95
translate english queen_lv_df768d02:

    # lagg "Рад вас видеть в добром здравии."
    lagg "很高兴看到各位身体健康。"

# game/a11/6queen_lv.rpy:96
translate english queen_lv_f01b1871:

    # guidon "Да, да, да. Давайте пропустим формальности и перейдем ближе к делу."
    guidon "好了，好了，好了。让我们省去繁文缛节，直入正题吧。"

# game/a11/6queen_lv.rpy:97
translate english queen_lv_71ace0da:

    # leonard "Все готово. Мы привезли посланника и корону."
    leonard "一切都准备好了。我们带来了使者和王冠。"

# game/a11/6queen_lv.rpy:98
translate english queen_lv_41dd6a68:

    # me "Посланника?"
    me "使者？"

# game/a11/6queen_lv.rpy:99
translate english queen_lv_ff57a249:

    # lagg "К сожалению лорды Запада не могут прибыть также быстро, как и мы. Так что они отправили посланника, представляющего их общие интересы."
    lagg "遗憾的是，西境领主们无法像我们这样迅速赶到。所以他们派来了一位代表他们共同利益的使者。"

# game/a11/6queen_lv.rpy:100
translate english queen_lv_bfdff196:

    # guidon "И наше общее согласие."
    guidon "以及我们共同的意见。"

# game/a11/6queen_lv.rpy:101
translate english queen_lv_194f0f7b:

    # leonard "Они преклонят колени позже."
    leonard "他们稍后会屈膝行礼。"

# game/a11/6queen_lv.rpy:102
translate english queen_lv_71fe7086:

    # me "Позже?"
    me "稍后？"

# game/a11/6queen_lv.rpy:103
translate english queen_lv_5411c25b:

    # lagg "Не волнуйтесь, мой принц, мы убедились...в преданности каждого."
    lagg "请放心，我的王子，我们已经确信……每个人的忠诚。"

# game/a11/6queen_lv.rpy:104
translate english queen_lv_b55a28e0:

    # guidon "Все кто не воевал с нами бок о бок с самого начала предоставили заложников и золото, чтобы оплатить расходы наших армий. Думаю этого достаточно для доверия."
    guidon "所有未曾从一开始就与我们并肩作战的人，都提供了人质和黄金，用以支付我们军队的开销。我想这足以信任了。"

# game/a11/6queen_lv.rpy:106
translate english queen_lv_8ecfd068:

    # me "Что насчет...управления? Имперское наместничество подразумевает назначаемое лицо."
    me "那……治理方面呢？帝国总督区的职位意味着需要任命一个人选。"

# game/a11/6queen_lv.rpy:107
translate english queen_lv_a887d5ad:

    # lagg "Мы говорили с королем и..."
    lagg "我们和国王谈过了，而且……"

# game/a11/6queen_lv.rpy:108
translate english queen_lv_3d4c030e:

    # guidon "Лорд Аргус. Идеальный вариант."
    guidon "洛尔·Argus。完美的人选。"

# game/a11/6queen_lv.rpy:109
translate english queen_lv_c4bc5b8d:

    # leonard "Ваш отец уже поставил печать под распоряжением."
    leonard "你父亲已经在这道命令上用了印。"

# game/a11/6queen_lv.rpy:110
translate english queen_lv_134fe287:

    # me "Значит лорд Аргус теперь наместник над Западом."
    me "这么说，Argus勋爵现在就是西境总督了。"

# game/a11/6queen_lv.rpy:111
translate english queen_lv_ff15e4ec:

    # guidon "Понимаю твое разочарование, я бы тоже выбрал себя. Но Аргус это самая компромиссная фигура. Он был с нами сначала, а значит лоялен. Он хорошо знает всех лордов и даже смог договориться с Черной косой."
    guidon "我理解你的失望，换成是我，我也会选自己的。但Argus是最折中的人选。他从一开始就和我们站在一起，这意味着他的忠诚。他熟悉所有领主，甚至能和“黑镰刀”谈妥。"

# game/a11/6queen_lv.rpy:112
translate english queen_lv_24932e54:

    # leonard "Это лучший вариант."
    leonard "这是最好的人选。"

# game/a11/6queen_lv.rpy:113
translate english queen_lv_4bb0b537:

    # me "Хорошо. А что насчет коронации?"
    me "好的。那关于加冕礼呢？"

# game/a11/6queen_lv.rpy:114
translate english queen_lv_7ed53e16:

    # lagg "Королю все еще нездоровится. Он и мы считаем, что тебе нужно продолжить исполнять обязанности принца-регента."
    lagg "国王仍感不适。他以及我们都认为，你应继续履行摄政王子的职责。"

# game/a11/6queen_lv.rpy:115
translate english queen_lv_8008b406:

    # leonard "И получить корону от от имени отца."
    leonard "并代表父王接受王冠。"

# game/a11/6queen_lv.rpy:116
translate english queen_lv_855db9ee:

    # me "Ясно."
    me "明白了。"

# game/a11/6queen_lv.rpy:117
translate english queen_lv_2d65e848:

    # lagg "Это...вас устраивает, мой принц?"
    lagg "对此……您能接受吗，我的王子？"

# game/a11/6queen_lv.rpy:118
translate english queen_lv_47b0442b:

    # guidon "Я был против, если тебе интересно, король должен сам одевать на себя корону, а иначе он не..."
    guidon "如果你想听，我本是反对的，国王应当自己加冕，否则他就不是……"

# game/a11/6queen_lv.rpy:119
translate english queen_lv_86b515ff:

    # leonard "Достаточно. Мы приняли решение большинством."
    leonard "够了。我们多数人已经做出了决定。"

# game/a11/6queen_lv.rpy:121
translate english queen_lv_46cbbf1f:

    # guidon "Как скажете. Пойду готовится к завтрашней коронации. Или пошлю вместо себя сына, раз уж теперь так можно."
    guidon "就按你们说的办。我去准备明天的加冕礼了。或者现在可以让我儿子代替我去，既然如今这么做是被允许的。"

# game/a11/6queen_lv.rpy:122
translate english queen_lv_8d6e4218:

    # leonard "Это небольшое нарушение Золотого Порядка."
    leonard "这在某种程度上违背了黄金秩序。"

# game/a11/6queen_lv.rpy:123
translate english queen_lv_7a0e009d:

    # lagg "Скорее это упущение в самом своде правил..."
    lagg "不如说是那套规则本身存在疏漏……"

# game/a11/6queen_lv.rpy:124
translate english queen_lv_f95c9fc9_1:

    # me "И?"
    me "然后呢？"

# game/a11/6queen_lv.rpy:125
translate english queen_lv_0a8fdef2:

    # leonard "Мы обратились в городской трибунал. Они уже выслали письменное согласие на подобную...процедуру."
    leonard "我们请示了城市裁判庭。他们已经发出了对这种……程序的书面许可。"

# game/a11/6queen_lv.rpy:126
translate english queen_lv_aad1d842:

    # lagg "Все будет легитимно."
    lagg "一切将是合法的。"

# game/a11/6queen_lv.rpy:127
translate english queen_lv_67ce5997:

    # leonard "Корона будет принадлежать твоему отцу. Но носить ее будете вы, мой принц, по крайней мере пока не закончатся ваши полномочия."
    leonard "王冠将属于你的父王。但将由您来佩戴，我的王子，至少在您的摄政权结束之前是如此。"

# game/a11/6queen_lv.rpy:128
translate english queen_lv_eee819cf:

    # me "Я понял."
    me "我明白了。"

# game/a11/6queen_lv.rpy:129
translate english queen_lv_feaa04b5:

    # leonard "Есть еще вопросы, мой принц?"
    leonard "还有别的问题吗，我的王子？"

# game/a11/6queen_lv.rpy:130
translate english queen_lv_5a7a7577:

    # me "Нет."
    me "没有。"

# game/a11/6queen_lv.rpy:131
translate english queen_lv_6905c5c1:

    # leonard "Тогда не будем тратить время друг друга. Завтра длинный день."
    leonard "那我们就不浪费彼此的时间了。明天将是漫长的一天。"

# game/a11/6queen_lv.rpy:132
translate english queen_lv_ffddebb1:

    # lagg "Верно. Хорошо выспитесь, принц [mename]."
    lagg "的确。祝您安眠，[mename]王子。"

# game/a11/6queen_lv.rpy:135
translate english queen_lv_5943b0c3:

    # lagg "Надо сказать ваша идея с Республикой заразила ум моего сына."
    lagg "不得不说，你那个关于共和国的想法，传染到了我儿子的脑子里。"

# game/a11/6queen_lv.rpy:136
translate english queen_lv_50044930:

    # cassius "Я рад."
    cassius "我很荣幸。"

# game/a11/6queen_lv.rpy:137
translate english queen_lv_21883ecf:

    # lagg "Не уверен, что это повод для радости. Теперь он хочет отправиться к вам на Запад."
    lagg "我不确定这有什么值得荣幸的。现在他想去西境投奔你们。"

# game/a11/6queen_lv.rpy:138
translate english queen_lv_3f2d1c24:

    # cassius "Мы с радостью его примем."
    cassius "我们会很乐意接纳他。"

# game/a11/6queen_lv.rpy:139
translate english queen_lv_e3c3a550:

    # lagg "Этого я и боюсь."
    lagg "我担心的正是这个。"

# game/a11/6queen_lv.rpy:140
translate english queen_lv_62602c7e:

    # cassius "Вы ведь были там, разве наше общество показалось вам ужасным?"
    cassius "您去过那里，难道我们的社会给您留下糟糕的印象吗？"

# game/a11/6queen_lv.rpy:141
translate english queen_lv_137f4b16:

    # lagg "Нет. Но не хотелось бы, чтобы через пару лет бунт подняли уже против нас."
    lagg "没有。但我不想几年后，叛乱之火反而烧到我们自己头上。"

# game/a11/6queen_lv.rpy:142
translate english queen_lv_be424b87:

    # cassius "Этого не случится. Можете высылать всех жаждущих свободы к нам на Запад."
    cassius "这不会发生的。您可以把所有渴望自由的人都送到我们西境来。"

# game/a11/6queen_lv.rpy:143
translate english queen_lv_40167050:

    # lagg "Сомнительное предложение."
    lagg "这个提议很可疑。"

# game/a11/6queen_lv.rpy:144
translate english queen_lv_cecb53b8:

    # cassius "Или можете их вешать. Но тогда шанс бунта только увеличится."
    cassius "或者您也可以绞死他们。但那样做只会增加叛乱的可能。"

# game/a11/6queen_lv.rpy:146
translate english queen_lv_c1c2c6c0:

    # me "Кассиус. Лаггариус. Леонард."
    me "卡西乌斯。Laggarius。Leonard。"

# game/a11/6queen_lv.rpy:147
translate english queen_lv_b95b8552:

    # lagg "Здравствуйте мой принц, рад видеть вас в добром здравии."
    lagg "您好，我的王子，很高兴看到您身体安好。"

# game/a11/6queen_lv.rpy:148
translate english queen_lv_c5b6d903:

    # cassius "[mename]. Рад, что с тобой все хорошо..."
    cassius "[mename]。很高兴看到你一切都好……"

# game/a11/6queen_lv.rpy:149
translate english queen_lv_1ad9ff92:

    # leonard "Давайте ближе к делу. Сегодня мы говорили с королем."
    leonard "让我们开门见山吧。今天，我们和国王谈过了。"

# game/a11/6queen_lv.rpy:150
translate english queen_lv_f95c9fc9_2:

    # me "И?"
    me "然后呢？"

# game/a11/6queen_lv.rpy:151
translate english queen_lv_74a357c1:

    # lagg "Тебе известно содержание этого разговора?"
    lagg "你知道这次谈话的内容吗？"

# game/a11/6queen_lv.rpy:152
translate english queen_lv_17a25f3c:

    # me "Приблизительно."
    me "大概知道。"

# game/a11/6queen_lv.rpy:153
translate english queen_lv_9898636f:

    # cassius "Ты примешь корону Запада от имени отца."
    cassius "你将代表父王接受西境王冠。"

# game/a11/6queen_lv.rpy:154
translate english queen_lv_a850d4ea:

    # leonard "Как принц-регент."
    leonard "以摄政王子的身份。"

# game/a11/6queen_lv.rpy:155
translate english queen_lv_ffc51265_1:

    # me "Понятно."
    me "明白。"

# game/a11/6queen_lv.rpy:156
translate english queen_lv_8d6e4218_1:

    # leonard "Это небольшое нарушение Золотого Порядка."
    leonard "这在某种程度上违背了黄金秩序。"

# game/a11/6queen_lv.rpy:157
translate english queen_lv_7a0e009d_1:

    # lagg "Скорее это упущение в самом своде правил..."
    lagg "不如说是那套规则本身存在疏漏……"

# game/a11/6queen_lv.rpy:158
translate english queen_lv_0a8fdef2_1:

    # leonard "Мы обратились в городской трибунал. Они уже выслали письменное согласие на подобную...процедуру."
    leonard "我们请示了城市裁判庭。他们已经发出了对这种……程序的书面许可。"

# game/a11/6queen_lv.rpy:159
translate english queen_lv_aad1d842_1:

    # lagg "Все будет легитимно."
    lagg "一切将是合法的。"

# game/a11/6queen_lv.rpy:160
translate english queen_lv_67ce5997_1:

    # leonard "Корона будет принадлежать твоему отцу. Но носить ее будете вы, мой принц, по крайней мере пока не закончатся ваши полномочия."
    leonard "王冠将属于你的父王。但将由您来佩戴，我的王子，至少在您的摄政权结束之前是如此。"

# game/a11/6queen_lv.rpy:161
translate english queen_lv_b6db9193:

    # me "Я понял. Я сделаю это."
    me "我明白了。我会这么做的。"

# game/a11/6queen_lv.rpy:162
translate english queen_lv_9759371f:

    # lagg "Отлично. Я же говорил, что с этим проблем не будет. Принц [mename] настоящий Стархед."
    lagg "好极了。我就说过，这件事不会有问题的。[mename]王子是真正的Starhead。"

# game/a11/6queen_lv.rpy:164
translate english queen_lv_287cfb33:

    # me "Что там с имперским наместничеством?"
    me "帝国总督区的任命怎么样了？"

# game/a11/6queen_lv.rpy:165
translate english queen_lv_6e0aeff6:

    # lagg "На Западе мы познакомились с твоим другом."
    lagg "在西境，我们结识了你的一位朋友。"

# game/a11/6queen_lv.rpy:166
translate english queen_lv_0c2a1f9a:

    # cassius "Мы обсудили все с Генри, пока были там."
    cassius "我们在那边时，已经和亨利把一切都谈妥了。"

# game/a11/6queen_lv.rpy:167
translate english queen_lv_f9e7d250:

    # leonard "Он показался нам неплохим вариантом. Тем более он сын лорда Аргуса."
    leonard "我们觉得他是个不错的人选。何况他是Argus勋爵的儿子。"

# game/a11/6queen_lv.rpy:168
translate english queen_lv_f2d29fb8:

    # me "И..."
    me "所以……"

# game/a11/6queen_lv.rpy:169
translate english queen_lv_c32c8538:

    # lagg "И мы предложили его кандидатуру королю. Сегодня утром он подписал указ."
    lagg "所以我们向国王提出了他的候选资格。今天早上，他签署了那份诏令。"

# game/a11/6queen_lv.rpy:170
translate english queen_lv_fbd69990:

    # cassius "Так что Генри теперь имперский Лорд-наместник Запада."
    cassius "所以，亨利现在就是帝国的西境总督了。"

# game/a11/6queen_lv.rpy:171
translate english queen_lv_4e1c8518:

    # leonard "Он хорошо себя зарекомендовал в качестве переговорщика."
    leonard "他作为谈判人，表现得非常出色。"

# game/a11/6queen_lv.rpy:172
translate english queen_lv_489a247d_1:

    # me "Правда?"
    me "真的吗？"

# game/a11/6queen_lv.rpy:173
translate english queen_lv_483b14ea:

    # lagg "Да. Мы думали придется взять в осаду пару замков, но он сумел договорится."
    lagg "是的。我们原以为必须围困几座城堡，但他成功地通过谈判解决了。"

# game/a11/6queen_lv.rpy:174
translate english queen_lv_3c2e0be7:

    # cassius "Мы начали с тех, кто колеблется. Когда дошли до береговых лордов, уже не осталось никого, кто бы мог им помочь."
    cassius "我们从那些动摇不定的人开始。等我们推进到沿海领主那里时，已经没有人能帮助他们了。"

# game/a11/6queen_lv.rpy:175
translate english queen_lv_599fe6df:

    # me "И что они просто..."
    me "那他们就那样直接……"

# game/a11/6queen_lv.rpy:176
translate english queen_lv_7bc3197e:

    # cassius "Они поняли, что сопротивление...контрпродуктивно. Они приняли новый порядок и имперскую власть."
    cassius "他们明白了，抵抗……只会适得其反。他们接受了新的秩序和帝国的权威。"

# game/a11/6queen_lv.rpy:177
translate english queen_lv_2f302e4a:

    # leonard "Мы взяли заложников и золото. Достаточно, чтобы не унижать их, но понять, что они теперь лояльны."
    leonard "我们收下了人质和黄金。这足以让他们明白自己的忠诚，又不会过分羞辱他们。"

# game/a11/6queen_lv.rpy:178
translate english queen_lv_592acbab:

    # me "Отлично. Это отлично."
    me "太好了。这太好了。"

# game/a11/6queen_lv.rpy:179
translate english queen_lv_14603544:

    # lagg "Они преклонят колени чуть позже. Корону передаст посланник общей воли."
    lagg "他们稍后会屈膝行礼。王冠将由代表共同意愿的使者转交。"

# game/a11/6queen_lv.rpy:180
translate english queen_lv_e1cb9f51:

    # cassius "Завтра ты сам все увидишь."
    cassius "明天你自己就能看到一切了。"

# game/a11/6queen_lv.rpy:181
translate english queen_lv_3c1569c9:

    # me "Хорошо, больше мне не о чем спрашивать."
    me "好，我没有其他要问的了。"

# game/a11/6queen_lv.rpy:182
translate english queen_lv_f47b8900:

    # leonard "Тогда не будем отвлекать друг у друга время."
    leonard "那我们就不相互打扰了。"

# game/a11/6queen_lv.rpy:184
translate english queen_lv_3820771a_2:

    # me "..."
    me "..."

# game/a11/6queen_lv.rpy:185
translate english queen_lv_5a9379c9:

    # cassius "..."
    cassius "..."

# game/a11/6queen_lv.rpy:186
translate english queen_lv_2ef97257:

    # me "Ты хотел что-то добавить, Кассиус?"
    me "你还有话要补充吗，卡西乌斯？"

# game/a11/6queen_lv.rpy:187
translate english queen_lv_7480d171:

    # cassius "Я был против, чтобы ты принимал корону."
    cassius "我曾反对让你接受王冠。"

# game/a11/6queen_lv.rpy:188
translate english queen_lv_ad02f53a:

    # me "Что?"
    me "什么？"

# game/a11/6queen_lv.rpy:189
translate english queen_lv_f2537b6e:

    # cassius "Как принц. Тебя стоило короновать как короля."
    cassius "以王子的身份。你应该被加冕为国王。"

# game/a11/6queen_lv.rpy:190
translate english queen_lv_2c08505b:

    # me "...спасибо?"
    me "……谢了？"

# game/a11/6queen_lv.rpy:191
translate english queen_lv_787994d8:

    # cassius "Дело не личных предпочтениях. Это вопрос двойной лояльности. Ты будешь носить регалии своего отца, но кто из вас король?"
    cassius "这与个人喜好无关。这是双重效忠的问题。你将佩戴你父亲的权标，但你们之中，谁是真正的国王？"

# game/a11/6queen_lv.rpy:192
translate english queen_lv_3820771a_3:

    # me "..."
    me "..."

# game/a11/6queen_lv.rpy:193
translate english queen_lv_1094c04e:

    # cassius "Вот именно. Что будет, если вы отдадите противоречащие друг другу приказы?"
    cassius "正是如此。如果你们下达了相互矛盾的命令，该怎么办？"

# game/a11/6queen_lv.rpy:194
translate english queen_lv_c3b9c58a:

    # me "Понятие не имею."
    me "我完全没有头绪。"

# game/a11/6queen_lv.rpy:195
translate english queen_lv_18e9c16a:

    # cassius "Твой отец... он поступает неразумно. Я предложил ему принять корону позже или отречься в твою пользу. К сожалению мой голос был в меньшинстве."
    cassius "你的父亲……他行事不够理智。我提议过，让他稍后加冕，或是让位给你。可惜我的意见属于少数。"

# game/a11/6queen_lv.rpy:196
translate english queen_lv_ffc51265_2:

    # me "Понятно."
    me "明白了。"

# game/a11/6queen_lv.rpy:197
translate english queen_lv_ec49992f:

    # cassius "Просто хочу чтобы ты знал. И я и Генри и Валериан выбрали бы...тебя."
    cassius "我只是想让你知道。我，亨利，还有瓦勒良，我们本都会选择……你。"

# game/a11/6queen_lv.rpy:198
translate english queen_lv_3820771a_4:

    # me "..."
    me "..."

# game/a11/6queen_lv.rpy:199
translate english queen_lv_0cbc74a7:

    # cassius "До завтра, [mename]."
    cassius "明天见，[mename]。"

# game/a11/6queen_lv.rpy:200
translate english queen_lv_2e909f62:

    # me "До завтра, Кассиус."
    me "明天见，卡西乌斯。"

# game/a11/6queen_lv.rpy:203
translate english queen_lv_881b4e42:

    # cass "Ну что за прелесть? Посмотрите на него. Сидит такой непринужденный и задумчивый."
    cass "哟，这不是个可爱的人儿嘛。看看他。坐得一副洒脱又若有所思的样子。"

# game/a11/6queen_lv.rpy:204
translate english queen_lv_ae772f86:

    # me "Привет, [cass]."
    me "你好，[cass]。"

# game/a11/6queen_lv.rpy:205
translate english queen_lv_5385623e:

    # cass "У тебя такое выражение лица, будто ты завтра второй раз будешь коронован."
    cass "你脸上的表情，就好像明天你要第二次加冕一样。"

# game/a11/6queen_lv.rpy:206
translate english queen_lv_3820771a_5:

    # me "..."
    me "..."

# game/a11/6queen_lv.rpy:207
translate english queen_lv_1b92e978:

    # cass "Да-да. Не удивляйся. Отец решил даровать корону тебе."
    cass "是啊，是啊。别惊讶。父亲决定把王冠给你。"

# game/a11/6queen_lv.rpy:208
translate english queen_lv_ca76fd56:

    # cass "Не в прямом смысле конечно."
    cass "当然，不是字面上的意思。"

# game/a11/6queen_lv.rpy:209
translate english queen_lv_7427a59c:

    # me "А в каком?"
    me "那是什么意思？"

# game/a11/6queen_lv.rpy:211
translate english queen_lv_3dbf5c9c:

    # cass "Получишь корону от посланника Запада. Примешь ее, как принц-регент. Добавишь отцу титулов."
    cass "你会从西境使者手中接过王冠。以摄政王子的身份接受。给你父亲增添头衔。"

# game/a11/6queen_lv.rpy:212
translate english queen_lv_d28f4c5f:

    # me "Посланник Запада?"
    me "西境使者？"

# game/a11/6queen_lv.rpy:213
translate english queen_lv_d7cee0ba:

    # guran "Это их коллективное согласие."
    guran "那是他们的集体同意。"

# game/a11/6queen_lv.rpy:214
translate english queen_lv_3dd09d4f:

    # cass "Не волнуйся. Они уже преклонили колено новому Лорду-наместнику."
    cass "别担心。他们已经向新任总督屈膝了。"

# game/a11/6queen_lv.rpy:215
translate english queen_lv_1483eccc:

    # me "И кто это?"
    me "那是谁？"

# game/a11/6queen_lv.rpy:216
translate english queen_lv_c8e3d753:

    # cass "Какой-то мой дальний родственник. Дядя лучше знает."
    cass "我的一个远亲。叔叔知道得更清楚。"

# game/a11/6queen_lv.rpy:217
translate english queen_lv_6185fac7:

    # guran "Дюран. Он...лояльный и послушный."
    guran "Duran。他……既忠诚又听话。"

# game/a11/6queen_lv.rpy:218
translate english queen_lv_d2a5be5b:

    # me "Хорошо...он не здесь?"
    me "好吧……他不在这里吗？"

# game/a11/6queen_lv.rpy:219
translate english queen_lv_2bf24ab5:

    # guran "Опаздывает. Там возникла небольшая заминка."
    guran "来晚了。那边出了点小岔子。"

# game/a11/6queen_lv.rpy:220
translate english queen_lv_7a20a130:

    # cass "Пришлось угрожать смертью. А для этого понадобилось собрать под стенами береговых лордов приличную армию."
    cass "不得不以死亡相威胁。为此，还需要在沿海领主的城堡下集结一支像样的军队。"

# game/a11/6queen_lv.rpy:221
translate english queen_lv_f561d17e:

    # me "Но они согласились?"
    me "他们同意了？"

# game/a11/6queen_lv.rpy:222
translate english queen_lv_2a79a30b:

    # guran "Да. Пример остальных их успокоил."
    guran "是的。其他人的榜样让他们平静了下来。"

# game/a11/6queen_lv.rpy:223
translate english queen_lv_8e8da36f:

    # cass "Правда пришлось везти заложников прямо сюда. Это было их условие. Почему-то никто не захотел отправлять своих детей в Черную Косу."
    cass "只不过，我们不得不把人质直接送到这里来。这是他们的条件。不知为什么，没人愿意把自己的孩子送到“黑镰刀”去。"

# game/a11/6queen_lv.rpy:224
translate english queen_lv_e6506d10:

    # me "Я их понимаю."
    me "我能理解他们。"

# game/a11/6queen_lv.rpy:225
translate english queen_lv_1847ebf3:

    # guran "Нам повезло. Разобщенность сыграла нам на руку."
    guran "我们很走运。四分五裂的局面帮了我们。"

# game/a11/6queen_lv.rpy:226
translate english queen_lv_1a94c6a7:

    # cass "Все верно. Сначала было трудновато, но потом все покатилось, как снежный ком."
    cass "确实如此。起初有些困难，但后来就像滚雪球一样顺利。"

# game/a11/6queen_lv.rpy:228
translate english queen_lv_2d6c9501:

    # cass "Теперь нужно все это удержать."
    cass "现在要做的就是守住这一切。"

# game/a11/6queen_lv.rpy:229
translate english queen_lv_3292d053:

    # me "А с этим могут быть проблемы?"
    me "这可能会出问题吗？"

# game/a11/6queen_lv.rpy:230
translate english queen_lv_6eac9880:

    # guran "Скорее всего нет. Но сейчас лучше действовать дипломатией."
    guran "很可能不会。但现在最好采取外交手段。"

# game/a11/6queen_lv.rpy:231
translate english queen_lv_38ee516c:

    # cass "Западные лорды скоро прибудут один за другим. Будут преклонять колено."
    cass "西境领主们很快就会一个接一个地抵达。将会屈膝致敬。"

# game/a11/6queen_lv.rpy:232
translate english queen_lv_71d3b8c8_1:

    # me "Хорошо."
    me "好的。"

# game/a11/6queen_lv.rpy:233
translate english queen_lv_9240c7c4:

    # guran "Нужно будет дать им понять что старый порядок вернулся. В этот раз навсегда. По крайней мере до конца их жизней."
    guran "需要让他们明白，旧秩序已经回归了。这一次是永远地。至少终他们一生是如此。"

# game/a11/6queen_lv.rpy:234
translate english queen_lv_e7272097:

    # cass "Не будем слишком давить. Пусть они и были разобщены, скоро они снова начнут ездить друг другу в гости и шептаться."
    cass "我们不能逼迫得太紧。就算他们曾经四分五裂，很快他们又会开始彼此走动、窃窃私语。"

# game/a11/6queen_lv.rpy:235
translate english queen_lv_a1125e72:

    # me "Понимаю. И надо будет дать им понять, что процветать с Империей лучше, чем висеть на дереве с мятежниками."
    me "我明白。而且得让他们明白，与帝国共繁荣，总比和叛党一起吊在树上强。"

# game/a11/6queen_lv.rpy:236
translate english queen_lv_f0686a63:

    # guran "Все верно."
    guran "完全正确。"

# game/a11/6queen_lv.rpy:237
translate english queen_lv_64534492:

    # cass "Нужно отменить пошлину на товары, идущие через Долину."
    cass "需要取消通过山谷转运的货物的关税。"

# game/a11/6queen_lv.rpy:238
translate english queen_lv_3982ac08:

    # me "Ну...ты теперь вместо совета. Отмени."
    me "嗯……现在你代替了议会。取消掉吧。"

# game/a11/6queen_lv.rpy:239
translate english queen_lv_014e861e:

    # cass "Уже. Нужна твоя печать и подпись."
    cass "已经取消了。需要你的印章和签名。"

# game/a11/6queen_lv.rpy:240
translate english queen_lv_19f11c39:

    # me "Сделаю. Так что? Меняем кнут на пряник."
    me "我会办的。那么，我们这是要恩威并施了。"

# game/a11/6queen_lv.rpy:241
translate english queen_lv_742d99ae:

    # cass "Ну да. Действуем тонко."
    cass "嗯，对。手段要巧妙。"

# game/a11/6queen_lv.rpy:242
translate english queen_lv_985d7510:

    # me "Хорошо. Я вас понял."
    me "好的。我明白你们的意思了。"

# game/a11/6queen_lv.rpy:243
translate english queen_lv_34b23b2d:

    # guran "Отлично. Тогда я пойду."
    guran "好极了。那我走了。"

# game/a11/6queen_lv.rpy:245
translate english queen_lv_5f3048c7:

    # cass "Ну что, нервничаешь?"
    cass "怎么，紧张吗？"

# game/a11/6queen_lv.rpy:246
translate english queen_lv_5f7e1872_1:

    # me "А должен?"
    me "我应该紧张吗？"

# game/a11/6queen_lv.rpy:247
translate english queen_lv_6fe9121b:

    # cass "Ну...как-никак завтра твоя коронация. Опять."
    cass "嗯……不管怎么说，明天都是你的加冕礼。又一次。"

# game/a11/6queen_lv.rpy:248
translate english queen_lv_7a03e037:

    # guran "Не забудьте про указ."
    guran "别忘了诏令的事。"

# game/a11/6queen_lv.rpy:249
translate english queen_lv_d432d525:

    # cass "Не забудем, вали уже."
    cass "不会忘的，你快走吧。"

# game/a11/6queen_lv.rpy:250
translate english queen_lv_9dfc355d:

    # me "Это будет не совсем моя коронация."
    me "这算不上真正是我的加冕礼。"

# game/a11/6queen_lv.rpy:251
translate english queen_lv_a964d4de:

    # cass "Да ладно тебе, отец еле встает с кровати. Все и так знают, что ты тут король."
    cass "得了吧，你父亲几乎都起不了床。所有人都知道，你才是这里的国王。"

# game/a11/6queen_lv.rpy:252
translate english queen_lv_752e937b:

    # me "Да ну."
    me "才怪。"

# game/a11/6queen_lv.rpy:253
translate english queen_lv_af88df2f:

    # cass "Таки есть."
    cass "真的是。"

# game/a11/6queen_lv.rpy:254
translate english queen_lv_56f69399:

    # me "Разве не король назначает Лорда-наместника?"
    me "难道不是国王任命总督的吗？"

# game/a11/6queen_lv.rpy:255
translate english queen_lv_91a0e891:

    # cass "Ну да."
    cass "嗯，是啊。"

# game/a11/6queen_lv.rpy:256
translate english queen_lv_2c5308bd:

    # me "И что же? Король подписал назначение...как его там?"
    me "那又怎样呢？国王签署了对……他叫什么来着……的任命？"

# game/a11/6queen_lv.rpy:257
translate english queen_lv_a97f88e2:

    # cass "Дюрана."
    cass "Duran。"

# game/a11/6queen_lv.rpy:258
translate english queen_lv_16de10d2:

    # me "Ага. Дюрана. Никогда не поверю, что он сделал это не посоветовавшись с Лаггариусом и Леонардом."
    me "对。Duran。我绝不相信，他没跟Laggarius和Leonard商量就做了这个决定。"

# game/a11/6queen_lv.rpy:259
translate english queen_lv_33b1b89a:

    # cass "Ну может он и посоветовался."
    cass "嗯，他可能确实商量了。"

# game/a11/6queen_lv.rpy:260
translate english queen_lv_088270d8:

    # me "Ага. С ними и с тобой."
    me "是啊。跟他们，还有你。"

# game/a11/6queen_lv.rpy:262
translate english queen_lv_8fe426db:

    # cass "Я тебя уверяю. Я там была лишней."
    cass "我向你保证。我当时在场是多余的。"

# game/a11/6queen_lv.rpy:263
translate english queen_lv_5c445f33:

    # me "Меня там вообще не было."
    me "我根本就不在场。"

# game/a11/6queen_lv.rpy:264
translate english queen_lv_b598e25d:

    # cass "Королева рассказала тебе об утреннем разговоре?"
    cass "是王后告诉了你早上的谈话内容吗？"

# game/a11/6queen_lv.rpy:265
translate english queen_lv_458b73ab:

    # me "Может быть."
    me "也许吧。"

# game/a11/6queen_lv.rpy:266
translate english queen_lv_cbe46b98:

    # cass "Ну конечно. Она. Кто же еще. [mename], не волнуйся, я освобождаю тебя от придворных формальностей."
    cass "当然是了。除了她还能有谁。[mename]，别担心，我免去你所有的宫廷礼仪。"

# game/a11/6queen_lv.rpy:267
translate english queen_lv_1b4d53d1:

    # me "От политических решений."
    me "还有政治决策。"

# game/a11/6queen_lv.rpy:268
translate english queen_lv_1b4fc6bf:

    # cass "Мы это уже обсуждали. Я просто лучше знаю, что нужно делать. Я была при дворе гораздо больше твоего."
    cass "这些我们已经讨论过了。我只是更清楚该做什么。我在宫廷里的时间可比你久得多。"

# game/a11/6queen_lv.rpy:269
translate english queen_lv_66948067:

    # me "Мгм."
    me "嗯。"

# game/a11/6queen_lv.rpy:270
translate english queen_lv_7bdf5a98:

    # cass "Успокойся. Разве я позвала бы политическую марионетку в одиночку защищать меня перед толпой ублюдков с Черной Косы?"
    cass "冷静点。难道我会叫上一个政治傀儡，去独自面对那群“黑镰刀”的杂种们保护我吗？"

# game/a11/6queen_lv.rpy:271
translate english queen_lv_3820771a_6:

    # me "..."
    me "..."

# game/a11/6queen_lv.rpy:272
translate english queen_lv_7d80b270:

    # cass "Мы с тобой вернем Империи ее былое величие. Ты и я."
    cass "我们两个人一起，将恢复帝国昔日的辉煌。你和我。"

# game/a11/6queen_lv.rpy:273
translate english queen_lv_5805455f:

    # me "Ага. Ладно."
    me "嗯。好吧。"

# game/a11/6queen_lv.rpy:274
translate english queen_lv_d86bcec2:

    # cass "Если тебя правда это так волнует - могу звать тебя на каждую бесполезную встречу с вассалами отца, где твой голос ничего не будет значить."
    cass "如果你真的对此如此介怀——我可以叫你去参加你父亲那些封臣的每一次无用会议，在那里你的意见将毫无分量。"

# game/a11/6queen_lv.rpy:275
translate english queen_lv_3820771a_7:

    # me "..."
    me "..."

# game/a11/6queen_lv.rpy:276
translate english queen_lv_d07f7bc4:

    # cass "Или лучше мы, как и прежде, будем приносить королевству....империи пользу."
    cass "或者我们还是像以前一样，为王国……为帝国做出贡献。"

# game/a11/6queen_lv.rpy:277
translate english queen_lv_d5f2e963:

    # me "Скажи честно, ты репетировала?"
    me "坦白说，你刚才是不是排练过？"

# game/a11/6queen_lv.rpy:278
translate english queen_lv_429ca6c7:

    # cass "Может быть. Ладно. Я пойду. Не забудь выспаться, встретимся завтра."
    cass "也许吧。好了。我走了。别忘了好好睡觉，我们明天见。"

# game/a11/6queen_lv.rpy:279
translate english queen_lv_55c4ec71:

    # me "До завтра."
    me "明天见。"

# game/a11/6queen_lv.rpy:281
translate english queen_lv_c5b74baf:

    # me "{i}Иронично. Завтра у меня будет уже две короны, но я все равно не буду королем.{/i}"
    me "{i}真是讽刺。明天我就有两顶王冠了，但我依然不是国王。{/i}"

# game/a11/6queen_lv.rpy:282
translate english queen_lv_c3189d8c:

    # me "{i}Почему отец сам не захотел ее принимать?{/i}"
    me "{i}为什么父亲自己不愿接受它呢？{/i}"

# game/a11/6queen_lv.rpy:283
translate english queen_lv_da14eb82:

    # me "{i}Тем более если он снова стал ходить.{/i}"
    me "{i}更何况他都能重新走路了。{/i}"

# game/a11/6queen_lv.rpy:284
translate english queen_lv_702e2ef1:

    # me "{i}Хотя, для того чтобы принять корону и ходить-то не нужно.{/i}"
    me "{i}不过，接受个王冠，本来也用不着走路。{/i}"

# game/a11/6queen_lv.rpy:285
translate english queen_lv_2538b2c7:

    # me "{i}Может он пытается что-то сделать?{/i}"
    me "{i}也许他想做点什么？{/i}"

# game/a11/6queen_lv.rpy:286
translate english queen_lv_e2698d42:

    # me "{i}Играет в какую-то свою игру?{/i}"
    me "{i}在玩他自己的什么把戏？{/i}"

# game/a11/6queen_lv.rpy:287
translate english queen_lv_64bc0c78:

    # me "{i}Не знаю...{/i}"
    me "{i}我不知道……{/i}"

# game/a11/6queen_lv.rpy:289
translate english queen_lv_8ebfb7c4:

    # mom "All went well?"
    mom "一切顺利吗？"

# game/a11/6queen_lv.rpy:290
translate english queen_lv_2d42945b:

    # me "Aye."
    me "对。"

# game/a11/6queen_lv.rpy:291
translate english queen_lv_800f5df8:

    # mom "Truly?"
    mom "真的？"

# game/a11/6queen_lv.rpy:292
translate english queen_lv_5bf30a01:

    # me "Yes. All’s well. As if you weren’t listening."
    me "是。都很好。好像你没在听似的。"

# game/a11/6queen_lv.rpy:293
translate english queen_lv_b1d5c63b:

    # mom "I wasn’t eavesdropping."
    mom "我没有偷听。"

# game/a11/6queen_lv.rpy:294
translate english queen_lv_ca053a93:

    # me "...Mother?"
    me "...妈妈？"

# game/a11/6queen_lv.rpy:295
translate english queen_lv_d92ad55e:

    # mom "Well, perhaps a little."
    mom "嗯，也许有一点。"

# game/a11/6queen_lv.rpy:296
translate english queen_lv_12eef60d:

    # me "And what did you hear?"
    me "你听到了什么？"

