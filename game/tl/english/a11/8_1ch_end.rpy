    # me "ЧТО ЖЕ ТЫ ЗАМОЛЧАЛ?"
    me "怎么不吭声了？"

# game/a11/8_1ch_end.rpy:616
translate english ch_11_end2_con_ee2b61e2:

    # me "ПОЧЕМУ ТВОЙ ПОГАНЫЙ РОТ БОЛЬШЕ НЕ НАЗЫВАЕТ МЕНЯ МАЛЬЧИШКОЙ, М?"
    me "你那肮脏的嘴怎么不再叫我臭小子了，嗯？"

# game/a11/8_1ch_end.rpy:618
translate english ch_11_end2_con_c2a8c371:

    # me "ИЛИ ТЫ СНОВА РЕШИЛ МЕНЯ ИГНОРИРОВАТЬ?"
    me "还是你又打算无视我？"

# game/a11/8_1ch_end.rpy:620
translate english ch_11_end2_con_d6dfb763:

    # me "НЕ ПОЛУЧИТСЯ. ЧЕМ ДОЛЬШЕ ТЫ МОЛЧИШЬ, ТЕМ БОЛЬШЕ У ТЕБЯ В ЧЕРЕПЕ ВМЯТИН."
    me "没用的。你沉默得越久，你脑袋上的坑就越多。"

# game/a11/8_1ch_end.rpy:622
translate english ch_11_end2_con_c37083b5:

    # mom "Хватит, [mename]..."
    mom "够了，[mename]..."

# game/a11/8_1ch_end.rpy:624
translate english ch_11_end2_con_7873eeae:

    # me "Да. Что-то я увлекся. Уберите его."
    me "是。我是有点太投入了。把他拖下去。"

# game/a11/8_1ch_end.rpy:625
translate english ch_11_end2_con_a56d86a2:

    # me "Уберите его я сказал."
    me "我说了，把他拖下去。"

# game/a11/8_1ch_end.rpy:626
translate english ch_11_end2_con_abb29409:

    # guard "Да, мой принц."
    guard "遵命，我的亲王。"

# game/a11/8_1ch_end.rpy:627
translate english ch_11_end2_con_f2ed6f4e:

    # me "Принц?"
    me "亲王？"

# game/a11/8_1ch_end.rpy:628
translate english ch_11_end2_con_50f76904:

    # guard "Мой...Император..."
    guard "我的...皇帝..."

# game/a11/8_1ch_end.rpy:629
translate english ch_11_end2_con_e8f6a189:

    # me "Найди себе помощника, эта туша много весит."
    me "找个帮手，这坨肉太重了。"

# game/a11/8_1ch_end.rpy:631
translate english ch_11_end2_con_5c76dbe7:

    # me "{i}...{/i}"
    me "{i}...{/i}"

# game/a11/8_1ch_end.rpy:632
translate english ch_11_end2_con_51288673:

    # me "{i}Вот она...цена власти.{/i}"
    me "{i}这便是...权力的代价。{/i}"

# game/a11/8_1ch_end.rpy:633
translate english ch_11_end2_con_5c3c8fec:

    # me "{i}Холодный метал короны и ее темно-зеленый камень...просто вещь? Нет. Она говорила со мной.{/i}"
    me "{i}冰凉的王冠金属与它那暗绿色的宝石...仅仅是一件物品吗？不。它曾对我说话。{/i}"

# game/a11/8_1ch_end.rpy:634
translate english ch_11_end2_con_6c85c7d7:

    # me "{i}Требовала окропить регалию кровью.{/i}"
    me "{i}它要求我以鲜血浇灌这权柄信物。{/i}"

# game/a11/8_1ch_end.rpy:635
translate english ch_11_end2_con_77588082:

    # me "{i}Говорила, что не положено надевать ее на голову без инициации.{/i}"
    me "{i}它说，不经洗礼，无权戴上此冠。{/i}"

# game/a11/8_1ch_end.rpy:636
translate english ch_11_end2_con_b005dc67:

    # me "{i}Власти без крови не бывает. Если ты не прольешь кровь за корону...{/i}"
    me "{i}不流血，则无权。若你不为王冠流血...{/i}"

# game/a11/8_1ch_end.rpy:637
translate english ch_11_end2_con_b44503c1:

    # me "{i}Прольют твою, когда будут срывать ее с твоей головы.{/i}"
    me "{i}那当他们把它从你头上扯下时，就会流你的血。{/i}"

# game/a11/8_1ch_end.rpy:639
translate english ch_11_end2_con_e2c2ad25:

    # me "{i}Но я утолил ее жажду. Утолил потребность в крови.{/i}"
    me "{i}但我已满足了它的渴望。满足了它对血的需求。{/i}"

# game/a11/8_1ch_end.rpy:640
translate english ch_11_end2_con_2d4876c8:

    # me "{i}Я прошел инициацию{/i}"
    me "{i}我已通过了洗礼。{/i}"

# game/a11/8_1ch_end.rpy:641
translate english ch_11_end2_con_f92ed0a7:

    # me "{i}Да...металл на моей голове спокойно гудит...{/i}"
    me "{i}是啊...我头上的金属在平静地嗡鸣...{/i}"

# game/a11/8_1ch_end.rpy:642
translate english ch_11_end2_con_2f53f8ae:

    # me "{i}Он знает, что я его новый хозяин.{/i}"
    me "{i}它知道我是它的新主人了。{/i}"

# game/a11/8_1ch_end.rpy:643
translate english ch_11_end2_con_293cf220:

    # me "{i}Он видел, что я ради него сделал.{/i}"
    me "{i}它看见了我为它所做的一切。{/i}"

# game/a11/8_1ch_end.rpy:644
translate english ch_11_end2_con_3d7e2237:

    # me "{i}Я король, а не мой отец. Я Император, а не мой отец. Все они это видели и понимают. И корона...она тоже видела... И даже безымянные боги. Это мое.{/i}"
    me "{i}我才是国王，而非我的父亲。我才是皇帝，而非我的父亲。他们都看到了，也都明白了。而王冠...它也一样看到了...甚至无名的众神也看到了。这是我的了。{/i}"

# game/a11/8_1ch_end.rpy:646
translate english ch_11_end2_con_cb7b6def:

    # me "Как хорошо, что в этом зале больше нет живых предателей. По крайней мере пока что."
    me "真好，这大厅里再也没有活着的叛徒了。至少暂时如此。"

# game/a11/8_1ch_end.rpy:647
translate english ch_11_end2_con_6bd0f819:

    # me "А раз так - поднимите кубки."
    me "既然如此——举起你们的酒杯。"

# game/a11/8_1ch_end.rpy:648
translate english ch_11_end2_con_b2f30e6b:

    # me "Выпейте за силу и верность."
    me "为力量与忠诚干杯。"

# game/a11/8_1ch_end.rpy:649
translate english ch_11_end2_con_339a3370:

    # me "За волю и решимость."
    me "为意志与决心干杯。"

# game/a11/8_1ch_end.rpy:650
translate english ch_11_end2_con_baae4663:

    # me "За долг и клятвы."
    me "为责任与誓言干杯。"

# game/a11/8_1ch_end.rpy:651
translate english ch_11_end2_con_e8121f9a_1:

    # me "За Золотой Порядок."
    me "为黄金秩序干杯。"

# game/a11/8_1ch_end.rpy:652
translate english ch_11_end2_con_313537ea_1:

    # me "За Железную Волю."
    me "为钢铁意志干杯。"

# game/a11/8_1ch_end.rpy:653
translate english ch_11_end2_con_1d0e4355:

    # me "Выпейте за своего нового Императора."
    me "为你们的新皇帝干杯。"

# game/a11/8_1ch_end.rpy:658
translate english ch_11_end2_ala_041bc8c5:

    # me "{size=+5}Верно, леди [alaina]?{/size}"
    me "{size=+5}我说得对吗，[alaina]夫人？{/size}"

# game/a11/8_1ch_end.rpy:659
translate english ch_11_end2_ala_92443169:

    # ala "Чего?"
    ala "什么？"

# game/a11/8_1ch_end.rpy:660
translate english ch_11_end2_ala_e72e415d:

    # me "{size=+5}Да. Я обращаюсь к вам.{/size}"
    me "{size=+5}对。我就是在对您说话。{/size}"

# game/a11/8_1ch_end.rpy:661
translate english ch_11_end2_ala_0dc54aab:

    # ala "Какого хрена..."
    ala "搞什么鬼..."

# game/a11/8_1ch_end.rpy:662
translate english ch_11_end2_ala_0af58be0:

    # me "{size=+5}Именно вы та самая тень. Арестуйте ее.{/size}"
    me "{size=+5}您就是那片阴霾。逮捕她。{/size}"

# game/a11/8_1ch_end.rpy:664
translate english ch_11_end2_ala_b89e84d0:

    # ala "{size=+5}Только попробуйте, первый кто ко мне приблизится - превратится в первое блюдо на стол.{/size}"
    ala "{size=+5}你们尽管试试，第一个靠近我的人——会变成桌上的头道菜。{/size}"

# game/a11/8_1ch_end.rpy:665
translate english ch_11_end2_ala_88c1fd7c:

    # me "{size=+5}Не стоит все усложнять.{/size}"
    me "{size=+5}别让事情变得复杂。{/size}"

# game/a11/8_1ch_end.rpy:666
translate english ch_11_end2_ala_811d28f7:

    # ala "{size=+5}Вот именно. Не усложняй все, [mename].{/size}"
    ala "{size=+5}正是如此。别把事情搞复杂了，[mename]。{/size}"

# game/a11/8_1ch_end.rpy:667
translate english ch_11_end2_ala_23d09893:

    # me "{size=+5}Прекрати. Если ты воспользуешься магией, все в зале захотят воткнуть в тебя мечи.{/size}"
    me "{size=+5}住手。如果你动用魔法，这大厅里的每一个人都会想把剑捅进你的身体。{/size}"

# game/a11/8_1ch_end.rpy:668
translate english ch_11_end2_ala_089bf386:

    # ala "{size=+5}А я и не воспользуюсь ей. Если ко мне никто не подойдет.{/size}"
    ala "{size=+5}我也不打算用。只要没人靠近我。{/size}"

# game/a11/8_1ch_end.rpy:669
translate english ch_11_end2_ala_a4985c37:

    # me "{size=+5}Это невозможно. Предлагаю добровольно сдаться.{/size}"
    me "{size=+5}这不可能。我建议你自愿束手就擒。{/size}"

# game/a11/8_1ch_end.rpy:670
translate english ch_11_end2_ala_9abd9f20:

    # ala "{size=+5}Предлагаю тебе отсосать у самого себя. Как только выполнишь мое предложение - я выполню свое.{/size}"
    ala "{size=+5}我建议你自己给自己口交。只要你完成我的提议——我就完成你的。{/size}"

# game/a11/8_1ch_end.rpy:672
translate english ch_11_end2_ala_805e670c:

    # ala "Что за... вы что делаете?"
    ala "你们这是...你们在做什么？"

# game/a11/8_1ch_end.rpy:673
translate english ch_11_end2_ala_e0003846:

    # mom "Не шевелись, [alaina], или сделаешь только хуже."
    mom "别动，[alaina]，否则只会更糟。"

# game/a11/8_1ch_end.rpy:674
translate english ch_11_end2_ala_c8c13944:

    # ala "Вы спятили? Серафина?"
    ala "你们疯了吗？Seraphina？"

# game/a11/8_1ch_end.rpy:675
translate english ch_11_end2_ala_32ac1c64:

    # mom "Не сопротивляйся."
    mom "别反抗。"

# game/a11/8_1ch_end.rpy:676
translate english ch_11_end2_ala_2ec24f8f:

    # ala "[elin]?"
    ala "[elin]?"

# game/a11/8_1ch_end.rpy:677
translate english ch_11_end2_ala_ded091ac:

    # elin "Прошу леди [alaina], не заставляйте нас делать что-то еще."
    elin "求您了，[alaina]夫人，别逼我们做更多事。"

# game/a11/8_1ch_end.rpy:679
translate english ch_11_end2_ala_17150d85:

    # me "Вы сознаетесь в преступлениях против короны?"
    me "你承认犯下危害王室的罪行吗？"

# game/a11/8_1ch_end.rpy:680
translate english ch_11_end2_ala_2d326d45:

    # ala "Нет."
    ala "不承认。"

# game/a11/8_1ch_end.rpy:681
translate english ch_11_end2_ala_b7c4b117:

    # me "Очень жаль. Раскаяние было бы кстати."
    me "非常遗憾。坦白从宽本该对你有利。"

# game/a11/8_1ch_end.rpy:682
translate english ch_11_end2_ala_ce5e75cb:

    # ala "Кстати для чего? Для цирка, что ты устроил? Я не стану ни в чем сознаваться."
    ala "有什么好处？为了你安排的这场把戏？我什么也不会承认。"

# game/a11/8_1ch_end.rpy:683
translate english ch_11_end2_ala_4f0286db:

    # me "Даже в том, что тайно вели переписку с эльфами Долины?"
    me "就连暗中与山谷精灵通信的事也不承认吗？"

# game/a11/8_1ch_end.rpy:684
translate english ch_11_end2_ala_b7728ede:

    # ala "Спроси у своей матери. Она мне помогала."
    ala "去问你母亲。她曾协助过我。"

# game/a11/8_1ch_end.rpy:685
translate english ch_11_end2_ala_67df8173:

    # me "Я просил у нее. Она показала мне некоторые письма."
    me "我问过她了。她给我看了一些信件。"

# game/a11/8_1ch_end.rpy:686
translate english ch_11_end2_ala_cdef4f8c:

    # ala "И что? Почему тогда она не рядом со мной?"
    ala "那又如何？那她为什么不和我一样跪在这里？"

# game/a11/8_1ch_end.rpy:687
translate english ch_11_end2_ala_bdc1e3c2:

    # me "Потому что она писала своей семье. Описывала быт, взросление детей, еду при дворе. А вот вы, леди [alaina], в ваших письмах информация куда более...секретная."
    me "因为她写的是家信。描述了宫廷生活、孩子们的成长、饮食。而您，[alaina]夫人，您信中的信息...机密得多了。"

# game/a11/8_1ch_end.rpy:688
translate english ch_11_end2_ala_7df6f482:

    # ala "Что за чушь ты несешь?"
    ala "你胡说八道些什么？"

# game/a11/8_1ch_end.rpy:690
translate english ch_11_end2_ala_b2fa108a:

    # me "Так что? Этого не было?"
    me "怎么？你没做过？"

# game/a11/8_1ch_end.rpy:691
translate english ch_11_end2_ala_2d326d45_1:

    # ala "Нет."
    ala "没有。"

# game/a11/8_1ch_end.rpy:692
translate english ch_11_end2_ala_10031962:

    # me "Понятно. Видимо Конрад подделал найденное у твоего агента письмо, да?"
    me "明白了。看来是Conrad伪造了在你探子身上找到的信件，对吧？"

# game/a11/8_1ch_end.rpy:693
translate english ch_11_end2_ala_465a9dbd:

    # ala "Может быть."
    ala "有可能。"

# game/a11/8_1ch_end.rpy:694
translate english ch_11_end2_ala_d8753cf5:

    # me "Ну конечно. Естественно."
    me "呵，当然。理所当然。"

# game/a11/8_1ch_end.rpy:695
translate english ch_11_end2_ala_b6ac667e:

    # ala "А даже если оно и настоящее, повторю - почему твоя мать не рядом со мной?"
    ala "就算那封信是真的，我再问一次——为什么你的母亲不在这里陪着我？"

# game/a11/8_1ch_end.rpy:696
translate english ch_11_end2_ala_fb447482:

    # me "Потому что она..."
    me "因为她是..."

# game/a11/8_1ch_end.rpy:697
translate english ch_11_end2_ala_6008e2b0:

    # ala "Бред. Ты знаешь, что это неправда. Она помогала мне все это время."
    ala "荒唐。你知道这不是真的。一直以来，她都在帮我。"

# game/a11/8_1ch_end.rpy:698
translate english ch_11_end2_ala_fc277af8:

    # me "Конечно. Ты ведь манипулировала ей. Она думала, что переписывается с семьей. Даже не подозревала, что за письма ты шлешь вместе с ее письмами."
    me "当然了。是你操纵了她。她以为只是在和家里人通信。甚至都没怀疑过，你借她寄信之便，还夹带了什么信件出去。"

# game/a11/8_1ch_end.rpy:700
translate english ch_11_end2_ala_7b35af31:

    # ala "Умоляю, избавь меня от этого бреда."
    ala "得了吧，别用这种胡言乱语来烦我。"

# game/a11/8_1ch_end.rpy:701
translate english ch_11_end2_ala_b2f4614d:

    # me "Бреда? "
    me "胡言乱语？"

# game/a11/8_1ch_end.rpy:702
translate english ch_11_end2_ala_64996f9f:

    # ala "Да. Я уже поняла, что это просто фарс. Если тебе нужно от меня какое-то признание - его не будет. Я понятия не имею, в чем виновна."
    ala "对。我已经看明白了，这不过是一场闹剧。如果你需要我做出什么供认——绝无可能。我根本不知道我何罪之有。"

# game/a11/8_1ch_end.rpy:703
translate english ch_11_end2_ala_612fffa4:

    # me "Да что ты."
    me "哦，是吗。"

# game/a11/8_1ch_end.rpy:704
translate english ch_11_end2_ala_166fe0b4:

    # ala "Да. А если и знаю... ты правда хочешь, чтобы я рассказала это прямо здесь?"
    ala "是的。就算我知道...你真的想让我在这里当着所有人的面说出来吗？"

# game/a11/8_1ch_end.rpy:705
translate english ch_11_end2_ala_3820771a:

    # me "..."
    me "..."

# game/a11/8_1ch_end.rpy:706
translate english ch_11_end2_ala_b2b8d437:

    # ala "Ну же. Разреши мне и ты знаешь что произойдет."
    ala "来啊。允许我说，你就知道后果如何。"

# game/a11/8_1ch_end.rpy:707
translate english ch_11_end2_ala_8b677452:

    # me "Что же?"
    me "什么后果？"

# game/a11/8_1ch_end.rpy:708
translate english ch_11_end2_ala_233ff1ec:

    # ala "Все рухнет. Я бы могла рассказать это и сама. Но я служу короне и не собираюсь вредить ей...правдой."
    ala "一切都会崩塌。我本可以自己说出来。但我服务于王室，不打算用...真相来损害它。"

# game/a11/8_1ch_end.rpy:709
translate english ch_11_end2_ala_2ddad60d:

    # me "Правда..."
    me "真相..."

# game/a11/8_1ch_end.rpy:710
translate english ch_11_end2_ala_92a9b571:

    # ala "Если бы ты ее не знал, я бы не оказалась здесь на коленях, верно? Так что прими уже решение."
    ala "如果你不知晓真相，我现在也不会跪在这里，对吧？所以，快做决定吧。"

# game/a11/8_1ch_end.rpy:714
translate english ch_11_end2_ala_057fe43d:

    # me "Я принял решение. Леди [alaina], хоть ваши действия и нельзя назвать преступлением, я считаю их продолжением ваших...вредных для Короны и Империи намерений."
    me "我已做出决定。[alaina]夫人，尽管您的行为尚不能完全界定为罪行，但我认为它们是您那些...对王室及帝国有害意图的延续。"

# game/a11/8_1ch_end.rpy:715
translate english ch_11_end2_ala_7eaaa70a:

    # ala "Идиот..."
    ala "白痴..."

# game/a11/8_1ch_end.rpy:716
