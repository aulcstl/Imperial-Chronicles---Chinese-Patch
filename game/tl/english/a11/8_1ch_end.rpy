    # conrad "Да вы ахуели!"
    conrad "你们他妈疯了吧！"

# game/a11/8_1ch_end.rpy:467
translate english ch_11_end2_con_a8815d46:

    # mom "Я тебя предупредила."
    mom "我警告过你了。"

# game/a11/8_1ch_end.rpy:468
translate english ch_11_end2_con_f4eef025_2:

    # me "Конрад."
    me "Conrad。"

# game/a11/8_1ch_end.rpy:469
translate english ch_11_end2_con_fedbc2ce:

    # conrad "Пф...ну и семейка. Что, зажаришь меня прямо здесь?"
    conrad "呸...真是一家子。怎么，你要在这儿把我烤了吗？"

# game/a11/8_1ch_end.rpy:470
translate english ch_11_end2_con_8c8c12f0:

    # mom "Если придется."
    mom "有必要的话。"

# game/a11/8_1ch_end.rpy:471
translate english ch_11_end2_con_3820771a_4:

    # me "..."
    me "..."

# game/a11/8_1ch_end.rpy:475
translate english ch_11_end2_con_f4eef025_3:

    # me "Конрад."
    me "Conrad。"

# game/a11/8_1ch_end.rpy:476
translate english ch_11_end2_con_9c8512f3:

    # conrad "Ну что?"
    conrad "又怎么了？"

# game/a11/8_1ch_end.rpy:477
translate english ch_11_end2_con_be5eb66a:

    # me "Меня удивляет, сколько в тебе неуважения."
    me "我惊讶于你竟怀有如此多的不敬。"

# game/a11/8_1ch_end.rpy:478
translate english ch_11_end2_con_8534d021:

    # conrad "Я должен уважать того, кто не уважает меня?"
    conrad "我该尊重一个不尊重我的人吗？"

# game/a11/8_1ch_end.rpy:479
translate english ch_11_end2_con_fc0fdd1c:

    # me "Ты должен уважать своего Короля, а теперь и Императора."
    me "你该尊重你的国王，现在则是你的皇帝。"

# game/a11/8_1ch_end.rpy:480
translate english ch_11_end2_con_8bb7bc6d:

    # conrad "Ты не Император, мальчик. И даже не король. Ты принц-регент."
    conrad "你不是皇帝，小子。甚至不是国王。你只是个摄政亲王。"

# game/a11/8_1ch_end.rpy:481
translate english ch_11_end2_con_bef2b726:

    # me "Конечно. Мой отец носит все эти регалии. Но как ты и отметил ранее, я регент."
    me "当然。我父亲才佩戴着那些权柄信物。但正如你先前指出的，我是摄政。"

# game/a11/8_1ch_end.rpy:482
translate english ch_11_end2_con_bd724dc1:

    # conrad "И что?"
    conrad "那又如何？"

# game/a11/8_1ch_end.rpy:483
translate english ch_11_end2_con_9ccc8ebb:

    # me "Я исполняю волю отца. Неуважение ко мне, к моим приказам и к другим людям в замке..."
    me "我执行我父亲的意志。对我不敬，对我的命令不敬，对城堡中的其他人不敬..."

# game/a11/8_1ch_end.rpy:484
translate english ch_11_end2_con_41b31c60:

    # conrad "К эльфийской суке!"
    conrad "对那个精灵婊子！"

# game/a11/8_1ch_end.rpy:485
translate english ch_11_end2_con_d95546ce:

    # me "Об этом я и говорю. Ты снова меня перебил."
    me "我说的正是这个。你又打断了我的话。"

# game/a11/8_1ch_end.rpy:486
translate english ch_11_end2_con_a5dde3ec:

    # conrad "..."
    conrad "..."

# game/a11/8_1ch_end.rpy:487
translate english ch_11_end2_con_9e0f8879:

    # me "Спасибо. Я освобождаю тебя от всех занимаемых тобой обязанностей."
    me "谢谢。我解除你目前担任的一切职务。"

# game/a11/8_1ch_end.rpy:488
translate english ch_11_end2_con_489af7be:

    # conrad "Ты не можешь."
    conrad "你不能这么做。"

# game/a11/8_1ch_end.rpy:489
translate english ch_11_end2_con_db0675e5:

    # me "Могу. Я исполняю волю отца."
    me "我能。我是在执行父王的意志。"

# game/a11/8_1ch_end.rpy:490
translate english ch_11_end2_con_811be9fe:

    # conrad "Вот именно. Исполняешь. А не формируешь сам."
    conrad "正是如此。你在执行，而不是自行决断。"

# game/a11/8_1ch_end.rpy:491
translate english ch_11_end2_con_669c95d5:

    # me "Я говорил с отцом утром. Он согласен со мной."
    me "我今早和父王谈过了。他同意我的看法。"

# game/a11/8_1ch_end.rpy:492
translate english ch_11_end2_con_02ec9cf6:

    # conrad "Что? Я в это никогда не поверю."
    conrad "什么？我绝不会相信。"

# game/a11/8_1ch_end.rpy:493
translate english ch_11_end2_con_eb5e9423:

    # me "Я сообщил ему, что вместо службы, ты самостоятельно принимаешь решения. Мы пришли к выводу, что это не соотносится с обязанностями на твоей должности."
    me "我禀告他，你并非恪尽职守，而是独断专行。我们得出结论，这与你所处职位应尽的职责不符。"

# game/a11/8_1ch_end.rpy:494
translate english ch_11_end2_con_db31ab91:

    # conrad "Бред."
    conrad "一派胡言。"

# game/a11/8_1ch_end.rpy:495
translate english ch_11_end2_con_44df41c9:

    # me "Ты все еще член семьи. Ты сохраняешь за собой имя и привилегии, но Империя в твоих услугах более не нуждается."
    me "你依然是家族的一员。你保留你的姓氏和特权，但帝国不再需要你的服务了。"

# game/a11/8_1ch_end.rpy:497
