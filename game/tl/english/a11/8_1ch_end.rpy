    # "Час спустя."
    "一个小时以后。"

# game/a11/8_1ch_end.rpy:7
translate english ch_11_end_0c66afe5:

    # me "{i}Ну...кажется все готово.{/i}"
    me "{i}嗯...看来一切就绪。{/i}"

# game/a11/8_1ch_end.rpy:8
translate english ch_11_end_a9bca68a:

    # me "{i}Время принять корону для отца.{/i}"
    me "{i}是时候为父亲戴上王冠了。{/i}"

# game/a11/8_1ch_end.rpy:9
translate english ch_11_end_5c76dbe7:

    # me "{i}...{/i}"
    me "{i}...{/i}"

# game/a11/8_1ch_end.rpy:10
translate english ch_11_end_f28766cf:

    # me "{i}Забавно. Может мне стоило прийти в короне принца-регента? Тогда бы я надевал корону на корону.{/i}"
    me "{i}有意思。也许我该戴着摄政亲王的冠冕来？那样就能冠上加冠了。{/i}"

# game/a11/8_1ch_end.rpy:11
translate english ch_11_end_2faef69b:

    # me "{i}Интересно отец дал мне эту возможность потому что он болен или потому что...{/i}"
    me "{i}真想知道父亲给我这个机会，是因为他病重，还是因为...{/i}"

# game/a11/8_1ch_end.rpy:12
translate english ch_11_end_551c11b0:

    # me "{i}...почему? Он хочет чтобы я был королем уже сейчас? Тогда почему он не откажется от власти в мою пользу? Вопросов больше, чем ответов. Возможно мне стоит с ним об этом поговорить.{/i}"
    me "{i}...为什么？他想让我现在就当国王？那他为什么不直接让位给我？问题比答案更多。也许我该跟他谈谈这件事。{/i}"

# game/a11/8_1ch_end.rpy:13
translate english ch_11_end_2a152b6f:

    # me "{i}Надеюсь в этом не замешаны очередные предсказания.{/i}"
    me "{i}但愿这背后没有牵扯到那些没完没了的预言。{/i}"

# game/a11/8_1ch_end.rpy:15
translate english ch_11_end_a75d9cf6:

    # mom "[mename]? Ты готов?"
    mom "[mename]？你准备好了吗？"

# game/a11/8_1ch_end.rpy:16
translate english ch_11_end_5e648c4f:

    # me "Как видишь."
    me "如你所见。"

# game/a11/8_1ch_end.rpy:17
translate english ch_11_end_ff22f29c:

    # mom "Ты уже надел мантию? Пока мы дойдем до тронного зала она испачкается."
    mom "你已经披上礼袍了？等我们走到王座厅，它会弄脏的。"

# game/a11/8_1ch_end.rpy:18
translate english ch_11_end_004db99e:

    # me "Меня одевали слуги."
    me "仆人们帮我穿好的。"

# game/a11/8_1ch_end.rpy:19
translate english ch_11_end_c81aad3c:

    # mom "Нужно было доверить это мне. Я бы одела ее на тебя прямо перед церемонией."
    mom "你该让我来做这件事。我会在典礼开始前亲手为你披上。"

# game/a11/8_1ch_end.rpy:20
translate english ch_11_end_84b1f28a:

    # me "Мне ее снять?"
    me "要我现在脱下来吗？"

# game/a11/8_1ch_end.rpy:21
translate english ch_11_end_1f39a4c0:

    # mom "Нет...я...я просто немного волнуюсь вот и все."
    mom "不...我...我只是有点紧张，仅此而已。"

# game/a11/8_1ch_end.rpy:22
translate english ch_11_end_3390d39e:

    # me "Они будут болтать всякое в любом случае, но состояние моей мантии их будет интересовать в последнюю очередь, я уверяю."
    me "不管怎样他们都会说三道四，但我向你保证，我的礼袍状态如何，绝对是他们最后才会关心的事。"

# game/a11/8_1ch_end.rpy:23
translate english ch_11_end_68637db8:

    # mom "Ты прав."
    mom "你说得对。"

# game/a11/8_1ch_end.rpy:25
translate english ch_11_end_db135cac:

    # me "Я вот думаю, может мне отпустить бороду?"
    me "我在想，也许我该留胡子？"

# game/a11/8_1ch_end.rpy:26
translate english ch_11_end_199b9239:

    # mom "Зачем?"
    mom "为什么？"

# game/a11/8_1ch_end.rpy:27
translate english ch_11_end_cde03d19:

    # me "Раз уж я выполняю обязанности короля."
    me "既然我要履行国王的职责。"

# game/a11/8_1ch_end.rpy:28
translate english ch_11_end_fd5e4cd4:

    # mom "А как это связано?"
    mom "这两者有什么联系？"

# game/a11/8_1ch_end.rpy:29
translate english ch_11_end_09250013:

    # me "Борода добавляет возраста лицу. А людям проще доверять и подчиняться тем, кто их старше."
    me "胡子能让面容显得更年长。人们更容易信任并服从比他们年长的人。"

# game/a11/8_1ch_end.rpy:30
translate english ch_11_end_9b8dccd5:

    # mom "Это имеет смысл. Но ты ведь все еще не король. Принц-регнент Золотого Королевства."
    mom "这倒说得通。但你还不是国王。你是黄金王国的摄政亲王。"

# game/a11/8_1ch_end.rpy:31
translate english ch_11_end_9cea5c87:

    # me "Принцам можно ходить и без бороды?"
    me "亲王就可以不留胡子吗？"

# game/a11/8_1ch_end.rpy:32
translate english ch_11_end_09c802f6:

    # mom "Молодость тоже может быть к лицу королевской особе."
    mom "年轻对王室成员来说也可能很相称。"

# game/a11/8_1ch_end.rpy:33
translate english ch_11_end_5ac38cf1:

    # me "Почему?"
    me "为什么？"

# game/a11/8_1ch_end.rpy:34
translate english ch_11_end_4db4e3e3:

    # mom "Молодость это символ изменений. Песня о новой жизни и порядке. По-моему, молодость хорошо подходит сегодняшнему мероприятию."
    mom "年轻是变革的象征。是新生活、新秩序的颂歌。在我看来，年轻非常适合今天的盛事。"

# game/a11/8_1ch_end.rpy:35
translate english ch_11_end_3820771a:

    # me "..."
    me "..."

# game/a11/8_1ch_end.rpy:37
translate english ch_11_end_e30f34ab:

    # mom "Не переживай, старики будут рады, что ты вернул им их Империю. Это их молодость. А молодые - увидят в тебе одного из них."
    mom "别担心，老人们会高兴你帮他们恢复了帝国。那是他们的青春。而年轻人——会在你身上看到他们自己。"

# game/a11/8_1ch_end.rpy:38
translate english ch_11_end_473c9b2b:

    # me "Ты так думаешь?"
    me "你这么认为？"

# game/a11/8_1ch_end.rpy:39
translate english ch_11_end_657ef69f:

    # mom "Я уверена. Все пройдет хорошо."
    mom "我确信。一切都会很顺利。"

# game/a11/8_1ch_end.rpy:40
translate english ch_11_end_fee26889:

    # me "...конечно."
    me "...当然。"

# game/a11/8_1ch_end.rpy:41
translate english ch_11_end_6930cbd9:

    # mom "Пойдем?"
    mom "我们走吧？"

# game/a11/8_1ch_end.rpy:42
translate english ch_11_end_21d78709:

    # me "Пойдем."
    me "走吧。"

# game/a11/8_1ch_end.rpy:44
translate english ch_11_end_8109c491:

    # me "Выглядишь как-то по-боевому, [mename]."
    me "你看起来有点…杀气腾腾的，[mename]。"

