# game/a11/8_1ch_end.rpy:109
translate english ch_11_end_03403faf:

    # golosa2 "Нам? Языки? Это мы спонсировали его авантюру на Запад!"
    golosa2 "我们？舌头？是我们资助了他西征的冒险！"

# game/a11/8_1ch_end.rpy:110
translate english ch_11_end_3c92de85:

    # golosa3 "И что? Зря что ли? Империя возрождается!"
    golosa3 "那又怎样？难道白费劲吗？帝国正在复兴！"

# game/a11/8_1ch_end.rpy:111
translate english ch_11_end_a94b4344:

    # golosa "Нахрен нам эта Империя? И без нее жили неплохо."
    golosa "我们才不在乎什么帝国！没有它，我们过得也不赖。"

# game/a11/8_1ch_end.rpy:112
translate english ch_11_end_3c12ff99:

    # golosa2 "Закрой пасть, сопляк. Золотая Империя вечна!"
    golosa2 "闭嘴，小崽子。黄金帝国永恒不灭！"

# game/a11/8_1ch_end.rpy:113
translate english ch_11_end_da98baac:

    # golosa3 "Он похож на своего деда."
    golosa3 "他长得像他的祖父。"

# game/a11/8_1ch_end.rpy:114
translate english ch_11_end_1241324a:

    # golosa "О безымянные боги, надеюсь это не так."
    golosa "哦，无名的众神啊，但愿不是那样。"

# game/a11/8_1ch_end.rpy:115
translate english ch_11_end_7d15cc71_2:

    # guard "Дорогу!"
    guard "让路！"

# game/a11/8_1ch_end.rpy:117
translate english ch_11_end_fc9702a9:

    # golosa "Видели его жену? Она не отсюда."
    golosa "你们看到他的妻子了吗？她不是本地人。"

# game/a11/8_1ch_end.rpy:118
translate english ch_11_end_1f265203:

    # golosa2 "Говорят этот брак для того, чтобы присоединить к Империи еще кусок."
    golosa2 "据说这场联姻是为了给帝国再吞并一块领地。"

# game/a11/8_1ch_end.rpy:119
translate english ch_11_end_573b3239:

    # golosa3 "Какой еще Империи? У нас королевство."
    golosa3 "什么帝国？我们是王国。"

# game/a11/8_1ch_end.rpy:120
translate english ch_11_end_b56cd6d8:

    # golosa "Уже нет."
    golosa "已经不是了。"

# game/a11/8_1ch_end.rpy:121
translate english ch_11_end_1799b32c:

    # golosa2 "А разве так можно? Принимать корону за короля?"
    golosa2 "但这合乎规矩吗？代替国王接受王冠？"

# game/a11/8_1ch_end.rpy:122
translate english ch_11_end_cadf5633:

    # golosa3 "Нельзя. Говорят королевская делегация ездила к городскому трибуналу."
    golosa3 "不合规矩。听说王室代表团去找过城市裁判庭了。"

# game/a11/8_1ch_end.rpy:123
translate english ch_11_end_3b7cadc9:

    # golosa "И что они сказали?"
    golosa "他们怎么说？"

# game/a11/8_1ch_end.rpy:124
translate english ch_11_end_7576fce1:

    # golosa2 "Сам подумай, болван."
    golosa2 "你自个儿想想，笨蛋。"

# game/a11/8_1ch_end.rpy:125
translate english ch_11_end_c6c94c4c:

    # golosa3 "А что они сделают? Откажут королевской власти?"
    golosa3 "他们能怎样？驳回王室的权威吗？"

# game/a11/8_1ch_end.rpy:126
translate english ch_11_end_ea11e2c5:

    # golosa "Могут и отказать."
    golosa "他们确实可以驳回。"

# game/a11/8_1ch_end.rpy:127
translate english ch_11_end_d862b259:

    # golosa2 "Кто-нибудь может меня приподнять? Я ни хрена не вижу!"
    golosa2 "谁行行好，扶我一把？我什么都看不见！"

# game/a11/8_1ch_end.rpy:128
translate english ch_11_end_5b30c14a:

    # golosa3 "Отказать? Не смешите меня. Если понадобится, трибунал изменит Золотой Порядок так, что завтра вместо короля коронуют не то что его сына, а дворовую собаку."
    golosa3 "驳回？别逗我笑了。如果需要的话，裁判庭会把《黄金秩序》改得面目全非，明天别说加冕他儿子，连加冕一只看门狗都行。"

# game/a11/8_1ch_end.rpy:129
translate english ch_11_end_151d00c3:

    # golosa "Тсс... вы верно на виселицу захотели за такие разговоры."
    golosa "嘘...说这种话，你们肯定想上绞刑架了。"

# game/a11/8_1ch_end.rpy:130
translate english ch_11_end_3e6eded9:

    # golosa2 "Успокойся. Времена Красного Императора прошли."
    golosa2 "冷静点。红色皇帝的时代已经过去了。"

# game/a11/8_1ch_end.rpy:131
translate english ch_11_end_41c063f2:

    # golosa3 "Еще настанут. Чувствую в этом парнишке его крови больше всего."
    golosa3 "还会再来的。我感觉这小子身上那位的血脉最浓。"

# game/a11/8_1ch_end.rpy:133
translate english ch_11_end_606a78e4:

    # lagg "Ну как оно?"
    lagg "感觉如何？"

# game/a11/8_1ch_end.rpy:134
translate english ch_11_end_ad02f53a:

    # me "Что?"
    me "什么？"

# game/a11/8_1ch_end.rpy:135
translate english ch_11_end_283be038:

    # lagg "Они думают, что раз говорят все разом, то каждого по отдельности не слышно."
    lagg "他们以为大家都在同时说话，就听不清每个人各自在说什么了。"

# game/a11/8_1ch_end.rpy:136
translate english ch_11_end_1b07afee:

    # leonard "Разве посланник уже не должен быть здесь?"
    leonard "使者不是应该早就在这里了吗？"

# game/a11/8_1ch_end.rpy:137
translate english ch_11_end_0b4e464e:

    # me "Я думал, я пришел сюда последним."
    me "我还以为我是最后一个到的呢。"

# game/a11/8_1ch_end.rpy:138
translate english ch_11_end_500cdaad:

    # lagg "Ну это было бы странно нести корону туда, где некому ее надеть, верно?"
    lagg "嗯，毕竟把王冠送到没人能戴的地方，确实挺奇怪的，对吧？"

# game/a11/8_1ch_end.rpy:139
translate english ch_11_end_22cef9ea:

    # leonard "Но теперь принц тут и я что не вижу посланника."
    leonard "但现在亲王已经到了，我却没看到使者的人影。"

# game/a11/8_1ch_end.rpy:140
translate english ch_11_end_9284aeea:

    # lagg "Думаешь он сбежал вместе с короной?"
    lagg "你觉得他会不会带着王冠跑了？"

# game/a11/8_1ch_end.rpy:141
translate english ch_11_end_84fd076e:

    # leonard "Понятия не имею. Но я его не вижу."
    leonard "完全不知道。但我没看到他。"

# game/a11/8_1ch_end.rpy:142
translate english ch_11_end_57094a3a:

    # lagg "Может спросите об этом ваших новых подданных, мой принц?"
    lagg "关于这件事，也许您该问问您的新臣民，我的亲王？"

# game/a11/8_1ch_end.rpy:143
translate english ch_11_end_946bdb00:

    # me "Новых подданных?"
    me "新臣民？"

# game/a11/8_1ch_end.rpy:144
translate english ch_11_end_26f6d9bb:

    # leonard "А. Вот он. Сейчас тоже будет пробираться через толпу."
    leonard "啊。他来了。现在他也得穿过人群挤过来。"

# game/a11/8_1ch_end.rpy:145
translate english ch_11_end_471df69f:

    # lagg "Они сюда пришли даже раньше нас. Исполнительные. Это хорошо. Настоящие дети Запада."
    lagg "他们到得比我们还早。执行力很强。这很好。真正的西部儿女。"

# game/a11/8_1ch_end.rpy:148
translate english ch_11_end_a194a641:

    # guidon "Скажи павлину справа от тебя, что если он будет много болтать, я ему зубы прорежу."
    guidon "告诉你右边那只孔雀，他要是再喋喋不休，我就给他嘴上来几刀。"

# game/a11/8_1ch_end.rpy:149
translate english ch_11_end_1e2cfcff:

    # argus "Успокойтесь, лорд Гвидон."
    argus "冷静点，格维多大人。"

# game/a11/8_1ch_end.rpy:150
translate english ch_11_end_cc4d5394:

    # me "По-моему Лаггариус одарил вас комплиментом."
    me "在我看来，Laggarius刚刚是在夸奖您呢。"

# game/a11/8_1ch_end.rpy:151
translate english ch_11_end_6e753d7e:

    # guidon "Нда конечно. Я ему не шавка. Теперь я такой же знаменосец Красной Империи, как и он."
    guidon "哼，当然。我又不是他的走狗。现在我和他一样，也是红色帝国的掌旗官了。"

# game/a11/8_1ch_end.rpy:152
translate english ch_11_end_893f181d:

    # me "Конечно. Красной?"
    me "当然。红色？"

# game/a11/8_1ch_end.rpy:153
translate english ch_11_end_f4b53bd7:

    # argus "Золотой Империи."
    argus "黄金帝国。"

# game/a11/8_1ch_end.rpy:154
translate english ch_11_end_9a28c95a:

    # guidon "Чтобы золото сияло надо удобрять его кровью."
    guidon "要让黄金闪耀，就得用鲜血来浇灌。"

# game/a11/8_1ch_end.rpy:155
translate english ch_11_end_1d7a7488:

    # me "И зубами?"
    me "还要用牙齿？"

# game/a11/8_1ch_end.rpy:156
translate english ch_11_end_36fe6a16:

    # guidon "Ага. И головами. Думаете если бы на входе было пару пик с головами предателей короны, все эти ублюдки позволяли себе так чесать языками?"
    guidon "啊哈。还要用头颅。你们觉得，要是入口处插着几根挂着叛国者首级的长矛，这些杂种还敢这样嚼舌根吗？"

# game/a11/8_1ch_end.rpy:157
translate english ch_11_end_5aa70632:

    # me "И чьи же головы мне надо было насадить на пики?"
    me "那你说，我该把谁的头颅挂在矛尖上？"

# game/a11/8_1ch_end.rpy:158
translate english ch_11_end_3c523d71:

    # argus "Не отвечайте ему, мой принц."
    argus "别回答他，我的亲王。"

# game/a11/8_1ch_end.rpy:159
translate english ch_11_end_60555937:

    # guidon "Да вот хоть та парочка. Не закрывает рты уже час и все время ржут..."
    guidon "就比如那边那一对。一个多小时了嘴就没停过，还一直在怪笑..."

# game/a11/8_1ch_end.rpy:160
translate english ch_11_end_00778c19:

    # me "Мне казнить их за смех?"
    me "我该因为他们发笑就处决他们吗？"

# game/a11/8_1ch_end.rpy:161
translate english ch_11_end_8c5a8602:

    # guidon "Что начинается смехом, заканчивается битвой у Синих Гор."
    guidon "以笑开始，以蓝山之战结束。"

# game/a11/8_1ch_end.rpy:164
translate english ch_11_end_c08ffa4d:

    # cassius "Наш договор ведь в силе?"
    cassius "我们的约定还算数吗？"

# game/a11/8_1ch_end.rpy:165
translate english ch_11_end_d0ebc327:

    # me "Какой договор?"
    me "什么约定？"

# game/a11/8_1ch_end.rpy:166
translate english ch_11_end_aef86ec2:

    # valerian "О республике."
    valerian "关于共和国的。"

# game/a11/8_1ch_end.rpy:167
translate english ch_11_end_014cb4dd:

    # me "Конечно. Рад видеть тебя, Валериан."
    me "当然算数。很高兴见到你，Valerian。"

# game/a11/8_1ch_end.rpy:168
translate english ch_11_end_0656398c:

    # valerian "Отлично. Я тоже тебя рад видеть, [mename]."
    valerian "很好。我也很高兴见到你，[mename]。"

# game/a11/8_1ch_end.rpy:169
translate english ch_11_end_de1bbe45:

    # me "Почему вы вообще об этом спрашиваете?"
    me "您为何要在此时问起此事？"

# game/a11/8_1ch_end.rpy:170
translate english ch_11_end_a60aa2ff:

    # valerian "..."
    valerian "..."

# game/a11/8_1ch_end.rpy:171
translate english ch_11_end_c0397fb8:

    # cassius "Некоторым твоим...некоторым вассалом твоего отца кажется не нравится наша новая...формация."
    cassius "你父亲麾下的一些...你的某些封臣，似乎不太喜欢我们新的...体制。"

# game/a11/8_1ch_end.rpy:172
translate english ch_11_end_2325fa76:

    # me "И что?"
    me "那又如何？"

# game/a11/8_1ch_end.rpy:173
translate english ch_11_end_e5969c1a:

    # valerian "Успокойся, Кассиус, он же уже сказал, что все в силе."
    valerian "冷静点，卡西乌斯，他已经说了，一切照旧。"

# game/a11/8_1ch_end.rpy:174
translate english ch_11_end_e687aaf6:

    # cassius "Просто хотел убедиться."
    cassius "只是想确认一下。"

# game/a11/8_1ch_end.rpy:175
translate english ch_11_end_277cd3c4:

    # me "Я дал слово и я его сдержу. В противном случае вы можете не держать свое, верно?"
    me "我既然作出了承诺，就一定会遵守。否则，你们也可以不遵守你们的承诺，对吧？"

# game/a11/8_1ch_end.rpy:176
translate english ch_11_end_bc8440e3:

    # valerian "Верно."
    valerian "没错。"

# game/a11/8_1ch_end.rpy:177
translate english ch_11_end_58754d9a:

    # cassius "Верно."
    cassius "没错。"

# game/a11/8_1ch_end.rpy:178
translate english ch_11_end_06a30bc7:

    # me "Тогда в чем вопрос?"
    me "那还有什么问题？"

# game/a11/8_1ch_end.rpy:179
translate english ch_11_end_90b10973:

    # cassius "Вопроса больше нет, мой принц...мой король."
    cassius "没问题了，我的亲王...我的国王。"

# game/a11/8_1ch_end.rpy:180
translate english ch_11_end_31c698fd:

    # valerian "Император."
    valerian "是皇帝。"

# game/a11/8_1ch_end.rpy:181
translate english ch_11_end_01c6250e:

    # me "Отлично."
    me "很好。"

# game/a11/8_1ch_end.rpy:184
translate english ch_11_end_d87b31fb:

    # me "Это ты и твой дядя мои новые подданные?"
    me "你和你的叔叔，就是我的新臣民吗？"

# game/a11/8_1ch_end.rpy:185
translate english ch_11_end_bc998ac5:

    # cass "А ты бы хотел увидеть кого-то другого? Тем более мой дядя с Запада. Я в какой-то степени тоже."
    cass "难道你想看到别人？何况我叔叔来自西部。在某种程度上，我也是。"

# game/a11/8_1ch_end.rpy:186
translate english ch_11_end_05993ec1:

    # me "Ты родилась здесь."
    me "你出生在这里。"

# game/a11/8_1ch_end.rpy:187
translate english ch_11_end_a030f33b:

    # cass "Вот и отлично. У тебя под рукой человек контролирующий Запад, но который родился здесь."
    cass "那更好。你手头有个能掌控西部、却又出生在这里的人。"

# game/a11/8_1ch_end.rpy:188
translate english ch_11_end_5f3c078f:

    # me "Я думал Дюран контролирует Запад. Все-таки он новый Лорд-наместник."
    me "我还以为掌控西部的是Duran。毕竟他是新任总督大人。"

# game/a11/8_1ch_end.rpy:189
translate english ch_11_end_0741d4cd:

    # cass "Он контролирует Запад на Западе. А я контролирую Запад прямо здесь."
    cass "他在西部掌控西部。而我在此时此地掌控西部。"

# game/a11/8_1ch_end.rpy:190
translate english ch_11_end_3820771a_1:

    # me "..."
    me "..."

# game/a11/8_1ch_end.rpy:191
translate english ch_11_end_e200db6d:

    # cass "Не вижу радости на твоем лице, брат."
    cass "我在你脸上可没看到多少喜悦，兄长。"

# game/a11/8_1ch_end.rpy:192
translate english ch_11_end_1ab2394e:

    # me "Что на тебе за форма? Что это за дерево?"
    me "你穿的这是什么制服？那棵树是什么？"

# game/a11/8_1ch_end.rpy:193
translate english ch_11_end_24089124:

    # cass "Болотное древо с Черной Косы. Фамильный герб."
    cass "黑镰沼的沼木。家徽。"

# game/a11/8_1ch_end.rpy:194
translate english ch_11_end_51dc9411:

    # me "У Стархедов другой фамильный герб. Или ты уже не из нашей семьи?"
    me "Starhead家族的纹章是另一个。还是说，你已经不属于我们家了？"

# game/a11/8_1ch_end.rpy:195
translate english ch_11_end_f1d998e0:

    # cass "Это фамильный герб семьи моей матери. Да и вообще, какая разница?"
    cass "这是我母族家族的纹章。说到底，这有什么区别？"

# game/a11/8_1ch_end.rpy:196
translate english ch_11_end_65c726e6:

    # me "Просто интересно, почему ты решила одеться так именно сейчас."
    me "只是好奇，你为什么偏偏选在今天穿成这样。"

# game/a11/8_1ch_end.rpy:197
translate english ch_11_end_f9425a92:

    # cass "Я подозреваюсь в измене, мой принц?"
    cass "我是在被怀疑叛国吗，我的亲王？"

# game/a11/8_1ch_end.rpy:198
translate english ch_11_end_3820771a_2:

    # me "..."
    me "..."

# game/a11/8_1ch_end.rpy:199
translate english ch_11_end_c7fcc3fd:

    # cass "Вот и славно. Наслаждайся своим вниманием, а я буду наслаждаться своим."
    cass "那就好。享受你的万众瞩目吧，我也会享受我的。"

# game/a11/8_1ch_end.rpy:201
translate english ch_11_end_df549eff:

    # guard "ТИШИНА!"
    guard "安静！"

# game/a11/8_1ch_end.rpy:202
translate english ch_11_end_3259c58d:

    # poslan "Я посланник коллективной воли народов и властителей Запада!"
    poslan "我是西部人民与统治者集体意志的使者！"

# game/a11/8_1ch_end.rpy:203
translate english ch_11_end_0e7e87d3:

    # poslan "Мое имя и титул не имеют значения, но властью, данной властителями моей родины, я наделен полномочиями по передаче регалий."
    poslan "我的姓名与头衔无关紧要，但凭借我故土统治者们赋予的权力，我被授权转交这些权柄信物。"

# game/a11/8_1ch_end.rpy:204
translate english ch_11_end_32d1e505:

    # poslan "Одна из них у меня в руках. Эта корона - символ власти над территорией от моря Восторга и до Долины. От Черной Косы и до Меловых Озер."
    poslan "其中之一就在我手中。这顶王冠象征着对从狂喜之海到山谷，从黑镰沼到白垩湖这片广袤领土的统治权。"

# game/a11/8_1ch_end.rpy:205
translate english ch_11_end_eeea344d:

    # poslan "По поручению властителей Запада, я передаю эту корону крон-принцу Золотого Королевства, как символ воли к старому союзу, что сотни лет приносил величие обоим нашим землям."
    poslan "受西部统治者之托，我将此王冠交予黄金王国储君，作为向往古老联盟的意志象征，这联盟曾为两地带来数百年的辉煌。"

# game/a11/8_1ch_end.rpy:206
translate english ch_11_end_5c4dafe6:

    # poslan "Я передаю корону Запада, как символ не только союза и как обозначение подчинения Золотому Порядку."
    poslan "我移交这顶西部王冠，不仅作为联盟的象征，也标志着对黄金秩序的臣服。"

# game/a11/8_1ch_end.rpy:207
translate english ch_11_end_27992ff8:

    # poslan "Властители Запада присягают на верность Золотому Порядку и Железной Воле."
    poslan "西部统治者宣誓效忠于黄金秩序与钢铁意志。"

# game/a11/8_1ch_end.rpy:208
translate english ch_11_end_f9afb8d3:

    # poslan "Они надеются, что вы примете их предложение, восстановите наш великий старый союз и возьмете над ним главенство."
    poslan "他们希望您能接受他们的提议，重建我们伟大的古老联盟，并执掌其牛耳。"

# game/a11/8_1ch_end.rpy:209
translate english ch_11_end_ba152f57:

    # poslan "Если их воля будет принята, они обязуются прибыть в Золотую Столицу в кратчайшие возможные сроки и принести клятвы лично."
    poslan "若他们的意愿被接纳，他们将承诺在尽可能短的时间内抵达黄金之都，亲自立下誓言。"

# game/a11/8_1ch_end.rpy:210
translate english ch_11_end_48f7fbd3:

    # poslan "..."
    poslan "..."

# game/a11/8_1ch_end.rpy:212
translate english ch_11_end_8f8c3ca6:

    # me "{i}Похоже моя очередь.{/i}"
    me "{i}看来轮到我了。{/i}"

# game/a11/8_1ch_end.rpy:213
translate english ch_11_end_3820771a_3:

    # me "..."
    me "..."

# game/a11/8_1ch_end.rpy:214
translate english ch_11_end_ffbed5a6:

    # me "Кхм-кхм."
    me "咳嗯。"

# game/a11/8_1ch_end.rpy:215
translate english ch_11_end_70068f26:

    # me "Люди Золотого..."
    me "黄金之..."

# game/a11/8_1ch_end.rpy:217
translate english ch_11_end_d0ad5681:

    # me "{size=+5}Люди Золотого Королества. От имени своего отца, хранителя Золотого Порядка, властителя Земель от Северных Марок и до Арании, от Восточного моря и до Долины, и руководствуясь его железной волей я принимаю предложение посланника.{/size}"
    me "{size=+5}黄金王国的子民们。谨以吾父，黄金秩序的守护者，自北境边地至阿拉尼亚，从东境之海到山谷这片疆域的统治者之名义，并遵循他的钢铁意志，我接受使者之提议。{/size}"

# game/a11/8_1ch_end.rpy:218
translate english ch_11_end_8b9db4fd:

    # me "{size=+5}Я, крон-принц Золотого Королевства, принимаю корону Запада, этот священный символ, что некогда объединял наши земли в величии и славе.{/size}"
    me "{size=+5}我，黄金王国的储君，接受这顶西部王冠，这曾以伟大与荣耀将我们的土地联结一体的神圣象征。{/size}"

# game/a11/8_1ch_end.rpy:219
translate english ch_11_end_18673ac2:

    # me "{size=+5}Золотое Королевство чтит волю властителей Запада, их присягу Железной Воле и Золотому Порядку.{/size}"
    me "{size=+5}黄金王国尊重西部统治者们的意愿，以及他们对钢铁意志与黄金秩序的宣誓效忠。{/size}"

# game/a11/8_1ch_end.rpy:220
translate english ch_11_end_620a9eed:

    # me "{size=+5}Я приветствую намерение властителей Запада явиться в Золотую Столицу и принести клятвы лично.{/size}"
    me "{size=+5}我欢迎西部统治者们亲临黄金之都并当面立下誓言之意向。{/size}"

# game/a11/8_1ch_end.rpy:222
translate english ch_11_end_85a8f2e7:

    # me "{size=+5}Прежде чем я приму корону, я должен поблагодарить людей, чья воля позволила этому случиться.{/size}"
    me "{size=+5}在我接受这王冠之前，我必须感谢那些以意志促成此事的人们。{/size}"

# game/a11/8_1ch_end.rpy:223
translate english ch_11_end_0483d1d0:

    # me "{size=+5}Они перед вами.{/size}"
    me "{size=+5}他们就在你们面前。{/size}"

# game/a11/8_1ch_end.rpy:224
translate english ch_11_end_3f32d423:

    # me "{size=+5}И передо мной.{/size}"
    me "{size=+5}也在我面前。{/size}"

# game/a11/8_1ch_end.rpy:225
translate english ch_11_end_15ccca2e:

    # me "{size=+5}Вся сила, военная и дипломатическая - результат вашей помощи.{/size}"
    me "{size=+5}所有的军事与外交力量，皆是你们鼎力相助之结果。{/size}"

# game/a11/8_1ch_end.rpy:226
translate english ch_11_end_a22c8363:

    # me "{size=+5}Все то процветание и роскошь, к которой стремятся все народы мира - ваша работа.{/size}"
    me "{size=+5}世间万民所追求的一切繁荣与奢华，皆是你们劳苦之功。{/size}"

# game/a11/8_1ch_end.rpy:228
translate english ch_11_end_51cd2963:

    # me "{size=+5}Ни одна армия мира не принудит к недобровольным союзам.{/size}"
    me "{size=+5}世上没有任何一支军队能强迫缔结非自愿的联盟。{/size}"

# game/a11/8_1ch_end.rpy:229
translate english ch_11_end_b3d686c0:

    # me "{size=+5}И это ваша заслуга, что Запад вернулся к нам, не как раб, а как старый друг.{/size}"
    me "{size=+5}西部回归于我们，不是作为奴隶，而是作为老友，这亦是你们的功劳。{/size}"

# game/a11/8_1ch_end.rpy:230
translate english ch_11_end_b0a22a1f:

    # me "{size=+5}Ведь возвращаться в сияющий дом из золота всегда проще, чем в сгоревший барак.{/size}"
    me "{size=+5}毕竟，回到一座金碧辉煌的宅邸，总比回到烧焦的棚屋容易。{/size}"

# game/a11/8_1ch_end.rpy:231
translate english ch_11_end_15aae501:

    # me "{size=+5}А все слепящее великолепие нашего дома, это ваша заслуга.{/size}"
    me "{size=+5}而我们家园所有令人目眩的壮丽辉煌，皆是你们的功劳。{/size}"

# game/a11/8_1ch_end.rpy:232
translate english ch_11_end_050ba95f:

    # me "{size=+5}Пусть крыши Золотой Столицы больше не украшает золото, но она все равно сияет.{/size}"
    me "{size=+5}纵使黄金之都的屋顶不再饰以黄金，它依然闪耀夺目。{/size}"

# game/a11/8_1ch_end.rpy:233
translate english ch_11_end_caaee2b7:

    # me "{size=+5}Она сияет вами, мои верные подданные, мои друзья.{/size}"
    me "{size=+5}它以你们而闪耀，我忠实的臣民们，我的朋友们。{/size}"

# game/a11/8_1ch_end.rpy:234
translate english ch_11_end_271980ca:

    # me "{size=+5}Я принимаю эту корону от имени отца и от ваших имен.{/size}"
    me "{size=+5}我谨代表父亲，并以你们的名义，接受这顶王冠。{/size}"

# game/a11/8_1ch_end.rpy:236
translate english ch_11_end_1bb4367f:

    # poslan "Наш принц. Примите эту регалию. Примите этот символ нашего вечного союза."
    poslan "我们的亲王。请接受这权柄之象征。请接受这我们永恒联盟的象征。"

# game/a11/8_1ch_end.rpy:237
translate english ch_11_end_a18ff916:

    # poslan "Мы клянемся, что от моря Восторга и до Долины, от Черной Косы и до Меловых Озер все примут вашего отца, как нового властителя."
    poslan "我们起誓，从狂喜之海到山谷，从黑镰沼到白垩湖，所有人都将尊奉您的父亲为新的统治者。"

# game/a11/8_1ch_end.rpy:238
translate english ch_11_end_19fa7843:

    # poslan "Для нас больше нет закона главнее, чем законы Золотого Порядка."
    poslan "对我们而言，再无高于黄金秩序之法律。"

# game/a11/8_1ch_end.rpy:239
translate english ch_11_end_a988fdca:

    # poslan "Отныне для нас нет ничего священней Железной Воли."
    poslan "从今往后，对我们而言，再无神圣于钢铁意志之物。"

# game/a11/8_1ch_end.rpy:240
translate english ch_11_end_62001053:

    # poslan "Я клянусь в верности и Золотому Порядку и Железной Воле от всех властителей Запада."
    poslan "我代表所有西部统治者，宣誓效忠于黄金秩序与钢铁意志。"

# game/a11/8_1ch_end.rpy:241
translate english ch_11_end_48f7fbd3_1:

    # poslan "..."
    poslan "..."

# game/a11/8_1ch_end.rpy:243
translate english ch_11_end_ac8fe437:

    # me "{size=+5}Я принимаю вашу клятву.{/size}"
    me "{size=+5}我接受你们的誓言。{/size}"

# game/a11/8_1ch_end.rpy:244
translate english ch_11_end_6f82bf7e:

    # me "{size=+5}Я принимаю вашу верность.{/size}"
    me "{size=+5}我接受你们的忠诚。{/size}"

# game/a11/8_1ch_end.rpy:245
translate english ch_11_end_c19fcb54:

    # me "{size=+5}Я принимаю вашу покорность.{/size}"
    me "{size=+5}我接受你们的顺服。{/size}"

# game/a11/8_1ch_end.rpy:246
translate english ch_11_end_78b0abe3:

    # me "{size=+5}Я принимаю союз.{/size}"
    me "{size=+5}我接受此联盟。{/size}"

# game/a11/8_1ch_end.rpy:247
translate english ch_11_end_4dfaf9f7:

    # me "{size=+5}Я принимаю Запад, как старую и как новую часть нашей старой, но возрожденной и новой Империи.{/size}"
    me "{size=+5}我接纳西部，将其视作我们既古老又新生之帝国中，一个古老而又崭新的组成部分。{/size}"

# game/a11/8_1ch_end.rpy:250
translate english ch_11_end_1dbb1b2e:

    # me "{i}Но не сейчас.{/i}"
    me "{i}但不是现在。{/i}"

# game/a11/8_1ch_end.rpy:251
translate english ch_11_end_236295f1:

    # me "{i}Еще кое-что должно быть сделано.{/i}"
    me "{i}还有些别的事情必须先完成。{/i}"

# game/a11/8_1ch_end.rpy:252
translate english ch_11_end_a13c1937:

    # me "{i}Я не надену эту корону, пока ее не заслужу.{/i}"
    me "{i}在未能亲手赢得它之前，我不会戴上这王冠。{/i}"

# game/a11/8_1ch_end.rpy:253
translate english ch_11_end_191fbc49:

    # me "{i}Пусть я и сделал все, чтобы она оказалась у меня в руках.{/i}"
    me "{i}尽管我确实做了一切努力，让它能到我手中。{/i}"

# game/a11/8_1ch_end.rpy:254
translate english ch_11_end_81944f26:

    # me "{i}Кое-что еще не окончено.{/i}"
    me "{i}有些事尚未了结。{/i}"

# game/a11/8_1ch_end.rpy:255
translate english ch_11_end_53e08f4c:

    # me "{i}Пора это исправить.{/i}"
    me "{i}是时候做个了断了。{/i}"

# game/a11/8_1ch_end.rpy:256
translate english ch_11_end_44c83300:

    # me "Ужин! В честь великого возрождения нашей Империи!"
    me "宴会！为庆祝我们帝国之伟大复兴！"

# game/a11/8_1ch_end.rpy:260
translate english ch_11_end_dd2fff65:

    # me "{size=+5}Я принимаю вашу корону.{/size}"
    me "{size=+5}我接受你们的王冠。{/size}"

# game/a11/8_1ch_end.rpy:261
translate english ch_11_end_e585c427:

    # me "{size=+5}От имени моего отца я клянусь, что Железная Воля никогда не нарушит Золотой Порядок.{/size}"
    me "{size=+5}以吾父之名，我发誓，钢铁意志永不悖逆黄金秩序。{/size}"

# game/a11/8_1ch_end.rpy:262
translate english ch_11_end_b1a7f5c8:

    # me "{size=+5}Клянусь защищать вас и служить вам также, как вы будете защищать и служить нам.{/size}"
    me "{size=+5}我发誓保护你们，服务你们，正如你们将保护并服务于我们一样。{/size}"

# game/a11/8_1ch_end.rpy:263
translate english ch_11_end_acb521d7:

    # me "{size=+5}Клянусь, что никогда не нарушу данное вам обещание, если вы не нарушите свое.{/size}"
    me "{size=+5}我发誓，若你们不背弃承诺，我也绝不会违背对你们的诺言。{/size}"

# game/a11/8_1ch_end.rpy:264
translate english ch_11_end_f27076e0:

    # me "{size=+5}Я принимаю вашу клятву, как коллективную клятву всех властителей Запада.{/size}"
    me "{size=+5}我接受你们作为所有西部统治者集体之誓言。{/size}"

# game/a11/8_1ch_end.rpy:265
translate english ch_11_end_e7b63fd7:

    # me "{size=+5}Я буду ждать их каждый день, и когда последний из них преклонит колено - наши клятвы войдут в силу.{/size}"
    me "{size=+5}我将日复一日等待，当他们中最后一人屈膝时——我们的誓言即告生效。{/size}"

# game/a11/8_1ch_end.rpy:266
translate english ch_11_end_b1a8a146:

    # me "{size=+5}Да будет моя и воля моего отца Железом. {/size}"
    me "{size=+5}愿我与吾父之意志坚如钢铁。{/size}"

# game/a11/8_1ch_end.rpy:267
translate english ch_11_end_c6cea0fb:

    # me "{size=+5}Пусть Золотой Порядок будет вечен!{/size}"
    me "{size=+5}愿黄金秩序永恒不灭！{/size}"

# game/a11/8_1ch_end.rpy:268
translate english ch_11_end_4a8c8547:

    # golosa1 "Пусть Золотой Порядок будет вечен!"
    golosa1 "愿黄金秩序永恒不灭！"

# game/a11/8_1ch_end.rpy:273
translate english ch_11_end2_396c128f:

    # "Час спустя."
    "一个小时以后。"

# game/a11/8_1ch_end.rpy:276
translate english ch_11_end2_1fcd2a71:

    # aurora "Я никогда не присутствовала ни на чем подобном."
    aurora "我从未参加过这样的场面。"

# game/a11/8_1ch_end.rpy:277
translate english ch_11_end2_ccdcacd3:

    # aurora "Это...захватывающе. Хотя мне кажется на балу людей было больше."
    aurora "真是...太激动人心了。虽然我觉得舞会上的人更多些。"

# game/a11/8_1ch_end.rpy:278
translate english ch_11_end2_c3de1f13:

    # aurora "Но это все-таки другое. Знаешь...ощущается значимость момента."
    aurora "但这终归不同。你知道...能感受到此刻的非凡意义。"

# game/a11/8_1ch_end.rpy:279
translate english ch_11_end2_0867b2b0:

    # aurora "Хоть это и просто формальность."
    aurora "尽管这仅仅是个形式。"

# game/a11/8_1ch_end.rpy:280
translate english ch_11_end2_736a55ff:

    # aurora "Все равно это... пронизывает каким-то трепетом."
    aurora "即便如此，它还是...让人心潮澎湃。"

# game/a11/8_1ch_end.rpy:281
translate english ch_11_end2_b9e2a5e2:

    # aurora "Выборы на Севере наверное могут посоперничать, но я на них никогда не была. Туда не пускают женщин."
    aurora "北方的选举或许能与之媲美，但我从未去过。那里不准女性入场。"

# game/a11/8_1ch_end.rpy:282
translate english ch_11_end2_a982fc88:

    # aurora "А тут их было полно. Конечно большинство из них просто чьи-то жены. И все равно. Я была рада, что меня впустили, хахаха."
    aurora "而这里却有很多女性。当然，她们中的大多数只是某人的妻子。但即便如此，我也很高兴能被允许入场，哈哈哈。"

# game/a11/8_1ch_end.rpy:283
translate english ch_11_end2_b78a3b18:

    # aurora "[mename]?"
    aurora "[mename]?"

# game/a11/8_1ch_end.rpy:285
translate english ch_11_end2_df3f9ea1:

    # aurora "[mename], ты меня слушаешь?"
    aurora "[mename]，你在听我说话吗？"

# game/a11/8_1ch_end.rpy:286
translate english ch_11_end2_3b30f1c2:

    # me "Прости, немного задумался."
    me "抱歉，有点走神了。"

# game/a11/8_1ch_end.rpy:287
translate english ch_11_end2_2d9fe179:

    # aurora "Если я тебе надоела...просто я в первый раз за таким наблюдаю."
    aurora "如果是我让你觉得烦了...只是这是我第一次亲眼目睹这样的场面。"

# game/a11/8_1ch_end.rpy:288
translate english ch_11_end2_ba904ccb:

    # me "Нет. Все нормально."
    me "不。一切正常。"

# game/a11/8_1ch_end.rpy:289
translate english ch_11_end2_a3240681:

    # aurora "Ты какой-то хмурый. Я думала ты будешь радоваться."
    aurora "你看起来有点阴郁。我还以为你会很高兴。"

# game/a11/8_1ch_end.rpy:290
translate english ch_11_end2_9932ae96:

    # me "Чему мне радоваться. Это корона моего отца...пока что."
    me "我有什么可高兴的。这顶王冠是我父亲的...至少目前还是。"

# game/a11/8_1ch_end.rpy:291
translate english ch_11_end2_bfeff96c:

    # aurora "Но ты ведь принц-регент."
    aurora "但你是摄政亲王啊。"

# game/a11/8_1ch_end.rpy:292
translate english ch_11_end2_a85e4b69:

    # me "Он может лишить меня этого статуса в любой момент."
    me "他可以随时解除我这个地位。"

# game/a11/8_1ch_end.rpy:293
translate english ch_11_end2_31837ff0:

    # aurora "Ну и что? Ты все равно его единственный наследник."
    aurora "那又如何？你终究是他唯一的继承人。"

# game/a11/8_1ch_end.rpy:294
translate english ch_11_end2_6b7806a6:

    # me "Ну да..."
    me "嗯，是啊..."

# game/a11/8_1ch_end.rpy:295
translate english ch_11_end2_dfc30ac6:

    # aurora "Что-то не так?"
    aurora "有什么不对吗？"

# game/a11/8_1ch_end.rpy:296
translate english ch_11_end2_22a16adc:

    # me "Даже если корона достанется мне в любом случае, ее надо заслужить."
    me "即使王冠无论如何都会落到我头上，我也必须亲手赢得它。"

# game/a11/8_1ch_end.rpy:297
translate english ch_11_end2_a8768782:

    # aurora "В каком смысле?"
    aurora "此话怎讲？"

# game/a11/8_1ch_end.rpy:298
translate english ch_11_end2_9b88626a:

    # me "Показать, что ты ее достоин. Ответить...на неуважение. Тебе не пора спать?"
    me "证明你配得上它。对...不敬作出回应。你是不是该去歇息了？"

# game/a11/8_1ch_end.rpy:300
translate english ch_11_end2_b78a3b18_1:

    # aurora "[mename]?"
    aurora "[mename]?"

# game/a11/8_1ch_end.rpy:301
translate english ch_11_end2_183e5ff0:

    # me "Уже поздно."
    me "已经很晚了。"

# game/a11/8_1ch_end.rpy:302
translate english ch_11_end2_53dda03b:

    # aurora "Но...торжественный ужин еще даже не начался."
    aurora "但是...庆典晚宴甚至还没开始呢。"

# game/a11/8_1ch_end.rpy:303
translate english ch_11_end2_831474cf:

    # me "Я решил не затягивать с первым тостом. Ты ведь не будешь пить вино."
    me "我决定不耽搁，直接开始第一轮祝酒。你反正也不能喝酒。"

# game/a11/8_1ch_end.rpy:304
translate english ch_11_end2_331b1570:

    # aurora "Не буду, но..."
    aurora "是不能，不过..."

# game/a11/8_1ch_end.rpy:305
translate english ch_11_end2_704908f7:

    # me "После него ничего интересного не будет, я тебя уверяю."
    me "我向你保证，之后不会有什么有趣的事了。"

# game/a11/8_1ch_end.rpy:306
translate english ch_11_end2_7505b723:

    # aurora "Я не совсем тебя понимаю."
    aurora "我不太明白你的意思。"

# game/a11/8_1ch_end.rpy:307
translate english ch_11_end2_34ba5468:

    # me "Если ты хочешь есть, слуги принесут тебе еду в твои покои."
    me "如果你想吃东西，仆人们会把食物送到你的寝宫。"

# game/a11/8_1ch_end.rpy:308
translate english ch_11_end2_16a98a66:

    # aurora "Мне нельзя остаться? Я что-то сказала не так или сделала?"
    aurora "我不能留下吗？是我说错了什么，还是做错了什么？"

# game/a11/8_1ch_end.rpy:309
translate english ch_11_end2_02ba7ef2:

    # me "Все хорошо, жена моя, но тебе пора в свои покои."
    me "一切都好，我的妻子，但你该回你的寝宫去了。"

# game/a11/8_1ch_end.rpy:310
translate english ch_11_end2_9e9ec1e9:

    # aurora "Ладно, но..."
    aurora "好吧，但是..."

# game/a11/8_1ch_end.rpy:311
translate english ch_11_end2_83a6f5e3:

    # me "Аврора?"
    me "Aurora？"

# game/a11/8_1ch_end.rpy:312
translate english ch_11_end2_556cf561:

    # aurora "Я ухожу."
    aurora "我走了。"

# game/a11/8_1ch_end.rpy:315
translate english ch_11_end2_0f4ad392:

    # isi "Знаешь это все такой фарс."
    isi "你知道吗，这一切真是一场闹剧。"

# game/a11/8_1ch_end.rpy:316
translate english ch_11_end2_6697579c:

    # isi "Никогда не понимала, зачем это нужно."
    isi "从来不明白这有什么必要。"

# game/a11/8_1ch_end.rpy:317
translate english ch_11_end2_79d545f9:

    # isi "На Юге все эти торжества всегда только для черни."
    isi "在南方，所有这些庆典向来只为了那些贱民而设。"

# game/a11/8_1ch_end.rpy:318
translate english ch_11_end2_785615c0:

    # isi "Они обожают праздники, даже те, на которых им показывают, кто их новый хозяин."
    isi "他们热爱庆典，哪怕是那些向他们展示谁是新主子的庆典也不例外。"

# game/a11/8_1ch_end.rpy:319
translate english ch_11_end2_cc7bac81:

    # isi "Это их успокаивает. Дает иллюзию контроля. Они думают, что все это представление для их одобрения."
    isi "这能安抚他们。给他们一种掌控的错觉。他们以为这一切表演是为了求得他们的认可。"

# game/a11/8_1ch_end.rpy:320
translate english ch_11_end2_8d8f9162:

    # isi "А все эта уважаемая знать в расписанных дублетах и расшитых платьях...они и так все знают."
    isi "而所有这些身披彩绘紧身衣和刺绣长裙的尊贵贵族们...他们本来就知道一切。"

# game/a11/8_1ch_end.rpy:321
translate english ch_11_end2_fb0cc594:

    # isi "Для них природа власти абсолютно понятна, а иначе они бы быстро потеряли свое положение."
    isi "对他们来说，权力的本质一清二楚，若非如此，他们早就保不住自己的地位了。"

# game/a11/8_1ch_end.rpy:322
translate english ch_11_end2_a1e66138:

    # isi "Даже если они не кланялись тебе, они все равно знают, кто в случае чего отрубит им голову."
    isi "即使他们没有向你鞠躬，他们心里也清楚，若真有万一，谁会砍掉他们的脑袋。"

# game/a11/8_1ch_end.rpy:323
translate english ch_11_end2_9910e454:

    # isi "Верно?"
    isi "对吗？"

# game/a11/8_1ch_end.rpy:324
translate english ch_11_end2_568d923a:

    # isi "[mename]?"
    isi "[mename]?"

# game/a11/8_1ch_end.rpy:326
translate english ch_11_end2_c2946dfc:

    # me "Верно. Наверняка для знати вы проводите...мероприятия другого рода, да?"
    me "对。想必对贵族，你们举办的是...另一种性质的活动，是吧？"

# game/a11/8_1ch_end.rpy:327
translate english ch_11_end2_1a2ff2a1:

    # isi "Например?"
    isi "比如说？"

# game/a11/8_1ch_end.rpy:328
translate english ch_11_end2_bcbc28b2:

    # me "Я наслышан о Юге. Публичные пытки, казни. Это вы проводите не только для крестьян и черни, да?"
    me "我对南方早有耳闻。公开的拷打，处决。这些不仅仅是做给农民和贱民看的，对吧？"

# game/a11/8_1ch_end.rpy:329
translate english ch_11_end2_818a1f24:

    # isi "Возможно. Когда как."
    isi "也许吧。视情况而定。"

# game/a11/8_1ch_end.rpy:330
translate english ch_11_end2_26b52702:

    # me "Если бы твой отец усомнился в том, что его уважают, что бы он сделал?"
    me "假如你父亲怀疑有人对他不够敬重，他会怎么做？"

# game/a11/8_1ch_end.rpy:331
translate english ch_11_end2_54dbd504:

    # isi "Смотря кто его не уважает."
    isi "那得看是谁不敬重他。"

# game/a11/8_1ch_end.rpy:332
translate english ch_11_end2_471dc973:

    # me "Он знает кто. Просто подозревает."
    me "他知道是谁。只是起了疑心。"

# game/a11/8_1ch_end.rpy:333
translate english ch_11_end2_a6317aad:

    # isi "Ну в таком случае он бы...продемонстрировал силу на ком-то одном, кто наверняка его действительно не уважает и сделал бы это перед теми, в ком он сомневается."
    isi "嗯，那样的话，他会...在某个确凿无疑不敬重他的人身上展示力量，并且会当着那些他有所怀疑的人面前做。"

# game/a11/8_1ch_end.rpy:334
translate english ch_11_end2_a46cdcd2:

    # me "Демонстрация силы."
    me "力量的展示。"

# game/a11/8_1ch_end.rpy:335
translate english ch_11_end2_69a94beb:

    # isi "Ну да."
    isi "嗯，对。"

# game/a11/8_1ch_end.rpy:336
translate english ch_11_end2_25a9c615:

    # me "И как? Это эффективно?"
    me "那么效果如何？"

# game/a11/8_1ch_end.rpy:337
translate english ch_11_end2_f26330e9:

    # isi "Смотря что ты собираешься сделать."
    isi "这取决于你打算做什么。"

# game/a11/8_1ch_end.rpy:339
translate english ch_11_end2_de5dd677:

    # me "Я?"
    me "我？"

# game/a11/8_1ch_end.rpy:340
translate english ch_11_end2_8bc264ba:

    # isi "Ну да. Ты же явно что-то задумал."
    isi "嗯，对。你显然在谋划什么。"

# game/a11/8_1ch_end.rpy:341
translate english ch_11_end2_72c6f7e3:

    # me "Я не..."
    me "我没有..."

# game/a11/8_1ch_end.rpy:342
translate english ch_11_end2_bb82f2ed:

    # isi "Не надо врать. У тебя плохо получается."
    isi "别撒谎了。你不太擅长这个。"

# game/a11/8_1ch_end.rpy:343
translate english ch_11_end2_7bfbb509:

    # me "...как ты поняла?"
    me "...你怎么看出来的？"

# game/a11/8_1ch_end.rpy:344
translate english ch_11_end2_0c7d24e9:

    # isi "Да брось, [mename], ты минут десять злобно рассматривал всех исподлобья и почти не говорил."
    isi "得了吧，[mename]，有十分钟你都在一边皱着眉恶狠狠地环视所有人，而且几乎一言不发。"

# game/a11/8_1ch_end.rpy:345
translate english ch_11_end2_2325fa76:

    # me "И что?"
    me "所以呢？"

# game/a11/8_1ch_end.rpy:346
translate english ch_11_end2_afb024e6:

    # isi "Ты что-то задумал. А когда ты начал задавать характерные вопросы, я все поняла."
    isi "你在打什么主意。当你开始问那些带有指向性的问题时，我就全明白了。"

# game/a11/8_1ch_end.rpy:347
translate english ch_11_end2_424fea5d:

    # me "Ясно..."
    me "这样啊..."

# game/a11/8_1ch_end.rpy:348
translate english ch_11_end2_d542a9bc:

    # isi "Мне стоит опасаться того, что здесь произойдет?"
    isi "我该担心这里将要发生的事吗？"

# game/a11/8_1ch_end.rpy:349
translate english ch_11_end2_2edc6114:

    # me "Возможно."
    me "有可能。"

# game/a11/8_1ch_end.rpy:350
translate english ch_11_end2_784297cb:

    # isi "В таком случае я лучше подожду тебя в покоях."
    isi "那样的话，我最好还是在寝宫等你。"

# game/a11/8_1ch_end.rpy:351
translate english ch_11_end2_0de7be2f:

    # me "Хорошо. Я как раз хотел тебе это предложить."
    me "好的。我正想这么提议。"

# game/a11/8_1ch_end.rpy:353
translate english ch_11_end2_869cc9b4:

    # lagg "Его жена ушла."
    lagg "他妻子走了。"

# game/a11/8_1ch_end.rpy:354
translate english ch_11_end2_2ce2460d:

    # leonard "И что?"
    leonard "那又怎样？"

# game/a11/8_1ch_end.rpy:355
translate english ch_11_end2_563918c6:

    # lagg "Еду даже не принесли."
    lagg "食物都还没端上来呢。"

# game/a11/8_1ch_end.rpy:356
translate english ch_11_end2_8a85215d:

    # leonard "Она беременна."
    leonard "她怀孕了。"

# game/a11/8_1ch_end.rpy:357
translate english ch_11_end2_d49de440:

    # lagg "И поэтому следит за фигурой?"
    lagg "所以呢？为了保持身材？"

# game/a11/8_1ch_end.rpy:358
translate english ch_11_end2_6a8bfe33:

    # leonard "И поэтому может отойти в любой момент. Пописать, поблевать, поспать. У тебя же есть дети, ты не знаешь как это работает?"
    leonard "所以随时可能离席。撒尿、呕吐、睡觉。你又不是没孩子，你不知道这是怎么回事吗？"

# game/a11/8_1ch_end.rpy:359
translate english ch_11_end2_25abb10e:

    # lagg "...может быть. Ты уже пригласил его в свою Аранию?"
    lagg "...也许吧。你已经邀请他去你的阿拉尼亚了吗？"

# game/a11/8_1ch_end.rpy:360
translate english ch_11_end2_6441b39b:

    # leonard "Зачем?"
    leonard "为什么？"

# game/a11/8_1ch_end.rpy:361
translate english ch_11_end2_918abb79:

    # lagg "Ну как же. Я конечно верю в крепкое здоровье короля, особенно после его выздоровления, но он уже не молод."
    lagg "这还用问。我当然相信国王陛下龙体安康，尤其在他康复之后，但他毕竟不年轻了。"

# game/a11/8_1ch_end.rpy:362
translate english ch_11_end2_2ce2460d_1:

    # leonard "И что?"
    leonard "那又如何？"

# game/a11/8_1ch_end.rpy:363
translate english ch_11_end2_2c87b856:

    # lagg "Пора выстраивать связи с его прямым наследником."
    lagg "是时候和他的直接继承人建立联系了。"

# game/a11/8_1ch_end.rpy:364
translate english ch_11_end2_ee23e5df:

    # leonard "Я так понимаю ты его пригласил."
    leonard "我猜你已经邀请他了。"

# game/a11/8_1ch_end.rpy:365
translate english ch_11_end2_92170dc6:

    # lagg "А как же. Он пока не ответил, но думаю согласится."
    lagg "那当然。他还没回复，但我觉得他会同意的。"

# game/a11/8_1ch_end.rpy:366
translate english ch_11_end2_09e39b8d:

    # leonard "Что тебе мешает поговорить с ним здесь?"
    leonard "那你何不在这里和他谈呢？"

# game/a11/8_1ch_end.rpy:367
translate english ch_11_end2_44563f4e:

    # lagg "Ну что ты, здесь все слишком формально."
    lagg "哦，别这样，这儿一切都太形式化了。"

# game/a11/8_1ch_end.rpy:368
translate english ch_11_end2_db105773:

    # leonard "Могу я поинтересоваться зачем тебе лизать его жопу?"
    leonard "容我问一句，你干嘛要去拍他马屁？"

# game/a11/8_1ch_end.rpy:369
translate english ch_11_end2_566cbd47:

    # lagg "Раз уж Запад теперь часть...Империи, полагаю землю между нами тоже стали ее частью."
    lagg "既然西部现在成了...帝国的一部分，我想我们之间的那片土地也该成为帝国的一部分了。"

# game/a11/8_1ch_end.rpy:370
translate english ch_11_end2_bb3596bf:

    # leonard "Тебе нужна Долина? Там же одни болота."
    leonard "你想要山谷？那里可只有沼泽。"

# game/a11/8_1ch_end.rpy:371
translate english ch_11_end2_7745c096:

    # lagg "Ооо, там не только болота."
    lagg "哦哦，那里可不止有沼泽。"

# game/a11/8_1ch_end.rpy:372
translate english ch_11_end2_4fa3d002:

    # leonard "Да. Там еще эльфы."
    leonard "对。还有精灵。"

# game/a11/8_1ch_end.rpy:373
translate english ch_11_end2_ed781144:

    # lagg "С этим я разберусь."
    lagg "这个我会解决。"

# game/a11/8_1ch_end.rpy:374
translate english ch_11_end2_d4c35426:

    # leonard "Сначала разберись с тем, чтобы тебе эту Долину отдали."
    leonard "先想着怎么让他把山谷给你吧。"

# game/a11/8_1ch_end.rpy:375
translate english ch_11_end2_33400b5d:

    # lagg "Этим я как раз и занимаюсь."
    lagg "我正忙活这事呢。"

# game/a11/8_1ch_end.rpy:376
translate english ch_11_end2_25493201:

    # leonard "Будешь показывать принцу свои владения и обещать сделать все то же самое в Долине."
    leonard "你要带亲王参观你的领地，并承诺在山谷做同样的事。"

# game/a11/8_1ch_end.rpy:377
translate english ch_11_end2_8b811688:

    # lagg "Леонард, я тебя умоляю, есть куда более тонкие, но действующие приемы."
    lagg "Leonard，拜托，有的是更微妙但有效的手段。"

# game/a11/8_1ch_end.rpy:379
translate english ch_11_end2_7a231fe2:

    # elin "Мам?"
    elin "妈？"

# game/a11/8_1ch_end.rpy:380
translate english ch_11_end2_abc8a140:

    # mom "Да. Сейчас."
    mom "对。就是现在。"

# game/a11/8_1ch_end.rpy:381
translate english ch_11_end2_42bb4fb2:

    # elin "Прямо сейчас?"
    elin "就现在？"

# game/a11/8_1ch_end.rpy:382
translate english ch_11_end2_4ab4dd63:

    # mom "Как он объявит тост."
    mom "等他宣布祝酒。"

# game/a11/8_1ch_end.rpy:383
translate english ch_11_end2_3754c874:

    # elin "Мы должны что-то делать или..."
    elin "我们该做点什么，还是..."

# game/a11/8_1ch_end.rpy:384
translate english ch_11_end2_0a4c8cf8:

    # mom "Нет...просто контролируем его безопасность."
    mom "不...只需严守他的安全即可。"

# game/a11/8_1ch_end.rpy:385
translate english ch_11_end2_9976c209:

    # elin "Ясно."
    elin "明白。"

# game/a11/8_1ch_end.rpy:386
translate english ch_11_end2_f7d53dd1:

    # mom "Не волнуйся. Все будет нормально. Может даже и не потребуется ничего делать."
    mom "别担心。一切都会没事的。也许根本不需要做什么。"

# game/a11/8_1ch_end.rpy:387
translate english ch_11_end2_bd7a1e99:

    # elin "Я на это надеюсь."
    elin "但愿如此。"

# game/a11/8_1ch_end.rpy:389
translate english ch_11_end2_cd9c4e57:

    # me "{size=+5}Кхм-кхм.{/size}"
    me "{size=+5}咳嗯。{/size}"

# game/a11/8_1ch_end.rpy:390
translate english ch_11_end2_a45c163e:

    # me "{size=+5}Уважаемые подданные короны. Я собрал в этом зале тех, кто был верен короне и чья служба помогла нам сделать наше Королевство снова Империей.{/size}"
    me "{size=+5}尊敬的王室臣民们。我将在座诸位——那些忠于王室并以服务助力我国重新成为帝国的人们——聚集于此。{/size}"

# game/a11/8_1ch_end.rpy:391
translate english ch_11_end2_bb5fccf6:

    # me "{size=+5}В тронном зале я поблагодарил всех жителей нашей славной земли, и я был искренним.{/size}"
    me "{size=+5}在王座厅，我感谢了我们光荣国土上的所有居民，我由衷而发。{/size}"

# game/a11/8_1ch_end.rpy:392
translate english ch_11_end2_d26f4647:

    # me "{size=+5}Все они внесли вклад в наше великое дело. Все они помогли нашему старому новому союзу случиться.{/size}"
    me "{size=+5}他们都为我们伟大的事业作出了贡献。他们都促成了我们古老又崭新的联盟。{/size}"

# game/a11/8_1ch_end.rpy:393
translate english ch_11_end2_28216b65:

    # me "{size=+5}Но люди в этом зале - особые.{/size}"
    me "{size=+5}但这个大厅里的人，是特别的。{/size}"

# game/a11/8_1ch_end.rpy:394
translate english ch_11_end2_f39269bb:

    # me "{size=+5}Ваша поддержка, ваша честная служба это основная сила, благодаря которой вечный Золотой Порядок действительно вечен.{/size}"
    me "{size=+5}你们的支持，你们忠诚的服务，正是永恒黄金秩序得以真正永恒的根本力量。{/size}"

# game/a11/8_1ch_end.rpy:395
translate english ch_11_end2_a336ad91:

    # me "{size=+5}Я бы хотел выпить за вас. За вашу честь. Но не могу.{/size}"
    me "{size=+5}我本想为你们举杯，为你们的荣誉干杯。但我不能。{/size}"

# game/a11/8_1ch_end.rpy:396
translate english ch_11_end2_506b4dcc:

    # me "{size=+5}Потому что среди нас есть тот, кто этого не достоин.{/size}"
    me "{size=+5}因为在我们之中，有一个人不配得到这一切。{/size}"

# game/a11/8_1ch_end.rpy:397
translate english ch_11_end2_5deb9e10:

    # me "{size=+5}Чьи помыслы и поступки темны, чья служба - обман, призванная отдалить величие нашей Империи, а не приблизить.{/size}"
    me "{size=+5}其思想与行为阴暗，其服务乃欺骗，旨在推迟而非促成我帝国的辉煌。{/size}"

# game/a11/8_1ch_end.rpy:400
translate english ch_11_end2_2e58f50d:

    # argus "О ком он?"
    argus "他在说谁？"

# game/a11/8_1ch_end.rpy:401
translate english ch_11_end2_16e7855a:

    # guidon "Понятия не имею. Но звучит, как его дед."
    guidon "完全不知道。但这口吻，真跟他祖父一样。"

# game/a11/8_1ch_end.rpy:402
translate english ch_11_end2_4d5145a0:

    # argus "В каком смысле?"
    argus "什么意思？"

# game/a11/8_1ch_end.rpy:403
translate english ch_11_end2_1d5f0c9b:

    # guidon "Он тоже любил устраивать представления перед тем, как кого-нибудь казнить."
    guidon "他祖父也喜欢在处决某人前搞点场面。"

# game/a11/8_1ch_end.rpy:404
translate english ch_11_end2_a6111791:

    # argus "Нам стоит переживать?"
    argus "我们需要担心吗？"

# game/a11/8_1ch_end.rpy:405
translate english ch_11_end2_f557c4cc:

    # guidon "Не думаю. В этом нет смысла."
    guidon "不觉得。这没道理。"

# game/a11/8_1ch_end.rpy:406
translate english ch_11_end2_ee577496:

    # argus "В поступках Красного Императора не всегда был смысл."
    argus "红色皇帝的行事并非总有道理。"

# game/a11/8_1ch_end.rpy:407
translate english ch_11_end2_14e406f7:

    # guidon "Мы лояльны ему, к тому же он говорит только об одном человеке."
    guidon "我们对他忠心，况且他说了，只针对一个人。"

# game/a11/8_1ch_end.rpy:410
translate english ch_11_end2_9c2e7b85:

    # cassius "Что за чушь он мелет?"
    cassius "他在胡扯些什么？"

# game/a11/8_1ch_end.rpy:411
translate english ch_11_end2_f4fdd4ad:

    # valerian "Обвиняет кого-то в предательстве, разве не очевидно."
    valerian "在指控某人叛国，这不是明摆着吗。"

# game/a11/8_1ch_end.rpy:412
translate english ch_11_end2_2fbf619c:

    # cassius "Почему сейчас?"
    cassius "为什么选现在？"

# game/a11/8_1ch_end.rpy:413
translate english ch_11_end2_067ead92:

    # valerian "Публичная порка...или еще чего похуже."
    valerian "公开鞭笞...或者更糟的。"

# game/a11/8_1ch_end.rpy:414
translate english ch_11_end2_5b05b51b:

    # cassius "Ты же не думаешь что..."
    cassius "你该不会以为..."

# game/a11/8_1ch_end.rpy:415
translate english ch_11_end2_00ce5560:

    # valerian "Да ну. Это было бы глупо, не находишь?"
    valerian "当然不会。那也太蠢了，你不觉得吗？"

# game/a11/8_1ch_end.rpy:416
translate english ch_11_end2_969f6d5b:

    # cassius "Ну да...да...просто интересно о ком он."
    cassius "是啊...是啊...只是好奇是谁。"

# game/a11/8_1ch_end.rpy:417
translate english ch_11_end2_72121c24:

    # valerian "Сейчас и узнаем."
    valerian "马上就会知道了。"

# game/a11/8_1ch_end.rpy:420
translate english ch_11_end2_9388f757:

    # guran "Тебя это не...напрягает?"
    guran "你...你不觉得紧张吗？"

# game/a11/8_1ch_end.rpy:421
translate english ch_11_end2_2ba4c3a3:

    # cass "Нет."
    cass "不。"

# game/a11/8_1ch_end.rpy:422
translate english ch_11_end2_6ca86c81:

    # guran "Он...он не про тебя говорит?"
    guran "他...他说的不是你吧？"

# game/a11/8_1ch_end.rpy:423
translate english ch_11_end2_97d99736:

    # cass "Не думаю."
    cass "不觉得。"

# game/a11/8_1ch_end.rpy:424
translate english ch_11_end2_051c7b2f:

    # guran "Ты как-то беспечна."
    guran "你好像有点过于放心了。"

# game/a11/8_1ch_end.rpy:425
translate english ch_11_end2_47e6c3e8:

    # cass "Если он хотел нас убить, взял бы людей побольше. К тому же половина и тех кто нас охраняет - мои люди."
    cass "要是他想杀我们，会带更多人手。况且，看护我们的人里有一半是我的人。"

# game/a11/8_1ch_end.rpy:426
translate english ch_11_end2_20869ebd:

    # guran "Его мать и сестра здесь."
    guran "他母亲和妹妹也在场。"

# game/a11/8_1ch_end.rpy:427
translate english ch_11_end2_cf281e15:

    # cass "И что? Они будут стрелять огнем по всем вокруг? Не думаю."
    cass "那又怎样？她们能在这里到处喷火不成？我不觉得。"

# game/a11/8_1ch_end.rpy:428
translate english ch_11_end2_54e2c37b:

    # guran "Мне это не нравится."
    guran "我不喜欢这样。"

# game/a11/8_1ch_end.rpy:429
translate english ch_11_end2_fde518ed:

    # cass "Расслабься старик. Я ему доверяю."
    cass "放松点，老伙计。我信任他。"

# game/a11/8_1ch_end.rpy:430
translate english ch_11_end2_b652ac9e:

    # guran "Это меня и пугает."
    guran "这正是我所担心的。"

# game/a11/8_1ch_end.rpy:432
translate english ch_11_end2_8e8d2801:

    # me "{size=+5}Эта тень - мешала нам все это время. Она шныряла рядом, притворяясь другом.{/size}"
    me "{size=+5}这片阴霾，一直妨碍着我们。它潜伏在侧，假装是朋友。{/size}"

# game/a11/8_1ch_end.rpy:433
translate english ch_11_end2_47c1bc43:

    # me "{size=+5}Хотя все это время была злейшим врагом.{/size}"
    me "{size=+5}却一直是险恶至极的敌人。{/size}"

# game/a11/8_1ch_end.rpy:434
translate english ch_11_end2_e9fb6551:

    # me "{size=+5}Я был слеп, что не замечал этого раньше.{/size}"
    me "{size=+5}我曾盲目无知，未能早些察觉。{/size}"

# game/a11/8_1ch_end.rpy:435
translate english ch_11_end2_198cb2cd:

    # me "{size=+5}Но больше я себе этого позволить не могу. Мне придется открыть глаза и открыть их всем вам.{/size}"
    me "{size=+5}但我再不能容许自己如此。我必须睁开双眼，并让诸位也一并看清。{/size}"

# game/a11/8_1ch_end.rpy:436
translate english ch_11_end2_676202af:

    # me "{size=+5}Слишком многое стоит на кону. Стабильность не просто Королевства. А целой Империи.{/size}"
    me "{size=+5}太多事情危在旦夕。这不仅仅是王国的稳定，而是整个帝国的稳定。{/size}"

# game/a11/8_1ch_end.rpy:437
translate english ch_11_end2_7f82dcda:

    # me "{size=+5}И пусть этот вредитель маленький, но дай волю жукам и они сточат основание даже самой крепкой башни.{/size}"
    me "{size=+5}纵使这蠹虫渺小，若放任不管，蛀虫终将啃噬殆尽，即便是最坚固的塔基。{/size}"

# game/a11/8_1ch_end.rpy:444
translate english ch_11_end2_con_1b9bc9f2:

    # me "{size=+5}Верно, дядя Конрад?{/size}"
    me "{size=+5}我说得对吗，Conrad叔叔？{/size}"

# game/a11/8_1ch_end.rpy:445
translate english ch_11_end2_con_defa46ce:

    # conrad "Чего?"
    conrad "什么？"

# game/a11/8_1ch_end.rpy:446
translate english ch_11_end2_con_b569122b:

    # me "{size=+5}Да, я обращаюсь к вам.{/size}"
    me "{size=+5}对，我就是在对您说话。{/size}"

# game/a11/8_1ch_end.rpy:447
translate english ch_11_end2_con_e4acee3a:

    # conrad "Ты что, мать твою, несешь?"
    conrad "你他妈的在胡说些什么？"

# game/a11/8_1ch_end.rpy:448
translate english ch_11_end2_con_1dc8f2a4:

    # me "{size=+5}Так и будете стоять там? Или трусливо сбежишь?{/size}"
    me "{size=+5}您就打算站在那儿吗？还是准备像个懦夫一样逃走？{/size}"

# game/a11/8_1ch_end.rpy:450
translate english ch_11_end2_con_610ee03b:

    # conrad "Ты спятил, мальчишка."
    conrad "你疯了，小子。"

# game/a11/8_1ch_end.rpy:451
translate english ch_11_end2_con_3820771a:

    # me "..."
    me "..."

# game/a11/8_1ch_end.rpy:452
translate english ch_11_end2_con_d797876c:

    # conrad "Что бы ты там себе не напридумывал..."
    conrad "不管你给自己编造了些什么鬼话..."

# game/a11/8_1ch_end.rpy:453
translate english ch_11_end2_con_3820771a_1:

    # me "..."
    me "..."

# game/a11/8_1ch_end.rpy:454
translate english ch_11_end2_con_ee694e47:

    # conrad "Поверить не могу, что ты обвинил меня в каком-то предательстве."
    conrad "简直不敢相信，你居然指控我搞什么背叛。"

# game/a11/8_1ch_end.rpy:455
translate english ch_11_end2_con_3820771a_2:

    # me "..."
    me "..."

# game/a11/8_1ch_end.rpy:456
translate english ch_11_end2_con_dcd914e9:

    # conrad "Это тебя эта эльфийская сука надоумила?"
    conrad "是那个精灵婊子挑唆你的吧？"

# game/a11/8_1ch_end.rpy:457
translate english ch_11_end2_con_3820771a_3:

    # me "..."
    me "..."

# game/a11/8_1ch_end.rpy:458
translate english ch_11_end2_con_2f6af8a5:

    # conrad "Я сейчас достану мечи и ты у меня заговоришь, щенок."
    conrad "我现在就拔剑，你这狗崽子，看你还敢不敢嘴硬。"

# game/a11/8_1ch_end.rpy:460
translate english ch_11_end2_con_f1f76476:

    # mom "Конрад, не смей."
    mom "Conrad，不得放肆。"

# game/a11/8_1ch_end.rpy:461
translate english ch_11_end2_con_e6574f9d:

    # elin "Не надо, дядя Конрад."
    elin "别这样，Conrad叔叔。"

# game/a11/8_1ch_end.rpy:462
translate english ch_11_end2_con_f4eef025:

    # me "Конрад."
    me "Conrad。"

# game/a11/8_1ch_end.rpy:463
translate english ch_11_end2_con_528a7d50:

    # conrad "Вы что? Вы все это спланировали?"
    conrad "你们？这是你们串通好的？"

# game/a11/8_1ch_end.rpy:464
translate english ch_11_end2_con_8ed29102:

    # mom "Если ты потянешься к мечу..."
    mom "你的手要是敢去碰剑..."

# game/a11/8_1ch_end.rpy:465
translate english ch_11_end2_con_f4eef025_1:

    # me "Конрад."
    me "Conrad。"

# game/a11/8_1ch_end.rpy:466
