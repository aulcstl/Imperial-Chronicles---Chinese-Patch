    elin "是我的错。"

# game/a11/3guests.rpy:273
translate english guests3_elin_3820771a_1:

    # me "..."
    me "..."

# game/a11/3guests.rpy:274
translate english guests3_elin_92d397c8:

    # elin "..."
    elin "..."

# game/a11/3guests.rpy:275
translate english guests3_elin_8c6b60fa:

    # me "Я скучал."
    me "我想你了。"

# game/a11/3guests.rpy:276
translate english guests3_elin_eebd9be1:

    # elin "Я тоже."
    elin "我也是。"

# game/a11/3guests.rpy:277
translate english guests3_elin_3820771a_2:

    # me "..."
    me "..."

# game/a11/3guests.rpy:278
translate english guests3_elin_92d397c8_1:

    # elin "..."
    elin "..."

# game/a11/3guests.rpy:280
translate english guests3_elin_7b0cffaf:

    # elin "Когда мы будем вместе в следующий раз?"
    elin "我们下次什么时候能在一起？"

# game/a11/3guests.rpy:281
translate english guests3_elin_4705d6df:

    # me "Ты хочешь этого?"
    me "你想吗？"

# game/a11/3guests.rpy:282
translate english guests3_elin_c3ce1f02:

    # elin "Издеваешься? Ты сам...ты сам сделал это со мной, а теперь спрашиваешь?"
    elin "你是在取笑我吗？是你……是你把我变成这样的，现在你却问我？"

# game/a11/3guests.rpy:283
translate english guests3_elin_c645389b:

    # me "Так ты хочешь или нет?"
    me "那你到底想还是不想？"

# game/a11/3guests.rpy:284
translate english guests3_elin_d661c52b:

    # elin "Хочу."
    elin "想。"

# game/a11/3guests.rpy:285
translate english guests3_elin_ae9c5015:

    # me "Прямо здесь?"
    me "就在这里吗？"

# game/a11/3guests.rpy:286
translate english guests3_elin_9307c281:

    # elin "Может быть."
    elin "也许吧。"

# game/a11/3guests.rpy:287
translate english guests3_elin_f5847c6e:

    # me "Я не против."
    me "我不反对。"

# game/a11/3guests.rpy:288
translate english guests3_elin_0f787c64:

    # elin "Тогда я..."
    elin "那我……"

# game/a11/3guests.rpy:290
translate english guests3_elin_1c506f6d:

    # elin "Уммгрх..."
    elin "唔……"

# game/a11/3guests.rpy:291
translate english guests3_elin_03744e8d:

    # me "[elin]? Ты как?"
    me "[elin]？你怎么了？"

# game/a11/3guests.rpy:292
translate english guests3_elin_11bb5812:

    # elin "Пф...."
    elin "噗……"

# game/a11/3guests.rpy:293
translate english guests3_elin_0d19ce8f:

    # me "Тебе плохо?"
    me "你不舒服吗？"

# game/a11/3guests.rpy:294
translate english guests3_elin_1e8ee11b:

    # elin "Все нормально... Но меня похоже сейчас вырвет."
    elin "没事……但我觉得可能要吐了。"

# game/a11/3guests.rpy:295
translate english guests3_elin_13e96f65:

    # me "Дать воды?"
    me "要喝水吗？"

# game/a11/3guests.rpy:296
translate english guests3_elin_da708632:

    # elin "Нет...я...я..."
    elin "不，我……我……"

# game/a11/3guests.rpy:298
translate english guests3_elin_ba46457e:

    # elin "...я в порядке."
    elin "……我好了。"

# game/a11/3guests.rpy:299
translate english guests3_elin_8bba64c7:

    # me "Ты меня напугала."
    me "你吓到我了。"

# game/a11/3guests.rpy:300
translate english guests3_elin_973821a2:

    # elin "Все нормально. У меня часто такое...в последнее время."
    elin "没事了。我最近……经常这样。"

# game/a11/3guests.rpy:301
translate english guests3_elin_a05a8d64:

    # me "Думаешь это из-за..."
    me "你觉得是因为……"

# game/a11/3guests.rpy:302
translate english guests3_elin_325bc8e1:

    # elin "Не знаю..."
    elin "不知道……"

# game/a11/3guests.rpy:303
translate english guests3_elin_3820771a_3:

    # me "..."
    me "..."

# game/a11/3guests.rpy:304
translate english guests3_elin_92d397c8_2:

    # elin "..."
    elin "..."

# game/a11/3guests.rpy:305
translate english guests3_elin_3874d759:

    # me "Почти наверняка..."
    me "几乎可以肯定……"

# game/a11/3guests.rpy:306
translate english guests3_elin_3ed45065:

    # elin "Даже не хочу думать об этом."
    elin "我连想都不愿意想。"

# game/a11/3guests.rpy:308
translate english guests3_elin_3e716679:

    # me "Нужно обезопаситься."
    me "得采取安全措施了。"

# game/a11/3guests.rpy:309
translate english guests3_elin_9638490b:

    # elin "Я уже."
    elin "我已经做了。"

# game/a11/3guests.rpy:310
translate english guests3_elin_489a247d:

    # me "Правда?"
    me "真的吗？"

# game/a11/3guests.rpy:311
translate english guests3_elin_359f2be6:

    # elin "Локхарт в один из дней сильно напился. И на утро я сказала, что у нас была....ночь. Пришлось помять простыни и вылить на них крови."
    elin "有一天Lockhart喝得酩酊大醉。第二天早上我告诉他，我俩昨晚……春宵一度。我只好把床单揉皱，再往上倒了点血。"

# game/a11/3guests.rpy:312
translate english guests3_elin_541f4d38:

    # me "Умно."
    me "聪明。"

# game/a11/3guests.rpy:313
translate english guests3_elin_f3077d29:

    # elin "Пойдем уже обратно, пока меня действительно не вырвало."
    elin "我们快回去吧，省得我真要吐出来。"

# game/a11/3guests.rpy:317
translate english guests4_0f476a5d:

    # "Чуть позже."
    "过了一会。"

# game/a11/3guests.rpy:318
translate english guests4_9381dd60:

    # corina "...так что о тебе стараются не говорить."
    corina "……所以大家都不怎么提起你。"

# game/a11/3guests.rpy:319
translate english guests4_b2527988:

    # una "Хотя леди Милена еще вспоминает тебя, когда рассказывает новым ученикам о важности самоконтроля при сотворении огненных заклинаний."
    una "不过，米莱娜女士在给新学员讲施放火焰咒语时自我控制的重要性时，偶尔还会提到你。"

# game/a11/3guests.rpy:320
translate english guests4_b50cc8b3:

    # elin "Даже не напоминай."
    elin "你可别提了。"

# game/a11/3guests.rpy:321
translate english guests4_11a89683:

    # una "Хорошие были времена."
    una "那时候可真美好啊。"

# game/a11/3guests.rpy:322
translate english guests4_e7e571f0:

    # elin "Да..."
    elin "是啊……"

# game/a11/3guests.rpy:323
translate english guests4_d193681e:

    # corina "Говорите так, будто вам по сто лет."
    corina "听你们说话，好像都一百岁了似的。"

# game/a11/3guests.rpy:324
translate english guests4_42a05484:

    # me "Сколько всего активных башен?"
    me "现在总共有多少座仍在活跃的高塔？"

# game/a11/3guests.rpy:325
translate english guests4_584a7178:

    # elin "Мало."
    elin "不多了。"

# game/a11/3guests.rpy:326
translate english guests4_d372392e:

    # corina "Семь."
    corina "七座。"

# game/a11/3guests.rpy:327
translate english guests4_e2bc7291:

    # una "Уже шесть."
    una "现在是六座了。"

# game/a11/3guests.rpy:328
translate english guests4_95906ee2:

    # me "И сколько в одной башне учителей и учеников?"
    me "那一座塔里有多少老师和学生？"

# game/a11/3guests.rpy:329
translate english guests4_2aadd942:

    # elin "Зависит от того, сколько учеников смогли собрать."
    elin "这得看他们能招到多少学员。"

# game/a11/3guests.rpy:330
translate english guests4_bd057af5:

    # corina "Нас было трое, как ты мог понять. Следующих учеников привели, когда вы уже заканчивали обучение."
    corina "如同你所见，我们那时就三个。下一批学员是在你们快毕业时才被带来的。"

# game/a11/3guests.rpy:331
translate english guests4_33de1970:

    # una "Чувствительных к магии людей очень мало."
    una "能感知魔法的人太少了。"

# game/a11/3guests.rpy:332
translate english guests4_b79920f3:

    # me "А как учителя вас...находят?"
    me "那老师们是怎么……找到你们的？"

# game/a11/3guests.rpy:333
translate english guests4_574d341c:

    # corina "Моя мать сама сдала меня вербовщику с башни, я была одной из десятков детей, которых к нему привели, но единственная, кто действительно владел магией."
    corina "我母亲主动把我交给了塔里来的招募人。我是被带到他面前的好几十个孩子之一，却是唯一一个真正拥有魔法天赋的。"

# game/a11/3guests.rpy:334
translate english guests4_a7c7b458:

    # corina "Обычно в доме падает солонка, и родители тут же решают, что это их шанс на безбедную жизнь."
    corina "通常是家里的盐罐子突然倒了，父母立刻就觉得，这是他们能过上不用愁吃穿的好日子的机会。"

# game/a11/3guests.rpy:335
translate english guests4_954ad7fa:

    # me "За вас платят?"
    me "塔里会为你们付钱吗？"

# game/a11/3guests.rpy:336
translate english guests4_08d38ec8:

    # corina "Однократно. По сути это выкупная, как за корову. Хотя за твою сестру вряд ли платили."
    corina "一次性付清。本质上就是赎金，跟买头奶牛似的。至于你妹妹，多半是没付钱的。"

# game/a11/3guests.rpy:337
translate english guests4_e4671e2b:

    # me "Еще бы. Она же сама сбежала туда."
    me "那还用说。她是自己逃去那儿的。"

# game/a11/3guests.rpy:338
translate english guests4_e4d9a0b0:

    # elin "[mename]..."
    elin "[mename]..."

# game/a11/3guests.rpy:339
translate english guests4_f52f2519:

    # corina "Оу... она нам этого не рассказывала."
    corina "哦……她可没跟我们提过这个。"

# game/a11/3guests.rpy:340
translate english guests4_88704fe9:

    # elin "И не буду."
    elin "我也不会。"

# game/a11/3guests.rpy:342
translate english guests4_72ff22db:

    # corina "Может сменим тему разговора на более веселую?"
    corina "还是换个更愉快的话题吧？"

# game/a11/3guests.rpy:343
translate english guests4_12c9fd55:

    # una "Например?"
    una "比如说？"

# game/a11/3guests.rpy:344
translate english guests4_384698c2:

    # corina "Например обсудим почему вы не пьете эдельвейсовое вино. Это же просто вкуснятина."
    corina "比如说，谈谈你们为什么不喝这雪绒花酒。这明明就是人间美味。"

# game/a11/3guests.rpy:345
translate english guests4_9a8ff811:

    # una "Только не выпей весь ящик. Нам еще нужно немного на завтра."
    una "别把整箱都喝光了。我们明天还得用一点呢。"

# game/a11/3guests.rpy:346
translate english guests4_fbd276f9:

    # me "Неплохое. Но не сравнится с аранским золотым."
    me "这酒不赖。但根本没法跟阿兰的金酒比。"

# game/a11/3guests.rpy:347
translate english guests4_941ef0a3:

    # elin "Согласна."
    elin "我同意。"

# game/a11/3guests.rpy:348
translate english guests4_39c84148:

    # corina "А мне это больше нравится. Тем более разве это не волнительно пить вино, которое пересекло целое море?"
    corina "但我更喜欢这个。再说了，喝这种跨越了整片海洋而来的酒，难道不令人激动吗？"

# game/a11/3guests.rpy:349
translate english guests4_342fc141:

    # me "Откуда ты родом?"
    me "你老家在哪儿？"

# game/a11/3guests.rpy:350
translate english guests4_07b1ec70:

    # corina "Из Вольных городов на Севере. Бригдок. Это бедный портовый городок. Вы о нем и не слышали наверное."
    corina "来自北方的自由城邦。布里格多克。一个穷困的港口小镇。你们多半没听说过。"

# game/a11/3guests.rpy:351
translate english guests4_c18d04a4:

    # me "Почему же. Слышал."
    me "怎么会。我听说过。"

# game/a11/3guests.rpy:352
translate english guests4_f40c6086:

    # elin "Иронично."
    elin "真是讽刺。"

# game/a11/3guests.rpy:353
translate english guests4_aad395bd:

    # corina "Что?"
    corina "讽刺什么？"

# game/a11/3guests.rpy:354
translate english guests4_1790594a:

    # elin "[mename] прожил там почти десять лет, пока был в изгнании."
    elin "[mename]在被流放的近十年里就住在那里。"

# game/a11/3guests.rpy:355
translate english guests4_9b897a98:

    # corina "И ты мне об этом не рассказывала?"
    corina "这事你可没跟我说过。"

# game/a11/3guests.rpy:356
translate english guests4_25921618:

    # elin "Я не знала где он, до недавнего времени."
    elin "我也是不久前才知道他在哪儿。"

# game/a11/3guests.rpy:358
translate english guests4_7b9b5e9f:

    # me "Про то откуда ты, я уже знаю."
    me "关于你从哪里来，我已经知道了。"

# game/a11/3guests.rpy:359
translate english guests4_403dc622:

    # elin "Откуда?"
    elin "什么？"

# game/a11/3guests.rpy:360
translate english guests4_25d459d6:

    # una "Мы случайно столкнулись в замке. Пришлось объяснять...свой внешний вид."
    una "我们之前在城堡里偶然碰上过。我不得不解释一下……当时的状况。"

# game/a11/3guests.rpy:361
translate english guests4_0df1dee1:

    # me "Все так. Тебя тоже сдали родители, Юна?"
    me "是这样没错。你也是被父母送进塔的，Una？"

# game/a11/3guests.rpy:362
translate english guests4_1aa5bf21:

    # una "Мои родители меня любили. Не хотели отпускать меня в башню."
    una "我的父母很爱我。他们不愿送我去高塔。"

# game/a11/3guests.rpy:363
translate english guests4_d56df7db:

    # me "И все же ты там оказалась."
    me "可你还是到那儿了。"

# game/a11/3guests.rpy:364
translate english guests4_dc517f33:

    # corina "Ей звезды нашептали, что стоит попробовать, да?"
    corina "是星星悄悄告诉她值得一试，对吧？"

# game/a11/3guests.rpy:365
translate english guests4_68dc976b:

    # una "Верно. Они меня еще не подводили."
    una "没错。她们还从没让我失望过。"

# game/a11/3guests.rpy:366
translate english guests4_a9b769b5:

    # me "Так это правда, что ты боишься лошадей?"
    me "所以，你怕马是真的吗？"

# game/a11/3guests.rpy:367
translate english guests4_6769634e:

    # elin "[mename]!"
    elin "[mename]!"

# game/a11/3guests.rpy:368
translate english guests4_37d9c6ca:

    # corina "Хех."
    corina "呵。"

# game/a11/3guests.rpy:369
translate english guests4_7514fb0d:

    # una "Не боюсь. Просто пока не хочу приближать свою смерть."
    una "我不怕。我只是暂时还不想离死亡太近。"

# game/a11/3guests.rpy:370
translate english guests4_1ab67587:

    # me "У тебя есть основания доверять звездам?"
    me "你有理由信任星星吗？"

# game/a11/3guests.rpy:371
translate english guests4_4d10ac0d:

    # corina "Ой. Лучше в это не влезать."
    corina "哎呀。这事儿最好别掺和。"

# game/a11/3guests.rpy:372
translate english guests4_37c5d43d:

    # una "Ну конечно. А ты не веришь звездам?"
    una "那当然了。难道你不信星星？"

# game/a11/3guests.rpy:373
translate english guests4_9ea50851:

    # me "Ну как сказать..."
    me "这该怎么说呢……"

# game/a11/3guests.rpy:374
translate english guests4_c765d025:

    # elin "Я будто снова на ужине с Локхартом..."
    elin "我仿佛又回到了和Lockhart共进晚餐的时刻……"

# game/a11/3guests.rpy:376
translate english guests4_2b7a6b99:

    # me "У меня иногда бывает что-то вроде видений."
    me "我有时候会看到一些……像是幻象的东西。"

# game/a11/3guests.rpy:377
translate english guests4_9fc2de74:

    # corina "Видений?"
    corina "幻象？"

# game/a11/3guests.rpy:378
translate english guests4_3273e0d1:

    # una "И что ты в них видишь?"
    una "你在里面看到了什么？"

# game/a11/3guests.rpy:379
translate english guests4_b55cb519:

    # me "Разное. Будущее, прошлое. Может быть. А может я с ума сошел."
    me "各种东西。未来，过去。有可能。也可能只是我疯了。"

# game/a11/3guests.rpy:380
translate english guests4_35bca2fe:

    # una "Что-нибудь сбылось из того, что ты видел?"
    una "你看到的幻象，有实现的吗？"

# game/a11/3guests.rpy:381
translate english guests4_11d76127:

