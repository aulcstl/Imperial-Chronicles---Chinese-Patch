# game/a11/3guests.rpy:4
translate english guests3_38e574fb:

    # "Ночью в королевской роще."
    "入夜后的皇家林苑。"

# game/a11/3guests.rpy:5
translate english guests3_579f6088:

    # una "Вот. Это то место."
    una "好了。就是这里。"

# game/a11/3guests.rpy:6
translate english guests3_16499219:

    # elin "Уверена?"
    elin "你确定吗？"

# game/a11/3guests.rpy:7
translate english guests3_50c0824e:

    # una "Да. Базальтовая поляна."
    una "对。玄武岩草地。"

# game/a11/3guests.rpy:8
translate english guests3_4e202462:

    # elin "Контрабандист найдет нас здесь?"
    elin "走私者会来这里找我们吗？"

# game/a11/3guests.rpy:9
translate english guests3_51f9f0d7:

    # una "Да."
    una "会。"

# game/a11/3guests.rpy:10
translate english guests3_5f46fcdc:

    # elin "Он вообще знает, что вы собираетесь у него купить?"
    elin "他到底知不知道你们打算向他买什么？"

# game/a11/3guests.rpy:11
translate english guests3_057d15f3:

    # corina "Конечно. Мы передали весточку через алхимиков."
    corina "当然知道。我们已经通过炼金术士传过话了。"

# game/a11/3guests.rpy:12
translate english guests3_e6570099:

    # elin "Ну ладно..."
    elin "那好吧..."

# game/a11/3guests.rpy:14
translate english guests3_dc4e1206:

    # una "Видите? Созвездие короны. Оно особенно яркое в последнее время."
    una "看到了吗？那顶王冠状的星座。最近一段时间，它格外明亮。"

# game/a11/3guests.rpy:15
translate english guests3_a1fd76f7:

    # corina "Похоже на россыпь точек. Где в ней можно рассмотреть корону?"
    corina "看上去就像散落的光点。哪儿能看出王冠的形状？"

# game/a11/3guests.rpy:16
translate english guests3_89ced74b:

    # elin "Ну...очертания есть. Пять самых ярких звезд, как вершины зубцов короны."
    elin "嗯……轮廓是有的。最亮的五颗星，就像王冠上的齿尖。"

# game/a11/3guests.rpy:17
translate english guests3_2ea7ea6a:

    # una "Оно называется так не только потому что похоже на корону, но и потому что по легенде с этого созвездия одна из звезд рухнула на землю в последней битве людей и эльфов."
    una "它之所以叫这个名字，不仅是因为形状像王冠，还因为传说在人类与精灵的最后一战中，这个星座里的一颗星坠落到了大地。"

# game/a11/3guests.rpy:18
translate english guests3_a2a03246:

    # corina "Стархеды."
    corina "星陨之地。"

# game/a11/3guests.rpy:19
translate english guests3_16e24aa6:

    # elin "Мой дом. Из обломков этой звезды сделали первую корону железных людей."
    elin "我的故乡。那颗星星的碎片被用来打造了铁民的第一顶王冠。"

# game/a11/3guests.rpy:20
translate english guests3_c8ddbcfa:

    # una "Поэтому и называется созвездие короны."
    una "所以才被称为王冠星座。"

# game/a11/3guests.rpy:21
translate english guests3_43bd5399:

    # corina "Бредятина. Как они поняли, что звезда упала именно оттуда?"
    corina "胡扯。他们怎么知道那颗星星就是从那儿掉下来的？"

# game/a11/3guests.rpy:22
translate english guests3_325bc8e1:

    # elin "Не знаю..."
    elin "我不知道……"

# game/a11/3guests.rpy:23
translate english guests3_37636665:

    # una "Когда-то там было шесть звезд. А после того, как одна из звезд упала, стало пять."
    una "那里曾经有六颗星。一颗星坠落之后，就变成了五颗。"

# game/a11/3guests.rpy:24
translate english guests3_32fb94c3:

    # corina "Оу..."
    corina "哦……"

# game/a11/3guests.rpy:25
translate english guests3_b74b61de:

    # elin "Забавно. Я никогда раньше не слышала, что та звезда упала именно с созвездия короны."
    elin "有意思。我以前从未听说过，那颗坠落的星星来自王冠星座。"

# game/a11/3guests.rpy:27
translate english guests3_d55c0309:

    # me "Потрясающая история. Вот бы мне тоже слушать ее оперевшись на камень, а не таскать ящики с повозки."
    me "真是个好故事。要是我能靠着石头听这故事，而不是从板车上搬箱子就好了。"

# game/a11/3guests.rpy:28
translate english guests3_7bddf70a:

    # corina "Ты здесь единственный мужчина, так что терпи."
    corina "你可是这里唯一的男人，那就忍着点吧。"

# game/a11/3guests.rpy:29
translate english guests3_497a2223:

    # elin "Я могу помочь."
    elin "我可以帮忙。"

# game/a11/3guests.rpy:30
translate english guests3_95e6de0b:

    # me "Не надо. Это последний."
    me "不用了。这是最后一个了。"

# game/a11/3guests.rpy:31
translate english guests3_ca598394:

    # corina "Молодец. Осталось только нарубить дров, установить палатку и набрать воды."
    corina "好样的。现在就剩下劈点柴火、搭好帐篷和打水了。"

# game/a11/3guests.rpy:32
translate english guests3_f82e822f:

    # elin "Займешься?"
    elin "你来干？"

# game/a11/3guests.rpy:33
translate english guests3_f4999175:

    # me "Вы серьезно?"
    me "你们是认真的吗？"

# game/a11/3guests.rpy:34
translate english guests3_41904670:

    # elin "Шутка."
    elin "开玩笑的。"

# game/a11/3guests.rpy:36
translate english guests3_b3a049d0:

    # elin "Я схожу за водой."
    elin "我去打水。"

# game/a11/3guests.rpy:37
translate english guests3_138f7fc2:

    # corina "Тогда я займусь палаткой."
    corina "那我就负责帐篷。"

# game/a11/3guests.rpy:38
translate english guests3_5cd31de9:

    # una "Ну..я полагаю выбор у меня невелик."
    una "嗯……看来我没得选了。"

# game/a11/3guests.rpy:39
translate english guests3_fdfd041a:

    # elin "Нам вообще обязательно все это делать?"
    elin "我们真的必须得做这些吗？"

# game/a11/3guests.rpy:40
translate english guests3_675bfe38:

    # corina "Он может прийти сюда в любое время в следующие два дня. Можешь конечно подождать его на голых камнях и земле, но я думаю нас тогда на долго не хватит."
    corina "他可能会在接下来两天内的任何时候到这里。你大可以就在光秃秃的石头上和地上等他，但我想那样我们可撑不了多久。"

# game/a11/3guests.rpy:41
translate english guests3_c5a15e83:

    # elin "Можно попросить слуг..."
    elin "可以叫仆人们来……"

# game/a11/3guests.rpy:42
translate english guests3_459589b7:

    # una "Он отдаст камень только нам."
    una "他只会把石头交给我们。"

# game/a11/3guests.rpy:43
translate english guests3_58c35523:

    # corina "Верно. Это слишком ценная вещь. К тому же гномы казнят за попытку контрабанды любых артефактов из разлома."
    corina "没错。这东西太珍贵了。而且，矮人对于任何走私裂隙文物的行为，都会处以死刑。"

# game/a11/3guests.rpy:44
translate english guests3_17f6f9fa:

    # elin "И?"
    elin "所以呢？"

# game/a11/3guests.rpy:45
translate english guests3_b47c32b5:

    # corina "Он должен быть уверен, что передаст камень именно нам. Так что выбора у нас нет."
    corina "他必须确信是把石头交给了我们本人。所以我们别无选择。"

# game/a11/3guests.rpy:47
translate english guests3_54795435:

    # una "Может поможешь мне, [mename]?"
    una "也许你能帮帮我，[mename]？"

# game/a11/3guests.rpy:48
translate english guests3_de5dd677:

    # me "Я?"
    me "我？"

# game/a11/3guests.rpy:49
translate english guests3_6ede540c:

    # una "Ну да. Вместе быстрее управимся."
    una "嗯哼。两个人一起，更快些。"

# game/a11/3guests.rpy:50
translate english guests3_60358084:

    # me "Эм..."
    me "呃……"

# game/a11/3guests.rpy:51
translate english guests3_7316b863:

    # una "К тому же дров нам понадобится много. Вдруг нам действительно придется ждать его два дня?"
    una "再说，我们需要的柴火可不少。万一我们真的要等他两天呢？"

# game/a11/3guests.rpy:52
translate english guests3_01822020:

    # me "Ладно."
    me "好吧。"

# game/a11/3guests.rpy:53
translate english guests3_a544526a:

    # una "Вот и отлично."
    una "那太好了。"

# game/a11/3guests.rpy:55
translate english guests3_54483c8a:

    # corina "Дрова подождут. Можно просто насобирать сухих веток."
    corina "柴火可以等等。我们可以先去捡些干树枝。"

# game/a11/3guests.rpy:56
translate english guests3_b6626098:

    # me "А?"
    me "啊？"

# game/a11/3guests.rpy:57
translate english guests3_2b7d4cb0:

    # corina "Лучше помоги мне здесь."
    corina "还是先帮我弄这个吧。"

# game/a11/3guests.rpy:58
translate english guests3_75ba0772:

    # me "С чем?"
    me "弄什么？"

# game/a11/3guests.rpy:59
translate english guests3_1ceed519:

    # corina "С палаткой, с чем еще?"
    corina "帐篷，还能是什么？"

# game/a11/3guests.rpy:60
translate english guests3_dcbbe350:

    # me "Ты не справишься с палаткой?"
    me "你一个人搭不好帐篷吗？"

# game/a11/3guests.rpy:61
translate english guests3_d60a068b:

    # corina "Ростом не вышла."
    corina "我个子不够高嘛。"

# game/a11/3guests.rpy:62
translate english guests3_f7ec537d:

    # me "Зачем тогда вызвалась?"
    me "那你刚才干嘛主动请缨？"

# game/a11/3guests.rpy:63
translate english guests3_3dbfdafd:

    # corina "Чтобы не таскать воду и дерево, очевидно."
    corina "显然，是为了不用去打水和扛柴火。"

# game/a11/3guests.rpy:64
translate english guests3_3820771a:

    # me "..."
    me "..."

# game/a11/3guests.rpy:66
translate english guests3_59026d48:

    # elin "Пойдем лучше со мной за водой. На четырех человек понадобиться много."
    elin "你还是跟我去打水吧。四个人的用水量可不少。"

# game/a11/3guests.rpy:67
translate english guests3_01b75b31:

    # me "Вы издеваетесь?"
    me "你在耍我吗？"

# game/a11/3guests.rpy:68
translate english guests3_8f15d0bf:

    # elin "Что? Ты же принес ведра?"
    elin "怎么啦？你不是把水桶带来了吗？"

# game/a11/3guests.rpy:69
translate english guests3_216f19ef:

    # me "Принес."
    me "带来了。"

# game/a11/3guests.rpy:70
translate english guests3_c76e45b4:

    # elin "Ну вот."
    elin "那不就行了。"

# game/a11/3guests.rpy:71
translate english guests3_3820771a_1:

    # me "..."
    me "..."

# game/a11/3guests.rpy:72
translate english guests3_a4fe6712:

    # elin "Я не давлю. Можешь помочь кому хочешь."
    elin "我又不强迫你。你想帮谁就帮谁。"

# game/a11/3guests.rpy:83
translate english guests3_una_d6178073:

    # una "Спасибо, что выбрал помочь мне."
    una "谢谢你选择帮我。"

# game/a11/3guests.rpy:84
translate english guests3_una_104230ee:

    # me "Да не за что."
    me "没什么。"

# game/a11/3guests.rpy:85
translate english guests3_una_8be2efd7:

    # una "Знаешь, девочки всегда спихивали самую сложную работу на меня, как будто раз я высокого роста, то на меня можно использовать вместо тяглового быка."
    una "你知道吗，那些姑娘们总是把最重的活儿推给我，好像就因为我个子高，就得把我当牲口用似的。"

# game/a11/3guests.rpy:86
translate english guests3_una_19940692:

    # me "А в душе ты ранимая маленькая девочка."
    me "其实你内心是个敏感的小女孩吧。"

# game/a11/3guests.rpy:87
translate english guests3_una_b0ddae96:

    # una "Хех, ну не совсем, но все равно... ты понимаешь."
    una "呵，也不全是，但说到底……你能明白的。"

# game/a11/3guests.rpy:88
translate english guests3_una_6ab05865:

    # me "Наверное."
    me "大概吧。"

# game/a11/3guests.rpy:89
translate english guests3_una_be8ab656:

    # una "Знаешь, приходилось даже пару раз драться, чтобы защитить Корину и [elin]."
    una "你知道吗，我甚至还为了要保护Corina和[elin]，打过几架呢。"

# game/a11/3guests.rpy:90
translate english guests3_una_e3f73cce:

    # me "Драться? Вы же маги."
    me "打架？你们可是法师啊。"

# game/a11/3guests.rpy:91
translate english guests3_una_e8167add:

    # una "Да, но нам запрещено пользоваться магией вне башни, во время обучения."
    una "是没错，但在受训期间，我们被禁止在高塔之外使用魔法。"

# game/a11/3guests.rpy:92
translate english guests3_una_f2b4be70:

    # me "[elin] говорила вы использовали ее в тавернах, чтобы подзаработать."
    me "[elin]说过，你们在小酒馆里靠魔法赚点小钱。"

# game/a11/3guests.rpy:93
translate english guests3_una_077bcdef:

    # una "Мы делали это втайне от учителей. Но если бы какого-нибудь бедолагу спалили дотла, это быстро стало бы известно."
    una "我们是背着老师们偷偷干的。但要是真把哪个可怜虫烧成灰，那可就立刻人尽皆知了。"

# game/a11/3guests.rpy:94
translate english guests3_una_ec9689fe:

    # me "Поэтому ты дралась?"
    me "所以你就动拳头了？"

# game/a11/3guests.rpy:95
translate english guests3_una_d987d4c1:

    # una "Ну да."
    una "嗯哼。"

# game/a11/3guests.rpy:96
translate english guests3_una_a3bf0098:

    # me "И как успехи?"
    me "那你战绩如何？"

# game/a11/3guests.rpy:97
translate english guests3_una_eb282477:

    # una "В основном я просто неожиданно била под дых и мы убегали. Рост не сильно важен, если против тебя кутила из таверны с сотней драк за спиной, так что лучше в таких ситуациях просто ретироваться."
    una "通常我就是出其不意地给对方的肚子来一下，然后我们就趁机溜走。面对有上百场斗殴经验的酒馆常客，身高其实没那么大用，所以这种情况最好还是赶紧撤退。"

# game/a11/3guests.rpy:99
translate english guests3_una_ca3f41ae:

    # una "Готов?"
    una "准备好了吗？"

# game/a11/3guests.rpy:100
translate english guests3_una_4d0bbfb0:

    # me "Какого хуя?"
    me "搞什么鬼？"

# game/a11/3guests.rpy:106
translate english guests3_una_8b112231:

    # una "Ой."
    una "哎哟。"

# game/a11/3guests.rpy:107
translate english guests3_una_6c8383d9:

    # me "Не сегодня!"
    me "不是今天！"

# game/a11/3guests.rpy:108
translate english guests3_una_01051524:

    # una "Ты чего?"
    una "你怎么了？"

# game/a11/3guests.rpy:111
translate english guests3_una_cbbe8dff:

    # una "Ты что делаешь?"
    una "你在干什么？"

# game/a11/3guests.rpy:112
translate english guests3_una_f864606d:

    # me "Ты меня убить хотела!"
    me "你想杀了我吗！"

# game/a11/3guests.rpy:113
translate english guests3_una_91e34e54:

    # una "Что? Убить? Я нашла хорошее сухое дерево - вон, смотри."
    una "什么？杀了你？我找到了一棵很好的枯树——看那边。"

# game/a11/3guests.rpy:114
translate english guests3_una_358fda56:

    # me "Дерево?"
    me "树？"

# game/a11/3guests.rpy:115
translate english guests3_una_45585478:

    # una "Ну дa. Мы же за дровами пришли."
    una "对呀。我们不是来弄柴火吗。"

# game/a11/3guests.rpy:116
translate english guests3_una_59a1404b:

    # me "А...ну да...сухое дерево..."
    me "啊……是哦……枯树……"

# game/a11/3guests.rpy:117
translate english guests3_una_cf9be244:

    # una "Прости, что напугала тебя."
    una "抱歉，吓到你了。"

# game/a11/3guests.rpy:118
translate english guests3_una_c59b6cd3:

    # me "Нет, это ты меня прости. Я не хотел сбивать тебя с ног. Вернее хотел, но просто неправильно тебя понял..."
    me "不，该道歉的是我。我本来不想把你摔倒的。准确地说，我是想，但我只是没领会你的意思…"

# game/a11/3guests.rpy:119
translate english guests3_una_5e07b756:

    # una "..."
    una "..."

# game/a11/3guests.rpy:120
translate english guests3_una_3820771a:

    # me "..."
    me "..."

# game/a11/3guests.rpy:121
translate english guests3_una_57a27da0:

    # una "Может уже..."
    una "要不然我们……"

# game/a11/3guests.rpy:122
translate english guests3_una_73956735:

    # me "Да. Прости."
    me "嗯。抱歉。"

# game/a11/3guests.rpy:125
translate english guests3_una_bfbca00e:

    # una "Вот хорошее сухое дерево."
    una "那边有棵好枯树。"

# game/a11/3guests.rpy:126
translate english guests3_una_7fddf429:

    # me "А...да..."
    me "啊……好的……"

# game/a11/3guests.rpy:127
translate english guests3_una_590d3632:

    # una "Ты в норме?"
    una "你还好吧？"

# game/a11/3guests.rpy:128
translate english guests3_una_62fdf83c:

    # me "Да. Просто на секунду показалось, что ты хочешь порубить на куски меня, а не дерево."
    me "还好。只是刚刚一瞬间，我以为你是想把我剁成块，而不是去砍树。"

# game/a11/3guests.rpy:129
translate english guests3_una_606473e3:

    # una "Ты серьезно?"
    una "你是认真的吗？"

# game/a11/3guests.rpy:130
translate english guests3_una_955bc732:

    # me "Ну ты расказывала про драки, а потом замахнулась топором, как будто захотела отомстить всем мужчинам в мире, начав с меня."
    me "嗯，你刚才讲你打架的事，然后又突然挥起斧头，就好像是想替全世界的男人报复我，从我先开始似的。"

# game/a11/3guests.rpy:131
translate english guests3_una_3450bd15:

    # una "Ты слишком тревожный, [mename]. Хотя наверное для человека в твоем положении это плюс."
    una "你太容易受惊了，[mename]。不过话说回来，对于你这种身份的人来说，这也许算个优点。"

# game/a11/3guests.rpy:132
translate english guests3_una_7b1466b5:

    # me "В моем положении?"
    me "我这身份？"

# game/a11/3guests.rpy:133
translate english guests3_una_d890d834:

    # una "Ну да. Ты же кронпринц. Людям твоего положения надо быть осторожными."
    una "对啊。你可是王储。像你这样身份的人，是得小心些。"

# game/a11/3guests.rpy:134
translate english guests3_una_1b402144:

    # me "Ты хочешь мне что-то сказать?"
    me "你是不是想对我说什么？"

# game/a11/3guests.rpy:135
translate english guests3_una_cb65fc32:

    # una "Хочу сказать, что надо бы нарубить дров."
    una "我想说的是，我们该劈柴了。"

# game/a11/3guests.rpy:136
translate english guests3_una_d732dbfd:

    # me "А...ну да."
    me "额...好吧。"

# game/a11/3guests.rpy:138
translate english guests3_una_83749a03:

    # "Полчаса спустя."
    "半个小时以后。"

# game/a11/3guests.rpy:139
translate english guests3_una_623aebb8:

    # una "Фух. Закончили."
    una "呼。总算劈完了。"

# game/a11/3guests.rpy:140
translate english guests3_una_5f600361:

    # me "Этого хватит?"
    me "这些够了吗？"

# game/a11/3guests.rpy:141
translate english guests3_una_2e728183:

    # una "На ночь точно хватит. Если он не появится к утру, то потом еще нарубим."
    una "今晚肯定是够了。要是他明早还不出现，我们就再来多砍点。"

# game/a11/3guests.rpy:142
translate english guests3_una_71d3b8c8:

    # me "Хорошо."
    me "好的。"

# game/a11/3guests.rpy:144
translate english guests3_una_8a5cd929:

    # una "А ты силач."
    una "你可真有力气。"

# game/a11/3guests.rpy:145
translate english guests3_una_464a0888:

    # me "Спасибо, ты тоже ничего."
    me "谢谢，你也不赖。"

# game/a11/3guests.rpy:146
translate english guests3_una_ea2c0259:

    # una "Не тяжело?"
    una "不沉吗？"

# game/a11/3guests.rpy:147
translate english guests3_una_2acb48b0:

    # me "Тяжело. Но ты несешь такое же, поэтому я не могу жаловаться. Кстати зачем нам эти бревна?"
    me "沉啊。但你也扛着差不多重的东西，我可没资格抱怨。对了，我们干嘛要扛这些圆木？"

# game/a11/3guests.rpy:148
translate english guests3_una_0de00778:

    # una "Чтобы сидеть на них."
    una "用来坐啊。"

# game/a11/3guests.rpy:149
translate english guests3_una_e971a905:

    # me "Понял. Хотя мне кажется хватит и одного."
    me "明白了。不过我觉得一根就够了吧。"

# game/a11/3guests.rpy:150
translate english guests3_una_73f5f828:

    # una "У костра так не сидят. Надо видеть лица друг друга."
    una "围着篝火可不能这么坐。我们得能看到彼此的脸。"

# game/a11/3guests.rpy:151
translate english guests3_una_45e35aa9:

    # me "То есть мы сейчас надрываемся, чтобы потом было чуть-чуть удобнее пьянствовать у костра."
    me "所以我们现在累死累活，就是为了待会儿能围在篝火边，稍微舒坦一点地喝酒聊天？"

# game/a11/3guests.rpy:152
translate english guests3_una_8b2ebb16:

    # una "Если хочешь, можем остановиться, принесем их потом вместе по одному."
    una "如果你愿意，我们现在可以停下，等会再一起一根根搬过去。"

# game/a11/3guests.rpy:153
translate english guests3_una_279c3288:

    # me "Ладно уж. Тут недалеко."
    me "算了，就这样吧。反正也没多远了。"

# game/a11/3guests.rpy:158
translate english guests3_corina_281bf2df:

    # corina "Ты ведь сам справишься?"
    corina "你自己能行吧？"

# game/a11/3guests.rpy:159
translate english guests3_corina_45d1325f:

    # me "Не понял."
    me "我不明白你的意思。"

# game/a11/3guests.rpy:160
translate english guests3_corina_328a1eea:

    # corina "Я ведь уже говорила - мне рост не позволяет таким заниматься без магии."
    corina "我之前不是说了嘛，我个子不够高，不用魔法干不了这个。"

# game/a11/3guests.rpy:161
translate english guests3_corina_b35ad9f4:

    # me "Я правильно понимаю, что когда ты просила помощи, ты имела в виду, что работать буду один я."
    me "那我是不是可以理解为，你刚才请我帮忙，意思就是活儿全要我一个人干？"

# game/a11/3guests.rpy:162
translate english guests3_corina_4e41cde3:

    # corina "Нет."
    corina "不是。"

# game/a11/3guests.rpy:163
translate english guests3_corina_e6401794:

    # me "Нет?"
    me "不是？"

# game/a11/3guests.rpy:164
translate english guests3_corina_4e41cde3_1:

    # corina "Нет."
    corina "不是。"

# game/a11/3guests.rpy:165
translate english guests3_corina_20e50be6:

    # me "А что тогда ты будешь делать?"
    me "那你打算做什么？"

# game/a11/3guests.rpy:166
translate english guests3_corina_cea264cb:

    # corina "Эм...принесу вино из эдельвейса."
    corina "呃……我去拿雪绒花酒。"

# game/a11/3guests.rpy:167
translate english guests3_corina_87290f1b:

    # me "Оно у повозки."
    me "它在板车那边。"

# game/a11/3guests.rpy:169
translate english guests3_corina_69fdedf1:

    # corina "Пахнет замечательно."
    corina "闻起来真香啊。"

# game/a11/3guests.rpy:170
translate english guests3_corina_ead2838a:

    # me "Зачем ты достала пробки?"
    me "你把瓶塞取出来干嘛？"

# game/a11/3guests.rpy:171
translate english guests3_corina_ae1db03f:

    # corina "Чтобы не было соблазна все это не выпить."
    corina "免得我们一下子忍不住就全喝光了。"

# game/a11/3guests.rpy:172
translate english guests3_corina_4787d0fa:

    # me "Оно крепкое?"
    me "这酒很烈吗？"

# game/a11/3guests.rpy:173
translate english guests3_corina_ab76c8ca:

    # corina "Понятия не имею. Оно нам нужно для магического эксперимента."
    corina "一点儿也不知道。我们需要它来做魔法实验。"

# game/a11/3guests.rpy:174
translate english guests3_corina_08af0152:

    # me "Зачем тогда мы его пьем?"
    me "那我们现在干嘛要喝它？"

# game/a11/3guests.rpy:175
translate english guests3_corina_935a0806:

    # corina "Нам хватит и бутылки. А там еще ящик такой."
    corina "我们喝一瓶就够了。那还有整整一箱呢。"

# game/a11/3guests.rpy:176
translate english guests3_corina_fb6303a8:

    # me "Понял."
    me "明白了。"

# game/a11/3guests.rpy:177
translate english guests3_corina_4d5e196b:

    # corina "Попробуем?"
    corina "来尝尝？"

# game/a11/3guests.rpy:178
translate english guests3_corina_8084c27a:

    # me "Что? Сейчас?"
    me "什么？现在？"

# game/a11/3guests.rpy:180
translate english guests3_corina_bdade124:

    # corina "А чего ждать?"
    corina "还要等什么？"

# game/a11/3guests.rpy:181
translate english guests3_corina_400f4682:

    # me "Ну и как?"
    me "感觉怎么样？"

# game/a11/3guests.rpy:182
translate english guests3_corina_ddc97bd4:

    # corina "..."
    corina "..."

# game/a11/3guests.rpy:183
translate english guests3_corina_ab79d4ca:

    # me "Вкусно?"
    me "好喝吗？"

# game/a11/3guests.rpy:184
translate english guests3_corina_45dd5273:

    # corina "Мнмм.мм.мм..."
    corina "嗯嗯嗯..."

# game/a11/3guests.rpy:185
translate english guests3_corina_80b41ccd:

    # me "Видимо вкусно."
    me "看来很好喝。"

# game/a11/3guests.rpy:186
translate english guests3_corina_899fd638:

    # corina "ОЧнь вксно прбуй см."
    corina "非常喝你尝尝己。"

# game/a11/3guests.rpy:187
translate english guests3_corina_8a268005:

    # me "Нет. Я, пожалуй, сначала закончу с лагерем."
    me "不。我还是先把营地这边弄好吧。"

# game/a11/3guests.rpy:188
translate english guests3_corina_f719dfc4:

    # corina "Кк хчешь."
    corina "随便你。"

# game/a11/3guests.rpy:191
translate english guests3_corina_ddbda1a5:

    # corina "Кстати раз уж мы тут одни..."
    corina "对了，既然这里就我们两个人……"

# game/a11/3guests.rpy:192
translate english guests3_corina_5d6eebdb:

    # me "Опять?"
    me "又来了？"

# game/a11/3guests.rpy:193
translate english guests3_corina_40ea1b4d:

    # corina "Ой, не делай вид, что не ждал, пока мы останемся наедине...слуга."
    corina "哎呀，别装得好像你没在盼着咱俩单独相处似的……仆人。"

# game/a11/3guests.rpy:194
translate english guests3_corina_3820771a:

    # me "..."
    me "..."

# game/a11/3guests.rpy:195
translate english guests3_corina_0abc3a29:

    # corina "Что? Скажи мне остановиться и я остановлюсь."
    corina "什么？你只要说停下，我就会停下。"

# game/a11/3guests.rpy:196
translate english guests3_corina_3820771a_1:

    # me "..."
    me "..."

# game/a11/3guests.rpy:197
translate english guests3_corina_6eafc04c:

    # corina "Так вот, слуга. Напиток был очень вкусный. Но я боюсь, что он был отравлен."
    corina "那么，仆人。这酒味道真不错。但我恐怕它被下了毒。"

# game/a11/3guests.rpy:198
translate english guests3_corina_f95c9fc9:

    # me "И?"
    me "所以呢？"

# game/a11/3guests.rpy:199
translate english guests3_corina_7eb7f3ce:

    # corina "Тебе надо его проверить."
    corina "你得替我验验毒。"

# game/a11/3guests.rpy:200
translate english guests3_corina_7af8fce2:

    # me "Ну дай мне бутылку."
    me "那瓶子给我。"

# game/a11/3guests.rpy:201
translate english guests3_corina_dfd90193:

    # corina "Она уже пустая."
    corina "已经空了。"

# game/a11/3guests.rpy:202
translate english guests3_corina_a127efd5:

    # me "Как тогда я проверю? Дай мне другую бутылку."
    me "那我要怎么验？给我另一瓶。"

# game/a11/3guests.rpy:203
translate english guests3_corina_f77a70ab:

    # corina "Нет. А что если отравлена была только одна бутылка?"
    corina "不。万一只有这一瓶被下毒了呢？"

# game/a11/3guests.rpy:204
translate english guests3_corina_3f803328:

    # me "Что ты предлагаешь?"
    me "那你想怎么办？"

# game/a11/3guests.rpy:205
translate english guests3_corina_eb2ee78f:

    # corina "Тебе нужно попробовать содержимое этой бутылки. Определить на вкус был ли тут яд."
    corina "你得尝尝这瓶子里残留的东西。尝出里面有没有毒药。"

# game/a11/3guests.rpy:206
translate english guests3_corina_8fbe35a1:

    # me "Ладно. И как мне это сделать?"
    me "好吧。那我该怎么做？"

# game/a11/3guests.rpy:207
translate english guests3_corina_4b3991ab:

    # corina "Я вижу тут только один вариант."
    corina "眼下我看来，只有一个法子。"

# game/a11/3guests.rpy:209
translate english guests3_corina_116a6cbf:

    # me "Поверить не могу, что я это делаю."
    me "真不敢相信我在做这种事。"

# game/a11/3guests.rpy:210
translate english guests3_corina_53a25472:

    # corina "Да ладно тебе, слуга, готова поспорить, у тебя сейчас стояк."
    corina "别害羞嘛，仆人，我敢打赌，你现在肯定硬邦邦的。"

# game/a11/3guests.rpy:211
translate english guests3_corina_3820771a_2:

    # me "..."
    me "..."

# game/a11/3guests.rpy:212
translate english guests3_corina_a85bf0cd:

    # corina "Ну?"
    corina "怎么样？"

# game/a11/3guests.rpy:213
translate english guests3_corina_ad02f53a:

    # me "Что?"
    me "什么怎么样？"

# game/a11/3guests.rpy:214
translate english guests3_corina_75a5151d:

    # corina "Отравлена? Как моя слюна на вкус? Чувствуешь яд?"
    corina "有毒吗？我口水味道如何？尝出毒药了吗？"

# game/a11/3guests.rpy:215
translate english guests3_corina_5a7a7577:

    # me "Нет."
    me "没有。"

# game/a11/3guests.rpy:216
translate english guests3_corina_fee6da99:

    # corina "Точно?"
    corina "确定？"

# game/a11/3guests.rpy:217
translate english guests3_corina_e0d9c569:

    # me "Не знаю..."
    me "不知道……"

# game/a11/3guests.rpy:218
translate english guests3_corina_b80f3e0e:

    # corina "Ну тогда проглоти."
    corina "那就吞下去。"

# game/a11/3guests.rpy:219
translate english guests3_corina_ad02f53a_1:

    # me "Что?"
    me "什么？"

# game/a11/3guests.rpy:220
translate english guests3_corina_422bdf92:

    # corina "Проглоти говорю. Быстро."
    corina "我说，吞下去。快点。"

# game/a11/3guests.rpy:222
translate english guests3_corina_70ce46e7:

    # corina "Хороший слуга. Ну как тебе?"
    corina "真是个好仆人。感觉怎么样？"

# game/a11/3guests.rpy:223
translate english guests3_corina_943b8dcb:

    # me "Потрясающе. Яда не чувствую."
    me "棒极了。没尝出毒味。"

# game/a11/3guests.rpy:224
translate english guests3_corina_296d7677:

    # corina "А стояк чувствуешь?"
    corina "那现在呢？"

# game/a11/3guests.rpy:225
translate english guests3_corina_3820771a_3:

    # me "..."
    me "..."

# game/a11/3guests.rpy:226
translate english guests3_corina_b64954cb:

    # corina "Извращенец. Твоя сестра знает, что ты...такой?"
    corina "变态。你妹妹知道你……是这样的人吗？"

# game/a11/3guests.rpy:227
translate english guests3_corina_4e7dfaf3:

    # me "Какой?"
    me "怎么样的人？"

# game/a11/3guests.rpy:228
translate english guests3_corina_ffdee751:

    # corina "Любишь поиграть? Не переживай, у людей в твоем положении часто бывают такие наклонности."
    corina "喜欢玩这种游戏？别担心，在你这种位置上的人，往往都有这种怪癖。"

# game/a11/3guests.rpy:229
translate english guests3_corina_489a247d:

    # me "Правда?"
    me "真的吗？"

# game/a11/3guests.rpy:230
translate english guests3_corina_977d4218:

    # corina "Ага. Тот кто снизу хочет быть сверху, а кто сверху..."
    corina "是啊。被压的人想翻身，压别人的人嘛……"

# game/a11/3guests.rpy:231
translate english guests3_corina_eee819cf:

    # me "Я понял."
    me "我明白了。"

# game/a11/3guests.rpy:232
translate english guests3_corina_8406b52a:

    # corina "Молодец. Может в следующий раз попробуешь это вино...撸了以后?"
    corina "真聪明。也许下次你可以尝尝这酒……是从哪个出口出来的呢。"

# game/a11/3guests.rpy:233
translate english guests3_corina_784578a6:

    # me "Охренела?"
    me "你疯了吗？"

# game/a11/3guests.rpy:238
translate english guests3_elin_79d82858:

    # "Десять минут спустя."
    "十分钟以后。"

# game/a11/3guests.rpy:239
translate english guests3_elin_30ddf953:

    # me "Вот хороший ручей."
    me "这条小溪真不错。"

# game/a11/3guests.rpy:240
translate english guests3_elin_1b31e4de:

    # elin "Да. Супер. Нам повезло, что не пришлось идти слишком далеко."
    elin "是。太好了。我们运气真好，不用走太远。"

# game/a11/3guests.rpy:241
translate english guests3_elin_102956bb:

    # me "Стой. Не спускайся. Я сам."
    me "等等，别下去。我自己来。"

# game/a11/3guests.rpy:243
translate english guests3_elin_7e50ca66:

    # me "Раз..и два..."
    me "一……二……"

# game/a11/3guests.rpy:244
translate english guests3_elin_1242153a:

    # elin "Спасибо."
    elin "谢谢。"

# game/a11/3guests.rpy:245
translate english guests3_elin_6835496c:

    # me "Не за что. Обоим мочить ноги необязательно."
    me "没什么。没必要两个人都把脚弄湿。"

# game/a11/3guests.rpy:246
translate english guests3_elin_377a7062:

    # elin "Ты такой сильный..."
    elin "你可真强壮……"

# game/a11/3guests.rpy:247
translate english guests3_elin_e9811180:

    # me "Можешь не одаривать меня комплиментами. Одно ведро ты все равно понесешь сама."
    me "你不用恭维我。反正你还是得自己拎一桶回去。"

# game/a11/3guests.rpy:248
translate english guests3_elin_e4d9a0b0:

    # elin "[mename]..."
    elin "[mename]..."

# game/a11/3guests.rpy:249
translate english guests3_elin_26561f4f:

    # me "Эх..."
    me "唉……"

# game/a11/3guests.rpy:250
translate english guests3_elin_f21b3bc9:

    # elin "Я шучу. Я понесу второе."
    elin "开玩笑的。这桶我也拎。"

# game/a11/3guests.rpy:252
translate english guests3_elin_18d51879:

    # elin "Хотя ты был бы конечно самым сильным братом на свете, если бы..."
    elin "不过，你本来可以成为世上最强壮的哥哥，如果你……"

# game/a11/3guests.rpy:253
translate english guests3_elin_96f32740:

    # me "Не начинай."
    me "别又来这套。"

# game/a11/3guests.rpy:254
translate english guests3_elin_2b057b58:

    # elin "Если бы понес оба ведра обратно."
    elin "如果你能把两桶水都拎回去。"

# game/a11/3guests.rpy:255
translate english guests3_elin_4cd5637e:

    # me "Я так понимаю моя помощь заключается в полном выполнении твоих обязанностей."
    me "要我看，所谓的帮忙，就是完全替你干完你份内的活儿。"

# game/a11/3guests.rpy:256
translate english guests3_elin_7acc01b6:

    # elin "Ну я же девушка..."
    elin "可我毕竟是个女孩子……"

# game/a11/3guests.rpy:257
translate english guests3_elin_f95c9fc9:

    # me "И?"
    me "所以呢？"

# game/a11/3guests.rpy:258
translate english guests3_elin_a2607a93:

    # elin "Это невежливо заставлять меня таким заниматься."
    elin "强迫我做这种事是不礼貌的。"

