# game/a11/3guests.rpy:955
translate english guests5_5cc441a5:

    # corina "Она не мертва, чтобы ее воскрешать. По крайней мере не до конца...Это штуковина не дает ей умереть. Пока что."
    corina "她又没真正死透，谈不上复活。至少还没完全死……这玩意儿能让她暂时不彻底死去。暂时的。"

# game/a11/3guests.rpy:956
translate english guests5_7acf9d63:

    # elin "Пока что?"
    elin "暂时的？"

# game/a11/3guests.rpy:957
translate english guests5_a41b01c9:

    # corina "Это ненадолго. Камень изнашивается за считанные минуты."
    corina "撑不了多久。这石头再过几分钟就耗光了。"

# game/a11/3guests.rpy:958
translate english guests5_500de9c9:

    # elin "Ты серьезно?"
    elin "你是说真的吗？"

# game/a11/3guests.rpy:959
translate english guests5_f33adde6:

    # corina "Да. Впрочем если ее дух что-то и мог увидеть, скорее всего уже увидел."
    corina "是的。话说回来，就算她的灵魂能看到什么，多半也已经看到了。"

# game/a11/3guests.rpy:960
translate english guests5_67618c58:

    # elin "Так чего мы ждем?"
    elin "那我们还等什么？"

# game/a11/3guests.rpy:962
translate english guests5_7d486019:

    # corina "В принципе ничего. Можем начинать."
    corina "基本没什么可等的。可以开始了。"

# game/a11/3guests.rpy:963
translate english guests5_81735cce:

    # elin "Исцеление?"
    elin "治疗术吗？"

# game/a11/3guests.rpy:964
translate english guests5_d71c0ae7:

    # corina "Да."
    corina "对。"

# game/a11/3guests.rpy:966
translate english guests5_92d397c8_2:

    # elin "..."
    elin "..."

# game/a11/3guests.rpy:967
translate english guests5_ddc97bd4:

    # corina "..."
    corina "..."

# game/a11/3guests.rpy:968
translate english guests5_40bbee2f:

    # elin "Клянусь богами, если она умрет...я отправлю тебя вслед за ней."
    elin "我向诸神起誓，要是她死了……我就让你跟着下地狱。"

# game/a11/3guests.rpy:969
translate english guests5_2621f0f2:

    # corina "Успокойся. Она сама на это согласилась."
    corina "冷静。这是她自己同意的。"

# game/a11/3guests.rpy:970
translate english guests5_a111391a:

    # elin "Почему же ты не на ее месте?"
    elin "那你怎么不躺在这儿？"

# game/a11/3guests.rpy:971
translate english guests5_7ee65fb9:

    # corina "Потому что я лучше исцеляю. К тому же она испытала разовую боль, а я постарею на пару месяцев."
    corina "因为我更擅长治疗。再说，她承受的是一时的痛苦，而我可是会衰老好几个月。"

# game/a11/3guests.rpy:972
translate english guests5_604e3500:

    # elin "Да. Она всего лишь умерла. А ты, бедняжка, получишь лишнюю морщинку."
    elin "是啊。她不过是死了一回。而你呢，可怜见的，得添上几道皱纹。"

# game/a11/3guests.rpy:973
translate english guests5_ddc97bd4_1:

    # corina "..."
    corina "..."

# game/a11/3guests.rpy:974
translate english guests5_92d397c8_3:

    # elin "..."
    elin "..."

# game/a11/3guests.rpy:975
translate english guests5_57be58a4:

    # corina "Чувствуешь? Сердце снова бьется. Работает."
    corina "感觉到了吗？心跳恢复了。生效了。"

# game/a11/3guests.rpy:976
translate english guests5_9f91fd4a:

    # elin "Да. Но она все еще не..."
    elin "是的。但她还是没……"

# game/a11/3guests.rpy:978
translate english guests5_64f8db0d:

    # una "Ааааааааагх!"
    una "啊啊啊啊啊赫！"

# game/a11/3guests.rpy:979
translate english guests5_793b0073:

    # elin "...дышит."
    elin "……呼吸。"

# game/a11/3guests.rpy:980
translate english guests5_3a6805c7:

    # corina "С возвращением, подруга."
    corina "欢迎回来，我的姐妹。"

# game/a11/3guests.rpy:981
translate english guests5_61303b0a:

    # elin "Она...в норме?"
    elin "她……没事吧？"

# game/a11/3guests.rpy:982
translate english guests5_5b9376da:

    # una "Понятия не имею."
    una "一点也不清楚。"

# game/a11/3guests.rpy:983
translate english guests5_e5d73cb8:

    # una "О БОГИ!"
    una "哦 诸神啊！"

# game/a11/3guests.rpy:984
translate english guests5_b5dcdf0f:

    # corina "Ну речь сохранилась."
    corina "嗯，看来语言功能还是保住了。"

# game/a11/3guests.rpy:985
translate english guests5_9a78a590:

    # elin "Какой кошмар."
    elin "真是……噩梦一场。"

# game/a11/3guests.rpy:987
translate english guests5_df7fb247:

    # corina "Ты как?"
    corina "你感觉怎么样？"

# game/a11/3guests.rpy:988
translate english guests5_50a61b3d:

    # una "Дайте...отдышаться..."
    una "让我……喘口气……"

# game/a11/3guests.rpy:989
translate english guests5_ba20e8f0:

    # me "Ну вы, девочки, конечно и ебанутые..."
    me "你们这些姑娘们，真是他妈的精神错乱……"

# game/a11/3guests.rpy:990
translate english guests5_5fd34aa1:

    # elin "Может нам продолжить?"
    elin "也许我们该继续？"

# game/a11/3guests.rpy:991
translate english guests5_ca32b8b7:

    # corina "Рана затянулась."
    corina "伤口愈合了。"

# game/a11/3guests.rpy:992
translate english guests5_309215f7:

    # una "Не надо...я ...я в норме...если это конечно можно так назвать..."
    una "不用了……我……我没事了……如果这么说还算合适的话……"

# game/a11/3guests.rpy:993
translate english guests5_1672ffcc:

    # corina "Что-нибудь видела?"
    corina "看到什么了吗？"

# game/a11/3guests.rpy:994
translate english guests5_162e0e2c:

    # elin "Дай ей прийти в себя!"
    elin "让她缓缓！"

# game/a11/3guests.rpy:995
translate english guests5_5ebf2013:

    # una "Нет...все нормально..я...я видела."
    una "不……没关系的……我……我看到了。"

# game/a11/3guests.rpy:996
translate english guests5_eabeb23b:

    # corina "Что ты видела?"
    corina "你看到了什么？"

# game/a11/3guests.rpy:997
translate english guests5_ae965094:

    # una "По большей части эту комнату. Себя, только будто со стороны."
    una "大部分是这间屋子。还有我自己的身体，就好像站在旁边看一样。"

# game/a11/3guests.rpy:998
translate english guests5_4bab1ff5:

    # corina "Твою мать...не сработало."
    corina "他妈的……没成功。"

# game/a11/3guests.rpy:999
translate english guests5_91f64433:

    # elin "О, боги."
    elin "哦，诸神啊。"

# game/a11/3guests.rpy:1000
translate english guests5_004cbf38:

    # una "Сработало. Я видела... урывками... я видела тела. Их предали."
    una "成功了。我看到了……断断续续的片段……我看到了尸体。他们被出卖了。"

# game/a11/3guests.rpy:1001
translate english guests5_20773f06:

    # corina "Оп-па."
    corina "哇哦。"

# game/a11/3guests.rpy:1003
translate english guests5_67b5c1bd:

    # elin "Кто их предал?"
    elin "被谁出卖了？"

# game/a11/3guests.rpy:1004
translate english guests5_f8a7702b:

    # una "Магистр Западной Башни. Магна. Она увела их в портал. А там убила все до единого."
    una "西方高塔的魔导师。Magna。她把所有人领进了传送门。然后在那儿，把他们一个不剩，全杀了。"

# game/a11/3guests.rpy:1005
translate english guests5_f75d8a9f:

    # corina "Так значит это все же было предательство."
    corina "那么说，果然是叛变。"

# game/a11/3guests.rpy:1006
translate english guests5_7123dc89:

    # elin "Зачем?"
    elin "为什么？"

# game/a11/3guests.rpy:1007
translate english guests5_9707f891:

    # una "Не знаю. Я чувствовала в ней...страх...ужас. Он пронизывал ее целиком."
    una "不知道。我从她身上感受到了……恐惧……彻头彻尾的恐惧。她整个人都被恐惧浸透了。"

# game/a11/3guests.rpy:1008
translate english guests5_fa4b2acf:

    # corina "Ей кто-то угрожал? Могущественному магу?"
    corina "有人威胁她吗？一个强大的法师？"

# game/a11/3guests.rpy:1009
translate english guests5_61b44b4b:

    # elin "Ты уверена?"
    elin "你能确定吗？"

# game/a11/3guests.rpy:1010
translate english guests5_83483c7c:

    # una "Уверена. Я видела...я чувствовала, как она колеблется."
    una "我确定。我看到了……我感受到她当时的犹豫。"

# game/a11/3guests.rpy:1011
translate english guests5_60573e27:

    # corina "Интересно. Где она сейчас?"
    corina "有意思。那她现在在哪？"

# game/a11/3guests.rpy:1012
translate english guests5_9c4dc800:

    # una "В долине. Я чувствовала будто вокруг...эльфы. Но они ее ненавидят. Ищут. Но не все. Кто-то помогает."
    una "在某处山谷里。我感觉四周好像……全是精灵。但他们憎恨她。他们在搜索她。但并非所有人。有谁在帮她。"

# game/a11/3guests.rpy:1013
translate english guests5_577171de:

    # corina "Эльфы значит."
    corina "也就是说，是精灵。"

# game/a11/3guests.rpy:1014
translate english guests5_531f8e9a:

    # elin "Эльфы угрожали ей?"
    elin "精灵威胁了她？"

# game/a11/3guests.rpy:1015
translate english guests5_0614d6f2:

    # una "Нет. Кто-то другой. Она боялась. Не знаю...я будто видела...лицо...но оно было мутное...будто размыто в водной ряби."
    una "不。是别的什么人。她很害怕。我说不上来……我隐约看见……一张脸……但它很模糊……像水面荡开的波纹。"

# game/a11/3guests.rpy:1016
translate english guests5_8cfc5d59:

    # una "За лицом ничего не было. Пустота. Я не чувствовала ничего от этого лица. Будто это была какая-то пустая оболочка."
    una "那张脸的后面，什么都没有。一片虚空。我从那张脸上感受不到任何东西。就好像那只是个空壳。"

# game/a11/3guests.rpy:1017
translate english guests5_af97da8d:

    # corina "Может...какая-то иллюзия. Но почему она боялась иллюзии, да так что убила всех учеников и других учителей?"
    corina "也许是……某种幻术。但她为什么会被幻术吓成那样，以至于杀了所有的学生和其他的老师？"

# game/a11/3guests.rpy:1018
translate english guests5_bc486147:

    # una "Прямо перед тем, как вы вернули меня, я почти разглядела очертания... Я вдруг почувствовала, что в тот день Магна была не одна. Кто-то помогал ей."
    una "就在你们把我拉回来之前，我几乎就要看清那轮廓了……我忽然感觉到，出事那天，Magna不是一个人。有人在帮她。"

# game/a11/3guests.rpy:1021
translate english guests5_11370183:

    # una "Но прежде чем я поняла, кто это, меня будто одернули."
    una "可就在我认出那人是谁之前的一刻，我好像被人拉开了。"

# game/a11/3guests.rpy:1022
translate english guests5_2bb9e8bd:

    # corina "Мы вернули тебя?"
    corina "是我们把你拉回来的吗？"

# game/a11/3guests.rpy:1023
translate english guests5_d5236cfa:

    # una "Нет. Сначала это была она... твоя дочь."
    una "不。一开始是她……你的女儿。"

# game/a11/3guests.rpy:1024
translate english guests5_286bcd99:

    # elin "Чья дочь?"
    elin "谁的女儿？"

# game/a11/3guests.rpy:1025
translate english guests5_827f69d1:

    # una "Твоя, [elin]."
    una "你的，[elin]。"

# game/a11/3guests.rpy:1026
translate english guests5_e1ef207f:

    # elin "О чем ты говоришь? У меня нет дочери."
    elin "你在说什么？我没有女儿。"

# game/a11/3guests.rpy:1027
translate english guests5_a584b18e:

    # una "Я знаю. Но я чувствовала, что это твоя дочь."
    una "我知道。但我就是感觉到，那是你的女儿。"

# game/a11/3guests.rpy:1028
translate english guests5_aa809d47:

    # corina "Как это? Если ее не существует."
    corina "这怎么可能？她压根就不存在。"

# game/a11/3guests.rpy:1029
translate english guests5_8f5e584b:

    # una "Я не могу объяснить. Я просто чувствовала это и все."
    una "我没法解释。我就是感觉到了，就这样。"

# game/a11/3guests.rpy:1030
translate english guests5_5eed6eb8:

    # elin "И что она...делала или говорила?"
    elin "那她……干了什么，或者说了什么吗？"

# game/a11/3guests.rpy:1031
translate english guests5_5d4772b5:

    # una "Она будто заполонила меня...я вдруг почувствовала, что она заполняет мой разум. Я думала что умираю. А потом вы меня вернули."
    una "她好像把我整个都占据了……我突然间觉得，她在充满我的整个意识。我以为我真的死了。然后你们就把我拉回来了。"

# game/a11/3guests.rpy:1032
translate english guests5_0a2b4455:

    # corina "Ты так и не увидела, кто помогал Магне в ту ночь?"
    corina "所以你到底还是没有认出，出事那晚是谁在帮助Magna？"

# game/a11/3guests.rpy:1033
translate english guests5_c6b47444:

    # una "Нет. Это все. Теперь точно."
    una "没有了。就这些。这次是真的，就这些。"

# game/a11/3guests.rpy:1036
translate english guests5_92b7685f:

    # una "Я видела тебя, [elin]."
    una "可我看见了你，[elin]。"

# game/a11/3guests.rpy:1037
translate english guests5_aad395bd:

    # corina "Что?"
    corina "什么？"

# game/a11/3guests.rpy:1038
translate english guests5_e59e6e7c:

    # elin "Меня?"
    elin "我？"

# game/a11/3guests.rpy:1039
translate english guests5_e065aeae:

    # una "Это вроде была не ты и все же ты... выглядела, как ты. Но я будто тебя не чувствовала."
    una "那好像不是你，但又确实是你……看起来，就是你。但我似乎感觉不到你的存在。"

# game/a11/3guests.rpy:1040
translate english guests5_14d8c66f:

    # elin "Что это значит."
    elin "这是什么意思。"

# game/a11/3guests.rpy:1041
translate english guests5_f816ee23:

    # una "Ты говорила с ней. Ты открыла для нее портал. Они скрылись в нем. А ты ушла."
    una "你在和她说话。你为她打开了传送门。她们消失在那道门里。你也离开了。"

# game/a11/3guests.rpy:1042
translate english guests5_544bfed6:

    # corina "[elin]?"
    corina "[elin]?"

# game/a11/3guests.rpy:1043
translate english guests5_b3910a92:

    # elin "Я этого не делала."
    elin "我没做过这种事。"

# game/a11/3guests.rpy:1044
translate english guests5_558a8697:

    # una "Это будто была не ты... что-то вроде оболочки..."
    una "那好像不是你本人……像个躯壳……"

# game/a11/3guests.rpy:1045
translate english guests5_b81c287a:

    # corina "Оболочки?"
    corina "躯壳？"

# game/a11/3guests.rpy:1046
translate english guests5_fe5753e4:

    # elin "Может какое-то заклятие, меняющее внешность?"
    elin "也许是某种改变外貌的咒语？"

# game/a11/3guests.rpy:1047
translate english guests5_e6fb97ea:

    # una "И много ты таких знаешь?"
    una "你知道多少种这样的咒语？"

# game/a11/3guests.rpy:1048
translate english guests5_34914aeb:

    # elin "Ни одного. Но что я точно знаю - я попала в башню в первый раз с мамой и братом. Меня никогда не было там до этого."
    elin "一种也不知道。但有一件事我很肯定——我第一次去那座塔，是和妈妈还有哥哥一起去的。在那之前，我压根就没进过那座塔。"

# game/a11/3guests.rpy:1049
translate english guests5_9cd5947f:

    # corina "Ладно..."
    corina "好吧……"

# game/a11/3guests.rpy:1050
translate english guests5_1e61bf62:

    # elin "Издеваешься? Зачем мне убивать магов в Западной башне?"
    elin "你是在开玩笑吗？我为什么要去杀害西方高塔里的法师？"

# game/a11/3guests.rpy:1051
translate english guests5_f305615f:

    # corina "Не знаю. Может чтобы помочь брату?"
    corina "谁知道呢。也许是为了帮你哥哥？"

# game/a11/3guests.rpy:1052
translate english guests5_5bb4412b:

    # una "Стоп, Корина. Не вини ее. Я отчетливо видела и чувствовала Магну и ее действия и мысли. Но [elin]...это было что-то вроде наваждения."
    una "行了，Corina。别责怪她了。我能清晰地看见并感到Magna，以及她的行为和想法。至于[elin]……那更像是一种幻象。"

# game/a11/3guests.rpy:1053
translate english guests5_f77188a8:

    # elin "Как это понять."
    elin "这该如何理解。"

# game/a11/3guests.rpy:1054
translate english guests5_a1afd583:

    # una "Ты будто была частью какого-то сна...простите, я не могу объяснить это."
    una "你好像……是某个梦的一部分……很抱歉，我没法解释清楚。"

# game/a11/3guests.rpy:1055
translate english guests5_68970b7a:

    # corina "Ладно. В любом случае, даже если [elin] там и была, или тот кто ей притворялся, Магна убила всех, верно? Вот ее и будем искать."
    corina "好吧。不管怎么说，就算[elin]当时真的在场，或者有人假扮了她，Magna反正是杀了所有人，对吧？所以我们就去找她。"

# game/a11/3guests.rpy:1057
translate english guests5_c4aed106:

    # me "Вы закончили свой эксперимент?"
    me "你们的实验算是完成了吗？"

# game/a11/3guests.rpy:1058
translate english guests5_31661b03:

    # una "Да. Это все что я...чувствовала."
    una "是的。这就是我感觉到……的全部了。"

# game/a11/3guests.rpy:1059
translate english guests5_447517ef:

    # me "Я и не понимаю, в чем польза от этой информации. Разве магистры вам поверят?"
    me "我不明白，就算得到这消息有什么用。那些魔导师会信你们吗？"

# game/a11/3guests.rpy:1060
translate english guests5_e79ff239:

    # corina "Им придется."
    corina "他们不信也得信。"

# game/a11/3guests.rpy:1061
