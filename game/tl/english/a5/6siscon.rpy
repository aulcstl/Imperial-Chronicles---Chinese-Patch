    # me "Ты не могла ее контролировать?"
    me "你控制不住吗？"

# game/a5/6siscon.rpy:371
translate english sisconblue_1aa52a1c:

    # elin "Да. То есть нет. Не знаю. Боги, какого хрена это так приятно?"
    elin "是。不，不是。我不知道。天哪，这感觉怎么能这么舒服？"

# game/a5/6siscon.rpy:372
translate english sisconblue_a6028e92:

    # me "Выглядишь счастливой."
    me "看起来你很开心。"

