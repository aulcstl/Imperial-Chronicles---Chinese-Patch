    # me "Это еще что было?"
    me "刚才那是什么？"

# game/a5/6siscon.rpy:367
translate english sisconblue_35810698:

    # elin "Оргазм. Я кончила."
    elin "高潮。我去了。"

# game/a5/6siscon.rpy:368
translate english sisconblue_e82be5b1:

    # me "Это я понял. А что со столом?"
    me "这我明白。桌子是怎么回事？"

# game/a5/6siscon.rpy:369
translate english sisconblue_0d2e3270:

    # elin "Не знаю...кажется магия."
    elin "不知道……像是魔法。"

# game/a5/6siscon.rpy:370
