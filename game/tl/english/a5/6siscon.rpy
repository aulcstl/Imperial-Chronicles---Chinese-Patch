    # me "Я готов. Даже если не готова ты."
    me "我准备好了。就算你没准备好。"

# game/a5/6siscon.rpy:354
translate english sisconblue_e6ddd98a:

    # elin "Я готова, [mename], я почти..."
    elin "我准备好了，[mename]，我快……"

