translate english sisconblue_5a31611b:

    # me "Ну ладно."
    me "嗯，那就好。"

# game/a5/6siscon.rpy:284
translate english sisconblue_cc89022b:

    # elin "А ты был серьезен, когда говорил, что не будешь уделять мне внимание?"
