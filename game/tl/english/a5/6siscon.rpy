translate english sisconblue_489a247d:

    # me "Правда?"
    me "真的吗？"

# game/a5/6siscon.rpy:299
translate english sisconblue_3820771a_5:

    # me "..."
    me "..."

# game/a5/6siscon.rpy:300
translate english sisconblue_92d397c8_5:

    # elin "..."
    elin "..."

