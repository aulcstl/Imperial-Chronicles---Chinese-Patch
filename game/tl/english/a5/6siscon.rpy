translate english sisconblue_6381a52d:

    # elin "Мы же близнецы. [mename], я чуть не умерла во время нашей первой разлуки."
    elin "我们是双胞胎啊。[mename]，我们第一次分开的时候，我差点死掉。"

# game/a5/6siscon.rpy:289
translate english sisconblue_6883f855:

    # me "Мне тебя тоже не хватало."
    me "我也很想你。"

# game/a5/6siscon.rpy:290
translate english sisconblue_f508da25:

