    me "嗯，是的……我还吻了国王的手。"

# game/a5/7imperial.rpy:10
translate english imperial_ff447259:

    # lia "В честь признательности его выбору невесты для тебя."
    lia "以感谢他为你选择了新娘。"

# game/a5/7imperial.rpy:11
translate english imperial_2d42945b:

    # me "Ага."
    me "嗯。"

# game/a5/7imperial.rpy:13
translate english imperial_e17b4264:

    # me "Ну а потом был пир."
    me "嗯，然后就是宴会了。"

# game/a5/7imperial.rpy:14
