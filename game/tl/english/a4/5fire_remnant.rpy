# TODO: Translation updated at 2024-05-03 04:09

# game/a4/5fire_remnant.rpy:7
translate russian fire_remnant_ad5efb6c:

    # "На следующий день."
    "第二天。"

# game/a4/5fire_remnant.rpy:10
translate russian fire_remnant_fea25a47:

    # ahara "Какой это уже раз, третий, четвертый? "
    ahara "这已经是第几次了，第三次还是第四次？"

# game/a4/5fire_remnant.rpy:11
translate russian fire_remnant_d7d191e4:

    # me "Какая разница? Есть какой-то предел, после которого ты не сможешь трахаться? "
    me "有区别吗？难道有什么限制让你之后不能再干？"

# game/a4/5fire_remnant.rpy:12
translate russian fire_remnant_f4000b91:

    # ahara "Как раз у меня предела нет, а вот у мужчин есть некоторые лимиты...телесных жидкостей. "
    ahara "我倒是没有限制，但男人在体液方面总有些……限度。"

# game/a4/5fire_remnant.rpy:13
translate russian fire_remnant_5d0a2851:

    # me "Я давно уже эти телесные жидкости не изливал, так что у меня сформировался запас. "
    me "我已经很久没释放这些体液了，所以攒了不少存货。"

# game/a4/5fire_remnant.rpy:14
translate russian fire_remnant_594db541:

    # ahara "Что, во дворце совсем некого трахнуть? "
    ahara "怎么，宫里都没有人能让你发泄？"

# game/a4/5fire_remnant.rpy:15
translate russian fire_remnant_59d84bd2:

    # me "Нет, зачем по-твоему тебя наняли? "
    me "没有，不然你以为为什么会雇你来？"

# game/a4/5fire_remnant.rpy:16
translate russian fire_remnant_d4546b6e:

    # ahara "Чтобы служить вашим прихотям, господин. "
    ahara "为了侍奉您的喜好，大人。"

# game/a4/5fire_remnant.rpy:17
translate russian fire_remnant_dfdf76a9:

    # me "Ну вот служи и не жалуйся. "
    me "那就好好侍奉，别抱怨。"

# game/a4/5fire_remnant.rpy:18
translate russian fire_remnant_a10e5643:

    # ahara "Я вовсе не жалуюсь, наоборот, делаю комплимент вашей мужской силе. "
    ahara "我可不是在抱怨，相反，我是在恭维您的男性雄风。"

# game/a4/5fire_remnant.rpy:20
translate russian fire_remnant_5e1988e8:

    # me "Ух... Спасибо. Сегодня я и в правду в ударе. "
    me "呃……谢谢。今天我确实状态不错。"

# game/a4/5fire_remnant.rpy:21
translate russian fire_remnant_1ccf6c88:

    # ahara "Не то слово, во мне, по ощущениям, уже кружка вашей спермы. "
    ahara "何止不错，我感觉自己里面已经装满了您的精液，像一大杯那么多。"

# game/a4/5fire_remnant.rpy:22
translate russian fire_remnant_f62d7108:

    # me "Мне готовиться растить бастарда? "
    me "我需要准备养育一个私生子吗？"

# game/a4/5fire_remnant.rpy:23
translate russian fire_remnant_1f6e0629:

    # ahara "Не волнуйтесь, люди моей профессии знают как избегать этой проблемы. "
    ahara "别担心，干我们这行的知道怎么避免这种问题。"

# game/a4/5fire_remnant.rpy:25
translate russian fire_remnant_36e21b17:

    # ahara "Я немного подымлю, вы не против? "
    ahara "我稍微抽点烟，您不介意吧？"

# game/a4/5fire_remnant.rpy:26
translate russian fire_remnant_44d254cf:

    # me "Что это? "
    me "那是什么？"

# game/a4/5fire_remnant.rpy:27
translate russian fire_remnant_605dbcb3:

    # ahara "Белый дурман, на юге эту дрянь курят все. Хотите? "
    ahara "白曼陀罗，南方那边的人都抽这玩意儿。您要试试吗？"

# game/a4/5fire_remnant.rpy:28
translate russian fire_remnant_55d2ea7a:

    # me "Нет, спасибо, у меня сегодня запланирована встреча с невестой. "
    me "不了，谢谢，我今天约好了要见未婚妻。"

# game/a4/5fire_remnant.rpy:30
translate russian fire_remnant_a335462c:

    # ahara "Невеста? Вы скоро будете женаты? "
    ahara "未婚妻？您很快就要结婚了？"

# game/a4/5fire_remnant.rpy:31
translate russian fire_remnant_73050971:

    # me "А что? Переживаешь за свою работу? "
    me "怎么？担心你的饭碗？"

# game/a4/5fire_remnant.rpy:32
translate english fire_remnant_21c072d5:

    # ahara "Ни в коем случае, женатые мужчины тратят на шлюх больше денег, чем холостые. "
    ahara "绝对没有，结了婚的男人在妓女身上花的钱比单身汉多多了。"

# game/a4/5fire_remnant.rpy:33
translate english fire_remnant_7ce1e7f9:

    # ahara "Свадьба для людей вашего положения это только повод перестать стыдиться своими похождениями перед семьей, ведь вы теперь женаты. "
    ahara "对您这种地位的人来说，婚姻只是个借口，让您从此不用再为在外寻欢作乐而对家人感到羞耻，毕竟您现在已婚了。"

# game/a4/5fire_remnant.rpy:34
translate english fire_remnant_1bd85bbf:

    # me "Да? "
    me "是吗？"

# game/a4/5fire_remnant.rpy:35
translate english fire_remnant_cbc08e53:

    # ahara "Я уже не говорю о том, что благородные девушки редко бывают раскованными в постели, не говоря уже о том, чтобы выполнить ваше потаенные желания. "
    ahara "更不用说，那些贵族小姐在床上往往放不开，更别提满足您那些隐秘的欲望了。"

# game/a4/5fire_remnant.rpy:36
translate english fire_remnant_03fec380:

    # me "Намекаешь, что нам можно будет видеться и после свадьбы? "
    me "你这是在暗示我们婚后也能继续见面？"

# game/a4/5fire_remnant.rpy:37
translate english fire_remnant_d1a2a429:

    # ahara "Это зависит от ваших желаний, господин. "
    ahara "这取决于您的愿望，大人。"

# game/a4/5fire_remnant.rpy:38
translate english fire_remnant_6e887e96:

    # me "Не только от моих. Ты не забыла, что тебе платит моя мать?"
    me "不光是取决于我。你别忘了，付钱给你的是我母亲。"

# game/a4/5fire_remnant.rpy:39
translate english fire_remnant_c20a4108:

    # ahara "Да бросьте, вы наследный принц, я не верю, что вы не сможете меня взять на королевское обеспечение. "
    ahara "别逗了，您是王储，我不信您没法让我靠皇家供养起来。"

# game/a4/5fire_remnant.rpy:41
translate english fire_remnant_755789a3:

    # ahara "В конце концов даже комната во дворце и еда, без всякого золота, это лучше, чем оказаться на улице. "
    ahara "说到底，就算没有金银，只给我在宫里留个房间、管口饭吃，也比流落街头强。"

# game/a4/5fire_remnant.rpy:42
translate english fire_remnant_c3d188d1:

    # me "Хм... Я не знаю, как к этому будет относиться моя будущая жена. "
    me "嗯……我不知道我未来的妻子会怎么看这事。"

# game/a4/5fire_remnant.rpy:43
translate english fire_remnant_88b6a228:

    # ahara "А зачем ей вообще знать об этом? "
    ahara "她何必知道呢？"

# game/a4/5fire_remnant.rpy:44
translate english fire_remnant_a708f6c4:

    # me "Она может узнать сама. "
    me "她可能会自己发现。"

# game/a4/5fire_remnant.rpy:45
translate english fire_remnant_cc3d1d37:

    # ahara "Каким образом? Она будет следить за вами?"
    ahara "怎么发现？难道她会监视您？"

# game/a4/5fire_remnant.rpy:46
translate english fire_remnant_b1c885cc:

    # me "{i}Аврора вряд ли, а вот Исида...{/i}"
    me "{i}Aurora不太可能，但伊希斯……{/i}"

# game/a4/5fire_remnant.rpy:47
translate english fire_remnant_861566e9:

    # me "У вас, южанок, горячая кровь, все может быть."
    me "你们南方人热情似火，什么事都可能发生。"

# game/a4/5fire_remnant.rpy:49
translate english fire_remnant_9d25afaa:

    # ahara "Южанок? Она что, с Юга?"
    ahara "南方人？她……是从南方来的？"

# game/a4/5fire_remnant.rpy:50
translate english fire_remnant_bb686f7a:

    # me "Ну да."
    me "嗯，对。"

# game/a4/5fire_remnant.rpy:51
translate english fire_remnant_100f1536:

    # ahara "Откуда именно?"
    ahara "具体是哪儿？"

# game/a4/5fire_remnant.rpy:52
translate english fire_remnant_ef524e95:

    # me "Эм...я не вдавался в такие подробности если честно."
    me "呃……说实话我没细打听过这些。"

# game/a4/5fire_remnant.rpy:53
translate english fire_remnant_4229c94f:

    # ahara "А ее клан?"
    ahara "那她的氏族呢？"

# game/a4/5fire_remnant.rpy:54
translate english fire_remnant_835602cf:

    # me "Кажется он сейчас во главе Юга."
    me "好像现在正是南方的统治者。"

# game/a4/5fire_remnant.rpy:56
translate english fire_remnant_a45fa925:

    # ahara "О нет...о нет...нет-нет-нет...."
    ahara "哦不……哦不……不不不……"

# game/a4/5fire_remnant.rpy:57
translate english fire_remnant_75ba3164:

    # me "Что с тобой?"
    me "你怎么了？"

# game/a4/5fire_remnant.rpy:58
translate english fire_remnant_49d2cc04:

    # ahara "Это Гарпии с Красных гор, самый безжалостный клан на всем Юге."
    ahara "那是红山的哈比族，整个南方最残忍的氏族。"

# game/a4/5fire_remnant.rpy:59
translate english fire_remnant_93a2d93f:

    # me "Успокойся."
    me "冷静点。"

# game/a4/5fire_remnant.rpy:60
translate english fire_remnant_90aef3c5:

    # ahara "Успокоится? Они убили всю мою семью. Я была ребенком, но они бы и меня убили, я успела бежать на корабле сюда."
    ahara "冷静下来？他们杀了我全家。我当时还是个孩子，但肯定也会杀了我，我侥幸搭船逃到了这里。"

# game/a4/5fire_remnant.rpy:61
translate english fire_remnant_672a5a4c:

    # me "Ты серьезно?"
    me "你说真的？"

# game/a4/5fire_remnant.rpy:62
translate english fire_remnant_b2fc4b0c:

    # ahara "Похоже что я шучу? Они пришли к власти десять лет назад и тут же стали резать головы направо и налево."
    ahara "我看着像在开玩笑吗？他们十年前夺取了权力，立刻开始到处疯狂斩首。"

# game/a4/5fire_remnant.rpy:63
translate english fire_remnant_3d184bd2:

    # me "Исида в этом замешана?"
    me "伊希斯也参与了？"

# game/a4/5fire_remnant.rpy:64
translate english fire_remnant_ddf22dd8:

    # ahara "А как же. Она, ее братья, ее мать и отец и весь их клан, гребаные психопаты. Они травят, режут, сжигают заживо."
    ahara "当然了。她、她的兄弟们、她的父母，还有他们整个氏族，都是变态的疯子。他们用毒、砍头、活活把人烧死。"

# game/a4/5fire_remnant.rpy:65
translate english fire_remnant_14adf8bf:

    # me "Расслабься, она сюда не за тобой приехала."
    me "放轻松，她不是为你而来的。"

# game/a4/5fire_remnant.rpy:66
translate english fire_remnant_85e82bf4:

    # ahara "Какая разница зачем она приехала? Если ты женишься на ней я лишусь головы."
    ahara "她为什么来又有什么区别？你要是娶了她，我就脑袋搬家。"

# game/a4/5fire_remnant.rpy:67
translate english fire_remnant_b4a0b031:

    # me "Столько лет прошло, а она наверняка даже не знает, кто ты. К тому же когда твоя семья была убита, Исида сама была ребенком."
    me "都过去这么多年了，而且她甚至肯定不知道你是谁。更何况，你家人遇害时，伊希斯自己也只是个孩子。"

# game/a4/5fire_remnant.rpy:68
translate english fire_remnant_9a477179:

    # ahara "Не узнает она, узнает кто-то другой из ее клана. Ты не понимаешь, [mename], южане больше всего на свете ненавидят других южан. Даже если меня не узнают - мне все равно конец."
    ahara "她不认得我，总会有她氏族里的别人认得我。你不明白，[mename]，南方人最痛恨的就是其他南方人。就算我没被认出来——我也死定了。"

# game/a4/5fire_remnant.rpy:69
translate english fire_remnant_4fb4eb96:

    # isid "Тук-тук. Я могу войти?"
    isid "咚咚。我可以进来吗？"

# game/a4/5fire_remnant.rpy:71
translate english fire_remnant_b984c4c0:

    # ahara "Это она?"
    ahara "是她？"

# game/a4/5fire_remnant.rpy:72
translate english fire_remnant_fc30fd2b:

    # me "Да."
    me "是。"

# game/a4/5fire_remnant.rpy:73
translate english fire_remnant_3c72681e:

    # ahara "Пиздец!"
    ahara "靠！"

# game/a4/5fire_remnant.rpy:74
translate english fire_remnant_923a7f24:

    # me "Успокойся, пока я тут, тебя никто не тронет."
    me "冷静点，有我在，没人能动你。"

# game/a4/5fire_remnant.rpy:75
translate english fire_remnant_d231a668:

    # ahara "Я не хочу, чтобы она знала о моем существовании."
    ahara "我不想让她知道我的存在。"

# game/a4/5fire_remnant.rpy:76
translate english fire_remnant_7dc8a148:

    # me "Ладно, если хочешь спрячься на балконе. Я уведу ее."
    me "好吧，你要愿意就先躲到阳台上去。我把她引开。"

# game/a4/5fire_remnant.rpy:77
translate english fire_remnant_2c412d65:

    # ahara "Да. Хорошо."
    ahara "好。行。"

# game/a4/5fire_remnant.rpy:79
translate english fire_remnant_b088f513:

    # me "{i}Эх...пора на вторую встречу.{/i}"
    me "{i}唉……该赴第二个约了。{/i}"

# game/a4/5fire_remnant.rpy:80
translate english fire_remnant_a6bd3690:

    # me "{i}Невеста за невестой... Я могу к этому привыкнуть.{/i}"
    me "{i}一个又一个的未婚妻……我说不定能习惯。{/i}"

# game/a4/5fire_remnant.rpy:81
translate english fire_remnant_6375fb3f:

    # me "{i}Ладно, нужно одеться.{/i}"
    me "{i}好了，该穿好衣服了。{/i}"

# game/a4/5fire_remnant.rpy:83
translate english fire_remnant_21b131fa:

    # isid "Здравствуйте, принц."
    isid "您好，王子殿下。"

# game/a4/5fire_remnant.rpy:84
translate english fire_remnant_b406fd38:

    # me "Как ты...как ты вошла?"
    me "你怎么……怎么进来的？"

# game/a4/5fire_remnant.rpy:85
translate english fire_remnant_d35084ee:

    # isid "Было открыто."
    isid "门开着。"

# game/a4/5fire_remnant.rpy:86
translate english fire_remnant_9beae22a:

    # me "Я готов поспорить, что закрывал дверь..."
    me "我敢发誓我关了门……"

# game/a4/5fire_remnant.rpy:87
translate english fire_remnant_ddd77290:

    # isid "Я могу выйти."
    isid "我可以再出去。"

# game/a4/5fire_remnant.rpy:88
translate english fire_remnant_43dc6e2a:

    # me "Не нужно. Я готов к прогулке."
    me "不必了。我已经准备好去散步了。"

# game/a4/5fire_remnant.rpy:91
translate english fire_remnant_d97f3f44:

    # isid "Принц, здесь был кто-то из моих слуг или рабов?"
    isid "殿下，刚才这里有我的仆人或者奴隶吗？"

# game/a4/5fire_remnant.rpy:92
translate english fire_remnant_5a7a7577:

    # me "Нет."
    me "没有。"

# game/a4/5fire_remnant.rpy:93
translate english fire_remnant_b95e3d19:

    # isid "Вы уверены?"
    isid "您确定？"

# game/a4/5fire_remnant.rpy:94
translate english fire_remnant_541065ac:

    # me "Ну только если кто-то ночью пробирался ко мне, открывая незапертую дверь, а почему ты спрашиваешь?"
    me "嗯，除非有人夜里溜进我房间，打开那扇没锁的门进来。你怎么这么问？"

# game/a4/5fire_remnant.rpy:95
translate english fire_remnant_5ad37b05:

    # isid "Я узнаю этот запах везде...белый дурман. Вы курите южные травы?"
    isid "这个味道我无论到哪儿都认得出……白曼陀罗。您在抽南方草药？"

# game/a4/5fire_remnant.rpy:97
translate english fire_remnant_3683adcd:

    # me "Ну...попробовал вот первый раз, ради интереса."
    me "呃……就是出于好奇，第一次试试看。"

# game/a4/5fire_remnant.rpy:98
translate english fire_remnant_b03634db:

    # isid "И какой эффект?"
    isid "效果如何？"

# game/a4/5fire_remnant.rpy:99
translate english fire_remnant_e2706404:

    # me "Я...не успел докурить."
    me "我……没来得及抽完。"

# game/a4/5fire_remnant.rpy:100
translate english fire_remnant_fbd09838:

    # isid "Жаль. Ну может мы позже покурим вместе?"
    isid "可惜了。那不如我们晚些时候一起抽？"

# game/a4/5fire_remnant.rpy:101
translate english fire_remnant_bcbc5c5a:

    # me "Ага. Обязательно."
    me "唔。一定。"

# game/a4/5fire_remnant.rpy:102
translate english fire_remnant_fa1f1946:

    # isid "Может даже втроем."
    isid "说不定还能三人行。"

# game/a4/5fire_remnant.rpy:103
translate english fire_remnant_3cb23884:

    # me "А? В каком смысле?"
    me "嗯？什么意思？"

# game/a4/5fire_remnant.rpy:104
translate english fire_remnant_d09a4e49:

    # isid "Ни в каком. Пойдем уже, принц, мне не терпится оценить этот чудесный город."
    isid "没什么意思。我们走吧，殿下，我迫不及待想好好看看这座迷人的城市了。"

# game/a4/5fire_remnant.rpy:108
translate english fire_remnant2_30f3483a:

    # isid "Здесь...немноголюдно."
    isid "这儿……人真少。"

# game/a4/5fire_remnant.rpy:109
translate english fire_remnant2_834824dc:

    # me "А чего вы ожидали?"
    me "您本来期待什么？"

# game/a4/5fire_remnant.rpy:111
translate english fire_remnant2_5b57666f:

    # isid "Дворец моего отца стоит в Карате, днем, на рыночной площади, там так много людей, что не протолкнуться."
    isid "我父亲在王都的宫殿，白天的时候，市场广场上挤满了人，水泄不通。"

# game/a4/5fire_remnant.rpy:112
translate english fire_remnant2_5fcf4596:

    # me "Это верхний город. Здесь живут только знатные люди, поэтому здесь немноголюдно."
    me "这是上城区。住的都是贵族，所以人不多。"

# game/a4/5fire_remnant.rpy:113
translate english fire_remnant2_ce805e31:

    # isid "Хм...интересно."
    isid "嗯……有意思。"

# game/a4/5fire_remnant.rpy:114
translate english fire_remnant2_86efe32f:

    # me "На Юге такого нет?"
    me "南方没有这种地方？"

# game/a4/5fire_remnant.rpy:115
translate english fire_remnant2_9c29968e:

    # isid "На Юге есть только клан, все его члены живут во дворце, все остальные это простолюдины или еще хуже."
    isid "南方只有氏族，氏族所有成员都住在宫殿里，剩下的全是平民，甚至更卑贱。"

# game/a4/5fire_remnant.rpy:116
translate english fire_remnant2_ff660617:

    # me "На Юге совсем нет знати?"
    me "南方完全没有贵族吗？"

# game/a4/5fire_remnant.rpy:118
translate english fire_remnant2_0187eab3:

    # isid "Есть, но их положение не дает им никаких дополнительных прав. Обычно это просто богатые люди."
    isid "有，但他们的地位并不赋予他们任何额外的权利。通常不过是些富人罢了。"

# game/a4/5fire_remnant.rpy:119
translate english fire_remnant2_8493757f:

    # me "А как же другие кланы?"
    me "那其他氏族呢？"

# game/a4/5fire_remnant.rpy:120
translate english fire_remnant2_71fd29dc:

    # isid "Всем управляет один клан."
    isid "所有事务都由一个氏族掌管。"

# game/a4/5fire_remnant.rpy:121
translate english fire_remnant2_9a4ff272:

    # me "Всеми городами и землями?"
    me "所有的城市和土地都归一个氏族管？"

# game/a4/5fire_remnant.rpy:122
translate english fire_remnant2_914ba7c8:

    # isid "У меня сотни братьев, сестер, дядь, теть, племянников, племянниц...."
    isid "我有数百个兄弟姐妹、叔伯阿姨、侄子侄女……"

# game/a4/5fire_remnant.rpy:123
translate english fire_remnant2_16c7bbe9:

    # me "И что же... у вас совсем нет вассалов?"
    me "那你们……就完全没有封臣咯？"

# game/a4/5fire_remnant.rpy:125
translate english fire_remnant2_50d8f83b:

    # isid "Есть. Но над ними всегда есть управляющий из нашего клана."
    isid "有。但他们头上总有一个我们氏族的管理者。"

# game/a4/5fire_remnant.rpy:126
translate english fire_remnant2_8be0704c:

    # me "А я думал на Юге множество кланов."
    me "我还以为南方有很多氏族呢。"

# game/a4/5fire_remnant.rpy:127
translate english fire_remnant2_4e68c190:

    # isid "Так и есть. Просто они действуют скрытно. Наш клан долго был в подчинении..."
    isid "确实如此。只不过他们行事隐蔽。我们氏族也臣服了很长一段时间……"

# game/a4/5fire_remnant.rpy:128
translate english fire_remnant2_511310db:

    # me "Но?"
    me "但是？"

# game/a4/5fire_remnant.rpy:129
translate english fire_remnant2_df7bf708:

    # isid "Но то смутное время закончилось. Теперь другим кланам нужно прятаться, как крысам или целовать наши ноги."
    isid "但是那段黑暗混乱的岁月结束了。现在，轮到其他氏族像老鼠一样躲躲藏藏，或者来跪在我们脚下。"

# game/a4/5fire_remnant.rpy:131
translate english fire_remnant2_0371263c:

    # me "Ваша система куда более...иерархична."
    me "你们的体制远比我们的……等级森严。"

# game/a4/5fire_remnant.rpy:132
translate english fire_remnant2_e1e929b6:

    # isid "Ничего подобного, мы делим власть внутри клана, а у вас всем заправляет король."
    isid "才不是，我们是在氏族内部瓜分权力，而你们一切由国王说了算。"

# game/a4/5fire_remnant.rpy:133
translate english fire_remnant2_af75999a:

    # me "У короля есть совет и вассалы..."
    me "国王有议会和封臣……"

# game/a4/5fire_remnant.rpy:134
translate english fire_remnant2_c4b7c428:

    # isid "Да ладно. А люди вне дворца об этом знают?"
    isid "省省吧。宫墙外的人知道这些吗？"

# game/a4/5fire_remnant.rpy:135
translate russian fire_remnant2_d10af51e:

    # me "Ну конечно."
    me "当然知道。"

# game/a4/5fire_remnant.rpy:137
translate russian fire_remnant2_cc472e47:

    # isid "Простите, не поможете нам?"
    isid "打扰一下，能请您帮个忙吗？"

# game/a4/5fire_remnant.rpy:138
translate russian fire_remnant2_d5b278bc:

    # gorozw "А?"
    gorozw "啊？"

# game/a4/5fire_remnant.rpy:139
translate russian fire_remnant2_af35bf33:

    # isid "Ответьте на один вопрос."
    isid "请回答一个问题。"

# game/a4/5fire_remnant.rpy:140
translate russian fire_remnant2_9bd35864:

    # gorozw "Какой вопрос?"
    gorozw "什么问题？"

# game/a4/5fire_remnant.rpy:142
translate russian fire_remnant2_af69545b:

    # isid "Вы узнаете этого человека?"
    isid "您认识这个人吗？"

# game/a4/5fire_remnant.rpy:143
translate russian fire_remnant2_83b8afa5:

    # gorozw "Вы спрашиваете как его зовут или..."
    gorozw "您是指问他叫什么名字，还是……"

# game/a4/5fire_remnant.rpy:144
translate russian fire_remnant2_b5a29a1a:

    # isid "Неважно. Имя, статус, что угодно."
    isid "都无所谓。名字、地位，什么都行。"

# game/a4/5fire_remnant.rpy:146
translate russian fire_remnant2_35a2d0fc:

    # gorozw "Хм...Наверное военный..."
    gorozw "嗯……大概是个军人吧……"

# game/a4/5fire_remnant.rpy:147
translate russian fire_remnant2_45120717:

    # isid "Вы не знаете кто это?"
    isid "您不知道他是谁？"

# game/a4/5fire_remnant.rpy:148
translate russian fire_remnant2_df5ccbba:

    # gorozw "Аааа! Я кажется видела вас в театре. Комедия 'На Юг и обратно.'"
    gorozw "啊啊！我好像……在剧院见过您。那个喜剧，《南下又北归》。"

# game/a4/5fire_remnant.rpy:150
translate russian fire_remnant2_50c7a82a:

    # isid "Да-да. Точно!"
    isid "对对。没错！"

# game/a4/5fire_remnant.rpy:151
translate russian fire_remnant2_ad02f53a:

    # me "Что?"
    me "什么？"

# game/a4/5fire_remnant.rpy:152
translate russian fire_remnant2_19fdba5b:

    # gorozw "Вы играете молодого путешественника, вы еще так смешно падаете во втором акте!"
    gorozw "您演那个年轻的旅行者，在第二幕里您摔倒的样子特别滑稽！"

# game/a4/5fire_remnant.rpy:153
translate russian fire_remnant2_98eaa5b8:

    # isid "Ахахахаха."
    isid "哈哈哈哈。"

# game/a4/5fire_remnant.rpy:154
translate russian fire_remnant2_eed0c7b2:

    # me "Присмотритесь получше...мои уши...волосы..."
    me "您再仔细看看……我的耳朵……头发……"

# game/a4/5fire_remnant.rpy:155
translate russian fire_remnant2_434a5f70:

    # isid "Да. Может он и в другой комедии играл?"
    isid "是啊。也许他还在别的喜剧里演过？"

# game/a4/5fire_remnant.rpy:156
translate russian fire_remnant2_0a34494d:

    # me "Может я чей-то сын..."
    me "也许我是谁的儿子……"

# game/a4/5fire_remnant.rpy:158
translate russian fire_remnant2_84c596ba:

    # gorozw "Ох, простите меня великодушно, принц. Я вас не признала!"
    gorozw "啊，万分抱歉，殿下。我竟然没认出您来！"

# game/a4/5fire_remnant.rpy:159
translate russian fire_remnant2_7937338c:

    # gorozw "Пусть воля вашего отца будет железом. Пусть золотой закон будет вечен."
    gorozw "愿您父亲的意志坚如钢铁。愿黄金律法万古长存。"

# game/a4/5fire_remnant.rpy:161
translate russian fire_remnant2_d19497e2:

    # me "Ну вот видишь..."
    me "喏，你看……"

# game/a4/5fire_remnant.rpy:162
translate russian fire_remnant2_62571f84:

    # isid "Так нечестно, ты ей подсказал."
    isid "这不公平，你刚才提示她了。"

# game/a4/5fire_remnant.rpy:163
translate russian fire_remnant2_d2c97ebf:

    # me "Меня не было в городе десять лет, чего ты хотела? Чтобы меня все узнавали в лицо?"
    me "我离开了这座城市十年，你指望什么？所有人在街上都能认出我来？"

# game/a4/5fire_remnant.rpy:164
translate russian fire_remnant2_3141fbb8:

    # isid "Ну надо же..."
    isid "这还真没想到……"

# game/a4/5fire_remnant.rpy:165
translate russian fire_remnant2_4537b821:

    # me "Выходит наша система не хуже вашей."
    me "看来我们的体制也不比你们差。"

# game/a4/5fire_remnant.rpy:167
translate russian fire_remnant2_ee9f04f6:

    # isid "Ну это знать, а ты наследный принц, с очень выделяющимися отличительными признаками. Что насчет черни?"
    isid "但那是贵族，你可是王储，有着极其显眼的特征。普通民众呢？"

# game/a4/5fire_remnant.rpy:168
translate russian fire_remnant2_c74dc4a8:

    # me "А что насчет нее?"
    me "普通民众又怎么了？"

# game/a4/5fire_remnant.rpy:169
translate russian fire_remnant2_6f445266:

    # isid "Они тебя узнают?"
    isid "他们能认出你吗？"

# game/a4/5fire_remnant.rpy:170
translate russian fire_remnant2_b9290f5e:

    # me "Я не особо хочу проверять."
    me "我不太想去验证。"

# game/a4/5fire_remnant.rpy:171
translate russian fire_remnant2_e41fec56:

    # isid "Да ладно. Почему же? Они не признаю тебя даже если ты покажешь им свои уши и волосы?"
    isid "别这样。为什么不呢？就算你把耳朵和头发亮给他们看，他们也认不出你？"

# game/a4/5fire_remnant.rpy:172
translate russian fire_remnant2_c115f832:

    # me "Ты хочешь поспорить?"
    me "你想打赌？"

# game/a4/5fire_remnant.rpy:174
translate russian fire_remnant2_c7b3b7e5:

    # me "Мы хотим отправиться в нижний город."
    me "我们想下去逛逛平民肉眼。"

# game/a4/5fire_remnant.rpy:175
translate russian fire_remnant2_2755c8fb:

    # conrad "Что? Зачем?"
    conrad "什么？为什么？"

# game/a4/5fire_remnant.rpy:176
translate russian fire_remnant2_96bcdc78:

    # isid "Хотим кое-что проверить."
    isid "我们想验证点事。"

# game/a4/5fire_remnant.rpy:177
translate russian fire_remnant2_2d42945b:

    # me "Ага."
    me "哦。"

# game/a4/5fire_remnant.rpy:178
translate russian fire_remnant2_078a549b:

    # conrad "Мы туда не пойдем. Там опасно."
    conrad "我们不去那儿，太危险了。"

# game/a4/5fire_remnant.rpy:179
translate russian fire_remnant2_097cfc40:

    # isid "Разве ты здесь отдаешь приказы? Ты слышал своего принца."
    isid "难道这儿轮到你下令吗？听见你殿下的吩咐了吧。"

# game/a4/5fire_remnant.rpy:180
translate russian fire_remnant2_a3e5bbba:

    # conrad "Во-первых - я ему не раб, во-вторых - принц и сам знает, что туда не стоит идти без дополнительной охраны. Хотя бы человек тридцать."
    conrad "首先，我不是他的奴隶，其次，殿下自己也知道，没有额外护卫不该去那种地方。至少得带三十个人。"

# game/a4/5fire_remnant.rpy:181
translate russian fire_remnant2_70880e72:

    # isid "Эх. Ладно. Забудьте. А есть тут места куда можно пойти вообще без охраны? Я, например, хочу посмотреть на ваши храмы безымянным богам."
    isid "唉。行。算了吧。那有没有什么地方是可以完全不带护卫去的？比如，我想看看你们那些供奉无名诸神的神庙。"

# game/a4/5fire_remnant.rpy:182
translate russian fire_remnant2_2839e865:

    # conrad "Они все за городом, парочка есть в королевских угодьях к северу."
    conrad "他们都在城外，有几座在北边的王家猎场里。"

# game/a4/5fire_remnant.rpy:183
translate russian fire_remnant2_d7c850b2:

    # isid "Туда можно без охраны?"
    isid "那儿能不带护卫去吗？"

# game/a4/5fire_remnant.rpy:184
translate russian fire_remnant2_88be50f7:

    # conrad "Можно. Только переоденьтесь во что-то попроще, чтобы не привлекать внимание."
    conrad "可以。不过得换身朴素点的衣服，免得招人耳目。"

# game/a4/5fire_remnant.rpy:189
translate russian fire_remnant3_396c128f:

    # "Час спустя."
    "一个小时以后。"

# game/a4/5fire_remnant.rpy:190
translate russian fire_remnant3_2ddde644:

    # isid "Надо сказать ваша одежда очень даже удобная."
    isid "不得不说，你们的衣服穿着还挺舒服的。"

# game/a4/5fire_remnant.rpy:191
translate russian fire_remnant3_489a247d:

    # me "Правда?"
    me "真的？"

# game/a4/5fire_remnant.rpy:193
translate russian fire_remnant3_65eab1c2:

    # isid "Правда. Только материал грубоват."
    isid "真的。只是面料有些粗硬。"

# game/a4/5fire_remnant.rpy:194
translate russian fire_remnant3_c0065120:

    # me "Ну...шелка производят на Юге. Здесь с тканью попроще."
    me "唔……丝绸是在南方生产的。我们这边的布料就相对简陋些。"

# game/a4/5fire_remnant.rpy:195
translate russian fire_remnant3_7c617b94:

    # isid "А как же тот шелк, что привозят кораблями с востока?"
    isid "那那些从东方船运来的丝绸呢？"

# game/a4/5fire_remnant.rpy:196
translate russian fire_remnant3_3b122c52:

    # me "С востока? Я об этом не знал."
    me "东方？这我从未听说过。"

# game/a4/5fire_remnant.rpy:197
translate russian fire_remnant3_85f53c36:

    # isid "..."
    isid "..."

# game/a4/5fire_remnant.rpy:198
translate russian fire_remnant3_fee2b737:

    # me "В свое оправдание могу сказать, что я последние десять лет провел в городе, где в порт привозят только руду и рыбу."
    me "我得自我辩护一下，过去十年我一直待在一个港口只运来矿石和鱼的城市里。"

# game/a4/5fire_remnant.rpy:199
translate russian fire_remnant3_dbe4825d:

    # isid "Здесь совсем нет людей."
    isid "这里空无一人啊。"

# game/a4/5fire_remnant.rpy:200
translate russian fire_remnant3_8584fee4:

    # me "А чего ты ожидала?"
    me "那你还期待什么？"

# game/a4/5fire_remnant.rpy:202
translate russian fire_remnant3_5d98f90f:

    # isid "В храмах Юга народ толпится и днем и ночью."
    isid "在南方的神庙里，无论白天黑夜都挤满了人。"

# game/a4/5fire_remnant.rpy:203
translate russian fire_remnant3_ee2f6176:

    # me "Верование в безымянных богов отличается от верования Юга. У нас нет ни храмов ни священников, только алтари."
    me "我们对无名众神的信仰和南方不同。我们没有神殿也没有祭司，只有祭坛。"

# game/a4/5fire_remnant.rpy:205
translate russian fire_remnant3_b6781753:

    # isid "И никакого внутреннего убранства в алтарях тоже нет."
    isid "祭坛里也完全没有内部陈设。"

# game/a4/5fire_remnant.rpy:206
translate russian fire_remnant3_5656a1f6:

    # me "Это проистекает из веры. Какой смысл в предметах, если боги могут быть в чем угодно?"
    me "这源于信仰本身。如果神明可以存在于任何事物中，那摆放物品又有什么意义呢？"

# game/a4/5fire_remnant.rpy:207
translate russian fire_remnant3_af20cfb7:

    # me "На самом деле даже эти алтари это некоторое наследие слияния с эльфийской культурой этих мест. Люди молятся где угодно."
    me "其实，就连这些祭坛也是与当地精灵文化融合后留下的传统。人们可以在任何地方祈祷。"

# game/a4/5fire_remnant.rpy:208
translate russian fire_remnant3_0e0d4359:

    # isid "Неужели у вас вообще нет никакого символа веры?"
    isid "难道你们就完全没有信仰的象征物吗？"

# game/a4/5fire_remnant.rpy:209
translate russian fire_remnant3_cf1932dd:

    # me "Он может быть каким угодно. Счастливая монета, бабушкино ожерелье, камень с дороги - божественное присутствие можно ощутить в чем угодно."
    me "任何东西都可以是。一枚幸运钱币、祖母留下的项链、路边的一块石头——随处都能感受到神性的存在。"

# game/a4/5fire_remnant.rpy:211
translate russian fire_remnant3_0c8ff9e7:

    # meg_b "Верно, а еще боги могут явится нам в виде случайной встречи."
    meg_b "没错，神明也会以偶遇的形式出现在我们面前。"

# game/a4/5fire_remnant.rpy:212
translate english fire_remnant3_bb71c08a:

    # me "Верно. Но только если эта встреча действительно случайна."
    me "的确。但前提是，这次相遇真的是偶然。"

# game/a4/5fire_remnant.rpy:213
translate english fire_remnant3_f0a1b0ea:

    # meg_b "Ну...ты никогда не знаешь, случайная ли это встреча или безымянные боги проверяют тебя."
    meg_b "唔……你永远不知道，这究竟是偶然的相遇，还是无名众神在考验你。"

# game/a4/5fire_remnant.rpy:214
translate english fire_remnant3_87ece843:

    # isid "Кто это?"
    isid "这是谁？"

# game/a4/5fire_remnant.rpy:216
translate english fire_remnant3_9e425072:

    # me "Попрошайка. Они ошиваются в таких местах, надеясь на то, что верующие примут их за божественно проявление."
    me "一个乞丐。他们总在这种地方转悠，指望信众把他们当作神明的显化。"

# game/a4/5fire_remnant.rpy:217
translate english fire_remnant3_6b208bd0:

    # meg "Эй! Я не попрошайка! Я Мэг."
    meg "嘿！我可不是乞丐！我是梅格。"

# game/a4/5fire_remnant.rpy:218
translate english fire_remnant3_636eaf1e:

    # isid "И что же ты тут делаешь, Мэг?"
    isid "那你在干什么呢，梅格？"

# game/a4/5fire_remnant.rpy:220
translate english fire_remnant3_729285f3:

    # meg "Я живу здесь неподалеку. Живу очень бедно, так что я бы не отказалась от помощи. Например от монеты."
    meg "我就住在附近。生活非常贫困，所以不拒绝任何帮助。比如给枚硬币什么的。"

# game/a4/5fire_remnant.rpy:221
translate english fire_remnant3_9fcaa7a3:

    # me "Я же говорил."
    me "我就说吧。"

# game/a4/5fire_remnant.rpy:222
translate english fire_remnant3_ca4858e5:

    # meg "Вдруг это проверка богов? Никогда не знаешь, верно? Откажешься и тебя будут ждать сто лет неудач."
    meg "万一这是神明的考验呢？谁说得准呢，对吧？你拒绝了，搞不好会倒上百年霉运。"

# game/a4/5fire_remnant.rpy:223
translate english fire_remnant3_77e3084f:

    # isid "Сто лет это серьезный срок, я бы задумалась."
    isid "百年可是很长的时间，真得好好考虑一下。"

# game/a4/5fire_remnant.rpy:224
translate english fire_remnant3_26ab3635:

    # meg "Вот-вот. Одна маленькая монетка того не стоит."
    meg "就是就是。为这点小事搭上一枚小钱可不值。"

# game/a4/5fire_remnant.rpy:225
translate english fire_remnant3_94ca498f:

    # isid "[mename]?"
    isid "[mename]?"

# game/a4/5fire_remnant.rpy:230
translate english fire_remnant3_86b2fd6c:

    # me "Держи, хитрюга."
    me "拿着吧，小骗子。"

# game/a4/5fire_remnant.rpy:231
translate english fire_remnant3_ea5c20ee:

    # meg "Спасибо!"
    meg "谢谢！"

# game/a4/5fire_remnant.rpy:233
translate english fire_remnant3_291100a6:

    # meg "Золото!? Это золотая монета?"
    meg "金币！？这是金币吗？"

# game/a4/5fire_remnant.rpy:234
translate english fire_remnant3_0c18ba3b:

    # me "Ага. Не потеряй и сможешь месяц хорошо питаться."
    me "没错。可别弄丢了，足够你一个月好好吃饭的了。"

# game/a4/5fire_remnant.rpy:235
translate english fire_remnant3_0bf7e6b7:

    # meg "Вау...я никогда раньше такую в руках не держала...Спасибо!"
    meg "哇……我这辈子还没亲手拿过金币呢……谢谢！"

# game/a4/5fire_remnant.rpy:236
translate english fire_remnant3_b640fc23:

    # me "Больше не дам, а теперь сваливай, я хочу поговорить с дамой без лишних ушей."
    me "不会再给了，现在快走开，我想跟这位女士说话，不想有旁人打扰。"

# game/a4/5fire_remnant.rpy:237
translate english fire_remnant3_f90bbaf4:

    # meg "Уже ухожу!"
    meg "我这就走！"

# game/a4/5fire_remnant.rpy:239
translate english fire_remnant3_1765fd39:

    # isid "У богов в ее лице сегодня хороший день, да?"
    isid "今天以她面孔出现的神明运气不错啊，是吧？"

# game/a4/5fire_remnant.rpy:240
translate english fire_remnant3_db1b1123:

    # me "Ага. Надеюсь они вернут мне хотя бы сотню."
    me "没错。希望他们能还给我至少一百倍。"

# game/a4/5fire_remnant.rpy:241
translate english fire_remnant3_5cd1bc71:

    # isid "Сотню попрошаек."
    isid "一百个乞丐？"

# game/a4/5fire_remnant.rpy:242
translate english fire_remnant3_6a2f6e68:

    # me "Я бы хотел сотню монет, но зная благосклонность богов к моей судьбе, твой вариант кажется более вероятным."
    me "我倒是想要一百枚金币，但依神明对我命运的垂青程度来看，你说的那种情况听起来更有可能。"

# game/a4/5fire_remnant.rpy:245
translate english fire_remnant3_85203d26:

    # me "Много людей одурачила? Со мной не пройдет, проваливай!"
    me "骗了不少人吧？跟我可没门，滚开！"

# game/a4/5fire_remnant.rpy:246
translate english fire_remnant3_d9053a1d:

    # meg "Бе! Жадина! Боги тебя накажут!"
    meg "呸！小气鬼！神明会惩罚你的！"

# game/a4/5fire_remnant.rpy:247
translate english fire_remnant3_d13e10c9:

    # me "Ага. Буду ждать их кары каждый день."
    me "没错。我每天都在等着她们的惩罚降临呢。"

# game/a4/5fire_remnant.rpy:248
translate english fire_remnant3_cb1ea603:

    # meg "Долго ждать не придется."
    meg "你等不了多久的。"

# game/a4/5fire_remnant.rpy:249
translate english fire_remnant3_f51a0656:

    # me "Мне тебя выкинуть?"
    me "要我亲自动手把你扔出去吗？"

# game/a4/5fire_remnant.rpy:251
translate english fire_remnant3_a8ec0e16:

    # me "Думаешь слишком жестоко?"
    me "你不觉得太残忍了吗？"

# game/a4/5fire_remnant.rpy:252
translate english fire_remnant3_f48a4599:

    # isid "А? Нет. На Юге за попрошайничество бьют плетью."
    isid "什么？不。在南方，乞讨是要挨鞭子的。"

# game/a4/5fire_remnant.rpy:253
translate english fire_remnant3_79927447:

    # me "А чего задумалась?"
    me "那你在想什么？"

# game/a4/5fire_remnant.rpy:254
translate english fire_remnant3_79c2aee7:

    # isid "Да так...интересная концепция...ну эта....с проверкой богов. Интересно мой бог меня когда-нибудь проверял?"
    isid "没什么……挺有趣的概念……就是那种……神的考验。我在想我的神有没有考验过我？"

# game/a4/5fire_remnant.rpy:255
translate english fire_remnant3_5daa8d4d:

    # me "Каждый день с человек происходит сотня событий, если каждый раз думать о том, что это может быть проверка - рехнешься."
    me "一个人每天发生上百件事，如果每件事都觉得可能是考验，那可要疯了。"

# game/a4/5fire_remnant.rpy:257
translate english fire_remnant3_92c2ba65:

    # me "Боги, неведомые и безымянные свидетели моей жизни."
    me "冥冥无名、无处不在的神明，我生命历程的见证者。"

# game/a4/5fire_remnant.rpy:258
translate english fire_remnant3_38f9f118:

    # me "Явите мне свою волю, дайте знак и укажите путь."
    me "请你们向我显示旨意，赐我征兆，指明道路。"

# game/a4/5fire_remnant.rpy:259
translate english fire_remnant3_93dcd8e7:

    # me "Я обещаю все увидеть и понять."
    me "我承诺会洞悉所有，理解一切。"

# game/a4/5fire_remnant.rpy:261
translate english fire_remnant3_2890c585:

    # isid "Ты что делаешь?"
    isid "你在做什么？"

# game/a4/5fire_remnant.rpy:262
translate english fire_remnant3_2e06437a:

    # me "Вспоминаю как молился отец. А что? Выглядит смешно?"
    me "在回忆我父亲是如何祷告的。怎么？看起来很好笑吗？"

# game/a4/5fire_remnant.rpy:263
translate english fire_remnant3_c975c294:

    # isid "Нет, прости, просто это так сильно отличается от того, как мы делаем это на Юге."
    isid "不，抱歉，只是这跟我们在南方所做的完全不一样。"

# game/a4/5fire_remnant.rpy:264
translate english fire_remnant3_c8dc18c4:

    # me "Правда? Покажешь?"
    me "真的吗？能让我看看吗？"

# game/a4/5fire_remnant.rpy:265
translate english fire_remnant3_e7aeda97:

    # isid "Нам нельзя молиться вне храма."
    isid "我们不能在神殿之外祈祷。"

# game/a4/5fire_remnant.rpy:266
translate english fire_remnant3_c80727b7:

    # me "Хм...хочу однажды там побывать. На Юге."
    me "唔……真希望有一天能去那里看看。去南方。"

# game/a4/5fire_remnant.rpy:267
translate english fire_remnant3_d3e445f6:

    # isid "Тебе понравится."
    isid "你会喜欢的。"

# game/a4/5fire_remnant.rpy:268
translate english fire_remnant3_aab8518a:

    # me "Думаешь? Я слышал Юг это жестокое место."
    me "你这么觉得？我听说南方是个很残酷的地方。"

# game/a4/5fire_remnant.rpy:270
translate english fire_remnant3_5cb033ba:

    # isid "Везде свои порядки, [mename]. Вы считаете дикими и жестокими нас, а на Юге считают, что это место Kalantar dalla'h - страна бед."
    isid "每个地方都有各自的规矩，[mename]。你们认为我们野蛮残忍，而在南方，人们视Kalantar dalla'h为灾厄之地。"

# game/a4/5fire_remnant.rpy:271
translate english fire_remnant3_fa6792fd:

    # isid "Здесь родится Murrad Gar, разрушитель мира, с которого начнется апокалипсис. И все потому это место в котором нарушены все божественные порядки."
    isid "据说毁灭者将诞生于此，并由此开启末日天启。原因就在于这个地方违背了一切神圣的秩序。"

# game/a4/5fire_remnant.rpy:272
translate english fire_remnant3_a4834fa2:

    # me "И какие же божественные порядки мы нарушаем?"
    me "那我们违背了哪些神圣的秩序呢？"

# game/a4/5fire_remnant.rpy:273
translate english fire_remnant3_c6dd681f:

    # isid "Порядок мировых корней, вы не живете там, где рождены ваши предки, вы отняли эту землю у эльфов и живете поверх их гробниц."
    isid "世界根系的秩序，你们不住在先祖诞育之地，而是从精灵手中夺走了这片土地，居住在他们的坟墓之上。"

# game/a4/5fire_remnant.rpy:274
translate english fire_remnant3_dbffe5b3:

    # isid "Богоубийство - вы отняли имя у бога и расчленили его на тысячи кусков."
    isid "弑神之罪——你们剥夺了神的名，将其撕裂为千万碎片。"

# game/a4/5fire_remnant.rpy:275
translate english fire_remnant3_70a61592:

    # isid "Бурепоклонничество - вы позволяете магам творить их колдовство и даже учите их этому в башнях."
    isid "崇信风暴之罪——你们允许法师施展法术，甚至在塔楼中教授他们。"

# game/a4/5fire_remnant.rpy:276
translate english fire_remnant3_e7e82ab2:

    # isid "Мне продолжать?"
    isid "要我继续说吗？"

# game/a4/5fire_remnant.rpy:277
translate english fire_remnant3_63e0f427:

    # me "Если здесь так ужасно, зачем сюда приезжать?"
    me "如果这里如此可怕，为什么还要来这儿呢？"

# game/a4/5fire_remnant.rpy:278
translate english fire_remnant3_79407e17:

    # isid "Я же не говорю, что согласна со всем этим. Просто люди везде разные, а значит и понятия нормы везде свои."
    isid "我又没说赞同这一切。不过，人与人本是不同，所以对何为正常的观念也各自不同。"

# game/a4/5fire_remnant.rpy:279
translate english fire_remnant3_3d44cc50:

    # me "Это так... Ладно, пойдем отсюда, здесь больше не на что смотреть."
    me "确实如此……好了，咱们从这儿离开吧，没什么可看的了。"

# game/a4/5fire_remnant.rpy:281
translate english fire_remnant3_cb83f1c5:

    # me "Как тебе местная природа?"
    me "你觉得本地的自然风景怎么样？"

# game/a4/5fire_remnant.rpy:282
translate english fire_remnant3_a0a13df5:

    # isid "Отличается от южной, я никогда раньше не видела таких деревьев, даже в саду во во дворце."
    isid "跟南方大不一样，我从来没见过这样的树，即使在宫殿的花园里也没有。"

# game/a4/5fire_remnant.rpy:283
translate english fire_remnant3_2b788309:

    # me "Тебе это нравится?"
    me "你喜欢吗？"

# game/a4/5fire_remnant.rpy:284
translate english fire_remnant3_213d9901:

    # isid "Пожалуй. Только воздух здесь какой-то...сухой."
    isid "应该算是吧。只是这里的空气感觉有点……干燥。"

# game/a4/5fire_remnant.rpy:285
translate english fire_remnant3_29961fc8:

    # me "Ничего. Ты привыкнешь."
    me "没关系。你会习惯的。"

# game/a4/5fire_remnant.rpy:292
translate english fire_remnant_beg_e9f35e29:

    # meg "Вот. Это они."
    meg "看吧。就是他们。"

# game/a4/5fire_remnant.rpy:293
translate english fire_remnant_beg_bbeb2291:

    # woodc "Ты уверена?"
    woodc "你确定吗？"

# game/a4/5fire_remnant.rpy:294
translate english fire_remnant_beg_b00efc04:

    # meg "Да! Этот эльф дал мне золотую монету."
    meg "对！就是那个精灵给了我一枚金币。"

# game/a4/5fire_remnant.rpy:295
translate english fire_remnant_beg_3355d065:

    # me "Что-то мне это не нравится."
    me "这让我觉得不太舒服。"

# game/a4/5fire_remnant.rpy:297
translate english fire_remnant_beg_4f9ed49b:

    # woodc "Эльф и южанка. Интересно, что вы забыли в наших краях."
    woodc "一个精灵和一个南边来的女人。有意思，你们跑到我们的地盘来干什么。"

# game/a4/5fire_remnant.rpy:298
translate english fire_remnant_beg_7569d7ee:

    # isid "Просто гуляем."
    isid "就随便逛逛。"

# game/a4/5fire_remnant.rpy:299
translate english fire_remnant_beg_878f0b88:

    # woodc "Просто гуляете? Гуляете с золотыми монетами по лесу?"
    woodc "就随便逛逛？揣着金币在林子里逛逛？"

# game/a4/5fire_remnant.rpy:300
translate english fire_remnant_beg_bb686f7a:

    # me "Ну да."
    me "嗯哼。"

# game/a4/5fire_remnant.rpy:301
translate english fire_remnant_beg_4a993ac6:

    # woodc "В таком случае поделитесь ими со мной."
    woodc "既然这样，那不如分我一点金币吧？"

# game/a4/5fire_remnant.rpy:310
translate english fire_remnant_beg_5cc42a40:

    # me "{i}Хер тебе, а не мое золото.{/i}"
    me "{i}呸，这是我的金子，休想。{/i}"

# game/a4/5fire_remnant.rpy:311
translate english fire_remnant_beg_8a4d7c98:

    # woodc "И поторапливайтесь. А то у меня уже руки чешутся."
    woodc "利索点。我已经手痒痒了。"

# game/a4/5fire_remnant.rpy:312
translate english fire_remnant_beg_6df65773:

    # me "{size=-12}Tenmir...{/size}"
    me "{size=-12}Tenmir...{/size}"

# game/a4/5fire_remnant.rpy:314
translate english fire_remnant_beg_f785f3f4:

    # isid "Ты знаешь с кем говоришь?"
    isid "你知道你在跟谁说话吗？"

# game/a4/5fire_remnant.rpy:315
translate english fire_remnant_beg_91faf954:

    # woodc "С будущими трупами! Давайте золото или я вам черепа пробью топором!"
    woodc "跟未来的死尸！把金子交出来，不然我拿斧头劈了你们的脑袋！"

# game/a4/5fire_remnant.rpy:316
translate english fire_remnant_beg_202544b1:

    # me "{size=-12}Tenmir uppta...{/size}"
    me "{size=-12}Tenmir uppta...{/size}"

# game/a4/5fire_remnant.rpy:317
translate english fire_remnant_beg_136e280e:

    # me "{size=-12}Tenmir...uppta...{/size}"
    me "{size=-12}Tenmir...uppta...{/size}"

# game/a4/5fire_remnant.rpy:318
translate english fire_remnant_beg_7ef0320d:

    # woodc "Я что? Непонятно говорю? Сейчас я..."
    woodc "怎么？我说话还不清楚吗？看我不……"

# game/a4/5fire_remnant.rpy:320
translate english fire_remnant_beg_967e5e20:

    # woodc "{size=+12}БЛЯДЬ! СУКА!{/size}"
    woodc "{size=+12}操！妈的！{/size}"

# game/a4/5fire_remnant.rpy:321
translate english fire_remnant_beg_023a1573:

    # meg "{size=+12}Папа!{/size}"
    meg "{size=+12}爸！{/size}"

# game/a4/5fire_remnant.rpy:323
translate english fire_remnant_beg_08b7e592:

    # woodc "{size=+12}ЕБАНЫЙ В РОТ! ПОМОГИТЕ!{/size}"
    woodc "{size=+12}我操！救命啊！{/size}"

# game/a4/5fire_remnant.rpy:324
translate english fire_remnant_beg_b8188a9f:

    # isid "Как ты это сделал? Магия?"
    isid "你怎么做到的？是魔法吗？"

# game/a4/5fire_remnant.rpy:325
translate english fire_remnant_beg_2d42945b:

    # me "Ага."
    me "嗯哼。"

# game/a4/5fire_remnant.rpy:326
translate english fire_remnant_beg_4cce06b7:

    # isid "Ну теперь тебе решать его судьбу."
    isid "好了，现在这人就交给你处置了。"

# game/a4/5fire_remnant.rpy:327
translate english fire_remnant_beg_5704fc52:

    # woodc "{size=+12}СУЧЬЕ ВЫМЯ!{/size}"
    woodc "{size=+12}你这婊子养的！{/size}"

# game/a4/5fire_remnant.rpy:328
translate english fire_remnant_beg_a6ae5746:

    # me "Как думаешь, что с ним сделать?"
    me "你觉得该拿他怎么办？"

# game/a4/5fire_remnant.rpy:329
translate english fire_remnant_beg_e72a0347:

    # isid "Он пытался ограбить королевских особ, угрожал нам топором, на Юге за такое отрезают голову."
    isid "他试图抢劫皇室成员，用斧子威胁我们，在南方，这可是要掉脑袋的。"

# game/a4/5fire_remnant.rpy:334
translate english fire_remnant_beg_8c801c1d:

    # me "Королевская стража будет недовольна попыткой ограбления прямо у них под носом."
    me "皇家守卫要是知道眼皮底下发生这种抢劫未遂的事，肯定不会高兴的。"

# game/a4/5fire_remnant.rpy:335
translate english fire_remnant_beg_29d3d7b6:

    # woodc "Где?"
    woodc "在哪儿？"

# game/a4/5fire_remnant.rpy:337
translate english fire_remnant_beg_186672c8:

    # woodc "{size=+12}БЛЯДЬ!{/size}"
    woodc "{size=+12}妈的！{/size}"

# game/a4/5fire_remnant.rpy:338
translate english fire_remnant_beg_f0371383:

    # meg "{size=+12}ПАПА!{/size}"
    meg "{size=+12}爸！{/size}"

# game/a4/5fire_remnant.rpy:340
translate english fire_remnant_beg_16259504:

    # me "{size=+12}ТЫ У КОГО ВЫМОГАЕШЬ ЗОЛОТО ХОТЬ ЗНАЕШЬ, ТЫ, КУСОК ГОВНА!?{/size}"
    me "{size=+12}你知不知道自己在向谁勒索金子，你这坨狗屎！？{/size}"

# game/a4/5fire_remnant.rpy:341
