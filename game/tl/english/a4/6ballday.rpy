    # me "А когда, собственно говоря эти самые танцы начнутся?"
    me "那这些舞蹈到底什么时候开始？"

# game/a4/6ballday.rpy:226
translate english ballday3_50f2b578:

    # mom "Чуть попозже. Пойди пока поговори с кем-нибудь."
    mom "再等一会儿。先去和谁聊聊天吧。"

# game/a4/6ballday.rpy:227
translate english ballday3_01822020:

    # me "Ладно."
    me "好的。"

# game/a4/6ballday.rpy:231
translate english ballday3_6b335e90:

    # me "Привет, Людвиг."
    me "嗨，Ludwig。"

# game/a4/6ballday.rpy:232
translate english ballday3_751bbc5c:

    # ludwig "Ох! [mename], мальчик мой! Ты все таки пришел."
    ludwig "噢！[mename]，我的孩子！你还是来了。"

# game/a4/6ballday.rpy:233
translate english ballday3_02bfd520:

    # me "Ну да. Прошел ускоренное обучение танцам и пришел."
    me "是啊。刚上完舞蹈速成课就来了。"

# game/a4/6ballday.rpy:234
translate english ballday3_9e91096d:

    # ludwig "Знакомься, слева от тебя - Амалия, дочь графа Валруса. Справа - Дороти, дочь Арно, Герцога Аранского."
    ludwig "来认识一下，你左边这位是阿玛莉亚，瓦尔鲁斯伯爵的女儿。右边是多萝西，阿兰公爵阿尔诺的女儿。"

# game/a4/6ballday.rpy:235
translate english ballday3_938e4bab:

    # doroty "Приятно познакомится, принц."
    doroty "很荣幸认识您，王子殿下。"

# game/a4/6ballday.rpy:236
translate english ballday3_08941f29:

    # amalia "А это правда, что о вас говорят?"
    amalia "关于您的那些传闻是真的吗？"

# game/a4/6ballday.rpy:238
translate english ballday3_bf173fab:

    # me "А что обо мне говорят?"
    me "关于我，都传了些什么？"

# game/a4/6ballday.rpy:239
translate english ballday3_e57a17be:

    # ludwig "Девочки не надо надоедать принцу..."
    ludwig "姑娘们，别烦扰王子殿下……"

# game/a4/6ballday.rpy:240
translate english ballday3_85b6a4a1:

    # me "Нет, мне интересно, что про меня говорят."
    me "不，我很好奇，他们说我什么了。"

# game/a4/6ballday.rpy:241
translate english ballday3_11aa082b:

    # doroty "Про ваши приключения."
    doroty "关于您的冒险故事。"

# game/a4/6ballday.rpy:242
translate english ballday3_8654483c:

    # amalia "Вы действительно видели дракона в гномьих горах?"
    amalia "您真的在矮人山脉见到过龙吗？"

# game/a4/6ballday.rpy:243
translate english ballday3_85fc61b8:

    # me "Дракона? Кто вам такое..."
    me "龙？谁跟你们说的……"

# game/a4/6ballday.rpy:244
translate english ballday3_9e55f7b5:

    # ludwig "Кхм-кхм."
    ludwig "咳咳。"

# game/a4/6ballday.rpy:245
translate english ballday3_5d297e6b:

    # me "{i}Ludwig, старый пройдоха, решил заинтересовать молодых девочек небылицами? Ха-ха. А ты сложнее, чем кажешься.{/i}"
    me "{i}Ludwig，你这老滑头，是打算用瞎编的故事来吸引小姑娘吗？哈哈。你比看起来要复杂得多啊。{/i}"

# game/a4/6ballday.rpy:247
translate english ballday3_ecea0254:

    # me "Это правда. Он был не такой большой, как о них пишут в книгах, но вполне мог бы сожрать за раз корову."
    me "是真的。那条龙没有书上写的那么大，但一口吞下一头牛是绰绰有余的。"

# game/a4/6ballday.rpy:248
translate english ballday3_02ecc211:

    # doroty "Вау! Потрясающе!"
    doroty "哇！太惊人了！"

# game/a4/6ballday.rpy:249
translate english ballday3_d012f1fd:

    # amalia "Людвиг говорит вы вместе пытались добыть его зуб."
    amalia "Ludwig说你们曾一起试图弄到它的牙齿。"

# game/a4/6ballday.rpy:250
translate english ballday3_df4acd0d:

    # me "{i}Alright, I won't blatantly interrupt his lying to these poor girls.{/i}"
    me "{i}Alright, не буду мешать ему нагло врать этим бедняжкам.{/i}"

# game/a4/6ballday.rpy:251
translate english ballday3_a4e66e2e:

    # me "Я был пьян почти всю дорогу, Людвиг лучше помнит эту историю, а я, прошу меня простить, должен отойти."
    me "我几乎一整路都醉醺醺的，Ludwig更记得这个故事，而，请恕我失陪一下。"

# game/a4/6ballday.rpy:252
translate english ballday3_4a1fa5a6:

    # ludwig "Все верно, я расскажу, что было дальше. "
    ludwig "没错，我来讲后来发生了什么。"

# game/a4/6ballday.rpy:255
translate english ballday3_07e83b7e:

    # me "Привет королевскому совету."
    me "向御前会议成员们问好。"

# game/a4/6ballday.rpy:256
translate english ballday3_3fda4290:

    # arcadia "Ох, [mename]! И ты здесь."
    arcadia "噢，[mename]！你也在这儿啊。"

# game/a4/6ballday.rpy:257
translate english ballday3_847d3d64:

    # calah "Конечно он здесь, это бал в его честь."
    calah "他当然在这儿，这舞会可是为他举办的。"

# game/a4/6ballday.rpy:258
translate english ballday3_489a247d:

    # me "Правда?"
    me "真的吗？"

# game/a4/6ballday.rpy:259
translate english ballday3_eec0178b:

    # calah "Ну почти. В честь будущей королевской свадьбы. Но если мне не изменяет память у короля только один подходящий кандидат на эту позицию."
    calah "差不多吧。是为即将到来的王室婚礼举办的。不过，如果我没记错的话，国王陛下身边够资格的人选就只有一位。"

# game/a4/6ballday.rpy:260
translate english ballday3_87024532:

    # arcadia "Кажется [elin] тоже будет выходить замуж."
    arcadia "好像[elin]也要嫁人了。"

# game/a4/6ballday.rpy:261
translate english ballday3_2d42945b:

    # me "Ага."
    me "是啊。"

# game/a4/6ballday.rpy:262
translate english ballday3_b5bd9c67:

    # calah "Да ладно. Нас ждет двойная свадьба? Давненько я такого не видал."
    calah "不是吧。我们要迎来两场婚礼？我好久没见过这种场面了。"

# game/a4/6ballday.rpy:263
translate english ballday3_8e52bd63:

    # arcadia "Давненько? Последний раз такое было до нашего рождения."
    arcadia "好久？上一次发生这种事远在我们出生之前呢。"

# game/a4/6ballday.rpy:264
translate english ballday3_8b4f2299:

    # calah "Правда? Ну тогда тем более нас ждет грандиозное событие."
    calah "真的吗？那我们就更是要见证一场盛事啦。"

# game/a4/6ballday.rpy:266
translate english ballday3_e73a4b31:

    # me "Вы давно пришли?"
    me "你们来了很久了吗？"

# game/a4/6ballday.rpy:267
translate english ballday3_3001d456:

    # arcadia "Давно. Старые люди по типу меня и немощные по типу Калахана приходят на балы выпить аранского золотого, да посплетничать."
    arcadia "很久了。像我这样的老人和像Callahan那样身子骨不行的，来舞会就是为了喝点阿兰黄金，再聊聊闲话。"

# game/a4/6ballday.rpy:268
translate english ballday3_d49a9dbb:

    # calah "Это с чего я немощный? Я еще огого!"
    calah "谁说我身子骨不行了？我还能大战三百回合呢！"

# game/a4/6ballday.rpy:269
translate english ballday3_78fa86b9:

    # me "Будете танцевать?"
    me "你们打算跳舞吗？"

# game/a4/6ballday.rpy:270
translate english ballday3_6d57eba8:

    # calah "Ни в коем случае. Это может навредить моему запланированному употреблению вина."
    calah "绝不。那会影响到我计划好的饮酒大业。"

# game/a4/6ballday.rpy:271
translate english ballday3_675fb56a:

    # arcadia "Я в этих планах есть?"
    arcadia "这个计划里有我吗？"

# game/a4/6ballday.rpy:272
translate english ballday3_64ea439a:

    # calah "Обижаешь, ты там первым пунктом, подруга. Основной потребитель наравне со мной."
    calah "你这是什么话，你可是头号重点，朋友。和我平起平坐的主力。"

# game/a4/6ballday.rpy:274
translate english ballday3_9d30136a:

    # me "Я смотрю у вас хорошее настроение."
    me "我看你们心情都很好啊。"

# game/a4/6ballday.rpy:275
translate english ballday3_13191c55:

    # calah "Это же бал, [mename]. Единственное время и место, когда можно отвлечься от государственных дел и расслабиться."
    calah "这可是舞会啊，[mename]。唯一一个可以从国事中抽身、放松一下的时间和地点。"

# game/a4/6ballday.rpy:276
translate english ballday3_7a29c69c:

    # arcadia "Он прав, но я еще прихожу сюда отдохнуть от детей. Младшая совсем отбилась от рук в последнее время."
    arcadia "他说得对，不过我也是来这儿躲躲孩子的。小女儿最近完全不服管教了。"

# game/a4/6ballday.rpy:277
translate english ballday3_1083bece:

    # me "Ну ладно, пойду поищу еще знакомых лиц."
    me "好啦，我再去看看有没有其他熟人。"

# game/a4/6ballday.rpy:278
translate english ballday3_69829da4:

    # calah "Удачи в приключениях, принц."
    calah "祝你在冒险中好运，王子殿下。"

# game/a4/6ballday.rpy:279
translate english ballday3_38975f7d:

    # arcadia "Приключения? Ты уже совсем пьяный, Калахан."
    arcadia "冒险？你已经完全喝醉了，Callahan。"

# game/a4/6ballday.rpy:281
translate english ballday3_63dd2810:

    # me "{i}Надо посмотреть, что там на ярусе.{/i}"
    me "{i}得上露台去看看，那边怎么样了。{/i}"

# game/a4/6ballday.rpy:283
translate english ballday3_e6926c8b:

    # guard "Мой принц! Пусть твоя вашего отца будет железом. Пусть золотой закон..."
    guard "我的王子殿下！愿您父亲的意志坚如钢铁。愿黄金律法……"

# game/a4/6ballday.rpy:284
translate english ballday3_84248ba0:

    # me "Расслабься, ты случайно не видел гостью с Севера или может с Юга?"
    me "放松点，你碰巧看到了从北方来的那位，或者也许是南方的客人吗？"

# game/a4/6ballday.rpy:285
translate english ballday3_aa44305c:

    # guard "Видел, мой принц, я покажу."
    guard "看到了，我的王子，我指给您看。"

# game/a4/6ballday.rpy:287
translate english ballday3_55839417:

    # guard "Вот девушка с Севера. Южанка ярусом выше."
    guard "这位是北方来的姑娘。南方的那位在上面一层。"

# game/a4/6ballday.rpy:288
translate english ballday3_7c063d55:

    # me "{i}Аврора...Выглядит прекрасно.{/i}"
    me "{i}Aurora……真是光彩照人。{/i}"

# game/a4/6ballday.rpy:290
translate english ballday3_b3f61d7b:

    # me "Прошу прощения, не подскажите, что это за мероприятие? Кто-то умер? Или может быть женится?"
    me "抱歉，请问一下，这是什么活动？是谁去世了？还是有人要结婚？"

# game/a4/6ballday.rpy:291
translate english ballday3_4479fe56:

    # aurora "Пока не знаю. Но надеюсь, что все-таки второе."
    aurora "还不知道呢。不过希望是后者。"

# game/a4/6ballday.rpy:292
translate english ballday3_b7683cf5:

    # me "Привет, Аврора."
    me "嗨，Aurora。"

# game/a4/6ballday.rpy:293
translate english ballday3_5d43c6ba:

    # aurora "Привет, [mename]."
    aurora "嗨，[mename]。"

# game/a4/6ballday.rpy:294
translate english ballday3_2caa6fcb:

    # me "Ты давно пришла?"
    me "你到了很久了吗？"

# game/a4/6ballday.rpy:296
translate english ballday3_f8996d08:

    # aurora "Очень давно. И кажется зря. Ваши балы отличаются от северных."
    aurora "非常久了。而且好像白来了。你们的舞会和北方的不一样。"

# game/a4/6ballday.rpy:297
translate english ballday3_ef114c48:

    # me "Чем же?"
    me "有什么不同呢？"

# game/a4/6ballday.rpy:298
translate english ballday3_8cff55e2:

    # aurora "Здесь все просто пьют."
    aurora "这里大家只是喝酒。"

# game/a4/6ballday.rpy:299
translate english ballday3_5beefe5e:

    # me "Танцы еще не начинались."
    me "跳舞还没开始呢。"

# game/a4/6ballday.rpy:300
translate english ballday3_1cc657f6:

    # aurora "Правда? А как все эти люди будут танцевать? Они же пьяны."
    aurora "真的吗？那这些人要怎么跳舞？他们可都醉了啊。"

# game/a4/6ballday.rpy:301
translate english ballday3_c6ec2dd5:

    # me "Это...если честно я сам только что познакомился с культурой местных балов. Мать говорит сначала приходят те, кто хотят выпить, молодые подтянутся чуть позже."
    me "这个……说实话，我也是刚刚才了解本地舞会的文化。母亲说，想喝酒的人会先来，年轻人会稍晚一点才来。"

# game/a4/6ballday.rpy:302
translate english ballday3_3fecf3d8:

    # aurora "Аа...Выходит я просто, как обычно, прибыла раньше нужного."
    aurora "啊……这么说我只是，一如既往地，提前到了。"

# game/a4/6ballday.rpy:303
translate english ballday3_9086d4fd:

    # me "Ты не пьешь?"
    me "你不喝酒吗？"

# game/a4/6ballday.rpy:304
translate english ballday3_566ed84b:

    # aurora "Nope."
    aurora "No."

# game/a4/6ballday.rpy:305
translate english ballday3_40877fb6:

    # me "А я вот выпил бы бокал аранского. Пойду поищу слуг с бокалами."
    me "我倒想来杯阿兰黄金酒。我去找找端酒的仆人。"

# game/a4/6ballday.rpy:307
translate english ballday3_e4a8d9d6:

    # me "{i}Что он говорил? Южанка ярусом выше?{/i}"
    me "{i}他刚才说什么来着？南方的那位在更上面一层？{/i}"

# game/a4/6ballday.rpy:309
translate english ballday3_a736d117:

    # isid "[mename]! Ну наконец-то. Я ждала тебя."
    isid "[mename]！终于见到你了。我一直在等你。"

# game/a4/6ballday.rpy:310
translate english ballday3_51414bad:

    # me "Ты здесь уже давно?"
    me "你在这儿很久了？"

# game/a4/6ballday.rpy:311
translate english ballday3_9589bde9:

    # isid "Пришла самая первая. Смотрела в окно и все ждала своего будущего мужа."
    isid "我第一个到的。看着窗外，一直在等我的未来丈夫。"

# game/a4/6ballday.rpy:312
translate english ballday3_1ef8286a:

    # me "Я...был немного занят."
    me "我……有点事耽搁了。"

# game/a4/6ballday.rpy:313
translate english ballday3_3f2582f9:

    # isid "Не стой там. Проходи и садись."
    isid "别站在那儿。过来坐下。"

# game/a4/6ballday.rpy:315
translate english ballday3_50aadaf5:

    # isid "Так чем ты был занят?"
    isid "你在忙什么呢？"

# game/a4/6ballday.rpy:316
translate english ballday3_8dfc8a8d:

    # me "Я учился танцевать."
    me "我在学跳舞。"

# game/a4/6ballday.rpy:317
translate english ballday3_987c4b60:

    # isid "А этому нужно учиться?"
    isid "这个还需要学吗？"

# game/a4/6ballday.rpy:318
translate english ballday3_b942bfbc:

    # me "Ну да. А как же иначе? Нужно же синхронизироваться с партнершей - заучить одинаковые движения."
    me "当然啊。不然怎么跳？得和舞伴同步——记住相同的动作。"

# game/a4/6ballday.rpy:319
translate english ballday3_3d72e079:

    # isid "Я в этом не разбираюсь."
    isid "我不懂这些。"

# game/a4/6ballday.rpy:320
translate english ballday3_68ac6074:

    # me "Ты не умеешь танцевать?"
    me "你不会跳舞吗？"

# game/a4/6ballday.rpy:321
translate english ballday3_15247bbc:

    # isid "Умею. Хочешь посмотреть?"
    isid "会啊。想看吗？"

# game/a4/6ballday.rpy:323
translate english ballday3_b47df90c:

    # isid "Посмотреть? А я участвовать не буду?"
    isid "看？我自己不跳吗？"

# game/a4/6ballday.rpy:324
translate english ballday3_b3a3642e:

    # me "На Юге танцы другого рода...ну так что, посмотришь?"
    me "南方的舞蹈是另一种类型……怎么样，看看吗？"

# game/a4/6ballday.rpy:326
translate english ballday3_168b1e16:

    # me "Давай подождем, пока начнется бал. Не хочу ничего пропустить."
    me "还是等舞会正式开始吧。我可不想错过什么。"

# game/a4/6ballday.rpy:327
translate english ballday3_ff81c0f0:

    # isid "Как хочешь. Если что - ты знаешь, где меня искать."
    isid "随你。如果想看——你知道到哪儿找我。"

# game/a4/6ballday.rpy:328
translate english ballday3_6dcd3704:

    # me "Я обязательно приду. Захватить немного золотого аранского?"
    me "我一定会来的。要不要带点阿兰黄金酒来？"

# game/a4/6ballday.rpy:329
translate english ballday3_d9a448e3:

    # isid "Нет, спасибо, у меня свое."
    isid "不用了，谢谢，我自己有。"

# game/a4/6ballday.rpy:330
translate english ballday3_0111a2c1:

    # me "Ладно. Пойду схожу к отцу."
    me "好吧。那我去父王那边看看。"

# game/a4/6ballday.rpy:331
translate english ballday3_650e4b62:

    # isid "Конечно, [mename], я буду тебя ждать."
    isid "当然，[mename]，我会等你的。"

# game/a4/6ballday.rpy:334
translate english ballday3_4ed64d52:

    # me "{i}А вот и отец...и...[cass].{/i}"
    me "{i}父亲在那儿……还有……[cass]。{/i}"

