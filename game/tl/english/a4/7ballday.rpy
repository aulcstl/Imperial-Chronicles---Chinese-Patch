# game/a4/7ballday.rpy:141
translate english ballday_momdance_96cf08a8:

    # me "Я все помню."
    me "我全记得。"

# game/a4/7ballday.rpy:142
translate english ballday_momdance_4532624b:

    # mom "Хорошо, [mename], спасибо за танец."
