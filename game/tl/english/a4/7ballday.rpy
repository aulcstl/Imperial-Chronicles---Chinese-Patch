# game/a4/7ballday.rpy:30
translate english ballday4_95e2c760:

    # me "{i}Что [elin] делает?{/i}"
    me "{i}[elin]做什么呢？{/i}"

# game/a4/7ballday.rpy:32
translate english ballday4_6ee96369:

    # me "{i}Она тушит огонь? Зачем?{/i}"
    me "{i}她在灭那些火焰？为什么？{/i}"

# game/a4/7ballday.rpy:33
translate english ballday4_69495cb5:

    # voics1 "{size=-6}Что эта ведьма устроила?{/size}"
    voics1 "{size=-6}这女巫要闹什么？{/size}"

# game/a4/7ballday.rpy:34
translate english ballday4_35f09cde:

    # voics2 "{size=-6}Она хочет оставить нас в темноте?{/size}"
    voics2 "{size=-6}她存心想让咱们摸黑不成？{/size}"

