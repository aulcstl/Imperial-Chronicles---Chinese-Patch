    me "想必是吧。"

# game/a4/7ballday.rpy:14
translate english ballday4_1631a15f:

    # voics1 "{size=-6}Это принцесса [elin]? Как же она повзрослела.{/size}"
    voics1 "{size=-6}那是[elin]公主？竟出落得这般成熟了。{/size}"

# game/a4/7ballday.rpy:15
translate english ballday4_1dd90c93:

