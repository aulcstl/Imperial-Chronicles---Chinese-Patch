# game/a4/7ballday.rpy:157
translate english ballday_sisdance_a87c71d7:

    # me "Привет."
    me "你来了。"

# game/a4/7ballday.rpy:159
translate english ballday_sisdance_4c389526:

    # me "Локхарт, разреши украсть эту даму на один танец."
    me "Lockhart，容我借这位女士跳一支舞。"

# game/a4/7ballday.rpy:160
translate english ballday_sisdance_a248a2a2:

    # lockhart "Я не против. Но она говорит, что танцевать не хочет."
    lockhart "我不介意。不过她说不想跳。"

# game/a4/7ballday.rpy:161
translate english ballday_sisdance_8508cd22:

    # me "Это правда?"
    me "当真？"

# game/a4/7ballday.rpy:162
translate english ballday_sisdance_08dbcca5:

    # sis "Да, правда."
    sis "是，当真。"

# game/a4/7ballday.rpy:163
translate english ballday_sisdance_e33e9b6f:

    # lockhart "Вот видишь? Но я ее не виню. Музыка здесь... старомодна."
    lockhart "你瞧？不过我并不怪她。这里的音乐...太陈旧了。"

# game/a4/7ballday.rpy:165
translate english ballday_sisdance_aad626a6:

    # me "Этот бал в честь тебя и меня, разве мы не должны станцевать вместе, хотя бы один раз?"
    me "这场舞会原为贺你我二人，我们难道不该合舞一次吗，至少一次？"

# game/a4/7ballday.rpy:166
translate english ballday_sisdance_4cb050a7:

    # sis "Ну, может, один танец."
    sis "唔，也罢，就一支舞。"

# game/a4/7ballday.rpy:167
translate english ballday_sisdance_dea2f537:

    # lockhart "Эм..."
    lockhart "呃..."

# game/a4/7ballday.rpy:169
translate english ballday_sisdance_050f411b:

    # voics1 "{size=-6}Посмотрите, принц и принцесса танцуют.{/size}"
    voics1 "{size=-6}快看，王子与公主在跳舞。{/size}"

# game/a4/7ballday.rpy:170
translate english ballday_sisdance_88d643f4:

    # voics2 "{size=-6}Wonderful. The king has wonderful children.{/size}"
    voics2 "{size=-6}Wonderful. The king has wonderful children.{/size}"

# game/a4/7ballday.rpy:171
translate english ballday_sisdance_7f1c0208:

    # sis "Ты меня ради этого пригласил? Ради формальности?"
    sis "你为此才邀我？只为了场面？"

# game/a4/7ballday.rpy:172
translate english ballday_sisdance_d355dc3b:

    # me "О чем ты?"
    me "您说什么呢？"

# game/a4/7ballday.rpy:173
translate english ballday_sisdance_24249417:

    # sis "Бал в честь наших имен, это единственная причина, по которой ты пригласил меня на танец."
    sis "舞会冠以你我之名，这就是你邀我共舞的唯一缘由。"

# game/a4/7ballday.rpy:174
translate english ballday_sisdance_edccf5f0:

    # me "А должны быть еще?"
    me "难道还需要旁的缘由？"

# game/a4/7ballday.rpy:175
translate english ballday_sisdance_b3fd2aa8:

    # voics1 "{size=-6}Я слышала, что они друг друга ненавидят.{/size}"
    voics1 "{size=-6}我听闻他们彼此憎恶。{/size}"

# game/a4/7ballday.rpy:176
translate english ballday_sisdance_9f04c9c4:

    # voics2 "{size=-6}Это [cassa] и [mename] друг друга ненавидят, эти близнецы с детства вместе.{/size}"
    voics2 "{size=-6}彼此憎恶的是[cassa]和[mename]，这对孪生子自幼便在一处。{/size}"

# game/a4/7ballday.rpy:178
translate english ballday_sisdance_f42a2c77:

    # sis "Ну я не знаю. Может я...а забудь."
    sis "嗯，我不晓得。或许我...罢了，当我没说。"

# game/a4/7ballday.rpy:179
translate english ballday_sisdance_30d14d64:

    # me "[elin]?"
    me "[elin]?"

# game/a4/7ballday.rpy:180
translate english ballday_sisdance_65310d5e:

    # sis "Ты что, даже не заметил изменений во мне?"
    sis "怎么，你难道没瞧出我的变化？"

# game/a4/7ballday.rpy:181
translate english ballday_sisdance_c63adda7:

    # me "Чудесная новая прическа, [elin]."
    me "新发式很别致，[elin]。"

# game/a4/7ballday.rpy:182
translate english ballday_sisdance_dbe962d0:

    # sis "Это только на танцы, я люблю когда волосы свободны."
    sis "只为了跳舞，我更喜欢发丝自在散开。"

# game/a4/7ballday.rpy:183
translate english ballday_sisdance_b6866326:

    # me "Я знаю, ты свободная птичка."
    me "我知道，你是一只自在的小鸟。"

# game/a4/7ballday.rpy:185
translate english ballday_sisdance_03330977:

    # sis "[mename]."
    sis "[mename]."

# game/a4/7ballday.rpy:186
translate english ballday_sisdance_dfcceeac:

    # me "М?"
    me "嗯？"

# game/a4/7ballday.rpy:187
translate english ballday_sisdance_bdc0a50c:

    # sis "Ты ужасно танцуешь, ты это знаешь?"
    sis "你的舞步糟透了，你可清楚？"

# game/a4/7ballday.rpy:188
translate english ballday_sisdance_b17cfaf3:

    # me "Я...ты серьезно?"
    me "我...你可是当真？"

# game/a4/7ballday.rpy:189
translate english ballday_sisdance_5261a13d:

    # sis "Ты мне трижды уже на ноги наступил."
    sis "你已踩了我三回脚。"

# game/a4/7ballday.rpy:190
translate english ballday_sisdance_f819e3b8:

    # me "Прости. Мой опыт в этом искусстве сдвинулся с абсолютного отсутствия только сегодня."
    me "抱歉。我于此道的经验，是今天才从毫无门径开始往前挪的。"

# game/a4/7ballday.rpy:191
translate english ballday_sisdance_85b6a0a4:

    # sis "Мама?"
    sis "母亲？"

# game/a4/7ballday.rpy:192
translate english ballday_sisdance_4b14af29:

    # me "Мама."
    me "母亲。"

# game/a4/7ballday.rpy:193
translate english ballday_sisdance_f873bede:

    # sis "Ты мог бы попросить и меня."
    sis "你原也可以邀我。"

# game/a4/7ballday.rpy:194
translate english ballday_sisdance_2640666f:

    # me "Это не последний бал в нашей жизни. Еще поможешь мне освоить шарлестон."
    me "这又不是我们此生最后一场舞会。往后还得靠你教我查尔斯顿呢。"

# game/a4/7ballday.rpy:195
translate english ballday_sisdance_201a9e2a:

    # sis "Пусть ты и неуклюжий, мне все равно нравится с тобой танцевать."
    sis "哪怕你手脚笨拙，我仍喜欢和你共舞。"

# game/a4/7ballday.rpy:196
translate english ballday_sisdance_3066598f:

    # me "Спасибо."
    me "谢谢。"

# game/a4/7ballday.rpy:198
translate english ballday_sisdance_5cbc70d0:

    # sis "Ой!"
    sis "哎哟！"

# game/a4/7ballday.rpy:199
translate english ballday_sisdance_ea63ce77:

    # me "Что-то случилось?"
    me "怎么了？"

# game/a4/7ballday.rpy:200
translate english ballday_sisdance_a12aec61:

    # sis "Теперь мне придется танцевать с Локхартом, а то будет...неудобно, если я потанцую только с тобой."
    sis "这下我得和Lockhart跳了，不然...若只跟你一人跳过，未免太扎眼。"

# game/a4/7ballday.rpy:201
translate english ballday_sisdance_01822020:

    # me "Ладно."
    me "好。"

# game/a4/7ballday.rpy:202
translate english ballday_sisdance_ba662916:

    # sis "Ты не против?"
    sis "你不介意？"

# game/a4/7ballday.rpy:203
translate english ballday_sisdance_2dd6f9d6:

    # me "Не против ли я, чтобы ты потанцевала на балу с кем-то кроме меня? Что за вопрос?"
    me "我介不介意你在舞会上同别人跳舞？这是什么话？"

# game/a4/7ballday.rpy:204
translate english ballday_sisdance_a5f250d8:

    # sis "Я...эм....спасибо за танец, [mename]."
    sis "我...呃...谢谢你同我跳舞，[mename]。"

# game/a4/7ballday.rpy:205
translate english ballday_sisdance_ad0966d3:

    # me "Спасибо за танец, [elin]."
    me "谢谢你同我跳舞，[elin]。"

# game/a4/7ballday.rpy:211
translate english ballday_isisdance_7f9e404a:

    # me "{i}Я уже танцевал с ней.{/i}"
    me "{i}我已同她跳过舞了。{/i}"

# game/a4/7ballday.rpy:215
translate english ballday_isisdance_be98f6c8:

    # isid "[mename]! Ты вернулся. Поговорил с отцом?"
    isid "[mename]！你回来了。同父亲谈过了？"

# game/a4/7ballday.rpy:216
translate english ballday_isisdance_2d42945b:

    # me "Ага."
    me "嗯。"

# game/a4/7ballday.rpy:217
translate english ballday_isisdance_a0cc96c7:

    # isid "О чем болтали?"
    isid "聊了些什么？"

# game/a4/7ballday.rpy:218
translate english ballday_isisdance_ebcbac29:

    # me "Да так...о танцах."
    me "没什么...只聊了跳舞的事。"

# game/a4/7ballday.rpy:219
translate english ballday_isisdance_77dfaeb3:

    # isid "Ох, танцы...жаль я не умею танцевать ваши танцы."
    isid "哦，跳舞...可惜我不会跳你们这些舞步。"

# game/a4/7ballday.rpy:220
translate english ballday_isisdance_68ac8333:

    # me "Ты сказала, что умеешь танцевать по-другому..."
    me "你之前说过，你会跳另一种舞..."

# game/a4/7ballday.rpy:221
translate english ballday_isisdance_75653edd:

    # isid "Верно."
    isid "不错。"

# game/a4/7ballday.rpy:223
translate english ballday_isisdance_94fe4447:

    # isid "Уйдите. Оба."
    isid "退下。你们两人。"

# game/a4/7ballday.rpy:224
translate english ballday_isisdance_da069e27:

    # rabi "Да, моя госпожа."
    rabi "是，我的小姐。"

# game/a4/7ballday.rpy:225
translate english ballday_isisdance_d109ebba:

    # rab_v "Да, моя госпожа."
    rab_v "是，我的小姐。"

# game/a4/7ballday.rpy:227
translate english ballday_isisdance_1ebc0097:

    # me "Зачем ты прогнала своих слуг?"
    me "你为何遣走仆人？"

# game/a4/7ballday.rpy:228
translate english ballday_isisdance_14eec781:

    # isid "У этого танца должен быть только один зритель - мой муж."
    isid "此舞的观赏者只该有一人——我的夫婿。"

# game/a4/7ballday.rpy:229
translate english ballday_isisdance_5ac38cf1:

    # me "Почему?"
    me "为什么？"

# game/a4/7ballday.rpy:231
translate english ballday_isisdance_58dc5f75:

    # isid "Поэтому."
    isid "就为此。"

# game/a4/7ballday.rpy:232
translate english ballday_isisdance_f5847612:

    # me "Ох...теперь понятно."
    me "哦...这下明白了。"

# game/a4/7ballday.rpy:233
translate english ballday_isisdance_2eab1f37:

    # isid "Тебе нравится?"
    isid "你可喜欢？"

# game/a4/7ballday.rpy:234
translate english ballday_isisdance_4735efc6:

    # me "Я такого не видел никогда раньше. Выглядит..."
    me "我此前从未见过。看起来..."

# game/a4/7ballday.rpy:235
translate english ballday_isisdance_f5731eea:

    # isid "...сексуально?"
    isid "...十分撩人？"

# game/a4/7ballday.rpy:236
translate english ballday_isisdance_f6d60ea7:

    # me "Да. Это правильное слово."
    me "正是。这个词才准确。"

# game/a4/7ballday.rpy:237
translate english ballday_isisdance_3c40c993:

    # isid "Если я стану твоей женой, то буду танцевать, когда вы только захотите."
    isid "若我做了你的妻子，但凡你想看，我便跳。"

# game/a4/7ballday.rpy:238
translate english ballday_isisdance_4ae2625f:

    # me "У этого танца есть предназначение?"
    me "这舞有什么用意吗？"

# game/a4/7ballday.rpy:239
translate english ballday_isisdance_e001b954:

    # isid "В каком смысле?"
    isid "用意指什么？"

# game/a4/7ballday.rpy:240
translate english ballday_isisdance_ecdd4294:

    # me "Ну...не просто так же этот танец придумали."
    me "唔...总不该毫无缘故便编排出这支舞来。"

# game/a4/7ballday.rpy:242
translate english ballday_isisdance_b8e8b812:

    # isid "Ты прав. У танца есть предназначение."
    isid "你说得是。它确实有用途。"

# game/a4/7ballday.rpy:243
translate english ballday_isisdance_a0300076:

    # me "Какое же?"
    me "是什么呢？"

# game/a4/7ballday.rpy:244
translate english ballday_isisdance_d03f7b6b:

    # isid "Он предназначен для того, чтобы разогревать мужчину."
    isid "这舞是专用来让男子热起来的。"

# game/a4/7ballday.rpy:245
translate english ballday_isisdance_d143195b:

    # me "Разогревать?"
    me "热起来？"

# game/a4/7ballday.rpy:247
translate english ballday_isisdance_3691d25c:

    # isid "Создавать необходимое настроение для соития. И судя по тому, что я чувствую в твоих штанах, настроение для соития я создала."
    isid "为交合营造应有的兴致。凭我在你裤子里感觉到的东西来看，合欢的兴致我已营造妥当了。"

# game/a4/7ballday.rpy:248
translate english ballday_isisdance_b0d642c3:

    # me "Хех. Не стану отпираться. У меня встал, как только ты зашевелилась."
    me "哼。我不否认。你腰肢刚动起来，我便挺立了。"

# game/a4/7ballday.rpy:249
translate english ballday_isisdance_66f48aac:

    # isid "Хочешь поцеловать меня?"
    isid "你可想吻我？"

# game/a4/7ballday.rpy:250
translate english ballday_isisdance_e86e77ad:

    # me "Хочу."
    me "想。"

# game/a4/7ballday.rpy:252
translate english ballday_isisdance_03d8253a:

    # isid "Как жаль, что нам нельзя заходить дальше положенного."
    isid "可惜我们眼下还不能逾越了界限。"

# game/a4/7ballday.rpy:253
translate english ballday_isisdance_5ac38cf1_1:

    # me "Почему?"
    me "为何？"

# game/a4/7ballday.rpy:254
translate english ballday_isisdance_1c5373a6:

    # isid "Мы все еще не женаты. Но это можно легко исправить."
    isid "我们仍未成婚。不过要纠正这点倒也十分容易。"

# game/a4/7ballday.rpy:255
translate english ballday_isisdance_590015dd:

    # me "Жениться на тебе."
    me "娶你为妻。"

# game/a4/7ballday.rpy:256
translate english ballday_isisdance_e05a7af3:

    # isid "Ты такой умный, мой принц, мой мастер, мой будущий муж."
    isid "你真是聪明，我的王子，我的主人，我未来的丈夫。"

# game/a4/7ballday.rpy:257
translate english ballday_isisdance_853ce7ef:

    # me "Ладно. Пойду потанцую, а то у меня уже член болит."
    me "好了。我且再去跳一阵，否则下身涨得发痛。"

# game/a4/7ballday.rpy:258
translate english ballday_isisdance_279efc3b:

    # isid "Буду ждать тебя здесь, мой лев."
    isid "我就在此候着你，我的雄狮。"

# game/a4/7ballday.rpy:264
translate english ballday_auroradance_7f9e404a:

    # me "{i}Я уже танцевал с ней.{/i}"
    me "{i}我已同她跳过舞了。{/i}"

# game/a4/7ballday.rpy:268
translate english ballday_auroradance_ceba5dd9:

    # me "Аврора? Скучаешь?"
    me "Aurora？觉得乏味了？"

# game/a4/7ballday.rpy:269
translate english ballday_auroradance_31fa476c:

    # aurora "Надеюсь вы подошли, чтобы пригласить меня на танец."
    aurora "希望您过来，是来邀我共舞的。"

# game/a4/7ballday.rpy:270
translate english ballday_auroradance_7a2420a0:

    # me "Все верно. Пойдем танцевать."
    me "正是如此。走，我们去跳舞。"

# game/a4/7ballday.rpy:272
translate english ballday_auroradance_b529d573:

    # aurora "Скажу сразу - я танцую не очень хорошо. На многое не рассчитывайте."
    aurora "先说在头里——我舞步不佳。莫抱太高期许。"

# game/a4/7ballday.rpy:273
translate english ballday_auroradance_afa755ba:

    # me "Вы не поверите..."
    me "您或许不信..."

# game/a4/7ballday.rpy:274
translate english ballday_auroradance_318f10f6:

    # aurora "Надеюсь мы не запутаемся друг у друга в ногах и не упадем."
    aurora "只盼我们别缠作一团摔在地上便好。"

# game/a4/7ballday.rpy:275
translate english ballday_auroradance_bcd18fc9:

    # me "Звучит очень смешно, я бы попробовал."
    me "听来十分有趣，我倒想试试看。"

# game/a4/7ballday.rpy:276
translate english ballday_auroradance_963b2893:

    # aurora "Не стоит."
    aurora "还是不必了。"

# game/a4/7ballday.rpy:277
translate english ballday_auroradance_8f8de749:

    # me "Это еще почему?"
    me "这又是为何？"

# game/a4/7ballday.rpy:279
translate english ballday_auroradance_85eb5a63:

    # aurora "Я бы хотела подурачиться, но здесь всюду злые языки."
    aurora "我原想胡闹一下，可这里到处是恶舌。"

# game/a4/7ballday.rpy:280
translate english ballday_auroradance_b6626098:

    # me "А?"
    me "啊？"

# game/a4/7ballday.rpy:281
translate english ballday_auroradance_eb514829:

    # aurora "Разве вы не слышите? Они судачат о нас прямо сейчас. Прислушайтесь."
    aurora "您难道听不到吗？他们现下就在嚼我们的舌头。仔细听听。"

# game/a4/7ballday.rpy:282
translate english ballday_auroradance_73f050eb:

    # voics1 "{size=-6}Ее отец развалил нашу Империю, зачем ее сюда вообще пустили?{/size}"
    voics1 "{size=-6}她父亲把咱们帝国都弄垮了，怎竟放她跑到这里？{/size}"

# game/a4/7ballday.rpy:283
translate english ballday_auroradance_d1821a4c:

    # voics2 "{size=-6}Я слышала, что ее мать - дфорфиха.{/size}"
    voics2 "{size=-6}我听说，她母亲是个矮人。{/size}"

# game/a4/7ballday.rpy:284
translate english ballday_auroradance_b91543c5:

    # voics1 "{size=-6}Правда? Вроде рост у нее нормальный.{/size}"
    voics1 "{size=-6}当真吗？她个头看着倒还正常。{/size}"

# game/a4/7ballday.rpy:285
translate english ballday_auroradance_f7f4a77d:

    # voics2 "{size=-6}Рост может и нормальный, но ты видела ее жирные губы?{/size}"
    voics2 "{size=-6}个头或者不矮，你瞧见她那肥厚嘴唇了没有？{/size}"

# game/a4/7ballday.rpy:286
translate english ballday_auroradance_8e07cae6:

    # me "Я слышу. Это раздражает вас?"
    me "我听见了。惹您不快了吗？"

# game/a4/7ballday.rpy:287
translate english ballday_auroradance_719701fb:

    # aurora "Немного..."
    aurora "有一点..."

# game/a4/7ballday.rpy:289
translate english ballday_auroradance_566dc533:

    # voics1 "{size=-6}Они совершенно не умеют танцевать. Оба кривоногие.{/size}"
    voics1 "{size=-6}他们两个压根不会跳舞。全是一双跛腿。{/size}"

# game/a4/7ballday.rpy:290
translate english ballday_auroradance_4ba6a197:

    # voics2 "{size=-12}Тсс...они смотрят в нашу сторону.{/size}"
    voics2 "{size=-12}嘘...他们往咱们这边瞧了。{/size}"

# game/a4/7ballday.rpy:291
translate english ballday_auroradance_8b79a5d3:

    # me "Хотите я прямо сейчас отрежу пару языков?"
    me "要不要我这就去割下几条舌头？"

# game/a4/7ballday.rpy:292
translate english ballday_auroradance_dd2385e0:

    # aurora "Нет. Не нужно. Я просто не привыкла. На севере знать себе такого не позволяет."
    aurora "不。不必了。我只是还不习惯。在北方，贵族是不许自己这般行径的。"

# game/a4/7ballday.rpy:293
translate english ballday_auroradance_b7efe2ba:

    # me "Правда? Вообще?"
    me "当真吗？竟然不许？"

# game/a4/7ballday.rpy:294
translate english ballday_auroradance_eb569e6c:

    # aurora "Ну...справедливости ради, на северных балах столько не пьют. Вино не дает рту закрыться."
    aurora "唔...凭心讲，北方舞会上并不会饮这么多酒。酒水使人闭不上嘴。"

# game/a4/7ballday.rpy:295
translate english ballday_auroradance_455068fc:

    # me "На севере мало пьют? Я слышал иное."
    me "北地之人饮酒少？我听见的可不是这般。"

# game/a4/7ballday.rpy:296
translate english ballday_auroradance_d032abea:

    # aurora "Вы путаете с пирами. Вот на них северяне напиваются что есть сил."
    aurora "您是把宴会与舞会弄混了。到了宴会上，北方人才会放开量狂饮。"

# game/a4/7ballday.rpy:298
translate english ballday_auroradance_c4ccfc65:

    # me "И даже ваш отец?"
    me "连您的父亲也如此？"

# game/a4/7ballday.rpy:299
translate english ballday_auroradance_ab51c19f:

    # aurora "Мой отец...это исключение. Он пьет, но я никогда не видела его пьяным."
    aurora "我父亲...那个是例外。他饮酒，可我从未见过他醉态。"

# game/a4/7ballday.rpy:300
translate english ballday_auroradance_a2a16e34:

    # me "Я столько слышал о нем только хорошего, что у меня начинает складываться впечатление, что у вашего отца нет недостатков."
    me "关于他我只听得好话，听多了，竟渐渐觉得令尊毫无缺点。"

# game/a4/7ballday.rpy:301
translate english ballday_auroradance_b05c9f39:

    # aurora "Он идеальный король, никогда не обнажает свои слабые стороны, но наедине с семьей..."
    aurora "他是一位完美的君主，从不显露自己软弱的一面，但与我们独处时..."

# game/a4/7ballday.rpy:302
translate english ballday_auroradance_e2bd1fa7:

    # me "Наедине с семьей он?"
    me "与家人独处时他怎么样？"

# game/a4/7ballday.rpy:303
translate english ballday_auroradance_47e8a2f4:

    # aurora "Наедине с семьей он такой же...король."
    aurora "与家人独处时他一样是位...君王。"

# game/a4/7ballday.rpy:304
translate english ballday_auroradance_99b0b70b:

    # me "Мне кажется, я понимаю о чем ты. Мой отец редко меня чему-то учил. Разве что наказывал, когда я делал что-то не так. Наверное у королей слишком много забот, чтобы быть еще и отцами."
    me "我想我懂了。我父亲极少教导我什么，只有我做错时才受罚。大概君王牵挂太多，再做不了父亲。"

# game/a4/7ballday.rpy:305
translate english ballday_auroradance_4ce43581:

    # aurora "Думаю, вы правы."
    aurora "我想您说得不错。"

# game/a4/7ballday.rpy:306
translate english ballday_auroradance_c2311bb9:

    # me "Спасибо за танец, Аврора."
    me "谢谢你的舞，Aurora。"

# game/a4/7ballday.rpy:307
translate english ballday_auroradance_e801b426:

    # aurora "Спасибо за танец... и за разговор, [mename]."
    aurora "谢谢你的舞...也谢谢你陪我说话，[mename]。"

# game/a4/7ballday.rpy:313
translate english ballday_cassdance_7f9e404a:

    # me "{i}Я уже танцевал с ней.{/i}"
    me "{i}我已同她跳过舞了。{/i}"

# game/a4/7ballday.rpy:317
translate english ballday_cassdance_9f8370ee:

    # me "[cass]."
    me "[cass]."

# game/a4/7ballday.rpy:318
translate english ballday_cassdance_3b828add:

    # cass "[mename]. Даже не вздумай..."
    cass "[mename]。你最好连想都别想..."

# game/a4/7ballday.rpy:319
translate english ballday_cassdance_ffcf49f6:

    # me "Разреши пригласить тебя на танец."
    me "容我请你跳一支舞。"

# game/a4/7ballday.rpy:320
translate english ballday_cassdance_26ea6b68:

    # cass "Не разрешаю."
    cass "我不许。"

# game/a4/7ballday.rpy:321
translate english ballday_cassdance_91b52ccd:

    # me "Я настаиваю."
    me "我偏要请。"

# game/a4/7ballday.rpy:322
translate english ballday_cassdance_7cfb4ce6:

    # cass "[mename], проваливай отсюда. Я не хочу тебя убивать."
    cass "[mename]，滚远些。我不想杀你。"

# game/a4/7ballday.rpy:323
translate english ballday_cassdance_f75f9b4e:

    # me "Кажется все таки придется. Потому что без танца я не уйду."
    me "看来到底免不了，跳不到舞我是不会走的。"

# game/a4/7ballday.rpy:324
translate english ballday_cassdance_b6c9b5d5:

    # cass "Ты же не отстанешь, да?"
    cass "你是不肯罢休了，对吧？"

# game/a4/7ballday.rpy:325
translate english ballday_cassdance_fc30fd2b:

    # me "Да."
    me "没错。"

# game/a4/7ballday.rpy:326
translate english ballday_cassdance_9efb8f42:

    # cass "Ну давай.....потанцуем."
    cass "那就...来跳。"

# game/a4/7ballday.rpy:328
translate english ballday_cassdance_49e972e1:

    # cass "И зачем тебе это?"
    cass "你究竟图什么？"

# game/a4/7ballday.rpy:329
translate english ballday_cassdance_8b8036b4:

    # me "Что именно? "
    me "图什么？"

# game/a4/7ballday.rpy:330
translate english ballday_cassdance_82bcf981:

    # cass "Два лишних глаза. Сам как думаешь? Танец."
    cass "多管闲事。你自己想呢？跳舞。"

# game/a4/7ballday.rpy:331
translate english ballday_cassdance_d3ecaf86:

    # me "Хочу потанцевать со своей старшей сестрой, это такое странное желание?"
    me "我想和我的长姐跳一支舞，这念头很怪吗？"

# game/a4/7ballday.rpy:332
translate english ballday_cassdance_f58d4120:

    # cass "Если ты хочешь меня трахнуть, то это тебе не поможет."
    cass "若你想和我上床，这么做可帮不到你。"

# game/a4/7ballday.rpy:333
translate english ballday_cassdance_ef0075ad:

    # me "Что ты несешь, я просто хочу с тобой потанцевать."
    me "你在说什么，我不过想与你跳支舞罢了。"

# game/a4/7ballday.rpy:334
translate english ballday_cassdance_651ccc28:

    # cass "..."
    cass "..."

# game/a4/7ballday.rpy:335
translate english ballday_cassdance_834bece2:

    # cass "Ты какой-то умалишенный, либо притворяешься. Тебе правда нравится танцевать?"
    cass "你不是疯了，就是装的。你当真喜欢跳舞？"

# game/a4/7ballday.rpy:336
translate english ballday_cassdance_3954a142:

    # me "Слушай, а может ты просто стесняешься? Здесь столько людей, а с твоей репутацией наверное сложно добиться приглашения на танец. Поэтому и такая бурная реакция."
    me "听我说，或许你只是害臊？这里这么多人，以你的名声，恐怕很难收到共舞的邀请。所以才这般激愤。"

# game/a4/7ballday.rpy:338
translate english ballday_cassdance_4125c15f:

    # cass "Стесняюсь?"
    cass "害臊？"

# game/a4/7ballday.rpy:339
translate english ballday_cassdance_2181e2c9:

    # me "Ага. Стесняешься. Маленькая стеснительная девочка."
    me "对。害臊。一个小小害羞姑娘。"

# game/a4/7ballday.rpy:340
translate english ballday_cassdance_8d8ac034:

    # cass "Забери слова назад, пока не поздно, [mename]."
    cass "趁还来得及，把你的话收回去，[mename]。"

# game/a4/7ballday.rpy:341
translate english ballday_cassdance_0bc24752:

    # me "Не стану. Тебя оказывается так заботит мнение окружающих."
    me "我不收。原来你也这般在意旁人的眼光。"

# game/a4/7ballday.rpy:342
translate english ballday_cassdance_10f46fb1:

    # cass "Мнение окружающих? Я тебе сейчас кое-что покажу."
    cass "旁人的眼光？我这就让你见识见识。"

# game/a4/7ballday.rpy:344
translate english ballday_cassdance_da5be69d:

    # me "Что ты..."
    me "你要做..."

# game/a4/7ballday.rpy:346
translate english ballday_cassdance_2ad5a998:

    # me "...делаешь."
    me "...什么。"

# game/a4/7ballday.rpy:347
translate english ballday_cassdance_a88d5d7a:

    # voics1 "{size=-6}Ох, принц упал.{/size}"
    voics1 "{size=-6}哦嗬，王子跌倒了。{/size}"

# game/a4/7ballday.rpy:348
translate english ballday_cassdance_31d58a2b:

    # voics2 "{size=-6}Надо ему помочь.{/size}"
    voics2 "{size=-6}该去扶他才对。{/size}"

# game/a4/7ballday.rpy:349
translate english ballday_cassdance_c2a4669c:

    # cass "Ахахахахахах!"
    cass "啊哈哈哈哈哈哈！"

# game/a4/7ballday.rpy:351
translate english ballday_cassdance_f35c9f92:

    # cass "АХАхахахахахах!"
    cass "啊哈哈哈哈哈哈！"

# game/a4/7ballday.rpy:352
translate english ballday_cassdance_1513bac7:

    # voics1 "{size=-6}Хахаха, как же нелепо он упал.{/size}"
    voics1 "{size=-6}哈哈哈，他摔得多滑稽。{/size}"

# game/a4/7ballday.rpy:353
translate english ballday_cassdance_3bd32ec2:

    # voics2 "{size=-6}Он случайно штаны не порвал? Ну и растяпа.{/size}"
    voics2 "{size=-6}他裤子没扯破吧？真是个笨拙的家伙。{/size}"

# game/a4/7ballday.rpy:354
translate english ballday_cassdance_18092540:

    # cass "{size=+16}Какой же ты неуклюжий, [mename].{/size}"
    cass "{size=+16}你可真够笨手笨脚的，[mename]。{/size}"

# game/a4/7ballday.rpy:355
translate english ballday_cassdance_78620a0a:

    # voics1 "{size=-6}Действительно, и это наш принц? Запутался в собственных ногах.{/size}"
    voics1 "{size=-6}当真，这竟是我们王子？被自己脚绊倒。{/size}"

# game/a4/7ballday.rpy:356
translate english ballday_cassdance_cfcdac6e:

    # voics2 "{size=-6}Какой позор.{/size}"
    voics2 "{size=-6}实在丢人。{/size}"

# game/a4/7ballday.rpy:358
translate english ballday_cassdance_abec80ed:

    # cass "Теперь ты понял, какую чушь сказал?"
    cass "这下你明白了，你说了多蠢的话？"

# game/a4/7ballday.rpy:359
translate english ballday_cassdance_3820771a:

    # me "..."
    me "..."

# game/a4/7ballday.rpy:360
translate english ballday_cassdance_a31ddb9e:

    # cass "Мнение ЭТИХ людей должно меня заботить?"
    cass "这些人的眼光，需要我在意吗？"

# game/a4/7ballday.rpy:361
translate english ballday_cassdance_42fba65b:

    # me "Обязательно для этого жизненного урока было ронять меня на пол?"
    me "非要为了这个教训就把我摔到地上去？"

# game/a4/7ballday.rpy:362
translate english ballday_cassdance_959fb752:

    # cass "Ну, судя по тому, что ты не торопишься вставать тебе там, внизу, комфортно."
    cass "嗯，看你并不急着站起来，你在下头待得倒挺舒服。"

# game/a4/7ballday.rpy:363
translate english ballday_cassdance_c3141fe3:

    # cass "Держи руку. Вставай."
    cass "伸手。起来吧。"

# game/a4/7ballday.rpy:365
translate english ballday_cassdance_a93f615d:

    # me "Это нормально, что я хочу их убить?"
    me "我若想杀了他们，这正当么？"

# game/a4/7ballday.rpy:366
translate english ballday_cassdance_7e48c7cb:

    # cass "Тех кто над тобой смеялся, когда ты упал? Нормально. Главное не делать это сразу."
    cass "那些因你跌倒便嘲笑你的人？正当得很。要紧的是不可当时就做。"

# game/a4/7ballday.rpy:367
translate english ballday_cassdance_ee1454c5:

    # me "Мстить?"
    me "复仇？"

# game/a4/7ballday.rpy:368
translate english ballday_cassdance_832b5583:

    # cass "Ага. Держи в себе эту злобу. Помни о том, как они смеялись. Помни их мерзкие слова и уродливые лица."
    cass "对。把这愤怒捂在心里。记住他们如何笑，记住他们污糟的言语与丑陋的面孔。"

# game/a4/7ballday.rpy:369
translate english ballday_cassdance_831c33ae:

    # me "Зачем? Почему не ответить им сразу?"
    me "为何？为何不立刻还击？"

# game/a4/7ballday.rpy:370
translate english ballday_cassdance_503c1263:

    # cass "Сильного человека от слабого отличает далеко отложенная, но неотвратимая месть."
    cass "强者与弱者的差别，便是那久远的、却绝难逃避的复仇。"

# game/a4/7ballday.rpy:371
translate english ballday_cassdance_702496aa:

    # cass "Того, кто вслепую бросается на обидчика, ждет короткая жизнь, но если твои враги будут умирать позже..."
    cass "谁若盲目冲向欺辱者，便只能活个短命；可若你的仇敌是日后才死去..."

# game/a4/7ballday.rpy:372
translate english ballday_cassdance_efbce404:

    # cass "Кто-то подавится персиковой косточкой, кто-то упадет со стены замка, кто наткнется на разбойников на пути в город."
    cass "有的被桃核噎住，有的自城堡高墙坠落，有的在往城中去的路上撞见强盗。"

# game/a4/7ballday.rpy:373
translate english ballday_cassdance_1629f3b9:

    # cass "Живи так, и однажды у тебя не останется врагов, только жертвы."
    cass "你这样活下去，终有一日便再无仇敌，只剩祭品。"

# game/a4/7ballday.rpy:374
translate english ballday_cassdance_a8c250e1:

    # me "Спасибо за...танец, [cass]."
    me "谢...谢你的舞，[cass]。"

# game/a4/7ballday.rpy:375
translate english ballday_cassdance_d0d0e12c:

    # cass "Ага. Наслаждайся вечером, [mename], а я, пожалуй пойду, отец все равно уже не здесь."
    cass "嗯。好好享受这夜晚吧，[mename]，我呢，这便走了，父亲反正也不在此处了。"

# game/a4/7ballday.rpy:382
translate english ballday5_3ebf3a9b:

    # me "{i}Что-то я устал. В горле пересохло.{/i}"
    me "{i}我倒有些乏了。喉咙干得很。{/i}"

# game/a4/7ballday.rpy:383
translate english ballday5_4fa618e9:

    # me "{i}Надо бы сходить выпить чего-нибудь кроме вина.{/i}"
    me "{i}该去寻些酒水之外的什么来喝。{/i}"

# game/a4/7ballday.rpy:385
translate english ballday5_d3605b40:

    # me "{i}Кажется здесь стоят кувшины.{/i}"
    me "{i}这边像是摆着水罐。{/i}"

# game/a4/7ballday.rpy:386
translate english ballday5_91b2352b:

    # me "{i}Что это за шум?{/i}"
    me "{i}这是什么响动？{/i}"

# game/a4/7ballday.rpy:388
translate english ballday5_a87c71d7:

    # me "Привет."
    me "你好呀。"

# game/a4/7ballday.rpy:389
translate english ballday5_a20cefa7:

    # "..."
    ""

# game/a4/7ballday.rpy:390
translate english ballday5_6da46705:

    # me "{i}Эй, это же [lia].{/i}"
    me "{i}嘿，这不[lia]吗。{/i}"

# game/a4/7ballday.rpy:391
translate english ballday5_fa9feb07:

    # me "{i}Что она здесь делает?{/i}"
    me "{i}她在这儿做什么？{/i}"

# game/a4/7ballday.rpy:392
translate english ballday5_42e099d6:

    # me "{i}Все-таки пробралась на бал, плутовка.{/i}"
    me "{i}到底还是溜进了舞会，这个小滑头。{/i}"

# game/a4/7ballday.rpy:394
translate english ballday5_f03ce2bb:

    # me "Убираетесь да?"
    me "你在打扫对吗？"

# game/a4/7ballday.rpy:395
translate english ballday5_84b63cce:

    # lia "Да..."
    lia "是的..."

# game/a4/7ballday.rpy:396
translate english ballday5_e87722ad:

    # me "Почему не поздоровались? Ты забыла, как слуге надо обращаться к принцу?"
    me "怎么不向我问安？你忘了仆从该如何向王子请安吗？"

# game/a4/7ballday.rpy:397
translate english ballday5_25cc2a4b:

    # lia "Я..эм...простите сир мистер принц, сын короля, да будет его воля железной и..."
    lia "我...呃...请宽恕我，大人，王子殿下，国王之子，愿他意志如铁..."

# game/a4/7ballday.rpy:398
translate english ballday5_97749e1c:

    # me "Угум. И давно слуги ходят в носках?"
    me "嗯哼。仆从只穿着袜子走动，这是什么时候兴起的？"

# game/a4/7ballday.rpy:399
translate english ballday5_2588e527:

    # lia "Я сняла обувь чтобы....чтобы не пачкать ковер."
    lia "我脱了鞋，为了...为了不污了地毯。"

# game/a4/7ballday.rpy:400
translate english ballday5_89e34b78:

    # me "Тот самый ковер который ты чистишь метлой, [ophelia]?"
    me "就是你拿扫帚打理的那张地毯吗，[ophelia]？"

# game/a4/7ballday.rpy:402
translate english ballday5_c19f22f1:

    # lia "{size=+12}Ну да! Это я и что?{/size}"
    lia "{size=+12}是又如何！是我，又怎么了？{/size}"

# game/a4/7ballday.rpy:403
translate english ballday5_713c1391:

    # me "Эмм..."
    me "呃..."

# game/a4/7ballday.rpy:404
translate english ballday5_e6380b36:

    # lia "{size=+12}Я пробралась на этот бал, хотя мама мне запретила! И что?{/size}"
    lia "{size=+12}我溜进这舞会，妈妈明明不许！那又怎样？{/size}"

# game/a4/7ballday.rpy:405
translate english ballday5_246bd9f8:

    # me "[lia]..."
    me "[lia]..."

# game/a4/7ballday.rpy:406
translate english ballday5_d2671df7:

    # lia "{size=+12}ХОЧЕШЬ ЧТОБЫ Я СИДЕЛА ВЗАПЕРТИ ВСЮ ЖИЗНЬ? НУ ИДИ НАЖАЛУЙСЯ МАМЕ. ПРИВЕДИ ЕЕ, МОЖЕТ ВМЕСТЕ МЕНЯ НАКАЖИТЕ! ИДИ. ЯБЕДНИЧАЙ!{/size}"
    lia "{size=+12}要我终身被关着才满意吗？那就去向我妈妈告发啊。把她带去，你们一块儿来罚我啊！去啊。去告状啊！{/size}"

# game/a4/7ballday.rpy:407
translate english ballday5_58e2e766:

    # me "Успокойся, я не собираюсь никому ябедничать."
    me "安静些，我没打算去任何人面前告发。"

# game/a4/7ballday.rpy:409
translate english ballday5_5e31b0ad:

    # me "Правда. Ты чего раскричалась?"
    me "真的。你做什么嚷嚷起来？"

# game/a4/7ballday.rpy:410
translate english ballday5_260c7470:

    # lia "Потому что я всю жизнь хочу на бал. Хочу потанцевать! Разве не понятно? А мама меня заставила меня сидеть в комнате."
    lia "因为我这一辈子就盼着来舞会。我想跳舞！难道还不明白吗？可妈妈硬让我待在房里。"

# game/a4/7ballday.rpy:411
translate english ballday5_06cb23ce:

    # me "Почему тогда ты здесь, а не на самом балу."
    me "那你为何躲在这里，不去舞会上？"

# game/a4/7ballday.rpy:412
translate english ballday5_31077e5c:

    # lia "Потому что мама там и потому что Петти забрала платье, которое мне дала [elin]."
    lia "因为妈妈就在那边，也因为佩蒂把[elin]送我的裙裳收走了。"

# game/a4/7ballday.rpy:413
translate english ballday5_ddc7f5b4:

    # me "Петти?"
    me "佩蒂？"

# game/a4/7ballday.rpy:414
translate english ballday5_74570564:

    # lia "Слуга, которую приставила ко мне мама."
    lia "妈妈安排来照料我的仆人。"

# game/a4/7ballday.rpy:415
translate english ballday5_e31e4ce7:

    # me "Ты из-под ее присмотра сбежала?"
    me "你是从她看管下溜出来的？"

# game/a4/7ballday.rpy:417
translate english ballday5_a94ba325:

    # lia "Да."
    lia "是。"

# game/a4/7ballday.rpy:418
translate english ballday5_896f3bb1:

    # me "[lia] у тебя опять кровавые слезы..."
    me "[lia]，你又淌血泪了..."

# game/a4/7ballday.rpy:419
translate english ballday5_76ac9070:

    # lia "Я знаю. Мама пытается меня оградить, но это меня убивает еще сильнее."
    lia "我知道。妈妈想护着我，可这只会让我更痛苦。"

# game/a4/7ballday.rpy:420
translate english ballday5_9f63e17a:

    # me "Все так серьезно?"
    me "竟这样要紧吗？"

# game/a4/7ballday.rpy:421
translate english ballday5_9a591801:

    # lia "Да. Я просто хотела на бал...хотя бы раз."
    lia "是。我只想来一次舞会...哪怕只一次。"

# game/a4/7ballday.rpy:422
translate english ballday5_f6fa6ad0:

    # me "В твоей жизни еще будут балы."
    me "你的一生中总还会再有舞会。"

# game/a4/7ballday.rpy:423
translate english ballday5_24963d97:

    # lia "Я это каждый год слышу."
    lia "这话我年年都听。"

# game/a4/7ballday.rpy:425
translate english ballday5_3b6b33a4:

    # me "Ну хочешь потанцуем?"
    me "那么，想不想跳支舞？"

# game/a4/7ballday.rpy:426
translate english ballday5_bf613fc9:

    # lia "М?"
    lia "嗯？"

# game/a4/7ballday.rpy:427
translate english ballday5_0f5b8a8c:

    # me "Бал прямо за стенкой, музыку здесь слышно. Тебя приглашает принц. Все как по-настоящему."
    me "舞会就在墙那边，乐声此处也听得见。是王子在邀你。一切皆像真的那般。"

# game/a4/7ballday.rpy:428
translate english ballday5_23ec57ba:

    # lia "Я...с удовольствием."
    lia "我...荣幸之至。"

# game/a4/7ballday.rpy:430
translate english ballday5_ed3820c8:

    # lia "Только я не умею танцевать. Давай просто кружиться."
    lia "只是我不会跳舞。我们就这么转圈吧。"

# game/a4/7ballday.rpy:431
translate english ballday5_54c17f30:

    # me "Ну давай. Погоди... а как ты собиралась танцевать на настоящем балу?"
    me "好，转吧。且慢...你本打算到了真正舞会上怎样跳呢？"

# game/a4/7ballday.rpy:432
translate english ballday5_4f20f599:

    # lia "Не знаю. Приглашала бы только тебя или [elin]."
    lia "不知道。我只会去邀你或[elin]。"

# game/a4/7ballday.rpy:434
translate english ballday5_eeda525a:

    # me "[elin]? Девушкам нельзя танцевать с девушками."
    me "[elin]？女孩子是不能与女孩子跳舞的。"

# game/a4/7ballday.rpy:435
translate english ballday5_bd9b4823:

    # lia "Можно! Для этого есть специальный танец - ванева."
    lia "可以的！有一支专门的舞——叫瓦涅瓦。"

# game/a4/7ballday.rpy:436
translate english ballday5_552ba1a9:

    # me "Откуда ты это знаешь? Ты же не была ни на одном балу."
    me "你这又是从何得知的？你又没去过舞会。"

# game/a4/7ballday.rpy:437
translate english ballday5_91300a69:

    # lia "Я прочитала об этом в книгах."
    lia "我在书里读到过。"

# game/a4/7ballday.rpy:438
translate english ballday5_cad9f35a:

    # me "Знания из книг могут устаревать."
    me "书上的学问会陈旧。"

# game/a4/7ballday.rpy:439
translate english ballday5_92424e45:

    # lia "Это новая книга. Правда там описывался бал на Западе."
    lia "是本新书。只是那里面写的是西方的舞会。"

# game/a4/7ballday.rpy:440
translate english ballday5_98469d44:

    # me "На Западе? Ну там и не такое возможно."
    me "西方？那地方就没什么不可能。"

# game/a4/7ballday.rpy:441
translate english ballday5_a9738429:

    # lia "А ты меня туда когда-нибудь отвезешь?"
    lia "那你有朝一日会带我去那里吗？"

# game/a4/7ballday.rpy:442
translate english ballday5_de5dd677:

    # me "Я?"
    me "我？"

# game/a4/7ballday.rpy:443
translate english ballday5_d47641b3:

    # lia "Ну а кто еще?"
    lia "不然还有谁？"

# game/a4/7ballday.rpy:444
translate english ballday5_2e822d4d:

    # me "Ну не знаю. Твой муж например."
    me "唔，难说。比方说你丈夫。"

# game/a4/7ballday.rpy:446
translate english ballday5_ae2ebc1b:

    # lia "Мой муж? Ты представляешь сколько мне еще ждать? Отец и мать не отдадут меня замуж больной, а я может никогда не выздоровею!"
    lia "我丈夫？你可知我还要等多久？父亲与母亲不会把病弱的我嫁出去，偏生我或许永远也难痊愈！"

# game/a4/7ballday.rpy:447
translate english ballday5_459b2914:

    # me "Не говори глупостей. Ты идешь на поправку."
    me "不许说傻话。你正在好转。"

# game/a4/7ballday.rpy:448
translate english ballday5_1cac0698:

    # lia "Кто тебе такое сказал?"
    lia "这话谁对你说的？"

# game/a4/7ballday.rpy:449
translate english ballday5_4b14af29:

    # me "Мама."
    me "母亲。"

# game/a4/7ballday.rpy:450
translate english ballday5_0d61d4ef:

    # lia "Она врет."
    lia "她在说谎。"

# game/a4/7ballday.rpy:451
translate english ballday5_42d2a2e6:

    # me "Я же помню, какой ты была, когда я уезжал, ты выглядишь лучше."
    me "我可记得我离开时你的模样，你气色已好了许多。"

# game/a4/7ballday.rpy:452
translate english ballday5_fb28ceed:

    # lia "Все равно никто на мне не женится. Я неполноценная. Кто захочет меня взять в жены, если я даже ребенка родить не смогу."
    lia "反正也不会有谁娶我。我是个残破之人。谁会想要一个连子嗣都生不出的妻子。"

# game/a4/7ballday.rpy:453
translate english ballday5_30f180b8:

    # me "С чего ты это взяла. У тебя бывает кровь?"
    me "你打哪儿得出这念头。你会有流血吗？"

# game/a4/7ballday.rpy:454
translate english ballday5_a1a5c9c1:

    # lia "Какая кровь? Из носа?"
    lia "什么血？鼻血吗？"

# game/a4/7ballday.rpy:455
translate english ballday5_4d28f609:

    # me "Не из носа."
    me "不是鼻血。"

# game/a4/7ballday.rpy:456
translate english ballday5_312df1c2:

    # lia "А какая кровь? Откуда...ааа...ну да...бывает..."
    lia "那是什么血？从哪里...啊啊...嗯，是...会有的..."

# game/a4/7ballday.rpy:457
translate english ballday5_c7b7322e:

    # me "Значит ты можешь забеременеть. Если ты конечно мне не соврала."
    me "那你是能怀身孕的。当然，假若你没欺蒙我的话。"

# game/a4/7ballday.rpy:459
translate english ballday5_17d9dd70:

    # lia "Не соврала. Могу показать тебе простыни, когда это в следующий раз произойдет."
    lia "没有欺蒙。下回发生的时候，我可将床单给你看。"

# game/a4/7ballday.rpy:460
translate english ballday5_07e00415:

    # me "Не нужно, я тебе верю."
    me "不必了，我信你。"

# game/a4/7ballday.rpy:461
translate english ballday5_20601541:

    # lia "Ты правда думаешь, что кто-то возьмет меня в жены?"
    lia "你真以为会有人愿娶我吗？"

# game/a4/7ballday.rpy:462
translate english ballday5_f940b526:

    # me "Правда. Еще пару лет и ты будешь полностью здорова. Не хуже меня это точно."
    me "真的。再过两三年，你便能全然康健。这一点绝不会比我差。"

# game/a4/7ballday.rpy:463
translate english ballday5_c52ba726:

    # lia "А ты на мне можешь жениться?"
    lia "那你能不能娶我呢？"

# game/a4/7ballday.rpy:464
translate english ballday5_70b25e56:

    # me "Не могу, мы же брат и сестра."
    me "不能，我们是兄妹。"

# game/a4/7ballday.rpy:465
translate english ballday5_ec9e2a3e:

    # lia "Ой, точно. А ты возьмешь меня на Север, когда женишься на Авроре?"
    lia "噢，可不是。那你娶了Aurora的话，会带上我去北方吗？"

# game/a4/7ballday.rpy:466
translate english ballday5_293855c3:

    # me "Почему на Авроре?"
    me "怎么单提Aurora？"

# game/a4/7ballday.rpy:467
translate english ballday5_3538895c:

    # lia "А она мне больше нравится. Мы с ней вместе читали книги."
    lia "因为我更喜欢她。我们曾在一处读书。"

# game/a4/7ballday.rpy:468
translate english ballday5_5793e71b:

    # me "Да ладно. Она мне не рассказывала."
    me "竟有这事。她没同我说起过。"

# game/a4/7ballday.rpy:469
translate english ballday5_220ae1c5:

    # lia "Она очень хорошая. Бери в жены ее."
    lia "她人品极好。你就娶她吧。"

# game/a4/7ballday.rpy:470
translate english ballday5_69af009c:

    # me "Я учту твои рекомендации..."
    me "你的建言我记下了..."

# game/a4/7ballday.rpy:471
translate english ballday5_19e75cc5:

    # lia "А вы будете целоваться, когда поженитесь? А вы будете делать детей? А вы будете..."
    lia "你们婚后会接吻吗？会生小宝宝吗？会..."

# game/a4/7ballday.rpy:472
translate english ballday5_c4b43ce6:

    # me "Эм... успокойся, [lia]."
    me "呃...安静些，[lia]。"

# game/a4/7ballday.rpy:473
translate english ballday5_8cd629e0:

    # lia "А меня поцелуешь? Пожалуйста! Пожалуйста! Пожалуйста! Пожалуйста!"
    lia "那你肯不肯亲我呢？求你！求你！求你！"

# game/a4/7ballday.rpy:474
translate english ballday5_519239fc:

    # me "Один раз."
    me "就亲一次。"

# game/a4/7ballday.rpy:476
translate english ballday5_1f8673fc:

    # me "[lia]?"
    me "[lia]?"

# game/a4/7ballday.rpy:477
translate english ballday5_bf613fc9_1:

    # lia "М?"
    lia "嗯？"

# game/a4/7ballday.rpy:478
translate english ballday5_489998a1:

    # me "Что ты делаешь?"
    me "你做什么？"

# game/a4/7ballday.rpy:479
translate english ballday5_5e4bfc05:

    # lia "Я хочу взрослый поцелуй."
    lia "我想要大人那样的吻。"

# game/a4/7ballday.rpy:480
translate english ballday5_246bd9f8_1:

    # me "[lia]..."
    me "[lia]..."

# game/a4/7ballday.rpy:482
translate english ballday5_60acb391:

    # lia "Прости..."
    lia "对不住..."

# game/a4/7ballday.rpy:483
translate english ballday5_3a59da50:

    # me "Все нормально."
    me "没关系的。"

# game/a4/7ballday.rpy:484
translate english ballday5_39fb6a1f:

    # lia "Это так тяжело... ты не представляешь...я всю жизнь смотрю на то как люди делают то, что мне нельзя. И я даже не знаю, почувствую ли я когда-нибудь это или просто умру."
    lia "这太煎熬了...你想象不到...我一生都在看着旁人行那我所不能为之事。我甚至不晓得，我究竟能不能有感受这的一日，还是就这么死了。"

# game/a4/7ballday.rpy:485
translate english ballday5_cac94aa5:

    # me "Ты не умрешь."
    me "你不会死的。"

# game/a4/7ballday.rpy:486
translate english ballday5_34312f9b:

    # lia "Может и не умру. Но состарюсь, так и не узнав, каково это...жить."
    lia "或许不死。但会老去，仍不知那...真正活过的滋味是什么。"

# game/a4/7ballday.rpy:487
translate english ballday5_538ec64d:

    # me "{i}Ты рвешь мне сердце.{/i}"
    me "{i}你教我心都碎了。{/i}"

# game/a4/7ballday.rpy:488
translate english ballday5_7dd97919:

    # lia "Я бы все отдала, чтобы узнать каково это..."
    lia "我情愿舍掉一切，只为尝到那种滋味..."

# game/a4/7ballday.rpy:489
translate english ballday5_2fa6dfab:

    # me "Каково что?"
    me "哪种滋味？"

# game/a4/7ballday.rpy:490
translate english ballday5_2eeedba5:

    # lia "Что угодно. Что я не чувствовала до этого. Я жажду этого, понимаешь, всего чего у меня нет."
    lia "随便什么。我此前从未感受过的。我渴望着它，你可明白，所有我没有的那些。"

# game/a4/7ballday.rpy:491
translate english ballday5_bc3975c8:

    # me "Понимаю, малышка."
    me "我明白，小东西。"

# game/a4/7ballday.rpy:496
translate english ballday5_c6e1af6e:

    # me "{i}Так, сначала позаботимся о безопасности.{/i}"
    me "{i}好，先保得周全。{/i}"

# game/a4/7ballday.rpy:497
translate english ballday5_6531d605:

    # me "{i}Неожиданные гости сейчас тут точно будут лишними.{/i}"
    me "{i}这会儿若有不速之客，可就大为扫兴了。{/i}"

# game/a4/7ballday.rpy:499
translate english ballday5_8ad4f2d3:

    # lia "Ой! Ты чего?"
    lia "呀！你做什么？"

# game/a4/7ballday.rpy:500
translate english ballday5_b2979ca6:

    # me "Так. Я возможно сейчас сделаю серьезную ошибку, но ты сама напросилась, понятно?"
    me "这样。眼下我或许要犯下大错，却是你自己讨来的，明白吗？"

# game/a4/7ballday.rpy:501
translate english ballday5_d857597d:

    # lia "Ой ты будешь меня целовать по-взрослому?"
    lia "呀，你要用大人的法子亲我了吗？"

# game/a4/7ballday.rpy:502
translate english ballday5_6e803a6e:

    # me "Ты хочешь что-то, что никогда не испытывала?"
    me "你想要些从未体验过的滋味，对么？"

# game/a4/7ballday.rpy:503
translate english ballday5_9ff10a85:

    # lia "ХОЧУ!"
    lia "想要！"

# game/a4/7ballday.rpy:504
translate english ballday5_4b54305d:

    # me "Ты когда-нибудь испытывала оргазм?"
    me "你可曾体验过高潮？"

# game/a4/7ballday.rpy:505
translate english ballday5_2084a2d2:

    # lia "Нет."
    lia "没有。"

# game/a4/7ballday.rpy:506
translate english ballday5_2838fb6f:

    # me "А ты знаешь что это такое?"
    me "那你可知道何谓高潮？"

# game/a4/7ballday.rpy:507
translate english ballday5_a4145676:

    # lia "Эм...это когда..."
