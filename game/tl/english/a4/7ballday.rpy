# game/a4/7ballday.rpy:148
translate english ballday_sisdance_7f9e404a:

    # me "{i}Я уже танцевал с ней.{/i}"
    me "{i}我已同她跳过舞了。{/i}"

# game/a4/7ballday.rpy:152
translate english ballday_sisdance_4d96ed9d:

    # lockhart "Балы устраивают - это мое мнение."
    lockhart "依我看，办什么舞会。"

# game/a4/7ballday.rpy:153
