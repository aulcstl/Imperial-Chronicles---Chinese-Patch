# game/a4/11ball_end.rpy:4
translate english ball_end_25f37e34:

    # me "{i}Сегодня был по-настоящему насыщенный день.{/i}"
    me "{i}今天真是充实的一天。{/i}"

# game/a4/11ball_end.rpy:5
translate english ball_end_de35e0c7:

    # me "{i}Не то чтобы я много танцевал, но я определенно устал.{/i}"
    me "{i}倒不是说跳了很多舞，但我确实累了。{/i}"

# game/a4/11ball_end.rpy:6
translate english ball_end_0406634f:

    # me "{i}Устал, но почему-то все равно не хочу спать. Кажется все эти новые впечатления меня слегка перевозбудили.{/i}"
    me "{i}累了，但不知为何还是不想睡。大概是这些新印象让我有点过度兴奋了。{/i}"

# game/a4/11ball_end.rpy:8
translate english ball_end_99dbce59:

    # cass "Ты чего стоишь здесь, [mename]?"
    cass "你站在这里干什么，[mename]？"

# game/a4/11ball_end.rpy:9
translate english ball_end_99334025:

    # me "Ты...как ты так бесшумно подкралась?"
    me "你……你怎么能这么悄无声息地靠近？"

# game/a4/11ball_end.rpy:10
translate english ball_end_44158426:

    # cass "Я уже давно тренируюсь незаметно убивать наследных принцев. А легкая поступь это базис, с этого начинают обучение."
    cass "我早就训练过如何神不知鬼不觉地干掉王储。悄无声息的脚步是基本功，训练就从这里开始。"

# game/a4/11ball_end.rpy:11
translate english ball_end_7b2d4123:

    # me "И много наследных принцев ты уже убила?"
    me "那你已经干掉多少个王储了？"

# game/a4/11ball_end.rpy:12
translate english ball_end_0a2f821b:

    # cass "Хочешь стать первым?"
    cass "想当第一个吗？"

# game/a4/11ball_end.rpy:13
translate english ball_end_52dd7299:

    # me "Пожалуй откажусь."
    me "还是免了吧。"

# game/a4/11ball_end.rpy:14
translate english ball_end_651ccc28:

    # cass "..."
    cass "..."

# game/a4/11ball_end.rpy:15
translate english ball_end_3820771a:

    # me "..."
    me "..."

# game/a4/11ball_end.rpy:16
translate english ball_end_f6fb32fc:

    # cass "Бал закончился, ты чего не спишь?"
    cass "舞会结束了，你怎么不睡？"

# game/a4/11ball_end.rpy:17
translate english ball_end_c24b5dd8:

    # me "Не хочется."
    me "不想睡。"

# game/a4/11ball_end.rpy:18
translate english ball_end_7875cbd2:

    # cass "Понимаю."
    cass "我懂。"

# game/a4/11ball_end.rpy:19
translate english ball_end_b6626098:

    # me "А?"
    me "啊？"

# game/a4/11ball_end.rpy:20
translate english ball_end_caef1333:

    # cass "Это ведь твой первый бал?"
    cass "这是你第一次参加舞会吧？"

# game/a4/11ball_end.rpy:21
translate english ball_end_fc30fd2b:

    # me "Да."
    me "是的。"

# game/a4/11ball_end.rpy:23
translate english ball_end_724a1983:

    # cass "Перед моим первым балом я была так взволнована, что у меня тряслись руки."
    cass "我第一次参加舞会之前，紧张得手都在抖。"

# game/a4/11ball_end.rpy:24
translate english ball_end_e2c5b0b3:

    # me "Ты тоже не умела танцевать?"
    me "你也不会跳舞吗？"

# game/a4/11ball_end.rpy:25
translate english ball_end_71fa75c1:

    # cass "Я? Я умела. Меня учили этому. Дело не в этом. Я была маленькой девочкой. Маленькой девочкой без глаза с дурной репутацией. Я все думала, что все будут на меня пялиться."
    cass "我吗？我会跳。我学过。不是因为这个。那时我还是个小女孩。一个只有一只眼睛、名声很糟的小女孩。我一直在想，所有人都会盯着我看。"

# game/a4/11ball_end.rpy:26
translate english ball_end_86e1f1e2:

    # cass "Я боялась, что молодые дворяне ни за что не будут приглашать меня на танец."
    cass "我害怕那些年轻贵族绝对不会请我跳舞。"

# game/a4/11ball_end.rpy:27
translate english ball_end_f95c9fc9:

    # me "И?"
    me "然后呢？"

# game/a4/11ball_end.rpy:28
translate english ball_end_63d6a9c3:

    # cass "Я боялась напрасно, я не успевала закончить танец, прежде чем меня приглашали на новый. Люди смеялись и улыбались мне. В конце вечера я плакала от счастья."
    cass "我白担心了。我一支舞还没跳完就又有人来请了。人们对我笑着，朝我微笑。那晚结束时，我开心得哭了。"

# game/a4/11ball_end.rpy:29
translate english ball_end_5d20e8bb:

    # me "Не ожидал услышать от тебя такой...позитивной истории."
    me "真没想到会从你这儿听到这么……正面的故事。"

# game/a4/11ball_end.rpy:30
translate english ball_end_091ed83e:

    # cass "Это еще не конец. Были еще балы. Я приходила на них и с каждым разом все отчетливее понимала - это были маски. Они не были добры ко мне, я была птицей, упавшей в яму к змеям."
    cass "这还没完。后来还有别的舞会。我一次次去，就越来越清楚地明白——那些都是面具。他们对我的好不是真的，我就像只掉进蛇坑的鸟。"

# game/a4/11ball_end.rpy:31
translate english ball_end_2e910765:

    # cass "Они не знали, что я из себя представляю, поэтому они хотели сначала ко мне присмотреться, понять, можно ли меня укусить."
    cass "他们不知道我到底是什么样的人，所以想先好好打量我，看看能不能咬我一口。"

# game/a4/11ball_end.rpy:32
translate english ball_end_03efae8f:

    # cass "Их улыбки смех сменились злобными перешептываниями. Все чаще я стала видеть на лицах, приглашающих меня на танец молодых дворян, усталость и нетерпение."
    cass "他们的笑容和笑声变成了恶毒的窃窃私语。我越来越常看到那些请我跳舞的年轻贵族脸上露出疲惫和不耐烦。"

# game/a4/11ball_end.rpy:33
translate english ball_end_5fd2f7f8:

    # cass "Они не хотели танцевать со мной, они желали показать себя перед отцом, но чем сильнее он охладевал ко мне, тем реже меня приглашали на танец."
    cass "他们不是想跟我跳舞，他们是想在父亲面前表现自己。可他对我越来越冷淡，请我跳舞的人也就越来越少了。"

# game/a4/11ball_end.rpy:34
translate english ball_end_651ccc28_1:

    # cass "..."
    cass "..."

# game/a4/11ball_end.rpy:35
translate english ball_end_92a6ea4d:

    # me "Мне жаль..."
    me "我真遗憾……"

# game/a4/11ball_end.rpy:36
translate english ball_end_7187bff2:

    # cass "Жаль? Меня? Это величайший подарок судьбы, если бы не эти балы, я бы возненавидела всех этих лицемерных ублюдков позже нужного. Не успела бы отрастить толстую кожу, чтобы защищаться от их укусов."
    cass "遗憾？为我？这是命运最伟大的馈赠。要不是这些舞会，我恨透那些虚伪杂种的时间就会更晚，就来不及长出厚皮去抵御他们的撕咬。"

# game/a4/11ball_end.rpy:37
translate english ball_end_beb3c104:

    # me "Все равно это жестоко, неужели люди готовы были так поступать с ребенком?"
    me "那可太残忍了，人真的会对一个孩子做出这种事？"

# game/a4/11ball_end.rpy:38
translate english ball_end_2c879a4f:

    # cass "Эй, да хер с ними. Хочешь посмотреть на восход солнца из южной башни, как в детстве?"
    cass "哎，去他们的吧。想不想去南塔楼看日出，就像小时候那样？"

# game/a4/11ball_end.rpy:39
translate english ball_end_2079b8cd:

    # me "Да, давай."
    me "好啊，走吧。"

# game/a4/11ball_end.rpy:43
translate english ball_end_43b88d23:

    # me "Пойдем, только я кое-что тебе хочу дать."
    me "走，不过有样东西我想先给你。"

# game/a4/11ball_end.rpy:46
translate english ball_end_88d422cf:

    # me "{i}Пусть это кольцо останется со мной.{/i}"
    me "{i}让这枚戒指留在我身边吧。{/i}"

# game/a4/11ball_end.rpy:51
translate english ball_end2_51b4bb76:

    # me "Знаешь, что это такое?"
    me "知道这是什么吗？"

# game/a4/11ball_end.rpy:52
translate english ball_end2_4d0684e0:

    # cass "Ага. Принц-кольцо. Ты никому его не подарил на балу?"
    cass "嗯。王子之戒。你在舞会上没把它送给谁吗？"

# game/a4/11ball_end.rpy:53
translate english ball_end2_364dfc16:

    # me "Не нашел достойных кандидатов. А сейчас понял, что хочу подарить его тебе."
    me "没找到配得上的人。现在才明白，我想把它送给你。"

# game/a4/11ball_end.rpy:54
translate english ball_end2_16d9e36e:

    # cass "Мне? Зачем?"
    cass "给我？为什么？"

# game/a4/11ball_end.rpy:55
translate english ball_end2_df597615:

    # me "Кольцо дарят достойнейшей. Для меня это ты."
    me "戒指要献给最杰出的人。对我来说，那个人就是你。"

# game/a4/11ball_end.rpy:57
translate english ball_end2_c7254d48:

    # cass "Ты уверен?"
    cass "你确定？"

# game/a4/11ball_end.rpy:58
translate english ball_end2_3fac7c3e:

    # me "Уверен."
    me "确定。"

# game/a4/11ball_end.rpy:59
translate english ball_end2_69eb107b:

    # cass "Но...почему я? Это из-за слезливой истории, которую я рассказала?"
    cass "可……为什么是我？就因为我讲了那个可怜兮兮的故事？"

# game/a4/11ball_end.rpy:60
translate english ball_end2_5a7a7577:

    # me "Нет."
    me "不是。"

# game/a4/11ball_end.rpy:61
translate english ball_end2_8d7854b4:

    # cass "Хочешь меня трахнуть?"
    cass "你想上我？"

# game/a4/11ball_end.rpy:62
translate english ball_end2_462a7a2d:

    # me "Что? Это тут при чем?"
    me "什么？这跟那有什么关系？"

# game/a4/11ball_end.rpy:63
translate english ball_end2_1c7a41e2:

    # cass "Тогда почему я?"
    cass "那为什么是我？"

# game/a4/11ball_end.rpy:64
translate english ball_end2_ca7e17f7:

    # me "Я не обязан отвечать."
    me "我没义务回答。"

# game/a4/11ball_end.rpy:66
translate english ball_end2_898be74b:

    # cass "Ну и нахуй это говно!"
    cass "那这破玩意儿就滚蛋！"

# game/a4/11ball_end.rpy:67
translate english ball_end2_a4d2b1c8:

    # me "Ты чего?"
    me "你干什么？"

# game/a4/11ball_end.rpy:68
translate english ball_end2_28efeaf4:

    # cass "Ты мне его подарил, значит оно мое и я могу делать с этим кольцом что угодно."
    cass "你把它送给了我，那它就是我的了，我想拿这戒指做什么就做什么。"

# game/a4/11ball_end.rpy:69
translate english ball_end2_c72df875:

    # me "И поэтому ты решила его выбросить."
    me "所以你就决定把它扔掉。"

# game/a4/11ball_end.rpy:70
translate english ball_end2_934fc423:

    # cass "Верно. Нахуй это говно."
    cass "没错。这破东西滚蛋。"

# game/a4/11ball_end.rpy:71
translate english ball_end2_1dd13efc:

    # me "К чему такая ненависть к кольцу?"
    me "你对这戒指怎么这么大恨意？"

# game/a4/11ball_end.rpy:72
translate english ball_end2_d918dffb:

    # cass "Ненависть не к кольцу, а к тому, для чего оно сделано. Это кольцо - повод идиотам в дорогих тряпках посудачить об этом еще неделю."
    cass "我恨的不是戒指，是它存在的意义。这东西就是让那些穿金戴银的白痴再嚼一个礼拜舌头。"

# game/a4/11ball_end.rpy:73
translate english ball_end2_411aa6f7:

    # me "Я же подарил тебе его наедине."
    me "我可是私下把它送给你的。"

# game/a4/11ball_end.rpy:75
translate english ball_end2_4cb6ad74:

    # cass "И я ценю это и уважаю, [mename]. Но и ты уважай мое решение."
    cass "这我领情，也尊重，[mename]。但你也得尊重我的决定。"

# game/a4/11ball_end.rpy:76
translate english ball_end2_40dc3372:

    # me "Ну ладно...может обрадуешь какого-нибудь слугу-садовника."
    me "那好吧……也许你可以去逗某个花匠仆人开心。"

# game/a4/11ball_end.rpy:77
translate english ball_end2_9cb98882:

    # cass "[mename]..."
    cass "[mename]..."

# game/a4/11ball_end.rpy:78
translate english ball_end2_dfcceeac:

    # me "М?"
    me "嗯？"

# game/a4/11ball_end.rpy:79
translate english ball_end2_9568118b:

    # cass "Спасибо...брат."
    cass "谢谢……哥哥。"

# game/a4/11ball_end.rpy:80
translate english ball_end2_a66b3fc0:

    # me "Я уже давно не видел тебя такой нежной, по-моему, ты в последний раз обнимала меня еще когда у тебя был цел второй глаз."
    me "好久没见你这么温柔了，我觉得上次你抱我的时候，你另一只眼睛还在呢。"

# game/a4/11ball_end.rpy:81
translate english ball_end2_b57b219c:

    # cass "Заткнись и получай редкое удовольствие."
    cass "闭嘴，好好享受这难得的待遇。"

# game/a4/11ball_end.rpy:82
translate english ball_end2_01822020:

    # me "Ладно."
    me "好吧。"

# game/a4/11ball_end.rpy:84
translate english ball_end2_0e5909eb:

    # cass "Я тут подумала, раз уж ты обозначил меня кольцом..."
    cass "我刚在想，既然你用戒指认定了我……"

# game/a4/11ball_end.rpy:85
translate english ball_end2_c279c66b:

    # me "Которое ты выбросила."
    me "可你把它扔了。"

# game/a4/11ball_end.rpy:86
translate english ball_end2_6b081924:

    # cass "Которое я выбросила, да. Наверное ты на что-то рассчитывал."
    cass "是扔了，没错。你大概也是有所期待的。"

# game/a4/11ball_end.rpy:87
translate english ball_end2_626afde1:

    # me "Что? Ни на что я не рассчитывал."
    me "什么？我什么也没期待。"

# game/a4/11ball_end.rpy:88
translate english ball_end2_a9fe35e8:

    # cass "Правда?"
    cass "真的？"

# game/a4/11ball_end.rpy:89
translate english ball_end2_dae36352:

    # me "Правда."
    me "真的。"

# game/a4/11ball_end.rpy:90
translate english ball_end2_3af93b76:

    # cass "Даже на поцелуй? Потому что я не против."
    cass "连个吻也没期待？因为我不介意。"

# game/a4/11ball_end.rpy:91
translate english ball_end2_e3134d04:

    # me "Ну...и я не против."
    me "呃……我也不介意。"

# game/a4/11ball_end.rpy:93
translate english ball_end2_db0b6c55:

    # cass "Тю-тю-тю. Куда ты?"
    cass "啧啧啧，你往哪儿去？"

# game/a4/11ball_end.rpy:94
translate english ball_end2_bdd1294d:

    # me "Поцеловать тебя. Ты же сама сказала..."
    me "吻你啊。你自己说的……"

# game/a4/11ball_end.rpy:95
translate english ball_end2_a2052978:

    # cass "Я не обычная принцесса, [mename], а значит меня нужно целовать в необычное место."
    cass "我可不是普通公主，[mename]，所以要吻就得吻在不寻常的地方。"

# game/a4/11ball_end.rpy:96
translate english ball_end2_e473fa2f:

    # me "Например?"
    me "比如说？"

# game/a4/11ball_end.rpy:97
translate english ball_end2_ea773635:

    # cass "Опустись на колени и там уже действуй по обстоятельствам."
    cass "跪下，然后见机行事。"

# game/a4/11ball_end.rpy:99
translate english ball_end2_bb1cf006:

    # me "Ну? "
    me "怎么样？"

# game/a4/11ball_end.rpy:100
translate english ball_end2_1566afcf:

    # cass "Да. Это хорошее место."
    cass "嗯。这地方不错。"

# game/a4/11ball_end.rpy:101
translate english ball_end2_3820771a:

    # me "..."
    me "..."

# game/a4/11ball_end.rpy:103
translate english ball_end2_c0ae9270:

    # cass "Ты все же хочешь меня трахнуть, верно?"
    cass "你还是想上我，对吧？"

# game/a4/11ball_end.rpy:104
translate english ball_end2_0f1517b5:

    # me "С чего ты это взяла?"
    me "你从哪儿得出的结论？"

# game/a4/11ball_end.rpy:105
translate english ball_end2_6048b2b3:

    # cass "У меня есть глаза и я вижу ими, как ты целуешь мой живот."
    cass "我有眼睛，我看得见你在怎么亲我的肚子。"

# game/a4/11ball_end.rpy:107
translate english ball_end2_94bdf928:

    # me "Хорошая манипуляция, но я напоминаю, что и поцелуй и его место выбирала ты. Может это ты хочешь меня трахнуть?"
    me "好一手操控，可我提醒你，接吻和接吻的部位都是你选的。说不定是你在想上我呢？"

# game/a4/11ball_end.rpy:108
translate english ball_end2_c85fa3b2:

    # cass "Сначала хочу оценить твои навыки."
    cass "我想先评估一下你的本事。"

# game/a4/11ball_end.rpy:109
translate english ball_end2_e473fa2f_1:

    # me "Например?"
    me "比如？"

# game/a4/11ball_end.rpy:110
translate english ball_end2_7b9487c3:

    # cass "Например попробуй использовать язык."
    cass "比如试着用舌头。"

# game/a4/11ball_end.rpy:112
translate english ball_end2_bb910f07:

    # me "Так?"
    me "这样？"

# game/a4/11ball_end.rpy:113
translate english ball_end2_d5cf8912:

    # cass "Ага. У тебя отлично получается."
    cass "嗯。你做得真好。"

# game/a4/11ball_end.rpy:114
translate english ball_end2_4933553f:

    # me "Я просто представляю что ем огромный сладкий десерт."
    me "我就当是在吃一个巨大的甜点。"

# game/a4/11ball_end.rpy:115
translate english ball_end2_9cceb8f9:

    # cass "[mename]."
    cass "[mename]."

# game/a4/11ball_end.rpy:116
translate english ball_end2_dfcceeac_1:

    # me "М?"
    me "嗯？"

# game/a4/11ball_end.rpy:117
translate english ball_end2_b02792be:

    # cass "Я в последнее время часто думаю о том, что мы не сильно и отличаемся."
    cass "最近我常想，我们其实没有多大不同。"

# game/a4/11ball_end.rpy:118
translate english ball_end2_473c9b2b:

    # me "Ты так думаешь?"
    me "你这么想的？"

# game/a4/11ball_end.rpy:119
translate english ball_end2_57c55a72:

    # cass "Если честно, я просто тебя испытывала, не думала, что ты правда начнешь лизать мне живот."
    cass "老实说，我只是在试探你，没想到你真会舔我肚子。"

# game/a4/11ball_end.rpy:120
translate english ball_end2_1ad72893:

    # me "Мне остановиться?"
    me "要停下来吗？"

# game/a4/11ball_end.rpy:121
translate english ball_end2_b7c8f5f0:

    # cass "Да."
    cass "要。"

# game/a4/11ball_end.rpy:122
translate english ball_end2_fa9085d7:

    # me "Я не хочу."
    me "我不想。"

# game/a4/11ball_end.rpy:123
translate english ball_end2_bf217ebc:

    # cass "Хех. Из этого определенно что-то выйдет, ты так не считаешь."
    cass "呵。这肯定能发展出点什么来，你不觉得吗。"

# game/a4/11ball_end.rpy:124
translate english ball_end2_d355dc3b:

    # me "О чем ты?"
    me "你指什么？"

# game/a4/11ball_end.rpy:125
translate english ball_end2_bfb357f7:

    # cass "О нас..."
    cass "我们之间……"

# game/a4/11ball_end.rpy:127
translate english ball_end2_98a0d5e8:

    # me "Если ты решила меня убить, то сейчас неудачный момент."
    me "要是你现在想杀我，时机可不怎么好。"

# game/a4/11ball_end.rpy:128
translate english ball_end2_feb5461f:

    # cass "Я хочу кое-что почувствовать."
    cass "我想感觉点什么。"

# game/a4/11ball_end.rpy:129
translate english ball_end2_76b46c82:

    # me "Надеюсь не то, как кинжал входит в плоть."
    me "希望不是匕首刺入身体的感觉。"

# game/a4/11ball_end.rpy:131
translate english ball_end2_fbc1866b:

    # cass "Почти. Держи."
    cass "差不多。拿着。"

# game/a4/11ball_end.rpy:132
translate english ball_end2_7332342b:

    # me "Зачем?"
    me "干嘛？"

# game/a4/11ball_end.rpy:133
translate english ball_end2_a1eae0cd:

    # cass "Помнишь как мы с тобой встретились у хижины в лесу? Тогда я приставила кинжал к твоей шее."
    cass "记得我们在森林小屋旁碰面的那次吗？当时我把匕首抵在你脖子上。"

# game/a4/11ball_end.rpy:134
translate english ball_end2_f95c9fc9:

    # me "И?"
    me "那又怎样？"

# game/a4/11ball_end.rpy:135
translate english ball_end2_babc8ece:

    # cass "Хочу почувствовать каково это. Каково это когда тот, у кого есть мотивы тебя убить, держит тебя на волоске от смерти..."
    cass "我想体验一下那是什么感觉。一个你有动机杀的人，让你命悬一线……"

# game/a4/11ball_end.rpy:136
translate english ball_end2_b3d7d1ea:

    # me "У меня нет мотивов тебя убить."
    me "我没有杀你的动机。"

# game/a4/11ball_end.rpy:137
translate english ball_end2_dc58ecf5:

    # cass "Есть. Ты просто о них пока не знаешь."
    cass "你有。只是现在还不知道。"

# game/a4/11ball_end.rpy:139
translate english ball_end2_bf3e0682:

    # me "[cass]..."
    me "[cass]..."

# game/a4/11ball_end.rpy:140
translate english ball_end2_651ccc28:

    # cass "..."
    cass "..."

# game/a4/11ball_end.rpy:141
translate english ball_end2_f1f1405b:

    # me "[cass]!"
    me "[cass]!"

# game/a4/11ball_end.rpy:142
translate english ball_end2_d604a664:

    # cass "Ну что?"
    cass "怎么样？"

# game/a4/11ball_end.rpy:143
translate english ball_end2_566e4f18:

    # me "У тебя кровь...хватит."
    me "你流血了……够了。"

# game/a4/11ball_end.rpy:144
translate english ball_end2_a4c8e513:

    # cass "Ладно. Но мы когда-нибудь это повторим."
    cass "好吧。但我们改天还要再试。"

# game/a4/11ball_end.rpy:145
translate english ball_end2_7a4f0d06:

    # me "Пойдем уже смотреть на закат."
    me "现在去看日落吧。"

# game/a4/11ball_end.rpy:149
translate english ball_end3_7edf36cf:

    # cass "Помнишь, как мы впервые сюда забрались?"
    cass "还记得我们第一次爬到这里的情形吗？"

# game/a4/11ball_end.rpy:150
translate english ball_end3_1f0ca6de:

    # me "Еще бы. [elin] испугалась и пыталась нас отговорить. Но мы все равно сюда поднялись."
    me "当然。[elin]吓坏了，想劝我们别去。可我们还是上来了。"

# game/a4/11ball_end.rpy:151
translate english ball_end3_38be9397:

    # cass "Мы думали здесь хранятся всякие древние артефакты, а тут оказался только колокол."
    cass "我们以为这儿藏着什么古代神器，结果只有一口钟。"

# game/a4/11ball_end.rpy:152
translate english ball_end3_58e6225e:

    # me "Еще я помню, как смотритель подумал, что забыл закрыть дверь и случайно запер нас здесь."
    me "还记不记得看守以为自己忘了锁门，结果不小心把我们锁在了这里。"

# game/a4/11ball_end.rpy:153
translate english ball_end3_0cbe5293:

    # cass "Случайно? Этот старик сделал это специально."
    cass "不小心？那老头是故意的。"

# game/a4/11ball_end.rpy:154
translate english ball_end3_473c9b2b:

    # me "Ты так думаешь?"
    me "你这么想的？"

# game/a4/11ball_end.rpy:155
translate english ball_end3_4520839e:

    # cass "Забыл, как мы кричали и бились в дверь?"
    cass "你忘了我们怎么砸门叫喊的？"

# game/a4/11ball_end.rpy:156
translate english ball_end3_2d371880:

    # me "Может он не слышал."
    me "也许他没听见。"

# game/a4/11ball_end.rpy:158
translate english ball_end3_ded8c3cc:

    # cass "Ну да, конечно. Наверное стоял рядом и дрочил на наши испуганные вопли."
    cass "是啊，当然了。大概他就站在旁边，听着我们害怕的尖叫自慰呢。"

# game/a4/11ball_end.rpy:159
translate english ball_end3_c5dc2684:

    # me "Ну зато мы тогда впервые насладились рассветом."
    me "不过那次我们第一次欣赏了日出。"

# game/a4/11ball_end.rpy:160
translate english ball_end3_6ec9af7f:

    # cass "Наслаждалась рассветом только я, ты забился в угол и плакал, думая, что нас никогда не найдут и мы здесь умрем."
    cass "欣赏日出的只有我，你缩在角落里哭，以为永远没人发现我们，我们会死在这儿。"

# game/a4/11ball_end.rpy:161
translate english ball_end3_31b74bf5:

    # me "Да? Я этого не помню."
    me "是吗？我不记得了。"

# game/a4/11ball_end.rpy:162
translate english ball_end3_67f0acdd:

    # cass "Ну конечно. Мужчины не запоминают моменты своей слабости."
    cass "当然。男人不会记住自己软弱的时刻。"

# game/a4/11ball_end.rpy:163
translate english ball_end3_34231b68:

    # me "Шутишь? Только такое мы и помним."
    me "开什么玩笑？我们只记得这种事。"

# game/a4/11ball_end.rpy:164
translate english ball_end3_88e44e54:

    # cass "Хорошо, что [elin] никому ничего не рассказала и открыла нас утром сама."
    cass "还好[elin]什么都没说，一大早自己就来给我们开了门。"

# game/a4/11ball_end.rpy:165
translate english ball_end3_3cc6e351:

    # me "Ага. Еще чуть-чуть и нам пришлось бы гадить прямо с башни."
    me "是啊。再久一点我们就得直接从塔楼往外拉了。"

# game/a4/11ball_end.rpy:167
translate english ball_end3_10ed4db5:

    # cass "Ах, вот и он, рассвет, появился прямо под разговоры о дерьме."
    cass "啊，看，日出，正好在聊屎的时候出来了。"

# game/a4/11ball_end.rpy:168
translate english ball_end3_69d4e7b9:

    # me "Красиво."
    me "真美。"

# game/a4/11ball_end.rpy:169
translate english ball_end3_60d1d76e:

    # cass "Очень красиво."
    cass "非常美。"

# game/a4/11ball_end.rpy:170
translate english ball_end3_a7cd0db8:

    # me "Рад, что цинизм не отравил в тебе чувство прекрасного."
    me "很高兴愤世嫉俗没有毒害你对美的感觉。"

# game/a4/11ball_end.rpy:171
translate english ball_end3_a9e27679:

    # cass "Ты думаешь это разрушает мою злобную ауру?"
    cass "你觉得这会毁掉我邪恶的气场？"

# game/a4/11ball_end.rpy:172
translate english ball_end3_5001356d:

    # me "Ну немного."
    me "嗯，一点点。"

# game/a4/11ball_end.rpy:173
translate english ball_end3_1074d4ea:

    # cass "Этот рассвет отвратителен."
    cass "这日出糟透了。"

# game/a4/11ball_end.rpy:174
translate english ball_end3_5121f14f:

    # me "Ну конечно...конечно..."
    me "当然……当然……"

# game/a4/11ball_end.rpy:175
translate english ball_end3_b326699a:

    # cass "Да ну тебя."
    cass "去你的。"

translate english strings:

    # game/a4/11ball_end.rpy:41
    old "Подарить ей кольцо"
    new "送给她戒指"

#Elin

    old "Вы отдали принц-кольцо матери.\nОна разозлилась на вас за это решение."
    new "你将王子戒指送给了母亲。\n她因这个决定对你很生气。"

    old "Вы отдали принц-кольцо сестре.\nЕе растрогало ваше решение."
    new "你将王子戒指送给了妹妹。\n你的决定让她深受感动。"

    old "[cass] получила от вас принц-кольцо.\nОна выбросила его."
    new "[cass]从你这里得到了王子戒指。\n她把它扔掉了。"

    old "Вы отдали принц-кольцо Авроре.\nОна отвела вас в храм Безымянного бога."
    new "你将王子戒指送给了欧若拉。\n她带你去了无名之神的神庙。"

    old "Вы отдали принц-кольцо Исиде.\nОна показала вам, на что способна."
    new "你将王子戒指送给了伊西丝。\n她向你展示了自己的本事。"

    old "Вы не стали никому отдавать принц-кольцо."
    new "你没有把王子戒指送给任何人。"

    old "Во время приступа гибридной лихорадки вам привиделась эльфийская богиня и Красный Император."
    new "在一次混合热发作时，你看见了精灵女神和红色皇帝的幻象。"

    old "В скором времени вы должны жениться."
    new "很快你就要结婚了。"

# game/a4/11ball_end.rpy:172
translate english ball_end3_4b09bce5:

    # cass "Ну конечно. Мужчины не запоминают моменты своей слабости."
    cass "当然。男人不会记住自己软弱的时刻。"

