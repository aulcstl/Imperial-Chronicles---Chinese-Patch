# TODO: Translation updated at 2024-05-01 15:47

# game/a4/4ice_vortex.rpy:7
translate english ice_vortex_3f54b090:

    # "Некоторое время спустя"
    "过了一会"

# game/a4/4ice_vortex.rpy:8
translate english ice_vortex_699a2719:

    # me "Привет, это я, [mename]."
    me "嗨，是我，[mename]。"

# game/a4/4ice_vortex.rpy:9
translate english ice_vortex_88f84835:

    # aur "[mename]? Погоди секунду я не одета."
    aur "[mename]？等一下，我还没穿好衣服。"

# game/a4/4ice_vortex.rpy:10
translate english ice_vortex_35d9c255:

    # me "Ладно. Подожду тебя здесь."
    me "好的。我在这儿等你。"

# game/a4/4ice_vortex.rpy:11
translate english ice_vortex_f63e287c:

    # aur "Я быстро!"
    aur "我很快就好！"

# game/a4/4ice_vortex.rpy:13
translate english ice_vortex_c6f6847f:

    # "Я мог бы использовать магию на дверь и посмотреть, что там..."
    "I could use magic on the door and see what's there..."

# game/a4/4ice_vortex.rpy:17
translate english ice_vortex_5cdbdeb5:

    # me "{i}Duran nauro Laurelin...{/i}"
    me "{i}Duran nauro Laurelin...{/i}"

# game/a4/4ice_vortex.rpy:18
translate english ice_vortex_75bc480c:

    # me "{i}Duran...{/i}"
    me "{i}Duran...{/i}"

# game/a4/4ice_vortex.rpy:19
translate english ice_vortex_c33f209c:

    # me "{i}О, кажется что-то вижу...{/i}"
    me "{i}哦，我好像看到什么了……{/i}"

# game/a4/4ice_vortex.rpy:21
translate english ice_vortex_963ae798:

    # me "{i}Не торопись, я тут пока полюбуюсь видами.{/i}"
    me "{i}别着急，我先在这里欣赏一下风景。{/i}"

# game/a4/4ice_vortex.rpy:22
translate english ice_vortex_690f06d0:

    # me "{i}Жаль на ней ночная рубашка, если бы не она я мог бы оценить ее формы еще до свадьбы.{/i}"
    me "{i}可惜她还穿着睡衣，不然我就能在婚前好好欣赏一下她的身材了。{/i}"

# game/a4/4ice_vortex.rpy:23
translate english ice_vortex_a06f588d:

    # me "{i}Она выглядит взволнованной.{/i}"
    me "{i}她看起来有些激动。{/i}"

# game/a4/4ice_vortex.rpy:24
translate english ice_vortex_b74cf882:

    # me "{i}Я застал ее врасплох?{/i}"
    me "{i}我是不是让她措手不及了？{/i}"

# game/a4/4ice_vortex.rpy:26
translate english ice_vortex_4c382d40:

    # aur "Неведомый, даруй защиту мне и мои близким."
    aur "未知之神，请赐予我和我的亲人庇护。"

# game/a4/4ice_vortex.rpy:27
translate english ice_vortex_3e0be782:

    # me "{i}Она молится?{/i}"
    me "{i}她在祈祷吗？{/i}"

# game/a4/4ice_vortex.rpy:28
translate english ice_vortex_5552e3ef:

    # aur "Стань моим спутником на этот день и веди меня правильным путем."
    aur "今日请做我的向导，指引我走上正确的道路。"

# game/a4/4ice_vortex.rpy:29
translate english ice_vortex_9f2435f0:

    # me "{i}Неведомый? Ах, да, на севере своя вариация веры в неведомых богов, там бог только один.{/i}"
    me "{i}未知之神？哦，对了，在北方，对未知神灵的信仰有其自己的变体，那里只有一位神。{/i}"

# game/a4/4ice_vortex.rpy:30
translate english ice_vortex_e3126436:

    # aur "Я обещаю видеть твои знамения."
    aur "我承诺会留意你的征兆。"

# game/a4/4ice_vortex.rpy:31
translate english ice_vortex_ef6403e3:

    # me "{i}Она явно религиозная, раз молится в одиночестве.{/i}"
    me "{i}她显然很虔诚，一个人时也在祈祷。{/i}"

# game/a4/4ice_vortex.rpy:33
translate english ice_vortex_68cd4d13:

    # me "{i}Закончила молитву.{/i}"
    me "{i}她祈祷完了。{/i}"

# game/a4/4ice_vortex.rpy:34
translate english ice_vortex_5c76dbe7:

    # me "{i}...{/i}"
    me "{i}...{/i}"

# game/a4/4ice_vortex.rpy:35
translate english ice_vortex_95ad0445:

    # me "{i}Отличная попка надо сказать...{/i}"
    me "{i}不得不说，臀型真不错……{/i}"

# game/a4/4ice_vortex.rpy:36
translate english ice_vortex_0d09135f:

    # me "{i}Ладно, она скоро оденется, лучше не стоять прямо у двери.{/i}"
    me "{i}好了，她很快就要换好衣服了，最好别站在门口。{/i}"

# game/a4/4ice_vortex.rpy:39
translate english ice_vortex_2216a480:

    # me "{i}Не..не стоит мне это делать.{/i}"
    me "{i}不……我不该这么做。{/i}"

# game/a4/4ice_vortex.rpy:41
translate english ice_vortex_a59f1e99:

    # me "{i}Погода сегодня отличная.{/i}"
    me "{i}今天天气真好。{/i}"

# game/a4/4ice_vortex.rpy:42
translate english ice_vortex_215b0504:

    # me "{i}Даже не нужно придумывать, чем заняться, что может быть лучше для знакомства, чем конная прогулка?{/i}"
    me "{i}甚至不用费心去想做什么，还有什么比骑马散步更好的相识方式呢？{/i}"

# game/a4/4ice_vortex.rpy:43
translate english ice_vortex_559a8faa:

    # me "{i}Да, это отличная идея. Предложу Авроре, как только она выйдет.{/i}"
    me "{i}对，这主意太棒了。等Aurora一出来就提议。{/i}"

# game/a4/4ice_vortex.rpy:44
translate english ice_vortex_f7fc02aa:

    # me "{i}Только я кажется забыл, где расположены королевские конюшни...{/i}"
    me "{i}只是我好像忘了皇家马厩在哪儿了……{/i}"

# game/a4/4ice_vortex.rpy:46
translate english ice_vortex_970ac219:

    # aur "Привет, прости, что заставила ждать."
    aur "嗨，抱歉让你久等了。"

# game/a4/4ice_vortex.rpy:47
translate english ice_vortex_c1e16f10:

    # me "Все нормально. Мы не уславливались заранее, так что ты не обязана была ждать меня...одетой."
    me "没关系。我们没有提前约好，所以你也没必要……穿戴整齐地等我。"

# game/a4/4ice_vortex.rpy:48
translate english ice_vortex_e4576adc:

    # aur "Кхм-кхм. Наверное..."
    aur "咳咳。大概吧……"

# game/a4/4ice_vortex.rpy:49
translate english ice_vortex_78701810:

    # me "Сегодня такая чудесная погода, ты не против конной прогулки?"
    me "今天天气这么好，你介意去骑马散步吗？"

# game/a4/4ice_vortex.rpy:50
translate english ice_vortex_c4a19914:

    # aur "Я? Нет. Только я не умею ездить на лошади."
    aur "我吗？不介意。只是我不会骑马。"

# game/a4/4ice_vortex.rpy:51
translate english ice_vortex_672a5a4c:

    # me "Ты серьезно?"
    me "你认真的？"

# game/a4/4ice_vortex.rpy:52
translate english ice_vortex_833d5e34:

    # aur "Да. На Севере женщин не учат верховой езде."
    aur "是的。在北方，女性不学骑马。"

# game/a4/4ice_vortex.rpy:53
translate english ice_vortex_2a76d835:

    # me "Ничего страшного, мы можем ехать на одной."
    me "没关系，我们可以共乘一匹。"

# game/a4/4ice_vortex.rpy:54
translate english ice_vortex_fdfe171c:

    # aur "Я не против."
    aur "我不介意。"

# game/a4/4ice_vortex.rpy:56
translate english ice_vortex_f87c8067:

    # aur "Поверить не могу, что я в Имперской Столице. Я слышала о размерах этого города, видела его планы на картах и в книгах, но быть здесь...быть здесь и видеть все это самой...это совершенно другое."
    aur "真不敢相信我来到了帝国首都。我听说过这座城市的规模，在地图和书上看过它的平面图，但身处此地……亲眼目睹这一切……完全是另一回事。"

# game/a4/4ice_vortex.rpy:57
translate english ice_vortex_63107e5b:

    # me "Тебе нравится?"
    me "你喜欢吗？"

# game/a4/4ice_vortex.rpy:58
translate english ice_vortex_70415853:

    # aur "Это заставляет меня трепетать. Однажды я видела как свежуют кита. Рыбаки отрезали он него длинные полосы мяса и жира, пока он не обнажил скелет. Отсюда город кажется мне этим китом."
    aur "这让我感到震撼。我曾经见过人们宰杀鲸鱼。渔夫们从它身上割下长长的肉条和脂肪，直到它露出骨架。从这里看，这座城市对我来说就像那头鲸鱼。"

# game/a4/4ice_vortex.rpy:59
translate english ice_vortex_6cdeb058:

    # aur "Эти дома, улицы, лавочки, мосты, каналы будто части его исполинского тела. Единственная разница лишь в том, что этот кит - живой."
    aur "这些房屋、街道、店铺、桥梁、运河，都仿佛它庞大身躯的一部分。唯一的区别是，这头鲸鱼是活的。"

# game/a4/4ice_vortex.rpy:60
translate english ice_vortex_19672acd:

    # me "Все равно воняют они оба."
    me "反正它们都一样臭气熏天。"

# game/a4/4ice_vortex.rpy:61
translate english ice_vortex_a6a868ba:

    # aur "Из высоких замков вони не учуять и грязи не увидеть."
    aur "从高耸的城堡里是闻不到臭味，也看不见污秽的。"

# game/a4/4ice_vortex.rpy:62
translate english ice_vortex_b163436a:

    # me "Я провел половину жизни вне высоких замков, так что я знаю, что там есть грязь и вонь, даже если их не учуять и не увидеть отсюда."
    me "我半辈子都在高耸的城堡外度过，所以我知道那里有污秽和臭气，即使从这里闻不到、看不见。"

# game/a4/4ice_vortex.rpy:64
translate english ice_vortex_01067adc:

    # aur "Это ведь не так плохо. История показывает, что народ любит королей...так сказать из народа."
    aur "这也不算太糟。历史表明，人民爱戴那些……所谓来自民间的国王。"

# game/a4/4ice_vortex.rpy:65
translate english ice_vortex_9f2708a1:

    # me "Народ об этом не знает. Я был в изгнании далеко на севере."
    me "人民不知道这事。我是在遥远的北方流亡。"

# game/a4/4ice_vortex.rpy:66
translate english ice_vortex_6a571b66:

    # aur "Это не важно. Вы знаете их проблемы, их чаянья. Вам будет проще действовать в их интересах."
    aur "这无关紧要。您了解他们的问题，他们的愿望。您更容易为他们的利益行事。"

# game/a4/4ice_vortex.rpy:67
translate english ice_vortex_05dd8da6:

    # me "А мне нужно это делать?"
    me "我需要这么做吗？"

# game/a4/4ice_vortex.rpy:68
translate english ice_vortex_574d7f10:

    # aur "Наверное. Отец говорит, что тот, кто не слышит свой народ, будет слушать треск факелов и звон железных вил."
    aur "大概吧。父亲说，听不到人民声音的人，将会听到火把的噼啪声和铁叉的碰撞声。"

# game/a4/4ice_vortex.rpy:69
translate english ice_vortex_6c5fb8ee:

    # me "Твой отец легендарная личность. Один из зачинщиков великого восстания. Если он смог победить величайшую империю своего времени, он что-то да смыслит в политике."
    me "你的父亲是位传奇人物。伟大起义的领导者之一。如果他都能打败他那个时代最伟大的帝国，那他在政治上肯定很有一套。"

# game/a4/4ice_vortex.rpy:70
translate english ice_vortex_6df514a8:

    # aur "Он это обожает. Днями принимает просителей и созывает советы чуть ли не каждую неделю."
    aur "他热衷于此。整天接见请愿者，几乎每周都召集会议。"

# game/a4/4ice_vortex.rpy:71
translate english ice_vortex_40590d91:

    # aur "Мое скорое прибытие это тоже своего рода политическое решение..."
    aur "我即将到来这件事本身也是一种政治决定……"

# game/a4/4ice_vortex.rpy:73
translate english ice_vortex_96f2e21c:

    # me "Что ты имеешь в виду?"
    me "您指的是什么？"

# game/a4/4ice_vortex.rpy:74
translate english ice_vortex_86e0bfe0:

    # aur "А разве не ясно? Отец побоялся, что вы выйдете за южанку, он послал меня сюда раньше, чем дипломатическая переписка была завершена."
    aur "这还不明显吗？父亲担心您会娶一位南方姑娘，所以在外交信件完成前，就把我派到这里来了。"

# game/a4/4ice_vortex.rpy:75
translate english ice_vortex_85057a01:

    # me "Тебя это оскорбляет? Наличие второй невесты?"
    me "这让你感到受辱吗？有第二位未婚妻这件事？"

# game/a4/4ice_vortex.rpy:76
translate english ice_vortex_fb11c182:

    # aur "Мне некого винить в этом, кроме моего отца. А его я винить не могу. Он же король. Ваш отец тоже наверняка просто поставил вас перед фактом."
    aur "在这件事上，我不能责怪任何人，除了我父亲。但我又不能责怪他。他是国王。您的父亲大概也只是把既定事实摆在您面前吧。"

# game/a4/4ice_vortex.rpy:77
translate english ice_vortex_7aeacea5:

    # me "Такова традиция. Наследные принцы редко сами выбирают себе жен."
    me "这就是传统。王位继承人很少能自己选择妻子。"

# game/a4/4ice_vortex.rpy:78
translate english ice_vortex_62c27fb9:

    # aur "Об этом я и говорю. Мы все заложники своего положения."
    aur "我指的就是这个。我们都是自身处境的囚徒。"

# game/a4/4ice_vortex.rpy:79
translate english ice_vortex_1cf19dcc:

    # aur "Родители выбирают детям невест и женихов, они вырастают и все повторяется. Замкнутый цикл."
    aur "父母为孩子选择新娘或新郎，他们长大后一切又重演。一个封闭的循环。"

# game/a4/4ice_vortex.rpy:82
translate english ice_vortex_9db27c25:

    # aur "Простите мне мое уныние, я еще не слишком отошла от долгой дороги. "
    aur "请原谅我的沮丧，我还没从长途跋涉中完全恢复过来。"

# game/a4/4ice_vortex.rpy:83
translate english ice_vortex_ddcff34c:

    # me "Если вы хотите отдохнуть..."
    me "如果您想休息一下……"

# game/a4/4ice_vortex.rpy:84
translate english ice_vortex_2091fadf:

    # aur "Нет-нет. Дело не в этом. Я просто решила немного поговорить с вами по душам и случайно начала не с того..."
    aur "不，不。不是因为这个。我只是想和您坦诚地谈谈心，却不小心起了个不好的头……"

# game/a4/4ice_vortex.rpy:85
translate english ice_vortex_3820771a:

    # me "..."
    me "..."

# game/a4/4ice_vortex.rpy:86
translate english ice_vortex_001de12a:

    # aur "Не стоило заводить этого разговор, простите."
    aur "不该开始这个话题的，请原谅。"

# game/a4/4ice_vortex.rpy:90
translate english ice_vortex_8b354ebf:

    # aur "Ну...в конце концов мы в одном положении верно?"
    aur "嗯……说到底，我们的处境是一样的，对吧？"

# game/a4/4ice_vortex.rpy:91
translate english ice_vortex_dfcceeac:

    # me "М?"
    me "嗯？"

# game/a4/4ice_vortex.rpy:92
translate english ice_vortex_be247a7e:

    # aur "Вы кажетесь мне веселым и интересным. Я до сих пор в восторге от вашей шутки."
    aur "我觉得您是个开朗又有趣的人。我到现在都还对您的笑话感到兴奋。"

# game/a4/4ice_vortex.rpy:93
translate english ice_vortex_8fa399d3:

    # aur "Так что я, пожалуй, зря впала в уныние раньше времени. Мне лучше думать о том, как вам понравится, а не как я вообще сюда попала."
    aur "所以，我可能不该这么快就沮丧起来。我最好还是想想如何让您喜欢上我，而不是琢磨我到底是怎么来到这儿的。"

# game/a4/4ice_vortex.rpy:98
translate english ice_vortex_ff1b48e7:

    # aur "Простите меня, я не должна была так говорить...я не имела в виду того, что мое возможное замужество для меня тягость."
    aur "请原谅我，我不该那样说……我不是说可能的婚姻对我来说是种负担。"

# game/a4/4ice_vortex.rpy:99
translate english ice_vortex_e79d0fd5:

    # me "Да?"
    me "是吗？"

# game/a4/4ice_vortex.rpy:100
translate english ice_vortex_f55f3ee6:

    # aur "Да. Простите. Вы не должны были этого слышать."
    aur "是的。对不起。您不该听到这些的。"

# game/a4/4ice_vortex.rpy:101
translate english ice_vortex_3820771a_1:

    # me "..."
    me "..."

# game/a4/4ice_vortex.rpy:102
translate english ice_vortex_15f594a6:

    # aur "В следующий раз я обязательно сначала подумаю, а потом скажу. Не хочу чтобы вы думали, будто я настолько слабый человек."
    aur "下次我一定先想好再说。我不想让您觉得我是那么软弱的一个人。"

# game/a4/4ice_vortex.rpy:106
translate english ice_vortex_6a3c52b2:

    # me "Родители и дети... Ты меня натолкнула на одну мысль."
    me "父母和孩子……你让我想起了一件事。"

# game/a4/4ice_vortex.rpy:108
translate english ice_vortex_d983ae6c:

    # me "Детский колокол южной башни."
    me "南塔的报喜钟。"

# game/a4/4ice_vortex.rpy:109
translate english ice_vortex_de496b57:

    # aur "Почему детский? Выглядит внушительно."
    aur "为什么叫“报喜钟”？它看起来很宏伟。"

# game/a4/4ice_vortex.rpy:110
translate english ice_vortex_122716e1:

    # me "В него бьют, когда в королевской семье рождается ребенок."
    me "当王室有孩子出生时，就会敲响它。"

# game/a4/4ice_vortex.rpy:111
translate english ice_vortex_7d6242c1:

    # aur "Надо же."
    aur "原来如此。"

# game/a4/4ice_vortex.rpy:112
translate english ice_vortex_981d9036:

    # me "От частоты ударов между интервалами можно понять какого пола ребенок. Один - мальчик. Два - девочка."
    me "听敲钟的间隔次数就能知道孩子的性别。一声是男孩。两声是女孩。"

# game/a4/4ice_vortex.rpy:113
translate english ice_vortex_1fbf1a00:

    # me "Я предлагаю нам немного пошалить."
    me "我提议我们小小地胡闹一下。"

# game/a4/4ice_vortex.rpy:114
