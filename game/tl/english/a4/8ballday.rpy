# TODO: Translation updated at 2024-05-06 15:48

# game/a4/8ballday.rpy:14
translate english ballday6_snow_1ccac3f2:

    # me "Аврора."
    me "Aurora。"

# game/a4/8ballday.rpy:15
translate english ballday6_snow_41fdd804:

    # aurora "[mename]. Хотите потанцевать?"
    aurora "[角色名]。想跳支舞吗？"

# game/a4/8ballday.rpy:16
translate english ballday6_snow_5a7a7577:

    # me "Нет."
    me "不。"

# game/a4/8ballday.rpy:17
translate english ballday6_snow_d0bc1944:

    # aurora "Оу...может тогда поговорить?"
    aurora "哦……那聊聊天如何？"

# game/a4/8ballday.rpy:18
translate english ballday6_snow_39d24283:

    # me "Тоже нет."
    me "也不想。"

# game/a4/8ballday.rpy:19
translate english ballday6_snow_bcc3ecd9:

    # aurora "Эм..."
    aurora "呃……"

# game/a4/8ballday.rpy:20
translate english ballday6_snow_7f4c12c6:

    # me "Я хочу вам кое-что подарить."
    me "我有点东西想送给您。"

# game/a4/8ballday.rpy:21
translate english ballday6_snow_2badbc99:

    # aurora "Что?"
    aurora "什么？"

# game/a4/8ballday.rpy:22
translate english ballday6_snow_1aa10c46:

    # me "Дайте руку."
    me "手给我。"

# game/a4/8ballday.rpy:24
translate english ballday6_snow_5c3b3003:

    # me "Вы знаете, что такое принц-кольцо?"
    me "您知道什么是王子之戒吗？"

# game/a4/8ballday.rpy:25
translate english ballday6_snow_0d66247b:

    # aurora "Да."
    aurora "知道。"

# game/a4/8ballday.rpy:26
translate english ballday6_snow_24240b24:

    # me "Правда? Моя мама вам рассказала?"
    me "真的？我母亲告诉您的？"

# game/a4/8ballday.rpy:27
translate english ballday6_snow_c9057bc7:

    # aurora "Мама? Нет, ваша сестра, [lia]. Мы вместе читали книги в библиотеке."
    aurora "母亲？不是，是您的姐姐，[lia]。我们一起在图书馆读过书。"

# game/a4/8ballday.rpy:28
translate english ballday6_snow_c4eef57f:

    # me "Оу. Ну тогда вы понимаете, что значит этот жест."
    me "哦。那您一定明白这个举动意味着什么。"

# game/a4/8ballday.rpy:29
translate english ballday6_snow_e1cea337:

    # aurora "Да, [mename], спасибо."
    aurora "是的，[角色名]，谢谢您。"

# game/a4/8ballday.rpy:31
translate english ballday6_snow_75c0f5fa:

    # voics1 "{size=-6}Вы видели? Он выбрал северянку!{/size}"
    voics1 "{size=-6}您看见了吗？他选了那个北方女人！{/size}"

# game/a4/8ballday.rpy:32
translate english ballday6_snow_f6da3016:

    # voics2 "Какой позор, ее отец уничтожил Золотую Империю, а она теперь в Столице на балу с принц-кольцом на пальце!{/size}"
    voics2 "真丢脸，她父亲毁了黄金帝国，她现在倒好，在首都的舞会上，手上戴着王子之戒！"

# game/a4/8ballday.rpy:33
translate english ballday6_snow_f98403b7:

    # voics1 "{size=-6}А что, было бы лучше, если бы он выбрал южанку?{/size}"
    voics1 "{size=-6}怎么，难道他选个南方女人就更好了？{/size}"

# game/a4/8ballday.rpy:34
translate english ballday6_snow_589fe3a0:

    # voics2 "{size=-6}Их ребенок будет на три четверти северяниноэльфом, кровь врагов Империи будет течь в наследнике.{/size}"
    voics2 "{size=-6}他们的孩子会有四分之三的北方血统，继承人体内将流淌着帝国敌人的血。{/size}"

# game/a4/8ballday.rpy:35
translate english ballday6_snow_09659d89:

    # voics1 "{size=-6}Идиоты, может быть так мы и объеденимся с Севером. Мирно.{/size}"
    voics1 "{size=-6}一群蠢货，也许这样我们才能与北方联合。和平地。{/size}"

# game/a4/8ballday.rpy:36
translate english ballday6_snow_8e5effc5:

    # voics2 "{size=-6}Мирное объединение с предателями? Лучше бы он выбрал южанку и мы бы вместе утопили Север в крови.{/size}"
    voics2 "{size=-6}和叛徒和平联合？他倒不如选个南方女人，我们好一起把北方沉入血海。{/size}"

# game/a4/8ballday.rpy:37
translate english ballday6_snow_65adba7a:

    # voics1 "{size=-6}Почему никто не говорит, что они красивая пара? Готов поспорить ребенок у них будет чудесный.{/size}"
    voics1 "{size=-6}怎么没人说他们是漂亮的一对？我敢打赌他们的孩子会非常可爱。{/size}"

# game/a4/8ballday.rpy:38
translate english ballday6_snow_95d5b0e8:

    # voics2 "{size=-6}Красивая? Да мои сапоги после дождливой дороги красивее...{/size}"
    voics2 "{size=-6}漂亮？我那双走过泥泞路的靴子都比这漂亮……{/size}"

# game/a4/8ballday.rpy:40
translate english ballday6_snow_80b06994:

    # aurora "Не знаю, чем я заслужила..."
    aurora "我不知道自己何德何能……"

# game/a4/8ballday.rpy:41
translate english ballday6_snow_383605e6:

    # me "Знаешь. Ты мне нравишься, Аврора."
    me "你知道。我喜欢你，Aurora。"

# game/a4/8ballday.rpy:42
translate english ballday6_snow_af095c5b:

    # aurora "Прошу, не надо. А то я начинаю краснеть."
    aurora "请别说了。不然我就要脸红了。"

# game/a4/8ballday.rpy:43
translate english ballday6_snow_988fb26c:

    # me "Бал скоро закончится, проводить вас до вашей комнаты?"
    me "舞会快要结束了，我送您回房间吧？"

# game/a4/8ballday.rpy:44
translate english ballday6_snow_06194f04:

    # aurora "Давайте сначала кое-куда зайдем."
    aurora "我们能不能先去个地方？"

# game/a4/8ballday.rpy:45
translate english ballday6_snow_dfcceeac:

    # me "М?"
    me "嗯？"

# game/a4/8ballday.rpy:47
translate english ballday6_snow_83749a03:

    # "Полчаса спустя."
    "半个小时以后。"

# game/a4/8ballday.rpy:48
translate english ballday6_snow_5e27b962:

    # me "Я даже не знал, что в верхнем городе есть северный храм Безымянного Бога."
    me "我竟不知道上城区还有一座北方无名神的神殿。"

# game/a4/8ballday.rpy:49
translate english ballday6_snow_a5b7bab4:

    # aurora "Наши верования произошли из одного корня, так что местные не считают единобожников врагами."
    aurora "我们的信仰同出一源，所以本地人不把一神论者视为敌人。"

# game/a4/8ballday.rpy:50
translate english ballday6_snow_c429ae26:

    # me "Учитывая, что у веры в неведомых богов нет никаких храмов, местные возможно даже не знают, что это такое."
    me "考虑到对无名诸神的信仰没有任何神殿，本地人可能甚至不知道那是什么。"

# game/a4/8ballday.rpy:52
translate english ballday6_snow_edaa0532:

    # me "Кто зажигает все эти свечи? Здесь есть кто-то, кто присматривает за храмом?"
    me "这些蜡烛都是谁点的？这里有人照管神殿吗？"

# game/a4/8ballday.rpy:53
translate english ballday6_snow_1e564f22:

    # aurora "Это делают прихожане и безымянные монахи."
    aurora "是教众和无名的僧侣们做的。"

# game/a4/8ballday.rpy:54
translate english ballday6_snow_9a58e7b5:

    # me "Безымянные монахи? Я видел их пару раз, когда был в изгнании. Хотя я кажется и в храме вашего бога был, правда я помню, что там был кто-то вроде смотрителя."
    me "无名的僧侣？我流亡时见过他们几次。不过我好像也去过你们神的殿堂，记得似乎有个人，像是个看守。"

# game/a4/8ballday.rpy:55
translate english ballday6_snow_55df4c48:

    # aurora "Безымянный смотритель. Иногда он нужен чтобы ну...из храма не воровали."
    aurora "是无名的看守。有时需要他，嗯……为了防止神殿的东西被偷。"

# game/a4/8ballday.rpy:56
translate english ballday6_snow_3dfdef5c:

    # me "Понимаю. Если бы не смотритель, я бы тогда и сам что-то украл."
    me "明白了。要是没有看守，我当时可能自己就顺走什么东西了。"

# game/a4/8ballday.rpy:57
translate english ballday6_snow_b14e5875:

    # aurora "О мой бог, вы серьезно?"
    aurora "哦，我的神啊，您是认真的吗？"

# game/a4/8ballday.rpy:58
translate english ballday6_snow_f0f4ed2c:

    # me "Шутка."
    me "开玩笑的。"

# game/a4/8ballday.rpy:60
translate english ballday6_snow_d8685440:

    # aurora "Здесь так красиво, так умиротворяюще и..."
    aurora "这里如此美丽，如此宁静，还有……"

# game/a4/8ballday.rpy:61
translate english ballday6_snow_f95c9fc9:

    # me "И?"
    me "还有什么？"

# game/a4/8ballday.rpy:62
translate english ballday6_snow_28904fe6:

    # aurora "Я всегда чувствую здесь единение с богом."
    aurora "我在这里总能感受到与神的合一。"

# game/a4/8ballday.rpy:63
translate english ballday6_snow_8a0aaaa2:

    # me "Ты когда-нибудь его слышала? Или может видела?"
    me "你曾经听到过他的声音吗？或者见过他？"

# game/a4/8ballday.rpy:64
translate english ballday6_snow_9b999530:

    # aurora "Безымянного бога? Нет. Никогда."
    aurora "无名之神？没有。从未有过。"

# game/a4/8ballday.rpy:66
translate english ballday6_snow_f127da7a:

    # me "Тогда я не понимаю, почему ты считаешь, что он только один? Ты веришь в одного бога, а не во многих просто потому что так делают в том месте, где ты родилась?"
    me "那我就不明白了，你为何认为他只有一个？你相信只有一位神，而非众多神祇，仅仅是因为你出生地的人都这么做吗？"

# game/a4/8ballday.rpy:67
translate english ballday6_snow_4287258f:

    # aurora "Меня никто не заставлял принимать именно эту веру. На севере спокойно относятся к вере в безымянных богов."
    aurora "没人强迫我非要接受这个信仰。在北方，人们对信仰无名众神的态度很宽容。"

# game/a4/8ballday.rpy:68
translate english ballday6_snow_b5913fed:

    # me "И все же, почему один, а не много?"
    me "可是，为什么是一位，而不是许多位？"

# game/a4/8ballday.rpy:69
translate english ballday6_snow_d173429f:

    # aurora "Я просто смотрю на мир и понимаю, что носители сильной воли находятся в вечной войне друг с другом. Это естественный порядок, существовавший всегда."
    aurora "我只是观察这个世界，便明白意志强大的存在彼此之间处于永恒的战争。这是亘古存在的自然秩序。"

# game/a4/8ballday.rpy:70
translate english ballday6_snow_3820771a:

    # me "..."
    me "..."

# game/a4/8ballday.rpy:71
translate english ballday6_snow_bf52f708:

    # aurora "Потом я вспоминаю насколько сильна божественная воля и понимаю, что будь богов множество, мы бы видели проявления их вечной войны, понимаешь?"
    aurora "然后我回想起神之意志是何等强大，我便明白，若存在众多神明，我们定会见到他们永恒战争的表现，你明白吗？"

# game/a4/8ballday.rpy:73
translate english ballday6_snow_a1af85ae:

    # me "Может быть у них просто одни и те же цели и для них нет смысла воевать."
    me "也许他们目标一致，对他们而言战争没有意义。"

# game/a4/8ballday.rpy:74
translate english ballday6_snow_9006cff1:

    # aurora "В таком случае какая разница, много их или нет, если их воля одинакова?"
    aurora "那样的话，如果他们的意志都相同，一位或是多位又有什么区别？"

# game/a4/8ballday.rpy:75
translate english ballday6_snow_d6c68e76:

    # me "А что если они не могут воевать друг с другом?"
    me "要是他们不能互相争斗呢？"

# game/a4/8ballday.rpy:76
translate english ballday6_snow_9d0d8240:

    # aurora "Боги могут влиять на наш мир, но не могут друг на друга?"
    aurora "神能影响我们的世界，却不能影响彼此？"

# game/a4/8ballday.rpy:77
translate english ballday6_snow_068ca5fd:

    # me "Ага. Вдруг они висят где-нибудь в клетках и их руки способны дотянуться до земли, но не до друг друга?"
    me "对。或许他们被关在牢笼里，手能够到大地，却够不到彼此？"

# game/a4/8ballday.rpy:78
translate english ballday6_snow_35ccb37a:

    # aurora "В таком случае, они не должны знать друг о друге, верно? Ведь их руки не должны пересекаться даже на земле. А значит я просто молюсь тому богу, чьи руки могут достать до меня."
    aurora "那样的话，他们应该不知道彼此的存在，对吧？因为他们就算在地上，手也不该有交集。这就意味着，我只是在向我能够得着的那位神祈祷。"

# game/a4/8ballday.rpy:79
translate english ballday6_snow_8e41f060:

    # me "Так ты не исключаешь существование других богов?"
    me "那么你也不排除有其他神存在的可能？"

# game/a4/8ballday.rpy:80
translate english ballday6_snow_9c99e25e:

    # aurora "Не исключаю. Но молюсь я только моему безымянному богу."
    aurora "不排除。但我只向我唯一的无名之神祈祷。"

# game/a4/8ballday.rpy:82
translate english ballday6_snow_47204935:

    # me "Знаешь....я видел богиню."
    me "你知道吗……我见过一位女神。"

# game/a4/8ballday.rpy:83
translate english ballday6_snow_d2e5535d:

    # aurora "Правда?"
    aurora "真的吗？"

# game/a4/8ballday.rpy:84
translate english ballday6_snow_94101805:

    # me "Ага. Эльфийскую богиню. Правда вместе с ней я видел Красного Императора и все это было в лихорадочном припадке."
    me "嗯。一位精灵女神。不过与此同时我还见到了红皇帝，而且那一切发生在我高烧发作的时候。"

# game/a4/8ballday.rpy:85
translate english ballday6_snow_fe49d884:

    # aurora "Вы видели ее только во время приступа?"
    aurora "您只在发作时见过她？"

# game/a4/8ballday.rpy:86
translate english ballday6_snow_b50d7eb3:

    # me "Да. И все же...я не конца уверен, что это был лихорадочный бред. Мне кажется она и вправду говорила со мной."
    me "是的。尽管如此……我仍不确定那是高烧谵妄。我觉得她当时真的在对我说话。"

# game/a4/8ballday.rpy:87
translate english ballday6_snow_54e6bf1b:

    # aurora "Я вам верю."
    aurora "我相信您。"

# game/a4/8ballday.rpy:88
translate english ballday6_snow_489a247d:

    # me "Правда?"
    me "真的吗？"

# game/a4/8ballday.rpy:89
translate english ballday6_snow_e319396a:

    # aurora "Да. Вдруг боги действительно сидят в клетках, но могут дотянуться не до земли, а до крови...В вас же есть эльфийская кровь, верно?"
    aurora "是的。假如神确实被关在牢笼里，但手够不到大地，却能伸向血脉……您体内流淌着精灵之血，对吗？"

# game/a4/8ballday.rpy:90
translate english ballday6_snow_dfda2ced:

    # me "Ровно половина. И половина человеческой."
    me "正好一半。另一半是人类的。"

# game/a4/8ballday.rpy:91
translate english ballday6_snow_d7c8c96f:

    # aurora "Выходит до вас может дотянуться и бог людей."
    aurora "这样一来，人类之神或许也能触及您。"

# game/a4/8ballday.rpy:92
translate english ballday6_snow_077f8bad:

    # me "Не думаю, что бог людей, если он один, выглядит, как Красный Император. Это же человек."
    me "我不认为人类之神——如果他只有一位的话——会是红皇帝的模样。那毕竟是个人。"

# game/a4/8ballday.rpy:93
translate english ballday6_snow_aab346a6:

    # aurora "Может безымянный бог принял форму Красного Императора? Что он вам говорил?"
    aurora "或许无名之神化作了红皇帝的形态？他对您说了什么？"

# game/a4/8ballday.rpy:94
translate english ballday6_snow_7eb000a2:

    # me "Он и Мирта спорили. Я уже не помню о чем именно, кажется о том, стоит ли мне исполнять свое предназначение или идти своей дорогой."
    me "他和Mirta在争执。我已经不记得具体关于什么了，大概是关于我是该去履行我的宿命，还是走我自己的路。"

# game/a4/8ballday.rpy:95
translate english ballday6_snow_e7008fc5:

    # aurora "Красный Император хотел чтобы вы выбрали свою дорогу?"
    aurora "红皇帝想让您选择自己的路？"

# game/a4/8ballday.rpy:96
translate english ballday6_snow_fc30fd2b:

    # me "Да."
    me "是的。"

# game/a4/8ballday.rpy:97
translate english ballday6_snow_bf026fb6:

    # aurora "Я хочу помолиться..."
    aurora "我想祈祷……"

# game/a4/8ballday.rpy:101
translate english ballday6_snow_6d119ccf:

    # me "Я тоже. Пути неведомых богов, а значит и неведомого бога бесчисленны..."
    me "我也是。无名诸神的道路，也就是无名之神的道路，无穷无尽……"

# game/a4/8ballday.rpy:102
translate english ballday6_snow_b4d4240b:

    # aurora "Я поняла вас... Пусть неведомый бог дарует мне защиту и моим близким. Пусть боги, если их множество сделают то же самое."
    aurora "我明白了您的意思……愿无名之神赐予我与我的至亲庇护。若是诸神众多，也愿他们如此行。"

# game/a4/8ballday.rpy:103
translate english ballday6_snow_8d6e141d:

    # me "Я хочу увидеть тысячу дорог."
    me "我想看见千条道路。"

# game/a4/8ballday.rpy:104
translate english ballday6_snow_6b0cdab0:

    # aurora "Я хочу увидеть божественные знаки и понять их всех."
    aurora "我想看见神迹，并理解它们的全部。"

