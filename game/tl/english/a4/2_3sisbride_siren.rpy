# game/a4/2_3sisbride_siren.rpy:5
translate english sis_bride_496c473a:

    # "Что за шум в обеденной галерее?"
    "What's that noise in the dining gallery?"

# game/a4/2_3sisbride_siren.rpy:6
translate english sis_bride_e0fcc796:

    # "Кажется кто-то здесь разговаривает."
    "Seems like someone is talking here."

# game/a4/2_3sisbride_siren.rpy:7
translate english sis_bride_a01e5234:

    # "Надо посмотреть."
    "I should check it out."

# game/a4/2_3sisbride_siren.rpy:9
translate english sis_bride_f5f05617:

    # lockhart "Так что я бы купил эту лошадь за все золото что у меня есть."
    lockhart "所以我愿倾我所有黄金买下这匹马。"

# game/a4/2_3sisbride_siren.rpy:10
translate english sis_bride_577de2f2:

    # "О! Да это же [elin] и ее жених."
    "Oh! It's [elin] and her groom."

# game/a4/2_3sisbride_siren.rpy:11
translate english sis_bride_89ea77e6:

    # elin "Ага..."
    elin "嗯..."

# game/a4/2_3sisbride_siren.rpy:12
translate english sis_bride_cd4bcbf6:

    # lockhart "Жаль, что она ненастоящая."
    lockhart "可惜它不是真的。"

# game/a4/2_3sisbride_siren.rpy:13
translate english sis_bride_69677efe:

    # elin "Действительно жаль."
    elin "确实可惜。"

# game/a4/2_3sisbride_siren.rpy:14
translate english sis_bride_898524fd:

    # lockhart "Хотя некоторые родовые скакуны Каллабрии не сильно уступают в скорости и выносливости."
    lockhart "不过卡拉布里亚的某些纯种马，在速度与耐力上也不遑多让。"

# game/a4/2_3sisbride_siren.rpy:15
translate english sis_bride_690f74ba:

    # elin "Поразительно."
    elin "令人惊叹。"

# game/a4/2_3sisbride_siren.rpy:16
translate english sis_bride_15f87902:

    # me "Думаю нужно поздороваться."
    me "我想我该去打个招呼。"

# game/a4/2_3sisbride_siren.rpy:18
translate english sis_bride_f5749ba3:

    # me "Привет, [elin]."
    me "你好，[elin]。"

# game/a4/2_3sisbride_siren.rpy:19
translate english sis_bride_d5211b0a:

    # elin "О, привет, брат!"
    elin "哦，你好，哥哥！"

# game/a4/2_3sisbride_siren.rpy:20
translate english sis_bride_4ef2fa87:

    # me "Познакомишь меня с твоим собеседником."
    me "你会把我介绍给你的谈话对象吗？"

# game/a4/2_3sisbride_siren.rpy:21
translate english sis_bride_aca726f1:

    # elin "Конечно, это...."
    elin "当然，这是..."

# game/a4/2_3sisbride_siren.rpy:23
translate english sis_bride_efd2494a:

    # lockhart "Я представлюсь сам. Меня зовут Локхарт, я сын лорда Аргуса, хранителя Каллабрии, Ратонии и городов западного Пика."
    lockhart "我自己来介绍。我叫Lockhart，是Argus领主之子，我父乃卡拉布里亚、拉托尼亚及西峰诸城的守护者。"

# game/a4/2_3sisbride_siren.rpy:24
translate english sis_bride_725e12fe:

    # me "Ага. А я..."
    me "嗯。而我..."

# game/a4/2_3sisbride_siren.rpy:25
translate english sis_bride_c32ee3c9:

    # lockhart "Я наслышан о вас. Принц-изгнанник. В тех местах, где я вырос вы почти легендарная личность."
    lockhart "我久仰您的大名。流亡的王子。在我长大的地方，您几乎是个传奇人物。"

# game/a4/2_3sisbride_siren.rpy:26
translate english sis_bride_489a247d:

    # me "Правда?"
    me "真的吗？"

# game/a4/2_3sisbride_siren.rpy:27
translate english sis_bride_66564b39:

    # lockhart "Ну...скажем так, вы были весьма популярным примером строгости наказания для всех бунтующих детей от их недовольных отцов."
    lockhart "呃...这么说吧，您常被用作严厉惩罚的典范，让所有叛逆孩子的严父拿来教训他们。"

# game/a4/2_3sisbride_siren.rpy:28
translate english sis_bride_d13d1d66:

    # me "Я известен строгостью своего отца?"
    me "我因父亲的严厉而出名？"

# game/a4/2_3sisbride_siren.rpy:29
translate english sis_bride_b915255f:

    # lockhart "И несгибаемостью своего духа. Вы гордо приняли наказание."
    lockhart "以及您不屈的精神。您骄傲地接受了惩罚。"

# game/a4/2_3sisbride_siren.rpy:31
translate english sis_bride_e42e0637:

    # me "Я был ребенком, разве у меня был выбор?"
    me "我当时只是个孩子，我有选择吗？"

# game/a4/2_3sisbride_siren.rpy:32
translate english sis_bride_51bb021a:

    # lockhart "Ох, правда? Я думал это произошло около десяти лет назад."
    lockhart "哦，真的吗？我还以为那是大约十年前的事。"

# game/a4/2_3sisbride_siren.rpy:33
translate english sis_bride_b9bbc724:

    # elin "Так и было."
    elin "确实是。"

# game/a4/2_3sisbride_siren.rpy:34
translate english sis_bride_fa6e5d4d:

    # lockhart "Да, но ведь эльфы стареют медленнее."
    lockhart "是啊，但精灵衰老得慢啊。"

# game/a4/2_3sisbride_siren.rpy:35
translate english sis_bride_b3d79c2f:

    # me "Что? Может эльфы стареют и медленнее, но взрослеют они с такой же скоростью. К тому же я эльф только наполовину."
    me "什么？也许精灵衰老得慢，但他们成熟的速度是一样的。而且我只有一半精灵血统。"

# game/a4/2_3sisbride_siren.rpy:36
translate english sis_bride_8986ecde:

    # lockhart "Ох, простите мне мое невежество. Я мало знаю о эльфах."
    lockhart "哦，请原谅我的无知。我对精灵知之甚少。"

# game/a4/2_3sisbride_siren.rpy:37
translate english sis_bride_39cc41ba:

    # me "Это удивительно, разве среди всех бывших земель Империи на Западе не живет больше всего эльфов?"
    me "这真令人惊讶，难道帝国旧地中，不是西部居住的精灵最多吗？"

# game/a4/2_3sisbride_siren.rpy:38
translate english sis_bride_3da49851:

    # lockhart "Верно. Но я по правде говоря не особо с ними общался. Я и с людьми мало провожу время. Моя страсть это лошади."
    lockhart "没错。但说实话，我很少和他们打交道。我和人类相处的时间也不多。我的热情全在马身上。"

# game/a4/2_3sisbride_siren.rpy:40
translate english sis_bride_ee9de0d3:

    # me "Лошади?"
    me "马？"

# game/a4/2_3sisbride_siren.rpy:41
translate english sis_bride_8c094607:

    # lockhart "Да! Я могу говорить о них часами."
    lockhart "是的！关于马，我能说上几个小时。"

# game/a4/2_3sisbride_siren.rpy:42
translate english sis_bride_8b79c98c:

    # lockhart "Больше чем говорить о лошадях, мне нравится только на них кататься и ухаживать за ними."
    lockhart "比起谈论马，我唯一更喜欢的就是骑马和照料它们。"

# game/a4/2_3sisbride_siren.rpy:43
translate english sis_bride_8054d4a5:

    # me "Ваш отец разводит лошадей?"
    me "您父亲是养马的吗？"

# game/a4/2_3sisbride_siren.rpy:44
translate english sis_bride_19a4d71d:

    # lockhart "Мой отец? Умоляю. Он дилетант в этом вопросе. Он ориентируется только на цену, скрещивает самых дорогих и продает на Юг."
    lockhart "我父亲？拜托。在这件事上他纯粹是个外行。他只认价格，把最贵的马配种，然后卖到南方去。"

# game/a4/2_3sisbride_siren.rpy:45
translate english sis_bride_6bd2d378:

    # me "Что же делаете вы?"
    me "那您是怎么做的呢？"

# game/a4/2_3sisbride_siren.rpy:46
translate english sis_bride_f745503e:

    # lockhart "Ох, у меня есть целая система. Видите ли, хорошая лошадь это не только скорость и здоровье."
    lockhart "哦，我自有一套体系。您看，一匹好马不仅在于速度和健康。"

# game/a4/2_3sisbride_siren.rpy:48
translate english sis_bride_e6fca72b:

    # lockhart "Это еще и характер. Нельзя бездумно мешать кровь лучших лошадей не узнав их характер."
    lockhart "还在于脾性。不弄清楚脾性就胡乱混种最好的马匹血脉，是不可取的。"

# game/a4/2_3sisbride_siren.rpy:49
translate english sis_bride_537c6e3c:

    # elin "Может поговорим о чем-то другом?"
    elin "我们能聊点别的吗？"

# game/a4/2_3sisbride_siren.rpy:50
translate english sis_bride_574fa383:

    # lockhart "Простите, [elin], но принц не слышал о моей теории."
    lockhart "抱歉，[elin]，但王子殿下还没听过我的理论呢。"

# game/a4/2_3sisbride_siren.rpy:51
translate english sis_bride_c7d7a205:

    # me "{i}Кажется [elin] не особенно приятна эта беседа.{/i}"
    me "{i}看来[elin]不太喜欢这场谈话。{/i}"

# game/a4/2_3sisbride_siren.rpy:52
translate english sis_bride_f41cced0:

    # lockhart "Я приставляю к каждой лошади слугу. Он обязательно должен уметь писать, либо должен обладать хорошей памятью."
    lockhart "我给每匹马都指派一个仆人。这人必须会写字，或者得有很好的记忆力。"

# game/a4/2_3sisbride_siren.rpy:53
translate english sis_bride_7332342b:

    # me "Зачем?"
    me "为什么？"

# game/a4/2_3sisbride_siren.rpy:54
translate english sis_bride_a3b23737:

    # lockhart "Они наблюдают за тем, как она живет. Как ест, как играет с другими лошадьми, как она спит, как она..."
    lockhart "他们观察马是如何生活的。如何进食，如何与其他马玩耍，如何入睡，如何..."

# game/a4/2_3sisbride_siren.rpy:55
translate english sis_bride_9bf8540a:

    # me "И зачем это?"
    me "这又为了什么呢？"

# game/a4/2_3sisbride_siren.rpy:56
translate english sis_bride_b7f022d3:

    # lockhart "Здесь самое интересное. Сумма всех действий за день позволяет мне оценить под какой звездой ходит эта лошадь или конь."
    lockhart "最有趣的地方就在这里。一天中所有行为的总和，能让我判断这匹马或公马是在哪颗星辰下行走。"

# game/a4/2_3sisbride_siren.rpy:59
translate english sis_bride_404d849b:

    # elin "{i}[mename]!{/i}"
    elin "{i}[mename]!{/i}"

# game/a4/2_3sisbride_siren.rpy:60
translate english sis_bride_f4728018:

    # lockhart "Вы верите в силу звезд? Я вот верю."
    lockhart "您相信星辰的力量？我倒是信。"

# game/a4/2_3sisbride_siren.rpy:61
translate english sis_bride_8d22a253:

    # me "{i}[elin]? Это ты?{/i}"
    me "{i}[elin]？是你吗？{/i}"

# game/a4/2_3sisbride_siren.rpy:62
translate english sis_bride_20917b3b:

    # elin "{i}Да. Умоляю, прекрати эти разговоры. Я слышала этот бред уже два раза, а мы только познакомились.{/i}"
    elin "{i}是我。求你了，快别聊这些了。这胡话我已经听过两遍了，可我们才刚认识。{/i}"

# game/a4/2_3sisbride_siren.rpy:63
translate english sis_bride_aea49877:

    # lockhart "Многие ошибочно думают, что звезда выбирается за человеком в момент его рождения. Но это не так..."
    lockhart "许多人错误地认为，星辰是在人或马出生的那一刻选定的。但并非如此..."

# game/a4/2_3sisbride_siren.rpy:64
translate english sis_bride_1497e398:

    # me "{i}И что ты мне предлагаешь сделать?{/i}"
    me "{i}那你建议我怎么做？{/i}"

# game/a4/2_3sisbride_siren.rpy:65
translate english sis_bride_e0a7be51:

    # elin "{i}Не знаю. Скажи, что нам срочно нужно идти.{/i}"
    elin "{i}不知道。就说我们有急事必须走了。{/i}"

# game/a4/2_3sisbride_siren.rpy:67
translate english sis_bride_15e09e66:

    # lockhart "На самом деле звезда выбирает себе подданных сама. Как только понимает что за характер и человека или лошади."
    lockhart "事实上，星辰是自行选择其臣民的。一旦它了解了人或马的性格。"

# game/a4/2_3sisbride_siren.rpy:68
translate english sis_bride_9a125d57:

    # me "{i}Куда идти?{/i}"
    me "{i}去哪儿？{/i}"

# game/a4/2_3sisbride_siren.rpy:69
translate english sis_bride_e161cd4c:

    # elin "{i}Кажется я говорила ему, что нас ждет отец.{/i}"
    elin "{i}我记得我跟他说过，父亲在等我们。{/i}"

# game/a4/2_3sisbride_siren.rpy:70
translate english sis_bride_7c850bcd:

    # me "{i}Почему сама не скажешь?{/i}"
    me "{i}你为什么不自己说？{/i}"

# game/a4/2_3sisbride_siren.rpy:71
translate english sis_bride_97026da8:

    # elin "{i}Не хочу показаться невежливой. Пожалуйста, [mename]!{/i}"
    elin "{i}我不想显得失礼。求你了，[mename]！{/i}"

# game/a4/2_3sisbride_siren.rpy:72
translate english sis_bride_9d6cb3a4:

    # lockhart "Понять под какой звездой ходишь ты легко, а вот лошадь..."
    lockhart "弄清你行走在哪颗星辰下很容易，但对于马来说..."

# game/a4/2_3sisbride_siren.rpy:76
translate english sis_bride_f15acde0:

    # me "Прости, Локхарт, верно? Я тут вспомнил зачем зашел, не хочу прерывать твой рассказ, но меня и сестру ожидает отец."
    me "抱歉，你是叫Lockhart，对吗？我刚想起来我进来是干什么的，不想打断你的讲述，但我和妹妹得去见父亲，他正等着我们。"

# game/a4/2_3sisbride_siren.rpy:77
translate english sis_bride_435a7202:

    # lockhart "Ах да, [elin], что-то такое говорила."
    lockhart "啊，是的，[elin]好像提过。"

# game/a4/2_3sisbride_siren.rpy:78
translate english sis_bride_7dd84e16:

    # elin "Наверное он ужасно зол, раз отправил тебя."
    elin "他肯定气坏了，才派你过来。"

# game/a4/2_3sisbride_siren.rpy:79
translate english sis_bride_61ad9516:

    # lockhart "Не хочу заставлять короля ждать, закончу свой рассказ позже."
    lockhart "我可不想让国王久等，我稍后再讲完我的故事。"

# game/a4/2_3sisbride_siren.rpy:80
translate english sis_bride_d653be05:

    # me "Вот и отлично. Пойдем, [elin]."
    me "那太好了。走吧，[elin]。"

# game/a4/2_3sisbride_siren.rpy:83
translate english sis_bride_b61c6384:

    # me "{i}Что за чушь? Не нравится компания этого чудика, решай проблемы сама.{/i}"
    me "{i}什么鬼话？不喜欢这怪胎作伴，就自己解决问题。{/i}"

# game/a4/2_3sisbride_siren.rpy:84
translate english sis_bride_404d849b_1:

    # elin "{i}[mename]!{/i}"
    elin "{i}[mename]!{/i}"

# game/a4/2_3sisbride_siren.rpy:90
translate english sis_bride2_2d42945b:

    # me "Ага."
    me "嗯。"

# game/a4/2_3sisbride_siren.rpy:91
translate english sis_bride2_aea49877:

    # lockhart "Многие ошибочно думают, что звезда выбирается за человеком в момент его рождения. Но это не так..."
    lockhart "许多人错误地认为，星辰是在人出生的那一刻选定的。但并非如此..."

# game/a4/2_3sisbride_siren.rpy:92
translate english sis_bride2_3820771a:

    # me "..."
    me "..."

# game/a4/2_3sisbride_siren.rpy:93
translate english sis_bride2_15e09e66:

    # lockhart "На самом деле звезда выбирает себе подданных сама. Как только понимает что за характер и человека или лошади."
    lockhart "事实上，星辰是自行选择其臣民的。一旦它了解了人或马的性格。"

# game/a4/2_3sisbride_siren.rpy:94
translate english sis_bride2_748b87af:

    # me "Вы звездопоклонник?"
    me "您是星辰崇拜者？"

# game/a4/2_3sisbride_siren.rpy:95
translate english sis_bride2_9697af31:

    # lockhart "Тсс. Можно и так сказать, на Западе это очень популярно среди молодых. Сначала я скептически относился к этому, но как только я выяснил, что моя лошадь Тень ходит под звездой Каусса, я полностью поменял свое отношение к ней."
    lockhart "嘘。也可以这么说，这在西部的年轻人中很流行。起初我对此持怀疑态度，但当我弄清我的马“暗影”是在卡乌斯星下行走时，我对它的态度就完全改变了。"

# game/a4/2_3sisbride_siren.rpy:96
translate english sis_bride2_e8bdda94:

    # me "{i}Now I understand why my sister has such a look.{/i}"
    me "{i}Now I understand why my sister has such a look.{/i}"

# game/a4/2_3sisbride_siren.rpy:97
translate english sis_bride2_ab8bff5c:

    # me "{i}She's begging to stop this conversation.{/i}"
    me "{i}She's begging to stop this conversation.{/i}"

# game/a4/2_3sisbride_siren.rpy:102
translate english sis_bride2_52401ce3:

    # lockhart "I started smoking her leaves of smoke-grass and she..."
    lockhart "I let her breathe the smoke of the smoke-grass..."

# game/a4/2_3sisbride_siren.rpy:103
translate english sis_bride2_51302ec8:

    # me "Я тут кое-что вспомнил. Меня послала за сестрой мать. Им срочно нужно встретиться."
    me "我刚想起一件事。是母亲派我来找妹妹的。她们有急事要见面。"

# game/a4/2_3sisbride_siren.rpy:104
translate english sis_bride2_b022838c:

    # lockhart "Надо же. Ваша мать привела сюда вашу сестру немногим ранее."
    lockhart "哦，是吗。您的母亲不久前刚把您妹妹带到这儿来。"

# game/a4/2_3sisbride_siren.rpy:105
translate english sis_bride2_309381f3:

    # elin "Кхм-кхм...наверное что-то случилось."
    elin "咳...咳...大概是出了什么事吧。"

# game/a4/2_3sisbride_siren.rpy:106
translate english sis_bride2_b375d529:

    # me "Ага...."
    me "嗯..."

# game/a4/2_3sisbride_siren.rpy:107
translate english sis_bride2_5e42d6f2:

    # lockhart "Ну конечно. Видимо что-то срочное, раз вместо слуг послали целого принца."
    lockhart "当然。看来是急事，不然也不会派一位堂堂王子来，而不是仆人。"

