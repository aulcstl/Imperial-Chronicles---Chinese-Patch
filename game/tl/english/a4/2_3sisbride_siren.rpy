# game/a4/2_3sisbride_siren.rpy:223
translate english siren_5b0a013e:

    # me "Может быть. Но еще один день в тесном кафтане я бы не выдержал."
    me "也许吧。但再穿一天紧绷绷的长衣，我可真受不了。"

# game/a4/2_3sisbride_siren.rpy:224
translate english siren_fadeac73:

    # mom "Хотя бы отдавай вещи на стирку."
    mom "你至少把衣服送去洗洗吧。"

# game/a4/2_3sisbride_siren.rpy:225
translate english siren_31871489:

    # me "Разве они грязные?"
    me "难道它们脏了？"

# game/a4/2_3sisbride_siren.rpy:226
translate english siren_2779f2ce:

    # mom "Нет, но от тебя уже попахивает."
    mom "没有，但你身上已经有味儿了。"

# game/a4/2_3sisbride_siren.rpy:228
translate english siren_499362b3:

    # siren_b "Привет. Слуга на входе сказал я могу войти."
    siren_b "你好。门口的仆人说我可以进来。"

# game/a4/2_3sisbride_siren.rpy:229
translate english siren_95ff8626:

    # me "{i}Это...это очень молодая сирена. Обычно они значительно старше.{/i}"
    me "{i}这是...这是个非常年轻的海妖。她们通常年长得多。{/i}"

# game/a4/2_3sisbride_siren.rpy:230
translate english siren_36324c36:

    # siren_b "С чьей кровью нужно поговорить?"
    siren_b "需要与谁的血脉对话？"

# game/a4/2_3sisbride_siren.rpy:232
translate english siren_38f90f63:

    # me "С моей!"
    me "我的！"

# game/a4/2_3sisbride_siren.rpy:233
translate english siren_ea4eaa64:

    # mom "Это наверное какая-то ошибка. Вы мадам Розмари?"
    mom "这恐怕有什么误会。您是罗丝玛丽夫人吗？"

# game/a4/2_3sisbride_siren.rpy:234
translate english siren_def68912:

    # siren_b "Я? Нет. Я ее помощница. Мадам Розмари уехала на Запад, там бушует какая-то эпидемия. Меня зовут Нора."
    siren_b "我？不是。我是她的助手。罗丝玛丽夫人去了西部，那里正闹着某种瘟疫。我叫诺拉。"

# game/a4/2_3sisbride_siren.rpy:235
translate english siren_9eede075:

    # mom "Ага..."
    mom "嗯..."

# game/a4/2_3sisbride_siren.rpy:236
translate english siren_d2527fad:

    # siren_b "Не волнуйтесь, я умею все то же самое, что и мадам Розмари!"
    siren_b "别担心，罗丝玛丽夫人会的一切，我也会！"

# game/a4/2_3sisbride_siren.rpy:237
translate english siren_619c1fc1:

    # me "Я ей верю, мам."
    me "我相信她，妈。"

# game/a4/2_3sisbride_siren.rpy:238
translate english siren_22e7bc5f:

    # mom "Ну ладно... давайте попробуем."
    mom "那好吧...我们试试看。"

# game/a4/2_3sisbride_siren.rpy:240
translate english siren_19f386a7:

    # siren_b "Ляг и расслабься."
    siren_b "躺下，放松。"

# game/a4/2_3sisbride_siren.rpy:241
translate english siren_01822020:

    # me "Ладно."
    me "好的。"

# game/a4/2_3sisbride_siren.rpy:242
translate english siren_b059d2da:

    # siren_b "Ох, я чувствую в тебе сильную кровь...сильную, но нестабильную...эльфы и люди...два сильных рода сплелись в тебе."
    siren_b "哦，我感受到你体内强大的血脉...强大，但不稳定...精灵与人类...两个强大的谱系在你体内交织。"

# game/a4/2_3sisbride_siren.rpy:243
translate english siren_eb0d474a:

    # me "Верно."
    me "没错。"

# game/a4/2_3sisbride_siren.rpy:244
translate english siren_0300b60c:

    # mom "Кровь уже говорит с вами?"
    mom "血脉已经在对你说话了吗？"

# game/a4/2_3sisbride_siren.rpy:245
translate english siren_4cec0e88:

    # siren_b "Пока еще нет. Но я чувствую, как она бурлит...зовет.... "
    siren_b "还没有。但我能感觉到它在涌动...在呼唤..."

# game/a4/2_3sisbride_siren.rpy:246
translate english siren_39791627:

    # me "Правда? Я сейчас ничего не чувствую."
    me "真的吗？我现在什么都感觉不到。"

# game/a4/2_3sisbride_siren.rpy:247
translate english siren_c65571ce:

    # siren_b "Сейчас почувствуешь."
    siren_b "你马上就能感觉到了。"

# game/a4/2_3sisbride_siren.rpy:249
translate english siren_bd317eba:

    # siren_b "Закрой глаза. Расслабься. Глубоко вздохни."
    siren_b "闭上眼睛。放松。深吸一口气。"

# game/a4/2_3sisbride_siren.rpy:250
translate english siren_3820771a:

    # me "..."
    me "..."

# game/a4/2_3sisbride_siren.rpy:251
translate english siren_2f2ca87f:

    # siren_b "Какое твое самое первое воспоминание?"
    siren_b "你最初的记忆是什么？"

# game/a4/2_3sisbride_siren.rpy:252
translate english siren_70b8e1a0:

    # me "Эм...я не знаю...наверное лицо сестры, мне кажется нам было 2 или 3 года, мы ели что-то соленое и [elin] постоянно кривила лицо."
    me "呃...不知道...大概是妹妹的脸，那时我们好像两、三岁，在吃着什么咸的东西，[elin]总皱着脸。"

# game/a4/2_3sisbride_siren.rpy:253
translate english siren_80aa5ea1:

    # siren_b "Хорошо, теперь попробуй взглянуть глубже..."
    siren_b "好，现在试着看得更深一些..."

# game/a4/2_3sisbride_siren.rpy:254
translate english siren_8ef6852d:

    # me "Глубже куда?"
    me "更深是哪里？"

# game/a4/2_3sisbride_siren.rpy:256
translate english siren_546f024b:

    # siren_b "Представь что это воспоминание это крайняя ступень. Попробуй шагнуть дальше..."
    siren_b "想象这个记忆是最后一级台阶。试着再往前迈一步..."

# game/a4/2_3sisbride_siren.rpy:257
translate english siren_7c900288:

    # me "{i}Я ничего не чувствую...{/i}"
    me "{i}我什么也感觉不到...{/i}"

# game/a4/2_3sisbride_siren.rpy:258
translate english siren_587e6710:

    # siren_b "О...Да...голоса...слышишь? Они шепчут мне..."
    siren_b "哦...是的...声音...你听到了吗？它们在对我低语..."

# game/a4/2_3sisbride_siren.rpy:259
translate english siren_961bf600:

    # me "{i}А?{/i}"
    me "{i}啊？{/i}"

# game/a4/2_3sisbride_siren.rpy:260
translate english siren_e3e3b140:

    # siren_b "Твои предки...великие герои...что они говорят тебе?"
    siren_b "你的先祖们...伟大的英雄...他们在对你说什么？"

# game/a4/2_3sisbride_siren.rpy:261
translate english siren_316dc44f:

    # me "{i}Что за чушь она несет?{/i}"
    me "{i}她在胡说八道些什么？{/i}"

# game/a4/2_3sisbride_siren.rpy:262
translate english siren_9b1a4373:

    # siren_b "Они хотят чтобы ты что-то сделал...или чтобы тебе помогли что-то сделать, да?"
    siren_b "他们想让你做些什么...或者希望有人帮你做些什么，对吗？"

# game/a4/2_3sisbride_siren.rpy:263
translate english siren_81874225:

    # me "{i}Кажется я понял, в чем дело.{/i}"
    me "{i}我好像明白是怎么回事了。{/i}"

# game/a4/2_3sisbride_siren.rpy:265
translate english siren_e1f0e0fa:

    # me "Мам, можешь оставить нас ненадолго?"
    me "妈，你能出去一下吗？"

# game/a4/2_3sisbride_siren.rpy:266
translate english siren_b7f1a0f7:

    # mom "Ты уверен?"
    mom "你确定吗？"

# game/a4/2_3sisbride_siren.rpy:267
translate english siren_a89ca67a:

    # me "Да. Пожалуйста."
    me "是的。拜托了。"

# game/a4/2_3sisbride_siren.rpy:268
translate english siren_60387971:

    # mom "Ладно."
    mom "好吧。"

# game/a4/2_3sisbride_siren.rpy:270
translate english siren_a7879f3a:

    # me "Ну и как ты это объяснишь?"
    me "那么，你如何解释？"

# game/a4/2_3sisbride_siren.rpy:271
translate english siren_bd77274b:

    # siren_b "А? Что именно?"
    siren_b "嗯？解释什么？"

# game/a4/2_3sisbride_siren.rpy:272
translate english siren_67472eea:

    # me "Чушь которую ты несешь. Мои предки великие герои и прочее...со мной никто не говорит."
    me "你胡诌的那一套。什么我的先祖是伟大英雄之类的...根本没人跟我说话。"

# game/a4/2_3sisbride_siren.rpy:273
translate english siren_46d18927:

    # siren_b "Говорит, надо только придумать, кто говорит и что именно они говорят, понимаешь?"
    siren_b "他们在说，只需要编出来是谁在说，以及他们具体说了什么，明白吗？"

# game/a4/2_3sisbride_siren.rpy:274
translate english siren_89bfec03:

    # me "{i}Я ничего не чувствую...{/i}"
    me "{i}我什么也感觉不到...{/i}"

# game/a4/2_3sisbride_siren.rpy:275
translate english siren_4b126d7d:

    # siren_b "Секундочку, ты что, правда слышишь голоса?"
    siren_b "等等，你难道真能听到声音？"

# game/a4/2_3sisbride_siren.rpy:276
translate english siren_2c92e016:

    # me "Что это значит? Разве ты не должна слышать их тоже?"
    me "这话是什么意思？难道你不也该听到吗？"

# game/a4/2_3sisbride_siren.rpy:277
translate english siren_ff44e2f0:

    # siren_b "Я...погоди я тебе кое-что объясню."
    siren_b "我...等一下，我给你解释一下。"

# game/a4/2_3sisbride_siren.rpy:279
translate english siren_aa70eaec:

    # siren_b "Я умею разговаривать с кровью, но она говорит мне то, что хочет тот, кто меня нанял, понимаешь? Ну или в твоем случае, тот, из-за кого эти сеансы будут продолжаться."
    siren_b "我能与血脉交谈，但它告诉我的内容是雇佣我的人想说的，你明白吗？或者说，在你这种情况下，就是那个希望这些疗程能继续下去的人。"

# game/a4/2_3sisbride_siren.rpy:280
translate english siren_60358084:

    # me "Эм..."
    me "呃..."

# game/a4/2_3sisbride_siren.rpy:281
translate english siren_eca900b1:

    # siren_b "Муж, который хочет доказать, что это внутренний голос его умершего брата совратил его на измену, дворянин, желающий доказать впечатлительным друзьям, что в его роду были короли, вор, желающий доказать, что это голоса в голове надоумили его обокрасть торговца..."
    siren_b "比如，想证明是亡兄内心的声音诱使他出轨的丈夫；想向容易受影响的朋友证明自己祖上出过国王的贵族；想证明是脑子里声音唆使他去偷商人的小偷..."

# game/a4/2_3sisbride_siren.rpy:282
translate english siren_b872f79a:

    # me "Ты мошенница."
    me "你是个骗子。"

# game/a4/2_3sisbride_siren.rpy:283
translate english siren_b033603b:

    # siren_b "Как грубо. Я скорее универсальный помощник. Мне жаль, я думала ты знаешь, что делаешь."
    siren_b "这话真难听。我更像个全能助手。抱歉，我以为你知道自己在做什么。"

# game/a4/2_3sisbride_siren.rpy:284
translate english siren_47cda196:

    # me "Я действительно слышу голоса. А с сиренами я прежде не был знаком, так что не знал что разговор с кровью это большая ложь."
    me "我是真的能听见声音。而我之前没接触过海妖，所以不知道与血脉对话根本就是大骗局。"

# game/a4/2_3sisbride_siren.rpy:285
translate english siren_0fdd70a3:

    # siren_b "Может кто-то и умеет говорить с ней, но если честно, я думаю твой случай настолько редкий, что я гораздо чаще помогаю людям, чем те сирены, что действительно могут говорить с кровью."
    siren_b "也许有人真能与之交谈，但说实话，我认为你这种情况非常罕见，我帮人的次数，远比那些真正能与血脉交谈的海妖要多得多。"

# game/a4/2_3sisbride_siren.rpy:286
translate english siren_3f4be9a3:

    # me "Мдауш..."
    me "唉..."

# game/a4/2_3sisbride_siren.rpy:287
translate english siren_6cbbaa02:

    # siren_b "Ну так что? Помочь тебе? Хочешь скажу, что голоса велели тебе поцеловать королеву?"
    siren_b "那么，如何？要我帮忙吗？要不要我说，那些声音指示你去亲吻王后？"

# game/a4/2_3sisbride_siren.rpy:288
translate english siren_79cfb404:

    # me "Это моя мать."
    me "那是我母亲。"

# game/a4/2_3sisbride_siren.rpy:289
translate english siren_cee8fbde:

    # siren_b "Ну и что? Я тебя уверяю, это самое безобидное извращение из тех, с которыми я обычно сталкиваюсь."
    siren_b "那又怎样？我向你保证，在我通常遇到的怪癖里，这算是最无伤大雅的了。"

# game/a4/2_3sisbride_siren.rpy:293
translate english siren_3dc2f89b:

    # me "...Ну...может что-то более весомое чем поцелуй?"
    me "...嗯...能不能来点比亲吻更有分量的？"

# game/a4/2_3sisbride_siren.rpy:294
translate english siren_366211e4:

    # siren_b "Хех, я что-нибудь придумаю."
    siren_b "呵，我会想出点什么的。"

# game/a4/2_3sisbride_siren.rpy:297
translate english siren_df9ca5a1:

    # me "Ты предлагаешь мне обманывать собственную мать и еще платить тебе за это золотом?"
    me "你是建议我欺骗自己的母亲，还要付你金币？"

# game/a4/2_3sisbride_siren.rpy:298
translate english siren_24ea7b22:

    # siren_b "Ну ты ведь..."
    siren_b "可你不是..."

# game/a4/2_3sisbride_siren.rpy:299
translate english siren_0a910d9a:

    # me "Убирайся отсюда, пока твоя голова еще на плечах."
    me "趁你脑袋还在脖子上，赶紧滚。"

# game/a4/2_3sisbride_siren.rpy:300
translate english siren_c8a756de:

    # siren_b "Ладно-ладно. Успокойся. Ты меня больше никогда не увидишь."
    siren_b "好吧，好吧。冷静。你这辈子不会再见到我了。"

# game/a4/2_3sisbride_siren.rpy:301
translate english siren_406702e8:

    # me "Надеюсь на это. Шарлатанка."
    me "希望如此。江湖骗子。"

# game/a4/2_3sisbride_siren.rpy:304
translate english siren_52dc78b6:

    # mom "Все в порядке?"
    mom "一切都好吗？"

# game/a4/2_3sisbride_siren.rpy:305
translate english siren_b1605620:

    # siren_b "Да. Сеанс идет хорошо. Думаю дальше нужно продолжить с вами."
    siren_b "是的。疗程进行得很顺利。我认为接下来该在您这边继续。"

# game/a4/2_3sisbride_siren.rpy:306
translate english siren_32f53abc:

    # mom "Со мной? Я не слышу голосов."
    mom "我？我听不到声音。"

# game/a4/2_3sisbride_siren.rpy:307
translate english siren_fc573814:

    # siren_b "Дело не в этом. Вы связаны кровно, а значит можете стать проводником."
    siren_b "重点不在这里。你们血脉相连，意味着您可以成为一个媒介。"

# game/a4/2_3sisbride_siren.rpy:308
translate english siren_3b2a43ba:

    # mom "Проводником?"
    mom "媒介？"

# game/a4/2_3sisbride_siren.rpy:309
translate english siren_745e1a23:

    # siren_b "Да. Это поможет нас установить связь с предками сильнее. Пожалуйста, садитесь к сыну. Я покажу как."
    siren_b "对。这能帮我们与先祖建立更强的联系。请您坐到您儿子身边。我会教您怎么做。"

# game/a4/2_3sisbride_siren.rpy:311
translate english siren_32e5e9a8:

    # mom "Тебе удобно?"
    mom "你还好吗？"

# game/a4/2_3sisbride_siren.rpy:312
translate english siren_656b496d:

    # me "Все нормально, мам."
    me "没事，妈。"

# game/a4/2_3sisbride_siren.rpy:313
translate english siren_8735c06f:

    # mom "{size=-12}Думаешь нам правда стоит это делать?{/size}"
    mom "{size=-12}你觉得我们真的该这么做吗？{/size}"

# game/a4/2_3sisbride_siren.rpy:314
translate english siren_736282ee:

    # me "{size=-12}Конечно, это действительно...помогает...я так думаю. Я ей доверяю.{/size}"
    me "{size=-12}当然，这真的...有帮助...我觉得。我相信她。{/size}"

# game/a4/2_3sisbride_siren.rpy:315
translate english siren_e7ec3cad:

    # siren_b "Вы готовы?"
    siren_b "准备好了吗？"

# game/a4/2_3sisbride_siren.rpy:316
translate english siren_79699791:

    # mom "Я готова. Только что нужно делать?"
    mom "我准备好了。但需要做什么？"

# game/a4/2_3sisbride_siren.rpy:317
translate english siren_24a35fdd:

    # me "Да. Что нам делать?"
    me "是啊。我们该怎么做？"

# game/a4/2_3sisbride_siren.rpy:319
translate english siren_ee45ce0a:

    # siren_b "Очень просто. Смотрите мне в глаза."
    siren_b "很简单。看着我的眼睛。"

# game/a4/2_3sisbride_siren.rpy:320
translate english siren_15620dc1:

    # mom "Я? Или мы оба."
    mom "我吗？还是我们两人一起？"

# game/a4/2_3sisbride_siren.rpy:321
translate english siren_179a8032:

    # siren_b "Только вы."
    siren_b "只要您。"

# game/a4/2_3sisbride_siren.rpy:322
translate english siren_c641a42d:

    # mom "Ладно. Что-то еще?"
    mom "好吧。还有别的吗？"

# game/a4/2_3sisbride_siren.rpy:323
translate english siren_f4979404:

    # siren_b "Нет. Теперь просто постарайтесь расслабиться."
    siren_b "没了。现在请试着放松。"

# game/a4/2_3sisbride_siren.rpy:324
translate english siren_60387971_1:

    # mom "Ладно."
    mom "好的。"

# game/a4/2_3sisbride_siren.rpy:325
translate english siren_b22c3786:

    # siren_b "Nvahn...nvahn..."
    siren_b "Nvahn... nvahn..."

