    # cata "О чем говорил Генри с Варго?"
    cata "亨利和瓦尔戈谈了些什么？"

# game/a8/5after_party.rpy:294
translate english after_party_3820771a_2:

    # me "..."
    me "..."

# game/a8/5after_party.rpy:299
translate english after_party_a5bb1a9a:

    # cata "Но?"
    cata "但是？"

# game/a8/5after_party.rpy:300
translate english after_party_ad26361a:

    # me "Но они договорились что-то начать делать."
    me "他们商定要开始做些什么。"

