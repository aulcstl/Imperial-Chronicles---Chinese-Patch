translate english after_party_2739fce3:

    # cata "Трупы. Горы трупов. Многие люди, которых я знаю - погибнут."
    cata "尸体。堆积如山的尸体。我认识的许多人——会死。"

# game/a8/5after_party.rpy:277
translate english after_party_5ac38cf1:

    # me "Почему?"
    me "为什么？"

# game/a8/5after_party.rpy:278
translate english after_party_c34da8ec:

    # cata "Город в огне. Весь город пылает я видела это."
    cata "城市在燃烧。整座城都在火焰中，我看到了。"

# game/a8/5after_party.rpy:279
translate english after_party_3820771a_1:

    # me "..."
    me "..."

