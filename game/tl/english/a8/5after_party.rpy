    # me "Пока, Катарина."
    me "再见，卡塔琳娜。"

# game/a8/5after_party.rpy:333
translate english after_party_5a7a7577:

    # me "Нет."
    me "不。"

# game/a8/5after_party.rpy:334
translate english after_party_e2e5fd19:

    # cata "Что же...по крайней мере ты честен."
    cata "这……至少你倒是诚实。"

# game/a8/5after_party.rpy:335
translate english after_party_3820771a_5:

    # me "..."
    me "..."

# game/a8/5after_party.rpy:336
