# game/a8/5after_party.rpy:289
translate english after_party_cff70402:

    # me "Я не знаю. Может быть это и правда произойдет."
    me "我不知道。也许它真的会发生。"

# game/a8/5after_party.rpy:290
translate english after_party_24c95b91:

    # cata "..."
    cata "..."

# game/a8/5after_party.rpy:291
translate english after_party_f2dae8fb:

    # me "Может кровопролитие еще можно предотвратить."
    me "也许这场大流血还可以阻止。"

