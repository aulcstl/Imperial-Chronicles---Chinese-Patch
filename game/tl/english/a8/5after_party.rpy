    cata "太可怕了！"

# game/a8/5after_party.rpy:270
translate english after_party_14cfb7fd:

    # me "Голова болит?"
    me "头疼吗？"

# game/a8/5after_party.rpy:271
translate english after_party_628c9afa:

    # cata "Да. Что? Нет! Дело не в этом!"
    cata "疼。什么？不是！问题不在这！"

