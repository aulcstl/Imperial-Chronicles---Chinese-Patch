# TODO: Translation updated at 2025-02-20 18:42

# game/a8/5after_party.rpy:2
translate english after_party_591eb588:

    # "Ночью."
    "到了晚上。"

# game/a8/5after_party.rpy:6
translate english after_party_39e5c5ba:

    # cata "...да? Может тогда всех надо убить?"
    cata "...是吗？那是不是该把所有人都杀了？"

# game/a8/5after_party.rpy:7
translate english after_party_893344b9:

    # cassius "Почему вы все интерпретируете мои слова, будто я хочу всех убить?"
    cassius "为什么你们全都把我的话理解为我想杀光所有人？"

# game/a8/5after_party.rpy:8
translate english after_party_132c43ee:

    # valer "Ты об этом и говоришь."
    valer "你说的就是这个意思。"

# game/a8/5after_party.rpy:9
translate english after_party_144db61b:

    # cassius "Нет. Я говорю о том, что нужно бить в слабые места и бить первыми."
    cassius "不。我说的是，应该攻击弱点，并且要先发制人。"

# game/a8/5after_party.rpy:10
translate english after_party_cc14c4b5:

    # valer "И что за слабые места?"
    valer "那所谓的弱点是什么？"

# game/a8/5after_party.rpy:11
translate english after_party_ef771ede:

    # cassius "Лорд Гвидон в городе."
    cassius "格维多勋爵在城里。"

# game/a8/5after_party.rpy:12
translate english after_party_43df08ba:

    # valer "И?"
    valer "然后呢？"

# game/a8/5after_party.rpy:14
translate english after_party_6661d6f8:

    # cata "Разве непонятно? Он хочет его убить."
    cata "还不明白吗？他想杀了他。"

# game/a8/5after_party.rpy:15
translate english after_party_840187c8:

    # valer "Привет, [mename], я все ждал когда ты присоединишься к нашей беседе об убийствах."
    valer "你好，[mename]，我一直在等你加入我们这场关于谋杀的讨论。"

# game/a8/5after_party.rpy:16
translate english after_party_9eb7cf9d:

    # cassius "Он самый главный инициатор насилия - он сам руководит вооруженными рейдами в городе, арестовывает наших сторонников."
    cassius "他是暴力最大的煽动者——他亲自指挥城里的武装突袭，逮捕我们的支持者。"

# game/a8/5after_party.rpy:17
translate english after_party_00eb5650:

    # cata "Я не слышала, чтобы кого-то казнили."
    cata "我没听说有谁被处决了。"

# game/a8/5after_party.rpy:18
translate english after_party_b6a05ba0:

    # cassius "Это пока что. Они боятся эскалации насилия. Но когда поймают всех до единого - перевешают как собак."
    cassius "暂时而已。他们害怕暴力升级。但等他们把我们的人一个不剩全抓起来，就会像绞死野狗一样绞死他们。"

# game/a8/5after_party.rpy:19
translate english after_party_f0387a0e:

    # cata "Ты так думаешь, потому что ты бы так и сделал."
    cata "你这么想，是因为换作你，你也会这么做。"

# game/a8/5after_party.rpy:20
translate english after_party_d27aa1f4:

    # cassius "Конечно. Это политика. Здесь руководствуются практичностью поступков, а не их моральной составляющей."
    cassius "当然。这就是政治。这里指导行为的是行为的实用性，而不是它们的道德成分。"

# game/a8/5after_party.rpy:21
translate english after_party_89fae950:

    # cata "Удивительно. Каждая резня начиналась с того, что обе стороны считали, что действуют практично, но по итогу проигрывали оба."
    cata "真令人惊讶。每一次大屠杀都是这样开始的:双方都认为自己是在务实行事，但最终双方都输了。"

# game/a8/5after_party.rpy:24
translate english after_party_ffbed5a6:

    # me "Кхм-кхм."
    me "咳咳。"

# game/a8/5after_party.rpy:25
translate english after_party_c0c8b685:

    # valer "Не волнуйся, [mename], я не осуждаю...'твоих' взглядов на эту ситуацию."
    valer "别担心，[mename]，我并不是在谴责……你对此事的“观点”。"

# game/a8/5after_party.rpy:26
translate english after_party_f4774d00:

    # me "Уверен?"
    me "你确定？"

# game/a8/5after_party.rpy:27
translate english after_party_1067d829:

    # valer "Конечно. Я сторонник свободы, так что если все добровольно - и волноваться не о чем."
    valer "当然。我是自由的支持者，所以如果一切是自愿的——那就没什么可担心的。"

# game/a8/5after_party.rpy:28
translate english after_party_a9851127:

    # me "Это хорошо..."
    me "那就好……"

# game/a8/5after_party.rpy:29
translate english after_party_16305546:

    # valer "Будь уверен я ничего против не имею."
    valer "你放心，我没有任何意见。"

# game/a8/5after_party.rpy:30
translate english after_party_780c701b:

    # me "Ну дело не только в твоем отношении..."
    me "这不仅仅关乎你的态度……"

# game/a8/5after_party.rpy:31
translate english after_party_1a91a795:

    # valer "Я понимаю. Именно поэтому я никогда не стал бы...рассказывать об этом кому-то еще. Клянусь."
    valer "我明白。正因为如此，我才绝不会……把这事告诉其他任何人。我发誓。"

# game/a8/5after_party.rpy:32
translate english after_party_9d208e6e:

    # cassius "Вы что несете?"
    cassius "你们在胡说些什么？"

# game/a8/5after_party.rpy:33
translate english after_party_15736413:

    # cata "Я тоже не поняла о чем они."
    cata "我也没听懂他们在说什么。"

# game/a8/5after_party.rpy:34
translate english after_party_7123bb9a:

    # valer "О том же о чем и вы. О допустимости насилия."
    valer "和你们说的一样。关于暴力的可容许性。"

# game/a8/5after_party.rpy:35
translate english after_party_ccd1c47d:

    # me "Ага. Об этом."
    me "啊。是这个啊。"

# game/a8/5after_party.rpy:37
translate english after_party_2320c0f5:

    # cassius "Ну что ты об этом думаешь я знаю."
    cassius "你的想法我是知道的。"

# game/a8/5after_party.rpy:38
translate english after_party_a31aad60:

    # valer "Я знаю, что я тебе нравлюсь, Кассиус, но тебе меня не переубедить."
    valer "我知道你对我有好感，卡西乌斯，但你是说服不了我的。"

# game/a8/5after_party.rpy:39
translate english after_party_8781bde8:

    # cassius "Я и не пытался."
    cassius "我本来也没想说服你。"

# game/a8/5after_party.rpy:40
translate english after_party_a338a7c2:

    # valer "Мы с Катариной уже давно поняли, что ты просто жаждешь крови."
    valer "我和卡塔琳娜早就看明白了，你就是渴望流血。"

# game/a8/5after_party.rpy:41
translate english after_party_1fadd1f3:

    # cata "Ее не только он жаждет, но и..."
    cata "渴望这个的可不只是他，还有……"

# game/a8/5after_party.rpy:42
translate english after_party_48656844:

    # cassius "Ты просто слишком легкомысленный. Смерть одного старика может оставить в живых сотни, если не тысячи наших сторонников."
    cassius "你只是太轻率了。一个老头子的死，也许能换来我们成百甚至上千支持者的性命。"

# game/a8/5after_party.rpy:43
translate english after_party_b2e3cb5b:

    # valer "И поэтому надо его убить, да-да."
    valer "所以就为这个必须杀了他，对吧，对。"

# game/a8/5after_party.rpy:44
translate english after_party_0e161ef8:

    # cassius "А что? Прятаться по норам и ждать пока нас всех переловят?"
    cassius "怎么？难道要躲在地洞里，等着被他们一个个抓走吗？"

# game/a8/5after_party.rpy:45
translate english after_party_4c46adea:

    # valer "Начнем нападать на лордов и тут же объединим их против нас."
    valer "我们一开始攻击勋爵们，他们立刻就会联合起来对付我们。"

# game/a8/5after_party.rpy:46
translate english after_party_08eef133:

    # cassius "Есть другие варианты?"
    cassius "还有其他选择吗？"

# game/a8/5after_party.rpy:47
translate english after_party_1dd1e2fc:

    # valer "Разумеется. Нужно вооружиться. Всем. И если за нами придут - дать отпор."
    valer "当然有。需要武装起来。所有人都武装起来。如果有人来抓我们——就予以回击。"

# game/a8/5after_party.rpy:48
translate english after_party_0756f08c:

    # cassius "Ну ты гений. Вооруженная оборона, по-твоему, с насилием не связана?"
    cassius "你可真是个天才。武装防卫，在你看来，难道就不涉及暴力了？"

# game/a8/5after_party.rpy:49
translate english after_party_f94ff33b:

    # valer "Связана, но убить кого-то, когда он на тебя нападает и напасть самому это разные вещи."
    valer "涉及，但别人攻击你时杀死对方，和你自己主动去攻击，是两回事。"

# game/a8/5after_party.rpy:50
translate english after_party_18476a16:

    # cassius "Думаешь лордам будет не насрать, как именно умрет один из них?"
    cassius "你以为勋爵们会在乎他们其中一人具体是怎么死的吗？"

# game/a8/5after_party.rpy:51
translate english after_party_01ae0836:

    # valer "Нет. И не только им будет не насрать. Простые люди увидят, что мы готовы бороться, но мы не хотим насаждать наши идеи силой. Но от тех, кто будет посягать на нашу свободу мы готовы обороняться."
    valer "不。不仅他们会在乎。普通人会看到我们准备斗争，但我们不想用武力强加我们的理念。但对于那些企图侵犯我们自由的人，我们准备自卫。"

# game/a8/5after_party.rpy:52
translate english after_party_5b145490:

    # cassius "Да ты романтик. Романтик и идиот."
    cassius "你可真是个浪漫主义者。浪漫的傻瓜。"

# game/a8/5after_party.rpy:54
translate english after_party_8780764b:

    # cata "Оба ваших метода все равно приведут к катастрофе."
    cata "你们俩的方法最终都会导致灾难。"

# game/a8/5after_party.rpy:55
translate english after_party_407e64f3:

    # valer "Я думал ты на моей стороне!"
    valer "我还以为你站在我这边的！"

# game/a8/5after_party.rpy:56
translate english after_party_12059a1c:

    # cata "Ты просто объявишь часть людей свободными от обязательств, что на них наложены их происхождением?"
    cata "你是打算直接宣布一部分人，免除因其出身而强加给他们的义务吗？"

# game/a8/5after_party.rpy:57
translate english after_party_b055c629:

    # valer "Если они будут вооружены и организованы никто не заставит их соблюдать обязательства, на которые они не подписывались."
    valer "如果他们武装起来、组织起来，没人能强迫他们遵守那些他们从未同意的义务。"

# game/a8/5after_party.rpy:58
translate english after_party_7ef13b73:

    # cata "Как, по-твоему, могут соседствовать два центра силы? Лорды этого не будут терпеть."
    cata "你觉得，两个权力中心能够并存？勋爵们是不会容忍的。"

# game/a8/5after_party.rpy:59
translate english after_party_d02e6f76:

    # cassius "Даже Катарина поняла какой у тебя идиотский план."
    cassius "连卡塔琳娜都明白了你的计划有多蠢。"

# game/a8/5after_party.rpy:60
translate english after_party_35952361:

    # cata "У тебя не лучше. Если нападать на лордов уже через неделю улицы будут кишеть солдатами, а всех пойманных начнут вешать незамедлительно."
    cata "你的也好不到哪儿去。如果开始攻击勋爵们，不出一个星期，街上就会挤满士兵，所有被抓的人都会被立刻绞死。"

# game/a8/5after_party.rpy:61
translate english after_party_cbce3215:

    # cassius "Наши идеи тебя не устраивают. А что предложишь ты?"
    cassius "我们的想法你都不满意。那你倒是有什么提议？"

# game/a8/5after_party.rpy:62
translate english after_party_f9398986:

    # cata "Не знаю!"
    cata "我不知道！"

# game/a8/5after_party.rpy:63
translate english after_party_eec7c260:

    # cassius "Не знаешь?"
    cassius "不知道？"

# game/a8/5after_party.rpy:64
translate english after_party_8221c85f:

    # cata "Я не знаю. Я просто не хочу, чтобы люди умирали!"
    cata "我不知道。我只是不希望人们死去！"

# game/a8/5after_party.rpy:65
translate english after_party_f820652c:

    # valer "Благородно, но наивно."
    valer "很高尚，但太天真了。"

# game/a8/5after_party.rpy:66
translate english after_party_48326126:

    # cassius "Это просто наивно."
    cassius "这简直太天真了。"

# game/a8/5after_party.rpy:68
translate english after_party_7b929ce4:

    # valer "Знаете. На самом деле я собрал вас не для того, чтобы в очередной раз поспорить про нашу республику."
    valer "你们知道吗。其实我把你们聚在一起，不是为了再一次争论我们的共和国。"

# game/a8/5after_party.rpy:69
translate english after_party_e2e55940:

    # cata "Что это?"
    cata "这是什么？"

# game/a8/5after_party.rpy:70
translate english after_party_7f080554:

    # cassius "Выглядит как крестьянский самогон."
    cassius "看着像农民酿的私酒。"

# game/a8/5after_party.rpy:71
translate english after_party_08d80840:

    # valer "Это белая кровь."
    valer "这是白血。"

# game/a8/5after_party.rpy:72
translate english after_party_3b34fa16:

    # cata "Белая кровь? Зачем она тебе?"
    cata "白血？你要这东西干什么？"

# game/a8/5after_party.rpy:73
translate english after_party_14f2803d:

    # cassius "По-моему белая кровь более мутная."
    cassius "我觉得白血应该更浑浊一些。"

# game/a8/5after_party.rpy:74
translate english after_party_37d2b006:

    # valer "Ну это не совсем белая кровь...скорее что-то вроде эссенции смешанной с...я не уверен."
    valer "嗯，这不完全是白血……更像是混合了……我也不太确定。"

# game/a8/5after_party.rpy:75
translate english after_party_3fdfd6e1:

    # cassius "Звучит многообещающе. И что ты собрался с ней делать?"
    cassius "听起来很了不得。你打算拿它做什么？"

# game/a8/5after_party.rpy:76
translate english after_party_5e61106f:

    # valer "Пить!"
    valer "喝！"

# game/a8/5after_party.rpy:77
translate english after_party_d11a89f4:

    # cata "Пить?"
    cata "喝？"

# game/a8/5after_party.rpy:78
translate english after_party_7f7fb461:

    # valer "Эта штука позволяет видеть будущее. Попробуем?"
    valer "这东西能让人看到未来。试试看？"

# game/a8/5after_party.rpy:79
translate english after_party_137bebb1:

    # cassius "Ты вообще идиот?"
    cassius "你是真的蠢吗？"

# game/a8/5after_party.rpy:80
translate english after_party_93460f97:

    # valer "Катарина?"
    valer "卡塔琳娜？"

# game/a8/5after_party.rpy:81
translate english after_party_4508ac28:

    # cata "Эм...."
    cata "呃……"

# game/a8/5after_party.rpy:83
translate english after_party_bd458976:

    # valer "Ладно, с этими трусами все понятно. Ну ты то, [mename], заглянешь в будущее вместе со мной?"
    valer "好吧，这些胆小鬼的意思很明白了。那你呢，[mename]，愿意和我一起窥探一下未来吗？"

# game/a8/5after_party.rpy:84
translate english after_party_06c7525f:

    # me "Ты уже пил это раньше?"
    me "你以前喝过这个？"

# game/a8/5after_party.rpy:85
translate english after_party_45153878:

    # valer "Да."
    valer "是的。"

# game/a8/5after_party.rpy:86
translate english after_party_cd4db6c0:

    # cata "И что? Работает?"
    cata "然后呢？管用吗？"

# game/a8/5after_party.rpy:87
translate english after_party_3537749c:

    # cassius "Сомневаюсь."
    cassius "我表示怀疑。"

# game/a8/5after_party.rpy:89
translate english after_party_743c6b74:

    # valer "А! Хрен с вами!"
    valer "啊！去你们的！"

# game/a8/5after_party.rpy:90
translate english after_party_99bcca81:

    # cassius "Валериан, что передать твоей матери, сказать что ее сын погиб, добровольно выпив белой крови, или придумать что-то менее идиотское?"
    cassius "Valerian，我该怎么跟你母亲交代？是说你儿子是自愿喝了白血死掉的，还是编个没那么蠢的理由？"

# game/a8/5after_party.rpy:91
translate english after_party_d1e37aae:

    # valer "Если я увижу тебя в будущем, обязательно расскажу отрасли ли у тебя яица."
    valer "要是我在未来里看见你，一定告诉你你的蛋蛋还在不在。"

# game/a8/5after_party.rpy:92
translate english after_party_7e9974b0:

    # cassius "С такими экспериментами ты скоро перестанешь видеть и настоящее."
    cassius "再这么实验下去，你很快连现在也看不见了。"

# game/a8/5after_party.rpy:93
translate english after_party_dd57cc73:

    # cata "[mename], ты же не будешь пить это?"
    cata "[mename]，你不会也要喝这个吧？"

# game/a8/5after_party.rpy:95
translate english after_party_8610b2b1:

    # me "{i}Я уже пил это раньше. Локхарт давал мне попробовать. Хочу я сделать это еще раз?{/i}"
    me "{i}我以前喝过了。Lockhart给我尝过。我还想再来一次吗？{/i}"

# game/a8/5after_party.rpy:101
translate english after_party_dee52690:

    # cata "[mename]?"
    cata "[mename]?"

# game/a8/5after_party.rpy:102
translate english after_party_81ea2c7b:

    # valer "Вот. Еще один человек широкой воли в помещении."
    valer "瞧。这屋里又多了个胆大包天的人。"

# game/a8/5after_party.rpy:103
translate english after_party_210b017d:

    # cassius "Вы оба спятили."
    cassius "你们两个都疯了。"

# game/a8/5after_party.rpy:104
translate english after_party_ea02eda2:

    # cata "Неужели это работает?"
    cata "这东西难道真有效？"

# game/a8/5after_party.rpy:105
translate english after_party_de90d832:

    # cassius "Ты то куда, Катарина? Не вздумай пить эту дрянь."
    cassius "你去哪儿，卡塔琳娜？千万别喝这鬼东西。"

# game/a8/5after_party.rpy:106
translate english after_party_d581ef5d:

    # valer "[mename] оставь на нашего друга Кассиуса."
    valer "[mename]，把我们的朋友卡西乌斯看住。"

