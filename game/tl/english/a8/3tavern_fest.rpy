# game/a8/3tavern_fest.rpy:390
translate english tavern_fest2_025fb6a6:

    # me "Ладно, давай вместе."
    me "行吧，咱俩一块儿来。"

# game/a8/3tavern_fest.rpy:391
translate english tavern_fest2_ee00f9f8:

    # valer "Давай. Три..."
    valer "来。三..."

# game/a8/3tavern_fest.rpy:392
translate english tavern_fest2_0627e1f1:

    # me "Два..."
    me "二..."

# game/a8/3tavern_fest.rpy:393
translate english tavern_fest2_6ef47773:

    # valer "Один..."
    valer "一..."

# game/a8/3tavern_fest.rpy:395
translate english tavern_fest2_3533a58c:

    # valer "Пиздец!"
    valer "我操！"

# game/a8/3tavern_fest.rpy:396
translate english tavern_fest2_9a80b446:

    # elin "Я...я все по рецепту делала?"
    elin "我...我可是照着食谱做的？"

# game/a8/3tavern_fest.rpy:397
translate english tavern_fest2_10e6421d:

    # me "По рецепту яда для мышей?"
    me "照着鼠药的食谱吗？"

# game/a8/3tavern_fest.rpy:398
translate english tavern_fest2_6fe66e9e:

    # valer "У меня...у меня как будто кишки во рту...омерзительно..."
    valer "我感觉...感觉肠子都要翻到嘴里了...太恶心了..."

# game/a8/3tavern_fest.rpy:399
translate english tavern_fest2_39709fe1:

    # elin "Сильно плохо? Я могу немного вас порегенерировать."
    elin "很难受吗？我可以稍微给你们治疗一下。"

# game/a8/3tavern_fest.rpy:400
translate english tavern_fest2_df2b0c48:

    # me "Нет...хватит магии."
    me "不...别再魔法了。"

# game/a8/3tavern_fest.rpy:401
translate english tavern_fest2_cb7e330e:

    # valer "Я протрезвел."
    valer "我酒醒了。"

# game/a8/3tavern_fest.rpy:402
translate english tavern_fest2_b062f272:

    # me "Я тоже. Я выблевал вообще все что во мне было."
    me "我也是。我把肚子里所有东西都吐光了。"

# game/a8/3tavern_fest.rpy:403
translate english tavern_fest2_85762cc7:

    # elin "Это...это чушь какая-то я сто раз делала такой суп в башне и все было нормально."
    elin "这...这简直是胡说八道，我在塔里做过无数次这种汤，都好好的。"

# game/a8/3tavern_fest.rpy:404
translate english tavern_fest2_5d81fe64:

    # me "Пиздец, наверное поэтому маги в таком упадке."
    me "我操，大概这就是为什么法师这行这么衰败吧。"

# game/a8/3tavern_fest.rpy:405
translate english tavern_fest2_3d8557f6:

    # valer "Все...я все...у меня тоже больше ничего внутри нет."
    valer "好了...我好了...我也什么都吐不出来了。"

# game/a8/3tavern_fest.rpy:406
translate english tavern_fest2_23edaf68:

    # elin "Вам стало лучше?"
    elin "你们感觉好点了吗？"

# game/a8/3tavern_fest.rpy:407
translate english tavern_fest2_0bc1c9bb:

    # me "Набери нам пока что пива, надо перебить этот мерзотный вкус."
    me "先给我们倒点啤酒，得压一压这股恶心的味道。"

# game/a8/3tavern_fest.rpy:408
translate english tavern_fest2_97034119:

    # elin "Ладно. Извините..."
    elin "好吧。对不起..."

# game/a8/3tavern_fest.rpy:411
translate english tavern_fest2_7959bf32:

    # me "Скучаешь?"
    me "觉得无聊吗？"

# game/a8/3tavern_fest.rpy:412
translate english tavern_fest2_0a8f013c:

    # josephine "Немного."
    josephine "有一点。"

# game/a8/3tavern_fest.rpy:413
translate english tavern_fest2_2804dd9b:

    # me "А где Генри?"
    me "亨利呢？"

# game/a8/3tavern_fest.rpy:414
translate english tavern_fest2_0dfe9411:

    # josephine "..."
    josephine "..."

# game/a8/3tavern_fest.rpy:415
translate english tavern_fest2_771e3545:

    # me "Ладно. Я принес вина."
    me "算了。我带酒来了。"

# game/a8/3tavern_fest.rpy:416
translate english tavern_fest2_c503362a:

    # josephine "Вина? Я уже пила сегодня, [mename]."
    josephine "酒？我今天已经喝过了，[mename]。"

# game/a8/3tavern_fest.rpy:417
translate english tavern_fest2_a1dd7c35:

    # me "Когда, пять часов назад? Садись, поговорим."
    me "那是多久，五个小时前？坐下，我们聊聊。"

# game/a8/3tavern_fest.rpy:419
translate english tavern_fest2_7761cb05:

    # josephine "Только не много."
    josephine "别喝太多。"

# game/a8/3tavern_fest.rpy:420
translate english tavern_fest2_041c747a:

    # me "Успокойся, это вино из таверны, оно было разбавлено водой уже раз двенадцать."
    me "放心吧，这是酒馆的酒，已经兑了不下十二遍水了。"

# game/a8/3tavern_fest.rpy:421
translate english tavern_fest2_42e39d43:

    # josephine "Дело не в этом."
    josephine "问题不在这儿。"

# game/a8/3tavern_fest.rpy:422
translate english tavern_fest2_72cb68c0:

    # me "А что такое?"
    me "那是怎么了？"

# game/a8/3tavern_fest.rpy:423
translate english tavern_fest2_43171f1a:

    # josephine "Мне оно слишком нравится."
    josephine "我太喜欢它了。"

# game/a8/3tavern_fest.rpy:424
translate english tavern_fest2_f6f57b78:

    # me "Вино? Да я его тоже люблю. Жаль здесь нет Аранского золотого, но я нашел что-то похожее."
    me "酒吗？啊，我也爱酒。可惜这里没有阿兰的金葡萄酒，不过我找到了点类似的。"

# game/a8/3tavern_fest.rpy:425
translate english tavern_fest2_b5ba01ca:

    # josephine "Мне хватит и полстакана. Я слишком легко напиваюсь."
    josephine "我喝半杯就够了。我太容易醉了。"

# game/a8/3tavern_fest.rpy:426
translate english tavern_fest2_df332e86:

