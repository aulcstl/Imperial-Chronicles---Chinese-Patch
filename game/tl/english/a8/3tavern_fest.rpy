    # josephine "Ты как меня вообще нашел? Я думала, что стою здесь незаметно."
    josephine "你是怎么找到我的？我以为我站这儿挺隐蔽的。"

# game/a8/3tavern_fest.rpy:429
translate english tavern_fest2_34703966:

    # me "По запаху."
    me "凭气味。"

# game/a8/3tavern_fest.rpy:430
