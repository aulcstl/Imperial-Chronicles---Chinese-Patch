translate english tavern_fest2_1604c26d:

    # me "Это довольно по-республикански."
    me "这态度相当共和主义了。"

# game/a8/3tavern_fest.rpy:332
translate english tavern_fest2_b917a49d:

    # me "{i}Жозефина наверху. Кажется скучает.{/i}"
    me "{i}约瑟芬在楼上。似乎挺无聊的。{/i}"

# game/a8/3tavern_fest.rpy:333
translate english tavern_fest2_3653de35:

    # vargo "По-рестубли, по-реснублик...блядь да похуй. Короче ты поддержишь Генри или нет?"
    vargo "管他妈共合，共喝...操，管他呢。反正，你到底支持不支持亨利？"

# game/a8/3tavern_fest.rpy:334
translate english tavern_fest2_d4932297:

    # me "Это он тебя подослал спросить?"
    me "是他派你来问的？"

# game/a8/3tavern_fest.rpy:335
translate english tavern_fest2_293d2ba5:

    # vargo "Нет. У него со мной дельце. Но я подумал раз целый принц заехал в гости в наш город, значит он, сука, к лорду Аргусу."
    vargo "不是。他跟我有个小交易。但我心想，既然一整个王子都大驾光临来到我们这地儿，那他妈肯定得是冲着阿尔格斯大人来的。"

# game/a8/3tavern_fest.rpy:336
translate english tavern_fest2_f95c9fc9:

    # me "И?"
    me "然后呢？"

# game/a8/3tavern_fest.rpy:337
translate english tavern_fest2_f6122174:

    # vargo "И? Блядь на кой хуй тебе к ниму? Значит чето гавном здесь попахивает, смекаешь?"
    vargo "然后？他妈的你找他干嘛？这事儿肯定透着屎味儿，懂我意思吧？"

# game/a8/3tavern_fest.rpy:338
translate english tavern_fest2_1f249bd1:

    # me "Мы стоим у туалета."
    me "咱俩正站在厕所边上。"

# game/a8/3tavern_fest.rpy:339
translate english tavern_fest2_d225854c:

    # vargo "Да не..не в этом дело. Здесь гавнищем посерьезнее несет. Ты это... если будешь порядки наводить с Аргусом - ты мне сообщи."
    vargo "不是...问题不在这儿。这儿有股更严重的屎味儿。你这...你要是打算跟阿尔格斯一块算账——你可得通知我一声。"

# game/a8/3tavern_fest.rpy:340
translate english tavern_fest2_73039c95:

    # me "Не совсем понял..."
    me "不太明白..."

# game/a8/3tavern_fest.rpy:341
translate english tavern_fest2_f867ab5b:

    # vargo "Да Генри, пидар ебаный, какую-то хуйню мне сказал сделать, я сначала подумал ну просто хуйня, а раз уж ты в городе и лорды со всего Запада посъезжались..."
    vargo "就是亨利，那个狗娘养的，让我去做一他妈的件事，我一开始想，哦，就是件屁事。可既然你这当口进了城，整个西部的领主老爷们也都凑一块儿了..."

# game/a8/3tavern_fest.rpy:342
translate english tavern_fest2_bbd6b607:

    # vargo "Значит это не хуйня, а ХУЙНЯ. Понимаешь?"
    vargo "那就不是件屁事了，是件他妈的大事了。明白不？"

# game/a8/3tavern_fest.rpy:343
translate english tavern_fest2_f501b2f8:

    # me "Смутно."
    me "有点模糊。"

# game/a8/3tavern_fest.rpy:345
translate english tavern_fest2_362f46fc:

    # me "{i}Этот лысый опять клинья подбивает...{/i}"
    me "{i}那个秃子又在献殷勤了...{/i}"

# game/a8/3tavern_fest.rpy:346
translate english tavern_fest2_1ddc719b:

    # vargo "Да че непонятного то блядь? Я золото люблю, но в петле не болтаться я люблю больше! Ты если приехал с Генри хуйней заниматься, то и хорошо."
    vargo "他妈的有啥不明白的啊？老子喜欢金子，可我更喜欢不在绞索上晃荡！你要是来跟亨利一块干他妈的蠢事的，那挺好。"

# game/a8/3tavern_fest.rpy:347
translate english tavern_fest2_824a9f49:

    # me "А если нет?"
    me "如果不是呢？"

# game/a8/3tavern_fest.rpy:348
translate english tavern_fest2_94dcd3d6:

    # vargo "А если ты решил с Аргусом к ногтю всю эту шоблу-ёблу прижать - то я хочу остаться не при делах."
    vargo "要是你打定主意跟阿尔格斯一道把这一大帮狗屁倒灶的烂摊子给收拾了——那我就想置身事外，撇清关系。"

# game/a8/3tavern_fest.rpy:349
translate english tavern_fest2_63fefd7a:

    # me "Все ты знаешь..."
    me "你什么都知道..."

# game/a8/3tavern_fest.rpy:350
translate english tavern_fest2_da6dd123:

    # vargo "Да, у меня нюх хороший. Я дерьмо унюхаю даже если пизда-дворянка трижды в день розовой водой подмывается."
    vargo "是啊，我鼻子灵得很。就算那婊子贵族娘们儿一天用玫瑰花水洗三次下面，我也能闻出屎来。"

# game/a8/3tavern_fest.rpy:351
translate english tavern_fest2_83a6da19:

    # me "Так ты хочешь чтобы я тебе сказал чью сторону займу?"
    me "这么说，你是想让我告诉你我会站哪边？"

# game/a8/3tavern_fest.rpy:352
translate english tavern_fest2_5ab58379:

    # vargo "Ну да. Скажешь отвалить - и мои ребята отвалят. Мне подыхать ни к чему."
    vargo "嗯对。你说一句滚蛋，我和我的人就滚蛋。我可不想白白送命。"

# game/a8/3tavern_fest.rpy:353
translate english tavern_fest2_98d9b991:

    # me "Я еще не решил...где тебя искать в случае чего."
    me "我还没决定...要是有情况，去哪儿找你？"

# game/a8/3tavern_fest.rpy:354
translate english tavern_fest2_e8cb674f:

    # vargo "Приходи в эту таверну в любую ночь, скажи 'принц пришел увидеться к Варго' и тебя пропустят."
    vargo "随便哪晚来这酒馆，说“王子来找瓦尔戈了”，就会有人带你进来。"

# game/a8/3tavern_fest.rpy:355
translate english tavern_fest2_71d3b8c8:

    # me "Хорошо."
    me "好。"

# game/a8/3tavern_fest.rpy:356
translate english tavern_fest2_56e4f318:

    # vargo "Ну вот и добазарились. Только долго не думай, а то Генри меня заебет, хуле я не делаю ничего."
    vargo "那咱们就算说定了。别琢磨太久，不然亨利他妈的非烦死老子不可，怪我啥也没干。"

# game/a8/3tavern_fest.rpy:357
translate english tavern_fest2_de6a1ffc:

    # me "А что ты делаешь?"
    me "他会叫你做什么？"

# game/a8/3tavern_fest.rpy:358
translate english tavern_fest2_2f93a3f7:

    # vargo "Как определишься со стороной - так и скажу, а пока это информация кофиденц...концефед...короче иди нахуй пока что."
    vargo "等你决定站哪边了，我就告诉你。现在嘛，这消息是机米...积蜜...总之，现在先他妈给我滚蛋。"

# game/a8/3tavern_fest.rpy:362
translate english tavern_fest2_f1bd8882:

    # valer "О, [mename]! Вот и второй дегустатор."
    valer "哦，[mename]！第二位品鉴师来了。"

# game/a8/3tavern_fest.rpy:363
translate english tavern_fest2_cad42b60:

    # me "Дегустатор?"
    me "品鉴师？"

# game/a8/3tavern_fest.rpy:364
translate english tavern_fest2_6ef7db7d:

    # valer "Да, я вот думаю, стоит ли мне доверять этому или нет."
    valer "是啊，我在琢磨，这东西我到底该不该信。"

# game/a8/3tavern_fest.rpy:365
translate english tavern_fest2_1ba0c6ba:

    # elin "Ей можно добавить любой вкус."
    elin "可以给它添加任何味道。"

# game/a8/3tavern_fest.rpy:366
translate english tavern_fest2_05b551e7:

    # me "Звучит опасно."
    me "听起来很危险。"

# game/a8/3tavern_fest.rpy:367
translate english tavern_fest2_85cff5d0:

    # valer "Из-за магии?"
    valer "因为魔法吗？"

# game/a8/3tavern_fest.rpy:368
translate english tavern_fest2_bcd0e210:

    # me "Из-за [elin]."
    me "因为[elin]。"

# game/a8/3tavern_fest.rpy:369
translate english tavern_fest2_991d0649:

    # elin "Эй! Ты даже не попробовал еще!"
    elin "嘿！你还尝都没尝呢！"

# game/a8/3tavern_fest.rpy:370
translate english tavern_fest2_4afa145b:

    # me "Если честно я и не хочу."
    me "说实话，我也不想尝。"

# game/a8/3tavern_fest.rpy:372
translate english tavern_fest2_a6812c3c:

    # elin "А у тебя никто не спрашивает - тащите мясо и хлеб."
    elin "这可由不得你——去把肉和面包拿来。"

# game/a8/3tavern_fest.rpy:373
translate english tavern_fest2_60dbdaac:

    # me "Хлеб здесь?"
    me "这儿有面包吗？"

# game/a8/3tavern_fest.rpy:374
translate english tavern_fest2_6cdf2051:

    # valer "Нашел только колбасу."
    valer "只找到了香肠。"

# game/a8/3tavern_fest.rpy:375
translate english tavern_fest2_7a9b5ff9:

    # elin "Пойдет."
    elin "也行。"

# game/a8/3tavern_fest.rpy:376
translate english tavern_fest2_48387411:

    # me "Ты уверена, что это будет съедобно?"
    me "你确定这玩意儿能吃吗？"

# game/a8/3tavern_fest.rpy:377
translate english tavern_fest2_7c2c200b:

    # elin "Уверена! Мы это в башне каждый день ели."
    elin "确定！我们在法师塔里天天吃这个。"

# game/a8/3tavern_fest.rpy:379
translate english tavern_fest2_9ceecbf4:

    # valer "А чего оно светится?"
    valer "那它怎么在发光？"

# game/a8/3tavern_fest.rpy:380
translate english tavern_fest2_fc82b742:

    # elin "Потому что приготовлено с любовью."
    elin "因为是用爱烹饪的呀。"

# game/a8/3tavern_fest.rpy:381
translate english tavern_fest2_66b7a789:

    # me "Ничем не пахнет. Подозрительно."
    me "一点味道都没有。很可疑。"

# game/a8/3tavern_fest.rpy:382
translate english tavern_fest2_0695aa6e:

    # valer "Я не взорвусь?"
    valer "我不会爆炸吧？"

# game/a8/3tavern_fest.rpy:383
translate english tavern_fest2_d13475b3:

    # elin "Какие же вы дебилы, это просто ужас. Вы через секунду будете на коленях извиняться."
    elin "你们俩可真是蠢到家了，简直可怕。过一秒钟你们就要跪下来道歉了。"

# game/a8/3tavern_fest.rpy:384
translate english tavern_fest2_18889bdb:

    # me "Еще не поздно плеснуть ей это в лицо и убежать."
    me "现在把它泼她脸上然后跑，还来得及。"

# game/a8/3tavern_fest.rpy:385
translate english tavern_fest2_29bc4c9b:

    # valer "Ты думаешь? Надо попробовать."
    valer "你觉得行吗？得试试。"

# game/a8/3tavern_fest.rpy:386
translate english tavern_fest2_4711e03c:

    # elin "Жрите давайте!"
    elin "快吃吧你们！"

# game/a8/3tavern_fest.rpy:387
translate english tavern_fest2_f7c49162:

    # me "Валериан, запомни меня молодым и счастливым."
    me "Valerian，请记住我年轻快乐的样子。"

# game/a8/3tavern_fest.rpy:388
translate english tavern_fest2_80c7d53e:

    # valer "Я вместе с тобой помру, я тоже самое есть буду, забыл?"
    valer "我跟你是一块儿死的，我也得吃一样的东西，忘了吗？"

# game/a8/3tavern_fest.rpy:389
translate english tavern_fest2_56750c35:

    # elin "Если вы не прекратите и не начнете есть, я вас сама убью."
