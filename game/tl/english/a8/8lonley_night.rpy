    # mom "Мнм!"
    mom "嗯哼！"

# game/a8/8lonley_night.rpy:14
translate english lonley_night_aa023873:

    # me "Мнм?"
    me "嗯哼？"

# game/a8/8lonley_night.rpy:15
translate english lonley_night_8324732d:

    # mom "Ммнммм...."
    mom "嗯哼哼嗯...."

# game/a8/8lonley_night.rpy:16
