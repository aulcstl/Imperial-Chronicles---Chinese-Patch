# game/a8/2mage_and_inv.rpy:6
translate english mage_and_invent_d619f2e7:

    # me "{i}Республиканцы хотя бы зависят от моего решения. Их власть будет достаточно шаткой, чтобы я мог ставить им условия.{/i}"
