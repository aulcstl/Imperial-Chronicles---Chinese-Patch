translate english mage_and_invent2_a352ab41:

    # cata "Не знаю. Но он не хотел иметь с ними дел и вдруг передумал, когда ты появился в городе."
    cata "不知道。但他原本不想和他们打交道，在你出现在城里后突然改变了主意。"

# game/a8/2mage_and_inv.rpy:207
translate english mage_and_invent2_93c4d028:

    # me "Ну значит мне нужно поговорить с Генри."
    me "那意味着我需要和亨利谈谈。"

# game/a8/2mage_and_inv.rpy:208
translate english mage_and_invent2_e39f1416:

    # elin "Где он?"
    elin "他在哪？"

# game/a8/2mage_and_inv.rpy:210
translate english mage_and_invent2_f55c4eb9:

    # cata "Я покажу вам, но уверяю тебя - это бесполезно."
    cata "我带你们去，但我向你保证——这没用。"

# game/a8/2mage_and_inv.rpy:211
translate english mage_and_invent2_e5900b05:

    # elin "По-моему она не особо горит желанием предотвращать кровопролитие."
    elin "在我看来她并不特别热衷于阻止流血。"

# game/a8/2mage_and_inv.rpy:212
translate english mage_and_invent2_a6061709:

    # cata "Просто вы не знаете Генри. Его не разубедить. А если он говорит с ужасными людьми, значит и задумал он что-то ужасное."
    cata "只是你们不了解亨利。他无法被说服。如果他跟可怕的人交谈，那就意味着他计划着可怕的事情。"

# game/a8/2mage_and_inv.rpy:213
translate english mage_and_invent2_ac98f3c4:

    # me "Куда пойдем?"
    me "我们去哪？"

# game/a8/2mage_and_inv.rpy:214
translate english mage_and_invent2_e1279e78:

    # cata "Таверна 'Хромой Индюк'. Это недалеко. Только не говорите Генри, что это я вас привела."
    cata "酒馆“跛脚火鸡”。不远。只是别告诉亨利是我带你们来的。"

# game/a8/2mage_and_inv.rpy:215
translate english mage_and_invent2_1b4df2de:

    # me "Не будем."
    me "不会的。"

# game/a8/2mage_and_inv.rpy:216
translate english mage_and_invent2_67b633fd:

    # elin "Ты уверен? Если он говорит с бандитами..."
    elin "你确定？如果他在和土匪交谈..."

# game/a8/2mage_and_inv.rpy:217
translate english mage_and_invent2_d38a07d6:

    # me "Я просто оценю обстановку, спокойно."
    me "我只是评估一下情况，冷静。"

# game/a8/2mage_and_inv.rpy:219
translate english mage_and_invent2_3f54b090:

    # "Некоторое время спустя"
    "过了一会"

# game/a8/2mage_and_inv.rpy:220
translate english mage_and_invent2_1754e9c2:

    # band1 "Я его убил нахрен."
    band1 "我他妈杀了他。"

# game/a8/2mage_and_inv.rpy:221
translate english mage_and_invent2_4ec58eef:

    # band2 "Кому ты пиздишь? Ты бы обоссался от страха и сбежал."
    band2 "你骗谁呢？你早就吓得尿裤子跑了。"

# game/a8/2mage_and_inv.rpy:222
translate english mage_and_invent2_811fecb8:

    # band1 "Ты охренел? Он мертв!"
    band1 "你疯了吗？他死了！"

# game/a8/2mage_and_inv.rpy:223
translate english mage_and_invent2_143da3de:

    # band2 "Это не ты его убил."
    band2 "不是你杀的他。"

# game/a8/2mage_and_inv.rpy:224
translate english mage_and_invent2_7793f8f0:

    # band1 "А кто, блядь?"
    band1 "那他妈的谁杀的？"

# game/a8/2mage_and_inv.rpy:225
translate english mage_and_invent2_a30e9a94:

    # band2 "Ему шею стрелой пробили, а ты из лука себе в ногу не попадешь. Так что это был явно не ты, пиздабол."
    band2 "他的脖子被箭射穿了，而你用弓连自己的脚都射不中。所以显然不是你，吹牛大王。"

# game/a8/2mage_and_inv.rpy:226
translate english mage_and_invent2_a86c480f:

    # band1 "Да какая разница кто? Главное, что он умер и Варго нам щедро заплатил."
    band1 "谁杀的有区别吗？重要的是他死了，瓦戈给了我们一大笔钱。"

# game/a8/2mage_and_inv.rpy:227
translate english mage_and_invent2_c1d13d09:

    # band2 "Рано радуешься, если он узнает, что это не ты грохнул жирного - потребует деньги назад."
    band2 "高兴得太早了，如果他知道不是你干掉那胖子的——会要回钱的。"

# game/a8/2mage_and_inv.rpy:229
translate english mage_and_invent2_e45465ae:

    # band1 "А как он узнает? Сказал мне убить - получил труп."
    band1 "他怎么会知道？让我杀——就得到了尸体。"

# game/a8/2mage_and_inv.rpy:230
translate english mage_and_invent2_ed56ee28:

    # band2 "А вдруг объявится тот, кто убил его на самом деле? Или стража его задержит?"
    band2 "万一真杀他的人出现了呢？或者守卫抓住了他？"

# game/a8/2mage_and_inv.rpy:231
translate english mage_and_invent2_9e013116:

    # band1 "Да хрен там. У стражи сейчас полно забот."
    band1 "才不管呢。守卫现在忙得很。"

# game/a8/2mage_and_inv.rpy:232
translate english mage_and_invent2_d419342a:

    # band2 "И все же...кто убил эту свинью?"
    band2 "可话说回来...谁杀了那头猪？"

# game/a8/2mage_and_inv.rpy:233
translate english mage_and_invent2_d8467f4c:

    # band1 "Понятия не имею, может эльфы? Говорят он с ними якшался."
    band1 "一点头绪都没有，也许是精灵？据说他和他们勾搭。"

# game/a8/2mage_and_inv.rpy:234
translate english mage_and_invent2_bc203a6e:

    # band2 "А я слышал он торговал белой кровью."
    band2 "我听说他贩卖白血液。"

# game/a8/2mage_and_inv.rpy:235
translate english mage_and_invent2_b65ddae6:

    # band1 "На кой хуй она кому-то нужна?"
    band1 "那玩意谁他妈需要啊？"

# game/a8/2mage_and_inv.rpy:236
translate english mage_and_invent2_3f37dcd6:

    # band2 "Говорят от нее галлюцинации как от корня дым-травы, а то и сильнее."
    band2 "据说它能产生像烟草根一样的幻觉，甚至更强。"

# game/a8/2mage_and_inv.rpy:238
translate english mage_and_invent2_9723e546:

    # cata "Ну. Это здесь."
    cata "好了。就是这里。"

# game/a8/2mage_and_inv.rpy:239
translate english mage_and_invent2_5ac48a14:

    # me "Я тут знакомых лиц не вижу."
    me "我在这没看到熟面孔。"

# game/a8/2mage_and_inv.rpy:240
translate english mage_and_invent2_a8a5775c:

    # elin "А кого мы хотим встретить кроме Генри?"
    elin "除了亨利我们还想见到谁？"

# game/a8/2mage_and_inv.rpy:241
translate english mage_and_invent2_8c45dc34:

    # cata "Эм...да хоть кого-нибудь. Жозефина, Валериан или Кассиус. Они всюду таскаются вместе. Если здесь один, то и все на месте."
    cata "嗯...随便谁都行。约瑟芬娜、Valerian或卡修斯。他们总在一起。如果有一个在，其他人就都在。"

# game/a8/2mage_and_inv.rpy:242
translate english mage_and_invent2_15ae122e:

    # me "Может мы рано пришли?"
    me "也许我们来早了？"

# game/a8/2mage_and_inv.rpy:244
translate english mage_and_invent2_6b126f86:

    # band_cap "Вы что тут забыли, детишки?"
    band_cap "你们几个小鬼在这干嘛？"

# game/a8/2mage_and_inv.rpy:245
translate english mage_and_invent2_f6fe7889:

    # me "У нас здесь встреча."
    me "我们在这有约。"

# game/a8/2mage_and_inv.rpy:246
translate english mage_and_invent2_3bc90bb2:

    # barman "Таверна закрыта."
    barman "酒馆关门了。"

# game/a8/2mage_and_inv.rpy:247
translate english mage_and_invent2_0f8717cc:

    # cata "У нас встреча с Генри."
    cata "我们和亨利有约。"

# game/a8/2mage_and_inv.rpy:248
translate english mage_and_invent2_dac91658:

    # band_cap "Не знаю таких, проваливайте."
    band_cap "不认识这人，滚开。"

# game/a8/2mage_and_inv.rpy:250
translate english mage_and_invent2_f0fc604b:

    # cata "Мы друзья Генри."
    cata "我们是亨利的朋友。"

# game/a8/2mage_and_inv.rpy:251
translate english mage_and_invent2_49608d28:

    # band_cap "Уходите или я вынесу вас по частям."
    band_cap "走开，否则我把你们大卸八块扔出去。"

# game/a8/2mage_and_inv.rpy:252
translate english mage_and_invent2_58684845:

    # me "Может подождем снаружи?"
    me "也许我们在外面等等？"

# game/a8/2mage_and_inv.rpy:253
translate english mage_and_invent2_f434f0b4:

    # band_cap "Вот это умный парень. Валите!"
    band_cap "这才是个聪明小子。滚吧！"

# game/a8/2mage_and_inv.rpy:254
translate english mage_and_invent2_5768e020:

    # barman "Таверна откроется вечером."
    barman "酒馆晚上才开门。"

# game/a8/2mage_and_inv.rpy:255
translate english mage_and_invent2_09db4606:

    # band_cap "Ага. Тогда и приваливайте. А пока пиздуйте отсюда."
    band_cap "啊。那到时候再来。现在快他妈滚。"

# game/a8/2mage_and_inv.rpy:256
translate english mage_and_invent2_3fcd4022:

    # elin "Я его сейчас..."
    elin "我现在就..."

# game/a8/2mage_and_inv.rpy:258
translate english mage_and_invent2_7005795e:

    # valer "Ребята! Мы здесь! [mename]!"
    valer "伙计们！我们在这！[mename]！"

# game/a8/2mage_and_inv.rpy:259
translate english mage_and_invent2_a89d0056:

    # band_cap "Кто это?"
    band_cap "这是谁？"

# game/a8/2mage_and_inv.rpy:260
translate english mage_and_invent2_9708508f:

    # valer "Это наши друзья."
    valer "这是我们的朋友。"

# game/a8/2mage_and_inv.rpy:261
translate english mage_and_invent2_b36d1ebe:

    # band_cap "Какие еще друзья?"
    band_cap "什么朋友？"

# game/a8/2mage_and_inv.rpy:262
translate english mage_and_invent2_eca9131c:

    # valer "Обычные друзья? Ты не знаешь что такое дружба, лысый?"
    valer "普通朋友啊？你不知道什么是友谊吗，秃子？"

# game/a8/2mage_and_inv.rpy:263
translate english mage_and_invent2_8f8a34b9:

    # band_cap "Варго сказал..."
    band_cap "瓦戈说了..."

# game/a8/2mage_and_inv.rpy:264
translate english mage_and_invent2_c7e538fe:

    # valer "Варго сказал Генри может взять с собой кого захочет. Это друзья Генри."
    valer "瓦戈说亨利可以带任何他想带的人。这是亨利的朋友。"

# game/a8/2mage_and_inv.rpy:265
translate english mage_and_invent2_cd51f2e3:

    # valer "Подходите, не бойтесь."
    valer "过来吧，别怕。"

# game/a8/2mage_and_inv.rpy:266
translate english mage_and_invent2_d112e929:

    # cata "Ну... идите."
    cata "那...去吧。"

# game/a8/2mage_and_inv.rpy:267
translate english mage_and_invent2_dd9883ca:

    # elin "А ты?"
    elin "你呢？"

# game/a8/2mage_and_inv.rpy:268
translate english mage_and_invent2_90d54de5:

    # cata "Я... я присоединюсь к вам позже."
    cata "我...我晚点再来找你们。"

# game/a8/2mage_and_inv.rpy:270
translate english mage_and_invent2_9b646627:

    # valer "[mename], ты не говорил, что в следующий раз придешь с такой красоткой."
    valer "[mename]，你没说下次会带这么一位美人来。"

# game/a8/2mage_and_inv.rpy:271
translate english mage_and_invent2_c7c918d4:

    # elin "Спасибо..."
    elin "谢谢..."

# game/a8/2mage_and_inv.rpy:272
translate english mage_and_invent2_d36948f6:

    # josephine "О нет, начинается..."
    josephine "哦不，又来了..."

# game/a8/2mage_and_inv.rpy:273
translate english mage_and_invent2_b21e2b93:

    # me "Это моя сестра-близнец, [elin]."
    me "这是我的双胞胎妹妹，[elin]。"

# game/a8/2mage_and_inv.rpy:274
translate english mage_and_invent2_8cd45329:

    # valer "Приятно познакомится, [elin]. Я бы представился, но я настолько впечатлен вашей красотой, что кажется забыл свое имя."
    valer "很高兴认识你，[elin]。我本该自我介绍的，但你的美貌让我太震撼了，好像连自己名字都忘了。"

# game/a8/2mage_and_inv.rpy:275
translate english mage_and_invent2_c1817ade:

    # josephine "Меня зовут Жозефина. Этого льстеца - Валериан. Справа от меня Кассиус."
    josephine "我叫约瑟芬娜。这个马屁精叫Valerian。我右边的是卡修斯。"

# game/a8/2mage_and_inv.rpy:276
translate english mage_and_invent2_f5d643bc:

    # me "Мы присядем?"
    me "我们坐吗？"

# game/a8/2mage_and_inv.rpy:277
translate english mage_and_invent2_5e4181c4:

    # josephine "Ну конечно."
    josephine "当然。"

# game/a8/2mage_and_inv.rpy:278
translate english mage_and_invent2_fd0fd7d1:

    # cassius "Может уже отлипнешь от девушки?"
    cassius "能不能别再粘着姑娘了？"

# game/a8/2mage_and_inv.rpy:279
translate english mage_and_invent2_8cd5955d:

    # valer "Простите, [elin], я слишком вами очарован."
    valer "对不起，[elin]，我太被你迷住了。"

# game/a8/2mage_and_inv.rpy:281
translate english mage_and_invent2_d8b6315f:

    # valer "Мне всегда нравились полуэльфийки. В вас сочетается лучшее от обоих миров. Человеческий интеллект и эльфийская красота и молодость."
    valer "我一直喜欢半精灵。你们身上结合了两个世界的精华。人类的智慧和精灵的美丽与青春。"

# game/a8/2mage_and_inv.rpy:282
translate english mage_and_invent2_c7c918d4_1:

    # elin "Спасибо..."
    elin "谢谢..."

# game/a8/2mage_and_inv.rpy:283
translate english mage_and_invent2_ca0c0a9e:

    # josephine "Хватит наседать, Валериан. Она замужем."
    josephine "别纠缠了，Valerian。她结婚了。"

# game/a8/2mage_and_inv.rpy:284
translate english mage_and_invent2_52b70188:

    # valer "О нет! Кто счастливчик?"
    valer "哦不！哪个幸运儿？"

# game/a8/2mage_and_inv.rpy:285
translate english mage_and_invent2_ac6126e2:

    # elin "Локхарт."
    elin "Lockhart。"

# game/a8/2mage_and_inv.rpy:286
translate english mage_and_invent2_16cce512:

    # valer "Локхарт? Эх. Этой семейке всегда достаются лучшие женщины на континенте."
    valer "Lockhart？唉。这家子总能娶到大陆上最好的女人。"

# game/a8/2mage_and_inv.rpy:287
translate english mage_and_invent2_24b697a8:

    # elin "Это..."
    elin "这..."

# game/a8/2mage_and_inv.rpy:288
translate english mage_and_invent2_5a8fd4f7:

    # josephine "Это он про меня. Но я уже на его сладкие речи не ведусь. Сначала он всю тебя обласкает комплиментами, а потом попросит золота в долг."
    josephine "他是在说我。但我已经不吃他这套甜言蜜语了。他先是用赞美把你宠上天，然后就会借钱。"

# game/a8/2mage_and_inv.rpy:289
translate english mage_and_invent2_02a5405c:

    # valer "Не слушай ее, [mename], я бы не посмел, только не на первой встрече."
    valer "别听她的，[mename]，我可不敢，至少不是第一次见面。"

# game/a8/2mage_and_inv.rpy:290
translate english mage_and_invent2_03b53916:

    # josephine "На второй."
    josephine "第二次就敢了。"

# game/a8/2mage_and_inv.rpy:292
translate english mage_and_invent2_e323f290:

    # valer "Эй! Я тут единственный, кого полностью лишили привилегий и денег от семьи, не забыли?"
    valer "嘿！我可是这里唯一被家里完全剥夺特权和金钱的人，别忘了？"

# game/a8/2mage_and_inv.rpy:293
translate english mage_and_invent2_489a247d:

    # me "Правда?"
    me "真的吗？"

# game/a8/2mage_and_inv.rpy:294
translate english mage_and_invent2_094cda3a:

    # valer "Правда. Жозефине отец тайно отправляет деньги. Бабушка Кассиуса не отбирала у него имущество в городе, а Генри все еще пользуется именем отца, пусть тот он него и отрекся."
    valer "真的。约瑟芬娜的父亲偷偷给她寄钱。卡修斯的祖母没有没收他在城里的财产，而亨利虽然被父亲断绝关系，但还在用他的名字。"

# game/a8/2mage_and_inv.rpy:295
translate english mage_and_invent2_b91832eb:

    # valer "Так что я тут самый нищий парень в таверне. Думаю у тех бандитов золота в карманах побольше."
    valer "所以我是这酒馆里最穷的家伙。我看那些土匪口袋里的金子都比我多。"

# game/a8/2mage_and_inv.rpy:296
translate english mage_and_invent2_26a9d5da:

    # me "А как же твоя таверна?"
    me "那你的酒馆呢？"

# game/a8/2mage_and_inv.rpy:297
translate english mage_and_invent2_c6fb5227:

    # valer "Я ей больше не владею. Она закрыта."
    valer "我不再拥有它了。它关门了。"

# game/a8/2mage_and_inv.rpy:298
translate english mage_and_invent2_82926490:

    # cassius "Это тебе не мешает в ней жить."
    cassius "这并不妨碍你住在里面。"

# game/a8/2mage_and_inv.rpy:299
translate english mage_and_invent2_b7666849:

    # valer "Разве же это жизнь?"
    valer "这算哪门子生活？"

# game/a8/2mage_and_inv.rpy:300
translate english mage_and_invent2_4b0d532e:

    # cassius "Зато тебя не ищет стража, как Генри, не ищут люди лорда Арамиса, как Жозефину, и на тебя не объявлена охота за укрывательство беглых крестьян, как на меня."
    cassius "至少守卫不像抓亨利那样抓你，Aramis领主的人不像找约瑟芬娜那样找你，你也没像我这样因为藏匿逃亡农民而被通缉。"

# game/a8/2mage_and_inv.rpy:301
translate english mage_and_invent2_b751dfcf:

    # valer "Да. Это мое самое главное достижение в жизни - на меня всем насрать."
