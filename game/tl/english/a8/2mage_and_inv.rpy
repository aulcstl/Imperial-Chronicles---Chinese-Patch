    pretor "我开始吗？"

# game/a8/2mage_and_inv.rpy:116
translate english mage_and_invent_68a92d16:

    # tark "Колдуй, старик..."
    tark "施法吧，老头..."

# game/a8/2mage_and_inv.rpy:117
