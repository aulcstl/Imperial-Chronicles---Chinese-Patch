    elin "就是...假设我们能进入另一个世界。它和我们的相似...但有点不同。从那里拿任何东西...或带任何人安全吗？"

# game/a8/2mage_and_inv.rpy:136
translate english mage_and_invent_509d9e9e:

    # pretor "[elin], ты была в другом мире?"
    pretor "[elin]，你去过另一个世界？"

# game/a8/2mage_and_inv.rpy:137
translate english mage_and_invent_c18a03f6:

    # elin "Возможно..."
    elin "可能..."

# game/a8/2mage_and_inv.rpy:138
translate english mage_and_invent_e6ddeaf7:

    # pretor "Этого не может быть... Как?"
    pretor "这不可能...怎么去的？"

# game/a8/2mage_and_inv.rpy:139
translate english mage_and_invent_89cb8ad0:

    # me "Мы попали в него сквозь портал."
    me "我们是通过传送门进去的。"

# game/a8/2mage_and_inv.rpy:140
translate english mage_and_invent_bd0f5f15:

    # pretor "Это...это звучит невероятно."
    pretor "这...这听起来不可思议。"

# game/a8/2mage_and_inv.rpy:141
