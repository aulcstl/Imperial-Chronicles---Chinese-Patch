translate english mage_and_invent2_1aaafe4f:

    # me "Мы тебя не отвлекаем?"
    me "我们没打扰你吧？"

# game/a8/2mage_and_inv.rpy:182
translate english mage_and_invent2_45fa7997:

    # cata "Нет. Все нормально."
    cata "没。一切都好。"

# game/a8/2mage_and_inv.rpy:183
