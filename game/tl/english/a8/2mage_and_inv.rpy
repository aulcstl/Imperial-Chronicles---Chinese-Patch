    # me "Я пришел получше узнать о твоем предложении."
    me "我来是为了更详细了解你的提议。"

# game/a8/2mage_and_inv.rpy:188
translate english mage_and_invent2_227b1f55:

    # cata "Никакого предложения больше нет."
    cata "不再有什么提议了。"

