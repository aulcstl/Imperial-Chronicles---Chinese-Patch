# game/a8/2mage_and_inv.rpy:7
translate english mage_and_invent_e034b210:

    # me "{i}С другой стороны они гораздо менее предсказуемая сила. Кто знает, может они захотят установить республику у меня в королевстве?{/i}"
    me "{i}另一方面，他们是一股更不可预测的力量。谁知道呢，也许他们想在我的王国建立共和国？{/i}"

# game/a8/2mage_and_inv.rpy:8
