    # "Несколько дней спустя."
    "几天以后。"

# game/a8/9cassatio.rpy:4
translate english cassatio_5c76dbe7:

    # me "{i}...{/i}"
    me "{i}...{/i}"

# game/a8/9cassatio.rpy:5
translate english cassatio_d66ecd21:

    # me "{i}....{/i}"
    me "{i}....{/i}"

# game/a8/9cassatio.rpy:6
translate english cassatio_4d4ccdae:

    # me "{i}.....{/i}"
    me "{i}.....{/i}"

# game/a8/9cassatio.rpy:7
translate english cassatio_c9bfe5f1:

    # me "{i}Это уже не смешно. Где она?{/i}"
    me "{i}这已经不好笑了。她在哪？{/i}"

# game/a8/9cassatio.rpy:8
translate english cassatio_c7f801aa:

    # cass "Что ты делаешь в такой темноте совсем один? Замышляешь какое-то преступление?"
    cass "你一个人摸黑在这儿干什么？在策划什么犯罪吗？"

# game/a8/9cassatio.rpy:10
translate english cassatio_689c2eab:

    # cass "Или ты снова наслаждаешься своим любимым эльфийским искусством?"
    cass "还是说又在欣赏你最喜欢的精灵艺术？"

# game/a8/9cassatio.rpy:11
translate english cassatio_a261ce07:

    # me "Я пришел насладиться закатом. Ой. Кажется солнце зашло уже два часа назад."
    me "我是来欣赏日落的。哦。看来太阳两个小时前就下山了。"

# game/a8/9cassatio.rpy:12
translate english cassatio_d07f8879:

    # cass "[mename], в твоем возрасте пора бы уже понять, что все красивые девушки опаздывают на встречу."
    cass "[mename]，到了你这个年纪也该明白，所有漂亮的姑娘约会都会迟到的。"

# game/a8/9cassatio.rpy:13
translate english cassatio_7c6c2e84:

    # me "На два часа?"
    me "迟到两个小时？"

# game/a8/9cassatio.rpy:14
translate english cassatio_eb0d007c:

    # cass "Время опоздания прямо пропорционально красоте, а так как я красивее даже звезд на небе, тебе пришлось сначала дождаться их."
    cass "迟到的时间与美貌成正比，而我比天上的星星还要美，你只好先等它们出现了。"

# game/a8/9cassatio.rpy:15
translate english cassatio_3820771a:

    # me "..."
    me "..."

# game/a8/9cassatio.rpy:16
translate english cassatio_1079880b:

    # cass "Да ладно тебе. Мне пришлось потратить время на вранье."
    cass "得了吧你。我倒是花了不少时间去撒谎。"

# game/a8/9cassatio.rpy:17
translate english cassatio_d355dc3b:

    # me "О чем ты?"
    me "你什么意思？"

# game/a8/9cassatio.rpy:18
translate english cassatio_a1481af4:

    # cass "Я провела несколько нарочно громких бесед в присутствии слуг."
    cass "我故意在仆人面前大声说了几场对话。"

# game/a8/9cassatio.rpy:19
translate english cassatio_7332342b:

    # me "Зачем?"
    me "为什么？"

# game/a8/9cassatio.rpy:20
translate english cassatio_dc9eef35:

    # cass "Что бы завтра лорду Аргусу доложили, что выдвинулись в Долину за вассалами отца."
    cass "这样明天就会有人禀报Argus大人，说我们动身去山谷找父亲的封臣了。"

# game/a8/9cassatio.rpy:21
translate english cassatio_5e53c358:

    # me "А на самом деле?"
    me "那实际上呢？"

# game/a8/9cassatio.rpy:22
translate english cassatio_b28cf4df:

    # cass "А на самом деле..."
    cass "实际上嘛……"

# game/a8/9cassatio.rpy:24
translate english cassatio_c2dc8f04:

    # cass "На самом деле я не поняла что ты напялил."
    cass "实际上我没搞懂你穿的是什么玩意儿。"

# game/a8/9cassatio.rpy:25
translate english cassatio_dfcceeac:

    # me "М?"
    me "嗯？"

# game/a8/9cassatio.rpy:26
translate english cassatio_bf3f0029:

    # cass "Ты что, в этом в дорогу собрался?"
    cass "你就打算穿成这样上路吗？"

# game/a8/9cassatio.rpy:27
translate english cassatio_8be39039:

    # me "Откуда я знал, что нас ждет дорога? Ты сказала, что хочешь поговорить."
    me "我怎么知道我们要出远门？你只说你想要谈谈。"

# game/a8/9cassatio.rpy:28
translate english cassatio_a673a6b2:

    # cass "Я сказала, что хочу обсудить наши действия. А слово 'действие' предполагает действие. А как ты собрался действовать без удобной одежды."
    cass "我说的是我想讨论一下我们的“行动”。而“行动”这个词本身就意味着有所行动。你不穿得方便点，要怎么行动？"

# game/a8/9cassatio.rpy:29
translate english cassatio_27d28822:

    # me "Да. Но само обсуждение действия никаких действий не предполагает, кроме чесания языком неба."
    me "对。但光是讨论行动本身，除了耍嘴皮子之外，可不包含什么别的行动。"

# game/a8/9cassatio.rpy:30
translate english cassatio_d6bb6cb4:

    # cass "Что это вообще за дерьмо? "
    cass "这到底是什么狗屎？"

# game/a8/9cassatio.rpy:31
translate english cassatio_2a384e39:

    # me "Это местная мода. Не хочу выделяться."
    me "这是本地时尚。我可不想太显眼。"

# game/a8/9cassatio.rpy:32
translate english cassatio_41920088:

    # cass "Так ты теперь дворцовый пижон?"
    cass "这么说你成了宫廷里的花花公子了？"

# game/a8/9cassatio.rpy:33
translate english cassatio_3820771a_1:

    # me "..."
    me "..."

# game/a8/9cassatio.rpy:34
translate english cassatio_329975e5:

    # cass "Короче эта одежда не подойдет. Оденься поудобнее и встречай меня на хорошей лошади за городскими воротами через полчаса."
    cass "总之这身衣服不行。去换身方便的，半小时后骑匹好马，在城门外等我。"

# game/a8/9cassatio.rpy:36
translate english cassatio_57587b76:

    # "Полтора часа спустя."
    "一个半小时以后。"

# game/a8/9cassatio.rpy:37
translate english cassatio_1ebaef4b:

    # me "{size=-10}Вот ты где.{/size}"
    me "{size=-10}你在这儿啊。{/size}"

# game/a8/9cassatio.rpy:38
translate english cassatio_6d475b22:

    # cass "[mename], я чуть не уснула здесь. Ты же в курсе, что правило с красотой и опозданиями на мужчин не распространяется?"
    cass "[mename]，我差点在这儿睡着了。你该不会不知道，那条关于美貌与迟到的规则可不适用于男人吧？"

# game/a8/9cassatio.rpy:39
translate english cassatio_894c8302:

    # me "{size=-8}Мне надо было раздобыть лошадь.{/size}"
    me "{size=-8}我得去弄匹马。{/size}"

# game/a8/9cassatio.rpy:40
translate english cassatio_25fad4b9:

    # cass "Так ты еще и не специально опоздал. Какой ужас. Ничего тебе поручить нельзя."
    cass "这么说你还是故意迟到的。太可怕了。什么事都指望不上你。"

# game/a8/9cassatio.rpy:41
translate english cassatio_91b86e99:

    # me "{size=-6}Я бы пришел раньше, если бы ты сказала за какими именно воротами ты будешь меня ждать. В этом городе их шесть.{/size}"
    me "{size=-6}你要是说清楚会在哪个城门等我，我早就到了。这城里有六座门。{/size}"

# game/a8/9cassatio.rpy:42
translate english cassatio_763948f6:

    # cass "[mename], женщине очень важно сохранять какую-нибудь интригу. Может я буду за первыми воротами, а может за шестыми. Разве не интересно?"
    cass "[mename]，对女人来说，保留一点悬念非常重要。我或许会在第一座门，或许会在第六座门。难道不有趣吗？"

# game/a8/9cassatio.rpy:43
translate english cassatio_bf6a5d49:

    # me "{size=-4}Потрясающе просто.{/size}"
    me "{size=-4}简直太棒了。{/size}"

# game/a8/9cassatio.rpy:44
translate english cassatio_8c94798c:

    # cass "А если серьезно - я же говорила о нашей поездке."
    cass "说正经的——我说过我们的这趟行程。"

# game/a8/9cassatio.rpy:45
translate english cassatio_ef676a5f:

    # me "{size=-2}Ты говорила куда ты якобы хочешь поехать - в Долину. Куда мы поедем на самом деле я не знаю.{/size}"
    me "{size=-2}你只说了你假装要去的地方——山谷。我们实际上要去哪，我可不知道。{/size}"

# game/a8/9cassatio.rpy:46
translate english cassatio_2101a93b:

    # cass "Ты серьезно?"
    cass "你是认真的吗？"

# game/a8/9cassatio.rpy:48
translate english cassatio_fcf38ce2:

    # me "Я серьезно. Откуда я знаю, что у тебя в голове?"
    me "我是认真的。我怎么知道你脑子里在想什么？"

# game/a8/9cassatio.rpy:49
translate english cassatio_651ccc28:

    # cass "..."
    cass "..."

# game/a8/9cassatio.rpy:50
translate english cassatio_ad02f53a:

    # me "Что?"
    me "什么？"

# game/a8/9cassatio.rpy:51
translate english cassatio_de13de73:

    # cass "[mename], ты изображаешь идиота, или просто очень хорошо притворяешься?."
    cass "[mename]，你是在装傻，还是真的傻到家了？"

# game/a8/9cassatio.rpy:52
translate english cassatio_961ec96b:

    # me "Да я понятия не имею, куда мы отправимся."
    me "我根本不知道我们要去哪儿。"

# game/a8/9cassatio.rpy:53
translate english cassatio_817b044e:

    # cass "Серьезно? Вот прямо никаких предположений?"
    cass "真的？一点猜测都没有？"

# game/a8/9cassatio.rpy:54
translate english cassatio_481e2fa5:

    # me "В Черную Косу?"
    me "去黑湾？"

# game/a8/9cassatio.rpy:55
translate english cassatio_e79543b7:

    # cass "Умница. Ты мой самый способный ученик из числа тех, у кого непроизвольно капает слюна из-зо рта."
    cass "真聪明。你是我那帮会不由自主流口水的学生里，最有天赋的一个。"

# game/a8/9cassatio.rpy:56
translate english cassatio_08004b14:

    # me "И что мы там будем делать?"
    me "我们去那儿做什么？"

# game/a8/9cassatio.rpy:57
translate english cassatio_f76b8735:

    # cass "Пить, танцевать, веселиться - всегда мечтала побывать на родине моей матери."
    cass "喝酒、跳舞、寻欢作乐——我一直梦想着去我母亲的故乡看看呢。"

# game/a8/9cassatio.rpy:58
translate english cassatio_4a2753ae:

    # me "Это сарказм?"
    me "这是讽刺吧？"

# game/a8/9cassatio.rpy:59
translate english cassatio_b7c8f5f0:

    # cass "Да."
    cass "是的。"

# game/a8/9cassatio.rpy:60
translate english cassatio_c97fadc0:

    # me "Ну..."
    me "嗯……"

# game/a8/9cassatio.rpy:61
translate english cassatio_4f4ce316:

    # cass "Зачем нам на Косу? За армией конечно же. Поехали."
    cass "我们去黑湾干什么？当然是去找军队。走吧。"

# game/a8/9cassatio.rpy:62
translate english cassatio_ccd611a8:

    # me "И что...."
    me "那么……"

# game/a8/9cassatio.rpy:63
translate english cassatio_8b7f65b6:

    # cass "Что, что?"
    cass "什么，什么？"

# game/a8/9cassatio.rpy:64
translate english cassatio_22130a8b:

    # me "Мы соберем армию косы и нападем на лордов Запада?"
    me "我们要集结黑湾的军队，然后攻打西边的领主们？"

# game/a8/9cassatio.rpy:65
translate english cassatio_fbadbee3:

    # cass "Конечно. Они как раз очень удобно здесь все собрались."
    cass "当然。他们现在恰好都方便地聚在这儿了。"

# game/a8/9cassatio.rpy:67
translate english cassatio_ba54d138:

    # me "Они здесь не одни собрались, если ты не заметила. Многие взяли с собой солдат и рыцарей."
    me "他们可不是独自在这儿集合的，如果你没注意到的话。很多人带了士兵和骑士。"

# game/a8/9cassatio.rpy:68
translate english cassatio_3e316ac3:

    # cass "Все эти солдаты и рыцари скоро будут кормить воронов."
    cass "所有这些士兵和骑士很快就要去喂乌鸦了。"

# game/a8/9cassatio.rpy:69
translate english cassatio_5ac38cf1:

    # me "Почему?"
    me "为什么？"

# game/a8/9cassatio.rpy:70
translate english cassatio_46ad15a0:

    # cass "Потому что старший сынок Аргуса решил действовать."
    cass "因为Argus家的大儿子决定动手了。"

# game/a8/9cassatio.rpy:71
translate english cassatio_d2b04ecc:

    # me "Как?"
    me "怎么动手？"

# game/a8/9cassatio.rpy:72
translate english cassatio_970deea9:

    # cass "Он мобилизует все силы бунтовщиков. В речном городке собралось уже почти четыре тысячи крестьян."
    cass "他在动员叛乱者的全部力量。河畔小镇上已经聚集了将近四千农民。"

# game/a8/9cassatio.rpy:73
translate english cassatio_46368927:

    # me "Маловато для победы."
    me "这点人要取胜可不够。"

# game/a8/9cassatio.rpy:75
translate english cassatio_139d2df3:

    # cass "Они не одни. Как только они двинутся в Ривелье - там вспыхнет городское восстание. Эльфы перережут пути из города. Так что сбежать из него можно будет только прихватив с собой всех солдат и рыцарей."
    cass "他们不是孤军奋战。一旦他们向瑞维耶进发，那里就会爆发城市起义。精灵们会切断所有出城的道路。所以要想逃出去，唯一的办法就是带上所有士兵和骑士一起跑。"

# game/a8/9cassatio.rpy:76
translate english cassatio_3741e9af:

    # cass "Но это позорное бегство будет значить полное поражение. После этого к восстанию присоединятся и другие города и деревни."
    cass "但那种耻辱的逃跑就意味着彻底失败。在那之后，其他城镇和村庄也会加入起义。"

# game/a8/9cassatio.rpy:77
translate english cassatio_5915d5eb:

    # cass "Так что лордам останется только принять бой. А победить сброд на улицах сложнее, чем в поле. Генри не будет давать полноценных сражений. Люди будут жечь дома, травить еду, убивать патрули, а потом прятаться. "
    cass "所以领主们就只能选择应战。而在街头战胜乌合之众，比在野外难多了。亨利不会发动任何正面的大规模战斗。他的人民会烧房子、给食物下毒、杀死巡逻队，然后躲起来。"

# game/a8/9cassatio.rpy:78
translate english cassatio_bd3d92c5:

    # cass "Долго им так не продержаться. Единственный выход - убивать всех подряд, но даже если такая резня случится - это достаточно подкосит боеспособность лордов, чтобы мы...закончили начатое."
    cass "他们这样撑不了多久。唯一的出路是见人就杀，但即使发生了那样的屠杀，也足以大幅削弱领主们的战斗力，好让我们……收尾。"

# game/a8/9cassatio.rpy:79
translate english cassatio_b1f79605:

    # me "Откуда ты все это знаешь?"
    me "这些都是你从哪儿知道的？"

# game/a8/9cassatio.rpy:80
translate english cassatio_28185826:

    # cass "От надежных источников."
    cass "可靠消息来源。"

# game/a8/9cassatio.rpy:81
translate english cassatio_3820771a_2:

    # me "..."
    me "..."

# game/a8/9cassatio.rpy:82
translate english cassatio_651ccc28_1:

    # cass "..."
    cass "..."

# game/a8/9cassatio.rpy:83
translate english cassatio_c2390f96:

    # me "Ты забыла кое-что."
    me "你忘了点事。"

# game/a8/9cassatio.rpy:84
translate english cassatio_c2487b65:

    # cass "Что?"
    cass "什么？"

# game/a8/9cassatio.rpy:85
translate english cassatio_b4e67e70:

    # me "В городе есть большой замок. Что мешает лордам засесть там, послать весточки в свои замки и просто ждать пока основные силы будут на подходе?"
    me "城里有个大城堡。领主们为什么不能固守在那里，派人送信回自己的城堡，然后等主力部队接近呢？"

# game/a8/9cassatio.rpy:86
translate english cassatio_7f31a21f:

    # cass "Над этим я работала последнюю неделю."
    cass "这一周我就在忙这个。"

# game/a8/9cassatio.rpy:87
translate english cassatio_d626fb44:

    # me "И что ты сделала?"
    me "那你做了什么？"

# game/a8/9cassatio.rpy:88
translate english cassatio_256fdca1:

    # cass "Провела в замок нужных людей."
    cass "我把需要的人送进了城堡。"

# game/a8/9cassatio.rpy:89
translate english cassatio_be5c32fe:

    # cass "В зависимости от того, какая сторона будет побеждать, они будут делать пребывание в замке более или менее невыносимым."
    cass "根据哪一方会获胜，他们会设法让待在城堡里的日子变得多少难以忍受。"

# game/a8/9cassatio.rpy:90
translate english cassatio_1004d514:

    # me "Не понял. Это как?"
    me "没明白。这是什么意思？"

# game/a8/9cassatio.rpy:91
translate english cassatio_f89c1a09:

    # cass "Нам не нужна полная победа одной и сторон. Нам нужно их взаимное уничтожение. Так что если лорды начнут побеждать - замок сгорит, оружие будет сброшено со стен, а припасы и вода будут отравлены."
    cass "我们不需要任何一方获得完全胜利。我们需要他们互相毁灭。所以，如果领主们要赢了——城堡就会起火，武器会被扔下城墙，补给和水源也会被下毒。"

# game/a8/9cassatio.rpy:92
translate english cassatio_dbdabebd:

    # me "А если наоборот?"
    me "如果反过来呢？"

# game/a8/9cassatio.rpy:93
translate english cassatio_2a3a59d5:

    # cass "Тогда это будет надежным оплотом для защищающихся."
    cass "那城堡就会成为守军们坚实的堡垒。"

# game/a8/9cassatio.rpy:94
translate english cassatio_0758137d:

    # me "А если все-таки кто-то победит?"
    me "那如果最终还是有人胜利了呢？"

# game/a8/9cassatio.rpy:95
translate english cassatio_98bb622b:

    # cass "Тогда мы торжественно поможем установить новый порядок или поможем окончательно задушить богомерзкое восстание. На наших условиях."
    cass "那我们就庄严地协助建立新的秩序，或是帮助彻底扼杀那场侮神的叛乱。按照我们的条件。"

# game/a8/9cassatio.rpy:97
translate english cassatio_dba4e06b_1:

    # "Несколько дней спустя."
    "几天以后。"

# game/a8/9cassatio.rpy:98
translate english cassatio_bf3e0682:

    # me "[cass]..."
    me "[cass]..."

# game/a8/9cassatio.rpy:99
translate english cassatio_f12a20b4:

    # cass "М?"
    cass "嗯？"

# game/a8/9cassatio.rpy:100
translate english cassatio_4056d27a:

    # me "[cassa]..."
    me "[cassa]..."

# game/a8/9cassatio.rpy:101
translate english cassatio_b2ec930b:

    # cass "Нет, [mename]."
    cass "不，[mename]。"

# game/a8/9cassatio.rpy:102
translate english cassatio_c255fd39:

    # me "Я больше не могу. Я сейчас упаду с лошади."
    me "我不行了。我就要从马上掉下去了。"

# game/a8/9cassatio.rpy:103
translate english cassatio_d82b6eda:

    # cass "Мы делали привал и ты поспал."
    cass "我们中途休息过，你也睡了一觉。"

# game/a8/9cassatio.rpy:105
translate english cassatio_97e8462c:

    # me "Два часа? Мы третий день в пути."
    me "两个小时？我们都已经赶了三天路了。"

# game/a8/9cassatio.rpy:106
translate english cassatio_a2d22aff:

    # cass "Мы должны успеть до того, как кто-то победит, [mename]. Время для нас слишком ценно."
    cass "我们必须在某方获胜之前赶到，[mename]。时间对我们来说太宝贵了。"

# game/a8/9cassatio.rpy:107
translate english cassatio_f3781136:

    # me "Я понимаю...но я больше не могу."
    me "我明白……但我真的不行了。"

# game/a8/9cassatio.rpy:108
translate english cassatio_26c6eb78:

    # cass "Поспи на лошади."
    cass "在马上睡吧。"

# game/a8/9cassatio.rpy:109
translate english cassatio_cceba9e2:

    # me "Я так не умею."
    me "我不会。"

# game/a8/9cassatio.rpy:110
translate english cassatio_c2568da5:

    # cass "Терпи значит."
    cass "那就忍着。"

# game/a8/9cassatio.rpy:111
translate english cassatio_b8695bc2:

    # me "Знаешь, лошади ведь тоже устают."
    me "你知道马也会累的。"

# game/a8/9cassatio.rpy:112
translate english cassatio_07948ce1:

    # cass "Я даю им отдохнуть."
    cass "我有让它们休息。"

# game/a8/9cassatio.rpy:113
translate english cassatio_7b7a5d54:

    # me "Пару часов? Это мало. Если они упадут без сил - мы нескоро поедем дальше. Тогда все это путешествие займет еще больше времени."
    me "几个小时？那太少了。要是它们累垮了，我们一时半会儿就别想往前走。那样整个行程就会花更多时间。"

# game/a8/9cassatio.rpy:114
translate english cassatio_cb2f0b26:

    # cass "Ладно...сегодня вечером большой привал."
    cass "好吧……今晚歇个长点的。"

# game/a8/9cassatio.rpy:116
translate english cassatio_745a3b37:

    # "Сегодня вечером."
    "Tonight."

# game/a8/9cassatio.rpy:117
translate english cassatio_58f2b7f8:

    # cass "Привязал лошадей?"
    cass "马拴好了吗？"

# game/a8/9cassatio.rpy:118
translate english cassatio_fc30fd2b:

    # me "Да."
    me "嗯。"

# game/a8/9cassatio.rpy:119
translate english cassatio_c4f8fc59:

    # cass "Седла снял?"
    cass "马鞍卸了吗？"

# game/a8/9cassatio.rpy:120
translate english cassatio_dc50cef1:

    # me "Нет. Снимешь?"
    me "没有。你来卸？"

# game/a8/9cassatio.rpy:121
translate english cassatio_899c7734:

    # cass "Ладно я сама, ты пока собери дров."
    cass "算了，我自己来，你去捡点柴火。"

# game/a8/9cassatio.rpy:122
translate english cassatio_71d3b8c8:

    # me "Хорошо."
    me "好。"

# game/a8/9cassatio.rpy:124
translate english cassatio_17a5699c:

    # me "Я нашел чей-то костер."
    me "我找到了别人留下的篝火。"

# game/a8/9cassatio.rpy:125
translate english cassatio_1d68a19f:

    # cass "Серьезно?"
    cass "真的？"

# game/a8/9cassatio.rpy:126
translate english cassatio_c6345686:

    # me "Да. Ну вернее угли. Им наверное день. Еще чуть-чуть теплые."
    me "是。嗯，准确说是木炭。大概是一天前的。还有一点温热。"

# game/a8/9cassatio.rpy:127
translate english cassatio_b10d5bcd:

    # cass "Хм..."
    cass "嗯……"

# game/a8/9cassatio.rpy:128
translate english cassatio_1e39cba1:

    # me "Думаешь может быть опасно?"
    me "你觉得可能有危险？"

# game/a8/9cassatio.rpy:129
translate english cassatio_30101cc9:

    # cass "Эльфы не жгут костры так близко к дорогам. Наверное, какие-то торговцы. Костер тушили?"
    cass "精灵不会在离路这么近的地方生火。大概是些商人。火堆是被扑灭的吗？"

# game/a8/9cassatio.rpy:130
translate english cassatio_2227a4e3:

    # me "Мне кажется он догорал сам. Пепел ровный."
    me "我感觉它是自己烧完的。灰烬很平整。"

# game/a8/9cassatio.rpy:131
translate english cassatio_51283ea2:

    # cass "А, ладно. Я вроде никого не видела. Разводи костер здесь. Сэкономим время."
    cass "啊，管他呢。我好像没看见人。就在这儿生火吧。节省点时间。"

# game/a8/9cassatio.rpy:133
translate english cassatio_83749a03:

    # "Полчаса спустя."
    "半个小时以后。"

# game/a8/9cassatio.rpy:134
translate english cassatio_6629c4b0:

    # me "Пахнет вкусно."
    me "闻起来真香。"

# game/a8/9cassatio.rpy:135
translate english cassatio_188042ff:

    # cass "Еще бы. Телятина."
    cass "那当然。这可是小牛肉。"

# game/a8/9cassatio.rpy:136
translate english cassatio_e01a3f7a:

    # me "Я бы сейчас и быка сожрал."
    me "我现在能吃下一整头牛。"

# game/a8/9cassatio.rpy:137
translate english cassatio_04865a8b:

    # cass "Я думала ты спать хочешь."
    cass "我以为你想睡觉呢。"

# game/a8/9cassatio.rpy:138
translate english cassatio_16821f92:

    # me "Я и спать хочу. Я нормально не ел и не спал три дня."
    me "我也想睡啊。我都三天没好好吃饭睡觉了。"

# game/a8/9cassatio.rpy:139
translate english cassatio_7616d384:

    # cass "Это кстати последний кусок мяса."
    cass "顺便说一句，这是最后一块肉了。"

# game/a8/9cassatio.rpy:140
translate english cassatio_672a5a4c:

    # me "Ты серьезно?"
    me "你开玩笑吧？"

# game/a8/9cassatio.rpy:141
translate english cassatio_b85b966f:

    # cass "Ага. Остались только сухари."
    cass "没错。只剩下干面包了。"

# game/a8/9cassatio.rpy:142
translate english cassatio_451e11d0:

    # me "Пиздец."
    me "操蛋。"

# game/a8/9cassatio.rpy:143
translate english cassatio_5f2f1984:

    # cass "Расслабься. Мы большую часть пути уже проехали."
    cass "放轻松。大部分路我们都已经走完了。"

# game/a8/9cassatio.rpy:144
translate english cassatio_00d68cd0:

    # me "Серьезно?"
    me "真的？"

# game/a8/9cassatio.rpy:145
translate english cassatio_4fe02f04:

    # cass "Ага. Думаю завтра будем в Черной Косе к ночи."
    cass "嗯。我想明天入夜前我们就能到黑湾了。"

# game/a8/9cassatio.rpy:146
translate english cassatio_c5b247f3:

    # me "Мы едем в город."
    me "我们要进城吗？"

# game/a8/9cassatio.rpy:147
translate english cassatio_eff7089d:

    # cass "Нет. Сразу в родовой замок моей матери и дяди."
    cass "不。直接去我母亲和舅舅的家堡。"

# game/a8/9cassatio.rpy:148
translate english cassatio_833390cc:

    # me "Нас там будут ждать?"
    me "那边会有人等我们吗？"

# game/a8/9cassatio.rpy:149
translate english cassatio_26305e5b:

    # cass "Ну...не совсем."
    cass "嗯……不完全是。"

# game/a8/9cassatio.rpy:150
translate english cassatio_3820771a_3:

    # me "..."
    me "..."

# game/a8/9cassatio.rpy:151
translate english cassatio_fde69513:

    # cass "Хочешь о чем-то спросить?"
    cass "你有什么想问的吗？"

# game/a8/9cassatio.rpy:152
translate english cassatio_d753c0a4:

    # me "Вообще-то хочу. Но жрать я хочу больше."
    me "其实有。但我现在更想吃饭。"

# game/a8/9cassatio.rpy:154
translate english cassatio_a25e8d63:

    # "Пол куска мяса спустя."
    "吃了半块肉以后。"

# game/a8/9cassatio.rpy:155
translate english cassatio_a94d2aeb:

    # cass "А ты и вправду был голодный."
    cass "你确实是饿坏了。"

# game/a8/9cassatio.rpy:156
translate english cassatio_5f031b18:

    # me "Ага..."
    me "嗯……"

# game/a8/9cassatio.rpy:157
translate english cassatio_651ccc28_2:

    # cass "..."
    cass "..."

# game/a8/9cassatio.rpy:158
translate english cassatio_09e4e1f9:

    # me "Так что там с гостеприимством?"
    me "那你说的欢迎是怎么回事？"

# game/a8/9cassatio.rpy:159
translate english cassatio_fbb4a4db:

    # cass "Все нормально. Прибудем туда и убедим ься с нами."
    cass "没问题。我们到了那儿，就能说服他们跟着我们。"

# game/a8/9cassatio.rpy:160
translate english cassatio_7218e4f6:

    # me "Убедим? Ты шутишь?"
    me "说服？你开玩笑吗？"

# game/a8/9cassatio.rpy:161
translate english cassatio_2ba4c3a3:

    # cass "Нет."
    cass "没有。"

# game/a8/9cassatio.rpy:162
translate english cassatio_b5e62b83:

    # me "А если они нас не послушают?"
    me "要是他们不听呢？"

# game/a8/9cassatio.rpy:163
translate english cassatio_ffc343e5:

    # cass "Послушают. Дядя Гуран замолвил за нас словечко, а он пользуется уважением на Косе."
    cass "他们会听的。Guran舅舅替我们说了些好话，他在黑湾受人尊敬。"

# game/a8/9cassatio.rpy:164
translate english cassatio_707dfdb7:

    # me "Ты кое-что забыла..."
    me "你忘了点事……"

# game/a8/9cassatio.rpy:165
translate english cassatio_257c9e82:

    # cass "Дядя не там? Я это помню. У нас и без него все получится."
    cass "舅舅不在那儿？这我记得。没他我们也能搞定。"

# game/a8/9cassatio.rpy:166
translate english cassatio_bf3e0682_1:

    # me "[cass]..."
    me "[cass]..."

# game/a8/9cassatio.rpy:167
translate english cassatio_2892008b:

    # cass "Успокойся, все будет нормально."
    cass "放心吧，一切都会没事的。"

# game/a8/9cassatio.rpy:168
translate english cassatio_5daffe4b:

    # me "Ладно. В любом случае уже слишком поздно, чтобы поворачивать назад."
    me "好吧。不管怎样现在掉头也太晚了。"

# game/a8/9cassatio.rpy:170
translate english cassatio_3d21f40c:

    # me "Зачем твоей семье нам помогать?"
    me "你的家族凭什么要帮我们？"

# game/a8/9cassatio.rpy:171
translate english cassatio_881754be:

    # cass "Я их семья, забыл?"
    cass "我是他们的家人，你忘了？"

# game/a8/9cassatio.rpy:172
translate english cassatio_ffbed5a6:

    # me "Кхм-кхм."
    me "咳-咳。"

# game/a8/9cassatio.rpy:173
translate english cassatio_cfabd571:

    # cass "Не волнуйся, я ищу власти не для себя. Просто тебе будет проще править Западом, когда нужно будет иметь дело только с одним домом, ты так не думаешь?"
    cass "别担心，我寻求权力不是为了我自己。只是，当你只需要和一个家族打交道就能统治西境时，事情会简单得多，你不这么觉得吗？"

# game/a8/9cassatio.rpy:174
translate english cassatio_2fd475fe:

    # me "С домом твоей семьи."
    me "和你家族的家族打交道。"

# game/a8/9cassatio.rpy:175
translate english cassatio_651ccc28_3:

    # cass "..."
    cass "..."

# game/a8/9cassatio.rpy:176
translate english cassatio_faaed91b:

    # me "А остальные лорды Запада примут владычество Черной Косы?"
    me "其他西境领主会接受黑湾的统治吗？"

# game/a8/9cassatio.rpy:177
translate english cassatio_f0aa5975:

    # cass "Остальные лорды примут твою власть. Власть сильного. А Черная Коса будет проводником твоей власти."
    cass "其他领主会接受你的统治。强者的统治。黑湾将是你权力的执行者。"

# game/a8/9cassatio.rpy:178
translate english cassatio_64b02a62:

    # me "Как это будет выглядеть? Структурно."
    me "这具体要怎么运作？结构上。"

# game/a8/9cassatio.rpy:179
translate english cassatio_2901b4ea:

    # cass "Как протекторат. Мы прибудем с войском и восстановим порядок. Для защиты от подобных 'происшествий' в будущем, исключительно из твоей мудрости и миролюбия, ты присоеднишь Запад к Золотому Королевству."
    cass "像个保护国。我们会带着军队抵达，恢复秩序。为了防范未来再次发生此类“事件”，纯粹出于你的英明与爱好和平，你将把西境并入黄金王国。"

# game/a8/9cassatio.rpy:180
translate english cassatio_8a0e25c3:

    # cass "А в качестве благодарности за восстановление порядка, назначишь временным лордом-протектором за всем Западом кого-нибудь из Черной Косы."
    cass "作为恢复秩序的感谢，你会从黑湾任命一位临时的护国公，管辖整个西境。"

# game/a8/9cassatio.rpy:181
translate english cassatio_e5cb0cc0:

    # me "Тебя?"
    me "任命你？"

# game/a8/9cassatio.rpy:182
translate english cassatio_530af3a6:

    # cass "Я конечно понимаю, что я только твоя сводная сестра, но я вообще-то все еще Стархед."
    cass "我当然理解我只是你同父异母的姐姐，但说到底，我依然是个Starhead。"

# game/a8/9cassatio.rpy:183
translate english cassatio_2fba8c22:

    # me "Тогда кого? Твоего дядю?"
    me "那该是谁？你舅舅？"

# game/a8/9cassatio.rpy:184
translate english cassatio_a9ff508d:

    # cass "Моего дядю очень любят в Черной Косе, а значит ненавидят на остальном Западе. Так что лучше выбрать какой-то более компромиссный вариант."
    cass "我舅舅在黑湾很受爱戴，这意味着在西境其他地方他会被憎恨。所以最好选个更折中的方案。"

# game/a8/9cassatio.rpy:185
translate english cassatio_e473fa2f:

    # me "Например?"
    me "比如说？"

# game/a8/9cassatio.rpy:186
translate english cassatio_af3f44f0:

    # cass "Мы найдем парочку вариантов."
    cass "我们会找到几个备选的。"

# game/a8/9cassatio.rpy:187
translate english cassatio_3820771a_4:

    # me "..."
    me "..."

# game/a8/9cassatio.rpy:188
translate english cassatio_85997b6d:

    # cass "Что? Не доверяешь мне? [mename], я могла убить тебя и отобрать твою власть десятки раз."
    cass "怎么？不信任我？[mename]，我本可以杀死你、夺走你权力几十次了。"

# game/a8/9cassatio.rpy:189
translate english cassatio_c29e21b5:

    # me "И в чем же дело тогда? Я еще полезен, как пешка? Сначала хочешь собрать больше земель под поим именем?"
    me "那又是为什么？我还作为棋子有用？你想先以我的名义收集更多土地？"

# game/a8/9cassatio.rpy:190
translate english cassatio_22388985:

    # cass "Неужели так сложно поверить в то, что я хочу величия и тебе и короне? Не думал, что я просто считаю, что ты будешь лучшим королем, чем отец?"
    cass "相信我希望给你和这顶王冠带来伟大，就那么难吗？你难道没想过，我只是认为你会是比父亲更好的国王？"

# game/a8/9cassatio.rpy:191
translate english cassatio_3820771a_5:

    # me "..."
    me "..."

# game/a8/9cassatio.rpy:192
translate english cassatio_651ccc28_4:

    # cass "..."
    cass "..."

# game/a8/9cassatio.rpy:193
translate english cassatio_8a085e73:

    # me "Спокойной ночи, [cass]."
    me "晚安，[cass]。"

# game/a8/9cassatio.rpy:201
translate english cassatio_7dcb4844:

    # me "Если бы я тебе не верил, разве я стал бы делать все эти ужасные вещи вместе с тобой?"
    me "如果我不信任你，我还会和你一起做所有这些可怕的事情吗？"

# game/a8/9cassatio.rpy:202
translate english cassatio_dad86b96:

    # cass "Ничего ужасного."
    cass "没什么可怕的。"

# game/a8/9cassatio.rpy:203
translate english cassatio_570f8d61:

    # me "Ложь, шатнтаж, убийство, отцеубийство, лжесвидетельствование, незаконное заключение в тюрьму..."
    me "谎言、勒索、谋杀、弑父、作伪证、非法监禁……"

# game/a8/9cassatio.rpy:204
translate english cassatio_7c5d8d6c:

    # cass "Если ты продолжишь - я кончу."
    cass "你要是继续说下去我就要高潮了。"

# game/a8/9cassatio.rpy:205
translate english cassatio_75a41697:

    # me "Ты...плохая."
    me "你……真是坏。"

# game/a8/9cassatio.rpy:206
translate english cassatio_af4244b2:

    # cass "Ты меня за это и любишь."
    cass "你爱的就是这点。"

# game/a8/9cassatio.rpy:207
translate english cassatio_3820771a_6:

    # me "..."
    me "..."

# game/a8/9cassatio.rpy:208
translate english cassatio_102e670f:

    # cass "Любишь же?"
    cass "你确实爱，对吧？"

# game/a8/9cassatio.rpy:209
translate english cassatio_3eff09f9:

    # me "Люблю."
    me "爱。"

# game/a8/9cassatio.rpy:210
translate english cassatio_bf49ca10:

    # cass "Ты в меня с детства влюблен. Помню эти щенячьи глазки во время наших ссор. Ты больше хотел меня поцеловать, чем поспорить."
