# game/a8/9cassatio.rpy:324
translate english cassatio2_76c8d3e8:

    # me "Некоторые их них просто слоняются с самого детства и не знают ни одного языка, но нам повезло, что этот из племени и знает два. Ну как знает...он хотя бы меня понял."
    me "他们中有些从小就四处游荡，什么语言都不会。但我们运气好，这只有部落，还懂两种语言。算是有“懂”吧……他至少听懂了我的意思。"

# game/a8/9cassatio.rpy:325
translate english cassatio2_c1608474:

    # me "Думаешь еще нужно гнать лошадей? Он обещал за нами не идти..."
    me "你觉得我们还需要赶马跑吗？他答应不追我们了……"

# game/a8/9cassatio.rpy:326
translate english cassatio2_57f5cf63:

    # cass "Ну его нахуй! Я не хочу еще один урок континентальной лингвистики в экстремальных условиях!"
    cass "去他妈的！我可不想在极端条件下再上一堂大陆语言学课！"

# game/a8/9cassatio.rpy:329
translate english cassatio2_de0fb1b6:

    # ogre "Э? БАБОЧКА!"
    ogre "呃？小蝴蝶蝶！"

# game/a8/9cassatio.rpy:330
translate english cassatio2_63cbcced:

    # cass "[mename]?"
    cass "[mename]?"

# game/a8/9cassatio.rpy:331
translate english cassatio2_e1bc278b:

    # ogre "БАБОЧКА НОЧЬЮ? БАБАХ?"
    ogre "大半夜的有蝴蝶？敲敲？"

# game/a8/9cassatio.rpy:332
translate english cassatio2_70066e56:

    # me "Сейчас!"
    me "来了！"

# game/a8/9cassatio.rpy:334
translate english cassatio2_6332b353:

    # ogre "АЙ! БАБОЧКА!"
    ogre "嗷！小蝴蝶蝶！"

# game/a8/9cassatio.rpy:335
translate english cassatio2_d423af8f:

    # me "Вставай! Ты ранена?"
    me "起来！你受伤了？"

# game/a8/9cassatio.rpy:336
translate english cassatio2_fa2fe5e3:

    # cass "Чуть ногу подвернула."
    cass "脚稍微扭了一下。"

# game/a8/9cassatio.rpy:337
translate english cassatio2_cdcceb76:

    # ogre "БАБОЧКА УХОДИ!"
    ogre "小蝴蝶蝶走走！"

# game/a8/9cassatio.rpy:338
translate english cassatio2_3716194c:

    # me "на лошади сможешь ехать?"
    me "还能骑马吗？"

# game/a8/9cassatio.rpy:339
translate english cassatio2_e54c3fbc:

    # cass "ДА."
    cass "能。"

# game/a8/9cassatio.rpy:340
translate english cassatio2_dced79c6:

    # ogre "БАБОЧКА УЙДИ ТЫ МЕШАЕШЬ СДЕЛАТЬ БАБАХ!"
    ogre "小蝴蝶蝶你走开碍着我弄敲敲了！"

# game/a8/9cassatio.rpy:341
translate english cassatio2_7ca4ca59:

    # me "Тогда сваливаем отсюда."
    me "那我们离开这儿。"

# game/a8/9cassatio.rpy:342
translate english cassatio2_25cf17c1:

    # ogre "БАБОЧКА Я СЕЙЧАС СДЕЛАЮ БАБАХ!"
    ogre "小蝴蝶蝶我现在就要弄敲敲了！"

# game/a8/9cassatio.rpy:343
translate english cassatio2_c9e4d874:

    # cass "Может убьем эту скотину?"
    cass "要不我们宰了这畜生？"

# game/a8/9cassatio.rpy:344
translate english cassatio2_40d96c1b:

    # me "Спятила? У него кожа по толщине как наши кинжалы! Уходим отсюда, БЫСТРЕЕ!"
    me "疯了吗？它的皮跟我们的匕首差不多厚！我们快离开这儿，快！"

# game/a8/9cassatio.rpy:346
translate english cassatio2_6ca8c686:

    # cass "Какого хрена он тут забыл? Я думал они только в горах живут."
    cass "这鬼东西在这儿干什么？我以为它们只住在山里。"

# game/a8/9cassatio.rpy:347
translate english cassatio2_b7469b62:

    # me "Я тоже так думал. Но как видишь этот видимо решил жрать людей здесь."
    me "我也这么想的。但你也看到了，这只显然决定在这里吃人。"

# game/a8/9cassatio.rpy:348
translate english cassatio2_d839f91d:

    # cass "Пиздец, когда закончим нужно будет объявить награду за его голову."
    cass "操蛋，等这事完了，非得悬赏要它的脑袋。"

# game/a8/9cassatio.rpy:349
translate english cassatio2_0987f681:

    # me "Хорошая мысль."
    me "好主意。"

# game/a8/9cassatio.rpy:350
translate english cassatio2_7a48ec3b:

    # cass "Думаешь он может нас преследовать."
    cass "你觉得它会追我们吗？"

# game/a8/9cassatio.rpy:351
translate english cassatio2_c394fb5b:

    # me "Не думаю. Но лучше на всякий случай отбежим подальше."
    me "不觉得。但以防万一，我们还是跑远点好。"

# game/a8/9cassatio.rpy:352
translate english cassatio2_82230383:

    # cass "Согласна."
    cass "同意。"

# game/a8/9cassatio.rpy:354
translate english cassatio2_ad5efb6c:

    # "На следующий день."
    "第二天。"

# game/a8/9cassatio.rpy:355
translate english cassatio2_b3b66e53:

    # me "Ну что? Мы уже близко?"
    me "怎么样？我们快到了吗？"

# game/a8/9cassatio.rpy:356
translate english cassatio2_b7c8f5f0:

    # cass "Да."
    cass "嗯。"

# game/a8/9cassatio.rpy:357
translate english cassatio2_3820771a:

    # me "..."
    me "..."

# game/a8/9cassatio.rpy:358
translate english cassatio2_c2487b65:

    # cass "Что?"
    cass "怎么了？"

# game/a8/9cassatio.rpy:359
translate english cassatio2_861abcee:

    # me "Откуда ты вообще знаешь сколько нам ехать? Ты же здесь никогда не была."
    me "你到底是怎么知道还要走多远的？你从没来过这儿。"

# game/a8/9cassatio.rpy:360
translate english cassatio2_5621a24d:

    # cass "Дядя сказал, что если через три-четыря дня пути начнет пахнуть болотом, а от пейзажей захочется покончить с собой - значит мы двигаемся в правильно направлении."
    cass "舅舅说，走个三四天后，如果开始闻到沼泽味，而且景色让人恨不得自杀，那我们就走对路了。"

# game/a8/9cassatio.rpy:361
translate english cassatio2_9a6032d9:

    # me "Ну...похоже мы на верном пути."
    me "嗯……看来我们是在正确的道路上。"

# game/a8/9cassatio.rpy:362
translate english cassatio2_ec7bfadf:

    # cass "Ну конечно."
    cass "那还用说。"

# game/a8/9cassatio.rpy:364
translate english cassatio2_08174615:

    # me "Но как мы узнаем куда именно ехать в это болоте? Мы уже часов 10 не встречали никого на пути."
    me "但我们怎么知道在这片沼泽里该往哪儿走？我们已经快10个小时没在路上碰到任何人影了。"

# game/a8/9cassatio.rpy:365
translate english cassatio2_f1736d40:

    # cass "В Черной Косе одна дорога. Будем ехать по ней и не ошибемся."
    cass "黑湾只有一条路。顺着路走，准没错。"

# game/a8/9cassatio.rpy:366
translate english cassatio2_15a00bac:

    # me "Не думал, что комаров может быть больше, чем в Долине."
    me "真没想到这里的蚊子比山谷里还多。"

# game/a8/9cassatio.rpy:367
translate english cassatio2_4268db74:

    # cass "И вонять может хуже."
    cass "而且可能还更臭。"

# game/a8/9cassatio.rpy:368
translate english cassatio2_c63e82ad:

    # me "Какого хрена здесь вообще люди живут?"
    me "这儿的人到底为什么要住在这种鬼地方？"

# game/a8/9cassatio.rpy:369
translate english cassatio2_517fda78:

    # cass "Не знаю. По легенде на Косе жили белокожие люди еще до вторжения железных людей."
    cass "不知道。传说在黑湾，在铁民入侵之前，就有白皮肤的人住在这儿了。"

# game/a8/9cassatio.rpy:370
translate english cassatio2_a9e211da:

    # me "Думаешь это правда?"
    me "你觉得是真的吗？"

# game/a8/9cassatio.rpy:371
translate english cassatio2_b16d535b:

    # cass "Понятия не имею, все, кто застали те времена, уже превратились в прах, так что просить некого."
    cass "毫无头绪，所有经历过那个时代的人都已经化为尘土了，想问也没人可问。"

# game/a8/9cassatio.rpy:372
translate english cassatio2_934036bb:

    # me "Ну есть же различные хроники."
    me "不是有各种编年史嘛。"

# game/a8/9cassatio.rpy:373
translate english cassatio2_1f502dbd:

    # cass "Хроники? В них лжи всегда больше, чем правды."
    cass "编年史？里面的谎言总是比真相更多。"

# game/a8/9cassatio.rpy:374
translate english cassatio2_8f8de749:

    # me "Это еще почему?"
    me "这又是为什么？"

# game/a8/9cassatio.rpy:375
translate english cassatio2_89e575b5:

    # cass "В первый Хрониках нашего дома написано, что его основатель, сир Лотрик, выковал себе корону из павшей звезды."
    cass "我们家最早的编年史记载，其创始人，Lotric爵士，是用坠落的星星给自己锻造了一顶王冠。"

# game/a8/9cassatio.rpy:376
translate english cassatio2_2325fa76:

    # me "И что?"
    me "那又怎样？"

# game/a8/9cassatio.rpy:377
translate english cassatio2_0b5ba3f5:

    # cass "А то, что там еще написано, что звезда упала прямо в ряды эльфов и Лотрик выковал себе корону прямо посреди боя, пока кусок звезды еще был горячим. А закалял он ее в эльфийской крови."
    cass "问题是，上面还写着，那颗星星直接掉进了精灵的队列里，而Lotric就在战斗之中，趁着星星碎片还滚烫时，锻造了王冠。他淬火用的是精灵的血。"

# game/a8/9cassatio.rpy:378
translate english cassatio2_fcf18b55:

    # me "Ну может в хрониках немного приукрашивают..."
    me "呃，也许编年史有点小小的夸张……"

# game/a8/9cassatio.rpy:380
translate english cassatio2_a2de16e8:

    # cass "Ага. Немного. Самую малость."
    cass "对。有点“小小”夸张。才怪。"

# game/a8/9cassatio.rpy:381
translate english cassatio2_561560b8:

    # me "По-твоему в хрониках - все неправда?"
    me "照你看来，编年史里全是假话？"

# game/a8/9cassatio.rpy:382
translate english cassatio2_f28f86bb:

    # cass "Может все, а может не все - какая в хрониках ценность, если ничего из написанного нельзя проверить?"
    cass "也许全是，也许不全是——如果里面写的东西都没法验证，那编年史还有什么价值？"

# game/a8/9cassatio.rpy:383
translate english cassatio2_8cf3a751:

    # me "Лия пишет мои Хроники."
    me "Lia在写我的编年史。"

# game/a8/9cassatio.rpy:384
translate english cassatio2_c05718c8:

    # cass "Правда? Забавно. И в чьей ты там крови закаляешь свою корону?"
    cass "真的？有意思。那你是在谁的血里淬火你的王冠呢？"

# game/a8/9cassatio.rpy:385
translate english cassatio2_0988f65a:

    # me "Ни в чьей. Она пишет только правду."
    me "谁的血也没有。她只记录真相。"

# game/a8/9cassatio.rpy:386
translate english cassatio2_47c5f815:

    # cass "Да ну. А она откуда знает 'только правду'?"
    cass "得了吧。那她从哪儿知道这“真相”的？"

# game/a8/9cassatio.rpy:387
translate english cassatio2_43b56cd6:

    # me "Я ей надиктовываю."
    me "我口述给她的。"

# game/a8/9cassatio.rpy:388
translate english cassatio2_651ccc28:

    # cass "..."
    cass "..."

# game/a8/9cassatio.rpy:389
translate english cassatio2_1ddf22e3:

    # me "Что? По-твоему я лгу? Зачем мне это? Хроники публикуют только после смерти."
    me "什么？你觉得我在撒谎？我为什么要这么做？编年史只在死后才公布。"

# game/a8/9cassatio.rpy:390
translate english cassatio2_9145e3e8:

    # cass "Вспомни наш разговор в саду у лорда Аргуса. Некоторые люди больше всего на свете хотят оставить после себя след. Это такая форма нарциссизма."
    cass "记得我们在Argus领主花园里的对话吗？有些人毕生最想要的，就是留下自己的印记。这是一种自恋的形式。"

# game/a8/9cassatio.rpy:391
translate english cassatio2_02eedd72:

    # me "Приедем в столицу и я дам тебе почитать."
    me "回到都城我给你看看。"

# game/a8/9cassatio.rpy:392
translate english cassatio2_28ae42fe:

    # cass "Если там все будет правдой - я извинюсь."
    cass "如果里面全是真话，我就道歉。"

# game/a8/9cassatio.rpy:393
translate english cassatio2_f7531243:

    # me "Договорились."
    me "一言为定。"

# game/a8/9cassatio.rpy:395
translate english cassatio2_5b5db8a2:

    # "Этой ночью."
    "That night."

# game/a8/9cassatio.rpy:396
translate english cassatio2_1f00f096:

    # me "Ты уверена, что это нужный замок?"
    me "你确定就是这个城堡吗？"

# game/a8/9cassatio.rpy:397
translate english cassatio2_b7c8f5f0_1:

    # cass "Да."
    cass "是的。"

# game/a8/9cassatio.rpy:398
translate english cassatio2_f6b942ad:

    # me "Почему тут нет охраны?"
    me "为什么没有卫兵？"

# game/a8/9cassatio.rpy:399
translate english cassatio2_da487331:

    # cass "Понятия не имею. Может ее не вообще?"
    cass "完全不知道。也许根本就没设防？"

# game/a8/9cassatio.rpy:400
translate english cassatio2_75ec6ec2:

    # me "Как это не безопасно."
    me "这多不安全。"

# game/a8/9cassatio.rpy:401
translate english cassatio2_2dd53376:

    # cass "Когда живешь на краю мира, наверное, забываешь, что в нем есть кто-то еще."
    cass "当你住在世界的边缘时，大概会忘记这个世界里还有其他人存在。"

# game/a8/9cassatio.rpy:402
translate english cassatio2_cbf1fe52:

    # me "Внутри какой-то шум."
    me "里面好像有声音。"

# game/a8/9cassatio.rpy:403
translate english cassatio2_c62912d3:

    # cass "Ага. Я тоже слышу."
    cass "嗯。我也听到了。"

# game/a8/9cassatio.rpy:405
translate english cassatio2_15c83d43:

    # me "Эм...а вот кажется и охрана."
    me "呃……那好像是卫兵。"

# game/a8/9cassatio.rpy:406
translate english cassatio2_b7c8f5f0_2:

    # cass "Да."
    cass "是。"

# game/a8/9cassatio.rpy:407
translate english cassatio2_9b01d66c:

    # me "Убит?"
    me "他死了吗？"

# game/a8/9cassatio.rpy:408
translate english cassatio2_4ff4e75a:

    # cass "Да вроде дышит."
    cass "好像还在喘气。"

# game/a8/9cassatio.rpy:409
translate english cassatio2_72bb3b68:

    # me "Да он пьяный."
    me "他喝醉了。"

# game/a8/9cassatio.rpy:410
translate english cassatio2_85982a94:

    # cass "Похоже на то. Проверим?"
    cass "看起来是。进去看看？"

# game/a8/9cassatio.rpy:411
translate english cassatio2_eb2b9cda:

    # me "Я отсюда дешевое вино чую."
    me "我老远就闻到劣质酒味了。"

# game/a8/9cassatio.rpy:413
translate english cassatio2_550af200:

    # me "Хороши...охранники. А если бы мы были наемными убийцами?"
    me "好……好卫兵。要是我们是刺客怎么办？"

# game/a8/9cassatio.rpy:414
translate english cassatio2_8eec5eb2:

    # cass "Ну, как видишь, их эта угроза не сильно беспокоит."
    cass "嗯，看来，这种威胁一点也没让他们操心。"

# game/a8/9cassatio.rpy:415
translate english cassatio2_177cc91d:

    # me "Ну, разу уж охрана пьяна - видимо шум внутри это праздник."
    me "既然卫兵都醉倒了，那看来里面的动静是在开宴会。"

# game/a8/9cassatio.rpy:416
translate english cassatio2_6a18f3cb:

    # cass "Ага."
    cass "没错。"

# game/a8/9cassatio.rpy:417
translate english cassatio2_8881ba8a:

    # me "И что они празднуют?"
    me "他们在庆祝什么？"

# game/a8/9cassatio.rpy:418
translate english cassatio2_54352399:

    # cass "Понятия не имею. Возьми у него меч."
    cass "我完全不知道。把他的剑拿走。"

# game/a8/9cassatio.rpy:419
translate english cassatio2_7332342b:

    # me "Зачем?"
    me "为什么？"

# game/a8/9cassatio.rpy:420
translate english cassatio2_45eae6d7:

    # cass "Может понадобиться."
    cass "说不定用得着。"

# game/a8/9cassatio.rpy:421
translate english cassatio2_8054219c:

    # me "Не понял. Зачем например?"
    me "没明白。比如什么情况下？"

# game/a8/9cassatio.rpy:422
translate english cassatio2_58a47a8c:

    # cass "Я буду пытаться убедить толпу пьяный мужчин, мало ли что может случиться."
    cass "我要试着说服一屋子喝醉的男人，谁说得准会发生什么。"

# game/a8/9cassatio.rpy:423
translate english cassatio2_e8c38eca:

    # me "Звучит, как будто мы умрем через пару минут."
    me "听起来，我们几分钟后就要死翘翘了。"

# game/a8/9cassatio.rpy:424
translate english cassatio2_77db8167:

    # cass "Ты испугался?"
    cass "你害怕了？"

# game/a8/9cassatio.rpy:425
translate english cassatio2_fc30fd2b:

    # me "Да."
    me "害怕。"

# game/a8/9cassatio.rpy:426
translate english cassatio2_b766ff99:

    # cass "Поворачиваем обратно?"
    cass "掉头回去？"

# game/a8/9cassatio.rpy:427
translate english cassatio2_6b4371c8:

    # me "Ну уж нет, я по этому сраному болоту не зря ехал."
    me "那可不行，我可不能白在这片烂沼泽地里走一遭。"

# game/a8/9cassatio.rpy:429
translate english cassatio2_ff50a176:

    # zpd1 "Передай ножку."
    zpd1 "递个鸡腿过来。"

# game/a8/9cassatio.rpy:430
translate english cassatio2_9ce7beec:

    # zpd2 "Сам возьми."
    zpd2 "你自己拿。"

# game/a8/9cassatio.rpy:431
translate english cassatio2_37e7afb0:

    # zpd1 "Мне нельзя руки напрягать, они ночью будут обнимать твою маму."
    zpd1 "我不能让手太累，晚上它们还得抱着你妈呢。"

# game/a8/9cassatio.rpy:432
translate english cassatio2_eab6d9e5:

    # zpd2 "Че ты сказал?"
    zpd2 "你说什么？"

# game/a8/9cassatio.rpy:434
translate english cassatio2_b0be7be2:

    # cass "Только не кидайся на них первым."
    cass "你可别第一个冲上去找事。"

# game/a8/9cassatio.rpy:435
translate english cassatio2_c828284c:

    # me "Я похож на самоубийцу?"
    me "我看着像自杀狂吗？"

# game/a8/9cassatio.rpy:436
translate english cassatio2_7a131ad9:

    # cass "И говорить буду я, понял?"
    cass "还有，让我来说话，明白吗？"

# game/a8/9cassatio.rpy:437
translate english cassatio2_e47e3b71:

    # me "А я?"
    me "那我呢？"

# game/a8/9cassatio.rpy:438
translate english cassatio2_d80d6397:

    # cass "А ты знаешь, что сказать?"
    cass "那你知道该说什么吗？"

# game/a8/9cassatio.rpy:439
translate english cassatio2_ced33473:

    # me "Нет, а ты знаешь?"
    me "不知道，你知道吗？"

# game/a8/9cassatio.rpy:440
translate english cassatio2_3c8f2c1d:

    # cass "Знаю. Так что просто молчи и охраняй меня."
    cass "知道。所以你闭嘴，保护好我就行。"

# game/a8/9cassatio.rpy:441
translate english cassatio2_01822020:

    # me "Ладно."
    me "好吧。"

# game/a8/9cassatio.rpy:443
translate english cassatio2_4852e0ae:

    # zpd1 "Это что за уроды?"
    zpd1 "这两个怪胎是谁？"

# game/a8/9cassatio.rpy:444
translate english cassatio2_4e5dabfc:

    # zpd2 "Не знаю, но у белобрысого эльфийские уши."
    zpd2 "不知道，那个白头发的有精灵耳朵。"

# game/a8/9cassatio.rpy:445
translate english cassatio2_bc90ab35:

    # cass "Без резких движений."
    cass "别轻举妄动。"

# game/a8/9cassatio.rpy:446
translate english cassatio2_101d65a6:

    # me "Я стараюсь."
    me "我在尽力。"

# game/a8/9cassatio.rpy:447
translate english cassatio2_280fd249:

    # cass "Сохраняй спокойствие."
    cass "保持冷静。"

# game/a8/9cassatio.rpy:448
translate english cassatio2_130be89d:

    # zpd3 "И че он с мечом прется?"
    zpd3 "他带着剑鬼晃什么？"

# game/a8/9cassatio.rpy:449
translate english cassatio2_c00069bc:

    # zpd4 "А баба то без глаза."
    zpd4 "那个娘们还没了一只眼。"

# game/a8/9cassatio.rpy:451
translate english cassatio2_bd0cedce:

    # zpd1 "Думаете это она?"
    zpd1 "你俩觉得是她吗？"

# game/a8/9cassatio.rpy:452
translate english cassatio2_ae1c2322:

    # zpd2 "[cassa]?"
    zpd2 "[cassa]?"

# game/a8/9cassatio.rpy:453
translate english cassatio2_4e95e8e6:

    # zpd3 "Да ну. Чего она здесь с этим эльфом забыла?"
    zpd3 "得了吧。她和这个精灵来这儿干什么？"

# game/a8/9cassatio.rpy:454
translate english cassatio2_4d6b4541:

    # zpd4 "Забыли что нам Гуран говорил?"
    zpd4 "你们忘了Guran怎么说的了吗？"

# game/a8/9cassatio.rpy:455
translate english cassatio2_a57e3808:

    # cass "Здравствуй. Ты Корнелиус?"
    cass "你好。你是Cornelius吗？"

# game/a8/9cassatio.rpy:457
translate english cassatio2_28ecdbfd:

    # cornelius "Я не отвечаю гостям, которые заявляются без приглашения."
    cornelius "我不会回应不请自来的客人。"

# game/a8/9cassatio.rpy:458
translate english cassatio2_93c9c606:

    # cass "Я - [cassa], моя мать с Черной Косы."
    cass "我是[cassa]，我母亲来自黑湾。"

# game/a8/9cassatio.rpy:459
translate english cassatio2_247661bd:

    # cornelius "И что? Мне тебя за это в жопу поцеловать? Здесь все с Черной Косы."
    cornelius "那又怎样？要我给你屁股一个吻吗？这里人人都来自黑湾。"

# game/a8/9cassatio.rpy:460
translate english cassatio2_552858c6:

    # cass "Я племянница Гурана."
    cass "我是Guran的外甥女。"

# game/a8/9cassatio.rpy:461
translate english cassatio2_9ec0351c:

    # cornelius "Повторяю вопрос - и что? Гуран сбежал в Золотую Столицу. Его имя здесь больше ничего не значит."
    cornelius "我再问一遍——那又怎样？Guran逃去了黄金都城。他的名字在这里已经一文不值了。"

# game/a8/9cassatio.rpy:462
translate english cassatio2_cbf4a151:

    # cass "Я с предложением - Черная Коса может править Западом."
    cass "我带来了一个提议——黑湾可以统治西境。"

# game/a8/9cassatio.rpy:463
translate english cassatio2_6d4dda6b:

    # cornelius "Ты не слышала новости? Ворон принес сегодня письмо - на Западе восстание."
    cornelius "你没听说那个消息吗？今天渡鸦送来了信——西境发生了叛乱。"

# game/a8/9cassatio.rpy:464
translate english cassatio2_9ba96b6c:

    # cass "Вот именно. И их этого можно извлечь выгоду."
    cass "正是如此。我们可以从中获利。"

# game/a8/9cassatio.rpy:465
translate english cassatio2_50b9cd76:

    # cornelius "Наша выгода в том, чтобы сидеть и праздновать как эти ублюдки режут друг другу горло."
    cornelius "我们的好处就是坐在这儿，看着那些混蛋互相割喉咙，好好庆祝。"

# game/a8/9cassatio.rpy:466
translate english cassatio2_451d1fad:

    # cass "Ладно, с тобой говорить бесполезно, да, старик?"
    cass "好吧，跟你说不通，是吗，老头？"

# game/a8/9cassatio.rpy:468
translate english cassatio2_64f46ea5:

    # cornelius "Следи за языком, девка."
    cornelius "管好你的舌头，丫头。"

# game/a8/9cassatio.rpy:469
translate english cassatio2_cd02944a:

    # cass "Или что? Насрешь под себя?"
    cass "否则呢？你吓得拉裤子吗？"

# game/a8/9cassatio.rpy:470
translate english cassatio2_7925713b:

    # cornelius "Или его сейчас отрежут."
    cornelius "否则它就要被割掉了。"

# game/a8/9cassatio.rpy:471
translate english cassatio2_466343b2:

    # cass "Ты так в этом уверен?"
    cass "你真有这把握？"

# game/a8/9cassatio.rpy:472
translate english cassatio2_f4f53108:

    # cornelius "Хочешь проверить."
    cornelius "想试试看吗？"

# game/a8/9cassatio.rpy:473
translate english cassatio2_b61e5d11:

    # cass "[mename], подними меч и убивай любого, кто попытается к нас подойти."
    cass "[mename]，举起剑，任何想靠近我们的人，杀了他。"

# game/a8/9cassatio.rpy:474
translate english cassatio2_71d3b8c8:

    # me "Хорошо."
    me "好。"

# game/a8/9cassatio.rpy:475
translate english cassatio2_da4e21f0:

    # cornelius "Здесь человек сорок, девочка, вы правда думаете, что..."
    cornelius "这里有四十个人，丫头，你们真以为……"

# game/a8/9cassatio.rpy:477
translate english cassatio2_01cda6f4:

    # cass "{size=+4}Черная Коса! Выслушайте меня! Меня зовут [cassa], я дочь Сибиллы из Туманного Перешейка.{/size}"
    cass "{size=+4}黑湾的诸位！听我说！我叫[cassa]，雾桥的西比拉之女。{/size}"

# game/a8/9cassatio.rpy:478
translate english cassatio2_25e8d8c3:

    # cass "{size=+4}Мой дядя - Гуран, которого все уважают и любят за смелость.{/size}"
    cass "{size=+4}我的舅舅是Guran，一个因勇敢而备受尊敬和爱戴的人。{/size}"

# game/a8/9cassatio.rpy:479
translate english cassatio2_83b86241:

    # cornelius "Кто его любит? Что ты лопочешь?"
    cornelius "谁爱戴他？你瞎说什么？"

# game/a8/9cassatio.rpy:480
translate english cassatio2_866b938f:

    # cass "{size=+4}Это - мой брат. Легитимный наследник Золотой Империи.{/size}"
    cass "{size=+4}这是我的弟弟。黄金帝国的合法继承人。{/size}"

# game/a8/9cassatio.rpy:481
translate english cassatio2_d847858e:

    # cass "{size=+4}Мы почти неделю скакали без остановок, чтобы привести сюда предложение.{/size}"
    cass "{size=+4}我们几乎马不停蹄地赶了将近一周的路，就是为了带来一个提议。{/size}"

# game/a8/9cassatio.rpy:482
translate english cassatio2_2babbd7f:

    # cass "{size=+4}Вернее великий шанс. Шанс для Черной Косы править всем Западом.{/size}"
    cass "{size=+4}准确地说，是一个伟大的机遇。一个黑湾统治整个西境的机遇。{/size}"

# game/a8/9cassatio.rpy:483
translate english cassatio2_8ff39eb9:

    # cass "{size=+4}Вы рано сели праздновать за столы. Что толку от того, что на Западе хаос и резня, если вы все так и останетесь навечно сидеть в этом болоте?{/size}"
    cass "{size=+4}你们过早地坐在桌边庆祝了。西境陷入混乱和屠杀，如果你们仍旧永远困坐在这片沼泽里，那这一切对你们又有何意义呢？{/size}"

# game/a8/9cassatio.rpy:484
translate english cassatio2_bbce9daa:

    # cornelius "Как ты посмела такое сказать?"
    cornelius "你怎么敢说这种话？"

# game/a8/9cassatio.rpy:485
translate english cassatio2_992b1c00:

    # cass "{size=+4}Неужели вы не считаете себя достойными править?{/size}"
    cass "{size=+4}难道你们不觉得自己配得上统治吗？{/size}"

# game/a8/9cassatio.rpy:486
translate english cassatio2_e4672915:

    # cass "{size=+4}Наверно вы задаетесь вопросом, что же именно я предлагаю. Вот ответ - мы соберем объедененную армию со всей Черной Косы и выступим к Ривелье.{/size}"
    cass "{size=+4}你们大概在疑惑，我究竟提议的是什么。答案是这样的——我们将集结整个黑湾的联军，向瑞维耶进军。{/size}"

# game/a8/9cassatio.rpy:487
translate english cassatio2_b1b2bd9b:

    # cass "{size=+4}Мы не станем спешить и прибудем именно тогда, когда мятежники и лорды друг друга достаточно поубивают.{/size}"
    cass "{size=+4}我们不必着急，只待叛军和领主们彼此厮杀到足够两败俱伤之时，我们便正好抵达。{/size}"

# game/a8/9cassatio.rpy:488
translate english cassatio2_54eecb45:

    # cass "{size=+4}Мы захватим Ривелье, лордов и всех мятежников, как раз когда из Золотой Столицы прибудет войско моего брата.{/size}"
    cass "{size=+4}我们将攻占瑞维耶，抓住领主们和所有叛军，届时，我弟弟的军队将正好从黄金都城赶到。{/size}"

# game/a8/9cassatio.rpy:489
translate english cassatio2_b743f562:

    # cornelius "Зря стараешься..."
    cornelius "你白费力气了……"

# game/a8/9cassatio.rpy:490
translate english cassatio2_48483cc2:

    # cass "{size=+4}Он объявит о восстановлении Империи, мы присягнем ей и мой брат дарует всем лордам Черной Косы статус лордов-протекторов. {/size}"
    cass "{size=+4}他会宣布帝国重建，我们将向其宣誓效忠，而我的弟弟将授予黑湾所有领主护国公的地位。{/size}"

# game/a8/9cassatio.rpy:491
translate english cassatio2_ff1638e9:

    # cass "{size=+4}Вы все будете новыми властителями Запада.{/size}"
    cass "{size=+4}你们所有人都将成为西境新的统治者。{/size}"

# game/a8/9cassatio.rpy:492
translate english cassatio2_7ab31bac:

    # cass "{size=+4}Это власть, что никому из вас никогда и не снилась.{/size}"
    cass "{size=+4}这是你们所有人做梦都未曾想过的权力。{/size}"

# game/a8/9cassatio.rpy:493
translate english cassatio2_3fe5c98d:

    # cass "{size=+4}Там, где раньше при словосочетании 'Черная Коса' брезгливо плевались - будут чистить вам сапоги своими рубашками.{/size}"
    cass "{size=+4}从前，人们听到“黑湾”这个词就会厌恶地啐一口，以后，他们会用自己的衬衣为你们擦亮靴子。{/size}"

# game/a8/9cassatio.rpy:494
translate english cassatio2_218b4134:

    # cass "{size=+4}Там, где раньше ничего не желали слышать о нашей земле, все будут делать с нашего дозволения.{/size}"
    cass "{size=+4}从前，没有人愿意听到关于我们这片土地的半点消息，以后，万事都将经我们准许才能进行。{/size}"

# game/a8/9cassatio.rpy:495
translate english cassatio2_6ff1fa14:

    # cass "{size=+4}Ваши дети будут смотреть на вас, как на героев, подвалы ваши будут ломиться от золота, а спальни от женщин.{/size}"
    cass "{size=+4}你们的孩子会用看英雄的目光注视你们，你们的地窖将堆满黄金，你们的卧房将美女如云。{/size}"

# game/a8/9cassatio.rpy:496
translate english cassatio2_b7c805de:

    # cornelius "Это смешно...."
    cornelius "这真是可笑……"

# game/a8/9cassatio.rpy:498
translate english cassatio2_650f46ed:

    # cornelius "Очень пронзительная речь, но все эти люди уже дали клятву, что их клинки будут со мной. А это то, почему Черная Коса до сих пор существует."
    cornelius "非常动人的演说，但这里的所有人都已经立下誓言，他们的剑将与我同在。这正是黑湾至今仍然存在的原因。"

# game/a8/9cassatio.rpy:499
translate english cassatio2_5627015a:

    # cornelius "Мы верны клятве."
    cornelius "我们忠于誓言。"

# game/a8/9cassatio.rpy:500
translate english cassatio2_ee119da4:

    # cornelius "Так что я бы отпустил вас, но боюсь после того оскорбления, что вы нанесли мне и нашей земле..."
    cornelius "所以，我本想放你们走的，但恐怕，在你们侮辱了我和我们这片土地之后……"

# game/a8/9cassatio.rpy:502
translate english cassatio2_64f432e4:

    # cass "{size=+4}Мы привезли вам шанс - воспользуетесь вы им или просто сгниете на болоте, как сотни лордов до вас?{/size}"
    cass "{size=+4}我们给你们带来了机遇——你们是抓住它，还是像你们以前的成百上千的领主一样，烂在这片沼泽里？{/size}"

# game/a8/9cassatio.rpy:503
translate english cassatio2_eb655f0d:

    # me "[cass]?"
    me "[cass]?"

# game/a8/9cassatio.rpy:504
translate english cassatio2_904ffbd8:

    # zpd1 "Спокойно, парень, я иду к своему лорду."
    zpd1 "冷静点，小子，我是走向我的领主。"

# game/a8/9cassatio.rpy:505
translate english cassatio2_eb655f0d_1:

    # me "[cass]?"
    me "[cass]?"

# game/a8/9cassatio.rpy:506
translate english cassatio2_9717bf9c:

    # cass "Пропусти его."
    cass "让他过来。"

# game/a8/9cassatio.rpy:508
translate english cassatio2_af842576:

    # cornelius "Седрик, ты что удумал?"
    cornelius "塞德里克，你打算干什么？"

# game/a8/9cassatio.rpy:509
translate english cassatio2_f14163f1:

    # zpd1 "Мой клинок с тобой, Корнелиус."
    zpd1 "我的剑与你同在，Cornelius。"

# game/a8/9cassatio.rpy:510
translate english cassatio2_a5ee05cd:

    # cornelius "Молодец."
    cornelius "好样的。"

# game/a8/9cassatio.rpy:511
translate english cassatio2_98a59ff9:

    # zpd1 "Я верен клятве."
    zpd1 "我忠于誓言。"

# game/a8/9cassatio.rpy:512
translate english cassatio2_78bdc99f:

    # cornelius "Я знаю. Эта шлюха из Золотой Столицы понятие не имеет, что такое честь."
    cornelius "我知道。这个从黄金都城来的婊子根本不懂什么叫荣誉。"

# game/a8/9cassatio.rpy:514
translate english cassatio2_bc46f9c9:

    # zpd2 "{size=+4}Мой клинок с тобой, мой лорд!{/size}"
    zpd2 "{size=+4}我的剑与你同在，我的领主！{/size}"

# game/a8/9cassatio.rpy:515
translate english cassatio2_c163b4d9:

    # cornelius "Спасибо и тебе, Рональд."
    cornelius "也谢谢你，罗纳德。"

# game/a8/9cassatio.rpy:516
translate english cassatio2_011e5c32:

    # zpd3 "Мой клинок с тобой, Корнеулиус."
    zpd3 "我的剑与你同在，Cornelius。"

# game/a8/9cassatio.rpy:517
translate english cassatio2_d88dea80:

    # cornelius "Да...отлично...как там тебя..."
    cornelius "好……很好……你叫什么来着……"

# game/a8/9cassatio.rpy:519
translate english cassatio2_0928de5c:

    # zpd4 "{size=+12}МОЙ МЕЧ С ТОБОЙ, МОЙ ЛОРД!{/size}"
    zpd4 "{size=+12}我的剑与你同在，我的领主！{/size}"

# game/a8/9cassatio.rpy:520
translate english cassatio2_b722293d:

    # cornelius "Эй! Ты чего творишь?"
    cornelius "嘿！你在干什么？"

# game/a8/9cassatio.rpy:521
translate english cassatio2_32379671:

    # zpd5 "{size=+4}Мой клинок с тобой!{/size}"
    zpd5 "{size=+4}我的剑与你同在！{/size}"

# game/a8/9cassatio.rpy:522
translate english cassatio2_28d0a9d5:

    # cornelius "Хватит. Все всё поняли."
    cornelius "够了。大家都懂你意思了。"

# game/a8/9cassatio.rpy:523
translate english cassatio2_ef238c8b:

    # cornelius "Успокойтесь."
    cornelius "冷静点。"

# game/a8/9cassatio.rpy:525
translate english cassatio2_57998292:

    # me "Эм...я немного не понимаю, что происходит."
    me "呃……我有点搞不清状况。"

# game/a8/9cassatio.rpy:526
translate english cassatio2_6e566caa:

    # cass "Люди подтверждают свои клятвы."
    cass "人们在确认他们的誓言。"

# game/a8/9cassatio.rpy:527
translate english cassatio2_674dbfcb:

    # zpd6 "{size=+4}Мой нож с тобой!{/size}"
    zpd6 "{size=+4}我的刀与你同在！{/size}"

# game/a8/9cassatio.rpy:528
translate english cassatio2_16c44b8c:

    # cornelius "Аккуратнее!"
    cornelius "小心点！"

# game/a8/9cassatio.rpy:529
translate english cassatio2_99e330bd:

    # me "Я не об этом."
    me "我不是指这个。"

# game/a8/9cassatio.rpy:530
translate english cassatio2_fd8ff4ec:

    # cass "А о чем ты?"
