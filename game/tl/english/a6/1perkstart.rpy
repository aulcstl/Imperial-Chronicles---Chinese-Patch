# game/a6/1perkstart.rpy:37
translate english perkstart_i_128f9459:

    # lia "Практически все."
    lia "差不多都读了。"

# game/a6/1perkstart.rpy:38
translate english perkstart_i_2174616f:

    # me "Даже на других языках?"
    me "甚至其他语言的？"

# game/a6/1perkstart.rpy:39
translate english perkstart_i_347fea49:

    # lia "Даже на других языках."
    lia "甚至其他语言的。"

# game/a6/1perkstart.rpy:40
translate english perkstart_i_9ad43142:

    # me "Elentári'as?"
    me "Elentári'as?"

# game/a6/1perkstart.rpy:41
translate english perkstart_i_475545e4:

    # lia "Ага. На эльфийском тоже."
    lia "哈。精灵语的也读了。"

