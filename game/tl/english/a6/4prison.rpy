translate english prison2_47994dc3:

    # leo "Не успеет, тащи его мимо поста, там кого-нибудь окликнешь бежать за доктором. К тому времени что они сюда двинет ты уже будешь на пол пути."
    leo "来不及了，拖着他经过哨站，到那儿喊人去找医生。等他们赶到这儿，你路都跑一半了。"

# game/a6/4prison.rpy:196
translate english prison2_9714899e:

    # randolph "Да...точно."
    randolph "对……没错。"

# game/a6/4prison.rpy:197
translate english prison2_3cfcedd6:

    # leo "Помочь?"
    leo "搭把手？"

# game/a6/4prison.rpy:198
translate english prison2_a3e27042:

    # randolph "Ты останешься в клетке."
    randolph "你得待在笼子里。"

# game/a6/4prison.rpy:200
translate english prison2_528f137d:

    # ludwig "Эй. Ты что делаешь."
    ludwig "嘿，你在干什么。"

# game/a6/4prison.rpy:201
