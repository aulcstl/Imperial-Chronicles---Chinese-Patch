# TODO: Translation updated at 2024-09-30 00:17

# game/a6/4prison.rpy:3
translate english prison_3575c1dd:

    # me "{i}Ох...моя голова...{/i}"
    me "{i}呃……我的头……{/i}"

# game/a6/4prison.rpy:4
translate english prison_7a8f3918:

    # me "{i}Не могу сфокусировать зрение.{/i}"
    me "{i}视线无法聚焦。{/i}"

# game/a6/4prison.rpy:5
translate english prison_f4008981:

    # me "{i}[cass], что ты натворила...{/i}"
    me "{i}[cass]，你都干了些什么……{/i}"

# game/a6/4prison.rpy:7
translate english prison_5c76dbe7:

    # me "{i}...{/i}"
    me "{i}...{/i}"

# game/a6/4prison.rpy:8
translate english prison_e1aede67:

    # me "{i}Кажется со зрением получше.{/i}"
    me "{i}视力好像好些了。{/i}"

# game/a6/4prison.rpy:9
translate english prison_0bef8e78:

    # me "{i}Но голова болеть не перестает.{/i}"
    me "{i}但头疼没有停止。{/i}"

# game/a6/4prison.rpy:10
translate english prison_332fe239:

    # me "{i}А если бы доза была больше?{/i}"
    me "{i}要是剂量再大点会怎样？{/i}"

# game/a6/4prison.rpy:11
translate english prison_c8ac50a9:

    # me "{i}О нет, мама кажется и выпила больше...{/i}"
    me "{i}哦不，妈妈好像喝得更多……{/i}"

# game/a6/4prison.rpy:13
translate english prison_e1ad6931:

    # me "{i}Где я?{/i}"
    me "{i}我在哪儿？{/i}"

# game/a6/4prison.rpy:14
translate english prison_ad7f4bbd:

    # me "{i}Это подземелье?{/i}"
    me "{i}这是地牢吗？{/i}"

# game/a6/4prison.rpy:15
translate english prison_b4c16647:

    # me "{i}Оно же было заброшено.{/i}"
    me "{i}它原本已经废弃了。{/i}"

# game/a6/4prison.rpy:16
translate english prison_a54424b2:

    # me "{i}[cass] снова сделала это место тюрьмой?{/i}"
    me "{i}[cass]又把这里变成了监狱吗？{/i}"

# game/a6/4prison.rpy:17
translate english prison_50db35c5:

    # me "{i}Мне нужно попробовать встать.{/i}"
    me "{i}我得试着站起来。{/i}"

# game/a6/4prison.rpy:19
translate english prison_534a2f3e:

    # me "Эй, ты, где мы?"
    me "嘿，你，我们在哪儿？"

# game/a6/4prison.rpy:20
translate english prison_764e9973:

    # inkognito_m "О, все таки очнулся. А мы уже хотели звать доктора."
    inkognito_m "哦，你终于醒了。我们正打算去叫医生呢。"

# game/a6/4prison.rpy:21
translate english prison_08446af7:

    # me "Что происходит?"
    me "发生了什么？"

# game/a6/4prison.rpy:22
translate english prison_573c3b1e:

    # inkognito_m "А ты не догадываешься?"
    inkognito_m "你还猜不到吗？"

# game/a6/4prison.rpy:23
translate english prison_87e587e1:

    # me "Догадываюсь. Просто не совсем понимаю, [cass], что, собирается меня ЗДЕСЬ держать? И как долго? И для чего?"
    me "猜到了。只是不太明白，[cass]，打算把我关在这儿？关多久？目的是什么？"

# game/a6/4prison.rpy:24
translate english prison_214c5f5b:

    # inkognito_m "Она скоро придет. У нее и спросишь."
    inkognito_m "她很快就来。你亲自问她吧。"

# game/a6/4prison.rpy:25
translate english prison_98056477:

    # me "А ты кто? Я тебя ни разу раньше в замке не видел. Как тебя зовут?"
    me "你是谁？我以前从没在城堡里见过你。你叫什么名字？"

# game/a6/4prison.rpy:26
translate english prison_d04ef49a:

    # norman "Норман. Сразу проясню ситуацию. Я не стану тебе помогать сбежать, чтобы ты не предложил. Да и разговаривать я с тобой не буду. Я здесь только чтобы тебя охранять."
    norman "诺曼。先把话说清楚。我不会帮你逃跑的，无论你许诺什么。我也不会跟你多说话。我在这儿只是为了看守你。"

# game/a6/4prison.rpy:27
translate english prison_8f10c1fd:

    # me "Тебе то самому скучно не станет? Может я тут на всю жизнь."
    me "你自己不会觉得无聊吗？说不定我得在这儿待一辈子。"

# game/a6/4prison.rpy:28
translate english prison_76f5ba9d:

    # norman "..."
    norman "..."

# game/a6/4prison.rpy:29
translate english prison_77c5ec61:

    # me "Я вроде ничего секретного у тебя не выпытываю."
    me "我好像没在套你什么机密话。"

# game/a6/4prison.rpy:30
translate english prison_76f5ba9d_1:

    # norman "..."
    norman "..."

# game/a6/4prison.rpy:32
translate english prison_325643a5:

    # me "{i}Вот же...дерьмовая ситуация. Еще и башка болит...{/i}"
    me "{i}真是……糟糕透顶的情况。头还疼着……{/i}"

# game/a6/4prison.rpy:33
translate english prison_c90d1a09:

    # me "{i}Зачем [cass] все это затеяла.{/i}"
    me "{i}[cass]策划这一切是为了什么。{/i}"

# game/a6/4prison.rpy:34
translate english prison_eacc5956:

    # me "{i}Ну...то есть понятно зачем. Но с чего она решила, что если арестует всю семью ей просто так отдадут корону?{/i}"
    me "{i}嗯……她的目的倒是很明显。但她凭什么认为，只要逮捕了全家，王冠就会轻易落到她手上？{/i}"

# game/a6/4prison.rpy:35
translate english prison_da910e7c:

    # me "{i}Знаменосцы отца точно поднимут знамена.{/i}"
    me "{i}父亲的封臣们肯定会高举义旗。{/i}"

# game/a6/4prison.rpy:36
translate english prison_9793368c:

    # me "{i}Это какое-то самоубийство.{/i}"
    me "{i}这简直就是自杀行为。{/i}"

# game/a6/4prison.rpy:38
translate english prison_450de9d6:

    # me "{i}Неужели она этого не понимает?{/i}"
    me "{i}难道她不明白这一点吗？{/i}"

# game/a6/4prison.rpy:39
translate english prison_9e384d15:

    # me "{i}Или это я чего-то не понимаю?{/i}"
    me "{i}还是说，是我不明白什么？{/i}"

# game/a6/4prison.rpy:40
translate english prison_9c4e6c29:

    # me "{i}Где вся королевская стража?{/i}"
    me "{i}皇家卫队都去哪儿了？{/i}"

# game/a6/4prison.rpy:41
translate english prison_9b863a4d:

    # me "{i}Не могут же они все быть с ней заодно?{/i}"
    me "{i}他们不可能全都和她串通一气吧？{/i}"

# game/a6/4prison.rpy:42
translate english prison_94d06558:

    # me "{i}Но в таком случае они бы уже сюда давно ворвались.{/i}"
    me "{i}但要是那样的话，他们早就该冲进这里了。{/i}"

# game/a6/4prison.rpy:44
translate english prison_ca5ba103:

    # me "{i}А может и нет...сколько вообще я спал? Час? День? Неделю?{/i}"
    me "{i}也许不会……我到底睡了多久？一小时？一天？一周？{/i}"

# game/a6/4prison.rpy:45
translate english prison_7c3839a8:

    # me "{i}Может я и моя мать вообще единственные арестованные.{/i}"
    me "{i}说不定我和我母亲是唯二被逮捕的人。{/i}"

# game/a6/4prison.rpy:46
translate english prison_5b820dcc:

    # me "{i}Нет. Тогда бы я не слышал стоны этих бедолаг в соседних камерах.{/i}"
    me "{i}不对。否则我不会听到隔壁牢房里那些可怜人的呻吟声。{/i}"

# game/a6/4prison.rpy:47
translate english prison_767403c1:

    # me "{i}Это место точно было еще недавно заброшено, а теперь переполненно теми...{/i}"
    me "{i}这地方不久前明明还空置着，现在却塞满了……{/i}"

# game/a6/4prison.rpy:48
translate english prison_4bc1bb39:

    # me "{i}Кем? Кто не поддержал переворот [cass]? Или теми кто может быть для нее опасен?{/i}"
    me "{i}塞满了谁？那些没有支持[cass]政变的人？还是那些对她构成威胁的人？{/i}"

# game/a6/4prison.rpy:49
translate english prison_de0d2be1:

    # cass "Привет, брат."
    cass "你好啊，弟弟。"

# game/a6/4prison.rpy:51
translate english prison_2c07e16d:

    # me "[cass]! Что это херня? Что ты устроила?"
    me "[cass]！这他妈是怎么回事？你都干了些什么？"

# game/a6/4prison.rpy:52
translate english prison_475059b6:

    # cass "Ты злишься. Понимаю. Позволь мне все обьяснить."
    cass "你生气了。我理解。让我解释一切。"

# game/a6/4prison.rpy:53
translate english prison_0683843f:

    # me "Я тебя слушаю."
    me "我听着呢。"

# game/a6/4prison.rpy:54
translate english prison_19662538:

    # cass "То что здесь происходит - это небольшая предосторожность. Видишь ли, мне нужно отсеять всех тех, кто является предателями короны. Мои методы слегка жестоки, но на кону судьба державы."
    cass "这里发生的一切，只是一个小小的预防措施。你看，我需要筛除所有背叛王冠的逆贼。我的手段或许有点残酷，但这关系到王国的命运。"

# game/a6/4prison.rpy:55
translate english prison_3061e12e:

    # me "Но ведь это ты самая большая предательница короны."
    me "但你才是那个背叛王冠的最大逆贼。"

# game/a6/4prison.rpy:56
translate english prison_2b61dbd8:

    # cass "Я? Я всех нас спасаю."
    cass "我？我是在拯救我们所有人。"

# game/a6/4prison.rpy:57
translate english prison_e03f06c0:

    # me "От кого?"
    me "拯救我们免于谁的毒手？"

# game/a6/4prison.rpy:58
translate english prison_3ae69eff:

    # cass "От дегенерата, что одел корону своего отца и гниет под ней уже двадцать лет. И все бы ничего, сгнил бы и все. Но его язвы расползаются по всему королевству."
    cass "免于那个头戴父王冠冕、在其下腐朽了二十年的败类。本来也没什么，烂掉就烂掉了。但他的毒疮正在蔓延至整个王国。"

# game/a6/4prison.rpy:59
translate english prison_e1312f01:

    # cass "Так что я не предатель."
    cass "所以我不是叛徒。"

# game/a6/4prison.rpy:60
translate english prison_8700819a:

    # me "А кто ты?"
    me "那你是什么？"

# game/a6/4prison.rpy:61
translate english prison_ab99b695:

    # cass "Я доктор. Это одна из основ врачевания - если плоть гниет, надо ее вырезать, иначе все тело погибнет."
    cass "我是医生。这是治愈术的基本原则之一——如果机肉腐烂，就必须切除，否则全身都会死去。"

# game/a6/4prison.rpy:62
translate english prison_db85e217:

    # me "И что же...ты вырезала плоть? Ты убила нашего отца?"
    me "所以……你切除了腐肉？你杀了我们的父亲？"

# game/a6/4prison.rpy:63
translate english prison_df9f8abd:

    # cass "Ну что ты. Это же было бы преступлением. Его отравил неизвестный злодей. Я как раз его ищу."
    cass "怎么会。那是犯罪。他是被一个身份不明的恶徒毒死的。我正好在追查他。"

# game/a6/4prison.rpy:64
translate english prison_bedb7c85:

    # me "Это злодей отравил и нас с мамой, да?"
    me "那毒害我和妈妈的也是这个恶徒，对吗？"

# game/a6/4prison.rpy:65
translate english prison_5293b466:

    # cass "Нет. Это сделала я. Только я вас не травила, а усыпила. Скажи мне спасибо, я сделала это чтобы никто не пострадал."
    cass "不。那是我做的。不过我没有给你们下毒，只是用了安眠药。你该谢谢我，我这么做是为了避免有人受伤。"

# game/a6/4prison.rpy:67
translate english prison_7aa5924f:

    # me "Ладно...избавь меня от этого спектакля. Если я еще жив, значит тебе от меня что-то нужно."
    me "够了……别在我面前演戏了。我还活着，就意味着我对你还有利用价值。"

# game/a6/4prison.rpy:68
translate english prison_76fe99f4:

    # cass "Ну что, братик. Я бы никогда не стала убивать невиновного."
    cass "说什么呢，弟弟。我绝不会杀害无辜的人。"

# game/a6/4prison.rpy:69
translate english prison_49852d82:

    # me "Просто скажи."
    me "直说吧。"

# game/a6/4prison.rpy:70
translate english prison_651ccc28:

    # cass "..."
    cass "..."

# game/a6/4prison.rpy:71
translate english prison_64898afd:

    # cass "Ладно. Теперь когда старик...не в состоянии управлять государством, мне нужно чтобы ты его возглавил."
    cass "好吧。既然老头子……已经无力治理国家，我需要你来接管。"

# game/a6/4prison.rpy:72
translate english prison_ddadf324:

    # me "Как твоя марионетка? Чтобы лорды отца не отрубили тебе голову?"
    me "做你的傀儡吗？好让你不被父亲的领主们砍掉脑袋？"

# game/a6/4prison.rpy:73
translate english prison_1c5764cc:

    # cass "Как наследник трона. Королевство в кризисе. Но мы можем ему помочь. Ты и я. Стань регентом и вернем величие Золотому Королевству...нет...Золотой Империи."
    cass "作为王位继承人。王国正处危机之中。但我们可以挽救它。你和我。成为摄政王，让我们一起恢复黄金王国的荣光……不……是黄金帝国的荣光。"

# game/a6/4prison.rpy:74
translate english prison_56262720:

    # me "Пожалуй я откажусь."
    me "我拒绝。"

# game/a6/4prison.rpy:75
translate english prison_2d4c28aa:

    # cass "Ладно. Я ожидала такой...несговорчивости. Сейчас я вернусь с более весомыми аргументами."
    cass "好吧。我预料到你会这么……不合作。我马上回来，带着更有分量的筹码。"

# game/a6/4prison.rpy:77
translate english prison_3c9211a0:

    # me "Вот сука..."
    me "这个贱人……"

# game/a6/4prison.rpy:78
translate english prison_b2658852:

    # inkognito_m "Эй! Не соглашайся, [mename]."
    inkognito_m "嘿！[mename]，别答应她。"

# game/a6/4prison.rpy:79
translate english prison_e569e0df:

    # me "А? Кто ты?"
    me "嗯？你是谁？"

# game/a6/4prison.rpy:80
translate english prison_6c5de4f5:

    # leo "Я Лео. Я сын лорда Арании. Это самый большой знаменосец твоего отца."
    leo "我是莱奥。阿拉尼亚领主的儿子。他是你父亲最强大的封臣。"

# game/a6/4prison.rpy:81
translate english prison_cdf15f66:

    # me "Я знаю кто это. Я бы рад сопротивляьтся, но боюсь у нее большое пространство для шантажа. Все мои близкие у нее."
    me "我知道他是谁。我也很想反抗，但我怕她手里有太多把柄可以要挟我。我所有亲近的人都在她手上。"

# game/a6/4prison.rpy:82
translate english prison_cce4c47d:

    # leo "Не все. Твоя сестра сбежала."
    leo "不是全部。你的姐姐逃走了。"

# game/a6/4prison.rpy:83
translate english prison_b7e20278:

    # me "[elin]? "
    me "[elin]?"

# game/a6/4prison.rpy:84
translate english prison_12d3e2bc:

    # leo "Да. Я слышал как стражники переговариваются. Кажется она использовала магию."
    leo "对。我听到守卫们在交谈。她好像使用了魔法。"

# game/a6/4prison.rpy:85
translate english prison_d551d4f5:

    # me "Это не многое меняет..."
    me "这改变不了多少……"

# game/a6/4prison.rpy:86
translate english prison_727c0b02:

    # leo "Многое. Это значит, что как минимум один наследник твоего отца на свободе. Это вопрос времени, когда она встретит моего отца. А он, я уверен, уже собирает знамена."
    leo "改变很大。这意味着至少有一位你父亲的继承人身处自由。她遇到我父亲只是时间问题。而我确信，我父亲一定正在召集军队。"

# game/a6/4prison.rpy:87
translate english prison_329b5755:

    # leo "И твоя жена."
    leo "还有你的妻子。"

# game/a6/4prison.rpy:88
translate english prison_b841b530:

    # me "Тоже сбежала."
    me "也逃走了。"

# game/a6/4prison.rpy:90
translate english prison_d83e491a:

    # leo "Нет, но [cassa] боится ее арестовывать, наверное думает, что тогда Север придет за ней."
    leo "不，但[cassa]不敢逮捕她，可能觉得那样的话整个北方都会为她而来。"

# game/a6/4prison.rpy:92
translate english prison_9b5fcede:

    # leo "Нет, но [cassa] боится ее арестовывать, у Гарпий Красных гор плохая репутация."
    leo "不，但[cassa]不敢逮捕她，红山女妖的名声太坏了。"

# game/a6/4prison.rpy:93
translate english prison_86af2306:

    # me "У нее все еще моя мать, отец и младшая сестра."
    me "她手里还有我母亲、父亲和小妹妹。"

# game/a6/4prison.rpy:94
translate english prison_26cc00d7:

    # leo "Понимаю. Но ей нет смысла их убивать, если она рассчитывает сохранить голову."
    leo "我明白。但若是她还想保住脑袋，杀了他们对她毫无意义。"

# game/a6/4prison.rpy:95
translate english prison_32120857:

    # me "Ты плохо знаешь мою сестру, она вполне может на это не рассчитывать."
    me "你太不了解我姐姐了，她很可能根本不在乎保不保得住脑袋。"

# game/a6/4prison.rpy:97
translate english prison_599ca2ae:

    # norman "А ну заткнулись."
    norman "都给我闭嘴。"

# game/a6/4prison.rpy:98
translate english prison_031db8e2:

    # leo "О, рыцарь священного молчания вернулся."
    leo "哦，那位神圣沉默骑士回来了。"

# game/a6/4prison.rpy:99
translate english prison_6182c455:

    # norman "Я сказал закрой рот."
    norman "我叫你闭上嘴。"

# game/a6/4prison.rpy:100
translate english prison_ef5e7d01:

    # leo "Когда я выйду на свободу ты будешь мои сапоги чистить своим языком."
    leo "等我重获自由，你得用舌头把我的靴子舔干净。"

# game/a6/4prison.rpy:101
translate english prison_cfb99564:

    # norman "Если не заткнешься, на свободе будут только твои кишки."
    norman "再不闭嘴，重获自由的只会是你的肠子。"

# game/a6/4prison.rpy:102
