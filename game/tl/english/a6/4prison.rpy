    cass "{size=+8}立刻释放摄政王及王位继承人！{/size}"

# game/a6/4prison.rpy:144
translate english prison_42385a1a:

    # cass "Какой-то злодей запер тебя в подземелье. Надеюсь ты благодарен мне за спасение."
