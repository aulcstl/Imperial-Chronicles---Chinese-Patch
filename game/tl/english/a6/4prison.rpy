    # randolph "Агрх!"
    randolph "呃啊！"

# game/a6/4prison.rpy:216
translate english prison2_61f055a5:

    # ludwig "Не шуми, [mename]."
    ludwig "别出声，[mename]。"

# game/a6/4prison.rpy:217
