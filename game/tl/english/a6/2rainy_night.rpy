# TODO: Translation updated at 2024-09-27 22:09

# game/a6/2rainy_night.rpy:3
translate english rainy_night_32c4df8d:

    # "Этой же ночью."
    "Later that night."

# game/a6/2rainy_night.rpy:4
translate english rainy_night_93638b14:

    # me "Обязательно делать это именно сейчас?"
    me "非得现在就做这件事吗？"

# game/a6/2rainy_night.rpy:5
translate english rainy_night_866cc22d:

    # cass "Да. Чем раньше, тем лучше."
    cass "是的。越早越好。"

# game/a6/2rainy_night.rpy:6
translate english rainy_night_5ac38cf1:

    # me "Почему?"
    me "为什么？"

# game/a6/2rainy_night.rpy:7
translate english rainy_night_1abfaf18:

    # cass "Мы должны все сделать, пока во дворце еще много гостей твоей свадьбы."
    cass "我们必须趁你婚礼的宾客还大量留在宫中时，把一切都办妥。"

# game/a6/2rainy_night.rpy:8
translate english rainy_night_2e7f628e:

    # me "Не понял..."
    me "我不明白……"

# game/a6/2rainy_night.rpy:9
translate english rainy_night_1322eb89:

    # cass "Ты все понял."
    cass "你明白得很。"

# game/a6/2rainy_night.rpy:11
translate english rainy_night_25a51bce:

    # me "Ты хочешь сделать их заложниками?"
    me "你是想把他们都扣作人质吗？"

# game/a6/2rainy_night.rpy:12
translate english rainy_night_87a98e16:

    # cass "Ты осуждаешь мои методы? Считаешь можно совершить переворот не замарав руки?"
    cass "你在指责我的手段吗？你觉得可以不弄脏双手就完成一场政变吗？"

# game/a6/2rainy_night.rpy:13
translate english rainy_night_4a0cc9eb:

    # me "Дело не в этом, это может вызвать обратный эффект, лордам точно не понравится видеть своих детей в качестве наших заложников."
    me "我不是这个意思。这可能会适得其反，领主们肯定不会乐意看见自己的子女被我们扣作人质。"

# game/a6/2rainy_night.rpy:14
translate english rainy_night_0b6ccb1c:

    # cass "Я все продумала. Те лорды, что выскажут тебе лояльность, как регенту, получат своих детей и других близких обратно."
    cass "我全都考虑过了。那些宣誓效忠于你、拥戴你为摄政王的领主，将会领回他们的子女和其他亲属。"

# game/a6/2rainy_night.rpy:15
translate english rainy_night_2c8c5da3:

    # me "Но сам факт удержания их в заложниках..."
    me "但将人扣作人质这件事本身……"

# game/a6/2rainy_night.rpy:16
translate english rainy_night_1d644987:

    # cass "Мы ищем преступника, отравившего нашего отца, мы будем вынуждены идти на некоторые...жестокие меры."
    cass "我们正在追捕毒害我们父王的凶手，为此，我们不得不采取一些……残酷的手段。"

# game/a6/2rainy_night.rpy:17
translate english rainy_night_8d83fdc6:

    # me "Мы отравим отца?"
    me "我们要毒害父王？"

# game/a6/2rainy_night.rpy:18
translate english rainy_night_a869d0f5:

    # cass "Я этого не говорила."
    cass "我可没这么说。"

# game/a6/2rainy_night.rpy:20
translate english rainy_night_aaccf5e8:

    # me "Ты это сказала."
    me "你就是这个意思。"

# game/a6/2rainy_night.rpy:21
translate english rainy_night_5d4d04f7:

    # cass "Я сказала, что мы будем искать преступника, сделавшего это. Наше прямое участие будет слишком большим фактором риска."
    cass "我说的是，我们要追捕干下这件事的凶手。由我们直接参与，风险因素太大了。"

# game/a6/2rainy_night.rpy:22
translate english rainy_night_a3ddec5c:

    # me "И что же...это сделает кто-то другой?"
    me "那么……这事将由别人来做？"

# game/a6/2rainy_night.rpy:23
translate english rainy_night_d4fe5ec7:

    # cass "Сделает? Это уже сделано."
    cass "来做？已经做完了。"

# game/a6/2rainy_night.rpy:24
translate english rainy_night_2365e384:

    # me "Погоди...отец уже отравлен?"
    me "等等……父王已经被毒害了？"

# game/a6/2rainy_night.rpy:25
translate english rainy_night_f8b2d00f:

    # cass "Ты не о том думаешь, [mename]. Прямо сейчас нам нужно попасть в этот особняк, а ты отвлекаешь меня пустыми разговорами от слежки за маршрутами стражи."
    cass "这不是你该操心的事，[mename]。眼下我们需要潜入这栋宅邸，你却用这些无聊的谈话，来分散我监视卫兵巡逻路线的注意力。"

# game/a6/2rainy_night.rpy:26
translate english rainy_night_3820771a:

    # me "..."
    me "..."

# game/a6/2rainy_night.rpy:28
translate english rainy_night_23eb5e06:

    # cass "Вот этот, молодой, кажется обдумывает стоит ли ему мокнуть на дожде или переждать его внутри."
    cass "快看那个，年轻的，似乎在犹豫要不要淋雨，还是进去躲雨。"

# game/a6/2rainy_night.rpy:29
translate english rainy_night_454011e4:

    # cass "Будь готов, если он все же оставит пост - это будет наш шанс."
    cass "做好准备，要是他最终离开岗位——那将是我们的机会。"

# game/a6/2rainy_night.rpy:30
translate english rainy_night_308bbb6a:

    # me "Он все еще думает."
    me "他还在犹豫。"

# game/a6/2rainy_night.rpy:31
translate english rainy_night_b29dd0a4:

    # cass "Его чувство долга борется со здравым смыслом."
    cass "他的责任感和理智正在激烈斗争。"

# game/a6/2rainy_night.rpy:32
translate english rainy_night_570a5312:

    # me "Ага. Наверное уговаривает сам себя. Все дни до этого ничего не происходило. Почему должно произойти что-то сегодня?"
    me "是啊。大概在说服自己吧。这之前那么些天都平安无事。凭什么今天就一定会出事儿呢？"

# game/a6/2rainy_night.rpy:33
translate english rainy_night_33448236:

    # cass "Зачем ему мокнуть под дождем, если его усилий даже никто не заметит?"
    cass "反正他的努力也没人会注意到，何必淋雨呢？"

# game/a6/2rainy_night.rpy:34
translate english rainy_night_de61bdea:

    # me "Ну давай...иди в дом. Иди в теплый и сухой дом..."
    me "快啊……进屋去吧。去那又暖和又干爽的屋子里……"

# game/a6/2rainy_night.rpy:35
translate english rainy_night_3f69afe9:

    # cass "Если этот сукин сын так и будет стоять в нерешительности, я его убью..."
    cass "这狗娘养的要是再这么犹豫不决地站下去，我就杀了他……"

# game/a6/2rainy_night.rpy:36
translate english rainy_night_041a9203:

    # cass "Дай ему еще минуту подумать. Лучше обойтись без крови."
    cass "再给他一分钟考虑。最好不要见血。"

# game/a6/2rainy_night.rpy:38
translate english rainy_night_17b1607c:

    # arc_son "Когда отец вернется с Востока?"
    arc_son "父王什么时候从东方回来？"

# game/a6/2rainy_night.rpy:39
translate english rainy_night_4991ef4c:

    # arcadia "..."
    arcadia "..."

# game/a6/2rainy_night.rpy:40
translate english rainy_night_85d6a2c3:

    # arc_son "Он обещал, что не пробудет там долго. Сказал вернется меньше, чем за год."
    arc_son "他保证过不会在那里逗留太久。他说一年之内就会回来。"

# game/a6/2rainy_night.rpy:41
translate english rainy_night_4991ef4c_1:

    # arcadia "..."
    arcadia "..."

# game/a6/2rainy_night.rpy:42
translate english rainy_night_91ea26cb:

    # arc_son "Мам... Когда?"
    arc_son "妈……到底什么时候？"

# game/a6/2rainy_night.rpy:43
translate english rainy_night_464d05d7:

    # arcadia "Я не знаю. Ты каждый вечер у меня это спрашиваешь и каждый вечер я отвечаю, что не знаю, этого никто не знает."
    arcadia "我不知道。你每晚都这么问我，我也每晚都回答你，我不知道，没人知道。"

# game/a6/2rainy_night.rpy:44
translate english rainy_night_2c7a2cfe:

    # arc_son "Он же обещал!"
    arc_son "可他明明答应了啊！"

# game/a6/2rainy_night.rpy:46
translate english rainy_night_2ff79e50:

    # arcadia "Твоя нетерпеливость не наполнит паруса ветром. Если он задерживается, значит таковы обстоятельства. Вместо того чтобы унывать и заражать своим унынием меня, принеси еще вина."
    arcadia "你的急躁可没法鼓起船帆的风。既然他耽搁了，就说明情况如此。与其消沉并把你的沮丧传染给我，不如再去拿点酒来。"

# game/a6/2rainy_night.rpy:47
translate english rainy_night_63a73b7e:

    # arc_son "Мам, тебе уже хватит пить."
    arc_son "妈，你已经喝得够多了。"

# game/a6/2rainy_night.rpy:48
translate english rainy_night_b7a22341:

    # arcadia "С чего это вдруг? Я сегодня осушила всего пару бокалов."
    arcadia "怎么突然这么说？我今天总共才喝了两杯。"

# game/a6/2rainy_night.rpy:49
translate english rainy_night_1a8a7b8c:

    # arc_son "Мгм... конечно. {size=-8}Поэтому ты и не думаешь об отце.{/size}"
    arc_son "嗯哼……当然。{size=-8}难怪你都不惦记父亲。{/size}"

# game/a6/2rainy_night.rpy:50
translate english rainy_night_5ceb7a25:

    # arcadia "Что?"
    arcadia "什么？"

# game/a6/2rainy_night.rpy:51
translate english rainy_night_b9abd7e1:

    # arc_son "Ничего. Сейчас принесу."
    arc_son "没什么。我这就去拿。"

# game/a6/2rainy_night.rpy:53
translate english rainy_night_fc56c9f6:

    # me "А нам принесешь?"
    me "能给我们也拿点来吗？"

# game/a6/2rainy_night.rpy:54
translate english rainy_night_ea9918fe:

    # arc_son "Кто вы? Я...."
    arc_son "你们是什么人？我……"

# game/a6/2rainy_night.rpy:55
translate english rainy_night_7a6e71e8:

    # cass "Тсс.... Мы пришли к твоей матери. Не шуми."
    cass "嘘……我们是来找你母亲的。别嚷嚷。"

# game/a6/2rainy_night.rpy:56
translate english rainy_night_cfd1ee8b:

    # arc_son "Зачем?"
    arc_son "找我母亲做什么？"

# game/a6/2rainy_night.rpy:57
translate english rainy_night_093b6929:

    # me "Это сюрприз. Ты же не хочешь его испортить."
    me "是个惊喜。你总不想破坏这份惊喜吧。"

# game/a6/2rainy_night.rpy:58
translate english rainy_night_a8e21eff:

    # arc_son "С...Сюрприз..."
    arc_son "惊……惊喜……"

# game/a6/2rainy_night.rpy:59
translate english rainy_night_0555364b:

    # cass "Ну конечно. Она уже давно хотела с нами повидаться. Но у нее никак не получалось."
    cass "那当然了。她很久以前就想见我们了。可她一直抽不出身。"

# game/a6/2rainy_night.rpy:60
translate english rainy_night_5a61ad3c:

    # me "И мы, как хорошие друзья, решили устроить ей сюрприз и навестить ее сами."
    me "于是我们，身为她的好朋友，决定给她个惊喜，亲自登门看望她。"

# game/a6/2rainy_night.rpy:62
translate english rainy_night_2d917598:

    # arcadia "Кто...Что вы тут делаете?"
    arcadia "谁……你们在这里干什么？"

# game/a6/2rainy_night.rpy:63
translate english rainy_night_42cae299:

    # arc_son "Мам, это не твои друзья?"
    arc_son "妈，他们不是你的朋友吗？"

# game/a6/2rainy_night.rpy:64
translate english rainy_night_16c1427a:

    # me "Мы не совсем друзья, скорее коллеги."
    me "我们算不上朋友，更像是同僚。"

# game/a6/2rainy_night.rpy:65
translate english rainy_night_6756be9b:

    # cass "Главное не шуми, охрана здесь любит теплоту и сон, но даже они могут сбежаться на...ненужные этому разговору крики."
    cass "关键是别嚷嚷。这里的卫兵喜欢暖和和睡觉，但就算他们，听到……不必要的叫喊声，也可能聚过来。"

# game/a6/2rainy_night.rpy:66
translate english rainy_night_a0b4d82d:

    # arcadia "Я...вы....что вам надо?"
    arcadia "我……你们……你们想干什么？"

# game/a6/2rainy_night.rpy:67
translate english rainy_night_1b5552a3:

    # me "Мы пришли поговорить."
    me "我们是来谈谈的。"

# game/a6/2rainy_night.rpy:68
translate english rainy_night_9cb5d7d6:

    # cass "Прости, что без приглашения. Но тема срочная."
    cass "抱歉我们不清自来。但事情紧急。"

# game/a6/2rainy_night.rpy:70
translate english rainy_night_9c2fdf89:

    # arcadia "Что случилось?"
    arcadia "发生了什么事？"

# game/a6/2rainy_night.rpy:71
translate english rainy_night_ce46a25d:

    # me "На короля было совершено покушение."
    me "国王陛下遭遇了刺杀。"

# game/a6/2rainy_night.rpy:72
translate english rainy_night_865b6623:

    # cass "Верно. Неизвестный злодей отравил его."
    cass "没错。有某个身份不明的恶贼毒害了他。"

# game/a6/2rainy_night.rpy:73
translate english rainy_night_25f8286a:

    # arcadia "Что? Когда?"
    arcadia "什么？什么时候的事？"

# game/a6/2rainy_night.rpy:74
translate english rainy_night_1d7dba0c:

    # me "Недавно."
    me "不久前。"

# game/a6/2rainy_night.rpy:75
translate english rainy_night_5729b12f:

    # cass "Пару часов назад."
    cass "就在几小时前。"

# game/a6/2rainy_night.rpy:76
translate english rainy_night_1e9823ae:

    # arcadia "Кто это был? Зачем?"
    arcadia "是谁干的？为什么要这么做？"

# game/a6/2rainy_night.rpy:77
translate english rainy_night_f00a76ea:

    # me "Мы хотим это узнать. И медлить нельзя!"
    me "我们正想查清此事。而且刻不容缓！"

# game/a6/2rainy_night.rpy:78
translate english rainy_night_a548bd22:

    # cass "Верно. Для того чтобы наказать подлеца и не дать ему, и его сообщникам воспользоваться нестабильностью в королевстве, мы должны наделить регента особыми полномочиями."
    cass "没错。为了惩治这个恶棍，并阻止他及其党羽利用王国目前的动荡局面，我们必须授予摄政王临机专断之权。"

# game/a6/2rainy_night.rpy:80
translate english rainy_night_9b5ea551:

    # arcadia "Регента?"
    arcadia "摄政王？"

# game/a6/2rainy_night.rpy:81
translate english rainy_night_75ae62b9:

    # me "Это я."
    me "就是我。"

# game/a6/2rainy_night.rpy:82
translate english rainy_night_f90570fb:

    # me "Более того, есть предположения, что кто-то из совета может быть причастен к этому чудовищному преступлению. А значит его полномочия должны быть переданы доверенному лицу регента."
    me "而且，我们有理由怀疑，议会中或许有人参与了这个骇人听闻的罪行。因此，议会的权力必须移交给摄政王信赖的人。"

# game/a6/2rainy_night.rpy:83
translate english rainy_night_fc3e97ad:

    # cass "Это я."
    cass "就是我。"

# game/a6/2rainy_night.rpy:84
translate english rainy_night_aac11591:

    # arcadia "Это...это переворот. Вы хотите сложить полномочия совета и передать королевскую власть регенту? Кто его назначит регентом, если совет будет нефункционален?"
    arcadia "这……这是政变。你们想架空议会，把王权交给摄政王？如果议会无法行使职权，又有谁会任命他为摄政王？"

# game/a6/2rainy_night.rpy:85
translate english rainy_night_c9e21a7e:

    # me "Совет будет функционален до тех пор, пока не изберет меня регентом. А после он добровольно передаст полномочия моему носителю семи колец."
    me "在选我担任摄政王之前，议会会一直履行职权。选举结束后，议会将自愿把权力移交给我指定的七戒使者。"

# game/a6/2rainy_night.rpy:86
translate english rainy_night_ad440d20:

    # cass "Звучит конечно пугающе..."
    cass "听起来当然很可怕……"

# game/a6/2rainy_night.rpy:87
translate english rainy_night_4f1c9c1b:

    # arcadia "Звучит как узурпация власти, еще до того, как станет известно, кто отравил короля!"
    arcadia "听起来完全就是在尚未查明究竟是谁毒害了国王之前，赤裸裸地篡权！"

# game/a6/2rainy_night.rpy:88
translate english rainy_night_27a31ae8:

    # me "У вас есть предополжения кто это мог сделать?"
    me "您对下毒者是谁有猜测吗？"

# game/a6/2rainy_night.rpy:89
translate english rainy_night_71336ce5:

    # arcadia "Есть."
    arcadia "有。"

# game/a6/2rainy_night.rpy:90
translate english rainy_night_36e566d0:

    # me "Озвучьте их."
    me "不妨说来听听。"

# game/a6/2rainy_night.rpy:91
translate english rainy_night_90e6bc4a:

    # cass "Только осторожнее. Помните, что неосторожно брошенные слова в таких обстоятельствах могут стоить даже жизни многим невинным."
    cass "但请当心。记住，在这般局势下，不慎说出口的话，会让许多无辜者付出生命代价。"

# game/a6/2rainy_night.rpy:92
translate english rainy_night_ce930656:

    # arcadia "Вы...да как вы смеете...это шантаж!"
    arcadia "你们……你们怎么敢……这是勒索！"

# game/a6/2rainy_night.rpy:95
translate english rainy_night_7ca4cec1:

    # arcadia "[mename]! На самом первом заседании совета ты пообещал, что не дашь ей узурпировать власть! Ты солгал!"
    arcadia "[mename]！在第一次议会会议上，你曾许诺，不会让她篡夺权力！你撒了谎！"

# game/a6/2rainy_night.rpy:96
translate english rainy_night_4103e97c:

    # me "Это называется политика. Неужели за столько лет в совете вы не научились не верить людям на слово?"
    me "这就叫政治。您在议会待了这么多年，难道还没学会别轻信别人的口头承诺吗？"

# game/a6/2rainy_night.rpy:97
translate english rainy_night_21ddd238:

    # arcadia "Это работает в обе стороны, ты поймешь это, когда ты сам будешь вынужден доверять только чужому слову!"
    arcadia "这话对你们也一样有效。等到你自己也不得不轻信一面之辞的那天，你就会明白了！"

# game/a6/2rainy_night.rpy:98
translate english rainy_night_2bba9ba1:

    # me "ну что вы, Аркадия, я никогда не поставлю себя в такие условия."
    me "瞧您说的，阿尔卡季娅，我绝不会让自己落到那步田地。"

# game/a6/2rainy_night.rpy:99
translate english rainy_night_a9caa6f7:

    # arcadia "Ты уже в них, просто этого не понимаешь."
    arcadia "你已经身在其中了，只是你还没意识到。"

# game/a6/2rainy_night.rpy:101
translate english rainy_night_38c30ea9:

    # cass "Ну хватит. У нас не так много времени. Я хочу услышать ответ - вы поможете королевству или считать вас предателем?"
    cass "够了。我们时间不多。我想听到答复——您是打算帮助这个王国，还是我们该视您为叛徒？"

# game/a6/2rainy_night.rpy:102
translate english rainy_night_53636a64:

    # arcadia "Я...я...."
    arcadia "我……我……"

# game/a6/2rainy_night.rpy:103
translate english rainy_night_53f18c7f:

    # arc_son "Мам, не надо..."
    arc_son "妈，别这样……"

# game/a6/2rainy_night.rpy:104
translate english rainy_night_5f853f3e:

    # me "Тише, мальчик, она делает это на благо не только королевства, но и тебя."
    me "安静，小子，她这么做不仅是为了王国，也是为了你。"

# game/a6/2rainy_night.rpy:105
translate english rainy_night_1226a374:

    # cass "Верно."
    cass "正是。"

# game/a6/2rainy_night.rpy:106
translate english rainy_night_50e06ff0:

    # arcadia "Кто еще вас поддерживает?"
    arcadia "还有谁支持你们？"

# game/a6/2rainy_night.rpy:107
translate english rainy_night_ae4f825c:

    # cass "Ну уже нет. Настоящий верноподданный короны не станет задавать такие вопросы."
    cass "这就不必问了。真正的王国忠臣不会问这种问题。"

# game/a6/2rainy_night.rpy:108
translate english rainy_night_325ac959:

    # me "Да. Вы либо верны короне и поддержите мою власть, либо нет. И то, верны ли моей законной власти остальные для вас не должно иметь значения."
    me "没错。您要么忠于王国，支持我执掌大权；要么不忠。至于其他人是否忠于我的合法权力，这不该是您操心的事。"

# game/a6/2rainy_night.rpy:109
translate english rainy_night_41e00bb7:

    # cass "Не бойтесь, Аркадия, как только вы встанете на нашу сторону, и вы и ваши дети будут под нашей защитой..."
    cass "别怕，阿尔卡季娅，一旦你站在我们这边，你和你的孩子都将受我们保护……"

# game/a6/2rainy_night.rpy:111
translate english rainy_night_a775e0e6:

    # arc_son "НАЗАД! НАЗАД ИЛИ Я УБЬЮ ВАС!"
    arc_son "退后！退后，不然我杀了你们！"

# game/a6/2rainy_night.rpy:112
translate english rainy_night_60a77db8:

    # cass "Как ты...шустрый мальчишка. Умыкнул мой кинжал, а я не заметила, молодец."
    cass "好个……机灵的小鬼。偷了我的匕首，我竟然没察觉，有本事。"

# game/a6/2rainy_night.rpy:113
translate english rainy_night_6480acc4:

    # arc_son "УХОДИТЕ ИЗ НАШЕГО ДОМА!"
    arc_son "滚出我们家！"

# game/a6/2rainy_night.rpy:114
translate english rainy_night_540df7a7:

    # me "Успокойся, малец."
    me "冷静，小子。"

# game/a6/2rainy_night.rpy:115
translate english rainy_night_1b9a8c4c:

    # arcadia "Кайден, не надо!"
    arcadia "Kayden，别这样！"

# game/a6/2rainy_night.rpy:116
translate english rainy_night_3f564b4e:

    # arc_son "Я НЕ ПОЗВОЛЮ ШАНТАЖИРОВАТЬ МОЮ МАТЬ! УБИРАЙТЕСЬ ИЛИ Я ВАС УБЬЮ!"
    arc_son "我不许你们勒索我母亲！滚出去，不然我杀了你们！"

# game/a6/2rainy_night.rpy:117
translate english rainy_night_abf9de12:

    # cass "Правда? Ты сможешь это сделать?"
    cass "是吗？你做得到吗？"

# game/a6/2rainy_night.rpy:119
translate english rainy_night_459977cf:

    # arc_son "ПРАВДА! Я ВАС УБЬЮ!"
    arc_son "当然！我会杀了你们！"

# game/a6/2rainy_night.rpy:120
translate english rainy_night_e7c6692f:

    # cass "Ты сможешь убить другого человека? Ты сможешь убить меня? Сможешь проткнуть мое сердце этим острым кинжалом?"
    cass "你能下手杀别人？你能下手杀我？能用这把锋利的匕首刺穿我的心脏吗？"

# game/a6/2rainy_night.rpy:121
translate english rainy_night_b0617572:

    # arc_son "Я...смогу!"
    arc_son "我……我能！"

# game/a6/2rainy_night.rpy:122
translate english rainy_night_d4800589:

    # cass "Ты уверен в этом?"
    cass "你确定吗？"

# game/a6/2rainy_night.rpy:123
translate english rainy_night_badade6f:

    # arc_son "Да...я..уверен!"
    arc_son "是的……我……我确定！"

# game/a6/2rainy_night.rpy:124
translate english rainy_night_3e769b92:

    # cass "Ну что же...попробуй."
    cass "是吗……那就试试看。"

# game/a6/2rainy_night.rpy:126
translate english rainy_night_ccc47d20:

    # arcadia "Хватит."
    arcadia "够了。"

# game/a6/2rainy_night.rpy:127
translate english rainy_night_c2451da7:

    # arc_son "Мам!"
    arc_son "妈！"

# game/a6/2rainy_night.rpy:128
translate english rainy_night_381b2a8b:

    # arcadia "Я сделаю, что вы хотите. Я проголосую за передачу полномочий совета."
    arcadia "我答应你们的要求。我会投票赞成移交议会权力。"

# game/a6/2rainy_night.rpy:129
translate english rainy_night_58a5edf6:

    # cass "И за назначение моего брата регентом."
    cass "并任命我的兄长担任摄政王。"

# game/a6/2rainy_night.rpy:130
translate english rainy_night_49feb9aa:

    # arcadia "И за назначение регента."
    arcadia "并同意摄政王的任命。"

# game/a6/2rainy_night.rpy:131
translate english rainy_night_8e4c37ce:

    # cass "Отлично."
    cass "很好。"

# game/a6/2rainy_night.rpy:132
translate english rainy_night_7be1c886:

    # arcadia "Только прошу об одном...оставьте моих детей дома. Я пойду куда нужно. Я готова ночевать в подземелье, только не трогайте моих детей."
    arcadia "我只求一件事……让我的孩子留在家中。无论需要我去哪里，我都去。我愿意被关进地牢过夜，只求别动我的孩子。"

# game/a6/2rainy_night.rpy:133
translate english rainy_night_bb5c1bd4:

    # cass "Хорошо."
    cass "可以。"

# game/a6/2rainy_night.rpy:135
translate english rainy_night_f1f1405b:

    # me "[cass]!"
    me "[cass]!"

# game/a6/2rainy_night.rpy:136
translate english rainy_night_9325074b:

    # cass "Спокойно."
    cass "别紧张。"

# game/a6/2rainy_night.rpy:137
translate english rainy_night_f12642f7:

    # me "Она может резко передумать, если мы не будем уверены, что нам есть чем на нее надавить."
    me "她随时可能反悔，如果我们不确保手里有能拿捏她的把柄的话。"

# game/a6/2rainy_night.rpy:138
translate english rainy_night_3bef9cc4:

    # cass "Все нормально."
    cass "一切都在掌握之中。"

# game/a6/2rainy_night.rpy:139
translate english rainy_night_ece94be2:

    # me "Завтра ее дети могут плыть на корабле на Восток и мы..."
    me "明天她的孩子就能乘船前往东方，而我们……"

# game/a6/2rainy_night.rpy:140
translate english rainy_night_32dec249:

    # cass "Я бы насчет этого не переживала. И ты тоже...заткнись и не переживай."
    cass "我才不担心这个。你也……闭嘴，别瞎操心。"

# game/a6/2rainy_night.rpy:142
translate english rainy_night_e01dc55b:

    # "Несколько минут спустя."
    "几分钟以后。"

# game/a6/2rainy_night.rpy:143
translate english rainy_night_4f5aeadb:

    # me "{size=-7}Это ошибка, [cass].{/size}"
    me "{size=-7}这是个错误，[cass]。{/size}"

# game/a6/2rainy_night.rpy:144
translate english rainy_night_e5f31ae6:

    # cass "{size=-7}Успокойся. Мои люди скоро вернутся сюда и за детьми.{/size}"
    cass "{size=-7}冷静。我的人很快就会回来，带走孩子们。{/size}"

# game/a6/2rainy_night.rpy:145
translate english rainy_night_2edf92b4:

    # me "{size=-7}М?{/size}"
    me "{size=-7}嗯？{/size}"

# game/a6/2rainy_night.rpy:146
translate english rainy_night_05921890:

    # cass "{size=-7}Пусть она будет спокойна, пусть думает что делает это для безопасности детей. Нам всем будет лучше, если завтра она будет вести себя...хорошо.{/size}"
    cass "{size=-7}让她放心，让她以为自己这么做是为了孩子们的安全。只要她明天表现……乖乖配合，对我们大家都好。{/size}"

# game/a6/2rainy_night.rpy:147
translate english rainy_night_1da1cc38:

    # me "{size=-7}Ты ее обманула.{/size}"
    me "{size=-7}你骗了她。{/size}"

# game/a6/2rainy_night.rpy:148
translate english rainy_night_72eb7dcf:

    # cass "{size=-7}Это называется политика.{/size}"
    cass "{size=-7}这就叫政治。{/size}"

# game/a6/2rainy_night.rpy:149
translate english rainy_night_4936cbb6:

    # me "Что дальше? Каллахан?"
    me "接下来呢？去找Callahan？"

# game/a6/2rainy_night.rpy:150
translate english rainy_night_9fda19e7:

    # cass "Да. Попробуй его убедить."
    cass "对。试着说服他。"

# game/a6/2rainy_night.rpy:151
translate english rainy_night_faaa362d:

    # me "Один? Почему не вместе?"
    me "我一个人？为什么不一起去？"

# game/a6/2rainy_night.rpy:152
translate english rainy_night_50be1826:

    # cass "Мне нужно еще успеть подготовить моих людей."
    cass "我还得赶时间安排我的人手。"

# game/a6/2rainy_night.rpy:153
translate english rainy_night_b9d7f853:

    # me "А если он не согласится? У него детей нет, надавить нечем."
    me "要是他不答应呢？他没孩子，没什么可要挟他的。"

# game/a6/2rainy_night.rpy:154
translate english rainy_night_540a7a87:

    # cass "Тогда убей его."
    cass "那就杀了他。"

# game/a6/2rainy_night.rpy:155
translate english rainy_night_befba7d5:

    # me "Убить?"
    me "杀了他？"

# game/a6/2rainy_night.rpy:156
translate english rainy_night_5adb4053:

    # cass "Да. Но я бы рекомендовала договориться. Я думаю у него есть свои...желания."
    cass "对。不过我还是建议你尽量说服他。我觉得他有他自己的……欲望。"

# game/a6/2rainy_night.rpy:157
translate english rainy_night_788ec50f:

    # me "Ладно, я попробую."
    me "好吧，我试试看。"

# game/a6/2rainy_night.rpy:158
translate english rainy_night_9d2b2b07:

    # cass "Как закончишь - встретимся на кухне."
    cass "办完事后，在厨房碰面。"

# game/a6/2rainy_night.rpy:160
translate english rainy_night_83749a03:

    # "Полчаса спустя."
    "半个小时以后。"

# game/a6/2rainy_night.rpy:161
translate english rainy_night_e0550963:

    # me "{i}Договориться...{/i}"
    me "{i}说服他……{/i}"

# game/a6/2rainy_night.rpy:162
translate english rainy_night_2211df36:

    # me "{i}Как с ним договориться? Я ничего о нем не знаю, кроме того что он вечно хлещет вино.{/i}"
    me "{i}怎么说服他？我对他一无所知，只知道他成天灌酒。{/i}"

# game/a6/2rainy_night.rpy:163
translate english rainy_night_260c3b06:

    # me "{i}Убить?{/i}"
    me "{i}杀了他？{/i}"

# game/a6/2rainy_night.rpy:165
translate english rainy_night_97fc0a11:

    # me "{i}Нет. Сначала я попробую с ним поговорить.{/i}"
    me "{i}不。我得先试试跟他谈谈。{/i}"

# game/a6/2rainy_night.rpy:166
translate english rainy_night_328c15c7:

    # me "{i}Но если убедить его не получится...{/i}"
    me "{i}可要是说服不了他……{/i}"

# game/a6/2rainy_night.rpy:167
translate english rainy_night_544da8f8:

    # me "{i}О, боги, возможно мне придется это сделать.{/i}"
    me "{i}诸神在上，说不定真要我动手了。{/i}"

# game/a6/2rainy_night.rpy:170
translate english rainy_night_3a826e23:

    # sona "[mename], стой."
    sona "[mename]，站住。"

# game/a6/2rainy_night.rpy:172
translate english rainy_night_1d2d3e1b:

    # me "Кто здесь?"
    me "谁在那儿？"

# game/a6/2rainy_night.rpy:173
translate english rainy_night_7a86b66e:

    # sona "Это я, Сона."
    sona "是我，Sona。"

# game/a6/2rainy_night.rpy:174
translate english rainy_night_25b3b414:

    # me "Сона? Что ты тут делаешь?"
    me "Sona？你在这儿做什么？"

# game/a6/2rainy_night.rpy:175
translate english rainy_night_6434f630:

    # sona "Не заходи в эту дверь."
    sona "别进那扇门。"

# game/a6/2rainy_night.rpy:176
translate english rainy_night_fe09fa2e:

    # me "Может уже вылезешь оттуда? Не хочу говорить через коридор."
    me "你就不能从那里面出来吗？我可不喜欢隔着走廊说话。"

# game/a6/2rainy_night.rpy:178
translate english rainy_night_29e6c131:

    # sona "Извини, что так внезапно. Просто хотела предостеречь тебя."
    sona "抱歉出现得这么突然。我只是想警告你。"

# game/a6/2rainy_night.rpy:179
translate english rainy_night_dd507372:

    # me "Что-то не так?"
    me "有什么不对劲吗？"

# game/a6/2rainy_night.rpy:180
translate english rainy_night_03f53695:

    # sona "Ты собираешься зайти к вампиру."
    sona "你打算进吸血鬼的房间。"

# game/a6/2rainy_night.rpy:182
translate english rainy_night_f1349e90:

    # me "Стоп...что? Калахан - вампир? Ты уверена?"
    me "等等……你说什么？Callahan是吸血鬼？你确定？"

# game/a6/2rainy_night.rpy:183
translate english rainy_night_db28a3ec:

    # sona "Уверена. Я давно за ним слежу."
    sona "我确定。我已经盯了他很久了。"

# game/a6/2rainy_night.rpy:184
translate english rainy_night_31525e65:

    # me "Он...пьет человеческую кровь и..."
    me "他……喝人血了吗……"

# game/a6/2rainy_night.rpy:185
translate english rainy_night_25a8bebc:

    # sona "Нет. Он как я...как я была. Он пьет кровь зверей. Он слаб для вампира, но все еще сильнее человека."
    sona "没有。他和我一样……和我过去一样。他喝的是动物的血。对吸血鬼而言他很虚弱，但依然比凡人强。"

# game/a6/2rainy_night.rpy:186
translate english rainy_night_33c8d555:

    # me "Спасибо...это мне поможет."
    me "多谢……这可帮了我的大忙。"

# game/a6/2rainy_night.rpy:187
translate english rainy_night_daa52c52:

    # sona "Ты все еще собираешься зайти туда?"
    sona "你还是打算进去？"

# game/a6/2rainy_night.rpy:188
translate english rainy_night_ab8a8be1:

    # me "Мне нужно убедить его встать на мою сторону."
    me "我必须说服他站在我这一边。"

# game/a6/2rainy_night.rpy:189
translate english rainy_night_973cce29:

    # sona "Что же... теперь ты знаешь о нем кое-что сокровенное."
    sona "那好吧……现在你知道了关于他的一个隐秘秘密。"

# game/a6/2rainy_night.rpy:190
translate english rainy_night_b52a3570:

    # me "Верно... Но если я это раскрою это может ему не понравится."
    me "确实……但要是说穿这事，他只怕会不高兴。"

# game/a6/2rainy_night.rpy:192
translate english rainy_night_1dbc0fac:

    # sona "Насчет этого не беспокойся. Я оторву ему голову, если он попробует как-то тебе навредить."
    sona "这个你不用担心。他要是敢伤害你，我就拧断他的脑袋。"

# game/a6/2rainy_night.rpy:193
translate english rainy_night_a9ae01d7:

    # me "Ты...ты всегда так делаешь? Всегда следишь за мной? Всегда охраняешь?"
    me "你……你总是这样吗？一直在暗中监视我？一直保护着我？"

# game/a6/2rainy_night.rpy:194
translate english rainy_night_1a13173e:

    # sona "Нет. В замке это сделать очень тяжело. Тут полно охраны. Неосторожное движение и сюда вызовут инквизицию."
    sona "没有。在这座城堡里，这种行为非常危险。这儿到处是卫兵。稍不留神，就会把宗教裁判所的人招来。"

# game/a6/2rainy_night.rpy:195
translate english rainy_night_3820771a_1:

    # me "..."
    me "..."

# game/a6/2rainy_night.rpy:196
translate english rainy_night_3530ea5d:

    # sona "Поэтому я больше сосредотачиваюсь на потенциальных местах, что могут быть для тебя опасны, а что может быть опаснее вампира в замке?"
    sona "所以，我更专注于那些可能对你有危险的地方，而城堡里，还有什么能比一个吸血鬼更危险呢？"

# game/a6/2rainy_night.rpy:197
translate english rainy_night_563ed005:

    # me "Что же...спасибо."
    me "好吧……谢谢你。"

# game/a6/2rainy_night.rpy:198
translate english rainy_night_b14eeef2:

    # sona "На за что. Ты кажется хотел поговорить с тем, вторым вампиром."
    sona "不客气。你好像打算跟里头那个，也就是第二个吸血鬼谈谈。"

# game/a6/2rainy_night.rpy:199
translate english rainy_night_fc30fd2b:

    # me "Да."
    me "是的。"

# game/a6/2rainy_night.rpy:206
translate english rainy_night2_3bb4cbef:

    # me "Эй. Каллахан! Открой!"
    me "嘿。Callahan！开门！"

# game/a6/2rainy_night.rpy:208
translate english rainy_night2_a5e34c42:

    # calah "Ну кто там...а это ты, [mename]. Что нужно?"
    calah "到底谁啊……原来是你，[mename]。有何贵干？"

# game/a6/2rainy_night.rpy:209
translate english rainy_night2_274b65e3:

    # me "Я хочу поговорить."
    me "我想和你谈谈。"

# game/a6/2rainy_night.rpy:210
translate english rainy_night2_84a047d0:

    # calah "Ночью?"
    calah "大半夜的？"

# game/a6/2rainy_night.rpy:211
translate english rainy_night2_82bfaf7b:

    # me "Да. Ночью."
    me "对，大半夜的。"

# game/a6/2rainy_night.rpy:212
translate english rainy_night2_d5de1487:

    # calah "Ну ладно, проходи."
    calah "行吧，进来吧。"

# game/a6/2rainy_night.rpy:214
translate english rainy_night2_dc3ac886:

    # calah "Ты меня оторвал от такого хорошего сна..."
    calah "你把我从一个好梦里吵醒了……"

# game/a6/2rainy_night.rpy:215
translate english rainy_night2_2cdf50ba:

    # me "Ага. Извини. Но дело срочное."
    me "哈。抱歉。但情况紧急。"

# game/a6/2rainy_night.rpy:216
translate english rainy_night2_28a084b9:

    # calah "Насколько срочное?"
    calah "有多紧急？"

# game/a6/2rainy_night.rpy:217
translate english rainy_night2_ac5f1697:

    # me "Король отравлен."
    me "国王被毒害了。"

# game/a6/2rainy_night.rpy:218
translate english rainy_night2_df2a0bc2:

    # calah "Да что ты."
    calah "真的假的。"

# game/a6/2rainy_night.rpy:219
translate english rainy_night2_fc30fd2b:

    # me "Да."
    me "真的。"

# game/a6/2rainy_night.rpy:220
translate english rainy_night2_5a6afc41:

    # calah "Если бы король был отравлен, весь дворец был бы на ушах. Так что либо он не отравлен, либо об этом знаешь только ты. Не лги мне, [mename]."
    calah "国王要是被毒害了，整座宫殿早就该炸开锅了。所以要么他没被毒害，要么这事只有你知道。别对我撒谎，[mename]。"

# game/a6/2rainy_night.rpy:223
translate english rainy_night2_c2a9fcbc:

    # me "Не лгать? Странно, я думал, что человек всю жизнь живущий во лжи, не будет так строг. Хотя можно ли сказать человек..."
    me "别撒谎？真稀奇，我以为一个一辈子都活在谎言中的人，不会如此苛求。不过话说回来，你还能算是人吗……"

# game/a6/2rainy_night.rpy:224
translate english rainy_night2_88a717fc:

    # calah "Что ты несешь?"
    calah "你在胡说八道些什么？"

# game/a6/2rainy_night.rpy:225
translate english rainy_night2_d905f3cf:

    # me "Брось изображаться идиота. Ты вампир."
    me "别装了。你是个吸血鬼。"

# game/a6/2rainy_night.rpy:226
translate english rainy_night2_c023cf63:

    # calah "АХхахаха. Что?"
    calah "哈，哈哈。你说什么？"

# game/a6/2rainy_night.rpy:227
translate english rainy_night2_c44b68b5:

    # me "В библиотеке есть книга с описанием методов проверки человека на вампиризм, мне принести ее?"
    me "图书馆里有一本书，描述了验证一个人是否是吸血鬼的方法，要我把它拿来吗？"

# game/a6/2rainy_night.rpy:231
translate english rainy_night2_7836a929:

    # me "Как я могу не лгать, если ты сам начал со лжи."
    me "明明是你先撒谎的，却叫我别撒谎。"

# game/a6/2rainy_night.rpy:232
translate english rainy_night2_c821e74f:

    # calah "О чем ты?"
    calah "你指什么？"

# game/a6/2rainy_night.rpy:233
translate english rainy_night2_ec0cd42a:

    # me "Спал говоришь? Открытая книга и зажжённая свеча с тобой не согласны."
    me "你说你在睡觉？那本摊开的书和点亮的蜡烛可不这么认为。"

# game/a6/2rainy_night.rpy:234
translate english rainy_night2_9b39491f:

    # calah "Забыл потушить перед сном."
    calah "睡前忘了熄灭了。"

# game/a6/2rainy_night.rpy:235
translate english rainy_night2_959d6585:

    # me "Она едва просела под пламенем."
    me "蜡烛几乎没怎么烧。"

# game/a6/2rainy_night.rpy:237
translate english rainy_night2_390bfcc2:

    # me "В прочем это не единственные немые свидетели твоей лжи."
    me "不过这还不是你撒谎的唯一物证。"

# game/a6/2rainy_night.rpy:238
translate english rainy_night2_f87c6467:

    # calah "Есть еще?"
    calah "还有吗？"

# game/a6/2rainy_night.rpy:239
translate english rainy_night2_514ecf87:

    # me "Нетронутые фрукты, две порции, будто кто-то сознательно делает вид, что его интересует человеческая еда, но забывает ее есть."
    me "这些碰也没碰过的水果，还是两份，就好像有人刻意装作对人间的食物有兴趣，却忘了吃。"

# game/a6/2rainy_night.rpy:240
translate english rainy_night2_6d4b64a9:

    # calah "Что несешь."
    calah "你到底在说什么。"

# game/a6/2rainy_night.rpy:241
translate english rainy_night2_d8f09fc3:

    # me "Занавешенное окно. Не нравится свежий воздух или свет солнца?"
    me "遮起来的窗户。是不喜欢新鲜空气，还是不喜欢阳光？"

# game/a6/2rainy_night.rpy:242
translate english rainy_night2_72fd4fb5:

    # calah "..."
    calah "..."

# game/a6/2rainy_night.rpy:243
translate english rainy_night2_7ee1cfb4:

    # me "Зеркало за плотной вуалью, ну и конечно кроволист в качестве комнатного растения, воняет гнилым мясом, и никто не стал бы это держать у себя это в апартаментах..."
    me "用厚纱帘挡住的镜子，当然了，还有作为房间绿植的血腥草，散发着一股子腐肉的臭味，没人会在自己的住处放这种植物……"

# game/a6/2rainy_night.rpy:244
translate english rainy_night2_d42b2756:

    # me "Кроме вампира, которой старается не пить человеческую кровь и успокаивает свое тело...необычными ароматами. Мне продолжать?"
    me "除了某个努力克制不饮用人血的吸血鬼，用……不寻常的气味来安抚身体。还要我接着说吗？"

# game/a6/2rainy_night.rpy:251
translate english rainy_night_v_cf6559e6:

    # calah "Что тебе от меня нужно..."
    calah "你到底想从我这里得到什么……"

# game/a6/2rainy_night.rpy:252
translate english rainy_night_v_a47cae56:

    # me "Раз уж мой отец отравлен, кто-то должен возглавить королевство. Я хочу чтобы совет назначил меня регентом."
    me "既然我父王被毒害了，总得有人来领导这个王国。我希望议会任命我为摄政王。"

# game/a6/2rainy_night.rpy:253
translate english rainy_night_v_62b3348b:

    # calah "Это все?"
    calah "就这个？"

# game/a6/2rainy_night.rpy:254
translate english rainy_night_v_5694a9ff:

    # me "Нет. После этого совет должен передать полномочия [cass]. И вот это уже все."
    me "不是。议会任命之后，还得把权力移交给[cass]。这样才算完。"

# game/a6/2rainy_night.rpy:255
translate english rainy_night_v_72fd4fb5:

    # calah "... "
    calah "... "

# game/a6/2rainy_night.rpy:256
translate english rainy_night_v_f71c90f1:

    # me "Ну?"
    me "那？"

# game/a6/2rainy_night.rpy:258
translate english rainy_night_v_5a48fcb6:

    # calah "Ты пришел к вампиру в одиночку и шантажируешь его. Я могу тебя убить."
    calah "你独自一人来找一个吸血鬼，还勒索他。我可以杀了你。"

# game/a6/2rainy_night.rpy:259
translate english rainy_night_v_d04cefd2:

    # me "Можешь. Но кое-кто знает, что я здесь, так что если убьешь меня твоя жизнь будет разрушена."
    me "你可以。但有某人知道我在这里，所以你要是杀了我，你的生活就完了。"

# game/a6/2rainy_night.rpy:260
translate english rainy_night_v_51038651:

    # calah "Как она будет разрушена, если я откажусь от своего места в совете."
    calah "如果我放弃我在议会里的席位，我的生活怎么会完？"

# game/a6/2rainy_night.rpy:261
translate english rainy_night_v_bcbce690:

    # me "Ну что ты. Я слышал есть не менее жирная должность начальника столичного порта. Ты сможешь продолжать жить и работать там как ни в чем не бывало."
    me "瞧你说的。我听说，还有首都港务总长这么个肥缺。你可以继续在那里生活工作，若无其事。"

# game/a6/2rainy_night.rpy:262
translate english rainy_night_v_c3b845c6:

    # calah "Что помешает тебе сдать меня инквизиции сразу после того, как я сделаю все что тебе нужно?"
    calah "我怎么知道，等我做完你要我做的事后，你不会把我交给宗教裁判所？"

# game/a6/2rainy_night.rpy:263
translate english rainy_night_v_4657cb94:

    # me "Ты стабильно приносил в казну больше, чем кто-либо из твоих предшественников. Мне нужны талантливые и лояльные...люди."
    me "你为国库带来的收入，一直比你所有前任都要稳定。我需要有才能且忠诚的……人。"

# game/a6/2rainy_night.rpy:264
translate english rainy_night_v_c9c115db:

    # calah "Если я соглашусь...я всю жизнь буду у тебя на крючке."
    calah "如果我同意……我这辈子就得任由你摆布了。"

# game/a6/2rainy_night.rpy:265
translate english rainy_night_v_21ea50b2:

    # me "Я слышал вампиры живут неприлично долго. Так что твоя жизнь кончится гораздо позже, чем моя."
    me "我听说吸血鬼的寿命长得惊人。所以你这辈子，会结束得比我晚得多。"

# game/a6/2rainy_night.rpy:266
translate english rainy_night_v_60d49b07:

    # calah "Это только если вампир пьет человеческую кровь."
    calah "前提是该吸血鬼喝人血才行。"

# game/a6/2rainy_night.rpy:267
translate english rainy_night_v_d4bc9c38:

    # me "Ну что же. Я как регент буду готов списать пропажу пару портовых рабочих в месяц на несчастные случаи и не вызывать из-за этого инквизицию."
    me "行吧。作为摄政王，我准备将每月失踪的几个港口工人说成是意外事故，不因为这事招来裁判所。"

# game/a6/2rainy_night.rpy:268
translate english rainy_night_v_9900a1cd:

    # calah "... Я согласен. А теперь уходи."
    calah "……我同意。现在，请你离开。"

# game/a6/2rainy_night.rpy:269
translate english rainy_night_v_18134530:

    # me "До встречи."
    me "回头见。"

# game/a6/2rainy_night.rpy:274
translate english rainy_night3_7cea060a:

    # calah "Говори прямо, [mename]."
    calah "直说吧，[mename]。"

# game/a6/2rainy_night.rpy:275
translate english rainy_night3_de1b87a4:

    # me "Мне нужна твой голос, как члена совета, для того чтобы стать регентом."
    me "我需要作为议会成员的你投一票，让我成为摄政王。"

# game/a6/2rainy_night.rpy:276
translate english rainy_night3_9554b561:

    # calah "Так король все-таки отравлен."
    calah "这么说，国王到底还是被毒害了。"

# game/a6/2rainy_night.rpy:277
translate english rainy_night3_197baa2a:

    # me "Боюсь что да. И для того, чтобы найти злодея..."
    me "恐怕是的。为了找出恶贼……"

# game/a6/2rainy_night.rpy:278
translate english rainy_night3_0ba35c74:

    # calah "Не морочь мне голову этой чушью. Ты и твои люди хотите совершить переворот. Что? Устал ждать корону по наследству?"
    calah "别拿这些废话糊弄我。你和你的同伙想要发动政变。怎么了？等不及靠继承得到王冠了？"

# game/a6/2rainy_night.rpy:279
translate english rainy_night3_3820771a:

    # me "... "
    me "... "

# game/a6/2rainy_night.rpy:281
translate english rainy_night3_762f3857:

    # calah "Кто еще с тобой. [cass]? Наверняка она тебя надоумила."
    calah "还有谁跟着你。[cass]吗？八成是她教唆你的吧。"

# game/a6/2rainy_night.rpy:282
translate english rainy_night3_550e7d30:

    # me "Так ты поможешь мне?"
    me "那么，你帮不帮我？"

# game/a6/2rainy_night.rpy:283
translate english rainy_night3_cbc137eb:

    # calah "Зачем мне это делать? Из страха смерти?"
    calah "我为什么要帮你？因为怕死吗？"

# game/a6/2rainy_night.rpy:284
translate english rainy_night3_9ddfe45c:

    # me "Допустим."
    me "算是吧。"

# game/a6/2rainy_night.rpy:285
translate english rainy_night3_ee099d48:

    # calah "Не пойдет. Я бы мог тебе помочь, но..."
    calah "这行不通。我倒是可以帮你，但是……"

# game/a6/2rainy_night.rpy:286
translate english rainy_night3_511310db:

    # me "Но?"
    me "但是？"

# game/a6/2rainy_night.rpy:287
translate english rainy_night3_46c8756d:

    # calah "Но у меня есть одно условие."
    calah "但我有一个条件。"

# game/a6/2rainy_night.rpy:288
translate english rainy_night3_094d6b91:

    # me "Какое?"
    me "什么条件？"

# game/a6/2rainy_night.rpy:289
translate english rainy_night3_fca7d816:

    # calah "Семь колец. Я хочу быть твоей правой рукой."
    calah "七戒。我要当你的左膀右臂。"

# game/a6/2rainy_night.rpy:290
translate english rainy_night3_00ed426c:

    # me "Это место уже за [cass]."
    me "这个位置已经属于[cass]了。"

# game/a6/2rainy_night.rpy:291
translate english rainy_night3_cc803856:

    # calah "Верно. Но если онаtragически погибнет..."
    calah "没错。可假如她不幸丧命……"

# game/a6/2rainy_night.rpy:292
translate english rainy_night3_a2a1e562:

    # me "О чем ты говоришь?"
    me "你在说什么？"

# game/a6/2rainy_night.rpy:293
translate english rainy_night3_61ea2452:

    # calah "Я бы помог тебе с переворотом два раза, [mename]..."
    calah "我愿意帮你两次，[mename]……"

# game/a6/2rainy_night.rpy:294
translate english rainy_night3_a02fb8fb:

    # me "Два раза?"
    me "两次？"

# game/a6/2rainy_night.rpy:295
translate english rainy_night3_1d558f95:

    # calah "Да брось, ты прибыл ко дворцу не так давно и уже устраиваешь переворот? Я знаю кто за этим стоит на самом деле."
    calah "得了吧，你刚来王宫没多久，就要搞政变？我知道谁才是幕后主使。"

# game/a6/2rainy_night.rpy:296
translate english rainy_night3_3820771a_1:

    # me "... "
    me "... "

# game/a6/2rainy_night.rpy:297
translate english rainy_night3_86ae687d:

    # calah "Она оденет на тебя корону, только не твою голову, а на твою шею. А я помогу от этого избавиться."
    calah "她会为你戴上王冠，可不是戴在你头上，而是套在你脖子上。而我能帮你摆脱这个命运。"

# game/a6/2rainy_night.rpy:298
translate english rainy_night3_0c15ce72:

    # me "И займешь ее место."
    me "然后取代她的位置。"

# game/a6/2rainy_night.rpy:299
translate english rainy_night3_150548e7:

    # calah "Конечно."
    calah "当然。"

# game/a6/2rainy_night.rpy:300
translate english rainy_night3_1f3e16ff:

    # me "И в чем же разница?"
    me "那你和她，有什么不同？"

# game/a6/2rainy_night.rpy:301
translate english rainy_night3_bf196578:

    # calah "Разница в том, что я не полоумный кровожадный идиот, что мстит всем вокруг за что было и не было."
    calah "不同之处在于，我不是那种不分好歹，报复所有人的半疯嗜血的白痴。"

# game/a6/2rainy_night.rpy:302
translate english rainy_night3_3820771a_2:

    # me "..."
    me "..."

# game/a6/2rainy_night.rpy:303
translate english rainy_night3_71654d31:

    # calah "Я знаю как сделать это королевство...снова империей. Король вреден, его правление делает всех нас слабее. Но если его место займет полоумная девка, ситуация не станет лучше."
    calah "我知道如何让这个王国……再次成为帝国。国王昏庸，他的统治让我们所有人日益衰弱。可要是换一个半疯的女人坐上他的位子，情况也不会好到哪儿去。"

# game/a6/2rainy_night.rpy:304
translate english rainy_night3_4ae26afa:

    # calah "Но ты и я - мы разумные люди. Мы сделаем это место великим снова."
    calah "但你和我——我们是理智的人。我们能再次让这个国家强盛起来。"

# game/a6/2rainy_night.rpy:305
translate english rainy_night3_44efd859:

    # me "Мне всего лишь нужно будет предать мою сестру."
    me "我只需要背叛我的姐妹。"

# game/a6/2rainy_night.rpy:306
translate english rainy_night3_167a4632:

    # calah "Ты уже предал своего отца. Думаю совершить еще одно предательство, в этот раз с благой целью, будет не сложно."
    calah "你连自己的父亲都已经背叛了。我想，再背弃一次誓言，而且这次是出于正义的目的，对你而言应该不难。"

# game/a6/2rainy_night.rpy:310
translate english rainy_night3_11efd153:

    # me "Если я соглашусь...что мне нужно будет делать?"
    me "要是我同意……我需要做什么？"

# game/a6/2rainy_night.rpy:311
translate english rainy_night3_b5953403:

    # calah "Ничего сверх планов твоей сестры. Пусть тебя назначат регентом."
    calah "不用超出你姐的计划。就让议会任命你为摄政王。"

# game/a6/2rainy_night.rpy:312
translate english rainy_night3_b4479314:

    # me "Она получит всю власть совета."
    me "她会拿到议会的全部权力。"

# game/a6/2rainy_night.rpy:313
translate english rainy_night3_2fc677c1:

    # calah "Это хорошо. Как только твоя легитимность укрепится, я займу ее место."
    calah "这很好。一旦你的合法地位得到巩固，我就会取代她的位置。"

# game/a6/2rainy_night.rpy:314
translate english rainy_night3_d2b04ecc:

    # me "Как?"
    me "怎么做？"

# game/a6/2rainy_night.rpy:315
translate english rainy_night3_b6e109de:

    # calah "Когда придет время ты поймешь. Мы еще обговорим это. Так ты согласен?"
    calah "到时候你就知道了。我们到时再细谈。那么，你同意吗？"

# game/a6/2rainy_night.rpy:316
translate english rainy_night3_e9d52404:

    # me "Я согласен."
    me "我同意。"

# game/a6/2rainy_night.rpy:317
translate english rainy_night3_51af39d5:

    # calah "Я рад, что ты не только коварен, но и рационален."
    calah "我真高兴，你不仅阴险，还很理性。"

# game/a6/2rainy_night.rpy:318
translate english rainy_night3_18134530:

    # me "До встречи."
    me "回头见。"

# game/a6/2rainy_night.rpy:319
translate english rainy_night3_a1d2df49:

    # calah "До встречи, [mename]."
    calah "回头见，[mename]。"

# game/a6/2rainy_night.rpy:323
translate english rainy_night3_1563d983:

    # me "Я не стану этого делать."
    me "我不会这么做的。"

# game/a6/2rainy_night.rpy:324
translate english rainy_night3_aa7e3c30:

    # calah "Жаль."
    calah "真遗憾。"

# game/a6/2rainy_night.rpy:325
translate english rainy_night3_e5cdbbce:

    # me "И что же? Теперь ты будешь нам мешать?"
    me "那么怎样？你现在打算阻挠我们吗？"

# game/a6/2rainy_night.rpy:326
translate english rainy_night3_01411213:

    # calah "Ну что ты, я ценю не только свою репутацию, но и жизнь. К тому же я со вчерашнего дня в деловой торговой поездке на Восток."
    calah "怎么会，我不仅珍惜我的名声，也珍惜我的性命。何况，从昨天起，我就在去东方做贸易商旅了。"

# game/a6/2rainy_night.rpy:327
translate english rainy_night3_3820771a_3:

    # me "..."
    me "..."

# game/a6/2rainy_night.rpy:328
translate english rainy_night3_0ef0a09b:

    # calah "Ты ведь не против?"
    calah "你总不会反对吧？"

# game/a6/2rainy_night.rpy:329
translate english rainy_night3_5a7a7577:

    # me "Нет."
    me "不反对。"

# game/a6/2rainy_night.rpy:330
translate english rainy_night3_8762e4ee:

    # calah "Отлично. Желаю вам удачи в вашем...предприятии. А мне пора собирать вещи."
    calah "太好了。祝你们的……事业顺遂。我得去收拾行李了。"

# game/a6/2rainy_night.rpy:331
translate english rainy_night3_8d8bd849:

    # me "Тебе тоже удачи. Прощай."
    me "也祝你好运。再见。"

# game/a6/2rainy_night.rpy:335
translate english rainy_night3_9e42d19d:

    # me "Я лучше убью тебя!"
    me "我宁可杀了你！"

# game/a6/2rainy_night.rpy:337
translate english rainy_night3_e8df4f45:

    # calah "У тебя не выйдет, ублюдок."
    calah "你办不到的，杂种。"

# game/a6/2rainy_night.rpy:338
translate english rainy_night3_44d5404f:

    # me "БЛЯДЬ!"
    me "操！"

# game/a6/2rainy_night.rpy:340
translate english rainy_night3_7e6c7e22:

    # me "Сукин сын!"
    me "狗娘养的！"

# game/a6/2rainy_night.rpy:342
translate english rainy_night3_b3bfb4fa:

    # me "Я тебя убью!"
    me "我会杀了你的！"

# game/a6/2rainy_night.rpy:343
translate english rainy_night3_49a00948:

    # calah "не пытайся меня искать или наша следующая встреча кончится для тебя плохо."
    calah "别试图找我，否则我们下次见面，你的下场会很惨。"

# game/a6/2rainy_night.rpy:344
translate english rainy_night3_54ecc367:

    # me "Даже не пытайся..."
    me "休想……"

# game/a6/2rainy_night.rpy:346
translate english rainy_night3_f7a617e6:

    # me "...убежать."
    me "……逃跑。"

# game/a6/2rainy_night.rpy:347
translate english rainy_night3_ca5b2a41:

    # me "{i}Охренеть он быстрый....{/i}"
    me "{i}他可真他妈快……{/i}"

# game/a6/2rainy_night.rpy:348
translate english rainy_night3_e8b702ba:

    # me "{i}Да и сильный. И реакция его...что за черт? Он же не разжимает хватки вокруг бокала с вином...{/i}"
    me "{i}而且力气也大。还有他的反应……见鬼了？他握杯子的手居然都没松开过……{/i}"

# game/a6/2rainy_night.rpy:349
translate english rainy_night3_247cde21:

    # me "{i}Блядь! [cass] будет недовольна.{/i}"
    me "{i}操！[cass]会很不高兴的。{/i}"

# game/a6/2rainy_night.rpy:353
translate english rainy_night4_e01dc55b:

    # "Несколько минут спустя."
    "几分钟以后。"

# game/a6/2rainy_night.rpy:354
translate english rainy_night4_135c322b:

    # cass "Ну что? Как прошло?"
    cass "怎么样？事情进展如何？"

# game/a6/2rainy_night.rpy:357
translate english rainy_night4_b423daab:

    # me "Не очень."
    me "不太好。"

# game/a6/2rainy_night.rpy:358
translate english rainy_night4_df60101b:

    # cass "Не очень?"
    cass "不太好？"

# game/a6/2rainy_night.rpy:359
translate english rainy_night4_107e9720:

    # me "У нас не будет его голоса завтра."
    me "明天我们得不到他的票了。"

# game/a6/2rainy_night.rpy:360
translate english rainy_night4_4fc306dc:

    # cass "Дерьмо!"
    cass "妈的！"

# game/a6/2rainy_night.rpy:361
translate english rainy_night4_ed76d2be:

    # me "Да, прости."
    me "嗯，抱歉。"

# game/a6/2rainy_night.rpy:362
translate english rainy_night4_9abe5f78:

    # cass "Ладно. Отдохни пока. С утра у нас много работы."
    cass "罢了。你先去歇会儿。明早我们有得忙了。"

# game/a6/2rainy_night.rpy:365
translate english rainy_night4_71d3b8c8:

    # me "Хорошо."
    me "好。"

# game/a6/2rainy_night.rpy:366
translate english rainy_night4_952bffdc:

    # cass "Он проголосует за твое регентство?"
    cass "他愿意投票支持你担任摄政吗？"

# game/a6/2rainy_night.rpy:367
translate english rainy_night4_3a0de007:

    # me "Он сделает все что нужно."
    me "他会按我们说的做。"

# game/a6/2rainy_night.rpy:368
translate english rainy_night4_9432c0bd:

    # cass "Что ты ему предложил?"
    cass "你给了他什么好处？"

# game/a6/2rainy_night.rpy:369
translate english rainy_night4_3ceb79f2:

    # me "Это важно?"
    me "这重要吗？"

# game/a6/2rainy_night.rpy:370
translate english rainy_night4_2ba4c3a3:

    # cass "Нет."
    cass "不重要。"

# game/a6/2rainy_night.rpy:372
translate english rainy_night4_72dc405f:

    # me "Я пошел."
    me "我走了。"

# game/a6/2rainy_night.rpy:373
translate english rainy_night4_a174b16d:

    # cass "Стой. Не хочешь немного расслабиться? Завтра у нас трудный день."
    cass "等等。不想放松一下吗？明天可是要紧日子。"

# game/a6/2rainy_night.rpy:374
translate english rainy_night4_d355dc3b:

    # me "О чем ты?"
    me "你在暗示什么？"

# game/a6/2rainy_night.rpy:375
translate english rainy_night4_cf149f9f:

    # cass "Ты понимаешь о чем я."
    cass "你懂我在说什么。"

# game/a6/2rainy_night.rpy:379
translate english rainy_night4_05c11628:

    # me "Если завтра тяжелый день, то нужно не копить силы, а не тратить. Я спать."
    me "如果明天是要紧日子，那更应该积蓄力量，而不是耗费体力。我去睡了。"

# game/a6/2rainy_night.rpy:380
translate english rainy_night4_067783c1:

    # cass "Как хочешь. Будь готов рано вставать."
    cass "随你。准备好早起。"

# game/a6/2rainy_night.rpy:381
translate english rainy_night4_71d3b8c8_1:

    # me "Хорошо."
    me "好。"

# game/a6/2rainy_night.rpy:385
translate english rainy_night4_0e22abf1:

    # me "Я правильно тебя понял?"
    me "我没理解错你的意思吧？"

# game/a6/2rainy_night.rpy:386
translate english rainy_night4_b7c8f5f0:

    # cass "Да."
    cass "没错。"

# game/a6/2rainy_night.rpy:387
translate english rainy_night4_b2f4859f:

    # me "{i}Надо сказать она права.{/i}"
    me "{i}必须承认她说得对。{/i}"

# game/a6/2rainy_night.rpy:388
translate english rainy_night4_df7abd1a:

    # me "{i}Завтра великий день.{/i}"
    me "{i}明天是个伟大的日子。{/i}"

# game/a6/2rainy_night.rpy:389
translate english rainy_night4_d2a9705b:

    # me "{i}Думаю стоит избавиться от сомнений и дрожи в руках.{/i}"
    me "{i}我想我最好抛掉疑虑，让手别再颤抖。{/i}"

# game/a6/2rainy_night.rpy:391
translate english rainy_night4_b677b6aa:

    # cass "Ммм...чувствую некоторую твердость. Начнем с тебя?"
    cass "嗯……我感觉到了某种坚挺。先从你开始？"

# game/a6/2rainy_night.rpy:392
translate english rainy_night4_96f2e21c:

    # me "Что ты имеешь в виду?"
    me "你什么意思？"

# game/a6/2rainy_night.rpy:393
translate english rainy_night4_21fd23c1:

    # cass "Сейчас все поймешь. Залазь на стол."
    cass "马上就懂了。爬到桌子上来。"

# game/a6/2rainy_night.rpy:395
translate english rainy_night4_68e61fa4:

    # me "Помню как мы тут..."
    me "记得我们以前在这儿……"

# game/a6/2rainy_night.rpy:396
translate english rainy_night4_0296cb36:

    # cass "Ели?"
    cass "吃东西？"

# game/a6/2rainy_night.rpy:397
translate english rainy_night4_615dd3f4:

    # me "Если бы. Воровали сладости."
    me "才怪。偷甜点吃。"

# game/a6/2rainy_night.rpy:398
translate english rainy_night4_c3c23955:

    # cass "Я тоже это помню. Наши шалости с возрастом стали немного серьезнее."
    cass "我也记得。随着年纪渐长，我们的恶作剧也稍微严重了些。"

# game/a6/2rainy_night.rpy:399
translate english rainy_night4_2b526ce8:

    # me "Я бы не назвал, то, что произойдет завтра шалостью."
    me "我可不会把明天将要发生的事叫作恶作剧。"

# game/a6/2rainy_night.rpy:400
translate english rainy_night4_70d8c221:

    # cass "Ну что ты, шалости есть продолжение плохого воспитания. Как иронично что именно наша большая шалость снимет с отца корону."
    cass "怎么不是，恶作剧是缺乏教养的延续。多么讽刺啊，正是我们这场大恶作剧，会夺走父亲的王冠。"

# game/a6/2rainy_night.rpy:401
translate english rainy_night4_e0054ed1:

    # me "Мы так и будем...целоваться? У меня сейчас член взорвется."
    me "我们还要……一直亲吗？我老二都快炸了。"

# game/a6/2rainy_night.rpy:402
translate english rainy_night4_02edc788:

    # cass "Ух, какой нетерпеливый мальчик."
    cass "哟，真是个急不可耐的男孩。"

# game/a6/2rainy_night.rpy:404
translate english rainy_night4_126a95e8:

    # me "Мальчик? Следи за языком, я будущий король."
    me "男孩？注意你的言辞，我是未来的国王。"

# game/a6/2rainy_night.rpy:405
translate english rainy_night4_6280182d:

    # cass "Регент."
    cass "是摄政王。"

# game/a6/2rainy_night.rpy:406
translate english rainy_night4_ce72a309:

    # me "Это почти одно и то же."
    me "那几乎是一回事。"

# game/a6/2rainy_night.rpy:407
translate english rainy_night4_b339e529:

    # cass "Не совсем."
    cass "不完全是。"

# game/a6/2rainy_night.rpy:408
translate english rainy_night4_23ae23fc:

    # me "Умаляешь мою королевскую власть?"
    me "你在贬低我的王权吗？"

# game/a6/2rainy_night.rpy:409
translate english rainy_night4_83487d0e:

    # cass "Ну что вы, мой король, ни в коем случае."
    cass "怎么会呢，吾王，绝无此事。"

# game/a6/2rainy_night.rpy:410
translate english rainy_night4_d74872aa:

    # me "Может тогда уже как-нибудь докажешь свою лояльность?"
    me "那你是不是该用行动证明一下你的忠诚？"

# game/a6/2rainy_night.rpy:412
translate english rainy_night4_c89b7fcd:

    # cass "Как пожелаете, мой король. Могу я для этого действия использовать ваш...королевский скипетр."
    cass "如您所愿，吾王。请容我为此行事，借用一下您的……皇家权杖。"

# game/a6/2rainy_night.rpy:413
translate english rainy_night4_428d1483:

    # me "Используй."
    me "用吧。"

# game/a6/2rainy_night.rpy:414
translate english rainy_night4_2d88512f:

    # cass "Благодарю вас, мой король."
    cass "感谢您，吾王。"

# game/a6/2rainy_night.rpy:415
translate english rainy_night4_4eb3922d:

    # me "Ты умеешь с ним обращаться?"
    me "你懂得如何驾驭它吗？"

# game/a6/2rainy_night.rpy:416
translate english rainy_night4_565438a5:

    # cass "Не совсем. Но мне нужно учиться, раз уж я буду вашей...правой рукой."
    cass "不太懂。但我必须学习，毕竟我即将成为您的……左膀右臂。"

# game/a6/2rainy_night.rpy:417
translate english rainy_night4_b504616a:

    # me "Можешь учиться когда захочешь."
    me "只要你想，随时可以学。"

# game/a6/2rainy_night.rpy:419
translate english rainy_night4_9785d065:

    # cass "Правда, разве вас хватит на...когда всегда, когда мне захочется, мой король?"
    cass "真的吗，可您……能撑得住我随时随地的需要吗，吾王？"

# game/a6/2rainy_night.rpy:420
translate english rainy_night4_dee63805:

    # me "Ты слишком много болтаешь и слишком мало делаешь, плохая черта для правой руки короля."
    me "你话说得太多了，活干得太少，这对一个国王的左膀右臂来说，可是个坏毛病。"

# game/a6/2rainy_night.rpy:421
translate english rainy_night4_651ccc28:

    # cass "..."
    cass "..."

# game/a6/2rainy_night.rpy:422
translate english rainy_night4_05e09a92:

    # me "Может мне найти лучшего кандидата для семи колец?"
    me "或许我该为七戒找个更合适的人选？"

# game/a6/2rainy_night.rpy:423
translate english rainy_night4_bd0bf254:

    # cass "Ни в коем случае!"
    cass "绝对不行！"

# game/a6/2rainy_night.rpy:425
translate english rainy_night4_bfb7f983:

    # me "Вот так...да...меньше слов, больше дела..."
    me "这就对了……对……少说话，多做事……"

# game/a6/2rainy_night.rpy:426
translate english rainy_night4_b4c0ef3b:

    # cass "Мнм?"
    cass "唔？"

# game/a6/2rainy_night.rpy:427
translate english rainy_night4_143062a1:

    # me "У тебя хорошо получается."
    me "你做得不错。"

# game/a6/2rainy_night.rpy:428
translate english rainy_night4_40253b56:

    # cass "Мнмм?"
    cass "唔嗯嗯？"

# game/a6/2rainy_night.rpy:429
translate english rainy_night4_558b60eb:

    # me "Не понимаю, что ты там бормочешь, сначала достань мой член...мой королевский скипетр изо рта."
    me "听不懂你在嘟囔什么，先把我的老二……我的皇家权杖从嘴里拿出来。"

# game/a6/2rainy_night.rpy:430
translate english rainy_night4_69a0b14c:

    # cass "Ммнмммм."
    cass "唔嗯嗯嗯。"

# game/a6/2rainy_night.rpy:431
translate english rainy_night4_3820771a:

    # me "..."
    me "..."

# game/a6/2rainy_night.rpy:432
translate english rainy_night4_a34ca559:

    # me "Ты хорошая помощница, сестренка."
    me "你是个好帮手，我的妹妹。"

# game/a6/2rainy_night.rpy:433
translate english rainy_night4_536477f2:

    # me "Но и я благодарный король."
    me "但我也是个慷慨的国王。"

# game/a6/2rainy_night.rpy:434
translate english rainy_night4_8d4386ce:

    # me "Так что не оставлю тебя без награды для службы."
    me "所以我不会让你白白为皇家服务。"

# game/a6/2rainy_night.rpy:436
translate english rainy_night4_55c1f3be:

    # me "УХ...."
    me "呜……"

# game/a6/2rainy_night.rpy:437
translate english rainy_night4_d72bf975:

    # cass "мМММмМ!"
    cass "唔唔唔嗯！"

# game/a6/2rainy_night.rpy:438
translate english rainy_night4_a4c818a4:

    # me "Не доставай член...прими все внутрь. Не смей тратить попусту королевскую благодать."
    me "别把老二抽出来……全都吞下去。不许浪费皇家恩泽。"

# game/a6/2rainy_night.rpy:440
translate english rainy_night4_5d4cadea:

    # cass "Аххх..."
    cass "哈……"

# game/a6/2rainy_night.rpy:441
translate english rainy_night4_7db4fe5b:

    # me "Ты не проглотила?"
    me "你没吞下去吗？"

# game/a6/2rainy_night.rpy:442
translate english rainy_night4_56be5ca0:

    # cass "Эшто вшсе не пшлготить ша ошин раш."
    cass "贼么多，不可能一下子全吞下去。"

# game/a6/2rainy_night.rpy:443
translate english rainy_night4_d76c19a8:

    # me "Ну тогда проглоти сейчас."
    me "那就现在吞。"

# game/a6/2rainy_night.rpy:444
translate english rainy_night4_651ccc28_1:

    # cass "..."
    cass "..."

# game/a6/2rainy_night.rpy:445
translate english rainy_night4_be7aa58b:

    # me "...."
    me "...."

# game/a6/2rainy_night.rpy:447
translate english rainy_night4_651ccc28_2:

    # cass "..."
    cass "..."

# game/a6/2rainy_night.rpy:448
translate english rainy_night4_6fceae53:

    # me "Молодец."
    me "真乖。"

# game/a6/2rainy_night.rpy:449
translate english rainy_night4_d219fe96:

    # cass "Моя очередь."
    cass "轮到我了。"

# game/a6/2rainy_night.rpy:450
translate english rainy_night4_dfcceeac:

    # me "М?"
    me "嗯？"

# game/a6/2rainy_night.rpy:451
translate english rainy_night4_dbf4a36d:

    # cass "Я достаточно побыла твоей сучкой, моя очередь."
    cass "我当你的婊子已经当得够久了，轮到我了。"

# game/a6/2rainy_night.rpy:452
translate english rainy_night4_3820771a_1:

    # me "..."
    me "..."

# game/a6/2rainy_night.rpy:453
translate english rainy_night4_6a5ec324:

    # cass "Или ты хочешь познать гнев носителя семи колец?"
    cass "还是说你想领教一下七戒持有者的怒火？"

# game/a6/2rainy_night.rpy:455
translate english rainy_night4_0f44b538:

    # me "Ни в коем случае."
    me "绝无此意。"

# game/a6/2rainy_night.rpy:456
translate english rainy_night4_c15ca6bb:

    # cass "Тогда закрой рот и сделай мне приятно."
    cass "那就闭上嘴，让我舒服。"

# game/a6/2rainy_night.rpy:457
translate english rainy_night4_b21ff3fa:

    # me "Я не смогу сделать это с закрытым ртом...."
    me "闭着嘴我可没法干这个……"

# game/a6/2rainy_night.rpy:458
translate english rainy_night4_c84476b0:

    # cass "Ты начинаешь меня раздражать."
    cass "你开始让我恼火了。"

# game/a6/2rainy_night.rpy:460
translate english rainy_night4_55a6d81c:

    # cass "Вот так...да...это для твоего рта лучшее применение."
    cass "就这样……对……你的嘴就适合干这个。"

# game/a6/2rainy_night.rpy:461
translate english rainy_night4_16951209:

    # me "Мнмм."
    me "唔嗯。"

# game/a6/2rainy_night.rpy:462
translate english rainy_night4_04a9ea4f:

    # cass "А то каждый раз когда ты его открываешь, мне хочется тебя убить."
    cass "不然每次你开口说话，我都想杀了你。"

# game/a6/2rainy_night.rpy:463
translate english rainy_night4_789ecae9:

    # me "Ммнмм."
    me "唔嗯唔。"

# game/a6/2rainy_night.rpy:464
translate english rainy_night4_1264b2f0:

    # cass "Может своим первым указом запретишь себе открывать рот, пока мои ноги не у тебя за ушами? М?"
    cass "要不你的第一道诏令，就禁止自己开口，直到我的双脚架在你的耳朵后？嗯？"

# game/a6/2rainy_night.rpy:465
translate english rainy_night4_8e26e817:

    # me "Мнм!"
    me "唔嗯！"

# game/a6/2rainy_night.rpy:466
translate english rainy_night4_894dc0e4:

    # cass "Ну не злись. Ты молодец."
    cass "好啦，别生气。你做得很好。"

# game/a6/2rainy_night.rpy:467
translate english rainy_night4_c3ee4d16:

    # cass "Хороший пиздолиз."
    cass "真是个出色的马屁精。"

# game/a6/2rainy_night.rpy:468
translate english rainy_night4_ad25d58d:

    # cass "Хороший сестренкин пиздолиз."
    cass "姐姐的好马屁精。"

# game/a6/2rainy_night.rpy:469
translate english rainy_night4_ce810043:

    # cass "Мм...."
    cass "唔……"

# game/a6/2rainy_night.rpy:470
translate english rainy_night4_52fbb018:

    # cass "У тебя действительно...."
    cass "你确实……"

# game/a6/2rainy_night.rpy:471
translate english rainy_night4_8fdae445:

    # cass "Хорошо...."
    cass "很厉害……"

# game/a6/2rainy_night.rpy:473
translate english rainy_night4_23e86553:

    # cass "....получается! АХХХ!"
    cass "……很会弄！啊啊啊！"

# game/a6/2rainy_night.rpy:474
translate english rainy_night4_46639b9e:

    # cass "Блядь! Я хотела насладиться этим подольше."
    cass "操！我本来想多享受一会儿的。"

# game/a6/2rainy_night.rpy:475
translate english rainy_night4_9f0eae52:

    # cass "Кажется я была перенапряжена."
    cass "看来我绷得太紧了。"

# game/a6/2rainy_night.rpy:477
translate english rainy_night4_9423a849:

    # me "Я тоже быстро кончил. Может продолжим?"
    me "我也很快就射了。不如我们继续？"

# game/a6/2rainy_night.rpy:478
translate english rainy_night4_23cdbfee:

    # cass "А?"
    cass "啊？"

# game/a6/2rainy_night.rpy:479
translate english rainy_night4_a243aae4:

    # me "Ну продолжим снимать напряжение более глубокими способами. Смекаешь к чему я?"
    me "我是说，用更深入的方式继续缓解压力。你明白我的意思吧？"

# game/a6/2rainy_night.rpy:480
translate english rainy_night4_c3390f14:

    # cass "Займемся этим, когда все будет закончено."
    cass "等一切尘埃落定再说。"

# game/a6/2rainy_night.rpy:481
translate english rainy_night4_50a8d812:

    # me "Ну тогда просто еще раз удовлетворим друг друга, как мы делали это сейчас?"
    me "那就再像刚才那样，彼此满足一次？"

# game/a6/2rainy_night.rpy:482
translate english rainy_night4_e2c43861:

    # cass "Хватит. Нам еще нужно поспать. У нас осталась пара часов. Забирайся сюда."
    cass "够了。我们还需要睡觉。我们只剩下几小时了。到床上来。"

# game/a6/2rainy_night.rpy:484
translate english rainy_night4_4bd52a99:

    # me "Пару часов?"
    me "只剩几小时？"

# game/a6/2rainy_night.rpy:485
translate english rainy_night4_9c66e692:

    # cass "Ага. Отец будет у своего доктора на рассвете. Там мы его и застанем."
    cass "对。父亲会在黎明时分去找他的医生。我们就在那儿堵他。"

# game/a6/2rainy_night.rpy:486
translate english rainy_night4_649da73e:

    # me "Я думал он отравлен."
    me "我还以为他已经被毒害了。"

# game/a6/2rainy_night.rpy:487
translate english rainy_night4_e6d2a646:

    # cass "С чего ты так решил?"
    cass "你怎么会这么想？"

# game/a6/2rainy_night.rpy:488
translate english rainy_night4_7fc1e151:

    # me "Ты так сказала."
    me "是你说的。"

# game/a6/2rainy_night.rpy:489
translate english rainy_night4_09200dc3:

    # cass "Я сказала, что мы будем искать преступника, который его отравит."
    cass "我说的是，我们将追捕那个将要毒害他的凶手。"

# game/a6/2rainy_night.rpy:490
translate english rainy_night4_445dec00:

    # me "А отравим мы его сами утром?"
    me "那我们是早上再亲自动手？"

# game/a6/2rainy_night.rpy:491
translate english rainy_night4_c8f3f1d2:

    # cass "Возможно он уже будет...не в сознании, но на тот случай, если яд еще не подействовал...тогда мы сами увеличим дозировку."
    cass "或许到那时他已经……不省人事了，但以防毒药还没起效……我们那时候再加大剂量。"

# game/a6/2rainy_night.rpy:492
translate english rainy_night4_5c0ec457:

    # me "Так он все же отравлен? Я ничего не понимаю. Обьясни мне."
    me "所以说他到底被毒害了没有？我什么都搞不懂了。给我解释清楚。"

# game/a6/2rainy_night.rpy:493
translate english rainy_night4_25762f4f:

    # cass "Хорошо. Использовать известные яды опасно - отец просто умрет. А нам этого не нужно, ведь неожиданная смерть монарха это всегда дополнительные вопросы к легитимности его наследника."
    cass "好。用已知的毒药太危险——父亲会直接死掉。但这并非我们所需，因为君主猝死总会让他的继承人合法性上多出许多麻烦。"

# game/a6/2rainy_night.rpy:494
translate english rainy_night4_f95c9fc9:

    # me "И?"
    me "然后呢？"

# game/a6/2rainy_night.rpy:495
translate english rainy_night4_7a3efb55:

    # cass "Но если бы король стал немощным, неспособным выполнять свой монарший долг - ни у кого не возникло бы вопросов к тому, что от его имени правит регент и совет."
    cass "可要是国王变得虚弱无力，无法履行其君主职责——那就没人会对摄政王与议会代其治国提出质疑。"

# game/a6/2rainy_night.rpy:496
translate english rainy_night4_949ae4c6:

    # me "И что же это за яд, способный сделать кого-то немощным?"
    me "那到底是什么样的毒，能让人变得虚弱无力？"

# game/a6/2rainy_night.rpy:497
translate english rainy_night4_464023b7:

    # cass "Это не совсем яд, но действует он еще лучше - жертва просто...засыпает."
    cass "那其实不是真正的毒药，但效果更好——受害者会……陷入沉睡。"

# game/a6/2rainy_night.rpy:498
translate english rainy_night4_87891c90:

    # me "Не яд?"
    me "不是毒药？"

# game/a6/2rainy_night.rpy:499
translate english rainy_night4_a54e2a0c:

    # cass "Белая кровь. Эпидемия бушующая на Западе. Эссенцией из крови больного можно заразить кого угодно этой болезнью. А она сначала приводит к потере сил, а заканчивается длительной летаргией."
    cass "是白死病。正在西方肆虐的瘟疫。用病患血液中提炼的精华，可以让任何人感染此病。它先是使人丧失体力，最终陷入长久的昏睡。"

# game/a6/2rainy_night.rpy:502
translate english rainy_night4_bb67e638:

    # me "Не понимаю. Если отца можно травить незаметно, зачем нам спешить?"
    me "我不明白。既然能神不知鬼不觉地给父王下毒，我们又何必急于求成？"

# game/a6/2rainy_night.rpy:503
translate english rainy_night4_135594c3:

    # cass "Боюсь Присцилла использовала свою возможность для отравления. Так что пытаться отравить отца еще раз - это дополнительный риск быть раскрытыми."
    cass "恐怕Priscilla已经利用她的机会下过毒了。所以再尝试下一次毒，只会平添我们暴露的风险。"

# game/a6/2rainy_night.rpy:504
translate english rainy_night4_f34e0f7a:

    # cass "К тому же именно сейчас в замке больше всего знати, которую можно использовать как заложников против тех, кто не будет к нам лоялен."
    cass "此外，恰是此刻，城堡中聚集了最多可供我们利用的贵族，可以作为牵制那些不忠者的人质。"

# game/a6/2rainy_night.rpy:505
translate english rainy_night4_23d5aaf6:

    # cass "Ну и наконец - Преториус отправился на Запад. Он самый сильный из совета и точно не согласится передать нам власть. Так что лучше действовать, пока он не вернулся."
    cass "最后——普里托里乌斯已经动身前往西方。他是议会中最强大的一人，也绝不会同意把权力交给我们。所以，最好趁他尚未归来时动手。"

# game/a6/2rainy_night.rpy:507
translate english rainy_night4_71cbd534:

    # me "Если отравление вызовет болезнь, зачем кого-то в ней обвинять?"
    me "如果下毒会引发疾病，那为何还要指责某人下毒？"

# game/a6/2rainy_night.rpy:508
translate english rainy_night4_5dac951b:

    # cass "Белая кровь это бич Запада. Здесь ей болеют единицы, так что никто не поверит, будто король заболел белокровием сам."
    cass "白死病是西方之灾。在这里只有极少数人得这种病，所以没人会相信国王是自己染上的此病。"

# game/a6/2rainy_night.rpy:509
translate english rainy_night4_ed822d45:

    # cass "К тому же поиск отравителя это легитимный способ сконцентрировать власть в наших руках."
    cass "此外，追查下毒凶手，是将权力集中在我们手中的合法途径。"

# game/a6/2rainy_night.rpy:511
translate english rainy_night4_d09f15f2:

    # cass "Это крайне маловероятно. Я не слышала о том, чтобы хоть одного человека смогли бы вылечить."
    cass "这可能性微乎其微。我没听说过有谁能被治愈的。"

# game/a6/2rainy_night.rpy:512
translate english rainy_night4_bba2bea0:

    # cass "Но большинство здесь об этом не знает, так что это играет в нашу пользу. Если бы это мы отравили отца, мы бы не стали дожидаться, пока он очнется, верно?"
    cass "但这里的大多数人并不知道这一点，所以这反倒于我们有利。若真是我们毒害了父亲，我们也不会干等着他醒来，不是吗？"

# game/a6/2rainy_night.rpy:517
translate english rainy_night5_a36afec4:

    # cass "Завтра мир изменится...изменится навсегда..."
    cass "明天世界将改变……永远地改变……"

# game/a6/2rainy_night.rpy:518
translate english rainy_night5_423043a6:

    # me "Да..."
    me "是啊……"

# game/a6/2rainy_night.rpy:519
translate english rainy_night5_4a04b018:

    # cass "Не нервничай. У нас все получится."
    cass "别紧张。我们会成功的。"

# game/a6/2rainy_night.rpy:520
translate english rainy_night5_3820771a:

    # me "..."
    me "..."

# game/a6/2rainy_night.rpy:521
translate english rainy_night5_6dae339c:

    # cass "Спи, [mename]."
    cass "睡吧，[mename]。"

# game/a6/2rainy_night.rpy:522
translate english rainy_night5_3820771a_1:

    # me "..."
    me "..."

# game/a6/2rainy_night.rpy:523
translate english rainy_night5_4d902c09:

    # cass "Спи, мой король."
    cass "睡吧，我的国王。"

# game/a6/2rainy_night.rpy:524
translate english rainy_night5_3820771a_2:

    # me "..."
    me "..."

# game/a6/2rainy_night.rpy:525
translate english rainy_night5_9ffd205d:

    # cass "Спи, мой император."
    cass "睡吧，我的皇帝。"

translate english strings:

    # game/a6/2rainy_night.rpy:307
    old "Согласиться на убийство [cass]."
    new "同意谋杀 [cass]。"

    # game/a6/2rainy_night.rpy:307
    old "Не соглашаться"
    new "不同意"

    # game/a6/2rainy_night.rpy:500
    old "Зачем нам спешить?"
    new "我们何必着急？"

    # game/a6/2rainy_night.rpy:500
    old "Зачем обвинять кого-то в отравлении?"
    new "为什么要指控某人下毒？"

    # game/a6/2rainy_night.rpy:500
    old "А если король очнется?"
    new "万一国王醒过来呢？"

    # game/a6/2rainy_night.rpy:500
    old "Больше вопросов нет"
    new "没有问题了。"

