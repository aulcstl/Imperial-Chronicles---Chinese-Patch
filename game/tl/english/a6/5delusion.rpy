    # cass "Тебя это волновать не должно. Я не твоя жена."
    cass "这你不该过问。我又不是你妻子。"

# game/a6/5delusion.rpy:232
translate english delusion2_78ef55d7:

    # me "Ну...крови у тебя нет."
    me "可……你没有流血。"

# game/a6/5delusion.rpy:233
