    # cass "Почти...почти заставил. Но нужно еще постараться."
    cass "快……快做到了。但还得再努力点。"

# game/a6/5delusion.rpy:216
translate english delusion2_651ccc28:

    # cass "..."
    cass "..."

# game/a6/5delusion.rpy:217
translate english delusion2_63107e5b:

    # me "Тебе нравится?"
    me "你喜欢吗？"

# game/a6/5delusion.rpy:218
translate english delusion2_90cd62b2:

    # cass "Да..."
    cass "喜欢……"

# game/a6/5delusion.rpy:219
translate english delusion2_33fd06dc:

    # me "Тогда почему ты не стонешь?"
    me "那你为什么不叫？"

# game/a6/5delusion.rpy:220
translate english delusion2_09a5b9e8:

    # cass "[mename], те уличные девки, которых трахал до меня просто симулировали."
    cass "[mename]，你以前上过的那些街头妓女，她们不过是在装样子罢了。"

# game/a6/5delusion.rpy:221
translate english delusion2_fbe9f9af:

    # me "Что за бред."
    me "什么鬼话。"

# game/a6/5delusion.rpy:222
translate english delusion2_53413cc8:

    # cass "Ну вот все эти крики и закатывания глаз, ты же понимаешь, что все это чушь. Они просто хотели потешить твое самолюбие."
    cass "就是那些尖叫啊，翻白眼啊，你该明白那都是假的吧。她们不过是想满足你的虚荣心。"

# game/a6/5delusion.rpy:223
translate english delusion2_2d3fb7df:

    # me "Зачем им это?"
    me "她们为什么要这样？"

# game/a6/5delusion.rpy:224
