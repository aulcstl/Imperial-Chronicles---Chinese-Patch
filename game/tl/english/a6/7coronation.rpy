# game/a6/7coronation.rpy:428
translate english coronation_red_86286779:

    # me "{size=+6}Так знайте же - все предатели будут наказаны!{/size}"
    me "{size=+6}所以，听好了——所有叛徒都将受到惩罚！{/size}"

# game/a6/7coronation.rpy:429
translate english coronation_red_feb349c3:

    # me "{size=+6}Каждый, кто посмел перечить железной воле отца и пытался нарушить Золотой Порядок, будет казнен.{/size}"
    me "{size=+6}但凡胆敢违抗父亲的铁腕意志、企图扰乱黄金秩序的人，都将被处决。{/size}"

# game/a6/7coronation.rpy:430
translate english coronation_red_3f5378db:

    # me "{size=+6}Даже те, кто были мне семьей.{/size}"
    me "{size=+6}即使是曾经是我的家人。{/size}"

# game/a6/7coronation.rpy:431
translate english coronation_red_749b00d9:

