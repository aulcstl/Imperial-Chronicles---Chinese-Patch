# game/a6/3kings_bounty.rpy:3
translate english kings_bounty_9f2a99fe:

    # "Утром."
    "Morning."

# game/a6/3kings_bounty.rpy:4
translate english kings_bounty_4e956c10:

    # cass "Быстрее. У нас мало времени между пересменками стражи."
    cass "快点。我们换岗之间的时间不多。"

# game/a6/3kings_bounty.rpy:5
translate english kings_bounty_629606e2:

    # me "Я думал твой дядя с этим разберется, заменит нелояльных нам людей."
    me "我以为你舅舅会处理这事，把不忠于我们的人换掉。"

# game/a6/3kings_bounty.rpy:6
translate english kings_bounty_0060e5af:

    # cass "Всех не заменить, в королевской страже почти сотня людей. А если и попытаться - это сразу станет заметным."
    cass "不可能全换掉，王室卫队有近百人。就算想换，也会立刻暴露。"

# game/a6/3kings_bounty.rpy:7
translate english kings_bounty_56ee5c30:

    # me "Понял. Тогда поспешим."
    me "明白了。那就抓紧吧。"

# game/a6/3kings_bounty.rpy:9
translate english kings_bounty_14bf3ea2:

    # guard_a "Стоять!"
    guard_a "站住！"

# game/a6/3kings_bounty.rpy:10
translate english kings_bounty_739e5fc7:

    # guard_b "Кто вы?"
    guard_b "你们是谁？"

# game/a6/3kings_bounty.rpy:11
translate english kings_bounty_1775d20c:

    # cass "Артур, ты нас не узнаешь? Мы же дети короля."
    cass "亚瑟，你不认得我们了？我们是国王的孩子。"

# game/a6/3kings_bounty.rpy:12
translate english kings_bounty_8312798e:

    # me "Я же говорил тебе сменить прическу, все путают тебя кем-то другим."
    me "我跟你说过该换个发型，大家都把你认成别人。"

# game/a6/3kings_bounty.rpy:13
translate english kings_bounty_6ab08c3f:

    # guard_a "Я не о вас. "
    guard_a "我说的不是你们。"

# game/a6/3kings_bounty.rpy:14
translate english kings_bounty_61acb3a6:

    # guard_a "Это что за люди рядом с вами?"
    guard_a "你们身边这些人是谁？"

# game/a6/3kings_bounty.rpy:16
translate english kings_bounty_b843a9b4:

    # cass "Это мои с братом близкие друзья."
    cass "这是我和兄弟的密友。"

# game/a6/3kings_bounty.rpy:17
translate english kings_bounty_32fb38ec:

    # guard_a "Да? И почему они вооружены? В замке разрешено носить оружие только королевской страже."
    guard_a "是吗？那他们为什么带着武器？城堡内只允许王室卫队携带兵器。"

# game/a6/3kings_bounty.rpy:18
translate english kings_bounty_0e120932:

    # cass "Они как раз хотели получить эту должность, верно ребята."
    cass "他们正想申请这个职位，对吧伙计们。"

# game/a6/3kings_bounty.rpy:19
translate english kings_bounty_59df77c3:

    # me "Ага. Мы как раз хотели согласовать это с королем."
    me "嗯。我们正好想跟国王报备这件事。"

# game/a6/3kings_bounty.rpy:20
translate english kings_bounty_2812e3b5:

    # guard_a "Сложите оружие."
    guard_a "放下武器。"

# game/a6/3kings_bounty.rpy:21
translate english kings_bounty_858ec1b0:

    # guard_b "Артур..."
    guard_b "亚瑟……"

# game/a6/3kings_bounty.rpy:22
translate english kings_bounty_2abaa8f2:

    # cass "Прости, но королевский стражник не может сложить оружие без приказа короля."
    cass "抱歉，王室卫兵没有国王命令不能放下武器。"

# game/a6/3kings_bounty.rpy:23
translate english kings_bounty_c8195695:

    # guard_a "Они не королевские стражники."
    guard_a "他们不是王室卫兵。"

# game/a6/3kings_bounty.rpy:24
translate english kings_bounty_4e84e468:

    # me "Но они ими сейчас станут."
    me "但他们马上就是了。"

# game/a6/3kings_bounty.rpy:25
translate english kings_bounty_858ec1b0_1:

    # guard_b "Артур..."
    guard_b "亚瑟……"

# game/a6/3kings_bounty.rpy:27
translate english kings_bounty_b32f4281:

    # guard_a "Ну что?"
    guard_a "怎么？"

# game/a6/3kings_bounty.rpy:28
translate english kings_bounty_6f71a13b:

    # guard_b "Если они сюда попали с оружием..."
    guard_b "如果他们带着武器闯进这里……"

# game/a6/3kings_bounty.rpy:29
translate english kings_bounty_c2b4b631:

    # guard_a "Что с того? Исполняй свой долг."
    guard_a "那又如何？履行你的职责。"

# game/a6/3kings_bounty.rpy:30
translate english kings_bounty_584a4ced:

    # guard_b "Помнишь, что говорил каменный советник? Если они здесь и с оружием, значит..."
    guard_b "还记得磐石大臣说过的话吗？如果他们带武器出现在这里，那就意味着……"

# game/a6/3kings_bounty.rpy:31
translate english kings_bounty_64770ba6:

    # guard_a "...значит он такой же предатель, как и они."
    guard_a "……意味着他和他们一样是叛徒。"

# game/a6/3kings_bounty.rpy:32
translate english kings_bounty_57dd0e55:

    # cass "Не стоит разбрасываться такими громкими словами."
    cass "别乱用这么严重的词。"

# game/a6/3kings_bounty.rpy:34
translate english kings_bounty_c1de5835:

    # me "Артур, вы обвиняете старших детей короля в предательстве."
    me "亚瑟，你在指控国王的长子长女叛国。"

# game/a6/3kings_bounty.rpy:35
translate english kings_bounty_9c0d17fe:

    # cass "Какой ужас, да сам видимо клятвоотступник."
    cass "真可怕，看来你自己就是个背誓者。"

# game/a6/3kings_bounty.rpy:36
translate english kings_bounty_155fb15d:

    # me "Боюсь если начнется расследование и мы узнаем, что вы не были лояльны королевской власти..."
    me "恐怕一旦展开调查，发现你对王室不够忠诚的话……"

# game/a6/3kings_bounty.rpy:37
translate english kings_bounty_6f561e17:

    # cass "Чья-то голова окажется на плахе."
    cass "某人就要人头落地了。"

# game/a6/3kings_bounty.rpy:38
translate english kings_bounty_122ee076:

    # me "Ты, Морган, кажешься разумнее. Ты уступишь нашему законному требованию увидеть нашего дорого и любимого отца?"
    me "你，摩根，看起来更明事理。你会同意我们合法探望至亲至爱的父亲吧？"

# game/a6/3kings_bounty.rpy:39
translate english kings_bounty_678a857d:

    # guard_a "Не слушай их!"
    guard_a "别听他们胡说！"

# game/a6/3kings_bounty.rpy:40
translate english kings_bounty_f358ee1c:

    # cass "Артур, твое упорство вызывает вопросы."
    cass "亚瑟，你的固执令人起疑。"

# game/a6/3kings_bounty.rpy:41
translate english kings_bounty_d123b7dc:

    # me "Верно. Как думаешь, он не дает нам увидеть короля, потому что с ним что-то не так?"
    me "没错。你说，他不让我们见国王，是不是因为国王出事了？"

# game/a6/3kings_bounty.rpy:42
translate english kings_bounty_23f603ae:

    # cass "Думаешь он убил нашего отца?"
    cass "你觉得他谋害了我们的父亲？"

# game/a6/3kings_bounty.rpy:44
translate english kings_bounty_4cf049ca:

    # guard_a "Ну хватит, немедленно объяснитесь, зачем вы здесь и кто эти люди?"
    guard_a "够了，立刻解释清楚，你们来这里做什么，这些人又是谁？"

# game/a6/3kings_bounty.rpy:45
translate english kings_bounty_3101147b:

    # me "Что-то еще?"
    me "还有什么要说的？"

# game/a6/3kings_bounty.rpy:46
translate english kings_bounty_2e173ebd:

    # guard_a "Пусть они немедленно сложат оружие или пусть убираются отсюда."
    guard_a "让他们立刻卸下武器，要么就从这里滚出去。"

# game/a6/3kings_bounty.rpy:47
translate english kings_bounty_5c682de8:

    # cass "Морган, у тебя еще есть шанс правильно поступить..."
    cass "摩根，你还有机会做出正确选择……"

# game/a6/3kings_bounty.rpy:48
translate english kings_bounty_ab450db3:

    # guard_a "Заткнись, я считаю до трех, и если вы не уберетесь или не сложите оружие, я разоружу вас сам."
    guard_a "闭嘴，我数到三，如果你们既不离开也不放下武器，我就亲手缴了你们的械。"

# game/a6/3kings_bounty.rpy:49
translate english kings_bounty_d981de72:

    # guard_a "Один..."
    guard_a "一……"

# game/a6/3kings_bounty.rpy:50
translate english kings_bounty_c38f72c6:

    # guard_a "Два..."
    guard_a "二……"

# game/a6/3kings_bounty.rpy:52
translate english kings_bounty_12036e31:

    # guard_a "Ах! СУКИН СЫН!"
    guard_a "啊！狗娘养的！"

# game/a6/3kings_bounty.rpy:53
translate english kings_bounty_628a079b:

    # guard_b "Прости, Артур."
    guard_b "对不起，亚瑟。"

# game/a6/3kings_bounty.rpy:55
translate english kings_bounty_ef3d589f:

    # guard_b "Простите...простите..."
    guard_b "对不起……对不起……"

# game/a6/3kings_bounty.rpy:56
translate english kings_bounty_1ef55820:

    # cass "За что ты извиняешься? Ты молодец."
    cass "你道什么歉？做得漂亮。"

# game/a6/3kings_bounty.rpy:57
translate english kings_bounty_2f4daeea:

    # me "Ты обнаружил предателя короны. Ты должен быть награжден."
    me "你发现了王室的叛徒，理应受赏。"

# game/a6/3kings_bounty.rpy:58
translate english kings_bounty_b34779cb:

    # cass "Верно. Как думаешь, какую награду ему дать?"
    cass "没错。你觉得该给他什么奖赏？"

# game/a6/3kings_bounty.rpy:59
translate english kings_bounty_00743b81:

    # guard_b "Меня не за что награждать... я убил своего боевого товарища..."
    guard_b "我不配受赏……我杀害了自己的战友……"

# game/a6/3kings_bounty.rpy:60
translate english kings_bounty_d9b45cc8:

    # cass "Ну что ты. Не будь к себе так строг!"
    cass "哎，别这样，对自己太苛刻了。"

# game/a6/3kings_bounty.rpy:62
translate english kings_bounty_008444a0:

    # cass "Ты ведь был вынужден это сделать, понимаешь?"
    cass "你也是迫不得已，懂吗？"

# game/a6/3kings_bounty.rpy:63
translate english kings_bounty_47fae1c0:

    # guard_b "Да..."
    guard_b "是……"

# game/a6/3kings_bounty.rpy:64
translate english kings_bounty_26b05fca:

    # cass "Ты вступил в неравный бой с предателями короны и героически стражался, верно?"
    cass "你与叛徒们英勇搏斗，浴血奋战，对不对？"

# game/a6/3kings_bounty.rpy:65
translate english kings_bounty_e29fae13:

    # guard_b "Да, моя госпожа."
    guard_b "是的，我的公主。"

# game/a6/3kings_bounty.rpy:66
translate english kings_bounty_ab7049be:

    # cass "Ты раскрыл предательство в самом сердце замка и тебе пришлось действовать решительно."
    cass "你揭发了城堡核心的叛徒，不得不果断行事。"

# game/a6/3kings_bounty.rpy:67
translate english kings_bounty_89886147:

    # guard_b "Да."
    guard_b "是。"

# game/a6/3kings_bounty.rpy:68
translate english kings_bounty_fc7fbc12:

    # cass "Ты был верен клятве до конца."
    cass "你至死忠于誓言。"

# game/a6/3kings_bounty.rpy:69
translate english kings_bounty_89886147_1:

    # guard_b "Да."
    guard_b "是。"

# game/a6/3kings_bounty.rpy:70
translate english kings_bounty_81b0dc14:

    # cass "Жаль, что ты погиб исполняя свой великий долг."
    cass "可惜你尽忠职守时英勇牺牲了。"

# game/a6/3kings_bounty.rpy:72
translate english kings_bounty_bb839650:

    # guard_b "Погиб? ЧТо..ААА!"
    guard_b "牺牲？什么……啊啊啊！"

# game/a6/3kings_bounty.rpy:73
translate english kings_bounty_769f7b6b:

    # cass "Корона не забудет твоей верной службы, Морган."
    cass "王室不会忘记你的忠诚服务，摩根。"

# game/a6/3kings_bounty.rpy:74
translate english kings_bounty_861e5112:

    # guard_b "Агрххх...."
    guard_b "呃啊……"

# game/a6/3kings_bounty.rpy:76
translate english kings_bounty_b2e3c47f:

    # me "Он мог бы нам пригодится."
    me "他本可以对我们有用。"

# game/a6/3kings_bounty.rpy:77
translate english kings_bounty_4cde9270:

    # cass "Это еще зачем?"
    cass "有什么用？"

# game/a6/3kings_bounty.rpy:78
translate english kings_bounty_785e0849:

    # me "Был бы свидетелем нашей версии того, что случилось с королем."
    me "可以做我们关于国王事件说法的证人。"

# game/a6/3kings_bounty.rpy:79
translate english kings_bounty_eaff5c82:

    # cass "Я не работаю с предателями."
    cass "我不跟叛徒合作。"

# game/a6/3kings_bounty.rpy:80
translate english kings_bounty_0b794518:

    # me "Забыла кто мы?"
    me "忘了我们是什么人了？"

# game/a6/3kings_bounty.rpy:81
translate english kings_bounty_d8758248:

    # cass "Мы предаем ради власти, а не из страха за свою шкуру. Завтра кто-то еще напугает его и он из свидетеля защиты станет свидетелем обвинения."
    cass "我们为权力背叛，而不是因为怕死。明天别人吓吓他，他就会从辩护证人变成指控证人。"

# game/a6/3kings_bounty.rpy:82
translate english kings_bounty_5369559b:

    # me "Ладно. Ты права. Пойдем уже внутрь."
    me "好吧，你说得对。我们进去吧。"

# game/a6/3kings_bounty.rpy:84
translate english kings_bounty_5f497088:

    # doc "Что там за шум?"
    doc "那边什么动静？"

# game/a6/3kings_bounty.rpy:85
translate english kings_bounty_419feb5e:

    # king "Это мешает вам?"
    king "打扰到您了吗？"

# game/a6/3kings_bounty.rpy:86
translate english kings_bounty_d3404a45:

    # doc "Да, ваше величество, в этот раз гнилой кожи больше обычного, вот черт, надо было принести свой стул."
    doc "是的，陛下，这次腐肉味比平时更重，该死，真该自己带把椅子来。"

# game/a6/3kings_bounty.rpy:87
translate english kings_bounty_8ee15134:

    # king "Неужели стало настолько хуже."
    king "已经恶化到这种程度了？"

# game/a6/3kings_bounty.rpy:88
translate english kings_bounty_30b239d6:

    # doc "Не смею усомниться в вашей исполнительности, ваше величество, но выглядит так, будто вы не следуете моим советам."
    doc "不敢质疑您的勤勉，陛下，但看起来您并未听从我的建议。"

# game/a6/3kings_bounty.rpy:89
translate english kings_bounty_48b80e93:

    # king "Верно. Боюсь я был слишком занят последнее время."
    king "没错，恐怕最近我太忙了。"

# game/a6/3kings_bounty.rpy:91
translate english kings_bounty_df7bce12:

    # doc "Куда? Рано! Не видите я еще работаю!"
    doc "去哪儿？还早呢！没看见我还在工作吗！"

# game/a6/3kings_bounty.rpy:92
translate english kings_bounty_d034afb5:

    # cass "Спокойно, старик."
    cass "冷静点，老头。"

# game/a6/3kings_bounty.rpy:93
translate english kings_bounty_44788c84:

    # doc "Во время обработки ран, здесь никого быть не должно."
    doc "处理伤口时不该有旁人。"

# game/a6/3kings_bounty.rpy:94
translate english kings_bounty_416818c9:

    # cass "Заткнись."
    cass "闭嘴。"

# game/a6/3kings_bounty.rpy:95
translate english kings_bounty_ed35be0d:

    # doc "Да как вы смеете!"
    doc "你竟敢！"

# game/a6/3kings_bounty.rpy:97
translate english kings_bounty_e4331425:

    # me "Старик. Закрой. Свой. Рот. Я предупреждаю тебя в последний раз."
    me "老头，闭上你的嘴。最后警告你一次。"

# game/a6/3kings_bounty.rpy:98
translate english kings_bounty_2ea3e79e:

    # cass "Лучше послушай его, или тебя придется лечить самого себя."
    cass "最好听他的，否则你就得自己治自己了。"

# game/a6/3kings_bounty.rpy:99
translate english kings_bounty_cdcb64b1:

    # doc "Л-ладно..."
    doc "好……好吧……"

# game/a6/3kings_bounty.rpy:100
translate english kings_bounty_575a991a:

    # cass "Молодец. А теперь медленно выйди за дверь. Моим друзьям очень нужна медицинская консультация. Ты меня понял?"
    cass "真乖。现在慢慢走出门去。我的朋友们急需医疗咨询，你明白吗？"

# game/a6/3kings_bounty.rpy:101
translate english kings_bounty_5a284704:

    # doc "Я понял."
    doc "明白。"

# game/a6/3kings_bounty.rpy:102
translate english kings_bounty_b890a627:

    # me "Раз понял, то иди."
    me "明白就出去。"

# game/a6/3kings_bounty.rpy:104
translate english kings_bounty_3ac5248f:

    # cass "Фуу, та у нас тут уже гнилой труп. Слушай, может нам действительно надо было подождать месяцок?"
    cass "咦，这个腐烂的尸体还在这儿呢。话说我们是不是真该等一两个月再来？"

# game/a6/3kings_bounty.rpy:105
translate english kings_bounty_d81f91ec:

    # king "И как это понимать?"
    king "这算什么话？"

# game/a6/3kings_bounty.rpy:106
translate english kings_bounty_e982fb65:

    # me "Что именно? Наше вторжение?"
    me "你指什么？我们的闯入吗？"

# game/a6/3kings_bounty.rpy:107
translate english kings_bounty_1fe98e07:

    # cass "Понимай, как хочешь, старик. Мы здесь не для того, чтобы выслушивать твои вопросы и нравоучения."
    cass "随你怎么想，老头。我们不是来听你质问和说教的。"

# game/a6/3kings_bounty.rpy:108
translate english kings_bounty_c90e12bc:

    # king "Зачем же вы здесь?"
    king "那你们来做什么？"

# game/a6/3kings_bounty.rpy:109
translate english kings_bounty_a69ba350:

    # me "А ты не понимаешь?"
    me "你还不明白？"

# game/a6/3kings_bounty.rpy:110
translate english kings_bounty_2ec8b0cb:

    # king "Отцеубийство страшный грех. Свершивший это будет проклят."
    king "弑父是弥天大罪。行此罪者必遭诅咒。"

# game/a6/3kings_bounty.rpy:111
translate english kings_bounty_85846120:

    # cass "А если мы делаем это из милосердия?"
    cass "如果我们是出于仁慈这么做呢？"

# game/a6/3kings_bounty.rpy:112
translate english kings_bounty_54353551:

    # king "[cassa]..."
    king "[cassa]..."

# game/a6/3kings_bounty.rpy:113
translate english kings_bounty_db8d29be:

    # cass "Что? Хочешь сказать я не права? Он тебя воняет как от тухлого кабана."
    cass "怎么？想说我不对吗？他闻起来就像头腐烂的野猪。"

# game/a6/3kings_bounty.rpy:114
translate english kings_bounty_b7fbc5bb:

    # me "Прекрати..."
    me "别说了……"

# game/a6/3kings_bounty.rpy:116
translate english kings_bounty_75aa1a14:

    # cass "Нет. Ну действительно же! Мне кажется я даже вижу кость! Отвратительно. Как ты еще ходишь."
    cass "不，真的！我好像都看见骨头了！恶心。你这副样子怎么还能走动？"

# game/a6/3kings_bounty.rpy:117
translate english kings_bounty_1b416918:

    # me "Мы здесь не за этим."
    me "我们不是为这事来的。"

# game/a6/3kings_bounty.rpy:118
translate english kings_bounty_5cca60ea:

    # cass "Хватит мешать мне наслаждаться моими последними минутами с отцом."
    cass "别打扰我享受与父亲最后的几分钟。"

# game/a6/3kings_bounty.rpy:119
translate english kings_bounty_54353551_1:

    # king "[cassa]..."
    king "[cass]..."

# game/a6/3kings_bounty.rpy:120
translate english kings_bounty_7bcc2204:

    # cass "Да, любимый отец?"
    cass "对吧，亲爱的父亲？"

# game/a6/3kings_bounty.rpy:121
translate english kings_bounty_b01bac39:

    # king "Я хочу чтобы ты знала..."
    king "我想让你知道……"

# game/a6/3kings_bounty.rpy:122
translate english kings_bounty_9ec8dd7e:

    # cass "Ой, погоди, я вспомнила - мне насрать, что ты хочешь мне сказать. Заткнись."
    cass "哦，等等，我想起来了——我才不在乎你要说什么，闭嘴。"

# game/a6/3kings_bounty.rpy:123
translate english kings_bounty_7ae19ed6:

    # me "[cass]. Не надо."
    me "[cass]。别这样。"

# game/a6/3kings_bounty.rpy:125
translate english kings_bounty_dc23a891:

    # cass "Ну ладно-ладно. Простите за грубость. Я думала мы здесь для коварного предательства и мне не нужно соблюдать дворцовый этикет."
    cass "好好好，抱歉失礼了。我以为我们是来干阴险背叛的勾当，不用遵守宫廷礼仪。"

# game/a6/3kings_bounty.rpy:126
translate english kings_bounty_32896cef:

    # king "[mename]..."
    king "[mename]..."

# game/a6/3kings_bounty.rpy:127
translate english kings_bounty_fc30fd2b:

    # me "Да."
    me "是。"

# game/a6/3kings_bounty.rpy:128
translate english kings_bounty_9a9a68cc:

    # king "Ты то меня выслушаешь?"
    king "那你会听我说吗？"

# game/a6/3kings_bounty.rpy:129
translate english kings_bounty_68da4c93:

    # me "Попробую."
    me "尽量。"

# game/a6/3kings_bounty.rpy:130
translate english kings_bounty_2101a93b:

    # cass "Ты серьезно?"
    cass "你是认真的？"

# game/a6/3kings_bounty.rpy:131
translate english kings_bounty_797be9ea:

    # me "Дай нам пару минут."
    me "给我们两分钟。"

# game/a6/3kings_bounty.rpy:132
translate english kings_bounty_0a4aa51a:

    # cass "Ух...ладно."
    cass "呃……好吧。"

# game/a6/3kings_bounty.rpy:134
translate english kings_bounty_9f8093c3:

    # me "Говори."
    me "说吧。"

# game/a6/3kings_bounty.rpy:135
translate english kings_bounty_f054b295:

    # king "Не делай этого."
    king "别这么做。"

# game/a6/3kings_bounty.rpy:136
translate english kings_bounty_6671c266:

    # me "Пути назад нет."
    me "已经没有回头路了。"

# game/a6/3kings_bounty.rpy:137
translate english kings_bounty_ee930223:

    # king "Я говорю о проклятии не просто так. Боги карают за отцеубийство самым страшным образом. Поверь мне, я знаю о чем говорю."
    king "我提到诅咒不是白说的。诸神会用最可怕的方式惩罚弑父之人。相信我，我说这话是有根据的。"

# game/a6/3kings_bounty.rpy:138
translate english kings_bounty_6ab40291:

    # me "Мы не собираемся тебя убивать. Не так как ты думаешь..."
    me "我们不打算杀你，不是你想的那样……"

# game/a6/3kings_bounty.rpy:139
translate english kings_bounty_a86ba12c:

    # king "Не понимаю...Объясни мне."
    king "我不明白……解释一下。"

# game/a6/3kings_bounty.rpy:140
translate english kings_bounty_e7b7cb8a:

    # me "У нас идея получше..."
    me "我们有个更好的主意……"

# game/a6/3kings_bounty.rpy:141
translate english kings_bounty_2b8cde8a:

    # cass "Лучше не раскрывай ему карты, еще начнет вырываться."
    cass "最好别对他摊牌，否则他会拼命挣扎。"

# game/a6/3kings_bounty.rpy:142
translate english kings_bounty_fd2c030a:

    # king "Я не буду вам мешать. Я позволю вам сделать все что вы хотите."
    king "我不会阻碍你们。我会任凭你们处置。"

# game/a6/3kings_bounty.rpy:143
translate english kings_bounty_35fb71d8:

    # me "К чему такая неожиданная покорность? Стало интересно что мы для тебя придумали?"
    me "怎么突然这么顺从了？是不是好奇我们为你准备了什么？"

# game/a6/3kings_bounty.rpy:144
translate english kings_bounty_79632a66:

    # king "...Все это было предрешено. Я пытался изменить судьбу, но все пророки, настоящие пророки, а не те, что подсылала мне твоя мать, все они говорили одно."
    king "……这一切早已注定。我试图改变命运，但所有先知，真正的先知，不是你母亲安插的那些，他们全都说着同样的话。"

# game/a6/3kings_bounty.rpy:145
translate english kings_bounty_6bb4e0e6:

    # cass "Не могу слушать эту чушь."
    cass "听不下去了，都是胡言乱语。"

# game/a6/3kings_bounty.rpy:146
translate english kings_bounty_340899b0:

    # king "Меня погубит мое самое могучее семя. Все ваше детство я смотрел на вас и думал, кто из вас двоих это будет, а теперь понял...вы оба..."
    king "我最强大的子嗣会毁掉我。你们童年时我一直看着你们，琢磨会是你们中的哪一个，现在我明白了……你们俩都是……"

# game/a6/3kings_bounty.rpy:149
translate english kings_bounty_33723fdb:

    # king "Единственное чего я не могу понять...[mename], я же сделал тебя своим наследником. Зачем тебе это?"
    king "我唯一不明白的是……[mename]，我已经立你为继承人。你图什么？"

# game/a6/3kings_bounty.rpy:150
translate english kings_bounty_1af9e34d:

    # cass "Не отвечай...."
    cass "别回答……"

# game/a6/3kings_bounty.rpy:151
translate english kings_bounty_25793774:

    # me "Все нормально. Я объясню. Видишь ли, дорогой отец, годы проведенные в изгнании научили меня ценить время."
    me "没事，我来解释。你看，亲爱的父亲，流放岁月教会我珍惜时间。"

# game/a6/3kings_bounty.rpy:152
translate english kings_bounty_91e29b44:

    # me "Я бы мог подождать, пока ты умрешь, но я если честно я больше не хочу рисковать. Если даже статус старшего сына короля не спасает от его безумных решений, может корона спасет?"
    me "我本可以等你慢慢咽气，但老实说，我不想再冒险了。既然国王长子的身份都保护不了我不受你疯狂决策的伤害，或许戴上王冠能？"

# game/a6/3kings_bounty.rpy:153
translate english kings_bounty_c254e16b:

    # king "Я спасал тебя..."
    king "我那是在救你……"

# game/a6/3kings_bounty.rpy:154
translate english kings_bounty_cad0cc15:

    # cass "Видишь? Этот ублюдок будет требовать благодарности даже если отрежет тебя яица. Скажет это для твоей защиты от порочных женщин."
    cass "看见没？这杂种就算割了你的蛋也会要你感激，还说是为了保护你免受淫荡女人的危害。"

# game/a6/3kings_bounty.rpy:155
translate english kings_bounty_ed65de03:

    # me "Ну что, может быть он объяснит свои слова?"
    me "怎么，也许他会解释一下这话的意思？"

# game/a6/3kings_bounty.rpy:156
translate english kings_bounty_fc61d557:

    # king "Теперь это не имеет значения. Что бы я не сказал, ты сделаешь то, что сделаешь."
    king "现在这些已经不重要了。不管我说什么，你都会照做你想做的事。"

# game/a6/3kings_bounty.rpy:157
translate english kings_bounty_380173da:

    # cass "Перевожу с языка лживого говна - за все эти годы он так и не придумал зачем это сделал."
    cass "我来翻译下他的谎言和屁话——这些年他根本没想出当初为什么这么做。"

# game/a6/3kings_bounty.rpy:158
translate english kings_bounty_cdfb3134:

    # king "..."
    king "..."

# game/a6/3kings_bounty.rpy:160
translate english kings_bounty_d3c47fff:

    # me "Ладно. Хватит разговоров. Эссенция у тебя."
    me "好了，别废话了。精髓在你身上吗？"

# game/a6/3kings_bounty.rpy:161
translate english kings_bounty_e1ac6ff7:

    # cass "Да. Сейчас будет немного больно."
    cass "在。现在会有一点疼。"

# game/a6/3kings_bounty.rpy:162
translate english kings_bounty_47296d15:

    # king "Зачем это..."
    king "这是干什么……"

# game/a6/3kings_bounty.rpy:163
translate english kings_bounty_a445a468:

    # cass "Для тебя это уже не имеет значения."
    cass "对你来说已经不重要了。"

# game/a6/3kings_bounty.rpy:164
translate english kings_bounty_a9011fac:

    # king "Ах..."
    king "啊……"

# game/a6/3kings_bounty.rpy:165
translate english kings_bounty_8222fe3f:

    # me "И как быстро это подействует?"
    me "这东西多久起效？"

# game/a6/3kings_bounty.rpy:166
translate english kings_bounty_bb75b89f:

    # cass "Не знаю. Пойдем, у нас много других дел."
    cass "不知道。走吧，我们还有很多事。"

# game/a6/3kings_bounty.rpy:167
translate english kings_bounty_9ccc8c8a:

    # me "А отец?"
    me "父亲怎么办？"

# game/a6/3kings_bounty.rpy:168
translate english kings_bounty_78d09a6e:

    # cass "Мои друзья о нем позаботятся."
    cass "我的朋友们会照顾他。"

# TODO: Translation updated at 2025-03-11 02:51

# game/a6/3kings_bounty.rpy:42
translate english kings_bounty_4c817c35:

    # me "Ты, Морган, кажешься разумнее. Ты уступишь нашему законному требованию увидеть нашего дорогого и любимого отца?"
    me "你，摩根，看起来更明事理。你会同意我们合法探望至亲至爱的父亲吧？"

# game/a6/3kings_bounty.rpy:115
translate english kings_bounty_26a74360:

    # cass "Фуу, так у нас тут уже гнилой труп. Слушай, может нам действительно надо было подождать месяцок?"
    cass "咦，这个腐烂的尸体还在这儿呢。话说我们是不是真该等一两个月再来？"

# game/a6/3kings_bounty.rpy:127
translate english kings_bounty_ad1919bf:

    # cass "Нет. Ну действительно же! Мне кажется я даже вижу кость! Отвратительно. Как ты еще ходишь?"
    cass "不，真的！我好像都看见骨头了！恶心。你这副样子怎么还能走动？"

# game/a6/3kings_bounty.rpy:165
translate english kings_bounty_54c6ad42:

    # cass "Видишь? Этот ублюдок будет требовать благодарности даже если отрежет тебя яйца. Скажет это для твоей защиты от порочных женщин."
    cass "看见没？这杂种就算割了你的蛋也会要你感激，还说是为了保护你免受淫荡女人的危害。"
