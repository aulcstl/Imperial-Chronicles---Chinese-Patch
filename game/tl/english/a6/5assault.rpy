    # me "Я знаю."
    me "我知道。"

# game/a6/5assault.rpy:418
translate english assault2_93373dbd:

    # cass "Еще она мерзкая лицемерная мразь, вместе со мной клялась отомстить отцу, когда ее братца изгнали, а в итоге смирилась."
    cass "她还是个恶心虚伪的贱人，当初我弟弟被流放时，她跟我一起发誓要向父亲复仇，结果最后她却服软了。"

# game/a6/5assault.rpy:419
translate english assault2_b7a5fdbe:

    # me "Ты мстила за меня бросив меня в темницу?"
    me "你为了替我复仇就把我扔进地牢？"

# game/a6/5assault.rpy:420
translate english assault2_7f7487cb:

    # cass "Я тебя спасала. Я хотела дать тебе корону, забыл?"
    cass "我是在救你。我想把王冠给你，忘了？"

# game/a6/5assault.rpy:421
translate english assault2_725b59e6:

    # elin "О чем она?"
    elin "她在说什么？"

# game/a6/5assault.rpy:422
translate english assault2_788f8e0d:

    # cass "Расскажи. Расскажи этой дуре, что всего этого можно было избежать."
    cass "告诉她。告诉这个傻女人，这一切本是可以避免的。"

# game/a6/5assault.rpy:423
translate english assault2_00aec455:

    # me "Твое предложение занять место отца было отвратительно. Я могу любить или ненавидеть отца, но я уважаю и чту золотой порядок."
    me "你那个取代父亲的提议令人作呕。我可以爱或恨我的父亲，但我尊重并遵守黄金秩序。"

# game/a6/5assault.rpy:424
translate english assault2_aeaa75c8:

    # cass "Ты раб!"
    cass "你这个奴隶！"

# game/a6/5assault.rpy:425
translate english assault2_6a8f6917:

    # me "Уведите ее."
    me "把她带走。"

# game/a6/5assault.rpy:427
translate english assault2_0bb11aff:

    # cass "{size=+5}РАБ!{/size}"
    cass "{size=+5}奴隶！{/size}"

# game/a6/5assault.rpy:428
translate english assault2_ff86d95f:

    # me "Приставьте к ней хорошую охрану."
    me "给她配上最好的卫兵。"

# game/a6/5assault.rpy:429
translate english assault2_130bad8b:

    # cass "{size=-5}Все вы...все вы просто смирились.{/size}"
    cass "{size=-5}你们所有人...你们全都只是屈服了。{/size}"

# game/a6/5assault.rpy:430
translate english assault2_12814f6e:

    # me "И проследите, чтобы она с собой ничего не сделала."
    me "看紧她，确保她不会对自己做什么。"

# game/a6/5assault.rpy:431
translate english assault2_765ae806:

    # cass "{size=-5}Все вы просто терпите или забываете...{/size}"
    cass "{size=-5}你们全都只是忍耐着或遗忘着...{/size}"

# game/a6/5assault.rpy:432
translate english assault2_05896019:

    # elin "Она может знать..."
    elin "她可能知道..."

# game/a6/5assault.rpy:433
translate english assault2_654e604b:

    # me "Она ничего не скажет. Разве ты не стояла тут, со мной?"
