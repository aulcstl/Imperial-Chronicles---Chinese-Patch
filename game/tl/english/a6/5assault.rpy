translate english assault2_2b8f4689:

    # cass "{size=-5}Как же я вас всех ненавижу.{/size}"
    cass "{size=-5}我有多恨你们所有人。{/size}"

# game/a6/5assault.rpy:436
translate english assault2_f5290d00:

    # me "Попробуй."
    me "试试吧。"

# game/a6/5assault.rpy:437
translate english assault2_e7150899:

    # sold1 "Герцог Леонард! В подземелье пленные гости!"
    sold1 "Leonard公爵！地牢里有被俘的宾客！"

# game/a6/5assault.rpy:438
translate english assault2_db5c8e78:

    # leonard "Пойдем проверим."
    leonard "我们去看看。"

# game/a6/5assault.rpy:440
