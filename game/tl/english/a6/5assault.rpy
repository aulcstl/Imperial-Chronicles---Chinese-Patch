    # leonard "Ее люди?"
    leonard "她的人？"

# game/a6/5assault.rpy:441
translate english assault2_f3a92ba3:

    # sold1 "Никого нет, все сбежали."
    sold1 "一个人都没有，都跑了。"

# game/a6/5assault.rpy:442
translate english assault2_767e705f:

    # leonard "Трусы..."
    leonard "懦夫..."

# game/a6/5assault.rpy:443
translate english assault2_fac19de1:

    # me "Я видел тела во дворе."
    me "我在院子里看到了尸体。"

# game/a6/5assault.rpy:444
translate english assault2_eff0c7db:

    # leonard "Человек десять сразились с нами, люди [cass] и идиоты, что ей поверили."
    leonard "大概有十个人和我们交战了，是[cass]的人和那些相信了她的白痴。"

