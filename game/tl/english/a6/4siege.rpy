    elin "嗯。好。我下次见到他，会帮你问问你母亲的情况。"

# game/a6/4siege.rpy:332
translate english siege_33c2e7a8:

    # lockhart "Ты в норме?"
    lockhart "你还好吗？"

# game/a6/4siege.rpy:333
