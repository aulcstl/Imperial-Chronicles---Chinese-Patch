    # cassius "Ну...он победил. Думаю теперь выборы не понадобятся."
    cassius "行吧……他赢了。看来选举是用不着了。  "

# game/a9/5rebels.rpy:223
translate english rebels2_d355dc3b:

    # me "О чем ты?"
    me "什么意思？  "

# game/a9/5rebels.rpy:224
translate english rebels2_edcaff76:

    # valerian "Выборы. Когда мы окончательно победим, нужно будет выбрать..."
    valerian "选举。等我们最终获胜，就得选出一位……  "

# game/a9/5rebels.rpy:225
translate english rebels2_63e4b3b8:

    # me "...короля Запада."
    me "……西部之王。  "

# game/a9/5rebels.rpy:226
translate english rebels2_2ade1843:

    # valerian "Ну, титул будет звучать не так..."
    valerian "唔，头衔当然不会叫这个……  "

# game/a9/5rebels.rpy:227
translate english rebels2_9c10f866:

    # cassius "После того, что произошло, думаю его бы и королем выбрали."
    cassius "经过方才的事，哪怕选他当国王大家也认。  "

# game/a9/5rebels.rpy:228
translate english rebels2_b9908eee:

    # me "Что насчет клинка?"
    me "这剑怎么办？  "

# game/a9/5rebels.rpy:229
translate english rebels2_bd79ba7c:

    # valerian "Можешь пока оставить его себе."
    valerian "你先留着吧。  "

# game/a9/5rebels.rpy:230
translate english rebels2_c91ef262:

    # cassius "Генри дал четкие указания. К тому же теперь это наш Император. У него и так вся полнота власти."
    cassius "亨利交代得很明确。更何况他现在是我们的皇帝。他本就掌握全权。  "

# game/a9/5rebels.rpy:231
translate english rebels2_423043a6:

    # me "Да..."
    me "是啊……  "

# game/a9/5rebels.rpy:232
translate english rebels2_f5b96d50:

    # cassius "Ну так что, мой император? Вы выбрали?"
    cassius "那么，我的皇帝？您选好人了吗？  "

# game/a9/5rebels.rpy:233
translate english rebels2_fc30fd2b:

    # me "Да."
    me "选好了。  "

# game/a9/5rebels.rpy:237
translate english rebels2_e14d0f16:

    # me "Держи. Ты тут заслуживаешь его больше всего."
    me "拿着。在这儿，你比谁都配得上它。  "

# game/a9/5rebels.rpy:238
translate english rebels2_948f37fa:

    # cassius "Благодарю, мой Император."
    cassius "感谢您，我的皇帝。  "

# game/a9/5rebels.rpy:239
translate english rebels2_a5791a39:

    # me "Что будем делать дальше?"
    me "接下来我们做什么？  "

# game/a9/5rebels.rpy:240
translate english rebels2_f73e3c2f:

    # cassius "Если люди Аргуса отступят - нашей главной заботой станут лорды Темногорья и Курании."
    cassius "如果阿尔古斯的人退兵——我们的主要麻烦就成了黑山和库拉尼亚的领主们。  "

# game/a9/5rebels.rpy:241
translate english rebels2_9852c7fa:

    # me "Но ведь Гвидон мертв."
    me "可格维东已经死了。  "

# game/a9/5rebels.rpy:242
translate english rebels2_0303e7b5:

    # cassius "Мертв. Но его сын пока не обозначил сторону. Можно начать с переговоров. С агрессивных переговоров. Я соберу армию и она встретит армию вассалов вашего отца."
    cassius "死了。但他儿子还没表态。我们可以先谈判。带着军威去谈判。我会集结一支军队，同您父亲的封臣军队会合。  "

# game/a9/5rebels.rpy:243
translate english rebels2_ac03e156:

    # cassius "С тысячами воинов под стенами, сыну лорда Гвидона будет легче принять нашу сторону."
    cassius "有成千上万的战士兵临城下，格维东领主之子的选择就容易多了。  "

# game/a9/5rebels.rpy:244
translate english rebels2_b192f51a:

    # me "Но мы ведь убили его отца."
    me "可我们杀了他的父亲。  "

# game/a9/5rebels.rpy:245
translate english rebels2_ffbdb983:

    # cassius "Ну что вы, мой Император. Это сделали подлые эльфы."
    cassius "哪里的话，我的皇帝。那是卑鄙的精灵干的。  "

# game/a9/5rebels.rpy:246
translate english rebels2_9b079687:

    # me "Понимаю...когда выступаем?"
    me "懂了……我们何时出发？  "

# game/a9/5rebels.rpy:247
translate english rebels2_35d26ff8:

    # cassius "Дайте мне пару дней собрать людей."
    cassius "给我两天时间集结人马。  "

# game/a9/5rebels.rpy:248
translate english rebels2_71d3b8c8:

    # me "Хорошо."
    me "好。  "

# game/a9/5rebels.rpy:252
translate english rebels2_73bdc489:

    # me "Я доверяю тебе, Валериан."
    me "Valerian，我相信你。  "

# game/a9/5rebels.rpy:253
translate english rebels2_d9bbdd4a:

    # valerian "Ты уверен?"
    valerian "你确定吗？  "

# game/a9/5rebels.rpy:254
translate english rebels2_24983bae:

    # me "Да. Кто меньше хочет власти, тот лучше ей распоряжается."
    me "确定。对权力渴求越少的人，运用权力越得当。  "

# game/a9/5rebels.rpy:255
translate english rebels2_b61ae3e9:

    # valerian "Спасибо, [mename]."
    valerian "谢谢，[mename]。  "

# game/a9/5rebels.rpy:256
translate english rebels2_7e9249bc:

    # me "Что будешь делать дальше?"
    me "你接下来打算做什么？  "

# game/a9/5rebels.rpy:257
translate english rebels2_00e0ea1b:

    # valerian "Хочу попробовать договориться с людьми лорда Аргуса. Я знаю пару способов заставить их сложить оружие."
    valerian "我想试着跟阿尔古斯大人的人谈一谈。我有些法子，能让他们放下武器。  "

# game/a9/5rebels.rpy:258
translate english rebels2_01c6250e:

    # me "Отлично."
    me "好极了。  "

# game/a9/5rebels.rpy:259
translate english rebels2_389344a6:

    # valerian "Но нужно озаботиться о лордах Темногорья и Курании. Я слышал сын лорда Гвидона полный болван."
    valerian "但黑山和库拉尼亚的领主们得先解决。我听说格维东大人的儿子是个十足的蠢货。  "

# game/a9/5rebels.rpy:260
translate english rebels2_c0080309:

    # me "Войска вассалов моего отца скоро будут там. Но я могу попробовать договориться без лишнего кровопролития."
    me "我父亲的封臣大军很快会抵达那里。不过，我也可以试试不动刀兵谈成这件事。  "

# game/a9/5rebels.rpy:261
translate english rebels2_86859232:

    # valerian "Тогда возьми людей и Кассиуса. Думаю лишние мечи и хороший переговорщик не помешают."
    valerian "那你带上人马和卡西乌斯。多几把剑和一位好说客，总没有坏处。  "

# game/a9/5rebels.rpy:262
translate english rebels2_46e0cd4d:

    # me "Кассиус?"
    me "卡西乌斯？  "

# game/a9/5rebels.rpy:263
translate english rebels2_c63bf552:

    # cassius "С удовольствием. Мне нужно пару дней, чтобы собрать людей."
    cassius "乐意效劳。容我两天时间召集人手。  "

# game/a9/5rebels.rpy:264
translate english rebels2_998478c9:

    # valerian "Тогда решено?"
    valerian "那就这么定了？  "

# game/a9/5rebels.rpy:265
translate english rebels2_b0c9095a:

    # me "Решено."
    me "定了。  "

# game/a9/5rebels.rpy:268
translate english rebels2_7f5a3ea0:

    # me "Давайте не подведем нашего доброго друга, Генри. Будем действовать также решительно, как и он. Верно говорю?"
    me "咱们可别辜负我们的好朋友亨利。我们要像他一样果断行动。我说得对不对？  "

# game/a9/5rebels.rpy:269
translate english rebels2_b7869f7a:

    # myatej "Верно."
    myatej "对。  "

# game/a9/5rebels.rpy:270
translate english rebels2_2718d3f6:

    # me "{size=+5}За республику!{/size}"
    me "{size=+5}为了共和国！{/size}  "

# game/a9/5rebels.rpy:271
translate english rebels2_09975b3d:

    # myatej "{size=+5}За республику!{/size}"
    myatej "{size=+5}为了共和国！{/size}  "

# game/a9/5rebels.rpy:272
translate english rebels2_b72bbbff:

    # me "Нам еще многое предстоит сделать."
    me "我们还有许多事要做。  "

# game/a9/5rebels.rpy:273
translate english rebels2_dd315d4e:

    # me "{i}Очень многое...{/i}"
    me "{i}太多太多……{/i}  "

# game/a9/5rebels.rpy:274
translate english rebels2_6303008b:

    # me "{i}Куда я ввязался?{/i}"
    me "{i}我这是卷进了什么漩涡？{/i}  "

# game/a9/5rebels.rpy:275
translate english rebels2_cc8c0ad5:

    # me "{i}Я думал все закончится за пару недель...{/i}"
    me "{i}原以为顶多几周就能了结……{/i}  "

# game/a9/5rebels.rpy:276
translate english rebels2_c11031db:

    # me "{i}Кажется моя поездка на Запад в очередной раз затягивается.{/i}"
    me "{i}看来我这趟西部之行，又一次遥遥无期了。{/i}  "

