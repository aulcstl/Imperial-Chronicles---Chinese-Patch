    # "Один план спустя."
    "两周以后。"

# game/a9/5rebels.rpy:4
translate english rebels2_0e6afad0:

    # henry "Ну как тебе вино?"
    henry "你觉得这酒怎么样？  "

# game/a9/5rebels.rpy:5
translate english rebels2_3794bbdf:

    # me "Я больше люблю аранское золотое."
    me "我更喜欢阿兰的金色酒。  "

# game/a9/5rebels.rpy:6
translate english rebels2_7b761940:

    # henry "Неужели тебе совсем не нравится наше западное вино?"
    henry "难道你完全不喜欢我们西部的酒吗？  "

# game/a9/5rebels.rpy:7
translate english rebels2_840aecd4:

    # me "Нравится. Но от него у меня болит голова."
    me "喜欢。不过喝完我头疼。  "

# game/a9/5rebels.rpy:8
translate english rebels2_859a57bf:

    # henry "От вина или от Запада?"
    henry "是酒让你疼，还是西部让你疼？  "

# game/a9/5rebels.rpy:9
translate english rebels2_0aa44d81:

    # me "И от того и от другого."
    me "两个都疼。  "

# game/a9/5rebels.rpy:10
translate english rebels2_867e9017:

    # henry "Не беспокойся, все почти кончено. К тому времени, как ты встретишь армию вассалов твоего отца, останется только утихомирить лордов у долины."
    henry "别担心，差不多快结束了。等你见到你父亲封臣的军队时，就只剩平定谷地的领主们了。  "

# game/a9/5rebels.rpy:11
translate english rebels2_237a5d24:

    # me "И все?"
    me "就这些？  "

# game/a9/5rebels.rpy:12
translate english rebels2_cf7ee647:

    # henry "И все."
    henry "就这些。  "

# game/a9/5rebels.rpy:13
translate english rebels2_cbf896f6:

    # me "А как же твой отец? Мы дожидаемся его уже третий день."
    me "那你父亲呢？我们已经等了他整整三天。  "

# game/a9/5rebels.rpy:14
translate english rebels2_9a7b1552:

    # henry "Он придет."
    henry "他会来的。  "

# game/a9/5rebels.rpy:15
translate english rebels2_e0d25683:

    # me "А если все-таки нет?"
    me "万一还是不来呢？  "

# game/a9/5rebels.rpy:16
translate english rebels2_31f45321:

    # henry "Он придет. Я знаю своего отца."
    henry "他会来的。我了解我父亲。  "

# game/a9/5rebels.rpy:17
translate english rebels2_088c13fc:

    # me "Тебе ведь не обязательно это делать."
    me "其实你不一定非得这么做。  "

# game/a9/5rebels.rpy:19
translate english rebels2_67af37cb:

    # cassius "Можешь даже не пытаться его отговорить - я пытался."
    cassius "劝都不必劝他——我已经试过了。  "

# game/a9/5rebels.rpy:20
translate english rebels2_db6853ff:

    # me "Может твое письмо просто не дошло до него?"
    me "会不会是你的信根本没送到他手里？  "

# game/a9/5rebels.rpy:21
translate english rebels2_383b69e5:

    # cassius "Или он решил впервые в жизни забыть о чести? А что? Когда все стоит на кону люди часто быстро меняются... Старые клятвы забываются."
    cassius "或者他这辈子头一回决定不守信用？怎么？当一切悬于一线时，人往往变得很快……旧日的誓言也会被遗忘。  "

# game/a9/5rebels.rpy:22
translate english rebels2_07191b73:

    # henry "Кассиус прав."
    henry "卡西乌斯说得对。  "

# game/a9/5rebels.rpy:23
translate english rebels2_744843e6:

    # cassius "Правда?"
    cassius "真的吗？  "

# game/a9/5rebels.rpy:24
translate english rebels2_6d46f322:

    # henry "Да, не пытайтесь меня переубедить."
    henry "对，别再劝我了。  "

# game/a9/5rebels.rpy:25
translate english rebels2_7950481c:

    # me "Знаешь, мы ведь так еще много дней можем просто ждать."
    me "你知道吗，这样我们可能还得傻等好多天。  "

# game/a9/5rebels.rpy:26
translate english rebels2_02d00687:

    # henry "Время на нашей стороне, [mename]. Расслабься и пей наше паршивое вино."
    henry "时间在我们这边，[mename]。放松点，喝咱们这劣质酒吧。  "

# game/a9/5rebels.rpy:28
translate english rebels2_44e02d76:

    # argus "Так вот ты где. Надо было догадаться, что ты не осмелишься сидеть в замке. Опасаешься за свою шкуру и спрятался рядом - в городе?"
    argus "你原来在这儿。早该猜到你没胆子待在城堡里。怕自己掉脑袋，就躲到旁边城里来了？  "

# game/a9/5rebels.rpy:29
translate english rebels2_1847c2d1:

    # myatej "Это он!"
    myatej "是他！  "

# game/a9/5rebels.rpy:30
translate english rebels2_0a5293b0:

    # myatej "К оружию!"
    myatej "抄家伙！  "

# game/a9/5rebels.rpy:31
translate english rebels2_a14bde13:

    # myatej "Окружите его!"
    myatej "围住他！  "

# game/a9/5rebels.rpy:33
translate english rebels2_5719fd8a:

    # myatej "Не шагу дальше."
    myatej "再往前一步试试。  "

# game/a9/5rebels.rpy:34
translate english rebels2_6df34149:

    # argus "Я безоружен, дегенераты. Вы думаете я убью вашего лидера голыми руками?"
    argus "我没带武器，一群蠢货。你们以为我会赤手空拳杀了你们的头儿吗？  "

# game/a9/5rebels.rpy:35
translate english rebels2_a5c70d1c:

    # myatej "..."
    myatej "..."

# game/a9/5rebels.rpy:36
translate english rebels2_cf64f7dd:

    # argus "Хотя может и убью..."
    argus "不过或许真能……  "

# game/a9/5rebels.rpy:37
translate english rebels2_9abcf1a2:

    # henry "Здравствуй, отец. Рад тебя видеть."
    henry "父亲，见到你很高兴。  "

# game/a9/5rebels.rpy:38
translate english rebels2_99038242:

    # argus "Не могу сказать того же."
    argus "我可没法说同样的话。  "

# game/a9/5rebels.rpy:39
translate english rebels2_8e47a9f6:

    # henry "Ребята, уберите мечи. Это невежливо."
    henry "小伙子们，把剑收起来。这不礼貌。  "

# game/a9/5rebels.rpy:41
translate english rebels2_0d072ac4:

    # henry "К гостю нужно относиться с почтением."
    henry "对客人得尊重些。  "

# game/a9/5rebels.rpy:42
translate english rebels2_ca6da119:

    # argus "Я здесь не как гость."
    argus "我来这儿可不是做客的。  "

# game/a9/5rebels.rpy:43
translate english rebels2_881eb76f:

    # henry "И все же я хочу поднять тост за честь моего отца. О ней ходят легенды и как оказалось - они все правда."
    henry "但我还是要为父亲的荣誉举杯。你的荣誉已成传奇，如今看来——果真名不虚传。  "

# game/a9/5rebels.rpy:44
translate english rebels2_59855cc6:

    # argus "У меня отобрали оружие. И свидетелей с моей стороны арестовали у входа."
    argus "他们下了我的武器，门口还扣了我带来作证的证人。  "

# game/a9/5rebels.rpy:45
translate english rebels2_d50337ec:

    # henry "Свидетелей?"
    henry "证人？  "

# game/a9/5rebels.rpy:46
translate english rebels2_ff0222ab:

    # argus "Тех, кто смогут в случае чего подтвердить, что меня не закололи в спину. Или не зарезали прямо в дверях, пока я стою безоружный."
    argus "就是万一出事，能证明我没被人背后捅刀子的人。或者，趁我手无寸铁在门口就被抹了脖子。  "

# game/a9/5rebels.rpy:47
translate english rebels2_6ef4e551:

    # henry "Приведите свидетелей дуэли от лорда Аргуса."
    henry "带阿尔古斯大人的决斗证人上来。  "

# game/a9/5rebels.rpy:48
translate english rebels2_69fa3f59:

    # myat "Да, Генри. Ребята - быстро."
    myat "是，亨利。快——麻利点。  "

# game/a9/5rebels.rpy:49
translate english rebels2_4225bb1a:

    # argus "И мой меч."
    argus "还有我的剑。  "

# game/a9/5rebels.rpy:50
translate english rebels2_d4d4e6ed:

    # henry "И принесите меч. Когда начнем?"
    henry "把剑也送上来。我们什么时候开始？  "

# game/a9/5rebels.rpy:52
translate english rebels2_5cedc1cb:

    # argus "Прямо сейчас. Не вижу смысла тянуть. Если ты конечно не пьян."
    argus "就现在。拖下去没意义。当然，除非你喝醉了。  "

# game/a9/5rebels.rpy:53
translate english rebels2_5a6ddb4b:

    # henry "Вино мне не помешает."
    henry "酒不碍我的事。  "

# game/a9/5rebels.rpy:54
translate english rebels2_3b7bd8fd:

    # argus "Вино всегда мешает."
    argus "酒从来都碍事。  "

# game/a9/5rebels.rpy:55
translate english rebels2_46b15396:

    # henry "Но только не мне."
    henry "但我例外。  "

# game/a9/5rebels.rpy:56
translate english rebels2_9da1d19f:

    # argus "Ну конечно. Ты же бессмертный."
    argus "当然了。你是不死之身嘛。  "

# game/a9/5rebels.rpy:57
translate english rebels2_9cb64c3d:

    # henry "Разуверишь меня?"
    henry "想亲身领教我的反证吗？  "

# game/a9/5rebels.rpy:58
translate english rebels2_4d7e7306:

    # argus "С удовольствием."
    argus "乐意之至。  "

# game/a9/5rebels.rpy:60
translate english rebels2_6698713c:

    # henry "Свидетели готовы? Протерли глаза?"
    henry "证人准备好了吗？擦亮眼睛了？  "

# game/a9/5rebels.rpy:61
translate english rebels2_eeccdede:

    # argus "Готовы."
    argus "准备好了。  "

# game/a9/5rebels.rpy:62
translate english rebels2_7e5a123a:

    # me "Мы что, правда будет на это смотреть?"
    me "我们真就这么干看着？  "

# game/a9/5rebels.rpy:63
translate english rebels2_e30f5f01:

    # valerian "А у нас есть другие варианты?"
    valerian "还能有别的办法吗？  "

# game/a9/5rebels.rpy:64
translate english rebels2_dc6c2469:

    # cassius "Можешь уйти в другую комнату."
    cassius "你大可以去隔壁房间。  "

# game/a9/5rebels.rpy:65
translate english rebels2_570e22f9:

    # me "Смешно. Я ведь не об этом. Мы это допустим?"
    me "有意思。我说的不是这个。我们就允许这事发生？  "

# game/a9/5rebels.rpy:66
translate english rebels2_17ccc3a9:

    # valerian "Я уговаривал его, но он уперся. Он думает, что если не победит своего отца честно, то его люди будут вести партизанскую войну десятилетия."
    valerian "我劝过他，但他犟得很。他认为，如果不能堂堂正正战胜自己的父亲，他的人就会打几十年的游击战。  "

# game/a9/5rebels.rpy:67
translate english rebels2_483d9561:

    # cassius "Ох, ну хоть какой-то прагматизм в этом безумии."
    cassius "唉，这疯狂里总算还藏着一点务实。  "

# game/a9/5rebels.rpy:68
translate english rebels2_16f2f9f6:

    # me "По-моему это просто оправдание. Он что-то хочет доказать себе и нам."
    me "要我说，这不过是借口罢了。他想要向自己，也向我们证明什么。  "

# game/a9/5rebels.rpy:70
translate english rebels2_00a1d125:

    # argus "Встань в стойку, как я тебя учил."
    argus "照我教你的摆好架势。  "

# game/a9/5rebels.rpy:71
translate english rebels2_5413fbf9:

    # henry "Зачем?"
    henry "何必？  "

# game/a9/5rebels.rpy:72
translate english rebels2_8db59818:

    # argus "Чтобы не сдохнуть, идиот."
    argus "为了别送死，蠢货。  "

# game/a9/5rebels.rpy:73
translate english rebels2_5bf53a7b:

    # henry "Я справлюсь и так."
    henry "不摆架势我也能应付。  "

# game/a9/5rebels.rpy:74
translate english rebels2_201d70f4:

    # argus "Безрассудство. Как и всегда."
    argus "莽撞。一如既往。  "

# game/a9/5rebels.rpy:75
translate english rebels2_4ae0cb4a:

    # henry "Будешь поучать меня или мы наконец начнем?"
    henry "你是准备继续教训我，还是我们终于开始？  "

# game/a9/5rebels.rpy:77
translate english rebels2_06eaa4f8:

    # argus "{size=+4}Если бы я поучал тебя чаще, этой дуэли никогда не было бы.{/size}"
    argus "{size=+4}要是我能多教训你些，这场决斗根本就不会发生。{/size}  "

# game/a9/5rebels.rpy:78
translate english rebels2_45a35ee2:

    # henry "{size=+4}Ты ошибаешься, эта дуэль только из-за того что ты умеешь только поучать.{/size}"
    henry "{size=+4}你错了，这场决斗，正是因为你只会教训人。{/size}  "

# game/a9/5rebels.rpy:79
translate english rebels2_93a29224:

    # argus "{size=+4}А я должен был доверить твое воспитание уличным собакам?{/size}"
    argus "{size=+4}难道我该把你丢给街头野狗去管教？{/size}  "

# game/a9/5rebels.rpy:80
translate english rebels2_5b4ba0bb:

    # henry "{size=+4}Ты так и сделал, забыл?{/size}"
    henry "{size=+4}你早就这么做了，忘了吗？{/size}  "

# game/a9/5rebels.rpy:81
translate english rebels2_eef03895:

    # argus "{size=+4}Сначала ты обезумел.{/size}"
    argus "{size=+4}最先发疯的就是你。{/size}  "

# game/a9/5rebels.rpy:83
translate english rebels2_57e729c9:

    # henry "{size=+4}Это ты обезумел, старик. Ты и весь твой старый мир, что стоит на голове, а не ногах.{/size}"
    henry "{size=+4}是你疯了，老头。你和你的整个旧世界都疯了，颠倒黑白。{/size}  "

# game/a9/5rebels.rpy:84
translate english rebels2_c4069edb:

    # argus "{size=+4}Мой старый мир стоял тысячи лет, идиот.{/size}"
    argus "{size=+4}我的旧世界屹立了数千年，蠢货。{/size}  "

# game/a9/5rebels.rpy:85
translate english rebels2_75234e3e:

    # henry "{size=+4}Мой будет стоять вечно!{/size}"
    henry "{size=+4}我的世界将永世不倒！{/size}  "

# game/a9/5rebels.rpy:86
translate english rebels2_f77fe0f2:

    # argus "{size=+4}Безумец!{/size}"
    argus "{size=+4}疯子！{/size}  "

# game/a9/5rebels.rpy:88
translate english rebels2_1b9d636f:

    # valerian "А вы думали что будет, если..."
    valerian "你们想过没有，万一……  "

# game/a9/5rebels.rpy:89
translate english rebels2_a8e12839:

    # cassius "Если Генри умрет?"
    cassius "万一亨利死了？  "

# game/a9/5rebels.rpy:90
translate english rebels2_533a02e8:

    # valerian "Ага. Он строит новый вечный мир, но сам-то он не бессмертный."
    valerian "是啊。他口口声声要建新的永恒世界，可他自己又不是不死之身。  "

# game/a9/5rebels.rpy:91
translate english rebels2_564c4447:

    # cassius "Ага. А его отец гораздо более опытный воин."
    cassius "对。而他父亲的战士经验远比他老道。  "

# game/a9/5rebels.rpy:92
translate english rebels2_dc033f08:

    # me "Не понял. Вы оба думаете, что он проиграет?"
    me "我没明白。你们俩都觉得他会输？  "

# game/a9/5rebels.rpy:93
translate english rebels2_fad236d5:

    # valerian "Я верю в него, но...всякое ведь может случиться."
    valerian "我相信他，但……什么事都可能发生。  "

# game/a9/5rebels.rpy:94
translate english rebels2_dbcca635:

    # cassius "Не беспокойся на счет этого."
    cassius "这倒不用担心。  "

# game/a9/5rebels.rpy:95
translate english rebels2_9fac11c0:

    # valerian "Почему?"
    valerian "为什么？  "

# game/a9/5rebels.rpy:96
translate english rebels2_f12636fc:

    # cassius "Я обо всем позаботился. Если лорд Аргус вдруг выиграет, он и его люди не покинут это место живыми."
    cassius "我都安排好了。万一阿尔古斯大人侥幸得胜，他和他的部下别想活着离开这里。  "

# game/a9/5rebels.rpy:97
translate english rebels2_05f65e4b:

    # valerian "Это будет нечестно."
    valerian "那就不公平了。  "

# game/a9/5rebels.rpy:98
translate english rebels2_f2ffbca5:

    # cassius "Прости, Валериан, что задел твое чувство справедливости, но Генри не единственный, кто все эти годы строил Республику."
    cassius "Valerian，原谅我刺痛了你的正义感，但亨利不是这些年唯一一个建设共和国的人。  "

# game/a9/5rebels.rpy:99
translate english rebels2_0e5bf632:

    # cassius "Тысячи людей проливали свою кровь не для того, чтобы все это пошло прахом из-за желания Генри что-то доказать."
    cassius "成千上万的人洒下鲜血，不是为了让他一时意气证明什么就全盘崩塌的。  "

# game/a9/5rebels.rpy:100
translate english rebels2_cbb3b371:

    # valerian "Знаешь, даже не буду спорить с тобой в этот раз. Ты прав. Но ведь если свидетели лорда Аргуса не вернутся, его люди и так все поймут."
    valerian "知道吗，这次我甚至不想跟你争。你是对的。可要是阿尔古斯大人的证人回不去，他的部下照样会明白怎么回事。  "

# game/a9/5rebels.rpy:101
translate english rebels2_36c4e1a8:

    # cassius "Для нас ничего не изменится. Люди Аргуса и так собирались воевать с нами до последнего вздоха."
    cassius "对我们也一样。阿尔古斯的人本就准备跟我们战至最后一口气。  "

# game/a9/5rebels.rpy:102
translate english rebels2_495380a1:

    # valerian "..."
    valerian "..."

# game/a9/5rebels.rpy:104
translate english rebels2_3c7f8f12:

    # henry "{size=+4}Даже не рядом.{/size}"
    henry "{size=+4}碰都碰不着。{/size}  "

# game/a9/5rebels.rpy:105
translate english rebels2_5efe8dba:

    # argus "{size=+4}Будешь учить меня? Я сражался чаще, чем ты открывал проклятые эльфийские книги.{/size}"
    argus "{size=+4}你还想教我？我经历的战阵，比你翻开那些该死的精灵书页次数还多。{/size}  "

# game/a9/5rebels.rpy:106
