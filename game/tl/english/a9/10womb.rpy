# TODO: Translation updated at 2025-05-07 09:02

# game/a9/10womb.rpy:3
translate english womb_24b271ca:

    # "Неделю спустя."
    "一周后。"

# game/a9/10womb.rpy:4
translate english womb_655bb8d9:

    # me "Осторожнее."
    me "小心点。"

# game/a9/10womb.rpy:5
translate english womb_6e8e9006:

    # knight "Извините, мой принц. Я просто устал."
    knight "对不起，我的王子。我只是累了。"

# game/a9/10womb.rpy:6
translate english womb_5fedc748:

    # me "Все нормально. Я тоже."
    me "没关系，我也累了。"

# game/a9/10womb.rpy:8
translate english womb_c8dba96a:

    # me "Все остальные уже здесь?"
    me "其他人都到了吗？"

# game/a9/10womb.rpy:9
translate english womb_f47558e8:

    # knight "Да. Остался только обоз. Хотите я их проверю?"
    knight "是的，就剩辎重车队了。需要我去检查一下吗？"

# game/a9/10womb.rpy:10
translate english womb_9e6d1425:

    # me "Отправьте кого-то из передового отряда, я думаю они уже успели отдохнуть."
    me "从前锋队里派个人去吧，我想他们已经休息好了。"

# game/a9/10womb.rpy:11
translate english womb_1716b2e5:

    # knight "Конечно. Спасибо."
    knight "当然，谢谢。"

# game/a9/10womb.rpy:12
translate english womb_7137d392:

    # me "Надо бы заняться лошадью."
    me "我得去照料一下马。"

# game/a9/10womb.rpy:13
translate english womb_2b30041c:

    # knight "Вам помочь?"
    knight "需要我帮忙吗？"

# game/a9/10womb.rpy:14
translate english womb_e2daabaf:

    # me "Нет. Я вижу слугу."
    me "不用，我看到仆人了。"

# game/a9/10womb.rpy:16
translate english womb_e30c7fee:

    # slug "Вам показать, где я оставлю вашу лошадь, сир?"
    slug "阁下，需要我指给您看我会把您的马安置在哪儿吗？"

# game/a9/10womb.rpy:17
translate english womb_0c2ffc1d:

    # me "Без разницы. Если что я возьму любую."
    me "无所谓，如果需要，我随便牵一匹就行。"

# game/a9/10womb.rpy:18
translate english womb_9b107053:

    # slug "Конечно. Есть пожелания по кормлению?"
    slug "当然。喂养上有什么要求吗？"

# game/a9/10womb.rpy:19
translate english womb_2c7da0cf:

    # me "По кормлению меня?"
    me "喂养我吗？"

# game/a9/10womb.rpy:20
translate english womb_dc589969:

    # slug "...лошади, сир."
    slug "……是喂马，阁下。"

# game/a9/10womb.rpy:21
translate english womb_368599ae:

    # me "Мне все равно. Кормите тем же, что и остальных."
    me "我无所谓。跟其他马喂一样的就行。"

# game/a9/10womb.rpy:22
translate english womb_7577ff2a:

    # slug "Вас ждут в зале в башне."
    slug "他们在塔楼大厅等您。"

# game/a9/10womb.rpy:23
translate english womb_52142348:

    # me "Сейчас? Я бы сначала отдохнул."
    me "现在吗？我想先休息一下。"

# game/a9/10womb.rpy:24
translate english womb_aa796b19:

    # slug "Говорят, что это срочно."
    slug "听说事情很紧急。"

# game/a9/10womb.rpy:25
translate english womb_b5e9c06c:

    # me "Ладно, сейчас поднимусь."
    me "好吧，我现在就上去。"

# game/a9/10womb.rpy:28
translate english womb_4b46e047:

    # guran "Почему ты не подготовился?"
    guran "你为什么没准备好？"

# game/a9/10womb.rpy:29
translate english womb_9c9c9a82:

    # bart "Отец, я же не знал..."
    bart "父亲，我又不知道……"

# game/a9/10womb.rpy:30
translate english womb_be2ba306:

    # guran "Не знал, что припасы могут нам понадобится? Я тебе об этом написал."
    guran "不知道补给品我们可能要用到？我写信告诉过你了。"

# game/a9/10womb.rpy:31
translate english womb_385f60b4:

    # bart "Эм...я...дело не в этом."
    bart "呃……我……不是因为这个。"

# game/a9/10womb.rpy:32
translate english womb_af2c00d2:

    # guran "'Эмм, я....' Ты совсем идиот?"
    guran "'呃，我……' 你真是个白痴吗？"

# game/a9/10womb.rpy:33
translate english womb_238810fe:

    # bart "Нет."
    bart "不是。"

# game/a9/10womb.rpy:34
translate english womb_91f8004b:

    # guran "Нет? Значит ты не подготовил припасов из злого умысла?"
    guran "不是？那就是你出于恶意没准备补给品？"

# game/a9/10womb.rpy:35
translate english womb_4affecde:

    # bart "НЕТ!"
    bart "不是！"

# game/a9/10womb.rpy:37
translate english womb_aa44a6c0:

    # bart "Я подготовил припасы, сразу как прочитал твое письмо."
    bart "我一读完你的信就立刻准备了补给品。"

# game/a9/10womb.rpy:38
translate english womb_d9500dee:

    # guran "И? Их крысы сожрали?"
    guran "然后呢？被老鼠吃光了？"

# game/a9/10womb.rpy:39
translate english womb_899c7aa3:

    # bart "Их отравили."
    bart "被人下毒了。"

# game/a9/10womb.rpy:40
translate english womb_1ba2fbe7:

    # me "Отравили?"
    me "下毒了？"

# game/a9/10womb.rpy:41
translate english womb_9a6b1122:

    # guran "Кто?"
    guran "谁干的？"

# game/a9/10womb.rpy:42
translate english womb_b4c986fd:

    # bart "Мне пришлось закупать новые в городе прямо перед вашим приездом. Но я же не думал, что здесь будут сразу две армии."
    bart "我不得不在您到达前，在城里重新采购。但我没想到这里会一下子来两支军队。"

# game/a9/10womb.rpy:43
translate english womb_86114b26:

    # me "Так кто отравил припасы? Есть подозреваемые?"
    me "那么到底是谁给补给品下的毒？有嫌疑人吗？"

# game/a9/10womb.rpy:44
translate english womb_b511689e:

    # guran "Как это вообще произошло? Ты что, не приставил к припасам охрану?"
    guran "这到底是怎么发生的？难道你没有派人看守补给品吗？"

# game/a9/10womb.rpy:45
translate english womb_42b1b74e:

    # bart "Приставил. Охрана услышала ночью шум. Они ворвались в амбар, но там уже никого не было. А все зерно было полито какой-то отравой. Мы пробовали давать его свиньям - они сразу дохли."
    bart "派了。守卫夜里听到了动静。他们冲进谷仓，但那里已经没人了。所有的谷物都被浇了某种毒药。我们试着喂猪，猪立刻就死了。"

# game/a9/10womb.rpy:46
translate english womb_686be8eb:

    # guran "Что значит там никого не было? Они что, испарились?"
    guran "什么叫那里已经没人了？他们难道是蒸发了不成？"

# game/a9/10womb.rpy:47
translate english womb_4c5c6bcc:

    # bart "Не знаю!"
    bart "我不知道！"

# game/a9/10womb.rpy:48
translate english womb_22a62cd0:

    # me "А как они туда попали? И кто это был?"
    me "那他们是怎么进去的？又是谁干的？"

# game/a9/10womb.rpy:49
translate english womb_5e675551:

    # guran "Да?"
    guran "嗯？"

# game/a9/10womb.rpy:50
translate english womb_4718e461:

    # bart "..."
    bart "..."

# game/a9/10womb.rpy:51
translate english womb_94082547:

    # guran "Барт?"
    guran "Bart？"

# game/a9/10womb.rpy:52
translate english womb_95027ceb:

    # bart "Отец...только пообещай не злиться."
    bart "父亲……你得答应我别生气。"

# game/a9/10womb.rpy:53
translate english womb_b818e388:

    # guran "Ничего не обещаю."
    guran "我什么也不答应。"

# game/a9/10womb.rpy:55
translate english womb_70a88584:

    # bart "Я впустил бродячих артистов..."
    bart "我放了一些流浪艺人进来……"

# game/a9/10womb.rpy:56
translate english womb_1f3eb340:

    # guran "О боги...чем я вас прогневал? За что вы послали мне сына-идиота?"
    guran "哦，众神啊……我做了什么惹怒了你们？你们为何要赐给我一个白痴儿子？"

# game/a9/10womb.rpy:57
translate english womb_e40ccb22:

    # bart "Их обыскали! У них не было с собой оружия!"
    bart "他们被搜过身！他们身上没带武器！"

# game/a9/10womb.rpy:58
translate english womb_79541f74:

    # guran "Я...я даже не знаю, что сказать..."
    guran "我……我都不知道说什么好了……"

# game/a9/10womb.rpy:59
translate english womb_922ba280:

    # bart "Отец, я здесь уже год сижу по твоему указу и даже шагу ступить из замка не могу! Мне, как и всем людям в этом месте, надо было чуть-чуть отвлечься."
    bart "父亲，我奉你的命令在这里待了一年了，连城堡一步都出不去！我跟这地方的其他人一样，需要稍微放松一下。"

# game/a9/10womb.rpy:60
translate english womb_93e84048:

    # guran "Отвлекся?"
    guran "放松够了吗？"

# game/a9/10womb.rpy:61
translate english womb_fb0e3290:

    # bart "Я не понимаю...зачем им это?"
    bart "我不明白……他们这么做是为了什么？"

# game/a9/10womb.rpy:62
translate english womb_aadc658b:

    # guran "Я тебя сейчас убью!"
    guran "我现在就杀了你！"

# game/a9/10womb.rpy:63
translate english womb_e9d7e2fb:

    # bart "Я не думал, что они станут отдавать свои жизни на такое, тем более на стенах и у ворот всегда была охрана!"
    bart "我没想到他们会豁出性命干这种事，何况城墙和大门一直都有守卫！"

# game/a9/10womb.rpy:64
translate english womb_1d08fe87:

    # guran "И все таки ты их упустил..."
    guran "可你还是让他们跑了……"

# game/a9/10womb.rpy:65
translate english womb_7fa85cf4:

    # bart "Я не знаю, как!"
    bart "我不知道他们是怎么跑的！"

# game/a9/10womb.rpy:67
translate english womb_eedabaaf:

    # me "А среди этих 'бродячих артистов' были эльфы?"
    me "那这些'流浪艺人'里有精灵吗？"

# game/a9/10womb.rpy:68
translate english womb_ff0246c0:

    # bart "Да...кажется да."
    bart "有……好像有。"

# game/a9/10womb.rpy:69
translate english womb_64d2fe58:

    # guran "Ты думаешь это эльфы?"
    guran "你认为是精灵干的？"

# game/a9/10womb.rpy:70
translate english womb_60f18410:

    # me "Да. Кто еще мог так незаметно скрыться?"
    me "是的。还有谁能这样神不知鬼不觉地消失？"

# game/a9/10womb.rpy:71
translate english womb_7f146430:

    # guran "Маги?"
    guran "法师？"

# game/a9/10womb.rpy:72
translate english womb_46ea2f6d:

    # me "В Западной башне больше нет ни одного мага, так что они либо мертвы, либо заодно с эльфами и мятежниками. "
    me "西塔楼已经没有法师了，所以他们要么死了，要么就和精灵与叛军是一伙的。"

# game/a9/10womb.rpy:73
translate english womb_54fd6fec:

    # bart "Эльфы тоже могут быть магами?"
    bart "精灵也可能是法师吗？"

# game/a9/10womb.rpy:74
translate english womb_d97f34bf:

    # guran "Вот же сукины дети...так вот кто нам воду в обозе травил. А твоя мать..."
    guran "这群狗娘养的……原来就是他们在我们的辎重车里下毒。还有你母亲……"

# game/a9/10womb.rpy:75
translate english womb_255db3d2:

    # me "Моя мать здесь ни при чем. Я знаю кто это сделал."
    me "我母亲与此事无关。我知道是谁干的。"

# game/a9/10womb.rpy:76
translate english womb_3a7d7952:

    # guran "Разве все эльфы не за одно?"
    guran "难道所有精灵不是一伙的吗？"

# game/a9/10womb.rpy:77
translate english womb_6ca4186a:

    # me "Нет. Даже среди них есть...мятежники."
    me "不是。即使在他们中间也有……叛徒。"

# game/a9/10womb.rpy:78
translate english womb_784a35f2:

    # guran "И что будем с ними делать?"
    guran "那我们要怎么处置他们？"

# game/a9/10womb.rpy:79
translate english womb_dd5093d8:

    # me "Ничего."
    me "什么都不做。"

# game/a9/10womb.rpy:80
translate english womb_442ba23e:

    # guran "Ничего?"
    guran "什么都不做？"

# game/a9/10womb.rpy:82
translate english womb_784578fa:

    # me "Они отвлекают нас. Тянут время."
    me "他们在分散我们的注意力，拖延时间。"

# game/a9/10womb.rpy:83
translate english womb_c37a309b:

    # guran "Зачем?"
    guran "为什么？"

# game/a9/10womb.rpy:84
translate english womb_a7e569b1:

    # me "Теперь мы с уверенностью можем сказать, что они действуют заодно с мятежниками."
    me "现在我们可以肯定，他们和叛军是一伙的。"

# game/a9/10womb.rpy:85
translate english womb_9763e067:

    # guran "На кой хер им это надо?"
    guran "他们这么做到底图什么？"

# game/a9/10womb.rpy:86
translate english womb_a28d80b8:

    # me "Не знаю. Может мятежники им что-то пообещали, а может им просто выгоден хаос среди людей."
    me "不知道。也许是叛军许诺了他们什么，也许他们只是想看到人类陷入混乱。"

# game/a9/10womb.rpy:87
translate english womb_b5eb93b6:

    # guran "Так что будем делать?"
    guran "那我们该怎么做？"

# game/a9/10womb.rpy:88
translate english womb_7b979957:

    # me "Будем действовать по плану. Дождемся армию вассалов отца и двинемся в Ривелье. "
    me "按计划行事。等父亲的封臣军队到了，我们就向Rivelle进发。"

# game/a9/10womb.rpy:89
translate english womb_1abf799c:

    # me "Если береговые лорды рискнут напасть - дадим бой. Если нет - будем выдвигать им ультиматумы один за другим."
    me "如果海岸领主们胆敢进攻，我们就开战。如果不敢，我们就一个一个地向他们下达最后通牒。"

# game/a9/10womb.rpy:90
translate english womb_60b2b928:

    # guran "Мне нравится."
    guran "我喜欢这主意。"

# game/a9/10womb.rpy:91
translate english womb_46eff4e1:

    # me "Мне тоже."
    me "我也是。"

# game/a9/10womb.rpy:92
translate english womb_6164f850:

    # guran "Но эльфы..."
    guran "但是精灵……"

# game/a9/10womb.rpy:93
translate english womb_301ec5e7:

    # me "Позже. Эльфами займемся позже. Я что-нибудь придумаю."
    me "以后再说。精灵的事以后再说。我会想办法的。"

# game/a9/10womb.rpy:96
translate english womb_d64e9740:

    # cassius "Я рад, что ты оказался благоразумен, чтобы впустить нас внутрь, Барт."
    cassius "Bart，我很高兴你明智地放我们进来了。"

# game/a9/10womb.rpy:97
translate english womb_9d940e5d:

    # bart "Угу..."
    bart "嗯……"

# game/a9/10womb.rpy:98
translate english womb_f4eb5577:

    # cassius "Но там за стенами еще полно наших людей."
    cassius "但城墙外还有很多我们的人。"

# game/a9/10womb.rpy:99
translate english womb_68259d4b:

    # bart "Не уверен, что впускать их хорошая идея."
    bart "我不确定放他们进来是个好主意。"

# game/a9/10womb.rpy:100
translate english womb_5503408f:

    # cassius "Почему?"
    cassius "为什么？"

# game/a9/10womb.rpy:101
translate english womb_698abe87:

    # bart "Вы ведь воевали против моего отца..."
    bart "你们毕竟与我父亲交战过……"

# game/a9/10womb.rpy:102
translate english womb_a49436bb:

    # cassius "Это не так, Барт. Мы просто хотим, чтобы это бессмысленная резня на Западе закончилась. Вот и все."
    cassius "不是这样的，Bart。我们只是想结束西方这场无谓的屠杀。仅此而已。"

# game/a9/10womb.rpy:103
translate english womb_5527428d:

    # bart "Да, но ведь вы хотите установить Республику..."
    bart "是的，但你们想建立共和国……"

# game/a9/10womb.rpy:104
translate english womb_4e3a03ca:

    # cassius "Верно. Но это никак на тебе не скажется."
    cassius "没错。但这丝毫不会影响你。"

# game/a9/10womb.rpy:105
translate english womb_c831ff98:

    # bart "Это еще почему? Разве у меня не отберут замок и все такое..."
    bart "这又是为什么？难道我的城堡和一切不会被没收吗……"

# game/a9/10womb.rpy:107
translate english womb_f334c2de:

    # cassius "Кто тебе сказал такую глупость?"
    cassius "谁告诉你的这种蠢话？"

# game/a9/10womb.rpy:108
translate english womb_5d077588:

    # bart "Отец..."
    bart "我父亲……"

# game/a9/10womb.rpy:109
translate english womb_06642e4f:

    # cassius "Слушай, ты когда-нибудь имел дело с городскими торговцами? Ты знаешь что такое контракт?"
    cassius "听着，你以前和城里的商人打过交道吗？你知道什么是契约吗？"

# game/a9/10womb.rpy:110
translate english womb_3ab3ef6c:

    # bart "Вроде знаю..."
    bart "大概知道……"

# game/a9/10womb.rpy:111
translate english womb_3c946f6e:

    # cassius "Когда мы установим Республику - у тебя останутся все твои владения и замки, просто люди у людей на этих землях будет с тобой контракт."
    cassius "等我们建立共和国，你仍然拥有你所有的领地和城堡，只是你领地上的人会和你有一份契约。"

# game/a9/10womb.rpy:112
translate english womb_575c2fc6:

    # bart "Какой?"
    bart "什么契约？"

# game/a9/10womb.rpy:113
translate english womb_75b36bdd:

    # cassius "Простой. Ты будешь представлять их интересы."
    cassius "很简单。你将代表他们的利益。"

# game/a9/10womb.rpy:114
translate english womb_47ebf33f:

    # bart "Но разве все крестьяне, солдаты и горожане не станут...ну...свободными."
    bart "但是，难道所有的农民、士兵和市民不都……呃……自由了吗？"

# game/a9/10womb.rpy:115
translate english womb_d82d2383:

    # cassius "Станут. Но земля же все еще будет твоя."
    cassius "会自由的。但土地仍然是你的。"

# game/a9/10womb.rpy:116
translate english womb_8314453e:

    # bart "Но..."
    bart "但是……"

# game/a9/10womb.rpy:117
translate english womb_f1e16ffb:

    # cassius "Крестьяне будут платить тебе за пользование твоей землей. А на эти деньги ты сможешь содержать свои замки и солдат."
    cassius "农民会为使用你的土地付钱给你。用这些钱你就能维持你的城堡和士兵。"

# game/a9/10womb.rpy:118
translate english womb_49502c8b:

    # bart "А если они не захотят платить?"
    bart "如果他们不想付钱呢？"

# game/a9/10womb.rpy:119
translate english womb_33e52bd8:

    # cassius "Тогда у тебя будет легитимная причина применить к ним...силу."
    cassius "那你就有了合法的理由对他们使用……武力。"

# game/a9/10womb.rpy:121
translate english womb_3c574315:

    # bart "Ну я не знаю..."
    bart "嗯，我不知道……"

# game/a9/10womb.rpy:122
translate english womb_e4d46112:

    # cassius "Слушай, Барт. Я не собираюсь врать тебе и говорить якобы твое положение при новом порядке будет только лучше. Ты лишишься части привилегий в пользу свобод других людей."
    cassius "听着，Bart。我不想骗你，说新秩序下你的处境只会更好。你为了其他人的自由，确实会失去一部分特权。"

# game/a9/10womb.rpy:123
translate english womb_7a847d9b:

    # cassius "Но ты все еще будешь состоятельнее и влиятельнее, чем большинство людей на Западе."
    cassius "但你仍然会比西方的大多数人更富有、更有权势。"

# game/a9/10womb.rpy:124
translate english womb_2077759e:

    # bart "Но буду ли я Лордом...."
    bart "但我还会是领主吗……"

# game/a9/10womb.rpy:125
translate english womb_8f93ca31:

    # cassius "Конечно будешь. Просто ты не сможешь...злоупотреблять этим. Ты убивал когда-нибудь крестьян без нужды?"
    cassius "当然是。只是你不能……滥用职权了。你曾毫无必要地杀害过农民吗？"

# game/a9/10womb.rpy:126
translate english womb_238810fe_1:

    # bart "Нет."
    bart "没有。"

# game/a9/10womb.rpy:127
translate english womb_b63baa4f:

    # cassius "А насиловал? Собирал налоги сверх положенного? Заставлял страдать без причины?"
    cassius "强奸呢？征收超额赋税呢？无缘无故让他们受苦呢？"

# game/a9/10womb.rpy:128
translate english womb_dd4f5486:

    # bart "Нет!"
    bart "没有！"

# game/a9/10womb.rpy:129
translate english womb_2926f6b3:

    # cassius "В таком случае при Республике ты ничего не потеряешь."
    cassius "那样的话，在共和国里你不会失去任何东西。"

# game/a9/10womb.rpy:130
translate english womb_4c8429f2:

    # bart "Ну..."
    bart "嗯……"

# game/a9/10womb.rpy:132
translate english womb_c9175200:

    # me "Слушай, Барт. За стенами твоего замка стоят тысячи людей. Совсем скоро сюда подойдет армия вассалов моего отца."
    me "听着，Bart。你的城堡墙外站着成千上万的人。我父亲的封臣军队很快就要到了。"

# game/a9/10womb.rpy:133
translate english womb_8949734a:

    # cassius "[mename]..."
    cassius "[mename]..."

# game/a9/10womb.rpy:134
translate english womb_ebf04877:

    # me "Нет. Пусть поймет - мы здесь, чтобы договориться. Но если ты не хочешь - мы возьмем это место в осаду и сожжём до основания. А тебя повесим."
    me "不。让他明白——我们是来谈判的。但如果你不愿意，我们就包围这里，把它烧成灰烬。再把你绞死。"

# game/a9/10womb.rpy:135
translate english womb_9789f978:

    # cassius "Не надо..."
    cassius "不要……"

# game/a9/10womb.rpy:136
translate english womb_ccdaf337:

    # bart "Повесите?"
    bart "绞死？"

# game/a9/10womb.rpy:137
translate english womb_8ef78970:

    # me "Да. Лучше лишиться части привилегий, чем подохнуть?"
    me "是的。失去部分特权，总比死掉强，对吧？"

# game/a9/10womb.rpy:138
translate english womb_68aa47ab:

    # cassius "Кхм-кхм."
    cassius "咳-咳。"

# game/a9/10womb.rpy:139
translate english womb_0a3141bb:

    # bart "Я...мой отец..."
    bart "我……我的父亲……"

# game/a9/10womb.rpy:140
translate english womb_d8072fbf:

    # me "Подумай, Барт. Хорошо подумай. Мы не убивали твоего отца. Мы всегда сначала пытались решить все мирно. Но так получилось...что для врагов Республики все всегда заканчивается плохо."
    me "好好想想，Bart。仔细想想。我们没有杀你的父亲。我们总是先尝试和平解决。但是……对于那些反对共和国的人来说，结局总是不太好。"

# game/a9/10womb.rpy:141
translate english womb_4718e461_1:

    # bart "..."
    bart "..."

# game/a9/10womb.rpy:142
translate english womb_b4d47734:

    # me "Ты не успел собрать новое войско, и если мы решим тебя уничтожить - мы это сделаем. Быстро."
    me "你已经来不及召集新的军队了。如果我们决定消灭你，我们很快就能做到。"

# game/a9/10womb.rpy:143
translate english womb_6f55080e:

    # me "Мы не предлагаем дважды. Просто ответь. Ты станешь тем, кто проявит благоразумие, или ты хочешь дойти до моря Восторга в качестве нашего друга или в качестве головы на пике?"
    me "我们不提第二次建议。只要回答我。你是想做个明白事理的人，作为我们的朋友走到狂喜之海，还是想作为长矛上的头颅被送过去？"

# game/a9/10womb.rpy:144
translate english womb_b61a8681:

    # bart "Друга..."
    bart "朋友……"

# game/a9/10womb.rpy:145
translate english womb_9683a85c:

    # bart "Я согласен. Я впущу ваши армии."
    bart "我同意。我放你们的军队进来。"

# game/a9/10womb.rpy:147
translate english womb_6fceae53:

    # me "Молодец."
    me "好样的。"

# game/a9/10womb.rpy:148
translate english womb_9992bf18:

    # bart "Надеюсь я об этом не пожалею."
    bart "希望我不会为此后悔。"

# game/a9/10womb.rpy:149
translate english womb_69f84d0c:

    # me "Не волнуйся. Мы держим свое слово."
    me "别担心。我们言出必行。"

# game/a9/10womb.rpy:150
translate english womb_51935c98:

    # me "Более того - ты один из первых, а значит твое слово будет значит куда больше, когда все остальные Лорды преклонят колени."
    me "更何况，你是最早的一批，这意味着当其他所有领主都屈膝投降时，你的话会更有分量。"

# game/a9/10womb.rpy:151
translate english womb_b59d60c0:

    # bart "Так...что дальше?"
    bart "那么……接下来呢？"

# game/a9/10womb.rpy:152
translate english womb_afd18e25:

    # me "Скоро прибудет моя армия."
    me "我的军队很快就到。"

# game/a9/10womb.rpy:153
translate english womb_c993011f:

    # me "Они отдохнут и мы двинемся обратно в Ривелье. Оттуда удобно будет удобно совершать походы в любую часть Запада."
    me "他们会休息一下，然后我们就返回Rivelle。从那里可以方便地向西方的任何地方出征。"

# game/a9/10womb.rpy:154
translate english womb_9148d34b:

    # me "Учитывая, что Берег и Темногорье уже за нас, пару удачных битв и только безумец откажется принимать новый порядок."
    me "考虑到海岸和暗山已经支持我们，只要打赢几场胜仗，就只有疯子才会拒绝接受新秩序了。"

# game/a9/10womb.rpy:155
translate english womb_1aa071dd:

    # me "Скоро все закончится."
    me "很快一切就会结束了。"

# game/a9/10womb.rpy:158
translate english womb_4cff0a3b:

    # cass "Он сражался как герой."
    cass "他战斗得像一个英雄。"

# game/a9/10womb.rpy:159
translate english womb_617703f7:

    # bart "Правда?"
    bart "真的吗？"

# game/a9/10womb.rpy:160
translate english womb_6ff9550e:

    # cass "Да. Я сама это видела. Нам не хватило пары минут. Мы могли успеть."
    cass "是的。我亲眼所见。我们只差几分钟。我们本可以赶上的。"

# game/a9/10womb.rpy:161
translate english womb_09c8cae2:

    # bart "О боги..."
    bart "哦，众神啊……"

# game/a9/10womb.rpy:162
translate english womb_1c579291:

    # cass "Да. Это ужасно. Твой отец умер у меня на руках."
    cass "是的。这太可怕了。你的父亲死在了我的怀里。"

# game/a9/10womb.rpy:163
translate english womb_46e94787:

    # bart "Он что-то сказал про меня, перед тем как умер?"
    bart "他临死前有提到我吗？"

# game/a9/10womb.rpy:164
translate english womb_8f55325b:

    # cass "Да. Конечно сказал."
    cass "是的，当然提到了。"

# game/a9/10womb.rpy:165
translate english womb_b75c7a16:

    # bart "Что?"
    bart "说什么了？"

# game/a9/10womb.rpy:167
translate english womb_e9b60026:

    # cass "Просил прощения."
    cass "他请求原谅。"

# game/a9/10womb.rpy:168
translate english womb_e4649bb1:

    # bart "У меня? За что?"
    bart "向我吗？为什么？"

# game/a9/10womb.rpy:169
translate english womb_a515d446:

    # cass "За то что был слишком суров... Просил передать, что на самом деле любил тебя."
    cass "因为他过去太严厉了……他要我转告你，他其实爱你。"

# game/a9/10womb.rpy:170
translate english womb_9e45c566:

    # bart "Папа..."
    bart "爸爸……"

# game/a9/10womb.rpy:171
translate english womb_70d206f5:

    # cass "Он у всех просил прощения. У жены, у друзей, у Черной Косы..."
    cass "他向所有人请求了原谅。向他的妻子，向朋友们，向黑镰……"

# game/a9/10womb.rpy:172
translate english womb_2bfd38b4:

    # bart "У Черной Косы?"
    bart "向黑镰？"

# game/a9/10womb.rpy:173
translate english womb_3ccba1b3:

    # cass "Да. Это ведь благодаря Черной Косе и принцу-регенту мятежники были разбиты в Ривелье."
    cass "是的。多亏了黑镰和摄政王，叛军才能在Rivelle被击败。"

# game/a9/10womb.rpy:174
translate english womb_5f4e6944:

    # cass "Твоей отец говорил, что всю жизнь ненавидел Черную Косу."
    cass "你的父亲说，他一生都憎恨黑镰。"

# game/a9/10womb.rpy:175
translate english womb_75ec7c17:

    # bart "Это так..."
    bart "是这样的……"

# game/a9/10womb.rpy:176
translate english womb_4ff862f1:

    # cass "Но когда мы вошли в замок, когда мы отбили его у мятежников - он попросил прощения."
    cass "但当我们进入城堡，从叛军手中夺回他的时候，他请求了原谅。"

# game/a9/10womb.rpy:177
translate english womb_a8fcf5ef:

    # bart "Не может быть..."
    bart "这不可能……"

# game/a9/10womb.rpy:178
translate english womb_c6af0611:

    # cass "Так и было. Можешь спросить у лорда Арамиса, он свидетель."
    cass "事实如此。你可以去问Aramis大人，他是证人。"

# game/a9/10womb.rpy:179
translate english womb_473b2d2b:

    # bart "Он единственный, кто выжил?"
    bart "他是唯一活下来的吗？"

# game/a9/10womb.rpy:180
translate english womb_abb4aa72:

    # cass "Из лордов? Да. Все остальные погибли. Но с нами не только Арамис, Локхарт, свояк моего брата теперь Лорд Ривелье и Зеленых Вод."
    cass "领主中吗？是的。其他的都死了。但我们这边不止Aramis，Lockhart，我兄长的姐夫如今也是Rivelle和碧水域的领主了。"

# game/a9/10womb.rpy:181
translate english womb_5eb0a253:

    # bart "Ага..."
    bart "哦……"

# game/a9/10womb.rpy:183
translate english womb_e7d7f6da:

    # cass "Так о чем бишь я...ты ведь уважишь последнее желание твоего отца - впустишь нашу армию?"
    cass "我刚说到哪儿了……你会尊重你父亲的遗愿——放我们的军队进来，对吧？"

# game/a9/10womb.rpy:184
translate english womb_1c8823af:

    # bart "Я...ну да...наверное...какое желание?"
    bart "我……嗯，是的……大概……什么遗愿？"

# game/a9/10womb.rpy:185
translate english womb_b8656a6f:

    # cass "Желание остановить кровопролитие. Ты ведь не за мятежников?"
    cass "停止流血的遗愿。你不是支持叛军的吧？"

# game/a9/10womb.rpy:186
translate english womb_dd4f5486_1:

    # bart "Нет!"
    bart "不是！"

# game/a9/10womb.rpy:187
translate english womb_7df21c07:

    # cass "Тогда ты за лордов? За порядок?"
    cass "那你支持领主们？支持秩序？"

# game/a9/10womb.rpy:188
translate english womb_5c579258:

    # bart "Да!"
    bart "是的！"

# game/a9/10womb.rpy:189
translate english womb_4267effa:

    # cass "Умница. Тогда надо открыть ворота."
    cass "真聪明。那就得打开城门。"

# game/a9/10womb.rpy:190
translate english womb_5780c9bb:

    # bart "Я открою, но вам надо знать - бродячие артисты отравили все наши припасы."
    bart "我会开的，但你们得知道——那些流浪艺人毒害了我们所有的补给品。"

# game/a9/10womb.rpy:191
translate english womb_5b9353e1:

    # cass "Что? О чем ты?"
    cass "什么？你在说什么？"

# game/a9/10womb.rpy:192
translate english womb_3d8ea513:

    # bart "Долго армию здесь держать не получится. Я по глупости впустил сюда бродячих артистов...я уже год здесь сижу по настоянию отца и мне стало скучно..."
    bart "军队没法在这里久留了。我一时愚蠢，放了些流浪艺人进来……我听从父亲的吩咐在这里待了一年了，觉得太无聊了……"

# game/a9/10womb.rpy:193
translate english womb_3e1c21aa:

    # cass "Ближе к делу..."
    cass "说重点……"

# game/a9/10womb.rpy:194
translate english womb_e802b8d0:

    # bart "Они отравили зерно...и исчезли."
    bart "他们在谷物里下了毒……然后消失了。"

# game/a9/10womb.rpy:195
translate english womb_8284f01e:

    # cass "Исчезли?"
    cass "消失了？"

# game/a9/10womb.rpy:196
translate english womb_1d822cc2:

    # bart "Да! Охрана услышала шум в амбаре, но когда они туда ворвались - никого уже не было! А на утро оказалось, что и все артисты пропали."
    bart "是的！守卫听到谷仓有动静，但等他们冲进去时，人已经没了！到了早上，发现所有艺人也都不见了。"

# game/a9/10womb.rpy:198
translate english womb_eedabaaf_1:

    # me "А среди этих 'бродячих артистов' были эльфы?"
    me "这些'流浪艺人'里有精灵吗？"

# game/a9/10womb.rpy:199
translate english womb_e508061b:

    # bart "Да...кажется да, были."
    bart "有……好像有，有的。"

# game/a9/10womb.rpy:200
translate english womb_c59e055b:

    # cass "Ты думаешь..."
    cass "你认为……"

# game/a9/10womb.rpy:201
translate english womb_502b4baa:

    # me "Я уверен. "
    me "我肯定。"

# game/a9/10womb.rpy:202
translate english womb_70520e15:

    # cass "Почему?"
    cass "为什么？"

# game/a9/10womb.rpy:203
translate english womb_fe00075b:

    # me "Порталы. Я лично знаю пару эльфов, которые могли бы это сделать."
    me "传送门。我亲自认识几个能做到这点的精灵。"

# game/a9/10womb.rpy:204
translate english womb_68101b41:

    # cass "Твоя мать?"
    cass "你母亲？"

# game/a9/10womb.rpy:205
translate english womb_8c267fbc:

    # me "Она здесь ни при чем. Эти эльфы...что-то вроде мятежников."
    me "她与此事无关。这些精灵……算是叛徒吧。"

# game/a9/10womb.rpy:206
translate english womb_6c11fe66:

    # cass "Мятежники и...эльфийские мятежники действуют сообща?"
    cass "叛军和……精灵叛徒在联手行动？"

# game/a9/10womb.rpy:207
translate english womb_fc30fd2b:

    # me "Да."
    me "是的。"

# game/a9/10womb.rpy:208
translate english womb_cded30d5:

    # cass "И что нам с этим делать?"
    cass "那我们该怎么办？"

# game/a9/10womb.rpy:209
translate english womb_dd5093d8_1:

    # me "Ничего."
    me "什么都不做。"

# game/a9/10womb.rpy:210
translate english womb_5d74a985:

    # cass "Ничего?"
    cass "什么都不做？"

# game/a9/10womb.rpy:212
translate english womb_d1e2596b:

    # me "Ничего. Они отвлекают нас. Тянут время."
    me "什么都不做。他们在分散我们的注意力。拖延时间。"

# game/a9/10womb.rpy:213
translate english womb_11575f01:

    # cass "Все равно не понимаю, зачем им это нужно."
    cass "我还是不明白，他们这么做需要达到什么目的。"

# game/a9/10womb.rpy:214
translate english womb_a28d80b8_1:

    # me "Не знаю. Может мятежники им что-то пообещали, а может им просто выгоден хаос среди людей."
    me "不知道。也许是叛军许诺了他们什么，也许他们只是想看到人类陷入混乱。"

# game/a9/10womb.rpy:215
translate english womb_651ccc28:

    # cass "..."
    cass "..."

# game/a9/10womb.rpy:216
translate english womb_d3dbb85d:

    # me "Будем действовать по плану. Дождемся армию вассалов отца и двинемся в Ривелье."
    me "我们按计划行事。等父亲的封臣军队到了，就向Rivelle进发。"

# game/a9/10womb.rpy:217
translate english womb_1abf799c_1:

    # me "Если береговые лорды рискнут напасть - дадим бой. Если нет - будем выдвигать им ультиматумы один за другим."
    me "如果海岸领主们胆敢进攻，我们就开战。如果不敢，我们就一个一个地向他们下达最后通牒。"

# game/a9/10womb.rpy:218
translate english womb_113d947a:

    # cass "Хорошо. Просто действуем по плану. Барт, откроешь ворота?"
    cass "好的。就按计划行事。Bart，你会开城门吗？"

# game/a9/10womb.rpy:219
translate english womb_ccba6ed6:

