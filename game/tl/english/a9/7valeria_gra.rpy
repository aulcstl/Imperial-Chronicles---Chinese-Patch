# game/a9/7valeria_gra.rpy:3
translate english valeria_gra_169ce204:

    # "Следующим вечером."
    "第二天晚上。"

# game/a9/7valeria_gra.rpy:4
translate english valeria_gra_19270857:

    # me "{i}Пару дней и пора отправляться в Темногорье.{/i}"
    me "{i}再过几天就该动身前往暗山了。{/i}"

# game/a9/7valeria_gra.rpy:5
translate english valeria_gra_4e6717d8:

    # me "{i}Надо подумать, кого взять с собой.{/i}"
    me "{i}得考虑一下带谁一起去。{/i}"

# game/a9/7valeria_gra.rpy:7
translate english valeria_gra_2135c655:

    # me "{i}Мама точно поедет со мной.{/i}"
    me "{i}妈妈肯定要跟我走。{/i}"

# game/a9/7valeria_gra.rpy:8
translate english valeria_gra_ec9ac1e9:

    # me "{i}[elin]...теперь это ее новый дом.{/i}"
    me "{i}[elin]……如今这里已是她的新家。{/i}"

# game/a9/7valeria_gra.rpy:9
translate english valeria_gra_8417fa8d:

    # me "{i}Но с другой стороны здесь пока небезопасно.{/i}"
    me "{i}但另一方面，眼下这儿还不安全。{/i}"

# game/a9/7valeria_gra.rpy:10
translate english valeria_gra_d31dd914:

    # me "{i}Пока война не окончится - лучше она будет со мной.{/i}"
    me "{i}在战争结束前——她最好还是跟着我。{/i}"

# game/a9/7valeria_gra.rpy:11
translate english valeria_gra_5c76dbe7:

    # me "{i}...{/i}"
    me "{i}...{/i}"

# game/a9/7valeria_gra.rpy:12
translate english valeria_gra_782b4fa3:

    # me "{i}Опять неделю в дороге... Неужели жизнь короля из этого и состоит? А Императора?{/i}"
    me "{i}又是一周的路途奔波……难道一个国王的人生就是如此？皇帝的人生呢？{/i}"

# game/a9/7valeria_gra.rpy:19
translate english valeria_gra2_752abe78:

    # valeria "Прости, [mename], я не помешала твоему ужину?"
    valeria "抱歉，[mename]，我没打扰你用餐吧？"

# game/a9/7valeria_gra.rpy:20
translate english valeria_gra2_ef6160a5:

    # me "Мнм? Неа."
    me "嗯？没有。"

# game/a9/7valeria_gra.rpy:21
translate english valeria_gra2_b1e1c649:

    # valeria "Я могу зайти попозже, если ты хочешь."
    valeria "我可以稍后再来，如果你想的话。"

# game/a9/7valeria_gra.rpy:22
translate english valeria_gra2_71f63b26:

    # me "Да все нормально."
    me "真的没关系。"

# game/a9/7valeria_gra.rpy:23
translate english valeria_gra2_123d9500:

    # valeria "Точно?"
    valeria "确定吗？"

# game/a9/7valeria_gra.rpy:24
translate english valeria_gra2_35e31ca4:

    # me "Да. Присоединяйтесь ко мне, леди Валерия."
    me "确定。一起吃吧，Valeria夫人。"

# game/a9/7valeria_gra.rpy:25
translate english valeria_gra2_c5cfb5da:

    # valeria "Ох, спасибо, но я уже поела."
    valeria "哦，谢谢，不过我已经吃过了。"

# game/a9/7valeria_gra.rpy:26
translate english valeria_gra2_4366e696:

    # me "Ладно..."
    me "好吧……"

# game/a9/7valeria_gra.rpy:27
translate english valeria_gra2_d8af9eaa:

    # valeria "Я пришла поговорить."
    valeria "我来是想谈谈。"

# game/a9/7valeria_gra.rpy:28
translate english valeria_gra2_74c20ff1:

    # me "О чем?"
    me "谈什么？"

# game/a9/7valeria_gra.rpy:30
translate english valeria_gra2_9f9b33a9:

    # valeria "Ты понимаешь о чем."
    valeria "你心知肚明。"

# game/a9/7valeria_gra.rpy:31
translate english valeria_gra2_dfcceeac:

    # me "М?"
    me "嗯？"

# game/a9/7valeria_gra.rpy:32
translate english valeria_gra2_0c2c287e:

    # valeria "О моем сыне."
    valeria "关于我儿子。"

# game/a9/7valeria_gra.rpy:33
translate english valeria_gra2_7af28cf1:

    # me "А что с ним?"
    me "他怎么了？"

# game/a9/7valeria_gra.rpy:34
translate english valeria_gra2_058cfacc:

    # valeria "С ним все хорошо. Благодаря тебе. Я пришла сказать тебе спасибо."
    valeria "他一切都好。多亏了你。我正是来向你道谢的。"

# game/a9/7valeria_gra.rpy:35
translate english valeria_gra2_0180356f:

    # me "А...Не за что благодарить."
    me "啊……不用谢。"

# game/a9/7valeria_gra.rpy:36
translate english valeria_gra2_a8181d00:

    # valeria "Нет. Есть за что. Спасибо. Искреннее спасибо от меня, как от матери, [mename]."
    valeria "不。理应道谢。谢谢你。作为一个母亲，我由衷地感谢你，[mename]。"

# game/a9/7valeria_gra.rpy:37
translate english valeria_gra2_5c93e48b:

    # me "Я не испытал сильных трудностей с тем, чтобы ему помочь. Так что право - не стоит."
    me "帮他并没费我多大力气。所以真的——不必了。"

# game/a9/7valeria_gra.rpy:38
translate english valeria_gra2_be32e6f6:

    # valeria "И все же - спасибо. Спасибо. Тысячу раз спасибо. Валериан сказал мне, что тоже хочет тебя поблагодарить, но не нашел тебя в замке."
    valeria "即便如此——还是要谢谢你。谢谢。千万个感谢。Valerian告诉我，他也想亲自感谢你，但在城堡里没找到你。"

# game/a9/7valeria_gra.rpy:39
translate english valeria_gra2_0ca286de:

    # me "Да. Я готовлюсь к поездке в Темногорье, так что приходиться посещать конюшни, склады, оружейные, лагеря и прочее. Вот - вырвался на секунду перекусить."
    me "是啊。我正准备动身去暗山，所以不得不跑马厩、仓库、军械库、营地这些地方。这不——刚抽空回来吃口东西。"

# game/a9/7valeria_gra.rpy:41
translate english valeria_gra2_ed16af52:

    # valeria "Ох, в таком случае не буду тебе мешать."
    valeria "哦，既然如此，我就不打扰你了。"

# game/a9/7valeria_gra.rpy:44
translate english valeria_gra2_2f966efd:

    # valeria "Спасибо тебе."
    valeria "谢谢你。"

# game/a9/7valeria_gra.rpy:45
translate english valeria_gra2_5ad852e5:

    # me "Хватит меня благодарить."
    me "别再谢我了。"

# game/a9/7valeria_gra.rpy:46
translate english valeria_gra2_f0052548:

    # valeria "Я не могу остановиться. Ты очень сильно мне помог."
    valeria "我停不下来。你帮了我太大的忙了。"

# game/a9/7valeria_gra.rpy:47
translate english valeria_gra2_5acd4a13:

    # me "Я помог Валериану."
    me "我帮的是Valerian。"

# game/a9/7valeria_gra.rpy:48
translate english valeria_gra2_0eeb6979:

    # valeria "Для меня сын самое дорогое, так что помощь ему - это помощь мне. Спасибо. Ты первый за долгие годы, кто сделал это."
    valeria "对我来说，儿子是最珍贵的，帮他，就等于帮我。谢谢你。这么多年来，你是第一个这么做的人。"

# game/a9/7valeria_gra.rpy:49
translate english valeria_gra2_752e937b:

    # me "Да ну."
    me "啊，哪儿的话。"

# game/a9/7valeria_gra.rpy:50
translate english valeria_gra2_e7e8b211:

    # valeria "Да. Обычно мужчины теряют интерес к женщине, когда получают от нее, что хотят. Но ты все равно помог Валериану."
    valeria "是真的。男人们通常从女人身上得到想要的东西后，就会失去兴趣。但你还是帮了Valerian。"

# game/a9/7valeria_gra.rpy:51
translate english valeria_gra2_3820771a:

    # me "..."
    me "..."

# game/a9/7valeria_gra.rpy:52
translate english valeria_gra2_c9b91f75:

    # valeria "Это так благородно и бескорыстно. Ты просто помог ничего не требуя взамен."
    valeria "如此高尚，如此无私。你只是帮忙，不求任何回报。"

# game/a9/7valeria_gra.rpy:53
translate english valeria_gra2_e0461507:

    # me "Может быть и не бескорыстно. Может я хотел что-то взамен?"
    me "也许并非无私。也许我想要点什么作为回报呢？"

# game/a9/7valeria_gra.rpy:55
translate english valeria_gra2_89638952:

    # valeria "Да? и что?"
    valeria "是吗？想要什么？"

# game/a9/7valeria_gra.rpy:56
translate english valeria_gra2_2e9c9ebf:

    # me "А что ты можешь предложить?"
    me "那你能给我什么？"

# game/a9/7valeria_gra.rpy:57
translate english valeria_gra2_7adf419b:

    # valeria "Вот видишь. Ты даже не знаешь чего попросить. Значит действовал бескорыстно."
    valeria "你看。你甚至都不知道该要求什么。所以，你确实是无私的。"

# game/a9/7valeria_gra.rpy:58
translate english valeria_gra2_3081a9df:

    # me "Ты думаешь обо мне лучше, чем я есть на самом деле."
    me "你把我想得太好了，比真实的我好多了。"

# game/a9/7valeria_gra.rpy:59
translate english valeria_gra2_b351d83a:

    # valeria "Докажи."
    valeria "证明给我看。"

# game/a9/7valeria_gra.rpy:60
translate english valeria_gra2_7ec0f9d9:

    # me "Доказать?"
    me "证明？"

# game/a9/7valeria_gra.rpy:61
translate english valeria_gra2_8a4c85c6:

    # valeria "Да. Докажи. Докажи, что ты на самом деле плохой мальчик. Расчетливый и гнусный."
    valeria "对。证明啊。证明你其实就是个坏小子。精于算计，卑鄙无耻。"

# game/a9/7valeria_gra.rpy:63
translate english valeria_gra2_fbeda822:

    # me "Если идеи, как я могу это сделать?"
    me "我该怎么做呢，你有主意吗？"

# game/a9/7valeria_gra.rpy:64
translate english valeria_gra2_09a48402:

    # valeria "Есть парочка."
    valeria "有一两个。"

# game/a9/7valeria_gra.rpy:65
translate english valeria_gra2_e473fa2f:

    # me "Например?"
    me "比如？"

# game/a9/7valeria_gra.rpy:66
translate english valeria_gra2_74048f73:

    # valeria "Ну...я замужняя женщина..."
    valeria "嗯……我可是有夫之妇……"

# game/a9/7valeria_gra.rpy:67
translate english valeria_gra2_55153e7f:

    # me "Продолжай..."
    me "继续说……"

# game/a9/7valeria_gra.rpy:68
translate english valeria_gra2_9c398ad0:

    # valeria "И было бы крайне гнусно и корыстно просить меня, взамен на твою помощь..."
    valeria "如果你拿你的帮助做要挟……那该是多么卑鄙、多么自私的事啊……"

# game/a9/7valeria_gra.rpy:69
translate english valeria_gra2_c30a1e24:

    # me "Просить о чем?"
    me "要挟什么？"

# game/a9/7valeria_gra.rpy:70
translate english valeria_gra2_d5b10ce9:

    # valeria "Ну...знаешь...о всяких непристойностях."
    valeria "啊……你知道的……一些见不得人的事。"

# game/a9/7valeria_gra.rpy:71
translate english valeria_gra2_4f30b7b3:

    # me "Каких непристойностях?"
    me "什么见不得人的事？"

# game/a9/7valeria_gra.rpy:73
translate english valeria_gra2_bee3ce85:

    # valeria "Было бы по-настоящему ужасно, если бы ты потребовал от меня нарушить мою супружескую клятву."
    valeria "如果你要求我违背我的婚姻誓言，那可真就太可怕了。"

# game/a9/7valeria_gra.rpy:74
translate english valeria_gra2_a6ca38e2:

    # me "Ну что вы, леди Валерия, это чересчур даже для меня."
    me "您快别说了，Valeria夫人，这种事，即使对我来说也太过了。"

# game/a9/7valeria_gra.rpy:75
translate english valeria_gra2_067cc7b9:

    # valeria "Уверен?"
    valeria "你确定吗？"

# game/a9/7valeria_gra.rpy:76
translate english valeria_gra2_7e3095bb:

    # me "Нет. Мне кажется я бы пошел на такой отвратительный поступок при одном условии."
    me "不。我觉得，在某些条件下，我可能真会干出这种可恶的事。"

# game/a9/7valeria_gra.rpy:77
translate english valeria_gra2_4d8655a5:

    # valeria "Каком?"
    valeria "什么条件？"

# game/a9/7valeria_gra.rpy:78
translate english valeria_gra2_ec02db9c:

    # me "Если бы вы мне не отказали."
    me "只要您不拒绝我。"

# game/a9/7valeria_gra.rpy:79
translate english valeria_gra2_dbc2b5e0:

    # valeria "Я не могу отказать тебе, [mename]."
    valeria "我无法拒绝你，[mename]。"

# game/a9/7valeria_gra.rpy:81
translate english valeria_gra2_631876e5:

    # valeria "Ты так много для меня сделал. Если я откажу тебе - это будет даже хуже, чем нарушить мою супружескую клятву."
    valeria "你为我做了那么多。如果我拒绝了你——那比违背婚姻誓言更糟糕。"

# game/a9/7valeria_gra.rpy:82
translate english valeria_gra2_66ef5e19:

    # me "Так мне остается только воспользоваться моим положением?"
    me "所以，我只能利用我的这点优势了？"

# game/a9/7valeria_gra.rpy:84
translate english valeria_gra2_60f8a549:

    # valeria "Ну да. А ты воспользуешься?"
    valeria "嗯，是啊。那你会利用吗？"

# game/a9/7valeria_gra.rpy:85
translate english valeria_gra2_595d7b8c:

    # me "Не знаю."
    me "不知道。"

# game/a9/7valeria_gra.rpy:86
translate english valeria_gra2_9a20009f:

    # valeria "Что-то все еще останавливает тебя от этого ужасного, отвратительного поступка?"
    valeria "还有什么在阻止你做出这可怕、可恶的事情吗？"

# game/a9/7valeria_gra.rpy:87
translate english valeria_gra2_10201233:

    # me "Наверное во мне проснулась совесть."
    me "大概是我的良心突然觉醒了吧。"

# game/a9/7valeria_gra.rpy:88
translate english valeria_gra2_87ba067e:

    # valeria "Да ладно."
    valeria "得了吧。"

# game/a9/7valeria_gra.rpy:89
translate english valeria_gra2_5bfd9b83:

    # me "Да. Я как-никак все же будущий Император."
    me "真的。我好歹是未来的皇帝。"

# game/a9/7valeria_gra.rpy:90
translate english valeria_gra2_600046b7:

    # valeria "Оу. Понимаю. Будущий Император не может запятнать себя таким низким поступком."
    valeria "哦，我明白了。未来的皇帝不能让自己沾染如此下作的污点。"

# game/a9/7valeria_gra.rpy:91
translate english valeria_gra2_082ef00b:

    # me "Да...но..."
    me "是啊……但是……"

# game/a9/7valeria_gra.rpy:92
translate english valeria_gra2_fd42d430:

    # valeria "Но?"
    valeria "但是？"

# game/a9/7valeria_gra.rpy:93
translate english valeria_gra2_2d7671e8:

    # me "Но даже Императоры иногда грешат, верно?"
    me "但是即使是皇帝，有时候也会犯下罪孽，不是吗？"

# game/a9/7valeria_gra.rpy:94
translate english valeria_gra2_067f11f5:

    # valeria "Верно. К тому же молодые Императоры. Пока морщины еще не тронули их лица - они часто забывают о морали."
    valeria "没错。尤其是年轻的皇帝。在皱纹还没爬上他们的脸庞时——他们时常会忘记道德。"

# game/a9/7valeria_gra.rpy:95
translate english valeria_gra2_1a06ee40:

    # me "Это правда. Но испортить деревенскую девку это не то же самое, что стать любовниками с женой будущего вассала."
    me "这倒是真的。但糟蹋一个乡下姑娘，和成为未来封臣妻子的情人，可不是一回事。"

# game/a9/7valeria_gra.rpy:96
translate english valeria_gra2_4cbcef6b:

    # valeria "Это намного хуже."
    valeria "这要恶劣得多。"

# game/a9/7valeria_gra.rpy:97
translate english valeria_gra2_423043a6:

    # me "Да..."
    me "是啊……"

# game/a9/7valeria_gra.rpy:98
translate english valeria_gra2_b7bf091a:

    # valeria "Ну так что...молодой Император поддастся искушению или нет?"
    valeria "所以，怎么样……年轻的皇帝会屈服于诱惑吗？"

# game/a9/7valeria_gra.rpy:99
translate english valeria_gra2_3820771a_1:

    # me "..."
    me "..."

# game/a9/7valeria_gra.rpy:101
translate english valeria_gra2_54faa069:

    # valeria "Я так понимаю это - Да?"
    valeria "我是不是该理解为——你同意了？"

# game/a9/7valeria_gra.rpy:102
translate english valeria_gra2_76e58ced:

    # me "Похоть сильнее самых сильных людей. Даже Императоров."
    me "欲望比最强壮的人还要强大。即使是皇帝也不例外。"

# game/a9/7valeria_gra.rpy:104
translate english valeria_gra2_af8057f7:

    # valeria "Мы можем привести сюда деревенскую девку."
    valeria "我们可以找个乡下姑娘过来。"

# game/a9/7valeria_gra.rpy:105
translate english valeria_gra2_5a7a7577:

    # me "Нет."
    me "不。"

# game/a9/7valeria_gra.rpy:106
translate english valeria_gra2_a88cb9a5:

    # valeria "Роскошную заморскую шлюху."
    valeria "一个奢侈的海外名妓。"

# game/a9/7valeria_gra.rpy:107
translate english valeria_gra2_5a7a7577_1:

    # me "Нет."
    me "不。"

# game/a9/7valeria_gra.rpy:108
translate english valeria_gra2_ab3cae51:

    # valeria "Девственную городскую девушку."
    valeria "一个纯洁的城里姑娘。"

# game/a9/7valeria_gra.rpy:109
translate english valeria_gra2_5a7a7577_2:

    # me "Нет."
    me "不。"

# game/a9/7valeria_gra.rpy:110
translate english valeria_gra2_d8e57755:

    # valeria "Экзотическую сирену."
    valeria "一个充满异域风情的海妖。"

# game/a9/7valeria_gra.rpy:111
translate english valeria_gra2_5a7a7577_3:

    # me "Нет."
    me "不。"

# game/a9/7valeria_gra.rpy:112
translate english valeria_gra2_b12cb8b4:

    # valeria "Ты хочешь трахнуть именно жену твоего вассала? Хочешь нарушить Золотой Порядок? Хочешь разрушить мою с мужем клятву?"
    valeria "你偏偏想操你的封臣的妻子？想破坏黄金律法？想摧毁我和我丈夫的誓言？"

# game/a9/7valeria_gra.rpy:113
translate english valeria_gra2_fc30fd2b:

    # me "Да."
    me "是的。"

# game/a9/7valeria_gra.rpy:115
translate english valeria_gra2_aa06baf2:

    # valeria "Плохой...плохой мальчик."
    valeria "坏……坏小子。"

# game/a9/7valeria_gra.rpy:116
translate english valeria_gra2_56ce70f9:

    # me "Император."
    me "是皇帝。"

# game/a9/7valeria_gra.rpy:117
