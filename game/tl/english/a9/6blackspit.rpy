# game/a9/6blackspit.rpy:3
translate english blackspit_848daee1:

    # "Несколько недель спустя."
    "几周以后。"

# game/a9/6blackspit.rpy:4
translate english blackspit_7ef6fe1a:

    # knight "Назад, мрази!"
    knight "退后，人渣！"

# game/a9/6blackspit.rpy:5
translate english blackspit_c9f26eb1:

    # myat "Зачем ты сражаешься, идиот? Твой лорд давно мертв."
    myat "你为什么还要打，白痴？你的领主早就死了。"

# game/a9/6blackspit.rpy:6
translate english blackspit_9380556b:

    # knight "Я в это никогда не поверю, можете даже не пытаться."
    knight "我绝不会相信，你们连试都别想试。"

# game/a9/6blackspit.rpy:8
translate english blackspit_7e38a098:

    # myat "Замок захвачен, в это ты хоть поверить можешь? "
    myat "城堡已被攻陷，至少这点你总能信吧？"

# game/a9/6blackspit.rpy:9
translate english blackspit_9837f794:

    # myat2 "Ты получаешь оттуда жалование."
    myat2 "你可是从那里领薪饷的。"

# game/a9/6blackspit.rpy:10
translate english blackspit_8e627741:

    # knight "Замок был захвачен. Лорд Аргус и остальные отбили его."
    knight "城堡先前陷落过了。是Argus领主和其他人又把它夺了回来。"

# game/a9/6blackspit.rpy:11
translate english blackspit_e36bb96c:

    # myat "Да. И почему же оттуда нет новостей? "
    myat "是吗。那为什么那边至今没有消息传来？"

# game/a9/6blackspit.rpy:12
translate english blackspit_fd913251:

    # myat2 "Верно, разве лорд Аргус не стал бы зачищать город, если бы замок был под его контролем?"
    myat2 "对啊，如果城堡真在Argus领主控制下，他怎么会不出来清扫城市？"

# game/a9/6blackspit.rpy:13
translate english blackspit_d345699f:

    # knight "Да вы и сами нихрена не знаете, кто там победил, верно?"
    knight "你们自己他妈也不知道到底谁赢了，对吧？"

# game/a9/6blackspit.rpy:14
translate english blackspit_e8965276:

    # myat "..."
    myat "..."

# game/a9/6blackspit.rpy:15
translate english blackspit_5970ad5a:

    # myat2 "Тут он, сука, прав."
    myat2 "妈的，这家伙说得没错。"

# game/a9/6blackspit.rpy:17
translate english blackspit_cd84e228:

    # myat "Эй, ты видишь?"
    myat "喂，你看见了吗？"

# game/a9/6blackspit.rpy:18
translate english blackspit_02d378b9:

    # myat2 "И слышу."
    myat2 "也听见了。"

# game/a9/6blackspit.rpy:19
translate english blackspit_3dbc0952:

    # myat "Думаешь это наши?"
    myat "你觉得会是我们的人吗？"

# game/a9/6blackspit.rpy:20
translate english blackspit_d6435e59:

    # myat2 "На лошадях? Вряд ли."
    myat2 "骑着马？不大可能。"

# game/a9/6blackspit.rpy:21
translate english blackspit_4555a4ef:

    # knight "Хах. Вот и подмога с речного городка. Пиздец вам, ублюдки."
    knight "哈。河镇来的援军到了。你们这帮杂种死定了。"

# game/a9/6blackspit.rpy:22
translate english blackspit_eb6f3b88:

    # myat "Нужно бежать."
    myat "得赶紧跑。"

# game/a9/6blackspit.rpy:23
translate english blackspit_be04ffd9:

    # myat2 "Только что хотел это предложить."
    myat2 "我刚想提议这个。"

# game/a9/6blackspit.rpy:25
translate english blackspit_e2519c42:

    # myat "Только куда бежать? Может замок действительно отбили?"
    myat "可逃去哪儿？万一城堡真的被夺回来了呢？"

# game/a9/6blackspit.rpy:26
translate english blackspit_30db9f91:

    # myat2 "Спрячемся в городе!"
    myat2 "咱们藏进城里去！"

# game/a9/6blackspit.rpy:27
translate english blackspit_a67d1b08:

    # knight "Правильно! Бегите! Прячьтесь, ублюдки!"
    knight "没错！跑吧！藏起来吧，杂种们！"

# game/a9/6blackspit.rpy:28
translate english blackspit_ad2ec884:

    # knight "Только это вам не поможет."
    knight "不过这也救不了你们。"

# game/a9/6blackspit.rpy:29
translate english blackspit_963bd9d8:

    # knight "Я запомнил ваши уродские лица, когда город отобьют - я опознаю вас."
    knight "我记住了你们这些丑陋的面孔，等城市被夺回的时候——我会指认你们。"

# game/a9/6blackspit.rpy:30
translate english blackspit_5aae92f6:

    # knight "И тогда ваши жирные шеи на ночь обнимут не жены, а веревка."
    knight "到时候晚上搂着你们肥脖子的，就不是老婆，而是绞索了。"

# game/a9/6blackspit.rpy:31
translate english blackspit_0c356308:

    # knight "Понятно вам, ублюдки?"
    knight "听明白了吗，杂种？"

# game/a9/6blackspit.rpy:33
translate english blackspit_11182183:

    # cass "Что он так раскричался?"
    cass "他干嘛这么声嘶力竭的？"

# game/a9/6blackspit.rpy:34
translate english blackspit_26848744:

    # me "Думает, мы люди лордов."
    me "他以为我们是领主的人。"

# game/a9/6blackspit.rpy:35
translate english blackspit_03c571a3:

    # cass "Как же он ошибается."
    cass "那他可大错特错了。"

# game/a9/6blackspit.rpy:36
translate english blackspit_15a06f4f:

    # me "Разве? Мы все же за восстание?"
    me "是吗？咱们说到底还是支持起义的？"

# game/a9/6blackspit.rpy:37
translate english blackspit_8695fbcb:

    # cass "Мы ни за кого. [mename]. Мы пришли навести порядок. Но для удобства можно представляться мятежниками для мятежников и лоялистами для лоялистов."
    cass "我们谁也不支持。[mename]。我们是来恢复秩序的。不过为了方便，可以在起义军面前自称起义军，在保皇派面前自称保皇派。"

# game/a9/6blackspit.rpy:38
translate english blackspit_fb6303a8:

    # me "Понял."
    me "明白了。"

# game/a9/6blackspit.rpy:39
translate english blackspit_b7e3656f:

    # knight "Ну наконец-то вы прибыли! Я УЖЕ УСТАЛ УБИВАТЬ ЭТИХ МРАЗЕЙ!"
    knight "你们总算来了！我杀这帮人渣都杀腻了！"

# game/a9/6blackspit.rpy:41
translate english blackspit_ce2d79ac:

    # knight "Сначала нужно захватить колокольни! Дать знак защитникам в замке, что вы прибыли на их помощь."
    knight "首先得拿下钟楼！给城堡里的守军发信号，让他们知道你们是来支援的。"

# game/a9/6blackspit.rpy:42
translate english blackspit_b761f5a5:

    # cass "Тссс. Ты чего такой громкий?"
    cass "嘘。你这么大嗓门干嘛？"

# game/a9/6blackspit.rpy:43
translate english blackspit_3cdec284:

    # knight "Я хочу помочь! Рассказать о ситуации в городе!"
    knight "我想帮忙！汇报城里的情况！"

# game/a9/6blackspit.rpy:44
translate english blackspit_620f228b:

    # cass "Во-первых прекрати орать. Лишний шум нам сейчас точно ни к чему."
    cass "首先，别嚷嚷。我们现在最不需要的就是额外的噪音。"

# game/a9/6blackspit.rpy:45
translate english blackspit_91f8cd44:

    # knight "Почему? Секундочку...вы люди какого лорда?"
    knight "为什么？等等……你们是哪位领主的人？"

# game/a9/6blackspit.rpy:46
translate english blackspit_6d0fe8b3:

    # cass "Мы представляем не лорда."
    cass "我们不代表任何领主。"

# game/a9/6blackspit.rpy:47
translate english blackspit_bf489733:

    # knight "А кого?"
    knight "那代表谁？"

# game/a9/6blackspit.rpy:48
translate english blackspit_72364d01:

    # cass "Императора."
    cass "皇帝。"

# game/a9/6blackspit.rpy:49
translate english blackspit_123b25ee:

    # knight "Э..."
    knight "呃……"

# game/a9/6blackspit.rpy:50
translate english blackspit_97d3dbbf:

    # cass "Ты хочешь помочь убить всех мятежников?"
    cass "你想帮忙杀光所有叛军吗？"

# game/a9/6blackspit.rpy:51
translate english blackspit_c543f544:

    # knight "Да."
    knight "是的。"

# game/a9/6blackspit.rpy:52
translate english blackspit_827959f5:

    # cass "Тогда расскажешь, все что знаешь моему другу. Займешься, Буррус?"
    cass "那就把你所知道的一切都告诉我朋友。交给你了，布洛斯？"

# game/a9/6blackspit.rpy:53
translate english blackspit_2bee385e:

    # zpd1 "Да."
    zpd1 "好的。"

# game/a9/6blackspit.rpy:54
translate english blackspit_10750808:

    # knight "Так вы...вы против мятежников?"
    knight "这么说你们……你们是来对付起义军的？"

# game/a9/6blackspit.rpy:55
translate english blackspit_6da930d9:

    # cass "Ну конечно. Мы всех их убьем."
    cass "当然。我们会把他们杀个精光。"

# game/a9/6blackspit.rpy:56
translate english blackspit_eb18c9b4:

    # knight "А лорды..."
    knight "那领主们……"

# game/a9/6blackspit.rpy:57
translate english blackspit_a0372216:

    # cass "Как раз идем их спасать."
    cass "我们正要去救他们。"

# game/a9/6blackspit.rpy:59
translate english blackspit_d2b19717:

    # me "Ты его обманула."
    me "你骗了他。"

# game/a9/6blackspit.rpy:60
translate english blackspit_d2be07c9:

    # cass "Ну что ты. Я наоборот сказала ему правду. Мы убьем всех мятежников."
    cass "怎么会呢。我反倒对他说了实话。我们会杀光所有起义军。"

# game/a9/6blackspit.rpy:61
translate english blackspit_47157390:

    # me "Если они проигрывают."
    me "如果他们要输了的话。"

# game/a9/6blackspit.rpy:62
translate english blackspit_157c988b:

    # cass "Судя по тому, что в городе все еще идут бои - победителя нет."
    cass "看城里还在打，说明还没分出胜负。"

# game/a9/6blackspit.rpy:63
translate english blackspit_dffd29c3:

    # me "Почему ты так решила?"
    me "你怎么这么确定？"

# game/a9/6blackspit.rpy:64
translate english blackspit_28e5ef55:

    # cass "Сомневаюсь, что у мятежников был какой-то долгосрочный план. Скорее всего они выманили часть войск из замка, а потом попробовали захватить его."
    cass "我怀疑起义军那边根本没有什么长远计划。他们很可能是先把一部分兵力引出城堡，然后再尝试夺取它。"

# game/a9/6blackspit.rpy:65
translate english blackspit_837bc3a0:

    # me "И у них не получилось?"
    me "而他们没成功？"

# game/a9/6blackspit.rpy:66
translate english blackspit_13c92af6:

    # cass "Видимо получилось. Иначе мятежа бы уже не было. Но что-то пошло не так."
    cass "看来是成功了。要不然起义早就被扑灭了。但后来出了岔子。"

# game/a9/6blackspit.rpy:67
translate english blackspit_e473fa2f:

    # me "Например?"
    me "比如说？"

# game/a9/6blackspit.rpy:68
translate english blackspit_1b7bdfa3:

    # cass "Не знаю. Может они захватили замок, но им не удалось взять цитадель? Или те, кого выманили, вернулись и бой идет до сих пор."
    cass "不知道。也许他们攻下了城堡，却没拿下主塔？又或者被引出去的那批人回来了，仗打到这会儿还没停。"

# game/a9/6blackspit.rpy:69
translate english blackspit_825c611b:

    # cass "В любом случае я пока не вижу, чтобы одна из сторон явно побеждала. Для нас это хорошо."
    cass "不管怎么说，我暂时还没看出哪一方明显占优。这对我们来说是好事。"

# game/a9/6blackspit.rpy:70
translate english blackspit_3820771a:

    # me "..."
    me "..."

# game/a9/6blackspit.rpy:71
translate english blackspit_22b227d5:

    # me "И все равно ты солгала. Сказала, что мы идем спасать лордов."
    me "可你还是撒谎了。你说我们是去救领主的。"

# game/a9/6blackspit.rpy:72
translate english blackspit_1deb628c:

    # cass "А мы спасем их. Тех, кто захочет 'спасения', конечно."
    cass "我们确实是去救他们的。当然，只救那些愿意‘得救’的。"

# game/a9/6blackspit.rpy:73
translate english blackspit_ecf0e9ac:

    # me "И что это значит?"
    me "这什么意思？"

# game/a9/6blackspit.rpy:74
translate english blackspit_23628cde:

    # cass "Ну ты ведь уже не маленький, [mename]. Сам все понимаешь."
    cass "你又不是小孩子了，[mename]。你自己心里明白。"

# game/a9/6blackspit.rpy:75
translate english blackspit_051636f8:

    # me "Мы спасем только тех, кто захочет с нами сотрудничать?"
    me "我们只救那些愿意跟我们合作的？"

# game/a9/6blackspit.rpy:76
translate english blackspit_0e1a6479:

    # cass "Молодец. Людвиг был прав, ты все же не безнадежен."
    cass "真聪明。Ludwig说得没错，你还不算无可救药。"

# game/a9/6blackspit.rpy:77
translate english blackspit_dfc5d919:

    # cass "Брось факел, дальше пойдем в темноте."
    cass "扔掉火把，剩下的路我们在黑暗里走。"

# game/a9/6blackspit.rpy:79
translate english blackspit_15a3d2e9:

    # me "Это зачем? Для внезапности?"
    me "为什么？为了出其不意？"

# game/a9/6blackspit.rpy:80
translate english blackspit_7bb1dde4:

    # cass "В том числе. А еще я предупредила моих людей в замке, что мы будем без факелов. Надо же им как-то понять, что армия въезжающая в город это та самая армия, а не мятежники или лорды."
    cass "不全是。还因为我预先通知了我在城堡里的人，我们会不打火把。总得让他们知道，这支开进城来的军队，是那支该来的军队，而不是起义军或者领主的人。"

# game/a9/6blackspit.rpy:81
translate english blackspit_ffe26313:

    # me "Ах, да...твои люди в замке. Это они постоянно помогали проигрывающей стороне?"
    me "哦，对了……你在城堡里的人。就是他们一直在帮即将落败的那方？"

# game/a9/6blackspit.rpy:82
translate english blackspit_e3d2b6bc:

    # cass "Может быть. "
    cass "也许是吧。"

# game/a9/6blackspit.rpy:83
translate english blackspit_f9d1609b:

    # me "Если это так они заслужили двойную оплату, ты так не считаешь?"
    me "要真是这样，他们该拿双倍的酬劳，你不觉得吗？"

# game/a9/6blackspit.rpy:84
translate english blackspit_0cac660c:

    # cass "Я не собираюсь им платить."
    cass "我不打算付钱给他们。"

# game/a9/6blackspit.rpy:85
translate english blackspit_5ac38cf1:

    # me "Почему?"
    me "为什么？"

# game/a9/6blackspit.rpy:86
translate english blackspit_d5123860:

    # cass "Потому что пока они живы, они слишком много знают. Мы ведь хотим склонять западных лордов к альянсу. Это будет тяжело, если кто-то прознает, что я помогала мятежу."
    cass "因为只要他们活着，就知道得太多。我们是想拉拢西部领主结盟的。要是被人发现我暗地里帮过起义军，那就难办了。"

# game/a9/6blackspit.rpy:87
translate english blackspit_3369df93:

    # me "Так что, мы просто убьем твоих людей?"
    me "所以，我们干脆杀掉你的人？"

# game/a9/6blackspit.rpy:88
translate english blackspit_ce084b10:

    # cass "Всех. В замке нужно убить всех. Кроме лордов, которых мы 'спасаем'."
    cass "全部。城堡里的人都得死。除了我们要‘拯救’的那些领主。"

# game/a9/6blackspit.rpy:89
translate english blackspit_a7aeb90b:

    # me "Эти лорды ведь увидят, что мы делаем."
    me "那些领主可是会看见我们的所作所为。"

# game/a9/6blackspit.rpy:90
translate english blackspit_4aea21c4:

    # cass "Мы освобождаем замок от мятежников, верно? Будет печальной, но неизбежной данностью, что в процессе погибнет кто-то из людей лордов."
    cass "我们把城堡从起义军手里解放出来，不是吗？在过程中会有领主的部下死掉，这虽然是件憾事，但也是难以避免的事实。"

# game/a9/6blackspit.rpy:91
translate english blackspit_74db5ba8:

    # me "Но не сами лорды."
    me "但不是领主本人。"

# game/a9/6blackspit.rpy:92
translate english blackspit_c76d26ab:

    # cass "Но не сами лорды."
    cass "但不是领主本人。"

# game/a9/6blackspit.rpy:93
translate english blackspit_9297f419:

    # zpd1 "[cassa], рыцарь сказал, что замок был захвачен мятежниками, пару дней назад часть лордов вернулась с речного городка и попыталась отбить замок. С тех пор оттуда нет вестей."
    zpd1 "[cassa]，那个骑士说城堡之前被起义军攻占过，几天前一部分领主从河镇回来，试图夺回城堡。之后就再没那边的消息了。"

# game/a9/6blackspit.rpy:95
translate english blackspit_98be1639:

    # cass "Как я и говорила."
    cass "正如我所料。"

# game/a9/6blackspit.rpy:96
translate english blackspit_04d8ac17:

    # zpd1 "Ах, да. Он сказал мятежники пробрались в замок через эльфийские развалины."
    zpd1 "哦，对了。他说起义军是通过精灵遗迹潜入城堡的。"

# game/a9/6blackspit.rpy:97
translate english blackspit_cfa79155:

    # cass "Спасибо, Буррус."
    cass "谢谢，布洛斯。"

# game/a9/6blackspit.rpy:98
translate english blackspit_4d30fcdb:

    # me "Твоих рук дело?"
    me "是你搞的鬼？"

# game/a9/6blackspit.rpy:99
translate english blackspit_23cdbfee:

    # cass "А?"
    cass "嗯？"

# game/a9/6blackspit.rpy:100
translate english blackspit_4e42e370:

    # me "Ну... Эльфиские развалины."
    me "就是……精灵遗迹。"

# game/a9/6blackspit.rpy:101
translate english blackspit_ee71715d:

    # cass "Может и моих."
    cass "可能是我安排的。"

# game/a9/6blackspit.rpy:102
translate english blackspit_dab3a491:

    # me "У тебя до сих пор от меня секреты?"
    me "你到现在还对我保守秘密？"

# game/a9/6blackspit.rpy:103
