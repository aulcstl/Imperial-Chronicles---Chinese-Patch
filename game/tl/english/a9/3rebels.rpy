    valerian "喂！我们在这儿！你们搞什么？会被人听到的！"

# game/a9/3rebels.rpy:235
translate english rebels_3986dbf7:

    # me "Нам пришлось импровизировать."
    me "我们不得不随机应变。"

# game/a9/3rebels.rpy:236
translate english rebels_d7656b46:

    # valerian "Ладно, поднимайте решетку."
    valerian "好了，把栅栏升起来。"

# game/a9/3rebels.rpy:237
translate english rebels_64f4b7bc:

    # mom "{size=+12}Tenmir uppta!{/size}"
    mom "{size=+12}Tenmir uppta!{/size}"

# game/a9/3rebels.rpy:239
translate english rebels_0c3195d0:

    # valerian "Ну и вонь."
    valerian "真臭。"

# game/a9/3rebels.rpy:240
translate english rebels_953b372b:

    # me "Так пахнет горящая плоть."
    me "燃烧的肉就是这个味道。"

# game/a9/3rebels.rpy:241
translate english rebels_d5fe5842:

    # valerian "Ужас. Надо было отвлечь этих идиотов снаружи. Прости."
    valerian "真可怕。该把外面那些白痴引开才对。对不起。"

# game/a9/3rebels.rpy:242
translate english rebels_15ccf90b:

    # me "Забудь. Что сделано, то сделано."
    me "别提了。木已成舟。"

# game/a9/3rebels.rpy:243
translate english rebels_b0d23ec7:

    # valerian "Вроде тревогу не подняли. Это хорошо. Скорее всего не заметили."
    valerian "看来没有惊动警报。那还好。很可能没被发现。"

# game/a9/3rebels.rpy:244
translate english rebels_22301206:

    # me "Странно. Кричали эти бедолаги сильно."
    me "奇怪。这些可怜虫刚才叫得挺大声的。"

# game/a9/3rebels.rpy:245
translate english rebels_257dd436:

    # valerian "На стенах сейчас людей не очень много. Почти все войска отправились с лордами в речной городок."
    valerian "墙上现在人不多。几乎所有军队都跟着领主们去河边小镇了。"

# game/a9/3rebels.rpy:246
translate english rebels_e73e705d:

    # me "Это отвлекающий маневр?"
    me "那是佯攻吗？"

# game/a9/3rebels.rpy:247
translate english rebels_c643b6eb:

    # valerian "Ага. Очень эффективный, потому что крестьяне, которых превратят в фарш, о том, что они отвлекающий маневр не знают. Кассиус хорошо насрал им в голову."
    valerian "没错。非常有效，因为那些即将变成肉泥的农民们并不知道自己是佯攻。卡西乌斯很好地给他们洗了脑。"

# game/a9/3rebels.rpy:248
translate english rebels_919e9f72:

    # me "Моя помощь еще нужна."
    me "还需要我帮忙吗？"

# game/a9/3rebels.rpy:249
translate english rebels_50141ce8:

    # valerian "Дальше я сам."
    valerian "接下来我自己来。"

# game/a9/3rebels.rpy:250
translate english rebels_68865f64:

    # me "Сам?"
    me "你自己？"

# game/a9/3rebels.rpy:252
translate english rebels_291de0d0:

    # valerian "Ты здесь не единственный доказываешь лояльность нашему общему делу Республики."
    valerian "在这里，你不是唯一一个要证明对共和国共同事业忠诚的人。"

# game/a9/3rebels.rpy:253
translate english rebels_fc0b62f3:

    # me "Лояльность к Генри."
    me "对亨利的忠诚。"

# game/a9/3rebels.rpy:254
translate english rebels_dcc6408c:

    # valerian "Ну да. Лояльность к Генри."
    valerian "对，对亨利的忠诚。"

# game/a9/3rebels.rpy:255
translate english rebels_f2aba93d:

    # me "Ну я то понятно, новое лицо, а что доказываешь ты?"
    me "我么，明摆着，是个新人，那你又要证明什么？"

# game/a9/3rebels.rpy:256
translate english rebels_88726f95:

    # valerian "Я скорее несу наказание за длинный язык. Помнишь тот случай, когда вы с Каталиной пришли в таверну Варго?"
    valerian "我更多是在为嘴快受罚。还记得那次你和卡塔琳娜来瓦尔戈酒馆的事吗？"

# game/a9/3rebels.rpy:257
translate english rebels_52437f65:

    # me "Ах. Ну да."
    me "啊。记得。"

# game/a9/3rebels.rpy:258
translate english rebels_61680cde:

    # valerian "Ну вот. Теперь я буду доказывать что это была глупая случайность, а не злой умысел с целью навредить Республике."
    valerian "所以。现在我要证明那只是一次愚蠢的意外，而不是要损害共和国的恶意企图。"

# game/a9/3rebels.rpy:259
translate english rebels_0d6eeb29:

    # me "Ладно. Удачи."
    me "好吧。祝你好运。"

# game/a9/3rebels.rpy:260
translate english rebels_4f76a416:

    # valerian "Спасибо. Генри ждет тебя снаружи."
    valerian "谢谢。亨利在外面等你。"

# game/a9/3rebels.rpy:261
translate english rebels_09e6a737:

    # me "Он пришел?"
    me "他来了？"

# game/a9/3rebels.rpy:262
translate english rebels_37166c15:

    # valerian "Он бы такое ни за что не пропустил."
    valerian "这种事他是绝对不会错过的。"

# game/a9/3rebels.rpy:264
translate english rebels_e2a71b8d:

    # henry "Тихо."
    henry "安静。"

# game/a9/3rebels.rpy:265
translate english rebels_db3de0b9:

    # henry "Это хорошо."
    henry "这很好。"

# game/a9/3rebels.rpy:266
translate english rebels_8fa4e36e:

    # henry "Видите кого-нибудь с этой стороны?"
    henry "你们在这边看到人了吗？"

# game/a9/3rebels.rpy:267
translate english rebels_dc8aa5e9:

    # myatej "Вроде все чисто. В башне сейчас меняют караул."
    myatej "看起来都安全。塔楼那边正在换岗。"

# game/a9/3rebels.rpy:268
translate english rebels_0dd4d165:

    # henry "Тогда давайте - следующая группа. Только быстро и тихо."
    henry "那就行动——下一队跟上。要快，要安静。"

# game/a9/3rebels.rpy:269
translate english rebels_8847a8db:

    # myatej "Вперед парни."
    myatej "伙计们，上。"

# game/a9/3rebels.rpy:271
translate english rebels_173170bb:

    # me "На стенах и вправду никого нет."
    me "墙上真的一个人都没有。"

# game/a9/3rebels.rpy:272
translate english rebels_f52f648b:

    # henry "В замке только стража и люди лорда Арамиса. Они в башнях и цитадели."
    henry "城堡里只剩下卫兵和Aramis领主的人。他们在塔楼和要塞里。"

# game/a9/3rebels.rpy:273
translate english rebels_5deb163c:

    # henry "По стенам иногда ходят патрули, но стороны развалин их мало."
    henry "墙上偶尔有巡逻队，但从废墟这边来的人很少。"

# game/a9/3rebels.rpy:274
translate english rebels_79255e5d:

    # me "Как-то это безрассудно."
    me "这有点太鲁莽了吧。"

# game/a9/3rebels.rpy:275
translate english rebels_2a362750:

    # henry "Развалины огромные. Защитники полагаются на то, что туда не пробраться, не подняв тревогу."
    henry "废墟很大。守军指望的是，不触发警报就无法潜入。"

# game/a9/3rebels.rpy:276
translate english rebels_c74e44f7:

    # me "Но я..."
    me "但我……"

# game/a9/3rebels.rpy:277
translate english rebels_b4839347:

    # henry "Но ты решил эту проблему. Впрочем, ненадолго. Скоро они опомнятся."
    henry "但你解决了这个问题。不过，也只是暂时的。他们很快就会反应过来。"

# game/a9/3rebels.rpy:278
translate english rebels_9ee8d9b2:

    # me "И что тогда?"
    me "那到时候怎么办？"

# game/a9/3rebels.rpy:279
translate english rebels_bfa9348d:

    # henry "Для нас сейчас главное захватить ворота и стены."
    henry "对我们来说，现在最重要的是夺取城门和城墙。"

# game/a9/3rebels.rpy:280
translate english rebels_fe0b3347:

    # me "Чтобы впустить больше ваших людей?"
    me "是为了放你们更多的人进来？"

# game/a9/3rebels.rpy:281
translate english rebels_3f7f92bb:

    # henry "Наших людей. И нет...не только впустить. Но и не дать войти тем, кто возможно захочет вернуться. Лорд Аргус скоро узнает об этом."
    henry "我们的人。而且不……不仅仅是为了放人进来。也是为了防止那些可能想回来的人进来。Argus领主很快就会知道这件事。"

# game/a9/3rebels.rpy:282
translate english rebels_ddd38f10:

    # me "Разве они успеют вернуться?"
    me "他们来得及赶回来吗？"

# game/a9/3rebels.rpy:283
translate english rebels_d9351278:

    # henry "В центре замка есть цитадель. В худшем случае защитники догадаются отступить туда. А там можно обороняться неделями, пока не закончится еда и вода."
    henry "城堡中心有一座要塞。最坏的情况下，守军会想到撤退到那里。那里有食物和水，可以坚守好几个星期。"

# game/a9/3rebels.rpy:284
translate english rebels_1455e038:

    # me "Так я был полезен или нет?"
    me "所以我到底有没有用？"

# game/a9/3rebels.rpy:286
translate english rebels_6aa15fb9:

    # henry "Был. И не только ты. Спасибо всей твоей семьей, [mename]. Я могу так называть тебя? Или лучше сразу Императором?"
    henry "有用。而且不只是你。谢谢你的全家，[mename]。我可以这样称呼你吗？还是直接叫皇帝陛下更好？"

# game/a9/3rebels.rpy:287
translate english rebels_dd275109:

    # me "Так наша сделка в силе?"
    me "那我们说好的交易还算数吗？"

# game/a9/3rebels.rpy:288
translate english rebels_21922db2:

    # henry "Разумеется. Как только все закончится, Республика станет частью новообразованной Империи."
    henry "当然。一旦尘埃落定，共和国将成为新成立的帝国的一部分。"

# game/a9/3rebels.rpy:289
translate english rebels_f07eef0f:

    # me "Частью?"
    me "一部分？"

# game/a9/3rebels.rpy:290
translate english rebels_8dffc8e4:

    # henry "Автономной частью. Все как мы обсуждали. Налог людьми и золотом. Свободный проход армий и свободная торговля."
    henry "自治的一部分。就按我们讨论过的来。人员和黄金税。军队自由通行和自由贸易。"

# game/a9/3rebels.rpy:291
translate english rebels_23e01675:

    # me "А созыв знамен."
    me "还有旗帜的征召权。"

# game/a9/3rebels.rpy:292
translate english rebels_20f8c8ef:

    # henry "Ну конечно. Мы будем выполнять ВСЕ обязательства перед Империей. В том числе и военные. Кстати о знаменах."
    henry "那当然。我们会履行对帝国的所有义务。包括军事义务。说到旗帜。"

# game/a9/3rebels.rpy:294
translate english rebels_a8d1dd05:

    # henry "Как тебе?"
    henry "你觉得怎么样？"

# game/a9/3rebels.rpy:295
translate english rebels_51c2c17c:

    # me "Что это?"
    me "这是什么？"

# game/a9/3rebels.rpy:296
translate english rebels_3f234f32:

    # henry "Новое знамя Запада. Зеленое полотно. Наш традиционный цвет. И золотое солнце Золотой Империи над золотым львом Запада."
    henry "西方的新旗帜。绿色的底布。我们的传统颜色。还有黄金帝国的金色太阳照耀在西方的金色雄狮之上。"

# game/a9/3rebels.rpy:297
translate english rebels_cd52ef64:

    # me "Выглядит отлично."
    me "看起来棒极了。"

# game/a9/3rebels.rpy:298
translate english rebels_ef081f41:

    # henry "Я знал, что тебе понравится, [mename]."
    henry "我就知道你会喜欢的，[mename]。"

# game/a9/3rebels.rpy:299
translate english rebels_f0952db0:

    # me "Это..."
    me "这是……"

# game/a9/3rebels.rpy:300
translate english rebels_55bdd5d6:

    # henry "Это символ нашего нового общества и символ лояльности тому, кто поможет нам его построить. Я же могу на тебя рассчитывать?"
    henry "这是我们新社会的象征，也是对帮助我们建设它的人的忠诚象征。我能指望你吗？"

# game/a9/3rebels.rpy:301
translate english rebels_ac8fedb7:

    # me "Можешь."
    me "你能。"

# game/a9/3rebels.rpy:303
translate english rebels_da0adc65:

    # myatej "{size=+5}РЕСПУБЛИКА!{/size}"
    myatej "{size=+5}共和国！{/size}"

# game/a9/3rebels.rpy:304
translate english rebels_4326bc77:

    # henry "Отлично."
    henry "好极了。"

# game/a9/3rebels.rpy:305
translate english rebels_a6e0e2df:

    # me "Судя по тому, что я вижу - северные ворота захвачены."
    me "根据我看到的情况——北门已经拿下了。"

# game/a9/3rebels.rpy:306
translate english rebels_52515b3e:

    # henry "Да. Отправляйте всех остальных через ворота."
    henry "是的。让其余所有人都从大门进去。"

# game/a9/3rebels.rpy:307
translate english rebels_e961f303:

    # myatej "ВПЕРЕД ПАРНИ, ЗА РЕСПУБЛИКУ!"
    myatej "伙计们，为了共和国，冲啊！"

# game/a9/3rebels.rpy:308
translate english rebels_45b6d467:

    # me "Быстро они."
    me "他们动作真快。"

# game/a9/3rebels.rpy:309
translate english rebels_e7be1dfd:

    # henry "Они не жалеют своих голов, потому что бьются за идею. Может боги помогут нам и цитадель мы тоже возьмем сегодня."
    henry "他们不惜性命，因为他们是为理想而战。也许诸神会帮助我们，我们今天就能拿下要塞。"

# game/a9/3rebels.rpy:310
translate english rebels_c71cffe9:

    # me "Выходит наш союз теперь закреплен кровью."
    me "看来我们的联盟现在是以鲜血巩固了。"

# game/a9/3rebels.rpy:312
translate english rebels_2f893423:

    # henry "Верно. Можешь рассчитывать на меня, [mename]."
    henry "没错。你可以依靠我，[mename]。"

# game/a9/3rebels.rpy:313
translate english rebels_e3d4291d:

    # me "Только у меня есть парочку вопросов, ты не против?"
    me "只是我还有几个问题，你不介意吧？"

# game/a9/3rebels.rpy:314
translate english rebels_ea95ffa5:

    # henry "Нет. Задавай."
    henry "不介意。问吧。"

# game/a9/3rebels.rpy:315
translate english rebels_ae083998:

    # me "Что ты планируешь делать дальше?"
    me "你接下来打算做什么？"

# game/a9/3rebels.rpy:316
translate english rebels_67e0505f:

    # henry "Рассказывать все по порядку?"
    henry "要按顺序说吗？"

# game/a9/3rebels.rpy:317
translate english rebels_09421628:

    # me "Начни с города. Там ведь еще полно городской стражи."
    me "从城里开始吧。那里还有很多城市卫兵。"

# game/a9/3rebels.rpy:319
translate english rebels_1c28a557:

    # henry "Насчет этого я бы не беспокоился."
    henry "这个我倒不会担心。"

# game/a9/3rebels.rpy:320
translate english rebels_a86c2236:

    # strazh "Это еще что за говно?"
    strazh "这又是什么鬼东西？"

# game/a9/3rebels.rpy:321
translate english rebels_dd0c0dab:

    # strazh2 "Понятия не имею. Надо снять."
    strazh2 "不知道。得把它摘下来。"

# game/a9/3rebels.rpy:322
translate english rebels_c2a12293:

    # strazh "Уверен?"
    strazh "你确定？"

# game/a9/3rebels.rpy:323
translate english rebels_b0716ed1:

    # strazh2 "У нас приказ - никаких чужих флагов и символов."
    strazh2 "我们有命令——不准有任何外来的旗帜和符号。"

# game/a9/3rebels.rpy:325
translate english rebels_99740993:

    # strazh "Открывайте."
    strazh "开门。"

# game/a9/3rebels.rpy:326
translate english rebels_535ba174:

    # strazh2 "Может никого нет?"
    strazh2 "也许没人在？"

# game/a9/3rebels.rpy:327
translate english rebels_f98bb75b:

    # strazh "Ага. Конечно. Обосрались и погасили свечи, как только мы подошли."
    strazh "是啊。当然。我们一走近，他们就吓得拉了裤子，吹灭了蜡烛。"

# game/a9/3rebels.rpy:328
translate english rebels_7614e2cf:

    # strazh "Открывайте, сукины дети, или я вашу лачугу..."
    strazh "开门，狗娘养的，不然我就把你们这破屋子……"

# game/a9/3rebels.rpy:330
translate english rebels_89eab88b:

    # strazh "...подожгу."
    strazh "……给烧了。"

# game/a9/3rebels.rpy:331
translate english rebels_8475f68b:

    # strazh "Вот сука!"
    strazh "操！"

# game/a9/3rebels.rpy:332
translate english rebels_66f2ffd0:

    # mytej "Мы все думали чьи головы повесить рядом с нашим новым знаменем."
    mytej "我们还在想该把谁的脑袋挂在我们新旗帜旁边呢。"

# game/a9/3rebels.rpy:333
translate english rebels_73bb5905:

    # strazh2 "Пиздец!"
    strazh2 "完蛋了！"

# game/a9/3rebels.rpy:334
translate english rebels_bb4cd1f4:

    # henry "В городе у них нет никаких шансов. Пару дней и стража прекратит свое существование."
    henry "在城里他们没有任何机会。过不了几天，城市卫兵就不复存在了。"

# game/a9/3rebels.rpy:335
translate english rebels_d6ad9522:

    # me "Мы всех убьем?"
    me "我们要把所有人都杀了吗？"

# game/a9/3rebels.rpy:336
translate english rebels_251ad4b7:

    # henry "Ну почему сразу 'убьем'?"
    henry "嗯，为什么要说“杀”呢？"

# game/a9/3rebels.rpy:338
translate english rebels_59107d53:

    # strazh "Слышал что говорят? Будто вчера мятежники взяли замок?"
    strazh "听到他们说什么了吗？好像叛军昨天占领了城堡？"

# game/a9/3rebels.rpy:339
translate english rebels_fc92e65d:

    # strazh2 "Чушь."
    strazh2 "胡说八道。"

# game/a9/3rebels.rpy:340
translate english rebels_978df804:

    # strazh "Норт сказал, что видел их знамена на замке."
    strazh "诺特说他看到城堡上挂着他们的旗帜了。"

# game/a9/3rebels.rpy:341
translate english rebels_7044ec22:

    # strazh2 "Врет."
    strazh2 "他撒谎。"

# game/a9/3rebels.rpy:342
translate english rebels_fe46e28d:

    # strazh "А может и не врет."
    strazh "也许没撒谎。"

# game/a9/3rebels.rpy:343
translate english rebels_29b061da:

    # strazh2 "Слушай, у нас есть работа - охранять склад. Значит будем стоять и охранять склад."
    strazh2 "听着，我们有任务——守卫这个仓库。所以我们就站在这儿，守卫仓库。"

# game/a9/3rebels.rpy:344
translate english rebels_b1ea5e50:

    # strazh "А если это все же правда?"
    strazh "可要是这是真的呢？"

# game/a9/3rebels.rpy:345
translate english rebels_3802f407:

    # strazh2 "Даже если это правда. Скоро лорд Аргус сюда вернется."
    strazh2 "就算是真的。Argus领主很快就会回来的。"

# game/a9/3rebels.rpy:347
translate english rebels_87f0ef46:

    # orphan "Дядя, дай монетку!"
    orphan "叔叔，给个硬币吧！"

# game/a9/3rebels.rpy:348
translate english rebels_6d75e1b1:

    # strazh "Проваливай, пацан."
    strazh "滚开，小子。"

# game/a9/3rebels.rpy:349
translate english rebels_6e74a835:

    # orphan "Пожалуйста!"
    orphan "求求您了！"

# game/a9/3rebels.rpy:350
translate english rebels_f6b84308:

    # strazh "Я же говорю - проваливай! Тебя давно не били?"
    strazh "我说了——滚开！你很久没挨揍了是吧？"

# game/a9/3rebels.rpy:351
translate english rebels_f6968ca1:

    # orphan "А леди Нора и ее дети были щедрее."
    orphan "诺拉夫人和她的孩子们可比您大方。"

# game/a9/3rebels.rpy:353
translate english rebels_b0407697:

    # strazh "Что ты сказал?"
    strazh "你说什么？"

# game/a9/3rebels.rpy:354
translate english rebels_bf6494e8:

    # orphan "Леди Нора и ее дети. Они даже связанные были ко мне добры. А я за это им давал воды."
    orphan "诺拉夫人和她的孩子们。就算被绑着，他们也对我很好。所以我给他们水喝。"

# game/a9/3rebels.rpy:355
translate english rebels_8c9d8449:

    # strazh "Что? Где они? Где моя жена?"
    strazh "什么？她们在哪儿？我的妻子在哪儿？"

# game/a9/3rebels.rpy:356
translate english rebels_2212d761:

    # orphan "Другие дяди сказали вы можете их увидеть если отдадите доспехи и меч."
    orphan "其他叔叔说，如果你们交出盔甲和剑，就能见到她们。"

# game/a9/3rebels.rpy:357
translate english rebels_7ae65002:

    # strazh "О, боги..."
    strazh "噢，天哪……"

# game/a9/3rebels.rpy:358
translate english rebels_8b36c2cf:

    # henry "Иногда можно найти подход не требующий крови."
    henry "有时候能找到不流血的方法。"

# game/a9/3rebels.rpy:360
translate english rebels_1e72cb4c:

    # henry "А иногда..."
    henry "而有时候……"

# game/a9/3rebels.rpy:361
translate english rebels_08a9a01c:

    # henry "Иногда приходится прибегать к насилию."
    henry "有时候就不得不动用暴力。"

# game/a9/3rebels.rpy:362
translate english rebels_24d6186c:

    # henry "Когда мой отец и другие лорды попытаются вернуться... Придется создать ему преграды. Самая лучшая преграда - пожар. Большой пожар."
    henry "等我父亲和其他领主想回来的时候……就得给他们制造点障碍。最好的障碍就是火。一场大火。"

# game/a9/3rebels.rpy:363
translate english rebels_3756bb7a:

    # henry "Кассиус сможет убедить горожан, что это лорды подожгли город в ярости за неподчинение."
    henry "卡西乌斯能说服市民，是领主们因为市民不服从，在狂怒中放火烧了城。"

# game/a9/3rebels.rpy:365
translate english rebels_8266fc1d:

    # henry "Конечно большая армия лордов справится с восстанием."
    henry "当然，领主们的大军完全能够镇压起义。"

# game/a9/3rebels.rpy:366
translate english rebels_d3531db9:

    # henry "Но содержать эту армию в полусгоревшем бунтующем городе будет невозможно."
    henry "但在一个烧毁一半、仍在暴动的城市里，要维持这支军队是不可能的。"

# game/a9/3rebels.rpy:367
translate english rebels_73d7a603:

    # henry "Если он сошел с ума - он попробует взять замок приступом, но это нам только поможет. Он погубит всех лояльных ему людей, а замок и припасы мы просто сожжем."
    henry "如果他疯了——他会尝试强攻城堡，但这只会对我们有利。他会葬送所有忠于他的人，而我们只需要把城堡和补给都烧掉。"

# game/a9/3rebels.rpy:368
translate english rebels_0fe3caa3:

    # henry "В других землях бунты будут шириться, а армий, способных их остановить не останется. Так он только проиграет быстрее."
    henry "在其他地区，起义会蔓延开来，而能够阻止起义的军队却已经不复存在。这样他只会输得更快。"

# game/a9/3rebels.rpy:369
translate english rebels_d82103b3:

    # me "А если он не сошел с ума?"
    me "那如果他没有疯呢？"

# game/a9/3rebels.rpy:371
translate english rebels_b8ad99fa:

    # henry "Он встанет своей армией в лагере рядом с городом. Возьмет его в некое подобие осады. А всех лордов отправит в свои владения, чтобы они сначала подавили бунты там. А потом объединенной армией уничтожит нас."
    henry "他会把军队驻扎在城外的营地里。对城市形成某种包围。然后让所有领主回到各自的领地去，先镇压那里的叛乱。最后再集结大军来消灭我们。"

# game/a9/3rebels.rpy:372
translate english rebels_c5b89679:

    # me "Звучит как хороший план."
    me "听起来是个好计划。"

# game/a9/3rebels.rpy:373
translate english rebels_d9a51282:

    # henry "А он и есть хороший."
    henry "这确实是个好计划。"

# game/a9/3rebels.rpy:374
translate english rebels_94b38448:

    # henry "Но у меня есть ответ и на такой случай."
    henry "但应付这种情况，我也有对策。"

# game/a9/3rebels.rpy:376
translate english rebels_1e28315f:

    # henry "Когда лорды отправятся в свои земли, они будут крайне осторожны. Все. Кроме одного."
    henry "当领主们返回各自领地时，他们会非常谨慎。所有人。除了一个。"

# game/a9/3rebels.rpy:377
translate english rebels_f1131a97:

    # henry "Лорд Гвидон двинется прямой дорогой в свой черный лес."
    henry "格维东领主会走最近的路回他的黑森林。"

# game/a9/3rebels.rpy:378
translate english rebels_7a8b9772:

    # henry "Тут нам помогут наши друзья."
    henry "这时候我们的朋友们会帮我们。"

# game/a9/3rebels.rpy:379
translate english rebels_1978db54:

    # me "Друзья?"
    me "朋友们？"

# game/a9/3rebels.rpy:380
translate english rebels_0f1f2a93:

    # elfm "{size=-5}Вон они. Едут. Я же говорил, что те ребята были просто передовым отрядом.{/size}"
    elfm "{size=-5}他们来了。在骑马前进。我就说那些人只是先头部队。{/size}"

# game/a9/3rebels.rpy:381
translate english rebels_d0393d54:

    # elfw "{size=-5}О, Мирта, ты был прав.{/size}"
    elfw "{size=-5}噢，Mirta，你是对的。{/size}"

# game/a9/3rebels.rpy:382
translate english rebels_d42c868e:

    # elfm "{size=-5}Я всегда прав, а вы мне чуть не сорвали засаду, кровожадные ублюдки.{/size}"
    elfm "{size=-5}我总是对的，而你们这些嗜血混蛋差点搞砸了我的伏击。{/size}"

# game/a9/3rebels.rpy:383
translate english rebels_b34b4ca1:

    # elfw "{size=-5}Ну ладно-ладно, командир. Ты прав. Что будем делать?{/size}"
    elfw "{size=-5}好啦好啦，队长。你是对的。我们该怎么办？{/size}"

# game/a9/3rebels.rpy:384
translate english rebels_297ef75c:

    # elfm "{size=-5}Все, как по плану. Сначала цельтесь в лошадей. В ближний бой не вступайте.{/size}"
    elfm "{size=-5}按计划来。先瞄准马。不要近身肉搏。{/size}"

# game/a9/3rebels.rpy:386
translate english rebels_46733d2a:

    # guidon "Трус сраный. Девка. Я бы взял замок с этими ублюдками за одну ночь."
    guidon "该死的懦夫。像个娘们。要是我，带着这些混蛋一晚上就能拿下城堡。"

# game/a9/3rebels.rpy:387
translate english rebels_f8326643:

    # knight "Он хочет сберечь людей."
    knight "他是想保存实力。"

# game/a9/3rebels.rpy:388
translate english rebels_a95be895:

    # guidon "Он дает им время. Постоянно давал. И сейчас дает. А им только это и надо. Этим коварным ублюдкам."
    guidon "他一直在给他们时间。总是给他们时间。现在还在给。而这正是他们需要的。这些狡猾的混蛋。"

# game/a9/3rebels.rpy:389
translate english rebels_024a121d:

    # knight "Бунт не только в Ривелье. Давать такую крупную битву было бы опасно."
    knight "暴动不止在Rivelle。打一场大规模会战太危险了。"

# game/a9/3rebels.rpy:390
translate english rebels_64f45aad:

    # guidon "Да знаю я. Но будь Красный Император жив...он бы весь город вооружил и отправил на штурм, а кто бы отказывался - лишался головы."
    guidon "我知道。但要是红帝还活着……他会把全城的人都武装起来，让他们去强攻，谁不去就砍谁的脑袋。"

# game/a9/3rebels.rpy:391
translate english rebels_c13e080d:

    # knight "Люди бы просто разбежались. А те, кто не разбежался - меняли бы лояльность, только взобравшись на стены."
    knight "人们只会一哄而散。而那些没跑的——一爬上城墙就会变节。"

# game/a9/3rebels.rpy:392
translate english rebels_cea6a583:

    # guidon "Надо было забросать замок черной серой. Вот была бы потеха."
    guidon "应该用黑硫磺把城堡炸了。那才叫好看。"

# game/a9/3rebels.rpy:393
translate english rebels_2d3ddd6b:

    # knight "Черная сера сложна в производстве. Ее могут быстро изготовить только алхимики Арании."
    knight "黑硫磺制作复杂。只有阿拉尼亚的炼金术士才能快速制造。"

# game/a9/3rebels.rpy:394
translate english rebels_f73ebb26:

    # guidon "Все ты знаешь... щенок."
    guidon "你什么都懂啊……臭小子。"

# game/a9/3rebels.rpy:396
translate english rebels_3fd06c06:

    # knight "{size=+5}ЗАСАДА!{/size}"
    knight "{size=+5}有埋伏！{/size}"

# game/a9/3rebels.rpy:397
translate english rebels_085507fc:

    # guidon "{size=+5}Это еще что!?{/size}"
    guidon "{size=+5}这又是什么玩意儿！？{/size}"

# game/a9/3rebels.rpy:398
translate english rebels_487303c7:

    # knight "{size=+5}ИЗ-ЗА ДЕРЕВЬЕВ!{/size}"
    knight "{size=+5}从树后面来的！{/size}"

# game/a9/3rebels.rpy:399
translate english rebels_2c56ef28:

    # guidon "{size=+5}СУКА! ЭТО ЭЛЬФЫ!{/size}"
    guidon "{size=+5}操！是精灵！{/size}"

# game/a9/3rebels.rpy:400
translate english rebels_37dea774:

    # knight "{size=+5}НАДО ОТСТУПИТЬ! МЫ СЛИШКОМ РАСТЯНУТЫ ПО ДОРОГЕ.{/size}"
    knight "{size=+5}必须撤退！我们在路上拉得太长了。{/size}"

# game/a9/3rebels.rpy:401
translate english rebels_60b173e4:

    # guidon "{size=+5}НИКАКОГО ОТСТУПЛЕНИЯ!{/size}"
    guidon "{size=+5}不准撤退！{/size}"

# game/a9/3rebels.rpy:403
translate english rebels_ab24492e:

    # knight "{size=+5}Мы не можем так принять бой!{/size}"
    knight "{size=+5}这样子没法接战！{/size}"

# game/a9/3rebels.rpy:404
translate english rebels_f82be756:

    # guidon "{size=+5}Я НЕ ПОБЕГУ!{/size}"
    guidon "{size=+5}我不会逃跑！{/size}"

# game/a9/3rebels.rpy:405
translate english rebels_b0acb2b6:

    # knight "{size=+5}Мы не знаем сколько их!{/size}"
    knight "{size=+5}我们不知道他们有多少人！{/size}"

# game/a9/3rebels.rpy:406
translate english rebels_747eadf8:

    # guidon "{size=+5}ХВАТИТ СТОНАТЬ, КАК ДЕВКА, БЕРИ МЕЧ И ДЕРИСЬ!{/size}"
    guidon "{size=+5}别像个娘们一样鬼叫了，拿起剑来战斗！{/size}"

# game/a9/3rebels.rpy:407
translate english rebels_c0119bc4:

    # knight "{size=+5}Я не вижу где они?{/size}"
    knight "{size=+5}我看不到他们在哪儿！{/size}"

# game/a9/3rebels.rpy:408
translate english rebels_6a670f81:

    # guidon "{size=+5}ВОН! У ДЕРЕВЬЕВ!{/size}"
    guidon "{size=+5}那儿！树边上！{/size}"

# game/a9/3rebels.rpy:409
translate english rebels_74333f80:

    # knight "{size=+5}ОНИ УБИЛИ ЛОШАДЕЙ!{/size}"
    knight "{size=+5}他们射死了马！{/size}"

# game/a9/3rebels.rpy:410
translate english rebels_d3f6bc72:

    # guidon "{size=+5}НА ТЕБЯ БРОНЯ, ИДИОТ, ТЕБЕ СТРЕЛЫ НИЧЕГО НЕ СДЕЛАЮТ!{/size}"
    guidon "{size=+5}你有盔甲，白痴，箭伤不了你！{/size}"

# game/a9/3rebels.rpy:411
translate english rebels_d84c91eb:

    # guidon "{size=+5}ВПЕРЕД! УБЬЕМ УБЛЮДКОВ!{/size}"
    guidon "{size=+5}冲啊！杀光这些杂种！{/size}"

# game/a9/3rebels.rpy:412
translate english rebels_65e9ef81:

    # me "И что? Эти 'друзья' всех перебьют? У них хватит сил?"
    me "然后呢？这些‘朋友’能把所有人都杀光吗？他们有这个实力吗？"

# game/a9/3rebels.rpy:414
translate english rebels_f5893940:

    # henry "Хватит."
    henry "有。"

# game/a9/3rebels.rpy:415
translate english rebels_0f087ad5:

    # selest "{size=+5}ПОДОХНИ, УБЛЮДОК!{/size}"
    selest "{size=+5}去死吧，杂种！{/size}"

# game/a9/3rebels.rpy:416
translate english rebels_807cc8ef:

    # guidon "{size=+5}СУЧЬИ ЭЛЬФЫ!{/size}"
    guidon "{size=+5}狗娘养的精灵！{/size}"

# game/a9/3rebels.rpy:417
translate english rebels_d7c84bb1:

    # selest "{size=+5}Sindan blada ar carandar vellin all tena, Ia Mírta sind'daran!{/size}"
    selest "{size=+5}Sindan blada ar carandar vellin all tena, Ia Mírta sind'daran!{/size}"

# game/a9/3rebels.rpy:418
translate english rebels_9db3cf57:

    # henry "Главное, чтобы они убили Гвидона. С его сыном разобраться будет проще. Говорят он туп, как винная пробка."
    henry "关键是要杀掉格维东。对付他儿子就容易多了。听说他蠢得像葡萄酒瓶塞。"

# game/a9/3rebels.rpy:419
translate english rebels_cfab5aae:

    # henry "Если даже не удастся договориться, я слышал вассалы твоего отца подходят к его замку, он как раз первый после пересечения долины."
    henry "就算谈不拢，我听说我父亲的封臣们正逼近他的城堡，过了山谷第一个就是他那里。"

# game/a9/3rebels.rpy:420
translate english rebels_f0b6ffbd:

    # me "А что остальные лорды?"
    me "那其他领主呢？"

# game/a9/3rebels.rpy:422
translate english rebels_c418975e:

    # henry "У нас есть подход к каждому."
    henry "我们同样都有办法接近他们每一个人。"

# game/a9/3rebels.rpy:423
translate english rebels_10fa8d7d:

    # me "Подход?"
    me "接近？"

# game/a9/3rebels.rpy:424
translate english rebels_42327558:

    # henry "Ну да. Знаешь западную поговорку - 'в любой город есть хотя бы одна дорога'."
    henry "嗯。你知道西方有句谚语吗——‘每个城市至少都有一条路可以进去’。"

# game/a9/3rebels.rpy:426
translate english rebels_37a4f955:

    # henry "Она значит - решение всегда есть, пусть оно и не всегда нам по душе."
    henry "意思是——总有解决办法，哪怕那个办法不一定合我们的心意。"

# game/a9/3rebels.rpy:427
translate english rebels_942fdda4:

    # josephine "Отец."
    josephine "父亲。"

# game/a9/3rebels.rpy:428
translate english rebels_6b5101a4:

    # aramis "Жозефина."
    aramis "约瑟芬。"

# game/a9/3rebels.rpy:429
translate english rebels_ef9f052d:

    # josephine "Рада, что ты быстро добрался."
    josephine "真高兴你这么快就到了。"

# game/a9/3rebels.rpy:430
translate english rebels_76ed7f1f:

    # aramis "Это наша последняя встреча."
    aramis "这是我们最后一次见面了。"

# game/a9/3rebels.rpy:431
translate english rebels_c8219c7b:

    # josephine "Почему?"
    josephine "为什么？"

# game/a9/3rebels.rpy:432
translate english rebels_2fa04ac6:

    # aramis "Почему? Вы захватили замок! Генри совсем обезумел!"
    aramis "为什么？你们占领了城堡！亨利完全疯了！"

# game/a9/3rebels.rpy:433
translate english rebels_50e0e56d:

    # josephine "Забавно. Это ведь именно ты говорил, что он будет мне идеальной парой."
    josephine "真可笑。当初不正是你说，他会是我理想的伴侣吗。"

# game/a9/3rebels.rpy:434
translate english rebels_fe167760:

    # aramis "Это было давно. Генри был наследником лорда Аргуса, а не сумасшедшим революционером! Тогда я ошибался. Также, как сейчас ошибаешься ты, дочь моя."
    aramis "那是以前的事了。那时亨利还是Argus领主的继承人，而不是一个疯狂的革命者！那时候我错了。就像现在你错了一样，我的女儿。"

# game/a9/3rebels.rpy:435
translate english rebels_0dfe9411:

    # josephine "..."
    josephine "..."

# game/a9/3rebels.rpy:436
translate english rebels_574c3bfe:

    # aramis "Еще не поздно одуматься. Идем со мной и тебя пощадят. Прошу. Откажешь - и я больше не смогу тебе помочь. Вас всех повесят."
    aramis "现在醒悟还不晚。跟我走，你会得到赦免。求你了。如果你拒绝，我就再也帮不了你了。你们都会被绞死。"

# game/a9/3rebels.rpy:437
