translate english elin_portals2_d4d6a289:

    # elin "{size=-12}И как, получилось?{/size}"
    elin "{size=-12}那，准备好了吗？{/size}"

# game/a2/7elin_portals.rpy:127
translate english elin_portals2_0aa65c01:

    # me "{size=-12}Нет...{/size}"
    me "{size=-12}没有...{/size}"

# game/a2/7elin_portals.rpy:129
translate english elin_portals2_ec5ea74d:

    # me "{size=+12}А ну проваливай ты...огромный снежный обезьян!{/size}"
    me "{size=+12}你给我滚开...你这只大雪猴！{/size}"

# game/a2/7elin_portals.rpy:130
translate english elin_portals2_6f096e06:

    # elin "Что ты делаешь?"
    elin "你在干什么？"

# game/a2/7elin_portals.rpy:131
translate english elin_portals2_e1361b14:

    # me "Пытаюсь напугать его."
    me "试着吓跑它。"

# game/a2/7elin_portals.rpy:132
translate english elin_portals2_2e8756a7:

    # me "{size=+12}ПРОВАЛИВАЙ ОТСЮДА, ИЛИ Я ТЕБЕ ГОЛОВУ ОТКУШУ, ПОНЯЛ? ТЕПЕРЬ ЭТО МОЯ ЗЕМЛЯ!{/size}"
    me "{size=+12}滚开，不然我把你脑袋咬下来，明白吗？现在这是我的地盘了！{/size}"

# game/a2/7elin_portals.rpy:133
translate english elin_portals2_f0ec84b5:

    # elin "Ну как, помогло?"
    elin "怎么样，有用吗？"

# game/a2/7elin_portals.rpy:135
translate english elin_portals2_048fe0dd:

    # me "Нет, он разозлился и кажется хочет напасть."
    me "没有，它生气了，好像要攻击了。"

# game/a2/7elin_portals.rpy:136
translate english elin_portals2_686adf49:

    # elin "Это плохо."
    elin "那可不妙。"

# game/a2/7elin_portals.rpy:137
translate english elin_portals2_cf98c400:

    # me "Предлагаю убегать прямо сейчас."
    me "我建议现在就跑。"

# game/a2/7elin_portals.rpy:138
translate english elin_portals2_9092ef74:

    # elin "Не нужно."
    elin "不用了。"

# game/a2/7elin_portals.rpy:140
translate english elin_portals2_5f9abfe2:

    # me "Уверена?"
    me "你确定？"

# game/a2/7elin_portals.rpy:141
translate english elin_portals2_2c74eb39:

    # elin "Del'lá ístra!"
    elin "Del'lá ístra!"

# game/a2/7elin_portals.rpy:143
translate english elin_portals2_ca1a0b7b:

    # elin "Вау. Получилось с первого раза."
    elin "哇。一次就成功了。"

# game/a2/7elin_portals.rpy:144
translate english elin_portals2_a656f726:

    # me "Охренеть..."
    me "真是难以置信..."

# game/a2/7elin_portals.rpy:145
translate english elin_portals2_d969ae01:

    # elin "Обычно мне нужно дольше собираться с силами и мыслями, но видимо из-за стрессовой ситуации получилось быстрее."
    elin "通常我需要更长时间来积蓄力量和集中精神，但看来在压力下反而更快了。"

# game/a2/7elin_portals.rpy:146
translate english elin_portals2_c2ef4c0c:

    # me "Ты его...заморозила. Заморозила морозного ревуна."
    me "你把它...冻住了。把一只霜嚎兽给冻住了。"

# game/a2/7elin_portals.rpy:147
translate english elin_portals2_2c8c9575:

    # elin "Да. Я и сама не ожидала. Думала придется убегать."
    elin "是的。我自己也没想到。还以为我们得逃跑了。"

# game/a2/7elin_portals.rpy:149
translate english elin_portals2_9ec0d0e6:

    # me "Напомни мне никогда на тебя не кричать, если вокруг нет парочки костров."
    me "提醒我永远别对你吼，除非周围有几堆篝火。"

# game/a2/7elin_portals.rpy:150
translate english elin_portals2_89e07d2f:

    # elin "Как скажешь. Но я знаю и поджигающие заклинания."
    elin "随你。但我也会火焰法术。"

# game/a2/7elin_portals.rpy:151
translate english elin_portals2_68a38b28:

    # me "[elin]...это поразительно. Ты невероятно сильный маг."
    me "[elin]...这太惊人了。你真是个极其强大的法师。"

# game/a2/7elin_portals.rpy:152
translate english elin_portals2_0a5512e8:

    # elin "Спасибо! Я была лучшей ученицей в своей башне."
    elin "谢谢！我在我们魔法塔里可是最优秀的学生。"

# game/a2/7elin_portals.rpy:153
translate english elin_portals2_688049ca:

    # me "А эта башня еще существует? Ну...в незамороженном или несожженном виде?"
    me "那座塔还在吗？呃...我是说，没有被冻成冰块或是烧成灰烬吧？"

# game/a2/7elin_portals.rpy:154
translate english elin_portals2_ee9afc59:

    # elin "Хах, я применяю такую магию только в экстренных случаях, не волнуйся."
    elin "哈哈，我只在紧急情况下才用那种魔法，别担心。"

# game/a2/7elin_portals.rpy:155
translate english elin_portals2_65a6e08e:

    # me "Не волноваться? Ты огромную тварь превратила в куб льда за секунду."
    me "别担心？你一秒钟就把一个庞然大物变成了冰块。"

# game/a2/7elin_portals.rpy:156
translate english elin_portals2_253798b9:

    # elin "Ты еще не видел, что может наша мама и мастер Преториус."
    elin "你还没见过咱们妈妈和Pretorius大师的本事呢。"

# game/a2/7elin_portals.rpy:157
translate english elin_portals2_3b27bed8:

    # me "Боюсь даже предположить."
    me "我连想都不敢想。"

# game/a2/7elin_portals.rpy:159
translate english elin_portals2_d77be818:

    # dworf "Ух ты. Потрясающе. Потрясающая магия."
    dworf "哇哦。太厉害了。太厉害的魔法了。"

# game/a2/7elin_portals.rpy:160
translate english elin_portals2_5f86c11f:

    # dworf "Когда-то благодаря такой силе мой народ обрушивал на реки скалы."
    dworf "曾几何时，我的族人就是靠着这样的力量让山崖倾覆于河流之上。"

# game/a2/7elin_portals.rpy:161
translate english elin_portals2_5d099d3e:

    # dworf "Давненько я такого не видел."
    dworf "好久没见过这种场面了。"

# game/a2/7elin_portals.rpy:163
translate english elin_portals2_610a6fc4:

    # dworf "Спасибо! Теперь не придется убивать его своими руками. Я бы мог конечно, но почти за сотню лет кости уже не те. Убьешь такую животину и потом месяц носи пояс из бараньей шерсти."
    dworf "谢谢！这下不用我亲自动手杀它了。我自己当然也能杀，但快一百岁了，这把老骨头不行了。杀这么个大家伙，然后得戴一个月的羊绒护腰。"

# game/a2/7elin_portals.rpy:164
translate english elin_portals2_54879086:

    # elin "Поясница?"
    elin "腰不好？"

# game/a2/7elin_portals.rpy:165
translate english elin_portals2_bad85080:

    # dworf "ДА! Ну ты молодец, девчонка. Ты бы и дюжину таких свалила, да?"
    dworf "是啊！你可真厉害，小姑娘。你一下子打倒一打这种家伙都没问题吧？"

# game/a2/7elin_portals.rpy:166
translate english elin_portals2_325bc8e1:

    # elin "Не знаю..."
    elin "不知道..."

# game/a2/7elin_portals.rpy:167
translate english elin_portals2_63eeb11d:

    # dworf "Это надо отпраздновать. Я принесу пилу и мы нарежем этого сукиного сына на куски."
    dworf "这事儿得庆祝一下。我去拿锯子，咱们把这个狗娘养的切成块。"

# game/a2/7elin_portals.rpy:168
translate english elin_portals2_4f33a43a:

    # elin "Спасибо...но не нужно."
    elin "谢谢...但不用了。"

# game/a2/7elin_portals.rpy:169
translate english elin_portals2_f40fb1aa:

    # dworf "Согласен. Эта тварь только резать на кубики и засаливать к пиву. Слишком жесткий. Откуда вы тут, девочки?"
    dworf "同意。这畜生的肉太硬了，只能切成小方块腌了下酒。你们是从哪儿来的，姑娘们？"

# game/a2/7elin_portals.rpy:171
translate english elin_portals2_603fa203:

    # elin "Тут только я девочка. Рядом мой брат. "
    elin "这里只有我是姑娘。旁边是我哥哥。"

# game/a2/7elin_portals.rpy:172
translate english elin_portals2_4dbc66ea:

    # gwadar "Ты мужчина? А где твоя борода? И волосы отрастил ну... людская мода... совсем спятили. Меня кстати звать Гвадар."
    gwadar "你是男人？你的胡子呢？头发倒是留长了...唉...人类的时尚...真是疯了。对了，我叫Gwadar。"

# game/a2/7elin_portals.rpy:173
translate english elin_portals2_3db572e7:

    # elin "Меня зовут [elin], а брата - [mename]."
    elin "我叫[elin]，我哥哥叫[mename]。"

# game/a2/7elin_portals.rpy:174
translate english elin_portals2_f79aa519:

    # me "Приятно было познакомиться, но нам пора идти."
    me "很高兴认识你们，但我们该走了。"

# game/a2/7elin_portals.rpy:175
translate english elin_portals2_d5e33fb1:

    # gwadar "Идти? После такой славной победы? Ее нужно отпраздновать!"
    gwadar "走？打了一场这么漂亮的胜仗之后？必须得庆祝一下！"

# game/a2/7elin_portals.rpy:176
translate english elin_portals2_9f847873:

    # elin "Нам правда нужно идти."
    elin "我们真的得走了。"

# game/a2/7elin_portals.rpy:177
translate english elin_portals2_9e882778:

    # gwadar "Ни в коем случае! Или моя жена закатит нам пирушку или придется заморозить и меня!"
    gwadar "绝对不行！要么我老婆给我们开个小型宴会，要么你就把我也冻上吧！"

# game/a2/7elin_portals.rpy:178
translate english elin_portals2_e9cfc8b0:

    # me "[elin], как скоро закрывается портал?"
    me "[elin]，传送门还有多久会关闭？"

# game/a2/7elin_portals.rpy:179
translate english elin_portals2_63a95fcb:

    # elin "Ладно. Думаю у нас есть немного времени. Далеко идти?"
    elin "好吧。我想我们还有一点时间。要走很远吗？"

# game/a2/7elin_portals.rpy:181
translate english elin_portals2_f6a14992:

    # tira "Вот, приготовила, что успела. Мы не ждали гостей."
    tira "来，我随便准备了些现成的东西。我们没想到会有客人来。"

# game/a2/7elin_portals.rpy:182
translate english elin_portals2_95e3d905:

    # elin "Выглядит очень вкусно. Спасибо!"
    elin "看起来很美味。谢谢！"

# game/a2/7elin_portals.rpy:183
translate english elin_portals2_8648e10a:

    # gwadar "И потом она смотрит на ревуна и как рукой БАХ. Одни белые искры! А от ревуна остался только замороженный ревун."
    gwadar "然后她就看着那只霜嚎兽，就这么一挥手，砰！全是白色的火花！然后霜嚎兽就只剩下冻住的尸体了。"

# game/a2/7elin_portals.rpy:184
translate english elin_portals2_36721d63:

    # tira "Какая ты умница!"
    tira "你真是太厉害了！"

# game/a2/7elin_portals.rpy:185
translate english elin_portals2_24825cb7:

    # gwadar "Смотрит на него и говорит 'я бы еще дюжину убила', настоящая убийца ревунов. Великий маг!"
    gwadar "就那么看着它说‘我还能再杀一打’，真是个天生的霜嚎兽杀手。了不起的法师！"

# game/a2/7elin_portals.rpy:187
translate english elin_portals2_bbf415b2:

    # elin "Ваш муж любит слегка приукрашивать истории, да?"
    elin "你丈夫有点喜欢夸大其词，是吧？"

# game/a2/7elin_portals.rpy:188
translate english elin_portals2_3adc003c:

    # tira "В его возрасте все мужчины такие."
    tira "到他这个年纪的男人都这样。"

# game/a2/7elin_portals.rpy:189
translate english elin_portals2_4544d26b:

    # me "А, по-моему, все так и было. Ты еще подожгла ему руку и сказала 'погрейся, мудила', и все это время даже на него не смотрела, читала книгу."
    me "啊，我觉得事情本来就是那样的。你还点了把火烧了它的手，说‘暖和暖和吧，蠢货’，而且从头到尾你连看都没看它，就在那儿看书。"

# game/a2/7elin_portals.rpy:190
translate english elin_portals2_8a4fb92c:

    # tira "Серьезно?"
    tira "真的吗？"

# game/a2/7elin_portals.rpy:191
translate english elin_portals2_a4b0d63e:

    # gwadar "Мнгм."
    gwadar "嗯哼。"

# game/a2/7elin_portals.rpy:192
translate english elin_portals2_6c6910d6:

    # elin "Они...они все выдумывают. Я сама испугалась и у меня просто как-то само с первого раза вышло заклинание. Обычно оно не такое сильное."
    elin "他们...他们都在瞎编。我自己也吓坏了，法术就是一次就突然使出来了。通常没那么强的。"

# game/a2/7elin_portals.rpy:193
translate english elin_portals2_6bc51fa7:

    # me "Я думаю если я буду пить такими кружками в портал мы точно не попадем."
    me "我觉得我要是再拿这么大杯子喝下去，我们肯定赶不上传送门了。"

# game/a2/7elin_portals.rpy:194
translate english elin_portals2_03cb59b7:

    # tira "Вы попали сюда через портал?"
    tira "你们是通过传送门来到这儿的？"

# game/a2/7elin_portals.rpy:195
translate english elin_portals2_3877aca5:

    # elin "Да."
    elin "是的。"

# game/a2/7elin_portals.rpy:197
translate english elin_portals2_6daa0f29:

    # gwadar "Поразительно. Такая сильная магия. Надо показать ее старейшинам."
    gwadar "太惊人了。这么强大的魔法。得让长老们看看。"

# game/a2/7elin_portals.rpy:198
translate english elin_portals2_d9bb0a2e:

    # tira "Гвадар, не безумствуй. Тем более если они попали сюда через портал, ни на какие длинные походы они согласны не будут."
    tira "Gwadar，别发疯。再说他们既然是穿过传送门来的，肯定不会答应去长途跋涉的。"

# game/a2/7elin_portals.rpy:199
translate english elin_portals2_3e1eb2f6:

    # gwadar "Но это такая сила!"
    gwadar "可这是多么强大的力量啊！"

# game/a2/7elin_portals.rpy:200
translate english elin_portals2_525e598e:

    # tira "Милый...не начинай опять."
    tira "亲爱的...别又开始了。"

# game/a2/7elin_portals.rpy:201
translate english elin_portals2_e2b9a69d:

    # gwadar "Она может все вернуть! Я же силой, уговорим, если захочет - подарим золота весом с дракона!"
    gwadar "她能挽回一切！我又不强求她，我们可以商量，要是她愿意，我们可以送她像龙那么重的金子！"

# game/a2/7elin_portals.rpy:203
translate english elin_portals2_3a468b86:

    # tira "Не обращай внимание, милая, у мужчин на покое в голове один...реваншизм."
    tira "别在意，亲爱的，退休在家的男人脑子里想的就只有...复辟。"

# game/a2/7elin_portals.rpy:204
translate english elin_portals2_b5f3e425:

    # gwadar "Это вовсе не так! Это будет простой обмен услугами, она нам свою силу мы ей свои богатства!"
    gwadar "根本不是这样！这只是简单的服务交换，她用她的力量，我们给她我们的财富！"

# game/a2/7elin_portals.rpy:205
translate english elin_portals2_2d6cdc28:

    # tira "Так. Хватит. Обсуждали тысячу раз. К тому же это невежливо, хочешь обидеть гостей? Вот и помолчи."
    tira "行啦。够了。都讨论过一千遍了。再说这不礼貌，你想得罪客人吗？那就安静点。"

# game/a2/7elin_portals.rpy:206
translate english elin_portals2_3f144898:

    # tira "Ты почему так мало ешь, дорогая? Смотри какая ты худая. Возьми что-то посытнее."
    tira "亲爱的，你怎么吃这么少？看你瘦的。吃点顶饱的东西吧。"

# game/a2/7elin_portals.rpy:207
translate english elin_portals2_af87d69d:

    # me "Она привыкла столько есть. В детстве нас учивали есть понемногу, столовый этикет."
    me "她习惯吃这么少了。小时候我们受的教育就是要少食，这是餐桌礼仪。"

# game/a2/7elin_portals.rpy:208
translate english elin_portals2_13117500:

    # tira "Этикет? Вы из благородной семьи?"
    tira "礼仪？你们是贵族家庭出身吗？"

# game/a2/7elin_portals.rpy:209
translate english elin_portals2_50be2869:

    # elin "Мы принц и принцесса."
    elin "我们是王子和公主。"

# game/a2/7elin_portals.rpy:210
translate english elin_portals2_e2af6135:

    # tira "Вы муж и жена? Вы такие красивые... у вас будут прекрасные дети."
    tira "你们是夫妻吗？你们真漂亮...以后生的孩子一定很美。"

# game/a2/7elin_portals.rpy:213
translate english elin_portals2_e1d58ebb:

    # elin "Мы...э...спасибо."
    elin "我们...呃...谢谢。"

# game/a2/7elin_portals.rpy:214
translate english elin_portals2_3835bdbb:

    # tira "Но для легких беременности нужно больше есть. Чем ты будешь кормить ребенка, пока он в тебе?"
    tira "但为了顺利怀孕，得多吃点。孩子在肚子里的时候，你拿什么喂他呢？"

# game/a2/7elin_portals.rpy:215
translate english elin_portals2_8eff035a:

    # elin "Я...э..."
    elin "我...呃..."

# game/a2/7elin_portals.rpy:216
translate english elin_portals2_052a43c5:

    # tira "Поверь, я знаю о чем говорю. У меня шесть сыновей и дочка."
    tira "相信我，我懂这个。我有六个儿子和一个女儿呢。"

# game/a2/7elin_portals.rpy:217
translate english elin_portals2_92d397c8:

    # elin "..."
    elin "..."

# game/a2/7elin_portals.rpy:218
translate english elin_portals2_e94517ec:

    # tira "Ладно. Прости. Не хотела на тебя давить."
    tira "好吧。对不起。我不想给你压力。"

# game/a2/7elin_portals.rpy:221
translate english elin_portals2_f118fe1a:

    # elin "Нет-нет. Мы брат и сестра."
    elin "不不。我们是兄妹。"

# game/a2/7elin_portals.rpy:222
translate english elin_portals2_d263ffa4:

    # tira "Оу. Ну все равно тебе надо больше кушать."
    tira "哦。那你也得多吃点。"

# game/a2/7elin_portals.rpy:223
translate english elin_portals2_62749523:

    # elin "Я...может быть. Но я долго училась в магической башне, так что привыкла есть понемногу."
    elin "我...也许吧。但我之前在魔法塔学习了很久，所以习惯了少食。"

# game/a2/7elin_portals.rpy:224
translate english elin_portals2_99ab5ff6:

    # tira "Ух. Магические башни! Как интересно."
    tira "哇。魔法塔！真有意思。"

# game/a2/7elin_portals.rpy:226
translate english elin_portals2_5d5e384b:

    # tira "Милый, ты не слишком налегаешь на пиво?"
    tira "亲爱的，你是不是啤酒喝太多了？"

# game/a2/7elin_portals.rpy:227
translate english elin_portals2_b15d9a60:

    # gwadar "Все нормально, женщина! Я могу выпить еще хоть бочку."
    gwadar "没事，女人！我还能再喝一桶呢。"

# game/a2/7elin_portals.rpy:228
translate english elin_portals2_02ff4908:

    # me "Пиво надо сказать отменное."
    me "不得不说，这啤酒真棒。"

# game/a2/7elin_portals.rpy:230
translate english elin_portals2_3e63861a:

    # gwadar "Еще бы. Я сам его варил. Потратил год, чтобы отвести руду на юг и выменять ее на ингредиенты."
    gwadar "那当然。我自己酿的。花了一年时间把矿石运到南方，换来这些原料。"

# game/a2/7elin_portals.rpy:231
translate english elin_portals2_081ea004:

    # elin "Год? Так долго?"
    elin "一年？那么久？"

# game/a2/7elin_portals.rpy:232
translate english elin_portals2_27320d19:

    # gwadar "Почти все старые тоннели заброшены. Дворфы переселяются на север, некому больше за ними следить."
    gwadar "几乎所有的旧隧道都废弃了。矮人都迁往北方了，没人再维护它们了。"

# game/a2/7elin_portals.rpy:233
translate english elin_portals2_ba07b02e:

    # elin "А почему они переселяются на север?"
    elin "他们为什么要迁往北方？"

# game/a2/7elin_portals.rpy:234
translate english elin_portals2_50459e58:

    # gwadar "Из-за людей! Ваши лорды, что живут к северу от великих рек лезут к нам, заселяют наши тоннели! А мы им помогали сражаться против Красного Императора!"
    gwadar "都怪人类！你们那些住在大河北边的领主们侵占我们的土地，住进我们的隧道！而我们可是帮他们对抗过红皇帝的！"

# game/a2/7elin_portals.rpy:235
translate english elin_portals2_155f2864:

    # tira "Не начинай! Не из-за людей дворфы уходят на север. Люди селятся в уже пустых чертогах."
    tira "别又开始！矮人迁往北方不是因为人类。人类只是在已经空了的殿堂里定居。"

# game/a2/7elin_portals.rpy:236
translate english elin_portals2_e1532059:

    # gwadar "Что ты несешь женщина? Моего брата выгнали люди!"
    gwadar "你在胡说什么，女人？我弟弟就是被人类赶走的！"

# game/a2/7elin_portals.rpy:237
translate english elin_portals2_3e00a3db:

    # tira "Твой брат - пьяница. Когда от него сбежала семья он не смог жить сам и ушел на север. А тебе наплел, что его якобы люди прогнали."
    tira "你弟弟是个酒鬼。他老婆孩子跑了之后，他自己活不下去才去的北方。他跟你瞎说是被人类赶走的。"

# game/a2/7elin_portals.rpy:238
translate english elin_portals2_b95f5bc2:

    # gwadar "Да?"
    gwadar "是吗？"

# game/a2/7elin_portals.rpy:239
translate english elin_portals2_3c1a51d8:

    # tira "Да! Он тебе сам за столом признался."
    tira "是的！他自己在饭桌上都承认了。"

# game/a2/7elin_portals.rpy:241
translate english elin_portals2_4728519a:

    # gwadar "Ну тогда выпьем за людей! Пусть следят за нашими чертогами, пока мы не вернемся! Верно говорю!"
    gwadar "那就为人类干一杯！让他们在我们回去之前照看好我们的殿堂！我说得对吧！"

# game/a2/7elin_portals.rpy:242
translate english elin_portals2_1eeb9802:

    # me "За людей!"
    me "为人类干杯！"

# game/a2/7elin_portals.rpy:243
translate english elin_portals2_d7fe3f1f:

    # tira "Не напейся при гостях!"
    tira "别在客人面前喝醉了！"

# game/a2/7elin_portals.rpy:244
translate english elin_portals2_de6fc04e:

    # gwadar "Женщина, замолчи! Я пару кружек выпил, а мне, чтобы опьянеть, нужно еще как минимум столько же!"
    gwadar "女人，闭嘴！我才喝了几杯，想让我醉，至少还得再来这么多！"

# game/a2/7elin_portals.rpy:246
translate english elin_portals2_396c128f:

    # "Час спустя."
    "一个小时以后。"

# game/a2/7elin_portals.rpy:247
translate english elin_portals2_83bc1aa2:

    # tira "Так и знала, что этим закончится."
    tira "我就知道会是这样。"

# game/a2/7elin_portals.rpy:248
translate english elin_portals2_51950635:

    # elin "Мне жаль..."
    elin "我很抱歉..."

# game/a2/7elin_portals.rpy:249
translate english elin_portals2_4c3d42d6:

    # tira "Все нормально. Лучше пусть спит, а не бьет посуду. Все равно нашел бы способ напиться. Просто вы ему удачно подвернулись."
    tira "没关系。他睡着了总比摔盘子强。反正他总能找到法子喝醉。只是你们正好撞上了。"

# game/a2/7elin_portals.rpy:250
translate english elin_portals2_7f17f7bb:

    # me "Я...я с двух кружек окосел. Сильная у вас...пиво."
    me "我...我两杯就有点上头了。你们的...啤酒劲儿真大。"

# game/a2/7elin_portals.rpy:251
translate english elin_portals2_53459166:

    # tira "Пиво? Он туда какие-то корни намешивает, говорит что скоро его пиво будут во гномьих чертогах пить, что он легендарный пивовар. Я попробовала и меня чуть не вырвало."
    tira "啤酒？他在里面加了什么草根，说很快他的啤酒就会在所有矮人殿堂里流传，他会成为传奇酿酒大师。我尝了一口，差点没吐出来。"

# game/a2/7elin_portals.rpy:252
translate english elin_portals2_e724ab32:

    # me "Ну...крепковатый напиток, но пить можно."
    me "嗯...是有点烈，但还能喝。"

# game/a2/7elin_portals.rpy:254
translate english elin_portals2_6d407424:

    # tira "Вам расстелить кровать?"
    tira "要给你们铺床吗？"

# game/a2/7elin_portals.rpy:255
translate english elin_portals2_0351c102:

    # elin "Нет-нет. Нам нужно попасть к порталу. Он чуть выше чем тропа к вашему дому."
    elin "不用了，不用了。我们得赶到传送门那儿去。它就在比通往你们家的小路稍微高一点的地方。"

# game/a2/7elin_portals.rpy:256
translate english elin_portals2_056e7459:

    # tira "Ох, я и забыла. Туда можно попасть через запасной выход. Только он весь во льду."
    tira "哦，我都忘了。可以从备用出口上去。只是那条路全被冰封住了。"

# game/a2/7elin_portals.rpy:257
translate english elin_portals2_692e2a7c:

    # elin "Я растоплю его."
    elin "我来融化它。"

# game/a2/7elin_portals.rpy:258
translate english elin_portals2_15d8d7cb:

    # tira "Ну хорошо. Я покажу куда идти."
    tira "那好吧。我带你们去。"

# game/a2/7elin_portals.rpy:259
translate english elin_portals2_63a51eda:

    # elin "Спасибо вам большое! "
    elin "非常感谢你！"

# game/a2/7elin_portals.rpy:260
translate english elin_portals2_eeb25192:

    # tira "Еще встретимся."
    tira "后会有期。"

# game/a2/7elin_portals.rpy:262
translate english elin_portals2_637acda4:

    # tira "Погоди, [mename]... верно?"
    tira "等一下，[mename]...对吧？"

# game/a2/7elin_portals.rpy:263
translate english elin_portals2_2d42945b:

    # me "Ага."
    me "嗯。"

# game/a2/7elin_portals.rpy:264
translate english elin_portals2_68798adb:

    # tira "Можешь мне уделить немного времени, пока твоя сестра будет растапливать лед?"
    tira "能不能耽误你一点时间，趁你妹妹去融化冰块的时候？"

# game/a2/7elin_portals.rpy:265
translate english elin_portals2_9c27cee8:

    # me "Да, конечно, что нужно?"
    me "当然可以，有什么事吗？"

# game/a2/7elin_portals.rpy:267
translate english elin_portals2_8cb3015a:

    # tira "Думала может ты немного уважишь хозяйку чертогов..."
    tira "我在想，也许你愿意稍微...慰劳一下这座殿堂的女主人..."

# game/a2/7elin_portals.rpy:268
translate english elin_portals2_dc267098:

    # me "Эм...а как же ваш муж?"
    me "呃...那你丈夫呢？"

# game/a2/7elin_portals.rpy:269
translate english elin_portals2_f52614f8:

    # tira "О чем ты? А...я и забыла. У нас это не порицается. Не считается изменой."
    tira "你想什么呢？啊...我都忘了。在我们这儿这不被谴责。不算背叛。"

# game/a2/7elin_portals.rpy:270
translate english elin_portals2_14dcb89b:

    # me "Я что-то такое слышал."
    me "我好像听说过一点。"

# game/a2/7elin_portals.rpy:271
translate english elin_portals2_f67e53c8:

    # tira "Не переживай по этому поводу. Ну так что? Потратишь на меня немного сил?"
    tira "别担心这个。怎么样？愿意为我花点力气吗？"

# game/a2/7elin_portals.rpy:275
translate english elin_portals2_5a129aea:

    # tira "Ой. Давно мужчина не поднимал меня на такую высоту."
    tira "哦。好久没被男人举这么高了。"

# game/a2/7elin_portals.rpy:276
translate english elin_portals2_eae4b057:

    # me "Я...как то это непривычно."
    me "我...这感觉真不习惯。"

# game/a2/7elin_portals.rpy:277
translate english elin_portals2_58d88bb8:

    # tira "Никогда не трахал чью-то жену?"
    tira "从来没睡过别人的老婆？"

# game/a2/7elin_portals.rpy:278
translate english elin_portals2_1c5e9a43:

    # me "Никогда не трахал дворфиху."
    me "从来没睡过女矮人。"

# game/a2/7elin_portals.rpy:279
translate english elin_portals2_97465aa7:

    # tira "Здорово, я у тебя первая!"
    tira "太棒了，我是你的第一个！"

# game/a2/7elin_portals.rpy:281
translate english elin_portals2_e47e3b71:

    # me "А я?"
    me "那我呢？"

# game/a2/7elin_portals.rpy:282
translate english elin_portals2_f3aed71d:

    # tira "Первый человек? Нет. Первый полуэльф? Определенно."
    tira "第一个人类？不是。第一个半精灵？绝对是。"

# game/a2/7elin_portals.rpy:283
translate english elin_portals2_03b47637:

    # me "Мне всегда было интересно...а член у дворфов..."
    me "我一直很好奇...矮人那话儿..."

# game/a2/7elin_portals.rpy:284
translate english elin_portals2_aad55c2f:

    # tira "Короче. Заметно короче. Но зато гораздо толще."
    tira "比较短。明显短。但是粗得多。"

# game/a2/7elin_portals.rpy:286
translate english elin_portals2_b630ad55:

    # me "Однажды я напишу книгу о сексе со всеми расами континента."
    me "将来我要写一本关于和大陆上所有种族做爱的书。"

# game/a2/7elin_portals.rpy:287
translate english elin_portals2_1805db6a:

    # tira "С удовольствием ее прочитаю."
    tira "我一定拜读。"

# game/a2/7elin_portals.rpy:288
translate english elin_portals2_a63f273f:

    # tira "Начнем?"
    tira "开始吗？"

# game/a2/7elin_portals.rpy:290
translate english elin_portals2_cd22f79b:

    # me "Я не слишком быстро?"
    me "我是不是太快了？"

# game/a2/7elin_portals.rpy:291
translate english elin_portals2_c00163e0:

    # tira "Все нормально. Мне очень приятно. К тому же [elin] судя по всему сильный маг. Она быстро справится со льдом."
    tira "没事。我很舒服。再说[elin]看起来是个强大的法师。她很快就能搞定那些冰。"

# game/a2/7elin_portals.rpy:292
translate english elin_portals2_f7e01ac8:

    # me "Да, было бы неловко, если бы она нас застала."
    me "是啊，要是被她撞见就尴尬了。"

# game/a2/7elin_portals.rpy:293
translate english elin_portals2_bea0aa97:

    # tira "Ты проявляешь уважение к нашей культуре."
    tira "你这是尊重我们的文化。"

# game/a2/7elin_portals.rpy:294
translate english elin_portals2_cb6a5812:

    # me "Она бы не приняла это как обьяснение."
    me "她可不会接受这种解释。"

# game/a2/7elin_portals.rpy:295
translate english elin_portals2_56d0cfa6:

    # tira "Не переживай, у меня оо...отличный слух."
    tira "别担心，我的耳...听力好得很。"

# game/a2/7elin_portals.rpy:296
translate english elin_portals2_e0f3b62f:

    # me "У вас и вагина, что надо. Очень...тугая."
    me "你们那地方也真不赖。非常...紧致。"

# game/a2/7elin_portals.rpy:297
translate english elin_portals2_50d24528:

    # tira "Я специально напрягаю таз, чтобы тебе было приятней."
    tira "我是特意收紧骨盆的，为了让你更舒服。"

# game/a2/7elin_portals.rpy:298
translate english elin_portals2_6032db9b:

    # me "Потрясающий навык."
    me "惊人的技巧。"

# game/a2/7elin_portals.rpy:299
translate english elin_portals2_054bcec2:

    # tira "За десятки лет в браке и не такому научишься."
    tira "结婚几十年，总能学会这些的。"

# game/a2/7elin_portals.rpy:300
translate english elin_portals2_08d1fb54:

    # me "Куда мне..."
    me "我该..."

# game/a2/7elin_portals.rpy:301
translate english elin_portals2_d3bb2187:

    # tira "Кончи внутрь. Не хочу оттирать твое семя с пола."
    tira "射在里面吧。我可不想擦地板上你的精液。"

# game/a2/7elin_portals.rpy:302
translate english elin_portals2_468457df:

    # me "Вы уверены?"
    me "你确定吗？"

# game/a2/7elin_portals.rpy:303
translate english elin_portals2_1240c184:

    # tira "Уверена. У дворфа шанс забеременеть от человека или эльфа крайне мал."
    tira "确定。矮人被人类或精灵弄怀孕的几率非常低。"

# game/a2/7elin_portals.rpy:304
translate english elin_portals2_3b455f07:

    # me "Но он все же есть."
    me "但几率还是有的。"

# game/a2/7elin_portals.rpy:305
translate english elin_portals2_7e858826:

    # tira "Я готова рискнуть."
    tira "我愿意冒这个险。"

# game/a2/7elin_portals.rpy:307
translate english elin_portals2_3fa380de:

    # me "Ох...фуухх."
    me "哦...呼。"

# game/a2/7elin_portals.rpy:308
translate english elin_portals2_a1b59ecc:

    # tira "Молодец, [mename]."
    tira "好样的，[mename]。"

# game/a2/7elin_portals.rpy:310
translate english elin_portals2_9088de86:

    # me "Я тут это... все же кажется накапал на пол..."
    me "我好像...好像还是滴了点到地板上..."

# game/a2/7elin_portals.rpy:311
translate english elin_portals2_d2e6d059:

    # tira "Ничего страшного. Гордись, что молод и можешь производить столько семени, это признак крепкого здоровья."
    tira "没关系。你该为自己年轻、能产出这么多精液而自豪，这是身体强健的标志。"

# game/a2/7elin_portals.rpy:312
translate english elin_portals2_2bc17c7f:

    # me "Мне надо..."
    me "我得..."

# game/a2/7elin_portals.rpy:313
translate english elin_portals2_694e855f:

    # tira "Да. Понимаю. Иди."
    tira "嗯。我明白。去吧。"

# game/a2/7elin_portals.rpy:317
translate english elin_portals2_ae1b541f:

    # me "Я вообще-то тоже владею магией и портал скоро закроется, так что мне нужно помочь с..."
    me "我其实也会点魔法，而且传送门快关了，所以我得去帮忙..."

# game/a2/7elin_portals.rpy:318
translate english elin_portals2_a0dc1f3f:

    # tira "Ничего страшного! Я все понимаю. Иди, [mename]."
    tira "没关系！我完全理解。去吧，[mename]。"

# game/a2/7elin_portals.rpy:319
translate english elin_portals2_7a096df3:

    # me "Вы не в обиде?"
    me "你不生气吧？"

# game/a2/7elin_portals.rpy:320
translate english elin_portals2_d14e6e47:

    # tira "Не говори глупостей. Секс это добровольный акт, да и мне не 20 зим, чтобы обижаться на то, что мужчина не хочет секса со мной."
    tira "别傻了。性爱是自愿行为，再说我也不是20岁的姑娘了，会因为男人不想跟我做爱就生气。"

# game/a2/7elin_portals.rpy:321
translate english elin_portals2_1f45f35e:

    # me "Спасибо вам за гостеприимство."
    me "谢谢你们的款待。"

# game/a2/7elin_portals.rpy:322
translate english elin_portals2_986c558b:

    # tira "Не за что! Удачи на пути!"
    tira "不客气！一路顺风！"

# game/a2/7elin_portals.rpy:325
translate english elin_portals2_7e024ec9:

    # elin "Что-то ты долго."
    elin "你怎么这么久。"

# game/a2/7elin_portals.rpy:326
translate english elin_portals2_c14f0908:

    # me "Я...выпил еще немного пива."
    me "我...又喝了点啤酒。"

# game/a2/7elin_portals.rpy:327
translate english elin_portals2_8c56ce00:

    # elin "Ну что, готов?"
    elin "怎么样，准备好了吗？"

# game/a2/7elin_portals.rpy:328
translate english elin_portals2_2d42945b_1:

    # me "Ага."
    me "嗯。"

# game/a2/7elin_portals.rpy:329
translate english elin_portals2_039e07da:

    # elin "Прыгнешь первым?"
    elin "你先跳？"

# game/a2/7elin_portals.rpy:330
