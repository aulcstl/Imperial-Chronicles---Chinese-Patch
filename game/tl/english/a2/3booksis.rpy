    # lia "А?"
    lia "啊？"

# game/a2/3booksis.rpy:318
translate english booksis2_91843f6a:

    # me "Сначала я почувствовал как онемели ноги."
    me "一开始我感觉双腿发麻。"

# game/a2/3booksis.rpy:319
translate english booksis2_94ec960d:

    # me "Потом как зазвенело в голове."
