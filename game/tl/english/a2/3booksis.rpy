# game/a2/3booksis.rpy:307
translate english booksis2_c10c615e:

    # lia "Нет! Я бы точно смогла подняться в эльфийские развалины."
    lia "不累！我肯定能爬到精灵遗迹上去。"

# game/a2/3booksis.rpy:308
translate english booksis2_a9e1cfaa:

    # me "Хватит."
    me "打住吧。"

# game/a2/3booksis.rpy:309
translate english booksis2_bfce02d1:

    # lia "Ну ладно-ладно. Но однажды я все равно туда схожу."
    lia "嗯，好吧好吧。但总有一天我会去那里的。"

# game/a2/3booksis.rpy:310
