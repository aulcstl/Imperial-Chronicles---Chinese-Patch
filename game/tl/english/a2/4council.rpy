# game/a2/4council.rpy:3
translate english council_5078e324:

    # me "{i}Хочу есть.{/i}"
    me "{i}想吃东西。{/i}"

# game/a2/4council.rpy:4
translate english council_ff784b06:

    # me "{i}Надо бы стащить чего...{/i}"
    me "{i}得去偷点什么……{/i}"

# game/a2/4council.rpy:5
translate english council_712309c0:

    # me "{i}Хотя погодите...{/i}"
    me "{i}不过等等……{/i}"

# game/a2/4council.rpy:6
translate english council_6058ba66:

    # me "{i}Я уже и забыл, что я принц.{/i}"
    me "{i}我都忘了，我是个王子。{/i}"

# game/a2/4council.rpy:8
translate english council_8e0f6d7c:

    # me "{i}Могу заказать себе что угодно на ужин.{/i}"
    me "{i}我可以给自己叫任何想要的晚餐。{/i}"

# game/a2/4council.rpy:9
translate english council_359eaff1:

    # me "{i}Все что растет в этих землях и что их топчет - может попасть ко мне в желудок.{/i}"
    me "{i}这片土地上生长的、在上面行走的一切——都能进入我的胃里。{/i}"

# game/a2/4council.rpy:10
translate english council_8195ae1c:

    # me "{i}Наконец-то. Как же я устал за эти годы жрать помои.{/i}"
    me "{i}终于。这些年吃泔水，我已经厌倦透了。{/i}"

# game/a2/4council.rpy:11
translate english council_c071f22d:

    # me "{i}Еда...вкусная еда...{/i}"
    me "{i}食物……美味的食物……{/i}"

# game/a2/4council.rpy:13
translate english council_cae9af81:

    # cass "Думаешь о великих сражениях?"
    cass "在想着伟大的战役？"

# game/a2/4council.rpy:14
translate english council_b6626098:

    # me "А?"
    me "啊？"

# game/a2/4council.rpy:15
translate english council_0c922b4e:

    # cass "Так задумчиво пялишься на горизонт, наверняка представляешь себе грандиозные битвы, что не раз бушевали за стенами замка."
    cass "你如此若有所思地凝视着地平线，一定是在想象城堡墙外不止一次肆虐过的宏大战斗。"

# game/a2/4council.rpy:16
translate english council_560ee03b:

    # me "Ага. Именно об этом и думаю."
    me "对。我正是在想这个。"

# game/a2/4council.rpy:17
translate english council_1e4e6d55:

    # cass "Не хочешь немного поучаствовать?"
    cass "不想稍微参与一下吗？"

# game/a2/4council.rpy:18
translate english council_d768acb4:

    # me "В битвах?"
    me "参与战斗？"

# game/a2/4council.rpy:19
translate english council_774c0e60:

    # cass "Ну почти."
    cass "嗯，差不多。"

# game/a2/4council.rpy:21
translate english council_6158f5ab:

    # cass "Ты же знаешь, любая битва начинается не со звона железа, а со слов за большим столом."
    cass "你知道的，任何战斗都不是从金铁交鸣开始，而是从大桌旁的言辞开始。"

# game/a2/4council.rpy:22
translate english council_d355dc3b:

    # me "О чем ты?"
    me "你在说什么？"

# game/a2/4council.rpy:23
translate english council_e0382f63:

    # cass "Слышал про Совет Семерых?"
    cass "听说过七人议会吗？"

# game/a2/4council.rpy:24
translate english council_74f7e385:

    # me "Тот, что помогает королю вести дела?"
    me "就是那个辅佐国王处理事务的？"

# game/a2/4council.rpy:25
translate english council_3332d148:

    # cass "Ага. Именно он. Король не может в одиночку справляться со всем, так что декларирует некоторые свое полномочия совету."
    cass "对。就是它。国王没法独自应付一切，所以将部分权力授予议会。"

# game/a2/4council.rpy:27
translate english council_d6dc3bac:

    # cass "А сам в это время часами смотрит на то как ему...кланяются."
    cass "而他自己这时就花好几个小时看别人向他……鞠躬。"

# game/a2/4council.rpy:28
translate english council_3820771a:

    # me "..."
    me "..."

# game/a2/4council.rpy:29
translate english council_f95c9fc9:

    # me "И?"
    me "所以呢？"

# game/a2/4council.rpy:30
translate english council_5b78b35f:

    # cass "Хочешь стать одним из советников?"
    cass "想成为其中一位顾问吗？"

# game/a2/4council.rpy:31
translate english council_a34f030c:

    # me "Их назначает король."
    me "他们是国王任命的。"

# game/a2/4council.rpy:32
translate english council_cd29f4cf:

    # cass "Не всех. Он назначает шестерых, они и выбирают седьмого."
    cass "并非全部。他任命六位，由他们选出第七位。"

# game/a2/4council.rpy:33
translate english council_e0f1d565:

    # me "И меня выбрали седьмым?"
    me "所以我被选为第七个了？"

# game/a2/4council.rpy:34
translate english council_42633de8:

    # cass "Слушай, давай я просто тебе все покажу, пойдем."
    cass "听着，我直接带你去看吧，我们走。"

# game/a2/4council.rpy:36
translate english council_e21eef2b:

    # cass "Все уже собрались. Ждут только нас."
    cass "所有人都到齐了。就等我们了。"

# game/a2/4council.rpy:37
translate english council_0973ffc3:

    # me "Я конечно не великий математик, но нас здесь явно не семеро."
    me "我当然不是什么伟大的数学家，但我们这儿显然没有七个人。"

# game/a2/4council.rpy:38
translate english council_7b3d2ecf:

    # pretor "[cass]...Принц."
    pretor "[cass]……王子。"

# game/a2/4council.rpy:40
translate english council_50b2ebc8:

    # me "Рад вас видеть..."
    me "很高兴见到你们……"

# game/a2/4council.rpy:41
translate english council_b1056f98:

    # pretor "Меня зовут Преториус. Я башенный советник."
    pretor "我叫Pretorius。我是高塔顾问。"

# game/a2/4council.rpy:42
translate english council_313d1b17:

    # me "Магия."
    me "魔法。"

# game/a2/4council.rpy:43
translate english council_9a9b10be:

    # pretor "Совершенно верно."
    pretor "完全正确。"

# game/a2/4council.rpy:45
translate english council_23469b19:

    # calah "Кэлахан. Золотой советник. Торговля."
    calah "Callahan。黄金顾问。贸易。"

# game/a2/4council.rpy:46
translate english council_f49e9625:

    # me "Я вас кажется помню..."
    me "我好像记得您……"

# game/a2/4council.rpy:47
translate english council_7c5d2d2b:

    # calah "Возможно. Я был в совете еще до вашего...отбытия со двора."
    calah "可能吧。在您……离开宫廷之前，我就在议会里了。"

# game/a2/4council.rpy:48
translate english council_d81785f2:

    # me "Вы молодо выглядите. Сколько вам было, когда вы вступили в должность?"
    me "您看起来很年轻。您就任时多大年纪？"

# game/a2/4council.rpy:49
translate english council_bfdc9d0b:

    # calah "Не больше чем вам сейчас, но талант тут не при чем. Должность перешла ко мне по наследству."
    calah "不比您现在大，但这跟天赋无关。这个职位是我继承来的。"

# game/a2/4council.rpy:50
translate english council_9dcec6e6:

    # cass "Как скромно."
    cass "真谦虚。"

# game/a2/4council.rpy:51
translate english council_cfd76e08:

    # calah "Ну...какие-никакие навыки у меня конечно есть. Если любишь аранское золотое - обращайся. Я главный поставщик в городе."
    calah "嗯……一些技能我当然是有的。要是你喜欢阿兰金酒——来找我。我是城里最大的供应商。"

# game/a2/4council.rpy:53
translate english council_8f576383:

    # arcadia "Леди Аркадия. Бумажный советник. Дипломатия."
    arcadia "Arcadia夫人。文书顾问。外交。"

# game/a2/4council.rpy:54
translate english council_b22d1d9b:

    # arcadia "Может уже сядете?"
    arcadia "或许你们该坐下了？"

# game/a2/4council.rpy:55
translate english council_8058cc66:

    # cass "А где король?"
    cass "国王在哪儿？"

# game/a2/4council.rpy:56
translate english council_2cf46c64:

    # arcadia "Сегодня заседание совета пройдет без короля."
    arcadia "今天的议会会议将在国王缺席的情况下进行。"

# game/a2/4council.rpy:57
translate english council_cd30af19:

    # cass "Как обычно."
    cass "跟往常一样。"

# game/a2/4council.rpy:58
translate english council_e02b7ad1:

    # arcadia "Можно подумать ты сильно расстроена."
    arcadia "还以为你很失望呢。"

# game/a2/4council.rpy:60
translate english council_ae3fce0c:

    # arcadia "Это место для короля."
    arcadia "这是国王的位置。"

# game/a2/4council.rpy:61
translate english council_7ba1c5ec:

    # cass "Действительно. По-королевски удобно."
    cass "确实。皇家级别的舒适。"

# game/a2/4council.rpy:62
translate english council_0939a86b:

    # arcadia "На этом месте дозволено сидеть только королю."
    arcadia "这个位置只允许国王坐。"

# game/a2/4council.rpy:63
translate english council_616f3e47:

    # cass "Мне послышалось или кто-то говорил, что его сегодня не будет."
    cass "是我听错了，还是有人说过他今天不会来。"

# game/a2/4council.rpy:64
translate english council_b81f1f9a:

    # arcadia "Это еще не значит..."
    arcadia "那不意味着……"

# game/a2/4council.rpy:65
translate english council_c57c623e:

    # cass "Клянусь всеми богами, как только его королевское величество придет на заседание я не только уступлю ему место, но и извинюсь."
    cass "我向所有神明发誓，一旦国王陛下驾临会议，我不仅会把位置让给他，还会道歉。"

# game/a2/4council.rpy:66
translate english council_b4468529:

    # me "А где мне сесть?"
    me "那我坐哪儿？"

# game/a2/4council.rpy:67
translate english council_5bb38944:

    # arcadia "Судя по всему где хочешь."
    arcadia "看来你想坐哪儿都行。"

# game/a2/4council.rpy:69
translate english council_a0415c3d:

    # cass "Можем начинать?"
    cass "我们可以开始了吗？"

# game/a2/4council.rpy:70
translate english council_47e0a119:

    # arcadia "Начни с того, зачем ты привела сюда принца."
    arcadia "先从你为什么把王子带到这儿开始说起吧。"

# game/a2/4council.rpy:71
translate english council_b61babb7:

    # cass "Очень просто - это наш новый советник-консул."
    cass "很简单——这是我们新任的执政顾问。"

# game/a2/4council.rpy:72
translate english council_2b610e34:

    # arcadia "Ты серьезно?"
    arcadia "你是认真的？"

# game/a2/4council.rpy:73
translate english council_6205130f:

    # cass "Есть идеи получше?"
    cass "有更好的主意吗？"

# game/a2/4council.rpy:74
translate english council_c331a8f4:

    # arcadia "Я же сказала, мы будем брать в совет только тех, кто будет абсолютно беспристрастен. У тебя и так два голоса вместо положенного одного."
    arcadia "我说过了，我们只会让绝对公正无私的人进入议会。你一人本来就该只有一票，现在已经有两票了。"

# game/a2/4council.rpy:75
translate english council_8c2e23b6:

    # cass "Эй! Он мне глаз выколол, если и есть человек с которым нас не связывает общий интерес - то это принц."
    cass "嘿！他戳瞎了我一只眼睛，如果说有谁跟我绝对没有共同利益，那就是王子。"

# game/a2/4council.rpy:76
translate english council_4991ef4c:

    # arcadia "..."
    arcadia "..."

# game/a2/4council.rpy:78
translate english council_0458bfc2:

    # calah "Я согласен. Принц не был при дворе столько лет, что его едва ли можно уличить в связях с нашим новым платяным советником."
    calah "我同意。王子离宫这么多年，很难指认他和我们的新任间谍顾问有任何联系。"

# game/a2/4council.rpy:79
translate english council_f0952db0:

    # me "Это..."
    me "那是……"

# game/a2/4council.rpy:80
translate english council_17632b3f:

    # cass "Это я. Отвечаю за шпионские сети."
    cass "那是我。负责间谍网络。"

# game/a2/4council.rpy:81
translate english council_d05e1553:

    # calah "Я голосую за."
    calah "我投赞成票。"

# game/a2/4council.rpy:82
translate english council_82841efd:

    # cass "Я тоже за. Еще один голос."
    cass "我也赞成。多了一票。"

# game/a2/4council.rpy:84
translate english council_683bd930:

    # pretor "Я много слышал о принце от его сестры, ее слова не оставляют сомнений в отсутствии у него злонамеренности. По крайней мере пока что."
    pretor "我从他姐姐那里听说过很多关于王子的事，她的话让我毫不怀疑他并无恶意。至少目前如此。"

# game/a2/4council.rpy:85
translate english council_524c12a3:

    # cass "Вот и решили. Мой брат теперь новый советник-консул."
    cass "那就决定了。我弟弟现在是新任执政顾问了。"

# game/a2/4council.rpy:86
translate english council_0088fd7b:

    # pretor "Я еще не сказал да."
    pretor "我还没说同意呢。"

# game/a2/4council.rpy:87
translate english council_835e8377:

    # cass "Что же мешает?"
    cass "是什么在阻碍呢？"

# game/a2/4council.rpy:88
translate english council_7491c179:

    # pretor "Мнение самого принца."
    pretor "王子自己的意见。"

# game/a2/4council.rpy:89
translate english council_0be3de84:

    # cass "Он согласен."
    cass "他会同意的。"

# game/a2/4council.rpy:90
translate english council_1c0cc5a1:

    # arcadia "А он не может сказать за себя."
    arcadia "他就不能为自己说话吗。"

# game/a2/4council.rpy:92
translate english council_be4b002f:

    # me "Отказываться от такой должности было бы неразумно."
    me "拒绝这样一个职位是不明智的。"

# game/a2/4council.rpy:93
translate english council_49744988:

    # arcadia "Может сначала тебе стоило бы узнать, почему совет вообще наполовину опустел и почему в нем заседает твоя сестра."
    arcadia "或许你应该先弄清楚，为什么议会的席位空了一半，为什么你姐姐会坐在这里。"

# game/a2/4council.rpy:94
translate english council_7f317273:

    # me "Мама...королева рассказала мне о недавней...ситуации."
    me "母后……王后跟我说了最近的……情况。"

# game/a2/4council.rpy:95
translate english council_7f1e6c58:

    # arcadia "В таком случае ты понимаешь, что мы не потерпим вредительства в совете."
    arcadia "既然如此，你该明白，我们不会容忍议会出现破坏行为。"

# game/a2/4council.rpy:96
translate english council_400c8d6f:

    # cass "Это угроза принцу?"
    cass "这是在威胁王子吗？"

# game/a2/4council.rpy:98
translate english council_daf86a81:

    # arcadia "Ты нам скажи, это же ты убила всех этих прорицателей."
    arcadia "你来告诉我们，是你杀了所有那些先知。"

# game/a2/4council.rpy:99
translate english council_4848e131:

    # cass "Охх, какой ужас. Как жаль этих ублюдков, если хочешь я могу пройтись по нищим кварталам и привести еще парочку."
    cass "哦，真可怕。真为那些混蛋可惜，如果你愿意，我可以去贫民区走走，再带几个过来。"

# game/a2/4council.rpy:100
translate english council_51b832b8:

    # arcadia "Я говорю лишь о том, что это не такая простая должность."
    arcadia "我只是在说，这个职位并不那么简单。"

# game/a2/4council.rpy:101
translate english council_fedf9c29:

    # cass "Советник-консул не участвует в обсуждениях, только принимает решение, если голоса остальных советников разделились и приносит финальные предложения совета королю."
    cass "执政顾问不参与讨论，只在其他顾问票数相等时做出决定，并将议会的最终提案呈交给国王。"

# game/a2/4council.rpy:102
translate english council_1094302d:

    # arcadia "Тебе напомнить, какая резня началась в прошлый раз, когда паритет в совете был нарушен?"
    arcadia "需要我提醒你，上次议会的均势被打破时，爆发了怎样的屠杀吗？"

# game/a2/4council.rpy:103
translate english council_cc0657c7:

    # cass "Не нужно, я ведь и устроила эту резню."
    cass "不用，那场屠杀就是我发动的。"

# game/a2/4council.rpy:104
translate english council_ecad29d9:

    # pretor "Прекратите ваш спор, я ничего у вас не спрашивал. Ты хочешь заседать в совете, [mename]?"
    pretor "停止你们的争吵，我什么都没问你们。你想在议会中占有一席之地吗，[mename]？"

# game/a2/4council.rpy:105
translate english council_fc30fd2b:

    # me "Да."
    me "是的。"

# game/a2/4council.rpy:107
translate english council_2a632b21:

    # calah "Ну тогда мои поздравления новому советнику-консулу."
    calah "那就祝贺新任执政顾问了。"

# game/a2/4council.rpy:108
translate english council_e99d8959:

    # me "Спасибо! Я только одного понять не могу."
    me "谢谢！只有一件事我搞不明白。"

# game/a2/4council.rpy:110
translate english council_54c64b54:

    # cass "Что не так?"
    cass "怎么了？"

# game/a2/4council.rpy:111
translate english council_5e5bb21a:

    # me "Ты убила всех проповедников..."
    me "你杀了所有的先知……"

# game/a2/4council.rpy:112
translate english council_5ffd3712:

    # cass "Ну не я лично их всех убивала, они и сами неплохо справлялись."
    cass "嗯，并非我亲手杀了他们所有人，他们自己也内斗得挺厉害的。"

# game/a2/4council.rpy:113
translate english council_a2c04cc5:

    # me "После этого ты заняла место в совете. А два остальных?"
    me "在那之后，你在议会里得到了一个席位。那另外两个呢？"

# game/a2/4council.rpy:114
translate english council_7c7c339a:

    # cass "Погоди, ты думал я буду так рисковать всего за одно место в совете?"
    cass "等等，你以为我会只为一个议会席位冒这么大的险吗？"

# game/a2/4council.rpy:116
translate english council_0ea7e289:

    # guran "А вот и я."
    guran "我来了。"

# game/a2/4council.rpy:117
translate english council_1d1edb11:

    # arcadia "Как всегда опоздал и как всегда воняешь навозом."
    arcadia "一如既往地迟到，一如既往地散发着马粪味。"

# game/a2/4council.rpy:118
translate english council_62f66d5e:

    # guran "Ну...должность каменного советника требует следить за всеми углами королевского двора, даже за теми, где лежит конский навоз."
    guran "嗯……磐石顾问的职责要求我巡视王宫的每一个角落，连堆马粪的地方也不例外。"

# game/a2/4council.rpy:119
translate english council_4f29dfd4:

    # cass "Здравствуй, дядя."
    cass "你好，叔叔。"

# game/a2/4council.rpy:120
translate english council_1fdf8b16:

    # me "{i}Дядя? Он занимает должность в совете. [cass] выменяла убийство проповедников сразу на два места в совете.{/i}"
    me "{i}叔叔？他在议会里任职。[cass]用屠杀先知换来了议会的两个席位。{/i}"

# game/a2/4council.rpy:121
translate english council_c95bc4ce:

    # guran "А что здесь делает принц?"
    guran "王子在这里做什么？"

# game/a2/4council.rpy:122
translate english council_a64d7eff:

    # arcadia "Это наш новый советник-консул."
    arcadia "这是我们新任的执政顾问。"

# game/a2/4council.rpy:124
translate english council_900ce2c6:

    # arcadia "Убери свои руки."
    arcadia "把你的手拿开。"

# game/a2/4council.rpy:125
translate english council_5d79f4b8:

    # cass "Ты еще не устал?"
    cass "你还没累吗？"

# game/a2/4council.rpy:126
translate english council_35dbe149:

    # cass "После заседания присоединишься ко мне в термах?"
    cass "会议结束后一起去浴场吗？"

# game/a2/4council.rpy:127
translate english council_e93d1307:

    # cass "Ну подумай. Если что - знаешь где меня искать."
    cass "你想想吧。如果有需要——你知道在哪儿能找到我。"

# game/a2/4council.rpy:129
translate english council_09446f97:

    # guran "Вообще-то я предлагал на это должность более опытных кандидатов."
    guran "其实我为这个职位推荐了更有经验的候选人。"

# game/a2/4council.rpy:130
translate english council_3a5bd134:

    # arcadia "Ага. Мало нам двух человек из вашего семейства в совете."
    arcadia "是啊。议会里你们家族的人已经有两个，够多了。"

# game/a2/4council.rpy:131
translate english council_fb934d1e:

    # guran "Ты что-то имеешь против нашей семьи?"
    guran "你对我们家族有什么意见吗？"

# game/a2/4council.rpy:132
translate english council_d81c0f9c:

    # cass "Успокойся, дядя, [mename] отлично справится со своей новой должностью. Я его знаю."
    cass "冷静点，叔叔，[mename]会胜任他的新职位的。我了解他。"

# game/a2/4council.rpy:133
translate english council_947ad7f8:

    # cass "А ты, Аркадия, не забывай, что [mename] тоже моя семья."
    cass "Arcadia，你可别忘了，[mename]也是我的家人。"

# game/a2/4council.rpy:134
translate english council_aeac634b:

    # arcadia "Этого я и боюсь. Если вы нарушите паритет в совете опять..."
    arcadia "我担心的就是这个。如果你们再次打破议会的均势……"

# game/a2/4council.rpy:135
translate english council_cc3afb8a:

    # guran "Мы предлагаем хоть кого-то, ты только вечно всем недовольна, Аркадия."
    guran "好歹我们在提议人选，你总是对什么都不满，Arcadia。"

# game/a2/4council.rpy:136
translate english council_02a8fed9:

    # cass "Тут мой дядя прав."
    cass "这点我叔叔说得对。"

# game/a2/4council.rpy:137
translate english council_eb70233d:

    # arcadia "Прав? Я хочу найти человека, который будет идеален на должности советника, а не на должности твоего говорящего попугая."
    arcadia "说得对？我想找一个对顾问职位最合适的人选，而不是当你的应声虫的人选。"

# game/a2/4council.rpy:138
translate english council_00c2c579:

    # guran "Ты на что намекаешь?"
    guran "你暗示什么？"

# game/a2/4council.rpy:140
translate english council_b7a92771:

    # pretor "Замолчите. Каждое заседание одно и то же."
    pretor "闭嘴吧。每次开会都这样。"

# game/a2/4council.rpy:141
translate english council_5b12a01f:

    # pretor "Мы уже нашли консула. Не открывайте рты за зря. Давайте лучше обсудим как доукомплектовать совет."
    pretor "我们已经找到执政官了。别白白浪费口舌。最好讨论一下怎么补足议会剩下的空缺。"

# game/a2/4council.rpy:142
translate english council_28899b74:

    # me "Разве советников назначает не король?"
    me "难道顾问不是由国王任命的吗？"

# game/a2/4council.rpy:143
translate english council_602a292e:

    # pretor "В последнее время король слегка разубедился в своих силах, стал легко внушаем, иначе каждый в этом совете был бы назначен королем."
    pretor "最近国王对自己的能力有点丧失信心，变得容易受人影响，否则这个议会里的每一个人都应该是由国王任命的。"

# game/a2/4council.rpy:144
translate english council_4aa96b44:

    # cass "Попрошу. Разве весь оставшийся совет не просил назначить меня платяным советником?"
    cass "请注意你的言辞。难道不是整个现有议会都请求任命我为间谍顾问的吗？"

# game/a2/4council.rpy:145
translate english council_1c25974f:

    # pretor "Это было условие нашей сделки, ты очищаешь совет от заразы и получаешь место за столом, одно место."
    pretor "那是我们交易的条件，你清除议会里的祸害，然后在桌上得到一个席位，一个席位。"

# game/a2/4council.rpy:146
translate english council_18288749:

    # cass "Простите, король сам захотел назначить моего дядю."
    cass "抱歉，是国王自己想要任命我的叔叔。"

# game/a2/4council.rpy:147
translate english council_fe13a687:

    # pretor "В том состоянии духа, в котором он пребывал недавно он бы и осла назначил в совет."
    pretor "以他最近所处的那种精神状态，他连头驴都会任命进议会。"

# game/a2/4council.rpy:149
translate english council_8afc54af:

    # guran "Так. Ну это уже точно нельзя трактовать иначе как оскорбление."
    guran "够了。这话绝对只能被视为侮辱。"

# game/a2/4council.rpy:150
translate english council_3eb92cb1:

    # cass "Дядя, успокойся."
    cass "叔叔，冷静。"

# game/a2/4council.rpy:151
translate english council_32df218f:

    # calah "Думаю всем будет спокойнее, если мы договоримся никого не советовать королю на должность железного советника."
    calah "我觉得，如果我们能约定好，不向国王推荐任何铁血顾问的人选，大家都会更安心。"

# game/a2/4council.rpy:152
translate english council_63f108ae:

    # cass "Это будет не сложно, с недавнего времени он ни с кем не говорит."
    cass "这倒不难，最近他跟谁都不说话。"

# game/a2/4council.rpy:154
translate english council_9d7b31b6:

    # arcadia "Кроме советника-консула, а по совместительству его сына, верно?"
    arcadia "除了执政顾问，顺便也是他的儿子，对吧？"

# game/a2/4council.rpy:155
translate english council_150dc213:

    # me "Вы хотите что-то сказать?"
    me "你想说什么？"

# game/a2/4council.rpy:156
translate english council_68e00a3b:

    # arcadia "Ты же понимаешь, что если паритет в совете нарушится, кризис повторится?"
    arcadia "你明白的，如果议会的均势被打破，危机将重演。"

# game/a2/4council.rpy:157
translate english council_d612bdc6:

    # cass "Не надо на него давить."
    cass "别给他施加压力。"

# game/a2/4council.rpy:158
translate english council_0832bf37:

    # arcadia "Я не давлю, просто хочу убедиться, что он понимает, что если сюда придет еще один твой друг то каждое решение будет приниматься с голосами три на три."
    arcadia "我不是在施压，只是想确认他明白，如果再有一个你的朋友进来，那么每个决定都会以三票对三票来产生。"

# game/a2/4council.rpy:159
translate english council_931cf696:

    # guran "И что?"
    guran "那又怎样？"

# game/a2/4council.rpy:160
translate english council_1bc73bd1:

    # arcadia "Это будет хуже для тебя, [mename], они будут давить на тебя."
    arcadia "这对你更糟，[mename]，他们会向你施压。"

# game/a2/4council.rpy:161
translate english council_19f462b2:

    # guran "А вы на него давить не будете?"
    guran "那您就不会向他施压吗？"

# game/a2/4council.rpy:162
translate english council_1d6ada48:

    # arcadia "Кто вы? Я, Преториус и Калахан здесь давно, наше мнение часто разделяется, чего не скажешь про ваш с племянницей унисон."
    arcadia "谁们是'你们'？我、Pretorius和Callahan在这里很久了，我们的意见常常不合，这跟你们姑侄俩的异口同声可不一样。"

# game/a2/4council.rpy:163
translate english council_2dab7df0:

    # arcadia "Пообещай, [mename], пообещай, что не станешь советовать королю на должность железного советника никого из окружения твоей сестры."
    arcadia "答应我，[mename]，答应我你不会向国王推荐你姐姐身边的任何人担任铁血顾问一职。"

# game/a2/4council.rpy:168
translate english council_b7d9386d:

    # me "Думаю это будет справедливым. Паритет в совете лучше не нарушать."
    me "我觉得这很公平。议会的均势最好不要打破。"

# game/a2/4council.rpy:169
translate english council_e59dba99:

    # arcadia "Вот и отлично."
    arcadia "那就好极了。"

# game/a2/4council.rpy:173
translate english council_f8254707:

    # me "Ты же сама сказала, что нужно выбирать на место советника самого лучшего."
    me "你自己说的，应该为顾问职位选择最优秀的人。"

# game/a2/4council.rpy:174
translate english council_2965ead3:

    # me "Если вдруг у меня и получится повлиять на мнение отца, я не стану противится назначению хорошего военного, только потому что он как-либо связан с моей сестрой."
    me "如果我真能影响到父皇的看法，我不会因为一位优秀的将领跟我姐姐有任何关联，就去反对任命他。"

# game/a2/4council.rpy:175
translate english council_42a1fe23:

    # arcadia "Это...это ошибка."
    arcadia "这是……这是个错误。"

# game/a2/4council.rpy:177
translate english council_7e306e66:

    # cass "Какое мудрое решение, мы явно не прогадали с выбором советника-консула."
    cass "多么明智的决定，我们选择执政顾问显然是押对宝了。"

# game/a2/4council.rpy:178
translate english council_ebe18684:

    # arcadia "Посмотрим на следующем собрании."
    arcadia "下次会议上见分晓吧。"

# game/a2/4council.rpy:180
translate english council_fd79f58a:

    # cass ""
    cass "呵..."

# game/a2/4council.rpy:181
translate english council_4b8b0a97:

    # calah "Надеюсь король не будет временить с выбором последнего советника. Мне надоело каждое собрание обсуждать одно и то же и при этом не принимать никаких решений."
    calah "希望国王任命最后一位顾问不要拖太久。我厌倦了每次开会都讨论同一件事，却又无法做出任何决定。"

# game/a2/4council.rpy:182
translate english council_8941486f:

    # pretor "На этом собрание окончено. Я сообщу когда будет следующее, либо вы узнаете сами, если король назначит железного советника."
    pretor "本次会议结束。下次会议时间我会通知，或者如果国王任命了铁血顾问，你们自己会知道的。"

# game/a2/4council.rpy:183
translate english council_44243fb2:

    # calah "Ага. Всем до встречи."
    calah "好。大家回见。"

# game/a2/4council.rpy:189
translate english council2_e5f03b14:

    # "Собрание окончено, [cass] звала меня в термы, но может я могу немного задержаться?"
    "会议结束了，[cass]叫我去浴场，不过或许我可以稍微晚点去待一会儿？"

# game/a2/4council.rpy:216
translate english council_pret_4d5b64e8:

    # "Я уже говорил с ним"
    "I've already talked to him"

# game/a2/4council.rpy:220
translate english council_pret_b0a5e44b:

    # pretor "Собрание окончено, [mename], ты можешь идти."
    pretor "会议结束了，[mename]，你可以走了。"

# game/a2/4council.rpy:221
translate english council_pret_43610ba0:

    # me "Я знаю, я хотел кое-что спросить."
    me "我知道，我想问点事情。"

# game/a2/4council.rpy:222
translate english council_pret_fc5765ec:

    # pretor "Конечно, присаживайся, спрашивай."
    pretor "当然，坐下吧，问吧。"

# game/a2/4council.rpy:224
translate english council_pret_b10a1bc6:

    # me "У меня довольно необычный вопрос... Возможно ли что два человека, с магическими способностями, разумеется, могут при определенных обстоятельствах..."
    me "我有一个相当不寻常的问题……有没有可能，两个人，当然是有魔法能力的人，在特定情况下……"

# game/a2/4council.rpy:225
translate english council_pret_08da288b:

    # pretor "Читать мысли друг друга?"
    pretor "能读取彼此的想法？"

# game/a2/4council.rpy:226
translate english council_pret_7ecff054:

    # me "Что? Как вы..."
    me "什么？您怎么……"

# game/a2/4council.rpy:227
translate english council_pret_c6e517c0:

    # pretor "Твоя сестра спрашивала об этом у меня с утра."
    pretor "你姐姐早上就问过我这个问题了。"

# game/a2/4council.rpy:228
translate english council_pret_84755e17:

    # me "Оу..."
    me "哦……"

# game/a2/4council.rpy:229
translate english council_pret_3d98e2f2:

    # pretor "Я не думаю, что в этом замешана обычная магия. Во всяком случае я никогда о таком не слышал."
    pretor "我不认为这和寻常的魔法有关。至少我从未听说过此类事情。"

# game/a2/4council.rpy:230
translate english council_pret_ae5da08e:

    # me "Обычная магия? Есть какая-то другая?"
    me "寻常的魔法？还有其他种类的？"

# game/a2/4council.rpy:231
translate english council_pret_6efe5113:

    # pretor "Кровная магия."
    pretor "血魔法。"

# game/a2/4council.rpy:233
translate english council_pret_729a116d:

    # pretor "Я знаю, что в некоторых башнях экспериментировали с магией на крови, это позволяло чувствовать тело другого человека на расстоянии, его боль и удовольствие."
    pretor "我知道有些法师塔尝试过血魔法，它能让人远距离感受到另一个人的身体、痛苦和愉悦。"

# game/a2/4council.rpy:234
translate english council_pret_da973182:

    # me "А мысли?"
    me "那思想呢？"

# game/a2/4council.rpy:235
translate english council_pret_769c245f:

    # pretor "Нет. О таком я не слышал. Но если магия способна на передачу ощущений почему бы он не могла бы делать то же самое с мыслями?"
    pretor "不。这我没听说过。不过，如果魔法能传递感觉，为什么不能对思想做同样的事呢？"

# game/a2/4council.rpy:236
translate english council_pret_1d2fdc07:

    # me "Я слышал...я буквально слышал ее слова у себя в голове...каждое слово...четко и ясно."
    me "我听到了……我确实在脑海中听到了她的言语……每一个字……清晰分明。"

# game/a2/4council.rpy:237
translate english council_pret_a1882d1a:

    # pretor "В тебе непростая кровь, [mename], Elentári melda, кровь величайших эльфийских магов течет в тебе."
    pretor "你体内流淌着不寻常的血，[mename]，Elentári melda，最伟大的精灵法师的血在你体内流淌。"

# game/a2/4council.rpy:238
translate english council_pret_c151a8dc:

    # pretor "К тому же вы близнецы. У вас есть связь с самого рождения. Может магия, что течет в ваших с сестрой венах усиливает эту связь."
    pretor "而且你们是双胞胎。你们自出生起就存在联系。也许是流淌在你和你姐姐血管里的魔法增强了这种联系。"

# game/a2/4council.rpy:239
translate english council_pret_77be1c75:

    # me "Возможно..."
    me "或许吧……"

# game/a2/4council.rpy:240
translate english council_pret_60b8e2ff:

    # pretor "Я ответил на твой вопрос?"
    pretor "我回答了你的问题吗？"

# game/a2/4council.rpy:241
translate english council_pret_1d35527f:

    # me "Да. Спасибо, Преториус."
    me "是的。谢谢你，Pretorius。"

# game/a2/4council.rpy:242
translate english council_pret_924d060b:

    # pretor "Обращайся в любое время."
    pretor "随时可以来找我。"

# game/a2/4council.rpy:247
translate english council_arc_1199ad1b:

    # "Я уже говорил с ней"
    "I've already talked to her"

# game/a2/4council.rpy:251
translate english council_arc_e453a446:

    # arcadia "Ты можешь идти."
    arcadia "你可以走了。"

# game/a2/4council.rpy:252
translate english council_arc_fc33ba08:

    # me "Да, я знаю, у меня... личное."
    me "是的，我知道，我有点……私事。"

# game/a2/4council.rpy:253
translate english council_arc_9857f9b7:

    # arcadia "Личное? Мне не нужен молодой любовник."
    arcadia "私事？我可不需要年轻的情人。"

# game/a2/4council.rpy:254
translate english council_arc_d881f801:

    # me "Что? Нет. Вы же дипломат."
    me "什么？不。您是外交官。"

# game/a2/4council.rpy:255
translate english council_arc_b888c24b:

    # arcadia "Да."
    arcadia "对。"

# game/a2/4council.rpy:256
translate english council_arc_294ee3da:

    # me "Наверняка знаете много языков, среди них есть эльфийский?"
    me "您肯定懂很多种语言，其中包括精灵语吗？"

# game/a2/4council.rpy:257
translate english council_arc_ece82aa9:

    # arcadia "Да. Почему ты спрашиваешь?"
    arcadia "懂的。你为什么这么问？"

