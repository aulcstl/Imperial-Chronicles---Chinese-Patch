# game/a2/10royal_dinner.rpy:232
translate english royal_dinner_b5ccc246:

    # elin "Я не стану жить жизнью простой жены дворянина. Не стану рожать ему детей."
    elin "我不会过那种普通贵族妻子的生活。我不会给他生孩子。"

# game/a2/10royal_dinner.rpy:233
