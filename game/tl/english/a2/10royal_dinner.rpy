    me "{i}嗯……{/i}"

# game/a2/10royal_dinner.rpy:293
translate english royal_dinner2_ending_233b0c3f:

    # me "{i}О нет...{/i}"
    me "{i}哦不……{/i}"

# game/a2/10royal_dinner.rpy:294
translate english royal_dinner2_ending_be7659e4:

    # me "{i}Только не опять. Все же было хорошо...{/i}"
    me "{i}千万别再来一次了。一切都刚好起来……{/i}"

# game/a2/10royal_dinner.rpy:295
translate english royal_dinner2_ending_8d928dc6:

    # bloodking "[mename]."
    bloodking "[mename]."

# game/a2/10royal_dinner.rpy:296
